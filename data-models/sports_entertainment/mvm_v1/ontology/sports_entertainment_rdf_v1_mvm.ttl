    rdfs:range xsd:string .

ind:incidentLocation rdf:type rdf:Property ;
    rdfs:label 'Incident Location' ;
    rdfs:comment 'Physical or virtual location where the alleged incident or violation occurred.' ;
    rdfs:domain ind:Investigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initiatedDate rdf:type rdf:Property ;
    rdfs:label 'Initiated Date' ;
    rdfs:comment 'Date when the investigation was formally initiated and opened for review.' ;
    rdfs:domain ind:Investigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:investigationStatus rdf:type rdf:Property ;
    rdfs:label 'Investigation Status' ;
    rdfs:comment 'Current lifecycle status of the investigation indicating its progression through the investigative workflow.' ;
    rdfs:domain ind:Investigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationType rdf:type rdf:Property ;
    rdfs:label 'Investigation Type' ;
    rdfs:comment 'Classification of the investigation based on the nature of the alleged violation or incident being investigated.' ;
    rdfs:domain ind:Investigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leadInvestigatorName rdf:type rdf:Property ;
    rdfs:label 'Lead Investigator Name' ;
    rdfs:comment 'Full name of the lead investigator assigned to the case for reference and reporting purposes.' ;
    rdfs:domain ind:Investigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recommendedAction rdf:type rdf:Property ;
    rdfs:label 'Recommended Action' ;
    rdfs:comment 'Recommended corrective actions, sanctions, or remediation measures based on the investigation findings.' ;
    rdfs:domain ind:Investigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryFilingDate rdf:type rdf:Property ;
    rdfs:label 'Regulatory Filing Date' ;
    rdfs:comment 'Date when the investigation findings or incident report was submitted to the relevant regulatory authority. Null if no filing required or not yet submitted.' ;
    rdfs:domain ind:Investigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryFilingRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Filing Required Flag' ;
    rdfs:comment 'Boolean indicator of whether the investigation findings must be reported to external regulatory authorities or governing bodies.' ;
    rdfs:domain ind:Investigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sanctionImposed rdf:type rdf:Property ;
    rdfs:label 'Sanction Imposed' ;
    rdfs:comment 'Description of the actual sanction, penalty, or disciplinary action imposed as a result of the investigation findings.' ;
    rdfs:domain ind:Investigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subjectName rdf:type rdf:Property ;
    rdfs:label 'Subject Name' ;
    rdfs:comment 'Full name of the individual or entity under investigation for identification and reporting purposes.' ;
    rdfs:domain ind:Investigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subjectReference rdf:type rdf:Property ;
    rdfs:label 'Subject Reference' ;
    rdfs:comment 'Unique identifier of the individual or entity that is the primary subject of the investigation. Links to the appropriate master entity based on subject_type.' ;
    rdfs:domain ind:Investigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:subjectType rdf:type rdf:Property ;
    rdfs:label 'Subject Type' ;
    rdfs:comment 'Classification of the primary subject or entity under investigation.' ;
    rdfs:domain ind:Investigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Target Completion Date' ;
    rdfs:comment 'Planned or target date by which the investigation is expected to be completed based on regulatory timelines or internal policies.' ;
    rdfs:domain ind:Investigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:parentCampaignId rdf:type rdf:Property ;
    rdfs:label 'Parent Campaign Id' ;
    rdfs:comment 'Self-referencing FK on campaign (parent_campaign_id)' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Campaign .

ind:actualConversions rdf:type rdf:Property ;
    rdfs:label 'Actual Conversions' ;
    rdfs:comment 'Actual number of conversions achieved by the campaign.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualImpressions rdf:type rdf:Property ;
    rdfs:label 'Actual Impressions' ;
    rdfs:comment 'Actual number of impressions or views delivered by the campaign.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualSpendAmount rdf:type rdf:Property ;
    rdfs:label 'Actual Spend Amount' ;
    rdfs:comment 'Total amount actually spent on the campaign to date in USD.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:campaignCode rdf:type rdf:Property ;
    rdfs:label 'Campaign Code' ;
    rdfs:comment 'Externally-known unique business identifier for the campaign, used in marketing materials and tracking URLs.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:campaignDescription rdf:type rdf:Property ;
    rdfs:label 'Campaign Description' ;
    rdfs:comment 'Detailed narrative describing the campaign objectives, messaging, and creative approach.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:campaignName rdf:type rdf:Property ;
    rdfs:label 'Campaign Name' ;
    rdfs:comment 'Human-readable name of the marketing campaign.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:campaignStatus rdf:type rdf:Property ;
    rdfs:label 'Campaign Status' ;
    rdfs:comment 'Current lifecycle status of the campaign.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:campaignType rdf:type rdf:Property ;
    rdfs:label 'Campaign Type' ;
    rdfs:comment 'Classification of the campaign based on its primary business objective.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isAutomated rdf:type rdf:Property ;
    rdfs:label 'Is Automated' ;
    rdfs:comment 'Indicates whether the campaign is executed through automated marketing workflows (True) or manual execution (False).' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:landingPageUrl rdf:type rdf:Property ;
    rdfs:label 'Landing Page Url' ;
    rdfs:comment 'URL of the landing page where fans are directed when engaging with the campaign.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetAudience rdf:type rdf:Property ;
    rdfs:label 'Target Audience' ;
    rdfs:comment 'Description of the intended fan segment or demographic group targeted by this campaign.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetConversions rdf:type rdf:Property ;
    rdfs:label 'Target Conversions' ;
    rdfs:comment 'Planned number of conversions (ticket purchases, sign-ups, etc.) the campaign aims to achieve.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:targetImpressions rdf:type rdf:Property ;
    rdfs:label 'Target Impressions' ;
    rdfs:comment 'Planned number of impressions or views the campaign aims to achieve.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:trackingCode rdf:type rdf:Property ;
    rdfs:label 'Tracking Code' ;
    rdfs:comment 'Unique tracking or UTM code used to measure campaign performance across analytics platforms.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentTeamId rdf:type rdf:Property ;
    rdfs:label 'Parent Team Id' ;
    rdfs:comment 'Self-referencing FK on team (parent_team_id)' ;
    rdfs:domain ind:Team ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Team .

ind:trainingFacilityId rdf:type rdf:Property ;
    rdfs:label 'Training Facility Id' ;
    rdfs:comment 'Identifier of the primary training facility or practice venue used by the team.' ;
    rdfs:domain ind:Team ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Facility .

ind:championshipCount rdf:type rdf:Property ;
    rdfs:label 'Championship Count' ;
    rdfs:comment 'Total number of league championships or titles won by the team in its history.' ;
    rdfs:domain ind:Team ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:establishedDate rdf:type rdf:Property ;
    rdfs:label 'Established Date' ;
    rdfs:comment 'Date when the team officially joined the current league or was granted franchise status.' ;
    rdfs:domain ind:Team ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fanBaseSize rdf:type rdf:Property ;
    rdfs:label 'Fan Base Size' ;
    rdfs:comment 'Estimated number of registered or tracked fans associated with the team across all engagement platforms.' ;
    rdfs:domain ind:Team ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isExpansionTeam rdf:type rdf:Property ;
    rdfs:label 'Is Expansion Team' ;
    rdfs:comment 'Indicates whether the team was added to the league as an expansion franchise (true) or is an original/relocated team (false).' ;
    rdfs:domain ind:Team ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jerseySponsor rdf:type rdf:Property ;
    rdfs:label 'Jersey Sponsor' ;
    rdfs:comment 'Name of the primary corporate sponsor whose branding appears on team jerseys.' ;
    rdfs:domain ind:Team ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketValue rdf:type rdf:Property ;
    rdfs:label 'Market Value' ;
    rdfs:comment 'Estimated market valuation of the team franchise. Expressed in league\'s base currency.' ;
    rdfs:domain ind:Team ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:marketValueCurrency rdf:type rdf:Property ;
    rdfs:label 'Market Value Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for market value (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:Team ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mascotName rdf:type rdf:Property ;
    rdfs:label 'Mascot Name' ;
    rdfs:comment 'Name of the team\'s official mascot character used for fan engagement and entertainment.' ;
    rdfs:domain ind:Team ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nickname rdf:type rdf:Property ;
    rdfs:label 'Nickname' ;
    rdfs:comment 'Common nickname or informal name used by fans and media to refer to the team.' ;
    rdfs:domain ind:Team ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:playoffAppearances rdf:type rdf:Property ;
    rdfs:label 'Playoff Appearances' ;
    rdfs:comment 'Total number of playoff or postseason appearances by the team in its history.' ;
    rdfs:domain ind:Team ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryColor rdf:type rdf:Property ;
    rdfs:label 'Primary Color' ;
    rdfs:comment 'Primary brand color of the team (hex code or color name). Used for uniforms, branding, and broadcast graphics.' ;
    rdfs:domain ind:Team ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relocationHistory rdf:type rdf:Property ;
    rdfs:label 'Relocation History' ;
    rdfs:comment 'Textual summary of any previous cities or locations where the team was based before current location.' ;
    rdfs:domain ind:Team ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rivalryTeams rdf:type rdf:Property ;
    rdfs:label 'Rivalry Teams' ;
    rdfs:comment 'Comma-separated list of team codes representing traditional rivals or derby opponents.' ;
    rdfs:domain ind:Team ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:teamCode rdf:type rdf:Property ;
    rdfs:label 'Team Code' ;
    rdfs:comment 'Short alphanumeric code or abbreviation for the team (e.g., \'LAL\', \'MUN\', \'NYY\'). Used for broadcast graphics and standings displays.' ;
    rdfs:domain ind:Team ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:teamType rdf:type rdf:Property ;
    rdfs:label 'Team Type' ;
    rdfs:comment 'Classification of the team by competitive level and organizational structure.' ;
    rdfs:domain ind:Team ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryOriginalPaymentRunId rdf:type rdf:Property ;
    rdfs:label 'Primary Original Payment Run Id' ;
    rdfs:comment 'Reference to the original payment run being reversed. Populated only when is_reversal is true. Used to maintain audit trail of corrections.' ;
    rdfs:domain ind:PaymentRun ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PaymentRun .

ind:errorLog rdf:type rdf:Property ;
    rdfs:label 'Error Log' ;
    rdfs:comment 'Detailed error messages and exception logs for failed payments or processing issues. Used for troubleshooting and root cause analysis.' ;
    rdfs:domain ind:PaymentRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:executionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Execution Timestamp' ;
    rdfs:comment 'The precise date and time when the payment run execution began. Critical for audit trails and reconciliation with banking systems.' ;
    rdfs:domain ind:PaymentRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:failedPaymentAmount rdf:type rdf:Property ;
    rdfs:label 'Failed Payment Amount' ;
    rdfs:comment 'The sum of all failed payment amounts that were not disbursed. Represents funds that remain in the company account and require reprocessing.' ;
    rdfs:domain ind:PaymentRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:failedPaymentCount rdf:type rdf:Property ;
    rdfs:label 'Failed Payment Count' ;
    rdfs:comment 'The number of payment transactions that failed during processing due to validation errors, insufficient funds, or system issues. Requires manual intervention.' ;
    rdfs:domain ind:PaymentRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isReversal rdf:type rdf:Property ;
    rdfs:label 'Is Reversal' ;
    rdfs:comment 'Boolean flag indicating whether this payment run is a reversal of a previous run. True indicates reversal, false indicates original payment run.' ;
    rdfs:domain ind:PaymentRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:paymentCurrency rdf:type rdf:Property ;
    rdfs:label 'Payment Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for all payments in this run. All disbursements within a single run are typically in the same currency.' ;
    rdfs:domain ind:PaymentRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentFileFormat rdf:type rdf:Property ;
    rdfs:label 'Payment File Format' ;
    rdfs:comment 'The electronic file format standard used for bank transmission: ISO 20022 for international standard, NACHA for US ACH, BAI2 for bank reporting, MT940 for SWIFT, CAMT.053 for account statements, proprietary for bank-specific formats.' ;
    rdfs:domain ind:PaymentRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentFileName rdf:type rdf:Property ;
    rdfs:label 'Payment File Name' ;
    rdfs:comment 'The name of the electronic payment file generated for bank transmission. Used for file tracking and reconciliation with bank acknowledgments.' ;
    rdfs:domain ind:PaymentRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentRunStatus rdf:type rdf:Property ;
    rdfs:label 'Payment Run Status' ;
    rdfs:comment 'Current lifecycle status of the payment run: draft indicates initial creation, scheduled indicates approved and queued, processing indicates active execution, completed indicates successful finish, failed indicates execution error, cancelled indicates user-terminated run.' ;
    rdfs:domain ind:PaymentRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentTerms rdf:type rdf:Property ;
    rdfs:label 'Payment Terms' ;
    rdfs:comment 'The standard payment terms code applied to invoices included in this run. Defines due date calculation and discount eligibility.' ;
    rdfs:domain ind:PaymentRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reconciliationStatus rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Status' ;
    rdfs:comment 'The status of bank statement reconciliation for this payment run: pending indicates awaiting bank confirmation, reconciled indicates matched with bank statement, discrepancy indicates mismatch requiring investigation, under_review indicates active reconciliation process.' ;
    rdfs:domain ind:PaymentRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:runNumber rdf:type rdf:Property ;
    rdfs:label 'Run Number' ;
    rdfs:comment 'Business-facing unique identifier for the payment run, typically formatted as PR-YYYYMMDD-NNNN for external reference and audit trails.' ;
    rdfs:domain ind:PaymentRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:runType rdf:type rdf:Property ;
    rdfs:label 'Run Type' ;
    rdfs:comment 'Classification of the payment run based on business purpose: standard for regular scheduled runs, emergency for urgent off-cycle payments, supplemental for additional payments, reversal for payment corrections, adjustment for reconciliation runs, interim for partial disbursements.' ;
    rdfs:domain ind:PaymentRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:successfulPaymentAmount rdf:type rdf:Property ;
    rdfs:label 'Successful Payment Amount' ;
    rdfs:comment 'The sum of all successfully processed payment amounts. Used to reconcile actual cash outflows against planned disbursements.' ;
    rdfs:domain ind:PaymentRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:successfulPaymentCount rdf:type rdf:Property ;
    rdfs:label 'Successful Payment Count' ;
    rdfs:comment 'The number of payment transactions that were successfully processed and transmitted to the bank. Used to calculate success rate and identify exceptions.' ;
    rdfs:domain ind:PaymentRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalPaymentAmount rdf:type rdf:Property ;
    rdfs:label 'Total Payment Amount' ;
    rdfs:comment 'The sum of all payment amounts included in this run, expressed in the payment currency. Used for cash position management and bank account reconciliation.' ;
    rdfs:domain ind:PaymentRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalPaymentCount rdf:type rdf:Property ;
    rdfs:label 'Total Payment Count' ;
    rdfs:comment 'The total number of individual payment transactions included in this payment run. Used for reconciliation and control totals.' ;
    rdfs:domain ind:PaymentRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:transmissionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Transmission Timestamp' ;
    rdfs:comment 'The date and time when the payment file was transmitted to the bank. Critical for cut-off time compliance and value dating.' ;
    rdfs:domain ind:PaymentRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:valueDate rdf:type rdf:Property ;
    rdfs:label 'Value Date' ;
    rdfs:comment 'The date on which funds are to be debited from the company account and credited to payee accounts. Used for cash flow forecasting and liquidity management.' ;
    rdfs:domain ind:PaymentRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:parentLedgerId rdf:type rdf:Property ;
    rdfs:label 'Parent Ledger Id' ;
    rdfs:comment 'Self-referencing FK on ledger (parent_ledger_id)' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Ledger .

ind:accountingPrinciple rdf:type rdf:Property ;
    rdfs:label 'Accounting Principle' ;
    rdfs:comment 'The accounting standard or principle governing this ledger (e.g., US GAAP, IFRS, local statutory requirements).' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditTrailLevel rdf:type rdf:Property ;
    rdfs:label 'Audit Trail Level' ;
    rdfs:comment 'The level of audit trail and change tracking maintained for transactions posted to this ledger.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:balanceCarryforwardMethod rdf:type rdf:Property ;
    rdfs:label 'Balance Carryforward Method' ;
    rdfs:comment 'The method used to carry forward account balances from one fiscal year to the next in this ledger.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consolidationLedgerFlag rdf:type rdf:Property ;
    rdfs:label 'Consolidation Ledger Flag' ;
    rdfs:comment 'Indicates whether this ledger is used for group consolidation and intercompany elimination purposes.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:intercompanyEliminationFlag rdf:type rdf:Property ;
    rdfs:label 'Intercompany Elimination Flag' ;
    rdfs:comment 'Indicates whether this ledger includes intercompany elimination entries for consolidated financial reporting.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:leadingLedgerFlag rdf:type rdf:Property ;
    rdfs:label 'Leading Ledger Flag' ;
    rdfs:comment 'Indicates whether this ledger is the leading (primary) ledger for the organization used for statutory reporting and external financial statements.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ledgerCode rdf:type rdf:Property ;
    rdfs:label 'Ledger Code' ;
    rdfs:comment 'Unique business identifier code for the ledger used in financial reporting and system integration. Externally-known identifier.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ledgerDescription rdf:type rdf:Property ;
    rdfs:label 'Ledger Description' ;
    rdfs:comment 'Detailed business description and purpose of the ledger including its scope and intended use cases.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ledgerName rdf:type rdf:Property ;
    rdfs:label 'Ledger Name' ;
    rdfs:comment 'Full descriptive name of the ledger for human-readable identification and reporting purposes.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ledgerStatus rdf:type rdf:Property ;
    rdfs:label 'Ledger Status' ;
    rdfs:comment 'Current lifecycle status of the ledger indicating whether it is available for posting transactions.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ledgerType rdf:type rdf:Property ;
    rdfs:label 'Ledger Type' ;
    rdfs:comment 'Classification of the ledger based on its accounting purpose and scope within the enterprise financial architecture.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parallelAccountingFlag rdf:type rdf:Property ;
    rdfs:label 'Parallel Accounting Flag' ;
    rdfs:comment 'Indicates whether this ledger is used for parallel accounting to support multiple accounting standards simultaneously.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:postingAllowedFlag rdf:type rdf:Property ;
    rdfs:label 'Posting Allowed Flag' ;
    rdfs:comment 'Indicates whether direct financial postings are currently permitted to this ledger.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:retainedEarningsAccount rdf:type rdf:Property ;
    rdfs:label 'Retained Earnings Account' ;
    rdfs:comment 'The general ledger account number used for retained earnings and profit/loss carry-forward in this ledger.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentReportingEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Segment Reporting Enabled Flag' ;
    rdfs:comment 'Indicates whether this ledger supports segment reporting for business unit or geographic financial analysis.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:soxCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Sox Compliant Flag' ;
    rdfs:comment 'Indicates whether this ledger is subject to Sarbanes-Oxley Act internal control requirements and audit trails.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:valuationArea rdf:type rdf:Property ;
    rdfs:label 'Valuation Area' ;
    rdfs:comment 'Code identifying the valuation area or approach used for asset and inventory valuation in this ledger.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentOperatorId rdf:type rdf:Property ;
    rdfs:label 'Parent Operator Id' ;
    rdfs:comment 'Self-referencing FK on operator (parent_operator_id)' ;
    rdfs:domain ind:Operator ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Operator .

ind:amlComplianceProgram rdf:type rdf:Property ;
