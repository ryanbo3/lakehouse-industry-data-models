# RDFS Schema for Business: Sports Entertainment

@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix ind: <http://datamodel.lakehouse.org/business/sports_entertainment#> .

# --- Root Business Class ---
ind:Business rdf:type rdfs:Class ;
    rdfs:label 'Business' ;
    rdfs:comment 'Root class for all business entities' .

# --- Specific Business: Sports Entertainment ---
ind:SportsEntertainment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Business ;
    rdfs:label 'Sports Entertainment' ;
    rdfs:comment 'Sports and Entertainment is a live experience industry operating professional leagues, broadcasting networks, athlete management, venue operations, concerts, and fan engagement platforms across global markets.' .

# --- Domain Classes ---
ind:Event rdf:type rdfs:Class ;
    rdfs:subClassOf ind:SportsEntertainment ;
    rdfs:label 'Event' ;
    rdfs:comment 'Core operational domain managing the full lifecycle of live sports and entertainment events — planning, scheduling, production logistics, competition governance, and game-day execution. Owns event identity, fixture calendars, match results, season structures, tournament brackets, and event lifecycle from announcement through post-event reconciliation. Serves as SSOT for all event-related master data across leagues, concerts, and live experiences.' .

ind:Venue rdf:type rdfs:Class ;
    rdfs:subClassOf ind:SportsEntertainment ;
    rdfs:label 'Venue' ;
    rdfs:comment 'Facility operations domain managing stadium, arena, and concert hall infrastructure including seating inventory, concessions, parking, HVAC systems, building management (BMS), safety compliance (OSHA, ADA), and event-day logistics. Owns venue master data, capacity configurations, accessibility features, and operational readiness for live event execution.' .

ind:Athlete rdf:type rdfs:Class ;
    rdfs:subClassOf ind:SportsEntertainment ;
    rdfs:label 'Athlete' ;
    rdfs:comment 'Talent management domain owning athlete identity, contracts, performance statistics (WAR, ERA, QBR), health records, eligibility status, and career lifecycle. Manages player rosters, draft selections, trades, transfers, injury tracking, NIL agreements, agent relationships, and compliance with league regulations including anti-doping (WADA) and collective bargaining agreements (CBA). Critical for league operations and broadcast content.' .

ind:Fan rdf:type rdfs:Class ;
    rdfs:subClassOf ind:SportsEntertainment ;
    rdfs:label 'Fan' ;
    rdfs:comment 'Primary customer-facing domain and SSOT for all fan identity, demographic, and relationship data. Manages fan profiles, CRM segmentation, loyalty programs, membership tiers, NPS tracking, engagement history, and consent/privacy preferences under GDPR and CCPA. Serves B2C individual fans, family accounts, season ticket holders, VIP members, and fan club memberships across all engagement channels.' .

ind:Ticketing rdf:type rdfs:Class ;
    rdfs:subClassOf ind:SportsEntertainment ;
    rdfs:label 'Ticketing' ;
    rdfs:comment 'Revenue-generating domain managing the end-to-end ticket commerce lifecycle — inventory allocation, GA/VIP/SRO pricing tiers, dynamic pricing models, season ticket packages, group sales, resale marketplace, digital ticket delivery, access control, and PCI-DSS compliant payment processing. Integrates with Ticketmaster/AXS and Archtics for venue seating inventory. SSOT for all ticket transactions and access entitlements.' .

ind:Broadcast rdf:type rdfs:Class ;
    rdfs:subClassOf ind:SportsEntertainment ;
    rdfs:label 'Broadcast' ;
    rdfs:comment 'Media rights and distribution domain managing broadcast schedules, regional sports networks (RSN), OTT/IPTV streaming platforms, PPV event packaging, content delivery networks (CDN), and rights agreements. Owns media asset metadata, live feed distribution, blackout rules, DRM policies, replay content, and multi-platform delivery including linear TV and DTC streaming services. Critical for revenue generation through media rights deals.' .

ind:Sponsorship rdf:type rdfs:Class ;
    rdfs:subClassOf ind:SportsEntertainment ;
    rdfs:label 'Sponsorship' ;
    rdfs:comment 'Partnership and commercial domain managing B2B sponsor contracts, brand activations, advertising inventory, naming rights, and partnership fulfillment. Owns sponsor identity, deal terms, activation deliverables, performance metrics (CPM, GRP), ROI tracking, jersey sponsorships, venue naming rights, broadcast integrations, and digital platform partnerships. Manages the full sponsorship lifecycle from prospecting through renewal.' .

ind:Merchandise rdf:type rdfs:Class ;
    rdfs:subClassOf ind:SportsEntertainment ;
    rdfs:label 'Merchandise' ;
    rdfs:comment 'Product sales and licensing domain managing official team apparel, memorabilia, SKU catalog, inventory, e-commerce transactions via Shopify Plus, POS transactions, and retail operations. Owns product master data, licensing agreements, royalty tracking, IP protection, brand compliance, and omnichannel sales across venue stores, online platforms, and third-party retailers.' .

ind:Content rdf:type rdfs:Class ;
    rdfs:subClassOf ind:SportsEntertainment ;
    rdfs:label 'Content' ;
    rdfs:comment 'Digital asset management domain owning video highlights, photography, social media assets, user-generated content (UGC), audio, and editorial content managed through Dalet Galaxy DAM. Manages content production workflows, metadata tagging, rights clearance (DRM), and CDN distribution for OTT, digital platforms, and social channels. SSOT for all content asset identity and rights metadata.' .

ind:League rdf:type rdfs:Class ;
    rdfs:subClassOf ind:SportsEntertainment ;
    rdfs:label 'League' ;
    rdfs:comment 'Competition governance domain managing league structure, division hierarchies, team franchises, season calendars, standings, officiating (VAR/TMO), rule enforcement, disciplinary actions, and competitive integrity. Owns league identity, franchise agreements, draft rules, salary cap compliance, CBA compliance, and regulatory oversight across professional sports organizations (NFL, NBA, MLB, NHL, MLS, FIFA, IOC).' .

ind:Finance rdf:type rdfs:Class ;
    rdfs:subClassOf ind:SportsEntertainment ;
    rdfs:label 'Finance' ;
    rdfs:comment 'Corporate financial domain owning general ledger, cost centers, budgets, EBITDA reporting, ARR tracking, financial planning and analysis (FP&A), and SOX-compliant financial controls via SAP S/4HANA FI/CO. Manages chart of accounts, revenue recognition, expense allocation, intercompany settlements, and SEC financial reporting for publicly traded entities. SSOT for all enterprise financial master data.' .

ind:Compliance rdf:type rdfs:Class ;
    rdfs:subClassOf ind:SportsEntertainment ;
    rdfs:label 'Compliance' ;
    rdfs:comment 'Regulatory and governance domain managing WADA anti-doping programs, GDPR/CCPA data privacy obligations, PCI-DSS audit trails, ADA accessibility compliance, CAS arbitration case records, and legal case management. Owns regulatory filings, audit schedules, incident tracking, policy enforcement records, and eligibility certifications across all governing bodies.' .

ind:Gaming rdf:type rdfs:Class ;
    rdfs:subClassOf ind:SportsEntertainment ;
    rdfs:label 'Gaming' ;
    rdfs:comment 'Sports wagering and fantasy sports domain managing betting market definitions, odds feeds, responsible gaming compliance, fantasy league structures, prop bet catalogs, and regulatory reporting for licensed gaming operations across jurisdictions.' .

ind:Security rdf:type rdfs:Class ;
    rdfs:subClassOf ind:SportsEntertainment ;
    rdfs:label 'Security' ;
    rdfs:comment 'Event security and physical safety operations domain managing credentialing, access control zones, surveillance systems, crowd management protocols, emergency response plans, and law enforcement coordination for all Sports Entertainment venues and events.' .

# --- Data Product Classes (Tables) ---
ind:Asset rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Content ;
    rdfs:label 'Asset' ;
    rdfs:comment 'Core master entity representing every digital content asset managed in Dalet Galaxy DAM — video highlights, photography, audio clips, editorial articles, social media assets, and UGC. SSOT for all content asset identity, format metadata, file specifications, ingest status, lifecycle state, and tag associations across OTT, broadcast, and digital platforms. Serves as the central node connecting rights, production, distribution, and analytics workflows.' .

ind:ProductionOrder rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Content ;
    rdfs:label 'Production Order' ;
    rdfs:comment 'Transactional record capturing content production work orders within Dalet Galaxy — covering video highlight packages, editorial features (story angle, journalist assignment, word count targets), social cuts, broadcast segments, and commissioned editorial content. Tracks assignment, production stage, priority, deadline, assigned editor/producer, output specifications, delivery status, and editorial approval workflow. Supports both technical production (video editing, audio mixing) and editorial commissioning (articles, features, interviews) as order types.' .

ind:IngestJob rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Content ;
    rdfs:label 'Ingest Job' ;
    rdfs:comment 'Transactional record for each content ingest event into the DAM — capturing source system (OB truck, camera card, social feed, UGC upload), ingest timestamp, file manifest, quality check status, metadata extraction results, and destination storage path. Supports traceability from raw capture to DAM registration.' .

ind:PublishEvent rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Content ;
    rdfs:label 'Publish Event' ;
    rdfs:comment 'Transactional record of each content publication or distribution event — capturing asset, target platform (OTT, social, CDN, broadcast), publish timestamp, distribution status, CDN endpoint, geo-restriction applied, and DRM packaging applied. Provides the audit trail for all content distribution activity.' .

ind:MetadataTag rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Content ;
    rdfs:label 'Metadata Tag' ;
    rdfs:comment 'Master record for controlled vocabulary metadata tags applied to content assets — including sport, league, team, athlete, event, topic, mood, and content type taxonomies. Supports structured tagging for search, discovery, personalization, and rights filtering across the DAM and digital platforms.' .

ind:Collection rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Content ;
    rdfs:label 'Collection' ;
    rdfs:comment 'Master entity representing curated groupings of content assets — highlight reels, editorial playlists, photo galleries, branded content packages, and PPV event content bundles. Tracks collection type, member assets with sequence ordering, curation method (editorial vs. algorithmic), publish status, and associated rights window. Supports ordered playlists, highlight packages, and curated galleries for OTT and digital platform delivery.' .

ind:License rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Content ;
    rdfs:label 'License' ;
    rdfs:comment 'Master record for all outbound content commercialization agreements — covering individual asset licenses, bulk syndication deals (ongoing content feeds to media partners), third-party media outlet arrangements, social platform partnerships, broadcast partner feeds, and commercial licensees. Captures licensee/partner identity, licensed scope (asset, collection, sport, league), deal type (one-off license, ongoing syndication, revenue-share partnership), territory, usage type, fee structure (flat fee, royalty, revenue share), delivery format and schedule, content feed frequency, start/end dates, auto-renewal terms, and compliance status. SSOT for all outbound content monetization distinct from inbound rights_clearance.' .

ind:EditorialBrief rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Content ;
    rdfs:label 'Editorial Brief' ;
    rdfs:comment 'Master record for editorial content briefs — capturing story angle, assigned journalist or producer, target platform, sport/league/event context, word count or duration target, deadline, approval workflow status, and associated production order. Governs the editorial content production pipeline from commissioning to publication.' .

ind:PlatformChannel rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Content ;
    rdfs:label 'Platform Channel' ;
    rdfs:comment 'Reference master for all distribution platform channels — OTT apps, RSN broadcast slots, social media channels, DTC streaming, IPTV, and PPV portals. Captures platform name, channel type, operator, territory, supported content formats, and DRM requirements. Used to route publish events and rights windows to the correct distribution endpoint.' .

ind:TicketInventory rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Ticketing ;
    rdfs:label 'Ticket Inventory' ;
    rdfs:comment 'Master record of all available ticket inventory units within the venue seating manifest, sourced from Archtics/Ticketmaster Host. Tracks seat-level availability, hold status, kill status, accessibility designations (ADA), inventory pool assignments (GA, VIP, SRO, press, complimentary), and event-specific price zone mapping. SSOT for what seats exist per event and their current allocation state prior to sale. Supports real-time available-to-sell calculations across all channels.' .

ind:TicketOrder rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Ticketing ;
    rdfs:label 'Ticket Order' ;
    rdfs:comment 'Core transactional record capturing a fan\'s purchase of one or more tickets through any sales channel (Ticketmaster, AXS, box office, group sales, DTC, kiosk, partner API). Records order status, sales channel code, purchase timestamp, total face value, fees, taxes, PCI-DSS compliant payment reference, cashier/agent ID (for box office), and delivery method. SSOT for all ticket commerce transactions regardless of channel. Supports multi-channel reconciliation and revenue attribution.' .

ind:TicketOrderLine rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Ticketing ;
    rdfs:label 'Ticket Order Line' ;
    rdfs:comment 'Line-item detail within a ticket order representing a single ticket unit sold. Captures seat assignment, price tier, face value, service fee, facility fee, dynamic price applied, barcode/token, delivery method, delivery status, delivery timestamp, and comp flag with reason code. Enables per-seat revenue attribution, access control entitlement generation, fulfillment tracking, and complimentary ticket audit.' .

ind:PriceTier rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Ticketing ;
    rdfs:label 'Price Tier' ;
    rdfs:comment 'Reference catalog of pricing tiers available for ticket inventory, including GA (General Admission), VIP, SRO (Standing Room Only), premium club, suite, and accessible seating tiers. Defines base face value, fee structures, and eligibility rules per tier. Used by dynamic pricing engine and order processing.' .

ind:SeasonTicketPackage rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Ticketing ;
    rdfs:label 'Season Ticket Package' ;
    rdfs:comment 'Master record for season ticket packages offered to fans, including full-season, half-season, mini-plan, and flex-pack configurations. Tracks package type, included events, seat assignments, face value, renewal priority rights, and STH (Season Ticket Holder) benefits. SSOT for season ticket product definitions.' .

ind:SeasonTicketAccount rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Ticketing ;
    rdfs:label 'Season Ticket Account' ;
    rdfs:comment 'Transactional record linking a fan account to an active season ticket package. Captures enrollment date, seat assignments, payment plan status, renewal status, account balance, STH loyalty tier, and communication preferences. Represents the active season ticket holder relationship and entitlement.' .

ind:GroupSale rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Ticketing ;
    rdfs:label 'Group Sale' ;
    rdfs:comment 'Transactional record for group ticket sales involving 10+ tickets sold to a single organizational buyer (corporate outings, school field trips, community organizations, birthday parties, suite buyouts). Tracks group name, size, negotiated discount rate, group coordinator contact, deposit schedule, payment milestones, fulfillment status, assigned seating block, catering/hospitality add-ons, and group experience package. Managed as distinct workflow from individual retail sales with separate approval and pricing authority.' .

ind:Resale rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Ticketing ;
    rdfs:label 'Resale' ;
    rdfs:comment 'Unified lifecycle record for all secondary market and peer-to-peer ticket activity. Captures listing creation (price, channel, seller type, listing status), marketplace transaction execution (sale price, platform fees, seller proceeds, buyer reference), and peer-to-peer transfers (gift, forward). Tracks movement type, transfer timestamp, new entitlement token issuance, transfer restrictions, anti-scalping rule compliance, and revenue share calculations. SSOT for all secondary market listings, resale transactions, and fan-to-fan ticket transfers. Replaces separate listing and transaction records with a single lifecycle entity progressing through states: listed → sold/transferred/expired/withdrawn.' .

ind:AccessEntitlement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Ticketing ;
    rdfs:label 'Access Entitlement' ;
    rdfs:comment 'Digital entitlement record granting a specific fan the right to access a venue for a specific event. Generated upon ticket purchase or transfer. Contains barcode/QR token, NFC credential, validity window, seat assignment, access zone, and current entitlement status (valid, used, voided, transferred). SSOT for access control decisions at gate.' .

ind:GateScan rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Ticketing ;
    rdfs:label 'Gate Scan' ;
    rdfs:comment 'Transactional record of each access control scan event at venue entry points. Captures entitlement token scanned, gate/turnstile identifier, scan timestamp, scan result (granted, denied, duplicate), operator ID, and device ID. Feeds real-time attendance tracking and post-event access audit. Sourced from Ticketmaster/AXS access control hardware.' .

ind:TicketPayment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Ticketing ;
    rdfs:label 'Ticket Payment' ;
    rdfs:comment 'PCI-DSS compliant payment transaction record associated with a ticket order. Captures payment method type, masked card/wallet reference, payment processor token, authorization code, amount charged, currency, payment status (authorized, captured, failed, refunded), and settlement reference. SSOT for ticketing payment financial records.' .

ind:Refund rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Ticketing ;
    rdfs:label 'Refund' ;
    rdfs:comment 'Transactional record of a ticket refund or credit issued to a fan. Captures originating order reference, refund reason (event cancellation, postponement, fan request, fraud), refund amount, refund method (original payment, credit wallet, voucher), processing status, and approval workflow state. Supports PCI-DSS refund audit requirements.' .

ind:HoldAllocation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Ticketing ;
    rdfs:label 'Hold Allocation' ;
    rdfs:comment 'Record of ticket inventory blocks placed on hold for specific purposes — sponsor complimentary holds, artist/athlete holds, media holds, ADA holds, operational holds, pre-sale windows (with access codes and eligibility criteria), and comp allocations. Captures hold type, quantity, seat block, hold owner, hold expiry, release status, presale time windows, and access eligibility rules. Manages inventory allocation before public on-sale and enables tiered on-sale sequencing.' .

ind:Sponsor rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sponsorship ;
    rdfs:label 'Sponsor' ;
    rdfs:comment 'Master record for all sponsoring organizations and brands in the sports-entertainment ecosystem. Captures sponsor identity, corporate hierarchy, industry classification, account tier (title, presenting, official, associate), CRM account linkage from Salesforce, contact details, and relationship status. SSOT for sponsor identity across all commercial and activation workflows.' .

ind:Deal rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sponsorship ;
    rdfs:label 'Deal' ;
    rdfs:comment 'Core sponsorship deal record representing a negotiated commercial agreement between Sports Entertainment and a sponsor. Captures deal name, deal type (jersey sponsorship, venue naming rights, broadcast integration, digital platform partnership, presenting sponsor, official partner), total contract value (TCV), deal stage (prospecting, negotiation, executed, active, expired, renewed), start and end dates, exclusivity category and scope, territory. For naming rights deals: named asset (stadium, arena, practice facility, trophy, award, league division), signage specifications, broadcast mention requirements, digital property URL changes, and renewal option details. For digital partnerships: partnership type (app title sponsor, OTT streaming sponsor, social media co-branding, DTC campaign integration, API data partnership, Adobe Experience Platform personalization), digital property, impression commitment, CTR target, ARPU impact estimate, GDPR/CCPA data-sharing consent scope, and campaign flight dates. Includes originating Salesforce opportunity reference and renewal option flags. Central entity in the sponsorship lifecycle from prospecting through renewal, encompassing all deal sub-types.' .

ind:DealTerm rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sponsorship ;
    rdfs:label 'Deal Term' ;
    rdfs:comment 'Detailed contractual terms and financial obligations associated with a sponsorship deal. Captures payment schedule type (annual, quarterly, milestone), total fee, cash vs. value-in-kind (VIK) split, escalation clauses, performance bonuses, kill-clause thresholds, renewal options, right-of-first-refusal flags, and governing law jurisdiction. Supports SAP S/4HANA SD billing integration for invoicing milestones.' .

ind:Activation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sponsorship ;
    rdfs:label 'Activation' ;
    rdfs:comment 'Master record for individual brand activation deliverables committed within a sponsorship deal. Captures activation name, activation category (in-venue signage, jersey patch/sleeve/collar placement, broadcast billboard, virtual LED overlay, sponsored segment, branded replay, digital banner, social media post, experiential activation, naming rights display, PA announcement, LED perimeter board, halftime show integration, broadcast integration type with network/OTT platform association, airtime and duration), placement specifications (location, dimensions, visibility tier, kit manufacturer for jersey placements), scheduled and actual delivery dates, fulfillment status, responsible team, broadcast window, FCC/regulatory disclosure requirements, DRM compliance flags, and associated event. Core entity for tracking what was promised vs. delivered across all activation channels including broadcast integrations, jersey placements, and digital activations.' .

ind:ActivationFulfillment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sponsorship ;
    rdfs:label 'Activation Fulfillment' ;
    rdfs:comment 'Transactional record capturing the actual execution and proof-of-performance for each brand activation. Records fulfillment date, fulfillment channel (broadcast, in-venue, digital, social, OTT), proof-of-play reference (screenshot, broadcast log timestamp, photo), impressions delivered, GRP achieved, CPM realized, fulfillment quality rating, and any shortfall notes. Feeds ROI reporting and renewal negotiations.' .

ind:NamingRight rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sponsorship ;
    rdfs:label 'Naming Right' ;
    rdfs:comment 'Master record for venue and property naming rights agreements. Captures named asset (stadium, arena, practice facility, trophy, award, league division), naming rights holder (sponsor), naming rights fee, term start and end dates, signage specifications, broadcast mention requirements, digital property URL changes, and renewal option details. Distinct from general deal terms due to the long-term, high-value, and multi-property nature of naming rights.' .

ind:AdInventory rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sponsorship ;
    rdfs:label 'Ad Inventory' ;
    rdfs:comment 'Master catalog of available sponsorship and advertising inventory assets across all Sports Entertainment properties, including independently assessed market valuations. Captures asset type (LED perimeter board, broadcast billboard, digital overlay, PA announcement slot, in-app banner, OTT pre-roll, social media post, VIP hospitality suite, naming rights unit), property association (venue, broadcast channel, OTT platform, mobile app), capacity metrics (number of units, duration in seconds, estimated impressions), exclusivity category, current availability status. Includes valuation data: assessed value per unit, valuation methodology (broadcast equivalency, Nielsen media value, independent agency assessment), valuation date, valuation source, and currency. SSOT for what can be sold to sponsors, current market value of each asset, and benchmarking against industry CPM and GRP rates.' .

ind:InventoryAllocation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sponsorship ;
    rdfs:label 'Inventory Allocation' ;
    rdfs:comment 'Transactional record linking specific ad inventory units to sponsorship deals and activations. Captures allocation date, allocated quantity, event or broadcast window, exclusivity flag, priority tier, and allocation status (reserved, confirmed, delivered, cancelled). Prevents double-booking of inventory assets and supports capacity planning for future deal negotiations.' .

ind:PerformanceMetric rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sponsorship ;
    rdfs:label 'Performance Metric' ;
    rdfs:comment 'Transactional record capturing measured sponsorship performance data against contracted KPIs. Records metric type (GRP delivered, CPM realized, impressions, reach, frequency, brand recall score, NPS lift, social media engagement rate, broadcast airtime seconds, in-venue dwell time), measurement period, actual value, contracted target value, variance, measurement methodology, and data source (Nielsen, Kantar, internal analytics). Feeds ROI reporting and renewal negotiations.' .

ind:PaymentSchedule rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sponsorship ;
    rdfs:label 'Payment Schedule' ;
    rdfs:comment 'Master record defining the contractual payment milestones and installment schedule for a sponsorship deal. Captures milestone name, due date, payment amount, payment type (cash, VIK, barter), invoice reference, payment status (scheduled, invoiced, received, overdue), and SAP S/4HANA FI document number. Supports accounts receivable tracking and cash flow forecasting for the finance domain.' .

ind:Fixture rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Event ;
    rdfs:label 'Fixture' ;
    rdfs:comment 'Core master entity and SSOT for event identity — any scheduled live sports or entertainment event. Captures event name, type (match, concert, PPV, exhibition, all-star, draft, awards), status (announced → confirmed → in-progress → completed/cancelled), scheduled date/time with timezone, doors-open time, event tier (regular season, playoff, championship, special event), home/away designation, neutral site flag, broadcast eligibility flag, classification (league, cup, friendly, touring), and lifecycle timestamps. Anchor entity referenced by all downstream domains.' .

ind:Calendar rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Event ;
    rdfs:label 'Calendar' ;
    rdfs:comment 'Master entity defining a competitive or programming season within a league or entertainment series. Serves as the SSOT for season identity AND the official published fixture calendar/schedule. Captures season name, year, sport/entertainment type, start/end dates, number of scheduled rounds/weeks, playoff structure flag, season status (planning, active, completed), governing body reference, CBA applicability flag, season format (regular, shortened, expanded), calendar publication date, calendar version, scheduling authority, blackout dates, bye weeks, international window dates, and calendar status (draft, published, amended). Owns the official release of fixture schedules to downstream consumers including broadcast, ticketing, and venue operations.' .

ind:Tournament rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Event ;
    rdfs:label 'Tournament' ;
    rdfs:comment 'Master entity representing a structured competition format — knockout brackets, round-robin groups, double elimination, or multi-stage tournaments (e.g., FIFA World Cup, NBA Playoffs, UFC Championship Series). Captures tournament name, format type, number of rounds, seeding methodology, host region, prize pool amount, governing body, eligibility criteria, start/end dates, and tournament status. Distinct from season as tournaments have defined bracket structures and elimination logic.' .

ind:Bracket rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Event ;
    rdfs:label 'Bracket' ;
    rdfs:comment 'Transactional entity capturing the bracket structure and real-time progression of a tournament — rounds, matchup slots, seeding positions, advancement rules, bye assignments, and results-driven slot filling. Tracks which fixture occupies each bracket slot, winner advancement logic, bracket reset rules for double-elimination formats, and conditional scheduling of future fixtures as results are confirmed. Enables real-time bracket visualization for broadcast overlays and fan engagement platforms.' .

ind:MatchResult rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Event ;
    rdfs:label 'Match Result' ;
    rdfs:comment 'Transactional entity capturing the official outcome of a completed sports fixture — final scores, scorelines by period/quarter/half/set, overtime/shootout results, winning team/athlete, margin of victory, result status (official, under review, protested, forfeited), VAR/TMO intervention flag, and result confirmation timestamp. Serves as the SSOT for competitive outcomes used by league standings, broadcast highlights, and wagering integrations. Distinct from fixture (which is the scheduled event) — this is the recorded outcome.' .

ind:ScoringEvent rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Event ;
    rdfs:label 'Scoring Event' ;
    rdfs:comment 'Transactional entity capturing individual in-game scoring moments — goals, touchdowns, baskets, runs, points — with precise match clock time, period/quarter/half, athlete credited, assist attribution, scoring method (penalty, free kick, slam dunk, home run), VAR review flag, and score state after the event. Enables granular play-by-play data for broadcast overlays, content production, and fan engagement platforms. Feeds downstream content and broadcast domains.' .

ind:ProductionSchedule rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Event ;
    rdfs:label 'Production Schedule' ;
    rdfs:comment 'Operational entity managing the game-day/event-day production run-of-show for a fixture. Covers pre-event setup windows, doors-open coordination, pre-show entertainment, halftime/intermission programming (performer, duration, stage configuration, technical rider), post-event activities, and venue clearance timelines. Captures schedule version, production coordinator, broadcast go-live time, OB truck arrival, schedule lock timestamp, and sponsor activation windows. Serves as the execution plan distinct from fixture identity — owned by event production team.' .

ind:Participant rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Event ;
    rdfs:label 'Participant' ;
    rdfs:comment 'Association entity linking athletes, teams, performers, or competing entities to a specific fixture. Captures participant role (home team, away team, headliner, support act, wildcard entry), seeding rank, participation status (confirmed, withdrawn, suspended, TBD), lineup submission timestamp, and captain/lead performer designation. Serves as the SSOT for who is participating in each event — consumed by broadcast, ticketing, content, and fan engagement domains.' .

ind:OfficiatingAssignment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Event ;
    rdfs:label 'Officiating Assignment' ;
    rdfs:comment 'Transactional entity managing the assignment of match officials — referees, linesmen, VAR operators, TMO (Television Match Official), judges, and scorers — to specific fixtures. Captures official role, assignment date, confirmation status, governing body certification level, conflict-of-interest flag, and post-match officiating report reference. Supports league governance, compliance with officiating standards (FIFA, NFL, NBA), and VAR/TMO review workflows.' .

ind:EventIncident rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Event ;
    rdfs:label 'Event Incident' ;
    rdfs:comment 'Transactional entity recording significant in-event incidents requiring operational response — red cards, ejections, injuries requiring stoppage, crowd disturbances, equipment failures, weather delays (lightning, extreme heat), power outages, medical emergencies, and field/surface condition changes. Captures incident type, match clock time, severity level, response action taken, weather conditions at time of incident, regulatory reporting obligation flag (OSHA, governing body), resolution timestamp, and game-delay duration if applicable. Supports post-event reporting, safety compliance, and insurance documentation.' .

ind:VenueAssignment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Event ;
    rdfs:label 'Venue Assignment' ;
    rdfs:comment 'Association entity linking a fixture to its assigned venue, capturing venue confirmation status, primary/alternate venue designation, venue configuration type (full capacity, reduced capacity, neutral site), ADA compliance confirmation, field/court/stage setup type, and assignment change history flag. Enables venue operations domain to prepare facility resources and ticketing domain to configure seating inventory for the specific event.' .

ind:CompetitionRound rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Event ;
    rdfs:label 'Competition Round' ;
    rdfs:comment 'Reference entity defining the rounds, stages, and phases within a season or tournament — Week 1, Matchday 3, Quarter-Final, Semi-Final, Wild Card Round, Conference Championship, Super Bowl, Group Stage, Knockout Round. Captures round name, round number, stage type, parent season or tournament reference, scheduled start/end dates, and number of fixtures in the round. Enables fixture scheduling, standings calculation, and bracket progression logic.' .

ind:Roster rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Athlete ;
    rdfs:label 'Roster' ;
    rdfs:comment 'Master record of all athletes registered to a team or franchise within a league season. Tracks active, inactive, injured reserve (IR), practice squad, and waived status. Serves as the authoritative SSOT for athlete-team affiliation at any point in time, including jersey number, position designation, roster slot type, and activation dates. Critical for league operations, broadcast graphics, and ticketing systems.' .

ind:AthleteProfile rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Athlete ;
    rdfs:label 'Athlete Profile' ;
    rdfs:comment 'Core master identity record for every athlete managed by Sports Entertainment. Stores biographical data (full legal name, preferred name, date of birth, nationality, country of origin), physical attributes (height, weight, dominant hand/foot), headshot image reference, social media handles, and career status (active, retired, suspended, deceased). This is the SSOT for athlete identity — all other athlete entities reference this record. Sourced from SAP SuccessFactors talent module and league registration systems.' .

ind:Contract rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Athlete ;
    rdfs:label 'Contract' ;
    rdfs:comment 'Athlete employment and service contracts governing the full lifecycle from initial signing through free agency. Tracks contract terms (compensation, duration, performance bonuses, trade clauses, option years, CBA-mandated terms), contract type (rookie, veteran, max, minimum, two-way), total value, guaranteed money, signing bonus, annual average value (AAV), and contract status (active, expired, voided, restructured). Includes free agency lifecycle: classification (UFA, RFA, ERFA, franchise tag, transition tag), qualifying offer amounts, tender amounts, right-of-first-refusal flags, free agency open date, signing deadline, and negotiation status. Integrates with SAP S/4HANA SD module for financial obligations and payroll processing via SAP SuccessFactors. Serves as the SSOT for an athlete\'s complete employment relationship from signing through free agency periods and re-signing.' .

ind:PerformanceStat rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Athlete ;
    rdfs:label 'Performance Stat' ;
    rdfs:comment 'Game-level and season-level performance statistics for athletes across all sports disciplines. Captures sport-specific metrics including WAR (Wins Above Replacement), ERA (Earned Run Average), QBR (Quarterback Rating), goals, assists, rebounds, tackles, saves, batting average, on-base percentage, and advanced analytics inputs. Sourced from SportsCode/Hudl performance analytics platform. Each record represents a statistical line for one athlete in one game or aggregated period, enabling broadcast overlays, fantasy sports feeds, and league standings calculations.' .

ind:InjuryRecord rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Athlete ;
    rdfs:label 'Injury Record' ;
    rdfs:comment 'Clinical and operational record of athlete injuries, illnesses, and medical events throughout their career. Tracks injury type, body part affected, diagnosis code (ICD-10), injury date, expected return-to-play (RTP) date, actual RTP date, treatment protocol, treating physician, and impact on roster eligibility (IR designation, day-to-day, out). Supports OSHA compliance reporting, insurance claims, and broadcast injury updates. Managed in coordination with team medical staff systems.' .

ind:DraftSelection rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Athlete ;
    rdfs:label 'Draft Selection' ;
    rdfs:comment 'Record of athlete selections made during league drafts (NFL Draft, NBA Draft, MLB Draft, MLS SuperDraft, etc.). Captures draft year, round number, overall pick number, selecting team, original team (if traded), draft class, pre-draft ranking, combine performance scores, and signing slot value per CBA. Tracks compensatory picks, traded picks, and conditional picks. Essential for league governance, salary cap management, and historical analytics.' .

ind:EligibilityStatus rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Athlete ;
    rdfs:label 'Eligibility Status' ;
    rdfs:comment 'Authoritative single source of truth for an athlete\'s current and historical eligibility to compete, encompassing all factors that grant or restrict participation rights. Covers: amateur/professional status, league registration, visa and work permit status, age eligibility, and all disciplinary actions including PED suspensions, conduct violations, game misconduct bans, and CBA disciplinary procedures. Tracks eligibility type, governing body (FIFA, NFL, NBA, WADA, CAS), effective/expiry dates, restriction details, suspension type and length (games, days, indefinite), financial penalties, issuing authority, reinstatement conditions, appeal status and outcomes, and chain of custody to originating doping test or incident. Critical for CBA compliance, international transfer regulations, WADA anti-doping enforcement, broadcast rights clearances, and real-time game-day eligibility verification. Replaces any separate suspension tracking — all disciplinary restrictions are eligibility events.' .

ind:NilAgreement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Athlete ;
    rdfs:label 'Nil Agreement' ;
    rdfs:comment 'Unified commercial agreement record for all athlete brand partnerships, endorsements, and Name/Image/Likeness (NIL) deals. Covers both amateur/collegiate NIL agreements (subject to NCAA/conference NIL policies) and professional endorsement contracts (subject to CBA and league sponsor conflict rules). Tracks deal category (NIL-amateur, NIL-collegiate, professional endorsement, appearance, social media, licensing), brand partner, product category, deal value, contract duration, exclusivity scope, usage rights (broadcast, digital, social, in-venue), performance incentives, morality clause terms, disclosure status, and compliance with applicable regulations. Supports athlete commercial valuation, sponsorship conflict-of-interest checks, NIL compliance reporting, and broadcast rights clearances for athlete-branded content.' .

ind:AgentRelationship rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Athlete ;
    rdfs:label 'Agent Relationship' ;
    rdfs:comment 'Association record linking athletes to their certified agents, agencies, and legal representatives. Tracks agent name, agency name, agent certification number (NFLPA, NBPA, MLBPA certified), representation scope (contract negotiation, endorsements, NIL, legal), relationship start date, termination date, commission rate, and power of attorney status. Supports contract negotiation workflows, communication routing, and compliance with league agent certification requirements.' .

ind:SuspensionRecord rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Athlete ;
    rdfs:label 'Suspension Record' ;
    rdfs:comment 'Disciplinary suspension and ban records for athletes resulting from rule violations, anti-doping infractions, conduct violations, or CBA disciplinary procedures. Tracks suspension type (PED, conduct, game misconduct, league discipline), issuing authority, suspension length (games, days, indefinite), effective start and end dates, appeal status, reinstatement conditions, and financial penalties. Distinct from injury-related roster designations — suspensions are disciplinary actions with legal and compliance implications.' .

ind:SalaryCapEntry rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Athlete ;
    rdfs:label 'Salary Cap Entry' ;
    rdfs:comment 'Athlete-level salary cap accounting records tracking how each contract contributes to a team\'s league-mandated salary cap. Captures cap year, base salary cap hit, signing bonus proration, dead cap value, incentive escalators (likely/unlikely per CBA), cap relief from restructures, and cap hold for restricted free agents. Integrates with SAP S/4HANA FI/CO for financial reporting and Workday Adaptive Planning for cap forecasting. Distinct from the contract master — this is the annual cap accounting view.' .

ind:FreeAgencyStatus rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Athlete ;
    rdfs:label 'Free Agency Status' ;
    rdfs:comment 'Tracks an athlete\'s free agency eligibility, classification, and market activity during free agency periods. Captures free agency type (unrestricted/UFA, restricted/RFA, exclusive rights/ERFA, franchise tag, transition tag), qualifying offer amount, tender amount, original team right of first refusal flag, free agency open date, signing deadline, and current negotiation status. Supports roster planning, salary cap management, and broadcast transaction reporting.' .

ind:GlAccount rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Gl Account' ;
    rdfs:comment 'General ledger account master record defining a specific financial classification node within the enterprise chart of accounts. Each GL account represents a unique posting target (e.g., ticket revenue, broadcast rights income, venue operating expense, player salary, naming rights deferred revenue). Stores account number, description, account type (P&L vs balance sheet), currency, tax category, reconciliation account flag, cost element category, account group, and posting block status. SSOT for all account classification, financial statement line mapping, and cost element definitions across all Sports Entertainment legal entities in SAP S/4HANA FI.' .

ind:CostCenter rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Cost Center' ;
    rdfs:comment 'SAP CO cost center master representing an organizational unit responsible for incurring costs — e.g., venue operations, broadcast production, athlete performance, league administration, merchandise fulfillment. Tracks cost center hierarchy, responsible manager, controlling area, validity period, and budget allocation. SSOT for cost accountability across all Sports Entertainment business units.' .

ind:ProfitCenter rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Profit Center' ;
    rdfs:comment 'SAP CO profit center master representing a revenue-generating business unit — e.g., a specific league franchise, venue, OTT streaming platform, or merchandise line. Enables EBITDA reporting and profitability analysis at the business segment level. Stores profit center hierarchy, controlling area, company code assignment, and segment classification.' .

ind:CompanyCode rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Company Code' ;
    rdfs:comment 'Legal entity master record within the SAP S/4HANA organizational structure. Represents each incorporated Sports Entertainment subsidiary or operating company (e.g., league operating company, broadcast network entity, venue management LLC). Stores company code, legal name, country, currency, fiscal year variant, and chart of accounts assignment. Required for SOX-compliant intercompany and SEC reporting.' .

ind:JournalEntry rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Journal Entry' ;
    rdfs:comment 'Core financial posting document in SAP FI representing a balanced double-entry accounting transaction with embedded line items (posting rows). Each journal entry contains one or more line items specifying GL account, amount, debit/credit indicator, cost center, profit center, and tax code. Captures document type (invoice, payment, accrual, intercompany, allocation), posting date, fiscal period, company code, reference document, posting user, reversal indicator, and SOX approval workflow status. SSOT for all financial movements across the general ledger including revenue recognition postings for ticket sales, broadcast rights, sponsorship, merchandise, and cost allocation postings. Line-item granularity is embedded within this product — no separate line product exists.' .

ind:Budget rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Budget' ;
    rdfs:comment 'Financial planning record encompassing annual budgets, multi-year plans, and rolling forecasts per cost center, profit center, or WBS element. Managed in Workday Adaptive Planning and loaded into SAP CO. Captures budget/forecast version (original, revised, Q1-Q4 reforecast), scenario type (base, upside, downside), budget type (OPEX, CAPEX), fiscal year/period, planned amounts by GL account and cost element at monthly/quarterly granularity, committed amounts, actuals-to-date, and approval workflow status. Supports FP&A variance analysis, rolling forecast cycles, EBITDA projections, and investor relations guidance for Sports Entertainment.' .

ind:ArInvoice rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Ar Invoice' ;
    rdfs:comment 'Accounts receivable invoice issued to external customers — sponsors, broadcast rights licensees, merchandise wholesale buyers, and premium suite holders. Stores invoice number, billing date, due date, customer account, payment terms, gross amount, tax amount, net amount, currency, payment status, and dunning level. Managed in SAP FI-AR. SSOT for revenue billing documents.' .

ind:ApInvoice rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Ap Invoice' ;
    rdfs:comment 'Accounts payable invoice received from vendors and suppliers — venue service contractors, broadcast equipment providers, athlete agents, merchandise manufacturers. Stores vendor invoice number, receipt date, posting date, vendor account, payment terms, gross amount, tax amount, net amount, currency, three-way match status (PO/GR/IR), and payment block reason. Managed in SAP FI-AP.' .

ind:Payment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Payment' ;
    rdfs:comment 'Financial payment transaction recording the settlement of accounts receivable and accounts payable obligations. Captures payment document number, payment date, payment method (ACH, wire, check, card, digital wallet), bank account, cleared invoice references, payment amount, currency, exchange rate, clearing document number, and payment run ID. Covers outbound vendor disbursements, inbound customer receipts, and automated payment program runs in SAP FI. Links to AR invoices (customer receipts) and AP invoices (vendor payments) for complete cash application and reconciliation.' .

ind:FixedAsset rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Fixed Asset' ;
    rdfs:comment 'Fixed asset master record in SAP FI-AA representing capitalized physical and intangible assets — stadium structures, broadcast towers, OB trucks, scoreboards, digital platform infrastructure, and acquired broadcast rights. Stores asset class, acquisition date, acquisition cost, useful life, depreciation method, accumulated depreciation, net book value, and disposal status. SSOT for CAPEX and depreciation accounting.' .

ind:RevenueRecognitionSchedule rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Revenue Recognition Schedule' ;
    rdfs:comment 'Revenue recognition schedule governing when and how deferred revenue is recognized into earned revenue per ASC 606 / IFRS 15 standards. Applies to multi-year broadcast rights contracts, season ticket packages, multi-event sponsorship deals, and long-term naming rights agreements. Stores contract reference, performance obligation description, total contract value, deferred balance, recognition method (straight-line, milestone, usage-based), recognition start/end dates, period recognition amounts, and cumulative recognized amount. SSOT for ASC 606 compliance, deferred revenue waterfall reporting, and period-end revenue recognition journal entry generation. Distinct from recurring_revenue which tracks commercial ARR/churn metrics — this product owns the accounting treatment and timing of revenue recognition.' .

ind:Facility rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Venue ;
    rdfs:label 'Facility' ;
    rdfs:comment 'Master record for every physical venue asset — stadiums, arenas, amphitheaters, and concert halls — owned or operated by Sports Entertainment. Captures venue name, full address, geo-coordinates, venue type (stadium/arena/amphitheater/ballpark), playing surface type, roof type (open/retractable/enclosed), year built, year last renovated, total gross square footage, ownership structure (owned/leased/managed), primary sport or entertainment category, home team or resident tenant, ADA compliance certification status, OSHA safety rating, ISO 20121 sustainability certification, seating bowl configuration code, naming rights holder, time zone, and operational status (active/mothballed/under-renovation/decommissioned). Serves as the SSOT for all venue identity and physical characteristics consumed by event scheduling, ticketing inventory, and broadcast production planning.' .

ind:SeatingSection rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Venue ;
    rdfs:label 'Seating Section' ;
    rdfs:comment 'Defines every named seating section within a facility — bowl sections, club levels, suites, GA standing areas, SRO zones, press boxes, and accessible seating blocks. Attributes include section code, section name, level (lower/club/upper/field), section type (reserved/GA/SRO/suite/accessible), row count, seat count per row, total capacity, ADA-accessible seat count, sightline rating, price zone code, and whether the section is covered. Sourced from Archtics Venue Seating and Inventory Management.' .

ind:Seat rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Venue ;
    rdfs:label 'Seat' ;
    rdfs:comment 'Atomic seat-level inventory record for every individual seat within a seating section. Captures seat number, row identifier, seat type (standard/accessible/companion/premium/stool), physical coordinates (row-seat position), ADA designation flag, obstructed-view flag, aisle seat flag, kill-seat flag (structurally unavailable), current operational status (active/inactive/hold/kill), and last inspection date. Serves as the SSOT for seat-level inventory consumed by the ticketing domain.' .

ind:CapacityConfig rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Venue ;
    rdfs:label 'Capacity Config' ;
    rdfs:comment 'Event-specific or configuration-specific capacity setup for a facility, capturing how total capacity is allocated across seating modes for a given event type or configuration profile. Attributes include configuration name, event type applicability (concert/sports/mixed), total configured capacity, GA capacity, reserved capacity, suite capacity, accessible capacity, press/media capacity, field/floor capacity, kill-seat count, and configuration effective date range. Enables dynamic capacity management across different event formats (e.g., end-stage concert vs. full-bowl sports).' .

ind:ParkingLot rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Venue ;
    rdfs:label 'Parking Lot' ;
    rdfs:comment 'Master record for all parking facilities associated with a venue — surface lots, structured garages, VIP lots, accessible parking areas, and remote shuttle lots. Captures lot name, lot code, lot type (surface/garage/remote/VIP/accessible), total spaces, accessible spaces, EV charging spaces, distance from main entrance (meters), managed-by party reference, pricing tier, and operational status. Supports event-day parking logistics, revenue management, and ADA compliance reporting.' .

ind:MaintenanceWorkOrder rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Venue ;
    rdfs:label 'Maintenance Work Order' ;
    rdfs:comment 'Operational record capturing every planned or reactive maintenance activity performed on facility infrastructure, BMS systems, seating, concourse equipment, or structural elements. Attributes include work order number, work order type (preventive/corrective/emergency/inspection), priority level, asset or system reference, description of work, requested date, scheduled start/end date, actual start/end date, technician assignment, labor hours, parts used, estimated cost, actual cost, completion status, and sign-off by facility manager. Sourced from SAP S/4HANA Plant Maintenance (PM) module.' .

ind:SafetyInspection rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Venue ;
    rdfs:label 'Safety Inspection' ;
    rdfs:comment 'Records all formal safety and compliance inspections conducted at a facility, including OSHA walkthroughs, fire marshal inspections, ADA accessibility audits, structural engineering assessments, and ISO 20121 sustainability audits. Attributes include inspection type, inspection date, inspector name and credentials, regulatory body (OSHA/ADA/fire marshal/local authority), areas inspected, findings count, critical findings count, corrective actions required, corrective action due date, pass/fail outcome, and certificate issued flag. Supports regulatory reporting and compliance tracking.' .

ind:SafetyIncident rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Venue ;
    rdfs:label 'Safety Incident' ;
    rdfs:comment 'Captures every safety or security incident occurring at a venue — fan injuries, worker accidents, medical emergencies, structural failures, fire alarms, crowd disturbances, and security breaches. Attributes include incident date/time, incident type, location within venue (section/zone/lot), severity level (minor/moderate/serious/critical), number of persons affected, emergency services called flag, OSHA recordable flag, incident description, immediate response actions taken, root cause, corrective action plan, and incident closure date. Mandatory for OSHA 300 log compliance and insurance reporting.' .

ind:EventDayOps rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Venue ;
    rdfs:label 'Event Day Ops' ;
    rdfs:comment 'Operational readiness, execution, and closeout record for each event held at a venue, capturing the full event-day lifecycle from pre-event certification through post-event reconciliation. Pre-event readiness attributes include checklist completion status, checklist version, HVAC/fire/emergency system verification, security sweep completion, ADA access confirmation, medical station readiness, critical-item failure count, overall readiness status (approved/conditional/rejected), and facility manager approval with timestamp. Execution attributes include gates-open/close times, load-in/load-out windows, actual attendance, peak concourse occupancy, active concession stand count, active parking lot count, security and medical staffing counts, weather conditions, and incident count. Post-event attributes include operational status (pre-event/in-progress/post-event/closed), damage assessment flag, and facility manager sign-off. Distinct from the event domain\'s event record — this is the venue\'s operational execution layer owning the single source of truth for event-day readiness certification and operational performance.' .

ind:ConcessionStand rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Venue ;
    rdfs:label 'Concession Stand' ;
    rdfs:comment 'Master record and POS-level transactional detail for individual concession stand units within a facility — food and beverage outlets, portable carts, premium club kitchens, and bar stations. Master attributes include stand name, stand code, stand type (permanent/portable/premium/bar/specialty), concourse location, cuisine/product category (hot food/cold beverage/alcohol/snack/merchandise), operator name (in-house/third-party concessionaire), POS terminal count, seating capacity (if applicable), ADA-accessible service counter flag, health inspection status, and operational status. Transaction-level attributes include transaction date/time, event reference, POS terminal ID, item SKU, item description, quantity sold, unit price, discount applied, gross amount, tax amount, net amount, payment method (cash/card/mobile), and void flag. Supports per-event concession revenue reporting, per-capita spend analysis, top-selling item tracking, and health/safety compliance. Sourced from POS systems integrated with SAP S/4HANA SD.' .

ind:Suite rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Venue ;
    rdfs:label 'Suite' ;
    rdfs:comment 'Master record for premium hospitality suites and club boxes within a facility, encompassing physical configuration, amenities, and the full commercial license/lease lifecycle. Physical attributes include suite name, suite number, suite type (private suite/club box/loge box/party suite/press box), level, total capacity, seat count, standing positions, square footage, amenity list (private bar/catering kitchen/AV system/private restroom), and ADA-accessible flag. Commercial license attributes include license number, licensee name, licensee type (corporate/individual), license start/end dates, term (annual/multi-year/per-event), total license fee, payment schedule, included event types and count, catering credit amount, parking passes included, renewal option flag, contract status (active/expired/terminated/pending), and lease pipeline stage. Supports suite revenue management, premium hospitality operations, lease renewal pipeline tracking, and per-suite P&L analysis. Distinct from sponsorship domain partnership contracts — this is a venue-specific hospitality revenue instrument.' .

ind:AccessibilityFeature rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Venue ;
    rdfs:label 'Accessibility Feature' ;
    rdfs:comment 'Catalog of ADA and accessibility features installed or available at a facility — wheelchair ramps, elevator banks, accessible restrooms, hearing loop systems, braille signage, accessible parking spaces, companion seating areas, and sensory rooms. Attributes include feature name, feature type, location description, quantity/count, installation date, last inspection date, compliance standard (ADA/local code), compliance status (compliant/non-compliant/remediation-in-progress), and responsible maintenance team. Supports ADA compliance reporting and fan accessibility experience management.' .

ind:League rdf:type rdfs:Class ;
    rdfs:subClassOf ind:League ;
    rdfs:label 'League' ;
    rdfs:comment 'Master record for each professional sports league or governing body (NFL, NBA, MLB, NHL, MLS, FIFA, IOC, etc.). Captures league identity, founding year, sport type, governing body affiliation, headquarters, official name, acronym, active status, and league-level configuration such as number of teams, playoff format, and championship structure. This is the SSOT for league identity across the enterprise.' .

ind:Conference rdf:type rdfs:Class ;
    rdfs:subClassOf ind:League ;
    rdfs:label 'Conference' ;
    rdfs:comment 'Organizational subdivision of a league representing a conference or association grouping (e.g., AFC/NFC in NFL, Eastern/Western Conference in NBA, American/National League in MLB). Tracks conference name, abbreviation, parent league, geographic alignment, number of divisions, and active season range. Supports standings aggregation and playoff seeding logic.' .

ind:Division rdf:type rdfs:Class ;
    rdfs:subClassOf ind:League ;
    rdfs:label 'Division' ;
    rdfs:comment 'Sub-grouping within a conference representing a competitive division (e.g., NFC East, AL Central, Atlantic Division). Stores division name, abbreviation, parent conference, parent league, geographic region, number of member teams, and active status. Drives divisional standings, scheduling rules, and playoff qualification criteria.' .

ind:Franchise rdf:type rdfs:Class ;
    rdfs:subClassOf ind:League ;
    rdfs:label 'Franchise' ;
    rdfs:comment 'Master record for each team franchise holding a league membership license, including the governing franchise agreement terms. Captures franchise legal name, market city/metro area, team nickname, abbreviation, founding year, ownership entity reference, home venue reference, current league and division membership, historical relocation records, expansion/original franchise flag, franchise valuation estimate, active/suspended/defunct status, and CBA participation flag. Also stores franchise agreement terms: territorial rights, revenue sharing obligations, relocation restrictions, expansion fees, ownership transfer rules, agreement version, execution date, governing CBA reference, and amendment history. Tracks official roster filing snapshots (active roster count, IR, practice squad, compliance status) at points in time. SSOT for franchise identity, membership governance, and roster compliance.' .

ind:Season rdf:type rdfs:Class ;
    rdfs:subClassOf ind:League ;
    rdfs:label 'Season' ;
    rdfs:comment 'Defines a competitive season calendar and postseason structure for a league. Captures season year, season type (regular, preseason, postseason), official start and end dates, number of scheduled games per team, salary cap year flag, CBA governing version, and season status (upcoming, active, completed). Includes playoff/postseason bracket definition: bracket format (single elimination, best-of-series), number of rounds, seeding methodology, bye rules, home-court/field advantage rules, bracket position assignments per franchise, advancement status, and series results through each round to championship. Anchors all scheduling, standings, draft, and compliance calculations.' .

ind:LeagueSchedule rdf:type rdfs:Class ;
    rdfs:subClassOf ind:League ;
    rdfs:label 'League Schedule' ;
    rdfs:comment 'Official league-published game schedule record linking two franchises to a specific date, time, venue, and season week/round/matchday. Includes home/away designation, broadcast window assignment, game type (regular season, playoff, neutral site, exhibition), scheduling status (confirmed, postponed, cancelled, rescheduled), original vs. revised date tracking, and transaction window compliance flag. Serves as the planning backbone for event operations, broadcast scheduling, and standings calculations.' .

ind:Standing rdf:type rdfs:Class ;
    rdfs:subClassOf ind:League ;
    rdfs:label 'Standing' ;
    rdfs:comment 'Periodic snapshot of competitive standings for a franchise within a division, conference, and league for a given season. Tracks wins, losses, ties/draws, overtime losses, points (hockey/soccer), winning percentage, games behind leader, home/away/divisional/conference records, goal/run/point differential, current streak, last-10 record, strength of schedule, clinch/elimination status, and standings rank. Updated after each official game result. Drives playoff qualification logic and tiebreaker resolution.' .

ind:PlayoffBracket rdf:type rdfs:Class ;
    rdfs:subClassOf ind:League ;
    rdfs:label 'Playoff Bracket' ;
    rdfs:comment 'Defines the postseason bracket structure for a league season, including bracket format (single elimination, best-of-series), number of rounds, seeding methodology, bye rules, home-court/field advantage rules, and bracket position assignments per franchise. Tracks advancement status and series results through each round to championship.' .

ind:GameResult rdf:type rdfs:Class ;
    rdfs:subClassOf ind:League ;
    rdfs:label 'Game Result' ;
    rdfs:comment 'Official final result record for a completed scheduled game. Captures final score by team, overtime periods played, winning/losing franchise, result type (regulation, OT, SO, forfeit), official attendance, weather conditions (outdoor venues), VAR/TMO intervention flag, protest flag, and result certification status. SSOT for official game outcomes used in standings calculations.' .

ind:Official rdf:type rdfs:Class ;
    rdfs:subClassOf ind:League ;
    rdfs:label 'Official' ;
    rdfs:comment 'Master record for an individual game official (referee, umpire, linesman, VAR operator, TMO, line judge). Captures official name, badge number, officiating body, certification tier, sport specialization, active status, years of experience, geographic assignment region, and contract type. Distinct from athlete and workforce domains — officials are governed by league officiating bureaus.' .

ind:DisciplinaryAction rdf:type rdfs:Class ;
    rdfs:subClassOf ind:League ;
    rdfs:label 'Disciplinary Action' ;
    rdfs:comment 'Record of a formal disciplinary action issued by the league against a player, coach, franchise, or official. Includes infraction type (suspension, fine, ejection, probation, loss of draft pick), subject entity type and reference, incident date, game reference, ruling date, penalty amount, suspension length in games, appeal eligibility, appeal status, and final ruling. Supports competitive integrity and CBA compliance tracking.' .

ind:SalaryCap rdf:type rdfs:Class ;
    rdfs:subClassOf ind:League ;
    rdfs:label 'Salary Cap' ;
    rdfs:comment 'Annual salary cap definition and franchise compliance tracking per league and season. Defines hard cap, soft cap, luxury tax threshold, cap floor, and applicable exceptions (mid-level, bi-annual, franchise tag). Tracks cap year, total league revenue basis, escrow percentage, cap calculation methodology, and official announcement date. Also captures per-franchise compliance snapshots: total active payroll, cap space remaining, dead cap, injured reserve credits, practice squad charges, cap holds, luxury tax liability, and compliance status (compliant, warning, violation). Updated on roster transactions and contract signings. SSOT for salary cap rules AND franchise-level cap compliance.' .

ind:Draft rdf:type rdfs:Class ;
    rdfs:subClassOf ind:League ;
    rdfs:label 'Draft' ;
    rdfs:comment 'Master record for a league player draft event and all individual pick selections. At the event level: draft year, sport, number of rounds, total picks, draft format (live, virtual, hybrid), draft date and location, eligibility class (college, international, supplemental), draft order determination method (lottery, inverse standings, coin flip), and draft status. At the pick level: round number, overall pick number, current owning franchise, original owning franchise (if traded), full trade history chain, compensatory/conditional pick flags, pick protection level (top-N protected), pick status (available, traded, exercised, forfeited, voided), and selected athlete reference upon exercise. Supports draft asset management, trade analysis, and future pick valuation models.' .

ind:DraftPick rdf:type rdfs:Class ;
    rdfs:subClassOf ind:League ;
    rdfs:label 'Draft Pick' ;
    rdfs:comment 'Individual draft pick record within a draft event, tracking round number, overall pick number, current owning franchise, original owning franchise (if traded), full trade history chain, compensatory pick flag, conditional pick flag with conditions description, pick protection level (top-N protected), pick status (available, traded, exercised, forfeited, voided), and selected athlete reference upon exercise. Supports draft asset management, trade analysis, and future pick valuation models.' .

ind:TradeTransaction rdf:type rdfs:Class ;
    rdfs:subClassOf ind:League ;
    rdfs:label 'Trade Transaction' ;
    rdfs:comment 'Record of inter-franchise player and asset movement including trades, waiver claims, and waiver wire transactions. Captures transaction date, involved franchises, assets exchanged (player references, draft pick references, cash considerations), transaction type (trade, waiver claim, waiver placement, DFA assignment), league approval status, approval date, voiding conditions, transaction window compliance flag, waiver priority order, salary obligation transfer details, and clearing dates. SSOT for all inter-franchise roster movement requiring league approval.' .

ind:SkuCatalog rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Merchandise ;
    rdfs:label 'Sku Catalog' ;
    rdfs:comment 'Master product catalog for all official merchandise SKUs including team apparel, memorabilia, accessories, and licensed goods. Serves as the SSOT for product identity, descriptions, brand classifications, league/team associations, and product lifecycle status across all sales channels (Shopify Plus, POS, third-party retail). Tracks SKU codes, product names, categories, sizes, colors, materials, MSRP, and licensing requirements.' .

ind:InventoryPosition rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Merchandise ;
    rdfs:label 'Inventory Position' ;
    rdfs:comment 'Real-time inventory management record tracking on-hand stock quantities, reserved quantities, available-to-sell units, and stock movement history for each SKU across all storage locations — venue stores, warehouse fulfillment centers, and third-party retail consignment. Captures current position (reorder points, safety stock levels, inventory valuation per location) and transfer activity (origin, destination, quantities moved, transfer reason such as rebalancing or event-day stocking, transfer status, completion date). Sourced from Shopify Plus inventory sync, POS systems, and warehouse management. Supports omnichannel inventory optimization, event-day venue stocking, and inventory reconciliation.' .

ind:RetailLocation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Merchandise ;
    rdfs:label 'Retail Location' ;
    rdfs:comment 'Master record for all physical and virtual retail points-of-presence selling official merchandise — venue flagship stores, arena kiosks, warehouse outlets, pop-up event shops, and online storefronts (Shopify Plus). Tracks location name, type (venue store, kiosk, e-commerce, pop-up, third-party), address, operating hours, POS terminal assignments, associated venue, default currency, supported payment methods, and active status. Serves as the SSOT for retail channel geography and storefront configuration across all merchandise sales channels.' .

ind:MerchOrder rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Merchandise ;
    rdfs:label 'Merch Order' ;
    rdfs:comment 'Unified transactional record of any merchandise purchase across all channels — Shopify Plus e-commerce, venue POS (arena stores, kiosks, pop-ups), and third-party wholesale. Captures order header (date, channel type, status, total amount, currency, tax, shipping method, fulfillment status) and line-level detail (SKU, quantity, unit price, line discount, line total, line fulfillment status, return eligibility). Channel-specific metadata includes POS terminal ID, cashier ID, payment tender type for in-venue sales; cart session and shipping address for e-commerce; and wholesale account reference for B2B orders. Supports unified omnichannel sales reporting, revenue attribution at SKU level, and PCI-DSS compliant payment data handling. Single source of truth for \'a sale happened\' regardless of channel.' .

ind:OrderLine rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Merchandise ;
    rdfs:label 'Order Line' ;
    rdfs:comment 'Individual line item within a merchandise order representing a single SKU quantity purchased. Captures SKU reference, quantity ordered, unit price, line-level discount, line total, fulfillment status, and return eligibility. Supports revenue attribution at the product level and enables SKU-level sales performance tracking across channels.' .

ind:LicensingAgreement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Merchandise ;
    rdfs:label 'Licensing Agreement' ;
    rdfs:comment 'Master record for IP licensing agreements with manufacturers, brand partners, and third-party retailers authorizing production and sale of officially licensed merchandise. Captures licensor, licensee, licensed IP (team name, logo, player NIL rights), product categories covered, royalty rate, minimum guaranteed royalty, territory, agreement start/end dates, exclusivity terms, and compliance audit requirements. Supports NIL (Name Image and Likeness) tracking for athlete-branded merchandise.' .

ind:RoyaltyPayment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Merchandise ;
    rdfs:label 'Royalty Payment' ;
    rdfs:comment 'Transactional record of royalty calculations, periodic reporting submissions, and disbursements to IP rights holders (leagues, teams, athletes, player associations) based on licensed merchandise sales. Captures reporting period, gross sales by category/territory/channel, applicable royalty rate, calculated royalty due, adjustments, deductions, net royalty paid, payment date, payment status, report submission date, report status (draft, submitted, accepted, disputed), and licensor acceptance. Supports CBA and NIL compliance reporting, licensor audit rights, financial reconciliation of IP revenue sharing, and licensing agreement reporting obligations.' .

ind:FulfillmentShipment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Merchandise ;
    rdfs:label 'Fulfillment Shipment' ;
    rdfs:comment 'Outbound shipment record for merchandise orders fulfilled from warehouse or venue store to end customer. Captures carrier name, tracking number, ship date, estimated delivery date, actual delivery date, shipment status, shipping cost, package dimensions/weight, and origin location. Supports DTC e-commerce fulfillment SLA tracking and fan delivery experience management via Shopify Plus fulfillment workflows.' .

ind:ReturnRequest rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Merchandise ;
    rdfs:label 'Return Request' ;
    rdfs:comment 'Customer merchandise return and exchange request record capturing the reason for return, original order reference, items being returned, return authorization number, return method (mail-in, in-store), refund or exchange preference, refund amount, and resolution status. Supports omnichannel returns policy enforcement and reverse logistics tracking for both Shopify Plus and POS channels.' .

ind:PriceList rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Merchandise ;
    rdfs:label 'Price List' ;
    rdfs:comment 'Unified pricing and promotions configuration defining all price points and discount offers for merchandise SKUs across channels and customer segments. Captures base pricing (MSRP, wholesale, VIP member tiers), effective date ranges, channel applicability, and currency. Also owns promotional campaigns — percentage discounts, BOGO offers, free shipping, bundle deals, promo codes, usage limits, redemption counts, and event-day or championship launch pricing events. Supports dynamic pricing, fan loyalty reward redemptions, and promotional campaign performance tracking.' .

ind:Promotion rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Merchandise ;
    rdfs:label 'Promotion' ;
    rdfs:comment 'Promotional campaign record defining discount offers, bundle deals, and limited-time pricing events for merchandise. Captures promotion name, type (percentage discount, BOGO, free shipping, bundle), applicable SKUs or categories, discount value, promo code, start/end dates, channel restrictions, usage limits, and redemption count. Supports event-day promotions, championship merchandise launches, and fan loyalty reward redemptions.' .

ind:Supplier rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Merchandise ;
    rdfs:label 'Supplier' ;
    rdfs:comment 'Master record for merchandise suppliers, manufacturers, and contract producers who supply official licensed goods. Captures supplier name, type (manufacturer, distributor, print-on-demand), country of origin, contact details, payment terms, lead time, quality rating, certifications (ethical sourcing, ISO), and active status. Distinct from the partner domain\'s broader vendor registry — this is the merchandise-specific supplier master for procurement and quality management.' .

ind:MediaRightsDeal rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Broadcast ;
    rdfs:label 'Media Rights Deal' ;
    rdfs:comment 'Master record of media rights agreements with broadcast partners (RSN, OTT, linear TV networks), including granular rights window definitions. Captures rights holder, territory, sport/league, exclusivity type, deal value, contract term, revenue share structure, rights categories (live, replay, highlights, PPV), and per-window platform/territory/time-period entitlements with sublicensing permissions. SSOT for all broadcast rights ownership, licensing terms, and rights window enforcement. Sourced from Dalet Galaxy and Salesforce CRM.' .

ind:BroadcastSchedule rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Broadcast ;
    rdfs:label 'Broadcast Schedule' ;
    rdfs:comment 'Operational schedule of all planned and confirmed broadcast windows across linear TV, OTT, IPTV, and RSN platforms. Tracks event-to-channel assignments, air time, time zone, blackout applicability, feed type (live, tape-delay, replay), and production assignments. Core operational backbone for broadcast distribution — every broadcast begins as a schedule entry. Sourced from Dalet Galaxy broadcast workflow.' .

ind:Channel rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Broadcast ;
    rdfs:label 'Channel' ;
    rdfs:comment 'Master catalog of all broadcast channels and distribution outlets managed by Sports Entertainment — including RSN affiliates, OTT streaming channels, IPTV feeds, linear TV networks, and DTC streaming services. Captures channel name, type (linear/OTT/IPTV/DTC), platform operator, geographic coverage, language, resolution tier (SD/HD/4K), and active status.' .

ind:BlackoutRule rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Broadcast ;
    rdfs:label 'Blackout Rule' ;
    rdfs:comment 'Business rules governing broadcast blackouts by territory, event, channel, and rights agreement. Captures blackout type (local, national, international), triggering conditions (ticket sales threshold, RSN exclusivity, league mandate), effective date range, override eligibility, and enforcement mechanism. Critical for rights compliance and RSN exclusivity protection. Sourced from league governance and media rights deal terms.' .

ind:LiveFeed rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Broadcast ;
    rdfs:label 'Live Feed' ;
    rdfs:comment 'Operational record of each live broadcast feed produced and distributed for a scheduled event. Captures source venue, OB (Outside Broadcast) unit assignment, signal type (satellite, fiber, IP), encoding format (H.264/H.265), resolution (SD/HD/4K/8K), audio tracks, commentary language, feed status (active, standby, failed, backup), CDN origin endpoint, and redundancy configuration. Core operational entity for live broadcast production, distribution monitoring, and failover management.' .

ind:StreamingSubscription rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Broadcast ;
    rdfs:label 'Streaming Subscription' ;
    rdfs:comment 'Master record of fan streaming subscriptions to DTC and OTT broadcast services. Captures subscriber reference, subscription plan tier (basic, premium, all-access), billing cycle, start/end dates, platform (mobile, web, connected TV), auto-renewal flag, promotional rate, and current status. SSOT for streaming subscription lifecycle within the broadcast domain. Complements fan domain identity records.' .

ind:MediaAsset rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Broadcast ;
    rdfs:label 'Media Asset' ;
    rdfs:comment 'Master catalog of broadcast media assets managed within the Dalet Galaxy DAM system. Captures asset ID, title, asset type (live recording, highlight reel, replay, promo, interstitial), format, duration, resolution, language, sport/league association, event association, rights clearance status, archive location, and metadata tags. SSOT for broadcast-owned media asset inventory distinct from content domain editorial assets.' .

ind:RightsWindow rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Broadcast ;
    rdfs:label 'Rights Window' ;
    rdfs:comment 'Granular rights window records derived from media rights deals, defining the specific time periods, platforms, and territories in which a rights holder may broadcast specific content. Captures rights deal reference, content category, platform type, territory, window start/end, exclusivity flag, sublicensing permission, and rights fee allocation. Enables precise rights enforcement at the content-platform-territory level.' .

ind:Production rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Broadcast ;
    rdfs:label 'Production' ;
    rdfs:comment 'Operational record of each broadcast production instance for a scheduled event, including crew and commentary team assignments. Captures production type (live, studio, remote OB), director, technical producer, production company, equipment manifest, venue technical setup, graphics package version, pre-show/post-show segments, production status, and commentary team composition (play-by-play, color analyst, sideline reporter) with language and market designations. Links broadcast schedule to physical production execution. Sourced from Dalet Galaxy broadcast workflow.' .

ind:AudienceRating rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Broadcast ;
    rdfs:label 'Audience Rating' ;
    rdfs:comment 'Transactional record of broadcast audience measurement data per scheduled broadcast window. Captures channel, territory, measurement source (Nielsen, BARB, OzTAM, Comscore, internal streaming analytics), rating type (GRP, CPM, reach, frequency, viewership), total viewers, demographic breakdown (age, gender, income), peak concurrent viewers, average minute audience (AMA), share percentage, and time-shifted viewing. Operational data used for rights valuation, advertiser rate card justification, scheduling optimization, and contractual audience guarantee reconciliation.' .

ind:FanProfile rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fan ;
    rdfs:label 'Fan Profile' ;
    rdfs:comment 'SSOT master identity record for every individual fan across all engagement channels. Captures core demographic data (name, DOB, gender, nationality), contact details, preferred language, communication preferences, accessibility requirements, and account status. Sourced from Salesforce CRM and Adobe Experience Platform. Serves B2C individual fans, family account holders, season ticket holders, VIP members, and fan club members. This is the golden record for fan identity — all other fan domain entities reference this via fan_profile_id.' .

ind:Account rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fan ;
    rdfs:label 'Account' ;
    rdfs:comment 'Operational account record linking a fan profile to their registered digital or venue account. Tracks account type (individual, family, corporate group), account status, registration channel (web, mobile, in-venue kiosk), login credentials metadata, account tier, and tokenized payment methods on file (card brand, last four digits, expiry, default flag, PCI-DSS token). Distinct from fan_profile (identity) — this is the transactional account used for purchases, ticketing, loyalty redemptions, and stored payment instruments. Sourced from Salesforce CRM Account object.' .

ind:LoyaltyProgram rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fan ;
    rdfs:label 'Loyalty Program' ;
    rdfs:comment 'Master definition of each fan loyalty program offered across leagues, venues, and digital platforms. Captures program name, program type (points-based, tier-based, hybrid), earning rules summary, redemption rules summary, program currency name (e.g., \'Fan Points\', \'Arena Credits\'), program status, effective dates, and associated league or venue scope. Reference entity that governs all loyalty enrollment and transaction records.' .

ind:LoyaltyEnrollment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fan ;
    rdfs:label 'Loyalty Enrollment' ;
    rdfs:comment 'Records a fan\'s active enrollment in a specific loyalty program. Tracks enrollment date, current tier (e.g., Bronze, Silver, Gold, Platinum), tier qualification date, tier expiry date, cumulative points earned lifetime, current redeemable points balance, points expiry date, enrollment channel, and enrollment status. One fan may be enrolled in multiple programs. Sourced from Salesforce CRM and Adobe Experience Platform loyalty modules.' .

ind:LoyaltyTransaction rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fan ;
    rdfs:label 'Loyalty Transaction' ;
    rdfs:comment 'Transactional ledger of all loyalty point earning and redemption events for a fan. Captures transaction type (earn, redeem, adjust, expire, transfer), points amount, transaction date, triggering activity (ticket purchase, merchandise buy, check-in, content view, referral), reference order or event ID, running balance after transaction, and transaction status. Provides full audit trail for loyalty currency movements per fan enrollment.' .

ind:Membership rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fan ;
    rdfs:label 'Membership' ;
    rdfs:comment 'Master record for a fan\'s paid or complimentary membership and its associated benefits. Tracks membership type (season ticket holder, VIP club, fan club, OTT subscription), membership number, start/end dates, renewal status, auto-renew flag, fee, payment frequency, assigned seat block, and membership status. Also defines attached benefits: benefit type (priority ticketing, parking pass, merchandise discount, VIP lounge access, meet-and-greet, exclusive content), quantity/usage limits, redemption method, benefit value, and validity period. Distinct from loyalty enrollment — membership is a paid contractual relationship with defined benefit packages, not a points program.' .

ind:Segment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fan ;
    rdfs:label 'Segment' ;
    rdfs:comment 'CRM segmentation records classifying fans into behavioral, demographic, and value-based segments for targeted marketing and personalization. Captures segment name, segment type (RFM, behavioral, demographic, psychographic, predictive), definition criteria, segment size, creation date, last refresh date, and owning campaign or business unit. Sourced from Adobe Experience Platform audience segments and Salesforce CRM campaigns. Enables personalized fan engagement, DTC marketing, and campaign targeting.' .

ind:SegmentAssignment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fan ;
    rdfs:label 'Segment Assignment' ;
    rdfs:comment 'Association table recording which fans belong to which CRM segments at a given point in time. Tracks fan profile ID, segment ID, assignment date, assignment method (rule-based, manual, ML-predicted), assignment score or confidence, expiry date, and active flag. Supports time-variant segment membership for campaign targeting, personalization, and NPS cohort analysis. Carries its own business data (assignment method, score) beyond a simple M:N link.' .

ind:ConsentPreference rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fan ;
    rdfs:label 'Consent Preference' ;
    rdfs:comment 'GDPR and CCPA compliance record capturing each fan\'s data privacy consent and communication preferences. Tracks consent type (marketing email, SMS, push notification, data sharing with partners, profiling/personalization, cookie consent), consent status (granted, withdrawn, pending), consent date, withdrawal date, consent source (web form, mobile app, in-venue kiosk, call center), jurisdiction (EU-GDPR, CA-CCPA, UK-GDPR), and consent version. SSOT for all fan privacy obligations.' .

ind:EngagementEvent rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fan ;
    rdfs:label 'Engagement Event' ;
    rdfs:comment 'High-volume transactional record of every discrete fan engagement interaction across all channels — event attendance check-in, app session, content view, social share, merchandise browse, loyalty redemption, live stream watch, in-venue beacon detection, contest entry, and content follow/watchlist actions. Captures engagement type, channel (mobile app, web, in-venue, broadcast, social), timestamp, duration, associated event or content ID, device type, location context, and engagement value score. Sourced from Adobe Experience Platform behavioral data stream. Primary feed for RFM scoring, personalization models, and fan lifetime value calculation.' .

ind:Communication rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fan ;
    rdfs:label 'Communication' ;
    rdfs:comment 'Record of every outbound communication sent to a fan across all channels (email, SMS, push notification, direct mail, in-app message). Captures communication type, campaign or trigger name, channel, send timestamp, delivery status, open timestamp, click timestamp, opt-out flag, and associated segment or journey. Sourced from Salesforce CRM and Adobe Experience Platform campaign execution logs. Enables communication fatigue management and GDPR suppression compliance.' .

ind:ServiceCase rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fan ;
    rdfs:label 'Service Case' ;
    rdfs:comment 'CRM service case record for fan support interactions — ticketing disputes, membership billing issues, lost-and-found, accessibility accommodation requests, complaint escalations, and VIP concierge requests. Captures case type, case subject, description, priority, status, open date, resolution date, resolution notes, assigned agent, channel of origin (phone, email, chat, social, in-venue), and associated fan account. Sourced from Salesforce CRM Case object.' .

ind:PaymentMethod rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fan ;
    rdfs:label 'Payment Method' ;
    rdfs:comment 'Tokenized payment instrument records stored on file for a fan account. Captures payment method type (credit card, debit card, digital wallet, direct debit, gift card), card brand, last four digits, expiry month/year, billing address reference, tokenization provider, token value, default payment flag, and PCI-DSS compliance status. Enables one-click ticket purchases, auto-renewal of memberships, and merchandise checkout. Compliant with PCI-DSS tokenization standards.' .

ind:Club rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fan ;
    rdfs:label 'Club' ;
    rdfs:comment 'Master record for official fan clubs and their membership enrollments. Captures fan club name, associated team or athlete, club type (official, supporters trust, regional chapter), founding date, membership fee structure, club status, geographic territory, and club administrator contact. Also tracks individual member enrollments: membership number, join date, renewal date, membership tier within the club, dues payment status, voting rights, and chapter assignment. Enables fan club community participation, event access privileges, and engagement programs.' .

ind:RegulatoryFiling rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Regulatory Filing' ;
    rdfs:comment 'Master record of all regulatory submissions made to governing bodies including FIFA, IOC, NFL, NBA, MLB, NHL, FCC, SEC, WADA, and CAS. Tracks filing type, submission date, governing body (FK to governing_body), jurisdiction, filing status, due date, submitted by, acknowledgment reference, and linked compliance obligation (FK to obligation). Serves as the authoritative register of all formal regulatory submissions and enables deadline tracking and overdue alerting.' .

ind:GoverningBody rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Governing Body' ;
    rdfs:comment 'Reference master for all sports and entertainment governing bodies and regulatory authorities that Sports Entertainment must comply with — FIFA, IOC, NFL League Office, NBA League Office, WADA, CAS, FCC, SEC, OSHA, ADA, GDPR supervisory authorities, PCI SSC, SOX auditors, ISO 20121 certifiers. Captures body name, acronym, jurisdiction, regulatory domain, contact authority, and applicable frameworks.' .

ind:Obligation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Obligation' ;
    rdfs:comment 'Master catalog of all compliance obligations imposed on Sports Entertainment by governing bodies, regulations, and internal policies. Each obligation record captures the regulatory framework (GDPR, CCPA, PCI-DSS, WADA, ADA, SOX, OSHA, CBA), obligation type, effective date, expiry date, responsible business unit, enforcement consequence, review frequency, and linked governing body. Acts as the SSOT for what the organization is required to do.' .

ind:Policy rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Policy' ;
    rdfs:comment 'Master record of all internal compliance policies and codes of conduct enforced across Sports Entertainment — data privacy policies (GDPR/CCPA), anti-doping policies (WADA), payment security policies (PCI-DSS), venue accessibility policies (ADA), broadcast content policies (FCC), anti-corruption policies, and CBA-mandated conduct rules. Captures policy name, version, effective date, owner, approval authority, review cycle, and linked regulatory obligation.' .

ind:AuditEngagement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Audit Engagement' ;
    rdfs:comment 'Complete audit lifecycle record from planning through execution and disposition for all compliance audits — PCI-DSS QSA audits, SOX internal controls, OSHA venue safety inspections, ADA accessibility audits, GDPR data protection audits, WADA program audits, and ISO 20121 sustainability audits. Captures planned audit details (audit type, scheduled date, auditor assignment, scope, target business unit, venue/system in scope, cycle frequency, linked obligation) and execution details (actual start/end dates, lead auditor, audit firm, findings count, overall opinion, report issuance date, management response due date, final disposition). Status progression from scheduled through in-progress to completed enables both forward-looking audit pipeline management and historical audit trail.' .

ind:AuditFinding rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Audit Finding' ;
    rdfs:comment 'Individual finding or observation raised during a compliance audit engagement. Captures finding reference, linked audit engagement, finding category (critical/major/minor/observation), regulatory framework implicated, description of non-conformance, root cause, recommended remediation, assigned owner, target remediation date, and finding status (open/in-remediation/closed/accepted-risk). Supports PCI-DSS, SOX, OSHA, ADA, and GDPR audit trails.' .

ind:DopingTest rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Doping Test' ;
    rdfs:comment 'WADA anti-doping program operational record encompassing both testing events and athlete whereabouts filings. For tests: captures test reference number, athlete identifier, test type (in-competition/out-of-competition), sample type (urine/blood/ABP), collection date, collection location, DCO identifier, laboratory reference, chain of custody status, result status (negative/adverse/atypical/pending), and WADA ADAMS reference. For whereabouts: captures filing period (quarter), submission date, overnight location, training and competition schedule, filing compliance status (compliant/missed/incomplete), and missed filing count toward Article 2.4 violation threshold. Core operational record for the complete anti-doping program lifecycle from whereabouts compliance through sample collection and result management.' .

ind:DopingViolation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Doping Violation' ;
    rdfs:comment 'Record of an Anti-Doping Rule Violation (ADRV) issued against an athlete following an adverse or atypical analytical finding or non-analytical violation (whereabouts failure, tampering, refusal). Captures violation type, linked doping test, notification date, provisional suspension date, hearing date, sanction imposed (ban duration), appeal status, CAS arbitration reference if appealed, and reinstatement eligibility date. Governed by WADA Code and CAS jurisprudence.' .

ind:WhereaboutsFiling rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Whereabouts Filing' ;
    rdfs:comment 'WADA whereabouts information filing submitted by registered testing pool athletes. Captures athlete identifier, filing period (quarter), submission date, submission method (ADAMS portal), overnight location, training schedule, competition schedule, and filing compliance status (compliant/missed/incomplete). Three missed filings within 12 months constitute a whereabouts failure violation under WADA Code Article 2.4.' .

ind:EligibilityCertification rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Eligibility Certification' ;
    rdfs:comment 'Unified eligibility, certification, and exemption record confirming or modifying compliance status for athletes, participants, venues, and events. For certifications: covers league eligibility, amateur status, age/nationality eligibility, anti-doping clearance, medical clearance, ADA venue accessibility certification, and event safety certification. For exemptions: covers Therapeutic Use Exemptions (TUEs per WADA Code Article 4.4), broadcast territorial exemptions, ADA undue hardship exemptions, and FCC content exemptions. Captures record type (certification/exemption), issuing or reviewing authority, certified/exempt entity, effective and expiry dates, status, conditions or restrictions, medical justification (for TUEs), approved substance/method, WADA ADAMS TUE reference, and accommodation requirements. Integrates with athlete domain for competition gating and venue domain for operational permits.' .

ind:ArbitrationCase rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Arbitration Case' ;
    rdfs:comment 'Unified dispute resolution and case management record for all legal proceedings — CAS (Court of Arbitration for Sport) arbitration, internal arbitration, civil litigation, regulatory investigations, criminal referrals, IP infringement, employment disputes, and CBA grievances. Captures case reference, case type and jurisdiction (sports arbitration vs civil court vs regulatory), claimant/respondent or plaintiff/defendant, filing date, panel or judge composition, external counsel, hearing and trial dates, interim measures, discovery status, estimated liability, award or judgment summary, settlement terms, enforcement status, and matter management reference. Serves as the SSOT for all dispute proceedings regardless of forum.' .

ind:PrivacyRequest rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Privacy Request' ;
    rdfs:comment 'Unified data subject interaction record under GDPR, CCPA, and applicable privacy regulations covering both rights requests and consent management. For requests: captures request type (access/SAR, erasure, portability, rectification, restriction, opt-out of sale), requestor identity, submission channel, verification status, regulatory deadline (30-day GDPR / 45-day CCPA), fulfillment date, and response outcome. For consent: captures consent type (marketing, analytics, third-party sharing, cookies, biometric data), consent channel (web, app, in-venue kiosk), consent timestamp, policy version, withdrawal timestamp, and consent proof reference. Provides the single fan-privacy SSOT for all data subject touchpoints and integrates with Adobe Experience Platform consent management.' .

ind:DataProcessingRecord rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Data Processing Record' ;
    rdfs:comment 'GDPR Article 30 Record of Processing Activities (RoPA) with integrated Article 35 Data Protection Impact Assessment (DPIA/PIA) for all personal data processing activities. The authoritative register and risk assessment record capturing processing activity name, controller/processor role, data categories (fan PII, athlete health data, payment data, biometric data), purposes, legal basis, data subjects, retention period, third-party recipients, cross-border transfer mechanisms, security measures, DPIA/PIA assessment type, risk level, identified risks, risk mitigation measures, DPO consultation date, supervisory authority consultation requirement, assessment outcome, approval date, and review schedule. Mandatory for GDPR compliance and required before launching new fan platforms, biometric ticketing, athlete health systems, or any high-risk processing activity.' .

ind:StaffPlan rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Venue ;
    rdfs:label 'Staff Plan' ;
    rdfs:comment 'Event-day staffing plan for a facility specifying required headcount by role (security, medical, ushers, concessions, parking, cleaning, AV/production) for a specific event or event type. Attributes include plan name, event reference, facility reference, role category, required headcount, confirmed headcount, staffing agency reference, shift start/end times, credential requirements, cost estimate, actual cost, and plan approval status. Distinct from workforce domain employee records — this is the venue\'s operational labor demand and fulfillment plan for event execution.' .

ind:TransactionWindow rdf:type rdfs:Class ;
    rdfs:subClassOf ind:League ;
    rdfs:label 'Transaction Window' ;
    rdfs:comment 'Defines official league transaction periods (trade deadline, free agency window, waiver period, DFA window, international signing period) with open/close dates, eligible transaction types, franchise participation rules, and penalty provisions for violations. Anchors all roster movement and trade activity to authorized periods. Supports compliance validation for league_trade_transaction and waiver_claim records.' .

ind:BroadcastWindow rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Event ;
    rdfs:label 'Broadcast Window' ;
    rdfs:comment 'Association entity linking fixtures to their assigned broadcast windows and production requirements — capturing primary broadcaster, kickoff time constraints driven by broadcast, and territory-specific start times.' .

ind:TicketTransfer rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Ticketing ;
    rdfs:label 'Ticket Transfer' ;
    rdfs:comment 'Peer-to-peer ticket transfer records between fan accounts — capturing sender, recipient, transfer method (mobile, email), transfer timestamp, and terms acceptance.' .

ind:BettingMarket rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Gaming ;
    rdfs:label 'Betting Market' ;
    rdfs:comment 'Master catalog of all wagering market definitions available across sports and entertainment events — covering moneyline, spread, totals (over/under), futures, parlays, teasers, and live in-play markets. Captures market type code, sport/league scope, settlement rules, market status (open, suspended, closed, settled), minimum/maximum stake limits, and jurisdiction availability flags. SSOT for all market definitions consumed by odds feeds, prop bet catalogs, and regulatory reporting.' .

ind:OddsFeed rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Gaming ;
    rdfs:label 'Odds Feed' ;
    rdfs:comment 'High-frequency transactional record of odds price updates received from odds compilers and third-party odds providers (e.g., Sportradar, Kambi) for each betting market. Captures market ID, selection ID, decimal/fractional/American odds format values, implied probability, line movement direction, feed source, timestamp of update, and feed status. Supports real-time odds display, line movement analytics, and audit trails for regulatory compliance.' .

ind:Wager rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Gaming ;
    rdfs:label 'Wager' ;
    rdfs:comment 'Core transactional record of every individual bet placed by a registered bettor across all wagering channels — retail sportsbook, mobile app, kiosk, and online platform. Captures bettor account ID, betting market ID, selection, stake amount, odds at time of placement, potential payout, wager type (straight, parlay, teaser, prop), placement channel, placement timestamp, wager status (pending, won, lost, void, cashed out), settlement amount, and settlement timestamp. Primary transactional entity for sportsbook operations and regulatory reporting.' .

ind:BettorAccount rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Gaming ;
    rdfs:label 'Bettor Account' ;
    rdfs:comment 'Gaming-domain operational account record for each registered bettor on the sportsbook or fantasy platform. Distinct from fan.fan_profile (the enterprise identity SSOT) — this entity captures gaming-specific account attributes: account number, KYC verification status, age verification status, identity document reference, account tier (standard, VIP, professional), deposit limit settings, self-exclusion status, responsible gaming flags, jurisdiction of registration, account open date, and account balance. Links to fan.fan_profile via FK in the linking step.' .

ind:PropBet rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Gaming ;
    rdfs:label 'Prop Bet' ;
    rdfs:comment 'Master catalog of proposition bet offerings — player props (anytime touchdown scorer, first basket, strikeout totals), game props (first team to score, margin of victory), and novelty/entertainment props. Captures prop bet code, description, associated event/fixture, player or team subject, prop category, market open/close timestamps, settlement criteria, and jurisdiction availability. Distinct from betting_market (which covers standard market types) — prop_bet is the specific offering catalog for proposition wagering.' .

ind:FantasyLeague rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Gaming ;
    rdfs:label 'Fantasy League' ;
    rdfs:comment 'Master record for each fantasy sports league instance — public, private, and corporate leagues across NFL, NBA, MLB, NHL, and other sports. Captures league name, sport, season, scoring format (standard, PPR, half-PPR, dynasty, DFS), draft type (snake, auction, auto-pick), roster configuration, entry fee, prize pool structure, commissioner account ID, league status (forming, active, completed), and platform (DraftKings, FanDuel, proprietary). SSOT for fantasy league definitions.' .

ind:FantasyRoster rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Gaming ;
    rdfs:label 'Fantasy Roster' ;
    rdfs:comment 'Transactional record of a fantasy team\'s active roster at a point in time within a fantasy league season. Captures fantasy team ID, fantasy league ID, roster week/period, each rostered athlete slot (QB, RB, WR, FLEX, etc.), athlete ID, acquisition type (drafted, waiver, trade, free agent pickup), acquisition date, and roster lock timestamp. Supports weekly lineup management, waiver processing, and season-long roster history.' .

ind:FantasyTeam rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Gaming ;
    rdfs:label 'Fantasy Team' ;
    rdfs:comment 'Master record for each fantasy team registered within a fantasy league. Captures team name, owner bettor account ID, league ID, draft position, total points scored (season-to-date), wins/losses/ties record, waiver priority, trade block status, and team logo/branding. Distinct from fantasy_league (the league definition) and fantasy_roster (the weekly lineup). SSOT for fantasy team identity and season-long standings.' .

ind:Wallet rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Gaming ;
    rdfs:label 'Wallet' ;
    rdfs:comment 'Financial ledger record for each bettor account\'s gaming wallet — tracking real-money balance, bonus balance, withdrawable balance, pending wager holds, and lifetime deposit/withdrawal totals. Captures wallet ID, bettor account ID, currency, current real-money balance, bonus credit balance, pending hold amount, last transaction timestamp, and wallet status. Distinct from fan.payment_method (stored payment instruments) — this is the in-platform gaming funds ledger.' .

ind:Jurisdiction rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Gaming ;
    rdfs:label 'Jurisdiction' ;
    rdfs:comment 'Reference master for all gaming regulatory jurisdictions in which Sports Entertainment holds or is pursuing a sports wagering or fantasy sports operating license. Captures jurisdiction code, jurisdiction name (state/province/country), license type (sports wagering, DFS, iGaming), regulatory body name, license number, license status (active, pending, suspended, expired), license expiry date, tax rate on gross gaming revenue (GGR), and applicable responsible gaming mandates. SSOT for jurisdiction-level compliance configuration.' .

ind:ResponsibleGamingLimit rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Gaming ;
    rdfs:label 'Responsible Gaming Limit' ;
    rdfs:comment 'Master record of responsible gaming controls and self-imposed limits configured by a bettor account — deposit limits (daily/weekly/monthly), loss limits, wager limits, session time limits, cooling-off periods, and self-exclusion elections. Captures limit type, limit amount or duration, effective date, expiry date, limit status, source (player-initiated vs. operator-imposed vs. regulator-mandated), and jurisdiction context. Critical for regulatory compliance with responsible gaming mandates across all licensed jurisdictions.' .

ind:SelfExclusion rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Gaming ;
    rdfs:label 'Self Exclusion' ;
    rdfs:comment 'Transactional record of a bettor\'s self-exclusion election or operator-imposed exclusion from gaming activities. Captures bettor account ID, exclusion type (voluntary self-exclusion, operator exclusion, state-mandated exclusion via NCPG/state exclusion lists), exclusion scope (single platform, all platforms, statewide), exclusion start date, exclusion end date (or permanent flag), reinstatement request date, reinstatement approval status, and jurisdiction. Distinct from responsible_gaming_limit — self-exclusion is a full account suspension, not a limit adjustment.' .

ind:RegulatoryReport rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Gaming ;
    rdfs:label 'Regulatory Report' ;
    rdfs:comment 'Master record of all regulatory reports submitted to gaming authorities across licensed jurisdictions — gross gaming revenue (GGR) reports, suspicious activity reports (SAR), self-exclusion compliance reports, responsible gaming program reports, and AML/KYC compliance filings. Captures report type, jurisdiction, reporting period, submission date, submitted by, report status (draft, submitted, acknowledged, under review, accepted), and regulatory body reference number. Supports multi-jurisdiction regulatory compliance operations.' .

ind:Contest rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Gaming ;
    rdfs:label 'Contest' ;
    rdfs:comment 'Master record for Daily Fantasy Sports (DFS) contests and tournament-style gaming competitions — capturing contest name, sport, slate (game set), contest type (GPP/tournament, 50/50, head-to-head, satellite), entry fee, maximum entries per player, total entries cap, prize pool amount, prize pool structure (top-heavy vs. flat), contest start time, lock time, status (open, locked, live, completed, cancelled), and platform. Distinct from fantasy_league (season-long) — contest covers single-slate DFS competitions.' .

ind:ContestEntry rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Gaming ;
    rdfs:label 'Contest Entry' ;
    rdfs:comment 'Transactional record of a bettor\'s entry into a DFS contest — capturing contest ID, bettor account ID, entry timestamp, entry fee paid, lineup submitted (athlete selections by position), total projected points, actual points scored, final rank, prize won, and payout status. Supports contest settlement, prize distribution, and multi-entry tracking for DFS regulatory compliance.' .

ind:Payout rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Gaming ;
    rdfs:label 'Payout' ;
    rdfs:comment 'Transactional record of all gaming prize and winnings payouts disbursed to bettor accounts — covering wager settlements, DFS contest prizes, fantasy league prize distributions, and bonus conversions. Captures payout type, bettor account ID, wager or contest entry reference, gross payout amount, tax withholding amount (W-2G threshold compliance), net payout amount, payout method (wallet credit, check, ACH, wire), payout timestamp, and payout status. Supports financial reconciliation, tax reporting (IRS W-2G), and regulatory GGR calculations.' .

ind:Credential rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Security ;
    rdfs:label 'Credential' ;
    rdfs:comment 'Master record for all security credentials issued to personnel operating at Sports Entertainment venues and events — staff badges, media passes, VIP access cards, contractor IDs, law enforcement credentials, and athlete/team credentials. Captures credential type, holder identity reference, issuing authority, validity period, access tier, biometric linkage flag, barcode/RFID identifier, revocation status, and chain-of-custody audit fields. SSOT for credential identity across all access control operations.' .

ind:AccessZone rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Security ;
    rdfs:label 'Access Zone' ;
    rdfs:comment 'Master catalog of all defined physical access control zones within Sports Entertainment venues — field/pitch level, locker rooms, press box, broadcast compound, VIP hospitality, back-of-house, command center, parking compounds, and public concourse zones. Captures zone code, zone name, venue reference, zone tier (public/restricted/secured/sterile), maximum occupancy, surveillance coverage flag, and zone adjacency metadata used for crowd flow modeling.' .

ind:CredentialAssignment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Security ;
    rdfs:label 'Credential Assignment' ;
    rdfs:comment 'Transactional record linking a specific credential to an authorized holder for a defined event or period. Captures credential ID, holder type (staff, media, contractor, law enforcement, athlete, sponsor), event or venue scope, assignment date, assigned-by officer, pickup confirmation, return confirmation, and any special access annotations. Enables per-event credentialing workflows and post-event reconciliation.' .

ind:AccessEvent rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Security ;
    rdfs:label 'Access Event' ;
    rdfs:comment 'High-volume transactional record of every physical access control scan event at venue entry and internal zone checkpoints — credential presented, zone accessed, timestamp, scan result (granted/denied/flagged), reader device ID, officer override flag, and denial reason code. Feeds real-time occupancy tracking, post-event forensic review, and compliance audit trails. Distinct from ticketing.gate_scan which covers fan ticket entitlement scanning.' .

ind:ScreeningCheckpoint rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Security ;
    rdfs:label 'Screening Checkpoint' ;
    rdfs:comment 'Master record for all physical security screening checkpoints deployed at Sports Entertainment venues — magnetometer lanes, bag check stations, pat-down areas, vehicle inspection points, and credentialing desks. Captures checkpoint code, venue zone assignment, checkpoint type, equipment deployed (WTMD, X-ray, ETD), staffing requirement, throughput capacity (persons/hour), activation schedule, and ADA-accessible lane flag.' .

ind:ScreeningEvent rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Security ;
    rdfs:label 'Screening Event' ;
    rdfs:comment 'Transactional record of individual fan or personnel screening interactions at security checkpoints — capturing checkpoint ID, timestamp, screening outcome (cleared/secondary screening/denied entry/prohibited item confiscated), prohibited item type if applicable, officer ID, and escalation flag. Supports post-event security review, prohibited item trend analysis, and checkpoint throughput reporting.' .

ind:SecurityIncident rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Security ;
    rdfs:label 'Security Incident' ;
    rdfs:comment 'Core transactional record for all security incidents occurring at Sports Entertainment venues and events — fan altercations, ejections, prohibited item seizures, field invasions, credentialing violations, threats, suspicious packages, and law enforcement interventions. Captures incident type, severity tier, location (zone/section/gate), involved parties, responding officers, law enforcement notification flag, medical referral flag, narrative, disposition, and case closure status. Distinct from venue.safety_incident which covers physical safety/OSHA events.' .

ind:EjectionRecord rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Security ;
    rdfs:label 'Ejection Record' ;
    rdfs:comment 'Transactional record of every fan or personnel ejection from a Sports Entertainment venue or event. Captures ejection date/time, venue zone, reason code (intoxication, fighting, field invasion, harassment, prohibited item), ejecting officer, law enforcement handoff flag, ban recommendation flag, originating security incident reference, and fan account reference for ban enforcement. Feeds the venue ban registry and repeat offender tracking.' .

ind:EmergencyResponsePlan rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Security ;
    rdfs:label 'Emergency Response Plan' ;
    rdfs:comment 'Master record for all emergency response plans governing Sports Entertainment venues and events — active shooter protocols, bomb threat procedures, mass casualty incident (MCI) response, fire evacuation, severe weather shelter-in-place, and medical emergency escalation. Captures plan type, venue scope, version, activation triggers, command structure, law enforcement coordination contacts, medical triage zone assignments, and regulatory approval status (DHS, local fire marshal).' .

ind:EmergencyActivation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Security ;
    rdfs:label 'Emergency Activation' ;
    rdfs:comment 'Transactional record of each emergency response plan activation at a Sports Entertainment venue or event. Captures activation timestamp, plan activated, activating authority, event reference, incident trigger description, command post location, agencies notified (police, fire, EMS, FBI), evacuation initiated flag, all-clear timestamp, after-action report reference, and casualties/injuries count. SSOT for emergency response execution history.' .

ind:Venue rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Venue ;
    rdfs:label 'Venue' ;
    rdfs:comment 'Master reference table for venue. ' .

ind:FiscalPeriod rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Fiscal Period' ;
    rdfs:comment 'Master reference table for fiscal_period. Referenced by fiscal_period_id.' .

ind:Agent rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Athlete ;
    rdfs:label 'Agent' ;
    rdfs:comment 'Master reference table for agent. Referenced by agent_id.' .

ind:Agency rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Athlete ;
    rdfs:label 'Agency' ;
    rdfs:comment 'Master reference table for agency. Referenced by agency_id.' .

ind:Category rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Content ;
    rdfs:label 'Category' ;
    rdfs:comment 'Master reference table for content_category. Referenced by content_category_id.' .

ind:RightsHolder rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Broadcast ;
    rdfs:label 'Rights Holder' ;
    rdfs:comment 'Master reference table for rights_holder. Referenced by rights_holder_id.' .

ind:Licensee rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Broadcast ;
    rdfs:label 'Licensee' ;
    rdfs:comment 'Master reference table for licensee. Referenced by licensee_id.' .

ind:Investigation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Investigation' ;
    rdfs:comment 'Master reference table for investigation. Referenced by investigation_id.' .

ind:Campaign rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fan ;
    rdfs:label 'Campaign' ;
    rdfs:comment 'Master reference table for campaign. Referenced by acquisition_campaign_id.' .

ind:Team rdf:type rdfs:Class ;
    rdfs:subClassOf ind:League ;
    rdfs:label 'Team' ;
    rdfs:comment 'Master reference table for team. Referenced by preferred_team_id.' .

ind:PaymentRun rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Payment Run' ;
    rdfs:comment 'Master reference table for payment_run. Referenced by payment_run_id.' .

ind:Ledger rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Ledger' ;
    rdfs:comment 'Master reference table for ledger. Referenced by ledger_id.' .

ind:Operator rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Gaming ;
    rdfs:label 'Operator' ;
    rdfs:comment 'Master reference table for operator. Referenced by operator_id.' .

ind:Selection rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Gaming ;
    rdfs:label 'Selection' ;
    rdfs:comment 'Master reference table for selection. Referenced by selection_id.' .

ind:ProductCategory rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Merchandise ;
    rdfs:label 'Product Category' ;
    rdfs:comment 'Master reference table for product_category. Referenced by product_category_id.' .

ind:Property rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sponsorship ;
    rdfs:label 'Property' ;
    rdfs:comment 'Master reference table for property. Referenced by property_id.' .

ind:InventoryUnit rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Sponsorship ;
    rdfs:label 'Inventory Unit' ;
    rdfs:comment 'Master reference table for inventory_unit. Referenced by inventory_unit_id.' .

ind:Type rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Event ;
    rdfs:label 'Type' ;
    rdfs:comment 'Master reference table for event_type. Referenced by event_type_id.' .

ind:PriceZone rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Ticketing ;
    rdfs:label 'Price Zone' ;
    rdfs:comment 'Master reference table for price_zone. Referenced by price_zone_id.' .

ind:OfficialAssignment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:League ;
    rdfs:label 'Official Assignment' ;
    rdfs:comment 'This association product represents the Assignment between an official and a game_result. It captures the formal crew assignment record created by the league officiating bureau for each game, recording which official served in which crew role for a specific game result, along with per-game performance grading, VAR/TMO intervention tracking, and conflict-of-interest clearance. Each record links one official to one game_result and carries attributes that exist only in the context of that specific assignment.. Existence Justification: In professional sports leagues, each game is officiated by a multi-person crew (head referee, linesmen, VAR operators, etc.), meaning one game_result is associated with multiple officials. Simultaneously, each official works many games per season. The league officiating department actively manages these crew assignments as a formal business process — creating, updating, and tracking them with role, performance grade, and conflict-of-interest data that belongs to neither the official nor the game result alone.' .

ind:CollectionItem rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Content ;
    rdfs:label 'Collection Item' ;
    rdfs:comment 'This association product represents the membership relationship between a content collection and a digital asset in the Dalet Galaxy DAM. It captures the operational fact that a specific asset has been curated into a specific collection, including its position in the sequence, when it was added, who added it, and whether it is featured within that collection. Each record links one collection to one asset with attributes that exist only in the context of this membership relationship — not on the collection or asset alone.. Existence Justification: In DAM (Digital Asset Management) operations for sports entertainment, a content collection is explicitly defined as a curated grouping of multiple assets (highlight reels, playlists, galleries), and any single asset (a video clip, photo, article) can appear in multiple collections simultaneously — e.g., a LeBron James dunk clip may appear in a \'Top 10 Plays\' collection, a \'Lakers Season Highlights\' collection, and a \'PPV Event Bundle\'. This is a foundational operational relationship in Dalet Galaxy DAM, where collection membership is actively managed by editorial staff with ordering, featured flags, and timestamps. The relationship is a recognized business entity (\'collection membership\' or \'collection item\') that humans create, reorder, feature, and remove as part of daily content operations.' .

ind:AssetTag rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Content ;
    rdfs:label 'Asset Tag' ;
    rdfs:comment 'This association product represents the tagging event between a content asset and a controlled vocabulary metadata tag in the Dalet Galaxy DAM. It captures the operational record of each tag application — whether performed by an editorial user, an AI auto-tagging pipeline, or a bulk ingest process. Each record links one asset to one metadata tag and carries attributes that exist only in the context of that specific tagging action: when it was applied, by whom or what system, via which method, and with what AI confidence. This is the authoritative source of truth for all asset-tag associations across OTT, broadcast, and digital platforms.. Existence Justification: In DAM (Digital Asset Management) operations, a single content asset (e.g., a match highlight video) is tagged with MULTIPLE controlled vocabulary metadata tags simultaneously — sport, league, team, athlete, event type, mood, content rating, etc. Conversely, a single metadata tag (e.g., \'Premier League\') is applied to thousands of assets. This is the canonical M:N relationship in every DAM system: content tagging. The business actively manages these tag applications through editorial workflows, AI auto-tagging pipelines, and compliance review processes — each tagging event carries its own operational data (who tagged it, when, how, with what confidence).' .

ind:PlanZoneDesignation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Security ;
    rdfs:label 'Plan Zone Designation' ;
    rdfs:comment 'This association product represents the Role-based designation between emergency_response_plan and access_zone. It captures the specific operational role each physical access zone plays within a given emergency response plan — including triage staging, evacuation assembly, shelter-in-place, and command post assignments. Each record links one emergency_response_plan to one access_zone with attributes (zone role, activation sequence, triage/evacuation/shelter flags) that exist only in the context of this plan-zone pairing and cannot be stored on either entity alone.. Existence Justification: In sports venue emergency management, a single emergency response plan explicitly designates multiple access zones for specific operational roles — triage staging, evacuation assembly, shelter-in-place, command post. Conversely, a single access zone (e.g., the field level or a parking compound) can be designated under multiple emergency response plans (active shooter plan, MCI plan, severe weather plan) each assigning it a different role and activation sequence. The business actively manages these designations as a named operational concept called \'Plan Zone Designation\', and the relationship carries its own data (zone role, activation sequence, triage/evacuation flags) that belongs to neither the plan nor the zone alone.' .

ind:ClubMembership rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fan ;
    rdfs:label 'Club Membership' ;
    rdfs:comment 'This association product represents the Enrollment between fan_profile and club. It captures the operational lifecycle of a fan\'s membership in an official fan club — including join date, membership tier, renewal date, dues payment status, and membership number. Each record links one fan to one club and carries attributes that exist only in the context of that specific fan-club enrollment. Enables CRM segmentation, loyalty benefit delivery, compliance tracking, and fan club governance.. Existence Justification: In sports entertainment, fans actively join multiple official fan clubs (e.g., a fan can be a member of both the LA Lakers Official Fan Club and a regional supporters chapter), and each club has many member fans. This is a genuine operational M:N relationship: the business actively manages fan club memberships as a lifecycle concept — fans enroll, pay dues, renew, and hold tiered membership status within each club. The relationship is not derivable from existing FKs; it requires its own record with join_date, membership_tier, renewal_date, dues payment status, and membership number.' .

ind:SupplierCategoryAuthorization rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Merchandise ;
    rdfs:label 'Supplier Category Authorization' ;
    rdfs:comment 'This association product represents the formal Contract between a merchandise supplier and a product category, capturing the authorization for that supplier to produce goods in that category under defined commercial terms. Each record documents one supplier\'s approval to manufacture or supply a specific product category, including pricing, lead time, order minimums, preferred status, and the validity window of the authorization. This is the operational Approved Supplier List at the category level, distinct from the licensing_agreement (which governs IP rights with the licensor) and from the sku_catalog (which represents resulting products).. Existence Justification: In licensed merchandise operations, a supplier is formally approved to produce specific product categories under defined commercial terms — this is the \'Approved Supplier Category Agreement\' or \'Supplier Category Authorization\'. A single supplier can be authorized to produce multiple product categories (e.g., Apparel AND Accessories), and a single product category can be produced by multiple approved suppliers. This is an actively managed operational record: procurement teams create, update, and expire these authorizations as part of sourcing and brand compliance workflows.' .

ind:ParkingActivation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Venue ;
    rdfs:label 'Parking Activation' ;
    rdfs:comment 'This association product represents the Event (activation) between event_day_ops and parking_lot. It captures the operational record of which parking lots are activated for a specific event, including per-lot capacity allocation, open/close timing, shuttle status, and activation state. Each record links one event_day_ops to one parking_lot with attributes that exist only in the context of this activation relationship — data that belongs neither to the event-day operation record nor to the parking lot master record alone.. Existence Justification: In live event venue operations, parking lot activation is a genuinely managed business process: operations managers explicitly open and close specific lots for each event, allocate capacity per lot, and track shuttle status and timing. A single event_day_ops record activates multiple parking lots, and a single parking lot is activated across many different event_day_ops records over its lifetime. The relationship itself — which lots are open, when, with how many spaces allocated — is operationally managed and carries its own data.' .

ind:ConfigSectionAllocation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Venue ;
    rdfs:label 'Config Section Allocation' ;
    rdfs:comment 'This association product represents the operational allocation contract between a capacity_config and a seating_section. It captures how each seating section is configured — activated, killed, or restricted — within a specific capacity configuration profile. Each record links one capacity_config to one seating_section and carries attributes that exist only in the context of that pairing: how many seats are allocated, how many are killed, the section\'s operational status within the config, any price zone override, and access restrictions. Directly analogous to the manifest line concept in Archtics and Ticketmaster venue ticketing platforms.. Existence Justification: In professional sports and live entertainment venue operations, a capacity configuration (e.g., \'End-Stage Concert\', \'Full Bowl Sports\', \'Half-House Hockey\') explicitly governs which seating sections are active, how many seats are allocated, which sections are killed, and what price zone overrides apply — for that specific configuration. A single capacity_config spans many seating_sections, and a single seating_section participates in many capacity_configs over its operational lifetime (e.g., Section 101 is open for a sold-out game, partially killed for a smaller event, and entirely closed for a concert stage setup). This is the \'manifest\' concept in Archtics ticketing platforms — a recognized operational entity that venue operations teams actively create, update, and manage per event format.' .

# --- Attribute Properties ---
ind:assetId rdf:type rdf:Property ;
    rdfs:label 'Asset Id' ;
    rdfs:comment 'Unique surrogate identifier for each digital content asset record in the Dalet Galaxy DAM system. Primary key for the asset master entity.' ;
    rdfs:domain ind:Content ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Asset .

ind:assetAthleteAthleteProfileId rdf:type rdf:Property ;
    rdfs:label 'Asset Athlete Athlete Profile Id' ;
    rdfs:comment 'Reference to the primary athlete featured in this asset. Used for NIL (Name, Image, and Likeness) rights tracking, athlete profile content aggregation, and personalised fan experience delivery via Adobe Experience Platform.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AthleteProfile .

ind:assetAthleteProfileId rdf:type rdf:Property ;
    rdfs:label 'Asset Athlete Profile Id' ;
    rdfs:comment 'Reference to the primary athlete featured in this asset. Used for NIL (Name, Image, and Likeness) rights tracking, athlete profile content aggregation, and personalised fan experience delivery via Adobe Experience Platform.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AthleteProfile .

ind:assetEventFixtureId rdf:type rdf:Property ;
    rdfs:label 'Asset Event Fixture Id' ;
    rdfs:comment 'Reference to the sports or entertainment event (match, game, concert, tournament) that this asset is associated with. Enables event-centric content aggregation, broadcast rights enforcement, and fan engagement analytics.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Fixture .

ind:assetFixtureId rdf:type rdf:Property ;
    rdfs:label 'Asset Fixture Id' ;
    rdfs:comment 'Reference to the sports or entertainment event (match, game, concert, tournament) that this asset is associated with. Enables event-centric content aggregation, broadcast rights enforcement, and fan engagement analytics.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Fixture .

ind:categoryId rdf:type rdf:Property ;
    rdfs:label 'Category Id' ;
    rdfs:comment 'Foreign key linking to content.content_category. Business justification: Assets belong to content categories for taxonomy and rights management. Currently has content_category STRING which should be normalized to content_category.content_category_id FK. Content_category ta' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Category .

ind:competitionRoundId rdf:type rdf:Property ;
    rdfs:label 'Competition Round Id' ;
    rdfs:comment 'Foreign key linking to event.competition_round. Business justification: Round draw graphics, round preview videos, and round summary assets are produced and archived at the competition round level for rights management and archive retrieval. asset has fixture_id but no ro' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CompetitionRound .

ind:dataProcessingRecordId rdf:type rdf:Property ;
    rdfs:label 'Data Processing Record Id' ;
    rdfs:comment 'Foreign key linking to compliance.data_processing_record. Business justification: Assets containing personal data (athlete footage, UGC, biometric overlays) must reference the GDPR/CCPA data processing record governing their retention and usage rights. Content rights managers query' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DataProcessingRecord .

ind:draftId rdf:type rdf:Property ;
    rdfs:label 'Draft Id' ;
    rdfs:comment 'Foreign key linking to league.draft. Business justification: Draft-day content (pick announcement footage, war-room clips, prospect profiles) is a major annual content production event. Assets are cataloged against the specific draft for rights management, spon' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Draft .

ind:franchiseId rdf:type rdf:Property ;
    rdfs:label 'Franchise Id' ;
    rdfs:comment 'Foreign key linking to league.franchise. Business justification: Content assets produced by or featuring a specific franchise (team highlight reels, franchise media) require franchise attribution for rights ownership and team-branded asset management. Essential for' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Franchise .

ind:gameResultId rdf:type rdf:Property ;
    rdfs:label 'Game Result Id' ;
    rdfs:comment 'Foreign key linking to league.game_result. Business justification: Post-game highlight production, clip libraries, and broadcast packages are directly tied to specific game results. Content operations teams pull game_result metadata (score, OT, attendance) to tag and' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GameResult .

ind:governingPolicyId rdf:type rdf:Property ;
    rdfs:label 'Governing Policy Id' ;
    rdfs:comment 'Foreign key linking to compliance.policy. Business justification: Assets are governed by content policies (broadcast standards, UGC policy, watermarking policy). Rights managers and compliance officers need to identify which policy governs an asset\'s permitted use, ' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Policy .

ind:investigationId rdf:type rdf:Property ;
    rdfs:label 'Investigation Id' ;
    rdfs:comment 'Foreign key linking to compliance.investigation. Business justification: Assets subject to compliance investigations (copyright infringement, NIL violation, broadcast rights misuse) must be linked to the investigation record. Compliance investigators and legal teams need t' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Investigation .

ind:matchResultId rdf:type rdf:Property ;
    rdfs:label 'Match Result Id' ;
    rdfs:comment 'Foreign key linking to event.match_result. Business justification: Post-match highlight assets, official result graphics, and match report videos are produced against the confirmed match result record for rights compliance and archive retrieval. asset has fixture_id ' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MatchResult .

ind:mediaRightsDealId rdf:type rdf:Property ;
    rdfs:label 'Media Rights Deal Id' ;
    rdfs:comment 'Foreign key linking to broadcast.media_rights_deal. Business justification: Every content asset is governed by a media rights deal defining its distribution rights, territory exclusivity, and expiry. Rights clearance and compliance teams must know which deal covers each asset' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MediaRightsDeal .

ind:nilAgreementId rdf:type rdf:Property ;
    rdfs:label 'Nil Agreement Id' ;
    rdfs:comment 'Foreign key linking to athlete.nil_agreement. Business justification: NIL rights governance: content assets produced under athlete NIL agreements must reference the governing deal for usage rights validation, territory compliance, and platform-scope enforcement. Sports-' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NilAgreement .

ind:playoffBracketId rdf:type rdf:Property ;
    rdfs:label 'Playoff Bracket Id' ;
    rdfs:comment 'Foreign key linking to league.playoff_bracket. Business justification: Playoff bracket graphics, preview packages, and round-by-round highlight reels are produced and rights-cleared against specific playoff brackets. Bracket-scoped asset management drives OTT packaging a' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PlayoffBracket .

ind:seasonId rdf:type rdf:Property ;
    rdfs:label 'Season Id' ;
    rdfs:comment 'Foreign key linking to league.season. Business justification: Season-scoped asset cataloging is core to DAM and rights management — broadcast archives, season recap reels, and licensed highlight packages are organized and rights-cleared per league season. A spor' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Season .

ind:sponsorId rdf:type rdf:Property ;
    rdfs:label 'Sponsor Id' ;
    rdfs:comment 'Foreign key linking to sponsorship.sponsor. Business justification: Brand safety and rights clearance workflows require knowing which sponsor owns or commissioned a content asset. DAM systems in sports entertainment tag assets by sponsor for exclusivity enforcement, b' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Sponsor .

ind:venueId rdf:type rdf:Property ;
    rdfs:label 'Venue Id' ;
    rdfs:comment 'Reference to the venue or facility where the content was captured. Supports venue-specific content cataloguing, location-based fan engagement, and venue operations reporting.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Venue .

ind:aspectRatio rdf:type rdf:Property ;
    rdfs:label 'Aspect Ratio' ;
    rdfs:comment 'Display aspect ratio of the video or image asset. Drives platform-specific rendering and social media format compliance (e.g., 9:16 for vertical social stories, 16:9 for broadcast and OTT, 1:1 for social feed posts).' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetDescription rdf:type rdf:Property ;
    rdfs:label 'Asset Description' ;
    rdfs:comment 'Free-text editorial description of the asset content, providing context for search, discovery, and editorial use. Includes scene description, key subjects, and contextual notes as entered by the content team in Dalet Galaxy.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetType rdf:type rdf:Property ;
    rdfs:label 'Asset Type' ;
    rdfs:comment 'Primary classification of the digital content asset format managed in the DAM. Drives workflow routing, rights clearance rules, and CDN distribution logic. [ENUM-REF-CANDIDATE: video|photo|audio|editorial|social_media|ugc|graphic|document — promote to reference product if additional types are required]' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bitrateKbps rdf:type rdf:Property ;
    rdfs:label 'Bitrate Kbps' ;
    rdfs:comment 'Encoding bitrate of the media asset in kilobits per second. Used for CDN bandwidth planning, OTT adaptive bitrate ladder configuration, and broadcast transmission quality assessment.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:broadcastChannel rdf:type rdf:Property ;
    rdfs:label 'Broadcast Channel' ;
    rdfs:comment 'Name or identifier of the broadcast or OTT channel for which this asset was primarily produced or first aired (e.g., ESPN, TNT, NBC Sports, league OTT platform). Used for broadcast rights attribution and RSN (Regional Sports Network) distribution tracking.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cdnUrl rdf:type rdf:Property ;
    rdfs:label 'Cdn Url' ;
    rdfs:comment 'Primary CDN (Content Delivery Network) delivery URL for the published asset. Used by OTT platforms, digital channels, and social media integrations to stream or download the asset. Null if the asset has not been published to CDN.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:codec rdf:type rdf:Property ;
    rdfs:label 'Codec' ;
    rdfs:comment 'Video or audio codec used to encode the media file (e.g., H.264, H.265/HEVC, ProRes, DNxHD, AAC, PCM). Determines transcoding requirements, CDN compatibility, and broadcast delivery specifications.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentRating rdf:type rdf:Property ;
    rdfs:label 'Content Rating' ;
    rdfs:comment 'Audience content rating classification assigned to the asset per broadcast and streaming standards (e.g., TV-G, TV-PG, TV-14, TV-MA for television; G, PG, PG-13, R for film-style content). Enforced at OTT platform and broadcast distribution layer for audience protection compliance. [ENUM-REF-CANDIDATE: G|PG|PG-13|R|NC-17|TV-G|TV-PG|TV-14|TV-MA — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:createdTimestamp rdf:type rdf:Property ;
    rdfs:label 'Created Timestamp' ;
    rdfs:comment 'Date and time when the asset record was first created in the DAM master catalogue. Distinct from ingest_timestamp which reflects the media file arrival; this reflects the metadata record creation event.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:damAssetReference rdf:type rdf:Property ;
    rdfs:label 'Dam Asset Reference' ;
    rdfs:comment 'Native asset identifier assigned by Dalet Galaxy DAM system. Used for cross-system reconciliation and direct lookup within the DAM platform.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drmStatus rdf:type rdf:Property ;
    rdfs:label 'Drm Status' ;
    rdfs:comment 'Current rights clearance status of the asset under the DRM framework. Controls whether the asset can be distributed via OTT, broadcast, or social channels. Cleared = fully rights-cleared for distribution; Embargoed = time-restricted; Expired = rights window has lapsed.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:durationSeconds rdf:type rdf:Property ;
    rdfs:label 'Duration Seconds' ;
    rdfs:comment 'Playback duration of the media asset in seconds. Applicable to video and audio asset types. Used for broadcast scheduling, OTT player configuration, and content performance analytics. Null for non-temporal asset types such as photography or editorial.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fileFormat rdf:type rdf:Property ;
    rdfs:label 'File Format' ;
    rdfs:comment 'Technical file format or container format of the primary media file (e.g., MP4, MXF for broadcast video, WAV for audio, JPEG/PNG for photography). Drives transcoding workflow selection and CDN delivery profile assignment. [ENUM-REF-CANDIDATE: MP4|MOV|MXF|WAV|MP3|JPEG|PNG|PDF|XML|JSON — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fileName rdf:type rdf:Property ;
    rdfs:label 'File Name' ;
    rdfs:comment 'Original file name of the primary media file as ingested into Dalet Galaxy DAM. Used for file-level traceability, deduplication checks, and storage management.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fileSizeBytes rdf:type rdf:Property ;
    rdfs:label 'File Size Bytes' ;
    rdfs:comment 'Size of the primary media file in bytes as stored in Dalet Galaxy DAM. Used for storage capacity planning, CDN bandwidth estimation, and ingest SLA monitoring.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:frameRate rdf:type rdf:Property ;
    rdfs:label 'Frame Rate' ;
    rdfs:comment 'Video frame rate in frames per second (fps) for video assets (e.g., 23.98, 25.00, 29.97, 50.00, 59.94). Critical for broadcast compliance, transcoding workflow selection, and OTT adaptive bitrate streaming configuration.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ingestSource rdf:type rdf:Property ;
    rdfs:label 'Ingest Source' ;
    rdfs:comment 'Origin channel through which the asset was ingested into Dalet Galaxy DAM. Supports provenance tracking, quality control routing, and UGC (User-Generated Content) compliance workflows. OB refers to Outside Broadcast feed.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ingestTimestamp rdf:type rdf:Property ;
    rdfs:label 'Ingest Timestamp' ;
    rdfs:comment 'Date and time when the asset was first ingested into the Dalet Galaxy DAM system. Used for SLA tracking, content freshness reporting, and audit trail compliance.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:isLiveClip rdf:type rdf:Property ;
    rdfs:label 'Is Live Clip' ;
    rdfs:comment 'Indicates whether this asset was captured or clipped from a live broadcast event (e.g., live match highlight, live concert clip). Drives near-real-time CDN distribution workflows and live rights clearance checks.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPpvRestricted rdf:type rdf:Property ;
    rdfs:label 'Is Ppv Restricted' ;
    rdfs:comment 'Indicates whether this asset is associated with a Pay-Per-View (PPV) event and subject to PPV access restrictions. When true, distribution is gated behind PPV entitlement checks at the OTT and digital platform layer.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isUgc rdf:type rdf:Property ;
    rdfs:label 'Is Ugc' ;
    rdfs:comment 'Indicates whether this asset was submitted as User-Generated Content (UGC) by a fan or external contributor rather than produced by the organisation\'s internal content team. UGC assets require additional rights clearance and moderation workflows.' ;
    rdfs:domain ind:Content ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:languageCode rdf:type rdf:Property ;
    rdfs:label 'Language Code' ;
    rdfs:comment 'Primary language of the asset content expressed as an IETF BCP 47 language tag (e.g., en, en-US, es, fr, pt-BR). Used for localisation routing, subtitle matching, and regional distribution targeting.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastModifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Modified Timestamp' ;
    rdfs:comment 'Date and time when the asset record was most recently updated in the DAM. Supports change detection, incremental ETL processing, and editorial audit trails.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lifecycleStatus rdf:type rdf:Property ;
    rdfs:label 'Lifecycle Status' ;
    rdfs:comment 'Current state of the asset within the content production and distribution lifecycle managed in Dalet Galaxy. Controls editorial workflow progression, rights enforcement, and CDN availability. [ENUM-REF-CANDIDATE: draft|ingest|review|approved|published|archived|deleted|quarantined — promote to reference product if additional states are required]' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publishedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Published Timestamp' ;
    rdfs:comment 'Date and time when the asset was first published and made available for distribution via CDN to OTT, digital, or social platforms. Null if the asset has not yet been published.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:resolution rdf:type rdf:Property ;
    rdfs:label 'Resolution' ;
    rdfs:comment 'Video or image resolution classification of the asset (SD=Standard Definition, HD=High Definition 720p, FHD=Full HD 1080p, 4K=Ultra HD, 8K=Super Hi-Vision). Determines CDN delivery tier, OTT streaming profile, and broadcast transmission specification.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rightsOwner rdf:type rdf:Property ;
    rdfs:label 'Rights Owner' ;
    rdfs:comment 'Name of the entity that holds the intellectual property (IP) rights for this asset (e.g., league name, broadcaster, production company, athlete NIL rights holder). Determines licensing obligations and revenue share arrangements.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rightsType rdf:type rdf:Property ;
    rdfs:label 'Rights Type' ;
    rdfs:comment 'Classification of the media rights granted for this asset. Determines which distribution channels are permitted. NIL refers to Name, Image, and Likeness rights for athlete-associated content. [ENUM-REF-CANDIDATE: broadcast|ott|social|editorial|all_media|nil|ppv|archive — promote to reference product]' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sportDiscipline rdf:type rdf:Property ;
    rdfs:label 'Sport Discipline' ;
    rdfs:comment 'Sport or entertainment discipline associated with the asset (e.g., NFL, NBA, MLB, NHL, MLS, UFC, FIFA, concert, esports). Enables domain-specific filtering, rights segmentation, and league-aligned distribution workflows. [ENUM-REF-CANDIDATE: NFL|NBA|MLB|NHL|MLS|UFC|FIFA|ATP|concert|esports — promote to reference product]' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storagePath rdf:type rdf:Property ;
    rdfs:label 'Storage Path' ;
    rdfs:comment 'Internal storage path or object storage URI (e.g., S3 bucket path, NAS mount path) where the master media file is archived in the DAM storage tier. Used for file retrieval, backup verification, and disaster recovery operations.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subtype rdf:type rdf:Property ;
    rdfs:label 'Subtype' ;
    rdfs:comment 'Secondary classification providing granular categorisation within the asset type (e.g., highlight_clip, press_photo, podcast_episode, match_report, story_reel, fan_submission). Supports editorial workflow segmentation and metadata-driven distribution rules. [ENUM-REF-CANDIDATE: highlight_clip|full_match|press_photo|podcast_episode|match_report|story_reel|fan_submission|interview|promo_spot|behind_scenes — promote to reference product]' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tagsKeywords rdf:type rdf:Property ;
    rdfs:label 'Tags Keywords' ;
    rdfs:comment 'Comma-separated list of editorial metadata tags and keywords associated with the asset (e.g., athlete names, team names, event names, competition rounds). Supports full-text search, AI/ML content recommendation, and Adobe Experience Platform personalisation.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thumbnailUrl rdf:type rdf:Property ;
    rdfs:label 'Thumbnail Url' ;
    rdfs:comment 'URL of the representative thumbnail image for the asset, used in DAM browse interfaces, OTT content catalogues, and digital platform content cards. Auto-generated or manually selected by the editorial team.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:title rdf:type rdf:Property ;
    rdfs:label 'Title' ;
    rdfs:comment 'Human-readable title or display name of the digital content asset as catalogued in Dalet Galaxy. Used for search, discovery, and editorial labelling across OTT, broadcast, and digital platforms.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:versionNumber rdf:type rdf:Property ;
    rdfs:label 'Version Number' ;
    rdfs:comment 'Sequential version number of the asset, incremented each time the asset is revised, re-edited, or re-ingested. Supports version control, editorial rollback, and audit trail requirements within the Dalet Galaxy DAM versioning framework.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionOrderId rdf:type rdf:Property ;
    rdfs:label 'Production Order Id' ;
    rdfs:comment 'Unique surrogate identifier for the production order record within the Dalet Galaxy DAM system. Primary key for the production_order data product in the Silver Layer lakehouse.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProductionOrder .

ind:activationId rdf:type rdf:Property ;
    rdfs:label 'Activation Id' ;
    rdfs:comment 'Foreign key linking to sponsorship.sponsorship_activation. Business justification: A sponsorship activation (e.g., branded halftime show, jersey reveal) triggers a production order to create the required creative. Linking production_order to sponsorship_activation supports activatio' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Activation .

ind:budgetId rdf:type rdf:Property ;
    rdfs:label 'Budget Id' ;
    rdfs:comment 'Foreign key linking to finance.budget. Business justification: Production orders are planned against approved budgets. Finance tracks production spend vs. budget at the production order level for variance analysis and financial control. This link enables real-tim' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Budget .

ind:compliancePolicyId rdf:type rdf:Property ;
    rdfs:label 'Compliance Policy Id' ;
    rdfs:comment 'Foreign key linking to compliance.policy. Business justification: Production orders for sponsored, NIL, or broadcast content must comply with specific policies (branded content policy, NIL policy, broadcast standards). The production_order has nil_clearance_required' ;
    rdfs:domain ind:Content ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Policy .

ind:contestId rdf:type rdf:Property ;
    rdfs:label 'Contest Id' ;
    rdfs:comment 'Foreign key linking to gaming.contest. Business justification: Production teams create DFS slate preview videos, contest explainer content, and promotional packages commissioned for specific gaming contests. Linking production_order to contest enables cost tracki' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Contest .

ind:costCenterId rdf:type rdf:Property ;
    rdfs:label 'Cost Center Id' ;
    rdfs:comment 'Foreign key linking to finance.cost_center. Business justification: Production orders incur costs (production_cost field) that must be allocated to a cost center for budget vs. actuals reporting. This is a fundamental financial control in content operations. cost_cent' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostCenter .

ind:dealId rdf:type rdf:Property ;
    rdfs:label 'Deal Id' ;
    rdfs:comment 'Foreign key linking to sponsorship.deal. Business justification: Sponsored production orders must be traceable to the deal that funds them for cost allocation, billing milestone tracking, and deal fulfillment reporting. Production cost is a deal obligation; finance' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Deal .

ind:facilityId rdf:type rdf:Property ;
    rdfs:label 'Facility Id' ;
    rdfs:comment 'Foreign key linking to venue.facility. Business justification: Venue operations commission facility-specific production orders for in-venue digital displays, scoreboard content, and concourse signage. Linking production_order to facility enables facility-level co' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Facility .

ind:fiscalPeriodId rdf:type rdf:Property ;
    rdfs:label 'Fiscal Period Id' ;
    rdfs:comment 'Foreign key linking to finance.fiscal_period. Business justification: Production orders must be attributed to fiscal periods for budget variance reporting and period-end cost accruals. Sports entertainment finance teams track production spend by fiscal period against se' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FiscalPeriod .

ind:glAccountId rdf:type rdf:Property ;
    rdfs:label 'Gl Account Id' ;
    rdfs:comment 'Foreign key linking to finance.gl_account. Business justification: Production orders incur costs (crew, studio, editing) that must be posted to specific GL accounts for cost accounting and financial close. In sports entertainment ERP operations, every production cost' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GlAccount .

ind:leagueId rdf:type rdf:Property ;
    rdfs:label 'League Id' ;
    rdfs:comment 'Reference to the sports league or competition governing body associated with the content being produced. Determines applicable rights agreements, branding guidelines, and content governance rules (e.g., NFL, NBA, FIFA, MLS).' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:League .

ind:leagueSeasonId rdf:type rdf:Property ;
    rdfs:label 'League Season Id' ;
    rdfs:comment 'Foreign key linking to league.season. Business justification: Production orders are scoped to league seasons for production budgeting, scheduling, and rights clearance planning. Production departments plan content output by season (e.g., season preview packages,' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Season .

ind:primaryProductionAssetId rdf:type rdf:Property ;
    rdfs:label 'Primary Production Asset Id' ;
    rdfs:comment 'Reference to the primary source media asset in the Dalet Galaxy DAM from which this production order is derived (e.g., raw match footage, raw interview recording, raw photography). Enables lineage tracing from produced output back to source material.' ;
    rdfs:domain ind:ProductionOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Asset .

ind:primaryProductionAthleteAthleteProfileId rdf:type rdf:Property ;
    rdfs:label 'Primary Production Athlete Athlete Profile Id' ;
    rdfs:comment 'Reference to the primary athlete featured in the content production order. Relevant for highlight packages, athlete profile features, and NIL (Name, Image, and Likeness) content. Triggers NIL rights clearance checks and athlete approval workflows where applicable.' ;
    rdfs:domain ind:ProductionOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AthleteProfile .

ind:primaryProductionEventFixtureId rdf:type rdf:Property ;
    rdfs:label 'Primary Production Event Fixture Id' ;
    rdfs:comment 'Reference to the sports or entertainment event that this production order is associated with (e.g., a specific match, concert, or league game). Links content production to the source event for scheduling alignment and rights traceability.' ;
    rdfs:domain ind:ProductionOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Fixture .

ind:profitCenterId rdf:type rdf:Property ;
    rdfs:label 'Profit Center Id' ;
    rdfs:comment 'Foreign key linking to finance.profit_center. Business justification: Production orders for broadcast content, sponsored content, and live events are attributed to profit centers for P&L reporting by business unit. Sports entertainment media operations track production ' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProfitCenter .

ind:skuCatalogId rdf:type rdf:Property ;
    rdfs:label 'Sku Catalog Id' ;
    rdfs:comment 'Foreign key linking to merchandise.sku_catalog. Business justification: Content production orders for product photography, unboxing videos, and athlete endorsement content are commissioned per specific SKU. Merchandise and content teams track production costs against indi' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SkuCatalog .

ind:tournamentId rdf:type rdf:Property ;
    rdfs:label 'Tournament Id' ;
    rdfs:comment 'Foreign key linking to event.tournament. Business justification: Production orders are commissioned at tournament level (e.g., championship highlight packages, tournament recap films). Producers need to track all production orders against a tournament for budget ma' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Tournament .

ind:actualDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Actual Delivery Date' ;
    rdfs:comment 'The actual timestamp when the completed production order was delivered to the distribution channel or CDN. Compared against the deadline to measure SLA adherence and production team performance. Null until delivery is confirmed.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Approved Timestamp' ;
    rdfs:comment 'Timestamp when the production order received final editorial approval from the commissioning editor or editorial review board. Marks the transition from review to delivery-ready state. Null until approval is granted.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:billingRate rdf:type rdf:Property ;
    rdfs:label 'Billing Rate' ;
    rdfs:comment 'The rate at which this employee\'s time on this production order is billed against the production cost center, expressed in local currency per hour. May vary by role, production type, or CBA agreement. Belongs to the assignment, not to the employee master record (which holds base salary) or the production order (which does not hold per-person rates).' ;
    rdfs:domain ind:ProductionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:briefDescription rdf:type rdf:Property ;
    rdfs:label 'Brief Description' ;
    rdfs:comment 'Short editorial brief or production description summarising the creative intent, story angle, or technical specification of the content to be produced. Provides context for assigned editors, producers, and journalists on the scope and purpose of the work order.' ;
    rdfs:domain ind:ProductionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cdnDeliveryUrl rdf:type rdf:Property ;
    rdfs:label 'Cdn Delivery Url' ;
    rdfs:comment 'The CDN (Content Delivery Network) endpoint URL where the produced content asset has been published and is accessible for distribution. Populated upon successful delivery. Used by OTT platforms, digital editorial systems, and social media publishing tools to retrieve the asset.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentDomainCode rdf:type rdf:Property ;
    rdfs:label 'Content Domain Code' ;
    rdfs:comment 'Reference to the content domain or channel category this production order belongs to (e.g., OTT platform, social media, broadcast, digital editorial). Determines distribution pathway and rights clearance requirements.' ;
    rdfs:domain ind:ProductionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:costCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Cost Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the production cost amount (e.g., USD, GBP, EUR). Required for multi-currency financial reporting and SAP S/4HANA FI integration.' ;
    rdfs:domain ind:ProductionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deadline rdf:type rdf:Property ;
    rdfs:label 'Deadline' ;
    rdfs:comment 'Hard deadline by which the production order must be completed and delivered. Drives SLA monitoring, priority escalation, and resource scheduling. For broadcast segments, this is typically tied to the broadcast transmission schedule. For social cuts, it is tied to the event window.' ;
    rdfs:domain ind:ProductionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:editorialApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Editorial Approval Status' ;
    rdfs:comment 'Status of the editorial review and approval workflow for this production order. Tracks whether the content has been submitted for editorial review, approved for publication, rejected, or sent back for revision. Distinct from the overall order status — an order may be in_production while editorial approval is pending.' ;
    rdfs:domain ind:ProductionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:editorialNotes rdf:type rdf:Property ;
    rdfs:label 'Editorial Notes' ;
    rdfs:comment 'Free-text notes from the commissioning editor or editorial reviewer providing feedback, revision instructions, or approval commentary. Captured during the editorial approval workflow in Dalet Galaxy. Supports iterative content refinement and audit trail for editorial decisions.' ;
    rdfs:domain ind:ProductionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endDate rdf:type rdf:Property ;
    rdfs:label 'End Date' ;
    rdfs:comment 'The date on which this employee\'s assignment to the production order concludes. May differ from the production order deadline if the employee\'s contribution is scoped to a subset of the production timeline.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hoursAllocated rdf:type rdf:Property ;
    rdfs:label 'Hours Allocated' ;
    rdfs:comment 'The planned number of hours this employee is expected to contribute to this production order in their assigned role. Used for capacity planning, workload balancing, and production cost estimation. This value is specific to the employee-order-role combination and cannot reside on either entity alone.' ;
    rdfs:domain ind:ProductionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isSponsoredContent rdf:type rdf:Property ;
    rdfs:label 'Is Sponsored Content' ;
    rdfs:comment 'Indicates whether this production order is for sponsored or branded content produced under a commercial partnership agreement. When true, FCC-mandated sponsored content disclosure labels must be applied to the output asset before distribution.' ;
    rdfs:domain ind:ProductionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nilClearanceRequired rdf:type rdf:Property ;
    rdfs:label 'Nil Clearance Required' ;
    rdfs:comment 'Indicates whether Name, Image, and Likeness (NIL) rights clearance is required for this production order due to featured athlete content. When true, the order cannot be delivered without confirmed NIL clearance from the athlete or their representative.' ;
    rdfs:domain ind:ProductionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:orderNumber rdf:type rdf:Property ;
    rdfs:label 'Order Number' ;
    rdfs:comment 'Externally-known, human-readable business identifier for the production order as assigned by Dalet Galaxy. Used by editorial and production teams to reference work orders in communications, scheduling boards, and delivery manifests.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderStatus rdf:type rdf:Property ;
    rdfs:label 'Order Status' ;
    rdfs:comment 'Current lifecycle state of the production order within the Dalet Galaxy workflow. Tracks progression from initial draft through assignment, active production, editorial review, approval, and final delivery or cancellation. [ENUM-REF-CANDIDATE: draft|assigned|in_production|pending_review|approved|delivered|cancelled — promote to reference product]' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderType rdf:type rdf:Property ;
    rdfs:label 'Order Type' ;
    rdfs:comment 'Classifies the nature of the production work order. Distinguishes between technical production types (video highlight packages, social cuts, broadcast segments, audio packages) and editorial commissioning types (editorial features, commissioned editorial/articles). Drives workflow routing in Dalet Galaxy. [ENUM-REF-CANDIDATE: video_highlight|editorial_feature|social_cut|broadcast_segment|audio_package|commissioned_editorial — promote to reference product]' ;
    rdfs:domain ind:ProductionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outputFormat rdf:type rdf:Property ;
    rdfs:label 'Output Format' ;
    rdfs:comment 'Technical output format specification for the produced content asset. For video: codec, resolution, and container format (e.g., H.264 1080p MP4, ProRes 4K MOV). For audio: bitrate and format (e.g., AAC 320kbps). For editorial: file format (e.g., HTML, DOCX). Drives technical delivery requirements in Dalet Galaxy.' ;
    rdfs:domain ind:ProductionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priority rdf:type rdf:Property ;
    rdfs:label 'Priority' ;
    rdfs:comment 'Editorial and operational priority level assigned to the production order. Critical priority is reserved for breaking news, live event highlights, and time-sensitive broadcast segments. Drives queue ordering in Dalet Galaxy production workflows.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionCost rdf:type rdf:Property ;
    rdfs:label 'Production Cost' ;
    rdfs:comment 'Estimated or actual cost incurred to produce the content order, in the operating currency. Includes editor/producer time, freelancer fees, licensing costs, and technical production expenses. Used for content ROI analysis, budget tracking, and EBITDA reporting. Classified as confidential business financial data.' ;
    rdfs:domain ind:ProductionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:productionStage rdf:type rdf:Property ;
    rdfs:label 'Production Stage' ;
    rdfs:comment 'Current stage within the content production workflow pipeline. Tracks granular progress within the broader order status. Briefing covers initial creative direction; pre-production covers asset gathering and scripting; production covers active editing/writing; post-production covers finishing and QC; review covers editorial approval; delivery covers CDN publishing.' ;
    rdfs:domain ind:ProductionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestedDate rdf:type rdf:Property ;
    rdfs:label 'Requested Date' ;
    rdfs:comment 'The principal business event timestamp recording when the production order was formally raised and submitted in Dalet Galaxy. Represents the real-world moment the content production request was initiated, distinct from system audit timestamps.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rightsClearanceStatus rdf:type rdf:Property ;
    rdfs:label 'Rights Clearance Status' ;
    rdfs:comment 'Current status of Digital Rights Management (DRM) clearance for the content being produced. Indicates whether all necessary rights (music, athlete likeness, broadcast footage, third-party IP) have been cleared for the intended distribution channel. Blocked orders cannot proceed to delivery without rights resolution.' ;
    rdfs:domain ind:ProductionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roleOnProduction rdf:type rdf:Property ;
    rdfs:label 'Role On Production' ;
    rdfs:comment 'The specific crew role this employee fulfills on this production order. Determines responsibilities, billing rate applicability, and scheduling requirements. Belongs to the assignment, not to the employee (who may serve different roles on different orders) or the production order (which has multiple roles filled by different people).' ;
    rdfs:domain ind:ProductionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledPublishDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Publish Date' ;
    rdfs:comment 'The planned calendar date on which the produced content asset is scheduled for publication or broadcast. Used for editorial calendar planning and CDN pre-positioning. May differ from the production deadline if content is produced in advance.' ;
    rdfs:domain ind:ProductionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:startDate rdf:type rdf:Property ;
    rdfs:label 'Start Date' ;
    rdfs:comment 'The date on which this employee\'s assignment to the production order begins. Used for crew scheduling, capacity planning, and determining active assignments. Belongs to the assignment record, not to the employee or the order independently.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storyAngle rdf:type rdf:Property ;
    rdfs:label 'Story Angle' ;
    rdfs:comment 'The editorial perspective, narrative framing, or journalistic angle for the content piece. Applicable primarily to editorial features, commissioned articles, and interview content. Guides the journalist or writer on the intended narrative direction and audience focus.' ;
    rdfs:domain ind:Content ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:territoryCode rdf:type rdf:Property ;
    rdfs:label 'Territory Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code indicating the primary geographic territory for which this content is being produced and cleared for distribution. Drives territorial rights enforcement, geo-blocking rules on CDN, and regional broadcast compliance.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ugcFlag rdf:type rdf:Property ;
    rdfs:label 'Ugc Flag' ;
    rdfs:comment 'Indicates whether this production order involves User-Generated Content (UGC) as source material. UGC-sourced orders require additional rights clearance and moderation workflows before publication. Impacts DRM clearance and editorial approval processes.' ;
    rdfs:domain ind:ProductionOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:updatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Updated Timestamp' ;
    rdfs:comment 'System audit timestamp recording when the production order record was most recently modified in the source system or Silver Layer. Used for incremental data pipeline processing, change detection, and audit trail compliance.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:wordCountTarget rdf:type rdf:Property ;
    rdfs:label 'Word Count Target' ;
    rdfs:comment 'Target word count for editorial content types (articles, features, interviews, commissioned editorial). Null for non-editorial production types such as video highlights or audio packages. Used for editorial planning and writer briefing.' ;
    rdfs:domain ind:Content ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ingestJobId rdf:type rdf:Property ;
    rdfs:label 'Ingest Job Id' ;
    rdfs:comment 'Unique surrogate identifier for each content ingest job record in the Digital Asset Management (DAM) system. Primary key for the ingest_job data product.' ;
    rdfs:domain ind:IngestJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contentAssetId rdf:type rdf:Property ;
    rdfs:label 'Content Asset Id' ;
    rdfs:comment 'Reference to the DAM content asset record created or updated as a result of this ingest job. Establishes traceability from raw ingest event to registered DAM asset identity.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Asset .

ind:liveFeedId rdf:type rdf:Property ;
    rdfs:label 'Live Feed Id' ;
    rdfs:comment 'Foreign key linking to broadcast.live_feed. Business justification: Content ingest jobs sourced from live broadcasts must reference the originating live feed for MAM/DAM integration. Content operations teams track which live feed produced each ingest job for quality c' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LiveFeed .

ind:primaryIngestEventFixtureId rdf:type rdf:Property ;
    rdfs:label 'Primary Ingest Event Fixture Id' ;
    rdfs:comment 'Reference to the sports or entertainment event associated with the ingested content (e.g., match, concert, press conference). Links ingest jobs to the event scheduling and production context.' ;
    rdfs:domain ind:IngestJob ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Fixture .

ind:broadcastRightsFlag rdf:type rdf:Property ;
    rdfs:label 'Broadcast Rights Flag' ;
    rdfs:comment 'Indicates whether the ingested content carries cleared broadcast distribution rights for linear television and RSN (Regional Sports Network) channels. True = broadcast rights confirmed; False = broadcast rights not cleared or not applicable.' ;
    rdfs:domain ind:IngestJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cdnDistributionStatus rdf:type rdf:Property ;
    rdfs:label 'Cdn Distribution Status' ;
    rdfs:comment 'Status of the CDN (Content Delivery Network) distribution push for this ingested asset following successful DAM registration. Tracks whether the asset has been propagated to CDN edge nodes for OTT and digital platform delivery.' ;
    rdfs:domain ind:IngestJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checksumAlgorithm rdf:type rdf:Property ;
    rdfs:label 'Checksum Algorithm' ;
    rdfs:comment 'The hashing algorithm used to generate the file integrity checksum for this ingest job. Used to verify that files were transferred without corruption from source to DAM storage.' ;
    rdfs:domain ind:IngestJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checksumValue rdf:type rdf:Property ;
    rdfs:label 'Checksum Value' ;
    rdfs:comment 'The computed checksum hash value for the primary file or manifest package of this ingest job. Validated against the source-declared checksum to confirm file integrity upon arrival in the DAM.' ;
    rdfs:domain ind:IngestJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:completedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Completed Timestamp' ;
    rdfs:comment 'Timestamp recording when the ingest job reached a terminal state (completed, failed, or cancelled). Used alongside ingest_timestamp to calculate ingest_duration_seconds and for SLA compliance reporting.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:contentDate rdf:type rdf:Property ;
    rdfs:label 'Content Date' ;
    rdfs:comment 'The calendar date on which the content was originally captured or created, as declared by the source system or embedded metadata. May differ from ingest_timestamp if content is ingested after the fact (e.g., archival uploads).' ;
    rdfs:domain ind:IngestJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contentType rdf:type rdf:Property ;
    rdfs:label 'Content Type' ;
    rdfs:comment 'Classification of the media type being ingested. Covers video highlights, photography, audio recordings, editorial content, social media assets, and User-Generated Content (UGC). Drives downstream DAM workflow routing and metadata schema selection.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationStoragePath rdf:type rdf:Property ;
    rdfs:label 'Destination Storage Path' ;
    rdfs:comment 'The target storage path or URI in the DAM or cloud storage layer where the ingested content is written upon successful completion. Supports traceability from raw capture to registered DAM asset location.' ;
    rdfs:domain ind:IngestJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drmClearanceStatus rdf:type rdf:Property ;
    rdfs:label 'Drm Clearance Status' ;
    rdfs:comment 'Rights clearance status for the ingested content under the Digital Rights Management (DRM) framework. Determines whether the asset is cleared for distribution across OTT, broadcast, social, and digital channels.' ;
    rdfs:domain ind:IngestJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:errorCode rdf:type rdf:Property ;
    rdfs:label 'Error Code' ;
    rdfs:comment 'Standardized error code returned by the DAM ingest pipeline when the job encounters a failure condition. Populated only for failed or on-hold jobs. Used for automated alerting, root cause analysis, and SLA reporting.' ;
    rdfs:domain ind:IngestJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fileCount rdf:type rdf:Property ;
    rdfs:label 'File Count' ;
    rdfs:comment 'Total number of individual files included in this ingest job as declared in the file manifest. Used to validate completeness of ingest against expected file count.' ;
    rdfs:domain ind:IngestJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fileManifestPath rdf:type rdf:Property ;
    rdfs:label 'File Manifest Path' ;
    rdfs:comment 'Storage path or URI to the file manifest document listing all individual files included in this ingest job. The manifest captures filenames, sizes, checksums, and sequence information for multi-file ingest packages.' ;
    rdfs:domain ind:IngestJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ingestChannel rdf:type rdf:Property ;
    rdfs:label 'Ingest Channel' ;
    rdfs:comment 'The operational channel through which this ingest job was initiated. Distinguishes between manual operator-triggered ingests, fully automated pipeline ingests, scheduled batch ingests, and API-driven ingests from external systems.' ;
    rdfs:domain ind:IngestJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ingestDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Ingest Duration Seconds' ;
    rdfs:comment 'Elapsed time in seconds from ingest job initiation to completion or failure. Used for SLA (Service Level Agreement) compliance monitoring, pipeline performance benchmarking, and capacity planning.' ;
    rdfs:domain ind:IngestJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ingestPriority rdf:type rdf:Property ;
    rdfs:label 'Ingest Priority' ;
    rdfs:comment 'Business priority level assigned to this ingest job, governing queue position and resource allocation in the DAM ingest pipeline. Critical priority is used for live event highlights requiring immediate OTT/social distribution.' ;
    rdfs:domain ind:IngestJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jobReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Job Reference Number' ;
    rdfs:comment 'Externally-known business identifier for the ingest job, used by production teams and operations staff to reference and track a specific ingest event across systems. Follows the format INJ-{YEAR}-{SEQUENCE}.' ;
    rdfs:domain ind:IngestJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jobStatus rdf:type rdf:Property ;
    rdfs:label 'Job Status' ;
    rdfs:comment 'Current lifecycle state of the ingest job within the DAM workflow. Tracks progression from initial queuing through active processing to terminal states (completed, failed, cancelled). [ENUM-REF-CANDIDATE: queued|in_progress|completed|failed|cancelled|on_hold — promote to reference product]' ;
    rdfs:domain ind:IngestJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:metadataExtractionStatus rdf:type rdf:Property ;
    rdfs:label 'Metadata Extraction Status' ;
    rdfs:comment 'Status of the automated metadata extraction process that reads technical and descriptive metadata from the ingested files (e.g., EXIF, XMP, embedded timecode, audio levels). Drives DAM catalogue completeness.' ;
    rdfs:domain ind:IngestJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:metadataProfile rdf:type rdf:Property ;
    rdfs:label 'Metadata Profile' ;
    rdfs:comment 'The metadata schema profile applied during extraction and tagging for this ingest job (e.g., sports_event_video, ugc_social, broadcast_highlight, editorial_photo). Determines which metadata fields are populated in the DAM asset record.' ;
    rdfs:domain ind:IngestJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:moderationStatus rdf:type rdf:Property ;
    rdfs:label 'Moderation Status' ;
    rdfs:comment 'Editorial moderation status for ingested content, particularly applicable to UGC (User-Generated Content) and social media assets. Indicates whether the content has been reviewed and approved for DAM registration and distribution.' ;
    rdfs:domain ind:Content ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ottRightsFlag rdf:type rdf:Property ;
    rdfs:label 'Ott Rights Flag' ;
    rdfs:comment 'Indicates whether the ingested content carries cleared OTT (Over-The-Top Streaming) distribution rights for DTC (Direct-To-Consumer) streaming platforms. True = OTT rights confirmed; False = OTT rights not cleared.' ;
    rdfs:domain ind:IngestJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:primaryFormat rdf:type rdf:Property ;
    rdfs:label 'Primary Format' ;
    rdfs:comment 'The dominant file format or codec of the ingested content (e.g., MXF, MP4, MOV, RAW, JPEG, WAV, MP3). Determines transcoding requirements and DAM storage profile. [ENUM-REF-CANDIDATE: MXF|MP4|MOV|RAW|JPEG|TIFF|WAV|MP3|AIFF|PDF — promote to reference product]' ;
    rdfs:domain ind:IngestJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qcFailureReason rdf:type rdf:Property ;
    rdfs:label 'Qc Failure Reason' ;
    rdfs:comment 'Descriptive reason code or message explaining why the quality check failed. Populated only when qc_status is \'failed\'. Supports remediation workflows and root cause analysis.' ;
    rdfs:domain ind:IngestJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qcScore rdf:type rdf:Property ;
    rdfs:label 'Qc Score' ;
    rdfs:comment 'Numeric quality score assigned by the automated QC engine during ingest validation. Expressed as a percentage (0.00–100.00). Scores below threshold trigger QC failure and manual review routing.' ;
    rdfs:domain ind:IngestJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qcStatus rdf:type rdf:Property ;
    rdfs:label 'Qc Status' ;
    rdfs:comment 'Result of the automated and/or manual quality check performed on the ingested content. Indicates whether the asset meets technical and editorial standards required for DAM registration and downstream distribution.' ;
    rdfs:domain ind:IngestJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retryCount rdf:type rdf:Property ;
    rdfs:label 'Retry Count' ;
    rdfs:comment 'Number of times this ingest job has been retried following a failure or interruption. Tracks pipeline resilience and identifies problematic source feeds or assets requiring manual intervention.' ;
    rdfs:domain ind:Content ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rightsTerritory rdf:type rdf:Property ;
    rdfs:label 'Rights Territory' ;
    rdfs:comment 'Geographic territory or territories for which rights have been cleared for this ingested content. Expressed as ISO 3166-1 alpha-3 country codes or territory group codes (e.g., USA, GBR, WORLDWIDE). Governs CDN distribution routing.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceDeviceIdentifier rdf:type rdf:Property ;
    rdfs:label 'Source Device Identifier' ;
    rdfs:comment 'Unique identifier of the physical device or system that captured or submitted the content (e.g., camera serial number, OB truck unit ID, social feed connector ID). Supports chain-of-custody traceability and device-level quality diagnostics.' ;
    rdfs:domain ind:IngestJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemCode rdf:type rdf:Property ;
    rdfs:label 'Source System Code' ;
    rdfs:comment 'Reference to the originating system or device that submitted the content for ingest (e.g., Outside Broadcast truck, camera card reader, social media feed connector, UGC upload portal). Links to the content source system registry.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceType rdf:type rdf:Property ;
    rdfs:label 'Source Type' ;
    rdfs:comment 'Classification of the physical or digital origin of the content being ingested. Distinguishes between Outside Broadcast (OB) truck feeds, camera card transfers, social media feeds, User-Generated Content (UGC) uploads, broadcast feeds, and API push integrations. [ENUM-REF-CANDIDATE: ob_truck|camera_card|social_feed|ugc_upload|broadcast_feed|api_push|satellite_feed|ftp_transfer — promote to reference product]' ;
    rdfs:domain ind:IngestJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageTier rdf:type rdf:Property ;
    rdfs:label 'Storage Tier' ;
    rdfs:comment 'Storage tier classification assigned to the ingested content based on access frequency and retention policy. Hot tier for active production assets, warm for recent archive, cold for long-term retention, archive for compliance-only storage.' ;
    rdfs:domain ind:IngestJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalFileSizeMb rdf:type rdf:Property ;
    rdfs:label 'Total File Size Mb' ;
    rdfs:comment 'Aggregate size in megabytes of all files included in this ingest job as declared in the manifest. Used for storage capacity planning, CDN bandwidth tracking, and ingest throughput reporting.' ;
    rdfs:domain ind:IngestJob ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:publishEventId rdf:type rdf:Property ;
    rdfs:label 'Publish Event Id' ;
    rdfs:comment 'Unique surrogate identifier for each content publication or distribution event record in the Silver layer. Primary key for the publish_event data product.' ;
    rdfs:domain ind:PublishEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bettingMarketId rdf:type rdf:Property ;
    rdfs:label 'Betting Market Id' ;
    rdfs:comment 'Foreign key linking to gaming.betting_market. Business justification: Broadcast-linked wagering: when a live content publish_event goes live (stream activation), it triggers or is associated with the opening of a corresponding betting market — a named operational proces' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BettingMarket .

ind:broadcastScheduleId rdf:type rdf:Property ;
    rdfs:label 'Broadcast Schedule Id' ;
    rdfs:comment 'Foreign key linking to broadcast.broadcast_schedule. Business justification: Content publish events for broadcast distribution must be coordinated with the broadcast schedule slot. Content operations teams need to link publish events to broadcast schedule entries to synchroniz' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BroadcastSchedule .

ind:emergencyActivationId rdf:type rdf:Property ;
    rdfs:label 'Emergency Activation Id' ;
    rdfs:comment 'Foreign key linking to security.emergency_activation. Business justification: Emergency activations set broadcast_interrupted=true and can cause live publish events to be suspended or taken down. Linking the publish_event to the triggering emergency_activation is required for b' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EmergencyActivation .

ind:fixtureId rdf:type rdf:Property ;
    rdfs:label 'Fixture Id' ;
    rdfs:comment 'Reference to the sports or entertainment event (match, game, concert, tournament) that this content asset is associated with. Enables event-level content distribution analytics and rights traceability.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Fixture .

ind:licenseId rdf:type rdf:Property ;
    rdfs:label 'License Id' ;
    rdfs:comment 'Foreign key linking to content.content_license. Business justification: Publish events distribute content under a specific content license. Linking publish_event to content_license enables license compliance verification for each distribution event and supports license us' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:License .

ind:platformChannelId rdf:type rdf:Property ;
    rdfs:label 'Platform Channel Id' ;
    rdfs:comment 'Foreign key linking to content.platform_channel. Business justification: A publish event distributes content to a specific platform channel. platform_channel_name is a denormalized STRING that should be replaced by a FK to platform_channel.platform_channel_id, enabling JOI' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PlatformChannel .

ind:primaryPublishActivationId rdf:type rdf:Property ;
    rdfs:label 'Primary Publish Activation Id' ;
    rdfs:comment 'Reference to the sponsorship or advertising overlay package applied to this content distribution event. Links to the sponsorship management record for brand attribution, CPM (Cost Per Mille) reporting, and sponsor compliance.' ;
    rdfs:domain ind:PublishEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Activation .

ind:primaryPublishFixtureId rdf:type rdf:Property ;
    rdfs:label 'Primary Publish Fixture Id' ;
    rdfs:comment 'Reference to the sports or entertainment event (match, game, concert, tournament) that this content asset is associated with. Enables event-level content distribution analytics and rights traceability.' ;
    rdfs:domain ind:PublishEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Fixture .

ind:promotionId rdf:type rdf:Property ;
    rdfs:label 'Promotion Id' ;
    rdfs:comment 'Foreign key linking to merchandise.promotion. Business justification: Content publish events (product launch videos, limited-edition drop announcements) are executed in coordination with merchandise promotions. Campaign operations teams track which publish events are ti' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Promotion .

ind:targetFanSegmentId rdf:type rdf:Property ;
    rdfs:label 'Target Fan Segment Id' ;
    rdfs:comment 'Foreign key linking to fan.segment. Business justification: Segment-targeted content publishing: sports entertainment OTT/DTC platforms publish content to specific fan segments (e.g., premium members only, regional audience). This FK enables publish workflow a' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Segment .

ind:assetDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Asset Duration Seconds' ;
    rdfs:comment 'Duration of the published content asset in seconds. Used for CDN bandwidth estimation, broadcast scheduling slot validation, and platform-specific duration compliance checks (e.g., social media clip length limits).' ;
    rdfs:domain ind:PublishEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assetFileSizeMb rdf:type rdf:Property ;
    rdfs:label 'Asset File Size Mb' ;
    rdfs:comment 'File size of the published content asset in megabytes at the time of distribution. Supports CDN cost allocation, bandwidth consumption tracking, and storage capacity planning.' ;
    rdfs:domain ind:PublishEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cdnEndpointUrl rdf:type rdf:Property ;
    rdfs:label 'Cdn Endpoint Url' ;
    rdfs:comment 'The Content Delivery Network (CDN) URL from which the published content asset is served to end consumers. Provides the operational delivery address for playback, download, or streaming on the target platform.' ;
    rdfs:domain ind:Content ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionNotes rdf:type rdf:Property ;
    rdfs:label 'Distribution Notes' ;
    rdfs:comment 'Free-text operational notes recorded by content operations staff regarding this publish event. May include special handling instructions, rights clearance notes, or platform-specific configuration details.' ;
    rdfs:domain ind:PublishEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Distribution Reference Number' ;
    rdfs:comment 'Externally-known business identifier for this publish event, sourced from Dalet Galaxy distribution workflow. Used for cross-system reconciliation and audit trail tracking across CDN, OTT, and broadcast systems.' ;
    rdfs:domain ind:PublishEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionStatus rdf:type rdf:Property ;
    rdfs:label 'Distribution Status' ;
    rdfs:comment 'Current lifecycle state of the content publication event. Tracks the workflow from initial queue through active distribution to final published or failed terminal states. Supports operational monitoring and SLA compliance reporting.' ;
    rdfs:domain ind:PublishEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drmLicenseUrl rdf:type rdf:Property ;
    rdfs:label 'Drm License Url' ;
    rdfs:comment 'The URL endpoint of the DRM license server used to validate and serve decryption keys for this content distribution. Required for OTT and DTC platform playback authorization and rights enforcement audit.' ;
    rdfs:domain ind:PublishEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drmScheme rdf:type rdf:Property ;
    rdfs:label 'Drm Scheme' ;
    rdfs:comment 'The Digital Rights Management (DRM) packaging technology applied to the content asset during this distribution event. Governs encryption and access control for the published content on the target platform.' ;
    rdfs:domain ind:PublishEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:encodingProfile rdf:type rdf:Property ;
    rdfs:label 'Encoding Profile' ;
    rdfs:comment 'The video/audio encoding specification applied to the content asset for this distribution event (e.g., \'H264_1080p_5Mbps\', \'HEVC_4K_HDR\', \'AAC_128kbps\'). Supports quality assurance, platform compatibility validation, and CDN bandwidth planning.' ;
    rdfs:domain ind:PublishEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failureReason rdf:type rdf:Property ;
    rdfs:label 'Failure Reason' ;
    rdfs:comment 'Descriptive reason code or message explaining why a publish event failed or required retry. Populated only when distribution_status is \'failed\' or \'retrying\'. Supports root cause analysis and SLA reporting.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geoRestrictionApplied rdf:type rdf:Property ;
    rdfs:label 'Geo Restriction Applied' ;
    rdfs:comment 'Indicates whether geographic access restrictions are enforced for this content distribution event. When true, the content is restricted to specific territories based on broadcast rights agreements and regulatory requirements.' ;
    rdfs:domain ind:PublishEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:geoRestrictionMode rdf:type rdf:Property ;
    rdfs:label 'Geo Restriction Mode' ;
    rdfs:comment 'Defines whether the territory codes in geo_restriction_territory_codes represent an allowlist (content permitted only in listed territories) or a blocklist (content blocked in listed territories). Governs territorial rights enforcement logic.' ;
    rdfs:domain ind:PublishEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geoRestrictionTerritoryCodes rdf:type rdf:Property ;
    rdfs:label 'Geo Restriction Territory Codes' ;
    rdfs:comment 'Comma-separated list of ISO 3166-1 alpha-3 country codes defining the territories where this content is permitted or blocked. Supports broadcast rights territorial enforcement and GDPR/CCPA regional compliance. Example: \'USA,CAN,GBR\'.' ;
    rdfs:domain ind:PublishEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isLiveContent rdf:type rdf:Property ;
    rdfs:label 'Is Live Content' ;
    rdfs:comment 'Indicates whether this publish event distributes live or near-live content (e.g., live match stream, live press conference) as opposed to pre-produced or archived content. Drives latency SLA requirements and CDN live-streaming configuration.' ;
    rdfs:domain ind:PublishEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPpv rdf:type rdf:Property ;
    rdfs:label 'Is Ppv' ;
    rdfs:comment 'Indicates whether this content distribution event is a Pay-Per-View (PPV) monetized event requiring consumer purchase or entitlement validation prior to access. Drives paywall enforcement and revenue attribution.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:publishInitiatedBy rdf:type rdf:Property ;
    rdfs:label 'Publish Initiated By' ;
    rdfs:comment 'Indicates how the publish event was triggered — manually by a content operator, automatically by a workflow rule, via an API (Application Programming Interface) call from an external system, or by a scheduled distribution job. Supports operational audit and workflow optimization.' ;
    rdfs:domain ind:PublishEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publishTimestamp rdf:type rdf:Property ;
    rdfs:label 'Publish Timestamp' ;
    rdfs:comment 'The principal real-world event timestamp recording when the content asset was successfully published and made available on the target platform. Distinct from scheduled or requested times. Conforms to yyyy-MM-ddTHH:mm:ss.SSSXXX format.' ;
    rdfs:domain ind:PublishEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scheduledPublishTimestamp rdf:type rdf:Property ;
    rdfs:label 'Scheduled Publish Timestamp' ;
    rdfs:comment 'The planned date and time at which the content asset was scheduled for publication on the target platform. Used for embargo management, coordinated release windows, and SLA variance analysis against actual publish timestamp.' ;
    rdfs:domain ind:Content ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:takedownReason rdf:type rdf:Property ;
    rdfs:label 'Takedown Reason' ;
    rdfs:comment 'Reason code explaining why a content asset was taken down from the target platform. Supports IP rights enforcement audit, regulatory compliance reporting, and editorial governance review.' ;
    rdfs:domain ind:PublishEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:takedownTimestamp rdf:type rdf:Property ;
    rdfs:label 'Takedown Timestamp' ;
    rdfs:comment 'Timestamp recording when a published content asset was withdrawn or taken down from the target platform. Populated when distribution_status transitions to \'withdrawn\'. Supports rights expiry enforcement and DMCA/IP compliance audit.' ;
    rdfs:domain ind:PublishEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:ugcSourceFlag rdf:type rdf:Property ;
    rdfs:label 'Ugc Source Flag' ;
    rdfs:comment 'Indicates whether the content asset being distributed originated as User-Generated Content (UGC). UGC assets require additional rights clearance workflows and moderation approval before distribution.' ;
    rdfs:domain ind:PublishEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:workflowJobReference rdf:type rdf:Property ;
    rdfs:label 'Workflow Job Reference' ;
    rdfs:comment 'The Dalet Galaxy distribution workflow job identifier associated with this publish event. Enables cross-system traceability between the Silver layer record and the source DAM workflow execution for debugging and audit.' ;
    rdfs:domain ind:PublishEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:metadataTagId rdf:type rdf:Property ;
    rdfs:label 'Metadata Tag Id' ;
    rdfs:comment 'Unique surrogate identifier for each controlled vocabulary metadata tag record in the Digital Asset Management (DAM) system. Primary key for the metadata_tag master record. [_canonical_skip_reason: MASTER_RESOURCE role — this is a controlled vocabulary tag asset managed in Dalet Galaxy DAM with its own identity and lifecycle.]' ;
    rdfs:domain ind:Content ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MetadataTag .

ind:policyId rdf:type rdf:Property ;
    rdfs:label 'Policy Id' ;
    rdfs:comment 'Foreign key linking to compliance.policy. Business justification: Metadata tags with compliance_flag=true or is_rights_sensitive=true are mandated by specific compliance policies (rights sensitivity policy, NIL tagging policy). Linking tags to their governing policy' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Policy .

ind:aliasTerms rdf:type rdf:Property ;
    rdfs:label 'Alias Terms' ;
    rdfs:comment 'Pipe-delimited list of alternative names, synonyms, or common misspellings associated with this tag (e.g., \'Football|Footy|Association Football\' for the Soccer tag). Used to enhance search recall, support natural language queries, and map legacy tag names to current controlled vocabulary terms during DAM migration.' ;
    rdfs:domain ind:MetadataTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:autoTaggingConfidenceThreshold rdf:type rdf:Property ;
    rdfs:label 'Auto Tagging Confidence Threshold' ;
    rdfs:comment 'Minimum confidence score (0.0000 to 1.0000) required from the auto-tagging AI/ML model before this tag is automatically applied to a content asset without human review. Tags with lower model confidence scores are routed to editorial review queues. Null when auto_tagging_eligible is False.' ;
    rdfs:domain ind:MetadataTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:autoTaggingEligible rdf:type rdf:Property ;
    rdfs:label 'Auto Tagging Eligible' ;
    rdfs:comment 'Indicates whether this tag may be applied automatically by AI/ML-powered auto-tagging engines integrated with Dalet Galaxy DAM (e.g., computer vision for athlete recognition, speech-to-text for topic detection). When False, the tag requires manual editorial application only.' ;
    rdfs:domain ind:MetadataTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cdnCacheTtlSeconds rdf:type rdf:Property ;
    rdfs:label 'Cdn Cache Ttl Seconds' ;
    rdfs:comment 'Recommended cache Time-To-Live (TTL) in seconds for content assets bearing this tag when served via CDN. Tags associated with live or near-live event content (e.g., breaking news, live match highlights) have shorter TTLs to ensure freshness. Tags for evergreen content have longer TTLs to optimize CDN performance.' ;
    rdfs:domain ind:MetadataTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:complianceFlag rdf:type rdf:Property ;
    rdfs:label 'Compliance Flag' ;
    rdfs:comment 'Indicates whether this tag is associated with regulatory or compliance-sensitive content categories (e.g., PED/doping-related content, gambling-adjacent content, athlete NIL content, GDPR-sensitive fan data content). When True, additional compliance workflows are triggered in the DAM and distribution systems.' ;
    rdfs:domain ind:MetadataTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contentTypeAffinity rdf:type rdf:Property ;
    rdfs:label 'Content Type Affinity' ;
    rdfs:comment 'Indicates which content asset types this tag is applicable to within the DAM. Restricts tag availability in editorial workflows to relevant asset types (e.g., a \'mood\' tag may apply to \'video\' and \'photo\' but not \'editorial\'). \'all\' indicates the tag is applicable across all content types. [ENUM-REF-CANDIDATE: video|photo|audio|editorial|social|ugc|all — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:MetadataTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:damCategoryPath rdf:type rdf:Property ;
    rdfs:label 'Dam Category Path' ;
    rdfs:comment 'Full category path within Dalet Galaxy DAM where this tag is classified (e.g., \'/Sports/Soccer/Leagues/MLS\'). Used for DAM navigation, bulk asset operations, and workflow routing within the media asset management and broadcast workflow system.' ;
    rdfs:domain ind:MetadataTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:displayPriority rdf:type rdf:Property ;
    rdfs:label 'Display Priority' ;
    rdfs:comment 'Numeric ordering weight that controls the display sequence of this tag within its taxonomy type in search facets, editorial tag pickers, and fan-facing discovery interfaces. Lower values indicate higher priority display position. Used by DAM editors and OTT platform UX teams to surface the most relevant tags first.' ;
    rdfs:domain ind:MetadataTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:effectiveFromDate rdf:type rdf:Property ;
    rdfs:label 'Effective From Date' ;
    rdfs:comment 'Date from which this metadata tag becomes valid and available for application to content assets. Supports seasonal taxonomy management (e.g., a tag for a new league season becomes effective at season start) and planned tag activations aligned with event schedules.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectiveUntilDate rdf:type rdf:Property ;
    rdfs:label 'Effective Until Date' ;
    rdfs:comment 'Date after which this metadata tag is no longer valid for application to new content assets. Null indicates the tag has no planned expiry. Used for time-bound tags such as event-specific tags (e.g., a Super Bowl LIX tag expires after the event window) and seasonal competition tags.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:geoRestrictionScope rdf:type rdf:Property ;
    rdfs:label 'Geo Restriction Scope' ;
    rdfs:comment 'Pipe-delimited list of ISO 3166-1 alpha-3 country codes where content tagged with this tag has distribution restrictions (e.g., \'USA|CAN\' for North American blackout). Used by CDN and OTT platforms to enforce territorial rights. Null indicates no geographic restriction. Aligns with RSN blackout and international broadcast rights agreements.' ;
    rdfs:domain ind:MetadataTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hierarchyLevel rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Level' ;
    rdfs:comment 'Numeric depth of the tag within the taxonomy hierarchy tree, starting at 1 for root-level tags (e.g., Sport=1, League=2, Team=3, Athlete=4). Used for hierarchical search faceting, breadcrumb navigation, and roll-up reporting in analytics platforms.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hierarchyPath rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Path' ;
    rdfs:comment 'Full delimited path from root to this tag in the taxonomy tree (e.g., \'sport/soccer/league/mls/team/la_galaxy\'). Enables efficient subtree queries, breadcrumb rendering, and hierarchical filtering in DAM and OTT discovery interfaces without recursive joins.' ;
    rdfs:domain ind:MetadataTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ipOwner rdf:type rdf:Property ;
    rdfs:label 'Ip Owner' ;
    rdfs:comment 'Name of the entity that holds Intellectual Property (IP) rights over content associated with this tag (e.g., \'NFL Properties LLC\', \'FIFA\', \'NBA Properties Inc.\'). Used for rights clearance workflows, licensing fee calculations, and IP compliance reporting. Critical for league-branded and athlete-branded content tags.' ;
    rdfs:domain ind:MetadataTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isPersonalizationEligible rdf:type rdf:Property ;
    rdfs:label 'Is Personalization Eligible' ;
    rdfs:comment 'Indicates whether this tag may be used as a personalization signal in fan preference profiles and recommendation engines within Adobe Experience Platform. When True, the tag contributes to fan interest graphs, content affinity scoring, and targeted content delivery for DTC and OTT platforms.' ;
    rdfs:domain ind:MetadataTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRightsSensitive rdf:type rdf:Property ;
    rdfs:label 'Is Rights Sensitive' ;
    rdfs:comment 'Indicates whether content assets tagged with this tag are subject to Digital Rights Management (DRM) restrictions, broadcast rights windows, or territorial licensing constraints. When True, downstream distribution systems must perform rights clearance checks before serving content. Critical for OTT and CDN distribution compliance.' ;
    rdfs:domain ind:Content ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSearchable rdf:type rdf:Property ;
    rdfs:label 'Is Searchable' ;
    rdfs:comment 'Indicates whether this tag is exposed as a searchable facet in DAM search interfaces, OTT content discovery, and digital platform search indexes. When False, the tag is used for internal classification and workflow routing only and is not surfaced to end users or search APIs.' ;
    rdfs:domain ind:Content ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isUgcEligible rdf:type rdf:Property ;
    rdfs:label 'Is Ugc Eligible' ;
    rdfs:comment 'Indicates whether this tag may be applied to User-Generated Content (UGC) assets submitted by fans or third parties. When True, the tag is available in fan-facing content submission workflows and UGC moderation queues. When False, the tag is restricted to professionally produced content only.' ;
    rdfs:domain ind:MetadataTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastModifiedBy rdf:type rdf:Property ;
    rdfs:label 'Last Modified By' ;
    rdfs:comment 'Username or system identifier of the user or automated process that last modified this metadata tag record. Supports editorial accountability and taxonomy governance audits within Dalet Galaxy DAM and the Silver Layer data product.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nilApplicable rdf:type rdf:Property ;
    rdfs:label 'Nil Applicable' ;
    rdfs:comment 'Indicates whether this tag is associated with athlete Name, Image, and Likeness (NIL) rights considerations. When True, content assets bearing this tag must be checked against athlete NIL agreements before commercial use, licensing, or sponsorship activation. Particularly relevant for athlete-specific tags.' ;
    rdfs:domain ind:MetadataTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ottPlatformEligibility rdf:type rdf:Property ;
    rdfs:label 'Ott Platform Eligibility' ;
    rdfs:comment 'Pipe-delimited list of OTT and DTC platform identifiers where content tagged with this tag is eligible for distribution (e.g., \'nfl_plus|espn_plus|peacock\'). Null indicates no platform-specific restriction. Used by CDN distribution rules and OTT content ingestion pipelines to enforce platform-level rights.' ;
    rdfs:domain ind:MetadataTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewRequired rdf:type rdf:Property ;
    rdfs:label 'Review Required' ;
    rdfs:comment 'Indicates whether application of this tag to a content asset requires editorial review and approval before the tag association is published. Used for sensitive tags (e.g., athlete injury, disciplinary action, PED-related content) where incorrect tagging carries reputational or legal risk.' ;
    rdfs:domain ind:MetadataTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rightsRestrictionType rdf:type rdf:Property ;
    rdfs:label 'Rights Restriction Type' ;
    rdfs:comment 'Category of rights restriction applicable to content assets bearing this tag. Territorial restrictions limit distribution by geography; temporal restrictions apply broadcast windows; platform restrictions limit to specific OTT or DTC channels; league blackout enforces RSN blackout rules; PPV exclusive restricts to Pay-Per-View events. Null or \'none\' when is_rights_sensitive is False.' ;
    rdfs:domain ind:MetadataTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:socialChannelEligibility rdf:type rdf:Property ;
    rdfs:label 'Social Channel Eligibility' ;
    rdfs:comment 'Pipe-delimited list of social media channel identifiers where content tagged with this tag is approved for distribution (e.g., \'instagram|twitter|tiktok|youtube\'). Null indicates no social channel restriction. Used by social publishing workflows to enforce league and rights holder social media policies.' ;
    rdfs:domain ind:MetadataTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystem rdf:type rdf:Property ;
    rdfs:label 'Source System' ;
    rdfs:comment 'Operational system of record from which this metadata tag was originated or last synchronized. Dalet Galaxy is the primary DAM source; Adobe Experience Platform may contribute audience-derived tags; Salesforce CRM may contribute sponsor or fan segment tags. Used for data lineage tracking and conflict resolution during ETL.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceTagReference rdf:type rdf:Property ;
    rdfs:label 'Source Tag Reference' ;
    rdfs:comment 'Native identifier of this tag in the originating source system (e.g., Dalet Galaxy internal tag ID, Adobe Experience Platform segment ID). Enables bidirectional synchronization, change detection, and audit tracing between the Silver Layer lakehouse and operational systems.' ;
    rdfs:domain ind:MetadataTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sportCode rdf:type rdf:Property ;
    rdfs:label 'Sport Code' ;
    rdfs:comment 'Standardized sport classification code associated with this tag (e.g., \'SOC\' for Soccer, \'BBL\' for Basketball, \'AMF\' for American Football). Aligns with governing body sport codes from FIFA, NFL, NBA, MLB, NHL, MLS. Null for non-sport-specific tags such as topic or mood tags.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tagCode rdf:type rdf:Property ;
    rdfs:label 'Tag Code' ;
    rdfs:comment 'Externally-known, system-unique alphanumeric code identifying the tag within the DAM and digital platforms (e.g., \'SPORT_SOCCER\', \'LEAGUE_NFL\', \'ATHLETE_LEBRON\'). Used as the stable business key for API lookups, CDN metadata headers, and cross-system integrations. Sourced from Dalet Galaxy tag registry.' ;
    rdfs:domain ind:MetadataTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tagDescription rdf:type rdf:Property ;
    rdfs:label 'Tag Description' ;
    rdfs:comment 'Editorial description of the tag\'s meaning, scope, and intended usage within the controlled vocabulary. Guides content editors and automated tagging systems on correct application. Includes disambiguation notes for tags with similar names (e.g., distinguishing \'MLS\' as Major League Soccer vs. other uses).' ;
    rdfs:domain ind:MetadataTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tagName rdf:type rdf:Property ;
    rdfs:label 'Tag Name' ;
    rdfs:comment 'Human-readable display label for the metadata tag as shown in the DAM user interface, search facets, and editorial tools (e.g., \'Soccer\', \'National Football League\', \'LeBron James\'). Used for content discovery, faceted search, and personalization surfaces.' ;
    rdfs:domain ind:MetadataTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tagStatus rdf:type rdf:Property ;
    rdfs:label 'Tag Status' ;
    rdfs:comment 'Current lifecycle state of the metadata tag within the controlled vocabulary. Active tags are available for application to content assets. Deprecated tags are retained for historical asset associations but blocked from new tagging. Draft tags are under editorial review before activation.' ;
    rdfs:domain ind:MetadataTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tagType rdf:type rdf:Property ;
    rdfs:label 'Tag Type' ;
    rdfs:comment 'Primary classification category of the tag within the controlled vocabulary taxonomy. Determines which facet the tag belongs to for search, discovery, and rights filtering. [ENUM-REF-CANDIDATE: sport|league|team|athlete|event|topic|mood|content_type|venue|sponsor|geography|season|competition — promote to reference product]' ;
    rdfs:domain ind:MetadataTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxonomyDomain rdf:type rdf:Property ;
    rdfs:label 'Taxonomy Domain' ;
    rdfs:comment 'High-level domain grouping within the controlled vocabulary that the tag belongs to. Supports multi-domain tagging strategies across sport classification, editorial categorization, rights management, commercial/sponsorship, audience segmentation, and production metadata.' ;
    rdfs:domain ind:MetadataTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectionId rdf:type rdf:Property ;
    rdfs:label 'Collection Id' ;
    rdfs:comment 'Unique surrogate identifier for the content collection record in the Sports Entertainment digital asset management platform (Dalet Galaxy DAM). Primary key for the collection entity.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Collection .

ind:athleteProfileId rdf:type rdf:Property ;
    rdfs:label 'Athlete Profile Id' ;
    rdfs:comment 'Foreign key linking to athlete.athlete_profile. Business justification: Athlete-curated content collections: sports-entertainment platforms curate collections around specific athletes (career highlight reels, \'Best of\' packages). The collection must reference the featured' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AthleteProfile .

ind:brandSponsorId rdf:type rdf:Property ;
    rdfs:label 'Brand Sponsor Id' ;
    rdfs:comment 'Reference to the sponsoring brand or commercial partner associated with this collection for branded content packages. Supports sponsorship attribution, revenue reporting, and DRM rights enforcement.' ;
    rdfs:domain ind:Collection ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Sponsor .

ind:collectionEventFixtureId rdf:type rdf:Property ;
    rdfs:label 'Collection Event Fixture Id' ;
    rdfs:comment 'Reference to the primary sports or entertainment event (game, match, concert, PPV event) that this collection is associated with. Nullable for evergreen or multi-event collections.' ;
    rdfs:domain ind:Collection ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Fixture .

ind:collectionFixtureId rdf:type rdf:Property ;
    rdfs:label 'Collection Fixture Id' ;
    rdfs:comment 'Reference to the primary sports or entertainment event (game, match, concert, PPV event) that this collection is associated with. Nullable for evergreen or multi-event collections.' ;
    rdfs:domain ind:Collection ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Fixture .

ind:primaryMetadataTagId rdf:type rdf:Property ;
    rdfs:label 'Primary Metadata Tag Id' ;
    rdfs:comment 'Foreign key linking to content.metadata_tag. Business justification: A collection is classified under a primary taxonomy tag (e.g., \'Premier League Highlights\', \'Tennis\', \'Match Day\'). This FK normalizes the collection\'s primary content classification and gives metadat' ;
    rdfs:domain ind:Collection ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MetadataTag .

ind:rightsWindowId rdf:type rdf:Property ;
    rdfs:label 'Rights Window Id' ;
    rdfs:comment 'Foreign key linking to broadcast.broadcast_rights_window. Business justification: Content collections distributed via broadcast have rights_window_start/rights_window_end as denormalized plain attributes. Linking to broadcast_rights_window normalizes this and enables rights teams t' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RightsWindow .

ind:sponsorshipDealId rdf:type rdf:Property ;
    rdfs:label 'Sponsorship Deal Id' ;
    rdfs:comment 'Foreign key linking to sponsorship.deal. Business justification: Branded content collections (e.g., \'Sponsor X Season Highlights\') are created to fulfill specific deal deliverables, not just sponsor relationships. Linking collection to deal enables deal-level conte' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Deal .

ind:archivedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Archived Timestamp' ;
    rdfs:comment 'The date and time at which this collection was moved to archived status, removing it from active distribution channels. Supports rights window enforcement and content lifecycle management.' ;
    rdfs:domain ind:Collection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:cdnManifestUrl rdf:type rdf:Property ;
    rdfs:label 'Cdn Manifest Url' ;
    rdfs:comment 'The CDN-hosted manifest URL (e.g., HLS/DASH playlist) for streaming delivery of this collection to OTT and digital platforms. Populated upon publication approval.' ;
    rdfs:domain ind:Collection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectionDescription rdf:type rdf:Property ;
    rdfs:label 'Collection Description' ;
    rdfs:comment 'Long-form editorial description of the collection\'s content, context, and purpose. Displayed on OTT platforms, digital storefronts, and fan engagement interfaces to drive discovery and engagement.' ;
    rdfs:domain ind:Collection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectionType rdf:type rdf:Property ;
    rdfs:label 'Collection Type' ;
    rdfs:comment 'Categorical classification of the collection defining its structural and commercial purpose. [ENUM-REF-CANDIDATE: highlight_reel|playlist|photo_gallery|branded_package|ppv_bundle|editorial_series|audio_album|ugc_compilation — promote to reference product]' ;
    rdfs:domain ind:Collection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:curationMethod rdf:type rdf:Property ;
    rdfs:label 'Curation Method' ;
    rdfs:comment 'Indicates whether the collection was assembled by human editorial staff, an algorithmic recommendation engine, a hybrid of both, or automated business rules. Drives content governance and quality review workflows.' ;
    rdfs:domain ind:Collection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currencyCode rdf:type rdf:Property ;
    rdfs:label 'Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the PPV price (e.g., \'USD\', \'EUR\', \'GBP\'). Supports multi-currency pricing for global OTT market distribution.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:damCollectionCode rdf:type rdf:Property ;
    rdfs:label 'Dam Collection Code' ;
    rdfs:comment 'Externally-known unique business identifier for the collection as assigned by the Dalet Galaxy DAM system. Used for cross-system reference, API lookups, and CDN manifest identification.' ;
    rdfs:domain ind:Collection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:damVersionNumber rdf:type rdf:Property ;
    rdfs:label 'Dam Version Number' ;
    rdfs:comment 'Incremental version counter for this collection record as tracked in the Dalet Galaxy DAM system. Supports optimistic concurrency control, change history auditing, and rollback capabilities.' ;
    rdfs:domain ind:Collection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isFeatured rdf:type rdf:Property ;
    rdfs:label 'Is Featured' ;
    rdfs:comment 'Indicates whether this collection is designated as a featured or promoted collection on OTT homepages, digital storefronts, or fan engagement platform carousels. Drives editorial merchandising and fan experience design.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ppvPrice rdf:type rdf:Property ;
    rdfs:label 'Ppv Price' ;
    rdfs:comment 'Retail price in USD for purchasing access to this PPV collection bundle. Applicable only when is_ppv = true. Used for revenue management, fan entitlement validation, and financial reporting.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:primaryContentFormat rdf:type rdf:Property ;
    rdfs:label 'Primary Content Format' ;
    rdfs:comment 'Dominant media format of assets within the collection. Determines rendering templates, CDN delivery profiles, and platform compatibility requirements.' ;
    rdfs:domain ind:Collection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publishStatus rdf:type rdf:Property ;
    rdfs:label 'Publish Status' ;
    rdfs:comment 'Current lifecycle state of the collection within the content production and distribution workflow. Controls visibility on OTT and digital platforms. [ENUM-REF-CANDIDATE: draft|pending_review|approved|published|scheduled|archived|withdrawn|embargoed — promote to reference product]' ;
    rdfs:domain ind:Collection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rightsTerritoryCodes rdf:type rdf:Property ;
    rdfs:label 'Rights Territory Codes' ;
    rdfs:comment 'Pipe-delimited list of ISO 3166-1 alpha-3 country codes defining the geographic territories where this collection is licensed for distribution (e.g., \'USA|CAN|GBR\'). Drives geo-blocking and CDN routing logic.' ;
    rdfs:domain ind:Collection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rsnDistributionFlag rdf:type rdf:Property ;
    rdfs:label 'Rsn Distribution Flag' ;
    rdfs:comment 'Indicates whether this collection is cleared for distribution via Regional Sports Networks (RSN). Governs blackout rules and territorial broadcast rights compliance.' ;
    rdfs:domain ind:Collection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:seoKeywords rdf:type rdf:Property ;
    rdfs:label 'Seo Keywords' ;
    rdfs:comment 'Comma-separated list of SEO keywords and metadata tags associated with this collection for search discoverability on digital platforms, OTT storefronts, and web search engines.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shortDescription rdf:type rdf:Property ;
    rdfs:label 'Short Description' ;
    rdfs:comment 'Concise summary (typically 160 characters or fewer) of the collection used for social media previews, push notifications, and mobile platform display cards.' ;
    rdfs:domain ind:Collection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slug rdf:type rdf:Property ;
    rdfs:label 'Slug' ;
    rdfs:comment 'URL-safe, lowercase hyphenated identifier used for deep-linking and SEO-friendly routing on digital platforms and CDN-delivered pages.' ;
    rdfs:domain ind:Collection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:socialChannelCodes rdf:type rdf:Property ;
    rdfs:label 'Social Channel Codes' ;
    rdfs:comment 'Pipe-delimited list of social media channel identifiers where this collection is approved for distribution (e.g., \'YOUTUBE|INSTAGRAM|TIKTOK|TWITTER\'). Supports social content rights and distribution tracking.' ;
    rdfs:domain ind:Collection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thumbnailAssetCode rdf:type rdf:Property ;
    rdfs:label 'Thumbnail Asset Code' ;
    rdfs:comment 'DAM asset code referencing the primary thumbnail or cover image used to represent this collection on OTT platforms, digital storefronts, and social media channels.' ;
    rdfs:domain ind:Collection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Total Duration Seconds' ;
    rdfs:comment 'Aggregate playback duration of all video and audio assets within the collection, expressed in seconds. Used for OTT platform display, broadcast scheduling, and PPV event bundle packaging.' ;
    rdfs:domain ind:Collection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fixedAssetId rdf:type rdf:Property ;
    rdfs:label 'Fixed Asset Id' ;
    rdfs:comment 'Foreign key linking to finance.fixed_asset. Business justification: Long-term broadcast rights licenses (e.g., multi-year league rights deals) are capitalized as intangible fixed assets in SAP Asset Accounting. Finance teams in sports entertainment routinely capitaliz' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FixedAsset .

ind:gamingOperatorId rdf:type rdf:Property ;
    rdfs:label 'Gaming Operator Id' ;
    rdfs:comment 'Foreign key linking to gaming.operator. Business justification: Gaming operators license sports highlight clips and live content for display on their sportsbook platforms. Rights management teams issue content licenses specifically to gaming operators; this FK tra' ;
    rdfs:domain ind:License ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Operator .

ind:regulatoryFilingId rdf:type rdf:Property ;
    rdfs:label 'Regulatory Filing Id' ;
    rdfs:comment 'Foreign key linking to compliance.regulatory_filing. Business justification: Content licenses for broadcast distribution in regulated markets (FCC, Ofcom, ARPU) must reference the regulatory filing that authorizes the license terms. Sports broadcast rights compliance requires ' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RegulatoryFiling .

ind:revenueRecognitionScheduleId rdf:type rdf:Property ;
    rdfs:label 'Revenue Recognition Schedule Id' ;
    rdfs:comment 'Foreign key linking to finance.revenue_recognition_schedule. Business justification: Content licenses create performance obligations under ASC 606. Finance creates revenue recognition schedules for multi-period license fees. This link drives the content licensing revenue recognition w' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RevenueRecognitionSchedule .

ind:attributionRequired rdf:type rdf:Property ;
    rdfs:label 'Attribution Required' ;
    rdfs:comment 'Indicates whether the licensee must display a credit or attribution line (e.g., \'Courtesy of Sports Entertainment / League Name\') when publishing or broadcasting the licensed content. True = attribution mandatory.' ;
    rdfs:domain ind:License ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:attributionText rdf:type rdf:Property ;
    rdfs:label 'Attribution Text' ;
    rdfs:comment 'Exact credit line or attribution text the licensee must display when using the licensed content (e.g., \'Photo: Sports Entertainment / John Smith\'). Populated when attribution_required is True.' ;
    rdfs:domain ind:License ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:autoRenewalFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Renewal Flag' ;
    rdfs:comment 'Indicates whether the license agreement automatically renews at the end of the effective period without requiring a new negotiation cycle. True = auto-renews; False = requires explicit renewal action.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:complianceStatus rdf:type rdf:Property ;
    rdfs:label 'Compliance Status' ;
    rdfs:comment 'Current regulatory and contractual compliance state of the license: compliant (all obligations met), under_review (audit in progress), breach_identified (licensee violation detected), remediated (breach resolved), terminated_for_cause (agreement ended due to material breach). Supports GDPR, CCPA, and IP compliance monitoring.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentScope rdf:type rdf:Property ;
    rdfs:label 'Content Scope' ;
    rdfs:comment 'Breadth of content covered by the license: single_asset (one specific file), collection (curated package), sport (all content for a sport), league (all content for a league), event (all content for a specific event), season (all content for a competition season). Determines which asset_id or collection_id fields are populated.' ;
    rdfs:domain ind:License ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractDocumentRef rdf:type rdf:Property ;
    rdfs:label 'Contract Document Ref' ;
    rdfs:comment 'Reference identifier or URL to the executed license agreement document stored in the Digital Asset Management (DAM) system or document management repository (e.g., Dalet Galaxy document store, SharePoint). Enables direct access to the legal instrument.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cpmRate rdf:type rdf:Property ;
    rdfs:label 'Cpm Rate' ;
    rdfs:comment 'Monetary rate charged per one thousand impressions (Cost Per Mille) when fee_structure is cpm_based. Used for digital display and OTT advertising-supported license arrangements. Expressed in currency_code.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:crmOpportunityReference rdf:type rdf:Property ;
    rdfs:label 'Crm Opportunity Reference' ;
    rdfs:comment 'Salesforce CRM Opportunity record identifier associated with the commercial negotiation that resulted in this license. Enables traceability from CRM pipeline to executed license and supports revenue attribution reporting.' ;
    rdfs:domain ind:License ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:daletRightsReference rdf:type rdf:Property ;
    rdfs:label 'Dalet Rights Reference' ;
    rdfs:comment 'Dalet Galaxy Digital Asset Management (DAM) system rights record identifier linked to this license. Provides traceability to the source-of-truth rights metadata and DRM policy configuration in the DAM workflow.' ;
    rdfs:domain ind:License ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dealType rdf:type rdf:Property ;
    rdfs:label 'Deal Type' ;
    rdfs:comment 'Classification of the commercial arrangement: one_off (single asset transaction), syndication (ongoing bulk content feed to media partner), revenue_share (partner monetizes and shares proceeds), broadcast_feed (live or near-live feed to broadcast partner), social_platform (platform partnership for social channel distribution), sublicense (rights passed to a third party). [ENUM-REF-CANDIDATE: one_off|syndication|revenue_share|broadcast_feed|social_platform|sublicense|ppv_window|dtc_exclusive — promote to reference product]' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryFormat rdf:type rdf:Property ;
    rdfs:label 'Delivery Format' ;
    rdfs:comment 'Technical mechanism by which licensed content is delivered to the licensee: api_feed (Application Programming Interface automated feed), ftp_transfer (file transfer protocol batch), cdn_push (Content Delivery Network push via CDN), manual_download (portal-based manual retrieval), broadcast_signal (OB/satellite signal), email_package (packaged file via email). [ENUM-REF-CANDIDATE: api_feed|ftp_transfer|cdn_push|manual_download|broadcast_signal|email_package|iptv_stream — promote to reference product]' ;
    rdfs:domain ind:License ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drmRestrictions rdf:type rdf:Property ;
    rdfs:label 'Drm Restrictions' ;
    rdfs:comment 'Free-text description of specific Digital Rights Management technical restrictions applied to the licensed content (e.g., watermarking required, geo-blocking enforced, no download permitted, time-limited playback window). Sourced from Dalet Galaxy DAM rights metadata.' ;
    rdfs:domain ind:License ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveEndDate rdf:type rdf:Property ;
    rdfs:label 'Effective End Date' ;
    rdfs:comment 'Calendar date on which the license agreement expires and content distribution rights are revoked. Null for perpetual or open-ended agreements. Triggers renewal workflow when approaching.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectiveStartDate rdf:type rdf:Property ;
    rdfs:label 'Effective Start Date' ;
    rdfs:comment 'Calendar date on which the license agreement becomes legally binding and content distribution rights are activated. Aligns with contract execution date or agreed commencement date.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:exclusivityFlag rdf:type rdf:Property ;
    rdfs:label 'Exclusivity Flag' ;
    rdfs:comment 'Indicates whether this license grants the vendor exclusive rights to the asset within the defined territory_scope. When true, no other vendor may hold a concurrent license for the same asset in the same territory. Critical for rights conflict detection.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:expiryDate rdf:type rdf:Property ;
    rdfs:label 'Expiry Date' ;
    rdfs:comment 'Date on which the asset\'s distribution rights or licence window expires and the asset must be withdrawn from active distribution channels. Critical for DRM (Digital Rights Management) enforcement and rights clearance compliance. [Moved from asset: expiry_date on the asset master conflates the asset\'s overall distribution window with the expiry of individual vendor licenses. A single asset may have licenses expiring on different dates for different vendors. The per-license expiry belongs on content_license.effective_until_date; the asset-level expiry_date should represent the latest possible distribution window across all licenses, not a specific vendor\'s term.]' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:feeAmount rdf:type rdf:Property ;
    rdfs:label 'Fee Amount' ;
    rdfs:comment 'Agreed monetary consideration paid by the vendor to Sports Entertainment for the rights granted under this license. Expressed in the currency defined by license_fee_currency. Belongs to the license agreement, not to the asset or vendor master.' ;
    rdfs:domain ind:License ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:feeCurrency rdf:type rdf:Property ;
    rdfs:label 'Fee Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code in which the license_fee_amount is denominated (e.g., USD, GBP, EUR). Required to support multi-currency rights deals with international broadcasters.' ;
    rdfs:domain ind:License ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feeStructure rdf:type rdf:Property ;
    rdfs:label 'Fee Structure' ;
    rdfs:comment 'Commercial model governing how the licensee compensates Sports Entertainment: flat_fee (fixed one-time or periodic payment), royalty (per-use or per-unit fee), revenue_share (percentage of licensee revenue), cpm_based (Cost Per Mille impression-based), subscription (periodic access fee), free (no monetary consideration, e.g., promotional or editorial). Drives invoicing logic in SAP S/4HANA SD.' ;
    rdfs:domain ind:License ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feedFrequency rdf:type rdf:Property ;
    rdfs:label 'Feed Frequency' ;
    rdfs:comment 'Cadence at which content is delivered to the licensee under ongoing syndication or broadcast feed arrangements: real_time, hourly, daily, weekly, on_demand (licensee-initiated pull), event_triggered (delivery upon specific event occurrence). Null for one-off licenses.' ;
    rdfs:domain ind:License ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:flatFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Flat Fee Amount' ;
    rdfs:comment 'Fixed monetary amount payable by the licensee for the license term when fee_structure is flat_fee or subscription. Expressed in the currency defined by currency_code. Null for royalty or revenue_share structures.' ;
    rdfs:domain ind:License ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastComplianceReviewDate rdf:type rdf:Property ;
    rdfs:label 'Last Compliance Review Date' ;
    rdfs:comment 'Date on which the most recent compliance audit or review of the license was conducted. Used to schedule periodic compliance checks and track regulatory adherence timelines.' ;
    rdfs:domain ind:License ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:licenseName rdf:type rdf:Property ;
    rdfs:label 'License Name' ;
    rdfs:comment 'Human-readable descriptive name of the license agreement (e.g., \'ESPN NFL Highlight Syndication 2025\', \'UEFA Champions League Photo License — Getty Images\'). Used in reporting and partner communications.' ;
    rdfs:domain ind:License ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenseNumber rdf:type rdf:Property ;
    rdfs:label 'License Number' ;
    rdfs:comment 'Externally-known alphanumeric reference code for the license agreement, used in partner correspondence, invoicing, and legal documentation. Format: LIC-{DOMAIN}-{YEAR}-{SEQUENCE}.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenseScope rdf:type rdf:Property ;
    rdfs:label 'License Scope' ;
    rdfs:comment 'Defines the permitted scope of use for this specific IP asset within the license agreement (e.g., broadcast_only, merchandise, digital_streaming). Scope may differ per IP asset within the same license.' ;
    rdfs:domain ind:License ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenseStatus rdf:type rdf:Property ;
    rdfs:label 'License Status' ;
    rdfs:comment 'Current lifecycle state of the license agreement: draft (being negotiated), active (in force), suspended (temporarily halted due to breach or dispute), expired (past end date without renewal), terminated (cancelled before end date), pending_renewal (auto-renewal under review).' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxUsageCount rdf:type rdf:Property ;
    rdfs:label 'Max Usage Count' ;
    rdfs:comment 'Maximum number of times the licensee is permitted to use, broadcast, or distribute the licensed content within the license term. Null indicates unlimited usage. Enables usage cap enforcement and royalty calculation.' ;
    rdfs:domain ind:License ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:paymentFrequency rdf:type rdf:Property ;
    rdfs:label 'Payment Frequency' ;
    rdfs:comment 'Cadence at which the licensee is invoiced or remits payment: one_time (single payment), monthly, quarterly, semi_annual, annual. Drives billing schedule generation in SAP S/4HANA SD.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalNoticeDays rdf:type rdf:Property ;
    rdfs:label 'Renewal Notice Days' ;
    rdfs:comment 'Number of calendar days prior to effective_end_date by which either party must provide written notice of intent not to renew. Drives automated renewal notification workflows.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:renewalTermMonths rdf:type rdf:Property ;
    rdfs:label 'Renewal Term Months' ;
    rdfs:comment 'Duration in months of each automatic renewal cycle. Applicable only when auto_renewal_flag is True. Used to project future effective_end_date upon renewal.' ;
    rdfs:domain ind:License ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:revenueSharePct rdf:type rdf:Property ;
    rdfs:label 'Revenue Share Pct' ;
    rdfs:comment 'Percentage of licensee-generated revenue remitted to Sports Entertainment under a revenue_share fee structure (e.g., 30.00 = 30%). Used in ARPU and ARR revenue forecasting and partner settlement calculations.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:royaltyRate rdf:type rdf:Property ;
    rdfs:label 'Royalty Rate' ;
    rdfs:comment 'Per-use or per-unit royalty rate expressed as a decimal (e.g., 0.0500 = 5%). Applicable when fee_structure is royalty. Used to calculate royalty invoices based on reported usage volumes.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:signedDate rdf:type rdf:Property ;
    rdfs:label 'Signed Date' ;
    rdfs:comment 'Date on which all parties executed the license agreement. May differ from effective_start_date when agreements are backdated or have a future commencement.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sublicensePermitted rdf:type rdf:Property ;
    rdfs:label 'Sublicense Permitted' ;
    rdfs:comment 'Indicates whether the licensee is contractually permitted to sublicense the content to third parties. True = sublicensing allowed (subject to conditions); False = sublicensing prohibited. Critical for IP chain-of-title integrity.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:territoryExclusivity rdf:type rdf:Property ;
    rdfs:label 'Territory Exclusivity' ;
    rdfs:comment 'Defines whether the licensee holds exclusive rights in the specified territory (exclusive), shares rights with other licensees (non_exclusive), or holds first-window broadcast priority before other licensees (first_window). Directly impacts RSN and OTT deal structuring.' ;
    rdfs:domain ind:License ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ugcRightsIncluded rdf:type rdf:Property ;
    rdfs:label 'Ugc Rights Included' ;
    rdfs:comment 'Indicates whether the license grants the licensee rights to use or incorporate User-Generated Content (UGC) associated with the licensed assets (e.g., fan footage, social clips). True = UGC rights included; False = excluded.' ;
    rdfs:domain ind:License ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:usageRightsGranted rdf:type rdf:Property ;
    rdfs:label 'Usage Rights Granted' ;
    rdfs:comment 'Classification of the media usage rights conveyed to the vendor under this license agreement. Determines which distribution channels and use cases the vendor is permitted to exercise.' ;
    rdfs:domain ind:License ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usageType rdf:type rdf:Property ;
    rdfs:label 'Usage Type' ;
    rdfs:comment 'Permitted exploitation category for the licensed content: broadcast (linear TV/radio), streaming_ott (Over-The-Top Streaming platforms), social_media (social channel posting), editorial (news/journalism), commercial (advertising/promotional), print (physical/digital publication), digital_display (website/app display). [ENUM-REF-CANDIDATE: broadcast|streaming_ott|social_media|editorial|commercial|print|digital_display|ppv|dtc|iptv — promote to reference product]' ;
    rdfs:domain ind:License ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:watermarkRequired rdf:type rdf:Property ;
    rdfs:label 'Watermark Required' ;
    rdfs:comment 'Indicates whether the licensee is contractually required to apply a visible or forensic watermark to distributed content for IP tracking and anti-piracy enforcement. True = watermark mandatory; False = not required.' ;
    rdfs:domain ind:Content ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:editorialBriefId rdf:type rdf:Property ;
    rdfs:label 'Editorial Brief Id' ;
    rdfs:comment 'Unique system-generated identifier for the editorial brief record. Primary key for the editorial_brief data product within the content domain.' ;
    rdfs:domain ind:EditorialBrief ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bracketId rdf:type rdf:Property ;
    rdfs:label 'Bracket Id' ;
    rdfs:comment 'Foreign key linking to event.bracket. Business justification: Bracket draw editorial briefs and bracket analysis pieces (draw reaction, path-to-final analysis) are commissioned against specific brackets. editorial_brief has tournament_id but not bracket_id; brac' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Bracket .

ind:campaignId rdf:type rdf:Property ;
    rdfs:label 'Campaign Id' ;
    rdfs:comment 'Foreign key linking to fan.campaign. Business justification: Campaign-driven content commissioning: editorial briefs in sports entertainment are frequently initiated by a marketing campaign (e.g., campaign requires a player profile, match preview, or sponsor fe' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Campaign .

ind:channelId rdf:type rdf:Property ;
    rdfs:label 'Channel Id' ;
    rdfs:comment 'Foreign key linking to broadcast.channel. Business justification: Editorial briefs are commissioned for specific broadcast channels whose programming requirements (format, duration, language, resolution) drive the brief\'s specifications. Programming and editorial te' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Channel .

ind:damAssetId rdf:type rdf:Property ;
    rdfs:label 'Dam Asset Id' ;
    rdfs:comment 'Reference identifier of the associated digital asset record in the Dalet Galaxy DAM (Digital Asset Management) system. Links the editorial brief to the master content asset record for rights, metadata, and distribution management.' ;
    rdfs:domain ind:EditorialBrief ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Asset .

ind:disciplinaryActionId rdf:type rdf:Property ;
    rdfs:label 'Disciplinary Action Id' ;
    rdfs:comment 'Foreign key linking to league.disciplinary_action. Business justification: Disciplinary actions (suspensions, fines, integrity rulings) generate immediate editorial briefs for news coverage, official statements, and investigative features. Sports journalists and content team' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DisciplinaryAction .

ind:primaryEditorialAthleteAthleteProfileId rdf:type rdf:Property ;
    rdfs:label 'Primary Editorial Athlete Athlete Profile Id' ;
    rdfs:comment 'Identifier of the primary athlete or talent featured in the editorial brief. Nullable for team-focused or event-focused content. Links to the athlete master record.' ;
    rdfs:domain ind:EditorialBrief ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AthleteProfile .

ind:primaryEditorialEventFixtureId rdf:type rdf:Property ;
    rdfs:label 'Primary Editorial Event Fixture Id' ;
    rdfs:comment 'Identifier of the specific sporting event, match, or live experience that is the primary subject of this editorial brief. Nullable for non-event-specific editorial content.' ;
    rdfs:domain ind:EditorialBrief ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Fixture .

ind:productionScheduleId rdf:type rdf:Property ;
    rdfs:label 'Production Schedule Id' ;
    rdfs:comment 'Foreign key linking to event.production_schedule. Business justification: Event production schedules (halftime shows, pre-show segments) commission editorial briefs for scripted content, presenter notes, and segment rundowns. editorial_brief has fixture_id but not productio' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProductionSchedule .

ind:securityIncidentId rdf:type rdf:Property ;
    rdfs:label 'Security Incident Id' ;
    rdfs:comment 'Foreign key linking to security.security_incident. Business justification: Editorial briefs are routinely commissioned to cover stadium security incidents as news stories. Sports content teams need this link to track which briefs were triggered by specific incidents, support' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SecurityIncident .

ind:tradeTransactionId rdf:type rdf:Property ;
    rdfs:label 'Trade Transaction Id' ;
    rdfs:comment 'Foreign key linking to league.trade_transaction. Business justification: Trade announcements are among the highest-traffic editorial events in sports media. Editorial briefs for trade coverage (breaking news, analysis, press conference scheduling) are directly triggered by' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TradeTransaction .

ind:approvalStatus rdf:type rdf:Property ;
    rdfs:label 'Approval Status' ;
    rdfs:comment 'Current state of the editorial approval workflow for this brief. Tracks progression through editorial review, legal clearance, and final sign-off stages before publication.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brandedContentFlag rdf:type rdf:Property ;
    rdfs:label 'Branded Content Flag' ;
    rdfs:comment 'Indicates whether this editorial brief is for branded or sponsored content that requires commercial disclosure labelling per FCC and advertising standards. Triggers compliance review workflow.' ;
    rdfs:domain ind:EditorialBrief ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:briefReferenceCode rdf:type rdf:Property ;
    rdfs:label 'Brief Reference Code' ;
    rdfs:comment 'Externally-known alphanumeric code used to identify and reference the editorial brief across production systems, editorial calendars, and commissioning workflows. Format: EB-{SPORT}-{YEAR}-{SEQUENCE}.' ;
    rdfs:domain ind:EditorialBrief ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:briefStatus rdf:type rdf:Property ;
    rdfs:label 'Brief Status' ;
    rdfs:comment 'Current lifecycle state of the editorial brief within the content production pipeline, from initial commissioning through publication or cancellation. [ENUM-REF-CANDIDATE: draft|commissioned|in_production|under_review|approved|published|cancelled — promote to reference product]' ;
    rdfs:domain ind:EditorialBrief ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:briefTitle rdf:type rdf:Property ;
    rdfs:label 'Brief Title' ;
    rdfs:comment 'Human-readable working title of the editorial brief, describing the story or content piece being commissioned. Used in editorial calendars and production dashboards.' ;
    rdfs:domain ind:EditorialBrief ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cancellationReason rdf:type rdf:Property ;
    rdfs:label 'Cancellation Reason' ;
    rdfs:comment 'Free-text explanation of why the editorial brief was cancelled, if applicable. Null for active or completed briefs. Used for editorial pipeline analysis and resource recovery tracking.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commissionedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Commissioned Timestamp' ;
    rdfs:comment 'Date and time when the editorial brief was formally commissioned and entered the production pipeline. Represents the principal business event timestamp for this transaction.' ;
    rdfs:domain ind:EditorialBrief ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:contentPriority rdf:type rdf:Property ;
    rdfs:label 'Content Priority' ;
    rdfs:comment 'Editorial priority level assigned to this brief, determining resource allocation, production queue position, and escalation thresholds. Breaking news content receives highest priority.' ;
    rdfs:domain ind:EditorialBrief ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentSensitivityLevel rdf:type rdf:Property ;
    rdfs:label 'Content Sensitivity Level' ;
    rdfs:comment 'Classification of the editorial content\'s sensitivity level, determining access controls, legal review requirements, and distribution restrictions. Sensitive content (e.g., PED allegations, CBA disputes) requires legal sign-off.' ;
    rdfs:domain ind:EditorialBrief ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drmRightsStatus rdf:type rdf:Property ;
    rdfs:label 'Drm Rights Status' ;
    rdfs:comment 'Status of digital rights clearance for the content covered by this editorial brief. Governs whether the content can be distributed across target platforms. DRM (Digital Rights Management) clearance is mandatory before publication.' ;
    rdfs:domain ind:EditorialBrief ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:durationTargetSeconds rdf:type rdf:Property ;
    rdfs:label 'Duration Target Seconds' ;
    rdfs:comment 'Target runtime duration in seconds for audio-visual content (video highlights, podcasts, broadcast segments). Null for text-based content types. Drives production scheduling and CDN (Content Delivery Network) capacity planning.' ;
    rdfs:domain ind:EditorialBrief ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:embargoTimestamp rdf:type rdf:Property ;
    rdfs:label 'Embargo Timestamp' ;
    rdfs:comment 'Date and time before which the content must not be published or distributed. Used for coordinated release of exclusive stories, pre-match previews, and league-mandated embargo windows.' ;
    rdfs:domain ind:EditorialBrief ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:notes rdf:type rdf:Property ;
    rdfs:label 'Notes' ;
    rdfs:comment 'Free-text field for additional editorial guidance, special instructions, contextual background, or production notes provided by the commissioning editor to the assigned journalist or producer.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publicationDeadline rdf:type rdf:Property ;
    rdfs:label 'Publication Deadline' ;
    rdfs:comment 'Target date and time by which the content must be published or broadcast. May differ from submission deadline to allow for editorial review, legal clearance, and CDN distribution lead time.' ;
    rdfs:domain ind:EditorialBrief ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:revisionCount rdf:type rdf:Property ;
    rdfs:label 'Revision Count' ;
    rdfs:comment 'Number of revision cycles the editorial brief has undergone since initial commissioning. Tracks editorial iteration and is used to identify briefs requiring excessive rework for process improvement.' ;
    rdfs:domain ind:EditorialBrief ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:socialChannelTarget rdf:type rdf:Property ;
    rdfs:label 'Social Channel Target' ;
    rdfs:comment 'Specific social media platform(s) targeted for distribution of content produced under this brief (e.g., Instagram, X/Twitter, TikTok, YouTube). Drives format and duration specifications for social-first content.' ;
    rdfs:domain ind:EditorialBrief ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionDeadline rdf:type rdf:Property ;
    rdfs:label 'Submission Deadline' ;
    rdfs:comment 'Date and time by which the assigned journalist or producer must submit the completed content for editorial review. Critical for time-sensitive sports news and live event coverage.' ;
    rdfs:domain ind:EditorialBrief ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:ugcSourcedFlag rdf:type rdf:Property ;
    rdfs:label 'Ugc Sourced Flag' ;
    rdfs:comment 'Indicates whether this editorial brief incorporates or is based on UGC (User Generated Content) sourced from fan platforms or social channels. Triggers additional rights clearance and GDPR compliance workflows.' ;
    rdfs:domain ind:EditorialBrief ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:broadcastPolicyId rdf:type rdf:Property ;
    rdfs:label 'Broadcast Policy Id' ;
    rdfs:comment 'Foreign key linking to compliance.policy. Business justification: Platform channels must operate under broadcast standards and content policies (age rating policy, geo-restriction policy, closed captioning policy). The channel has content_rating_system and drm_requi' ;
    rdfs:domain ind:PlatformChannel ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Policy .

ind:daletChannelId rdf:type rdf:Property ;
    rdfs:label 'Dalet Channel Id' ;
    rdfs:comment 'The native channel identifier assigned to this distribution channel within the Dalet Galaxy Media Asset Management (MAM) and broadcast workflow system. Used to correlate platform_channel records with Dalet Galaxy publish destination configurations and workflow routing rules. System-of-record cross-reference key.' ;
    rdfs:domain ind:PlatformChannel ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Channel .

ind:operatorId rdf:type rdf:Property ;
    rdfs:label 'Operator Id' ;
    rdfs:comment 'Foreign key linking to gaming.operator. Business justification: Sportsbook-branded streaming channels (e.g., FanDuel TV, ESPN Bet integrations) are operated by or affiliated with a licensed gaming operator. Content distribution teams must track which gaming operat' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Operator .

ind:adInsertionEnabled rdf:type rdf:Property ;
    rdfs:label 'Ad Insertion Enabled' ;
    rdfs:comment 'Indicates whether dynamic ad insertion (DAI) or server-side ad insertion (SSAI) is enabled for content delivered on this platform channel. True = ad markers and SCTE-35 cue points must be included in the content package; False = ad-free delivery. Relevant for CPM-based revenue channels and sponsor integration.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:apiEndpointUrl rdf:type rdf:Property ;
    rdfs:label 'Api Endpoint Url' ;
    rdfs:comment 'The Application Programming Interface (API) endpoint URL for programmatic content submission and metadata exchange with this platform channel\'s operator system. Classified as confidential as it represents proprietary integration infrastructure. Used for automated publish event routing from Dalet Galaxy.' ;
    rdfs:domain ind:PlatformChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:audioFormat rdf:type rdf:Property ;
    rdfs:label 'Audio Format' ;
    rdfs:comment 'Audio format specification required or supported by this platform channel for content delivery. Drives audio encoding and packaging decisions in Dalet Galaxy production workflows. stereo = standard 2-channel; 5_1_surround = 5.1 surround sound; 7_1_surround = 7.1 surround sound; dolby_atmos = immersive Dolby Atmos; mono = single channel.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cdnProvider rdf:type rdf:Property ;
    rdfs:label 'Cdn Provider' ;
    rdfs:comment 'Name of the Content Delivery Network (CDN) provider used to distribute content to this platform channel (e.g., Akamai, Fastly, Cloudflare, AWS CloudFront, Limelight). Determines the CDN endpoint configuration and SLA parameters for content delivery performance.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelCode rdf:type rdf:Property ;
    rdfs:label 'Channel Code' ;
    rdfs:comment 'Externally-known unique business code identifying the distribution channel (e.g., ESPN_OTT_US, RSN_BALLY_MIDWEST, PPV_UFC_GLOBAL). Used as the canonical business identifier in Dalet Galaxy DAM publish routing and CDN distribution configurations.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelName rdf:type rdf:Property ;
    rdfs:label 'Channel Name' ;
    rdfs:comment 'Human-readable display name of the distribution platform channel (e.g., \'ESPN+ OTT United States\', \'Bally Sports Midwest RSN\', \'UFC PPV Global Portal\'). Used in reporting, content routing dashboards, and rights management interfaces.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelStatus rdf:type rdf:Property ;
    rdfs:label 'Channel Status' ;
    rdfs:comment 'Current operational lifecycle status of the platform channel. Active channels are eligible to receive publish events and content routing. Suspended channels are temporarily blocked from receiving new content. Decommissioned channels are retired from distribution operations.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelType rdf:type rdf:Property ;
    rdfs:label 'Channel Type' ;
    rdfs:comment 'Classification of the distribution channel by delivery technology and business model. OTT = Over-The-Top streaming app; RSN = Regional Sports Network; PPV = Pay-Per-View portal; IPTV = Internet Protocol Television; DTC = Direct-To-Consumer streaming; social_media = social platform channel; linear_broadcast = traditional broadcast slot. Drives rights window routing and DRM policy selection. [ENUM-REF-CANDIDATE: OTT|RSN|PPV|IPTV|DTC|social_media|linear_broadcast — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelUrl rdf:type rdf:Property ;
    rdfs:label 'Channel Url' ;
    rdfs:comment 'The public-facing URL of the platform channel accessible to end consumers (e.g., the OTT app store URL, the social media channel page URL, the DTC streaming portal URL). Used for fan engagement linking, marketing campaigns, and digital platform analytics in Adobe Experience Platform.' ;
    rdfs:domain ind:PlatformChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closedCaptioningRequired rdf:type rdf:Property ;
    rdfs:label 'Closed Captioning Required' ;
    rdfs:comment 'Indicates whether closed captioning (CC) is mandatory for all content published to this platform channel. True = closed captions must be included in the content package per ADA or FCC accessibility requirements; False = optional. Drives caption generation and QC steps in the Dalet Galaxy publish workflow.' ;
    rdfs:domain ind:PlatformChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:concurrentStreamLimit rdf:type rdf:Property ;
    rdfs:label 'Concurrent Stream Limit' ;
    rdfs:comment 'Maximum number of simultaneous content streams permitted on this platform channel at any given time, as defined in the operator SLA or broadcast rights agreement. Used for capacity planning, CDN bandwidth provisioning, and SLA compliance monitoring.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contentRatingSystem rdf:type rdf:Property ;
    rdfs:label 'Content Rating System' ;
    rdfs:comment 'The content rating classification system applicable to this platform channel\'s territory and regulatory environment (e.g., MPAA for US theatrical, TV Parental Guidelines for US broadcast, BBFC for UK, FSK for Germany). Determines which content rating metadata must be included in publish packages and enforced at the channel level.' ;
    rdfs:domain ind:PlatformChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decommissionDate rdf:type rdf:Property ;
    rdfs:label 'Decommission Date' ;
    rdfs:comment 'The date on which this platform channel was or is scheduled to be decommissioned and removed from active content distribution. Nullable for active channels. Used to enforce rights window expiry and cease automated publish routing to retired endpoints.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:drmRequired rdf:type rdf:Property ;
    rdfs:label 'Drm Required' ;
    rdfs:comment 'Indicates whether Digital Rights Management (DRM) encryption is mandatory for all content published to this platform channel. True = DRM packaging required before delivery; False = unencrypted delivery permitted (e.g., free-to-air social channels). Used as a gate in the Dalet Galaxy publish workflow.' ;
    rdfs:domain ind:PlatformChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:drmSystem rdf:type rdf:Property ;
    rdfs:label 'Drm System' ;
    rdfs:comment 'The Digital Rights Management (DRM) technology required by this platform channel for content protection and access control. Widevine is used for Android/Chrome; FairPlay for Apple devices; PlayReady for Microsoft/Smart TVs; multi_drm indicates the channel supports multiple DRM systems simultaneously. Drives DRM packaging decisions in Dalet Galaxy and CDN delivery configurations.' ;
    rdfs:domain ind:PlatformChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geoRestrictionEnabled rdf:type rdf:Property ;
    rdfs:label 'Geo Restriction Enabled' ;
    rdfs:comment 'Indicates whether geographic (geo-blocking) restrictions are enforced for content delivered to this platform channel. True = CDN geo-restriction rules are applied based on territory_code; False = global delivery without geo-blocking. Critical for broadcast rights compliance and territorial exclusivity enforcement.' ;
    rdfs:domain ind:Content ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hdrSupported rdf:type rdf:Property ;
    rdfs:label 'Hdr Supported' ;
    rdfs:comment 'Indicates whether this platform channel supports High Dynamic Range (HDR) video delivery. True = HDR content (HDR10, Dolby Vision, HLG) can be delivered to this channel; False = SDR only. Drives HDR transcoding and packaging decisions in the content production workflow.' ;
    rdfs:domain ind:PlatformChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:launchDate rdf:type rdf:Property ;
    rdfs:label 'Launch Date' ;
    rdfs:comment 'The date on which this platform channel became operational and began accepting content distribution. Used to calculate channel tenure, validate rights window effective dates, and support historical analytics on channel performance.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:liveStreamingEnabled rdf:type rdf:Property ;
    rdfs:label 'Live Streaming Enabled' ;
    rdfs:comment 'Indicates whether this platform channel is configured and authorized to receive and distribute live streaming content (e.g., live game broadcasts, live PPV events). True = live streaming supported; False = VOD/on-demand only. Critical for live event publish routing decisions.' ;
    rdfs:domain ind:PlatformChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maxResolution rdf:type rdf:Property ;
    rdfs:label 'Max Resolution' ;
    rdfs:comment 'Maximum video resolution supported by this platform channel for content delivery. SD = Standard Definition (480p); HD = High Definition (720p); FHD = Full High Definition (1080p); UHD_4K = Ultra High Definition 4K (2160p); UHD_8K = Ultra High Definition 8K (4320p). Used to determine transcoding profiles in Dalet Galaxy and CDN packaging.' ;
    rdfs:domain ind:PlatformChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:metadataStandard rdf:type rdf:Property ;
    rdfs:label 'Metadata Standard' ;
    rdfs:comment 'The metadata schema standard required by this platform channel for content package delivery (e.g., EIDR for entertainment identifier registry, EBUCore for broadcast, Dublin Core for general digital assets, IPTC for news/sports photography). Drives metadata mapping and transformation in Dalet Galaxy export workflows.' ;
    rdfs:domain ind:PlatformChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ppvEnabled rdf:type rdf:Property ;
    rdfs:label 'Ppv Enabled' ;
    rdfs:comment 'Indicates whether this platform channel is configured to support Pay-Per-View (PPV) transactional content purchases. True = PPV events can be routed to this channel with associated purchase gating; False = subscription or free-to-air only. Drives PPV event publish routing and revenue management integration.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:publishLeadTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Publish Lead Time Minutes' ;
    rdfs:comment 'Minimum number of minutes required before a scheduled broadcast or rights window start time that content must be submitted to this platform channel for successful ingestion and processing. Used by Dalet Galaxy automated scheduling to trigger publish events with sufficient lead time.' ;
    rdfs:domain ind:PlatformChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rightsWindowDefaultDays rdf:type rdf:Property ;
    rdfs:label 'Rights Window Default Days' ;
    rdfs:comment 'Default number of days that content rights are valid for distribution on this platform channel, used as a baseline when no specific rights agreement overrides are present. Supports automated rights window calculation in the Dalet Galaxy DRM and rights clearance workflow.' ;
    rdfs:domain ind:PlatformChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:slaUptimeTargetPct rdf:type rdf:Property ;
    rdfs:label 'Sla Uptime Target Pct' ;
    rdfs:comment 'The contractually agreed Service Level Agreement (SLA) uptime target percentage for this platform channel, expressed as a percentage (e.g., 99.90 = 99.9% uptime). Used for CDN performance monitoring, operator SLA compliance reporting, and penalty clause evaluation.' ;
    rdfs:domain ind:PlatformChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:socialHandle rdf:type rdf:Property ;
    rdfs:label 'Social Handle' ;
    rdfs:comment 'The official social media handle or username for this platform channel (e.g., @NBASports, @PremierLeague). Applicable for social_media channel types. Used for content routing, fan engagement tracking, and UGC attribution in Adobe Experience Platform and social analytics.' ;
    rdfs:domain ind:PlatformChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subscriptionModel rdf:type rdf:Property ;
    rdfs:label 'Subscription Model' ;
    rdfs:comment 'Business model governing how consumers access content on this platform channel. free = no cost access; subscription = recurring subscription fee (ARR/ARPU driven); ppv = Pay-Per-View (PPV) transactional; freemium = free tier with premium upgrade; ad_supported = free with advertising (CPM-based revenue). Informs rights window configuration and revenue attribution.' ;
    rdfs:domain ind:PlatformChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportedContentFormats rdf:type rdf:Property ;
    rdfs:label 'Supported Content Formats' ;
    rdfs:comment 'Comma-separated list of content asset formats accepted by this platform channel (e.g., \'MP4,HLS,DASH,MXF,HEVC\'). Defines the technical delivery specifications required when routing publish events from Dalet Galaxy to this channel endpoint. [ENUM-REF-CANDIDATE: MP4|HLS|DASH|MXF|HEVC|H264|H265|ProRes|AAC|MP3|JPEG|PNG|WebM — promote to reference product]' ;
    rdfs:domain ind:PlatformChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ugcAccepted rdf:type rdf:Property ;
    rdfs:label 'Ugc Accepted' ;
    rdfs:comment 'Indicates whether this platform channel accepts and distributes User-Generated Content (UGC) from fans and community contributors. True = UGC assets can be routed to this channel after rights clearance; False = professionally produced content only. Relevant for social media channels and fan engagement platforms managed via Adobe Experience Platform.' ;
    rdfs:domain ind:PlatformChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:vodEnabled rdf:type rdf:Property ;
    rdfs:label 'Vod Enabled' ;
    rdfs:comment 'Indicates whether this platform channel supports Video On Demand (VOD) content delivery. True = VOD content (highlights, replays, documentaries) can be published to this channel; False = live-only channel. Used in content routing logic to determine eligible publish targets.' ;
    rdfs:domain ind:PlatformChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:watermarkingRequired rdf:type rdf:Property ;
    rdfs:label 'Watermarking Required' ;
    rdfs:comment 'Indicates whether forensic or visible watermarking is required for content delivered to this platform channel to enable piracy detection and source identification. True = watermarking must be applied during packaging in Dalet Galaxy; False = no watermarking required. Supports IP protection and anti-piracy compliance.' ;
    rdfs:domain ind:PlatformChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ticketInventoryId rdf:type rdf:Property ;
    rdfs:label 'Ticket Inventory Id' ;
    rdfs:comment 'Unique surrogate primary key for each ticket inventory unit record within the venue seating manifest. Serves as the SSOT identifier for a single allocatable seat or standing position per event.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TicketInventory .

ind:accessZoneId rdf:type rdf:Property ;
    rdfs:label 'Access Zone Id' ;
    rdfs:comment 'Foreign key linking to security.access_zone. Business justification: Ticket inventory records define which security zone each seat belongs to. Security staffing plans and evacuation planning require knowing how many sold seats map to each security zone. Links inventory' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AccessZone .

ind:capacityConfigId rdf:type rdf:Property ;
    rdfs:label 'Capacity Config Id' ;
    rdfs:comment 'Foreign key linking to venue.capacity_config. Business justification: Inventory allocation must reference the active capacity_config to enforce fire-code-approved sellable capacity, kill seat counts, and ADA capacity limits. Manifest approval and league sign-off process' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CapacityConfig .

ind:leagueScheduleId rdf:type rdf:Property ;
    rdfs:label 'League Schedule Id' ;
    rdfs:comment 'Foreign key linking to league.league_schedule. Business justification: Inventory on-sale timestamps, PPV flags, and gate revenue split percentages are governed by league_schedule. Ticketing operations enforce on-sale windows directly from league_schedule.ticket_on_sale_d' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LeagueSchedule .

ind:priceTierId rdf:type rdf:Property ;
    rdfs:label 'Price Tier Id' ;
    rdfs:comment 'Foreign key linking to ticketing.price_tier. Business justification: Each ticket inventory unit belongs to a specific price tier (GA, VIP, SRO, etc.). ticket_inventory currently has price_zone_id (existing FK) and seat_tier as a STRING, but lacks a direct FK to price_t' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PriceTier .

ind:priceZoneId rdf:type rdf:Property ;
    rdfs:label 'Price Zone Id' ;
    rdfs:comment 'Reference to the event-specific price zone assigned to this inventory unit. Price zones define the base pricing tier and dynamic pricing eligibility for the seat.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PriceZone .

ind:primaryTicketEventFixtureId rdf:type rdf:Property ;
    rdfs:label 'Primary Ticket Event Fixture Id' ;
    rdfs:comment 'Reference to the specific event for which this inventory unit is allocated. Links the seat record to the event scheduling master.' ;
    rdfs:domain ind:Ticketing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Fixture .

ind:seatId rdf:type rdf:Property ;
    rdfs:label 'Seat Id' ;
    rdfs:comment 'Foreign key linking to venue.seat. Business justification: Physical seat manifest validation — kill-seat enforcement, ADA accommodation tracking, and obstructed-view disclosure — requires linking each inventory record to the authoritative venue.seat record. T' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Seat .

ind:seatingSectionId rdf:type rdf:Property ;
    rdfs:label 'Seating Section Id' ;
    rdfs:comment 'Foreign key linking to venue.seating_section. Business justification: Inventory allocation and manifest validation require linking each ticket inventory record to the canonical seating_section for ADA compliance, sightline disclosure, price zone enforcement, and kill-se' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SeatingSection .

ind:accessGate rdf:type rdf:Property ;
    rdfs:label 'Access Gate' ;
    rdfs:comment 'The designated entry gate or access point at the venue through which the holder of this inventory unit is directed. Used for access control configuration in AXS/Ticketmaster gate management and crowd flow planning.' ;
    rdfs:domain ind:TicketInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adaAccommodationType rdf:type rdf:Property ;
    rdfs:label 'Ada Accommodation Type' ;
    rdfs:comment 'Specifies the type of ADA accessibility accommodation provided by this inventory unit. Applicable only when is_ada_accessible = true. Supports ADA compliance reporting and accessible inventory allocation.' ;
    rdfs:domain ind:TicketInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:archticsSeatKey rdf:type rdf:Property ;
    rdfs:label 'Archtics Seat Key' ;
    rdfs:comment 'The native seat-level unique identifier as assigned by the Archtics venue seating system. Used for reconciliation and real-time sync with the source-of-record seating manifest.' ;
    rdfs:domain ind:TicketInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:barcodeFormat rdf:type rdf:Property ;
    rdfs:label 'Barcode Format' ;
    rdfs:comment 'The barcode or digital credential format used for access control scanning of this inventory unit. Determines scanner compatibility at venue entry points.' ;
    rdfs:domain ind:TicketInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compReason rdf:type rdf:Property ;
    rdfs:label 'Comp Reason' ;
    rdfs:comment 'The reason code for complimentary allocation of this inventory unit. Applicable only when inventory_type = COMPLIMENTARY or inventory_status = COMP. Required for SOX financial controls and sponsor/media comp tracking.' ;
    rdfs:domain ind:TicketInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:digitalDeliveryEligible rdf:type rdf:Property ;
    rdfs:label 'Digital Delivery Eligible' ;
    rdfs:comment 'Indicates whether this inventory unit supports digital ticket delivery (mobile wallet, NFC, QR code). Drives delivery method options presented at checkout and access control configuration at venue gates.' ;
    rdfs:domain ind:TicketInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dynamicPriceAmount rdf:type rdf:Property ;
    rdfs:label 'Dynamic Price Amount' ;
    rdfs:comment 'The current dynamically adjusted price for this inventory unit, reflecting real-time demand signals, sell-through rates, and competitive pricing algorithms. Updated continuously by the dynamic pricing engine. Null if dynamic pricing is not enabled for this inventory unit.' ;
    rdfs:domain ind:TicketInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:faceValueAmount rdf:type rdf:Property ;
    rdfs:label 'Face Value Amount' ;
    rdfs:comment 'The printed face value price of the ticket for this inventory unit in the event\'s base currency. Represents the base price before dynamic pricing adjustments, fees, or discounts. Used for resale market regulation and revenue reporting.' ;
    rdfs:domain ind:Ticketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:holdCode rdf:type rdf:Property ;
    rdfs:label 'Hold Code' ;
    rdfs:comment 'The hold code applied to this inventory unit when status is HELD or RESERVED. Hold codes identify the reason or pool for the hold (e.g., \'SPONSOR\', \'MEDIA\', \'ARTIST\', \'GROUP\', \'SEASON\'). Sourced from Archtics hold code configuration.' ;
    rdfs:domain ind:Ticketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdExpiryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Hold Expiry Timestamp' ;
    rdfs:comment 'The date and time at which a temporary hold on this inventory unit expires, returning it to AVAILABLE status if not converted to a sale. Applicable when inventory_status = HELD.' ;
    rdfs:domain ind:Ticketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:hostInventoryCode rdf:type rdf:Property ;
    rdfs:label 'Host Inventory Code' ;
    rdfs:comment 'The inventory unit identifier assigned by the Ticketmaster Host system. Used for cross-system reconciliation between Archtics seating manifest and Ticketmaster ticketing platform.' ;
    rdfs:domain ind:TicketInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inventoryStatus rdf:type rdf:Property ;
    rdfs:label 'Inventory Status' ;
    rdfs:comment 'Current allocation state of the inventory unit: AVAILABLE (open for sale), SOLD (ticket issued), HELD (temporarily locked for a transaction or hold pool), KILLED (removed from sellable inventory), COMP (complimentary allocation), RESERVED (pre-allocated to a specific channel or package). SSOT for available-to-sell calculations.' ;
    rdfs:domain ind:TicketInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inventoryType rdf:type rdf:Property ;
    rdfs:label 'Inventory Type' ;
    rdfs:comment 'Classifies the inventory unit into its designated pool: General Admission (GA), Very Important Person (VIP), Standing Room Only (SRO), Press, Complimentary, or Accessible (ADA). Drives pricing, access control, and channel eligibility rules. [ENUM-REF-CANDIDATE: GA|VIP|SRO|PRESS|COMPLIMENTARY|ACCESSIBLE|SUITE|GROUP|SEASON — promote to reference product]' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isAdaAccessible rdf:type rdf:Property ;
    rdfs:label 'Is Ada Accessible' ;
    rdfs:comment 'Indicates whether this inventory unit is designated as ADA-accessible, meeting Americans with Disabilities Act requirements for wheelchair access, companion seating, or other accessibility accommodations.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isAisleSeat rdf:type rdf:Property ;
    rdfs:label 'Is Aisle Seat' ;
    rdfs:comment 'Indicates whether this seat is positioned directly adjacent to an aisle. Used for accessibility filtering, premium seat designation, and fan preference matching in CRM-driven personalization.' ;
    rdfs:domain ind:TicketInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isDynamicPricingEnabled rdf:type rdf:Property ;
    rdfs:label 'Is Dynamic Pricing Enabled' ;
    rdfs:comment 'Indicates whether this inventory unit is eligible for dynamic pricing adjustments. When true, the dynamic_price_amount field is actively maintained by the pricing engine.' ;
    rdfs:domain ind:TicketInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isObstructedView rdf:type rdf:Property ;
    rdfs:label 'Is Obstructed View' ;
    rdfs:comment 'Indicates whether this seat has a partially or fully obstructed sightline to the stage or playing field. Drives discounted pricing eligibility and mandatory disclosure requirements at point of sale.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSeasonTicketEligible rdf:type rdf:Property ;
    rdfs:label 'Is Season Ticket Eligible' ;
    rdfs:comment 'Indicates whether this inventory unit is eligible to be included in a season ticket package. Drives season ticket renewal workflows and package construction in Archtics.' ;
    rdfs:domain ind:TicketInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:killReason rdf:type rdf:Property ;
    rdfs:label 'Kill Reason' ;
    rdfs:comment 'Reason code explaining why this inventory unit has been killed (removed from sellable inventory). Applicable only when inventory_status = KILLED. [ENUM-REF-CANDIDATE: OBSTRUCTED_VIEW|STRUCTURAL|SAFETY|ADA_COMPANION|EQUIPMENT|SIGHTLINE|BROADCAST|STAGING — promote to reference product]' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastStatusChangeTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Status Change Timestamp' ;
    rdfs:comment 'The date and time when the inventory_status of this unit was most recently updated. Supports audit trail, real-time inventory monitoring, and SLA tracking for hold-to-sale conversion.' ;
    rdfs:domain ind:TicketInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:manifestSectionType rdf:type rdf:Property ;
    rdfs:label 'Manifest Section Type' ;
    rdfs:comment 'The physical section category within the venue manifest as defined in the Archtics seating configuration. Supports venue layout analytics and capacity planning. [ENUM-REF-CANDIDATE: LOWER_BOWL|UPPER_BOWL|FLOOR|SUITE|CLUB|STANDING|PRESS_BOX|FIELD|MEZZANINE — promote to reference product]' ;
    rdfs:domain ind:TicketInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manifestVersion rdf:type rdf:Property ;
    rdfs:label 'Manifest Version' ;
    rdfs:comment 'The version identifier of the venue seating manifest from which this inventory unit was loaded. Enables tracking of manifest changes (e.g., reconfiguration for different event types such as concert vs. sports) and supports rollback and audit.' ;
    rdfs:domain ind:TicketInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:offSaleTimestamp rdf:type rdf:Property ;
    rdfs:label 'Off Sale Timestamp' ;
    rdfs:comment 'The date and time when this inventory unit is removed from public sale (e.g., event day cutoff). After this timestamp, the unit is no longer available through standard sales channels.' ;
    rdfs:domain ind:TicketInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:onSaleTimestamp rdf:type rdf:Property ;
    rdfs:label 'On Sale Timestamp' ;
    rdfs:comment 'The date and time when this inventory unit becomes available for public sale. Supports presale window management, channel release scheduling, and real-time available-to-sell calculations.' ;
    rdfs:domain ind:TicketInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:packageType rdf:type rdf:Property ;
    rdfs:label 'Package Type' ;
    rdfs:comment 'Identifies whether this inventory unit is allocated to a single-event sale, a full season ticket package, a mini-plan, group sales block, flex plan, or suite package. Drives entitlement and renewal logic.' ;
    rdfs:domain ind:Ticketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resaleEligible rdf:type rdf:Property ;
    rdfs:label 'Resale Eligible' ;
    rdfs:comment 'Indicates whether this inventory unit is eligible for listing on the official resale marketplace. Controlled by league rules, event-specific restrictions, and package terms (e.g., complimentary tickets are typically resale-ineligible).' ;
    rdfs:domain ind:Ticketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:resaleMaxPrice rdf:type rdf:Property ;
    rdfs:label 'Resale Max Price' ;
    rdfs:comment 'The maximum price ceiling enforced for resale of this inventory unit on the official resale marketplace. Applicable in jurisdictions or leagues with anti-scalping price cap regulations.' ;
    rdfs:domain ind:TicketInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:resaleMinPrice rdf:type rdf:Property ;
    rdfs:label 'Resale Min Price' ;
    rdfs:comment 'The minimum price floor enforced for resale of this inventory unit on the official resale marketplace. Set by league policy or event-specific pricing rules to prevent below-face-value resale.' ;
    rdfs:domain ind:Ticketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rowLabel rdf:type rdf:Property ;
    rdfs:label 'Row Label' ;
    rdfs:comment 'The alphanumeric row identifier within the section (e.g., \'A\', \'12\', \'AA\'). Null for General Admission (GA) or Standing Room Only (SRO) inventory types.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rowSequence rdf:type rdf:Property ;
    rdfs:label 'Row Sequence' ;
    rdfs:comment 'Numeric sequence of the row within the section, used for physical ordering and proximity-based seat grouping logic. Supports best-available seat algorithms and contiguous seat selection.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:saleChannel rdf:type rdf:Property ;
    rdfs:label 'Sale Channel' ;
    rdfs:comment 'The designated sales channel through which this inventory unit is authorized to be sold. Controls channel-specific routing in Ticketmaster/AXS and supports channel mix analytics. [ENUM-REF-CANDIDATE: BOX_OFFICE|ONLINE|MOBILE|GROUP_SALES|SEASON_PACKAGE|RESALE|API_PARTNER|VIP_HOSPITALITY — promote to reference product]' ;
    rdfs:domain ind:TicketInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seatSequence rdf:type rdf:Property ;
    rdfs:label 'Seat Sequence' ;
    rdfs:comment 'Numeric sequence of the seat within the row, used for physical ordering and contiguous seat grouping. Supports best-available algorithms that prioritize adjacent seats for group purchases.' ;
    rdfs:domain ind:TicketInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:seatingCapacityType rdf:type rdf:Property ;
    rdfs:label 'Seating Capacity Type' ;
    rdfs:comment 'Describes the physical seating configuration of this inventory unit: FIXED (permanent installed seat), PORTABLE (temporary/removable seat), STANDING (no seat, standing position), or LAWN (open lawn area). Affects ADA compliance and capacity calculations.' ;
    rdfs:domain ind:TicketInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sectionLabel rdf:type rdf:Property ;
    rdfs:label 'Section Label' ;
    rdfs:comment 'The alphanumeric label of the venue section in which this inventory unit is located (e.g., \'101\', \'FLOOR A\', \'PRESS BOX\'). Sourced from the Archtics seating manifest.' ;
    rdfs:domain ind:TicketInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ticketOrderId rdf:type rdf:Property ;
    rdfs:label 'Ticket Order Id' ;
    rdfs:comment 'Unique surrogate identifier for the ticket order record in the Silver Layer lakehouse. Primary key for all downstream joins and lineage tracking.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TicketOrder .

ind:accountId rdf:type rdf:Property ;
    rdfs:label 'Account Id' ;
    rdfs:comment 'Foreign key linking to fan.account. Business justification: Account-level ticket purchase reporting, chargeback management, and revenue reconciliation require linking orders to the fan account entity. Sports ticketing platforms (AXS, Ticketmaster) associate or' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Account .

ind:allotmentAthleteContractId rdf:type rdf:Property ;
    rdfs:label 'Allotment Athlete Contract Id' ;
    rdfs:comment 'Foreign key linking to athlete.athlete_contract. Business justification: Player contracts specify ticket allotment quantities and terms. Linking ticket orders to the governing contract enables contract compliance reporting, allotment limit enforcement, and dead-cap/contrac' ;
    rdfs:domain ind:TicketOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Contract .

ind:allotmentRosterId rdf:type rdf:Property ;
    rdfs:label 'Allotment Roster Id' ;
    rdfs:comment 'Foreign key linking to athlete.roster. Business justification: CBA-mandated player ticket allotments are roster-specific (per-game, per-season, per-team). Linking ticket orders to the active roster entry enables allotment tracking, CBA compliance audits, and per-' ;
    rdfs:domain ind:TicketOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Roster .

ind:groupSaleId rdf:type rdf:Property ;
    rdfs:label 'Group Sale Id' ;
    rdfs:comment 'Reference to the group sales agreement if this order is part of a bulk group purchase. Null for individual orders. Supports group sales revenue attribution and coordinator commission tracking.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GroupSale .

ind:membershipId rdf:type rdf:Property ;
    rdfs:label 'Membership Id' ;
    rdfs:comment 'Foreign key linking to fan.membership. Business justification: Membership benefit utilization tracking requires linking ticket orders placed under membership privileges (priority access, member discounts) to the membership record. Enables membership ROI reporting' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Membership .

ind:paymentMethodId rdf:type rdf:Property ;
    rdfs:label 'Payment Method Id' ;
    rdfs:comment 'Foreign key linking to fan.payment_method. Business justification: PCI compliance and payment method lifecycle management require linking ticket orders to the stored tokenized payment method record. The existing plain-text `payment_method` column is denormalized. Pro' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PaymentMethod .

ind:ppvAssetId rdf:type rdf:Property ;
    rdfs:label 'Ppv Asset Id' ;
    rdfs:comment 'Foreign key linking to content.asset. Business justification: PPV ticket orders must reference the specific content asset being purchased for revenue reconciliation, entitlement validation, and PPV rights reporting. Sports entertainment operators track which con' ;
    rdfs:domain ind:Ticketing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Asset .

ind:primaryTicketFanFanProfileId rdf:type rdf:Property ;
    rdfs:label 'Primary Ticket Fan Fan Profile Id' ;
    rdfs:comment 'Reference to the fan (purchaser) who placed this ticket order. Links to the fan master record in the CRM system (Salesforce CRM / Adobe Experience Platform).' ;
    rdfs:domain ind:Ticketing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FanProfile .

ind:resaleOriginalOrderId rdf:type rdf:Property ;
    rdfs:label 'Resale Original Order Id' ;
    rdfs:comment 'Reference to the original primary-market ticket order from which the resale tickets originated. Populated only when resale_flag is True. Enables full resale chain traceability and anti-fraud analysis.' ;
    rdfs:domain ind:TicketOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TicketOrder .

ind:seasonTicketAccountId rdf:type rdf:Property ;
    rdfs:label 'Season Ticket Account Id' ;
    rdfs:comment 'Foreign key linking to ticketing.season_ticket_account. Business justification: Season ticket holder orders are placed against a specific season ticket account, which tracks the fan\'s enrollment, seat assignments, payment plan, and loyalty tier. Linking ticket_order to season_tic' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SeasonTicketAccount .

ind:seasonTicketPackageId rdf:type rdf:Property ;
    rdfs:label 'Season Ticket Package Id' ;
    rdfs:comment 'Reference to the season ticket package if this order was placed as part of a season ticket subscription. Null for single-event purchases. Supports season ticket holder analytics and renewal management.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SeasonTicketPackage .

ind:accessBarcode rdf:type rdf:Property ;
    rdfs:label 'Access Barcode' ;
    rdfs:comment 'The primary digital access credential (barcode, QR code token, or NFC token reference) associated with this order for venue entry. Stored as a tokenized reference, not the raw barcode value, to prevent unauthorized duplication. Used by access control systems at venue gates.' ;
    rdfs:domain ind:TicketOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accessibleSeatingFlag rdf:type rdf:Property ;
    rdfs:label 'Accessible Seating Flag' ;
    rdfs:comment 'Indicates whether this order includes ADA-compliant accessible seating accommodations. True = accessible seating requested and allocated. Required for ADA compliance reporting and venue accessibility management.' ;
    rdfs:domain ind:TicketOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cancellationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Cancellation Timestamp' ;
    rdfs:comment 'Date and time when this order was cancelled. Populated only when order_status is \'cancelled\'. Used for cancellation rate analysis, revenue impact assessment, and SLA compliance reporting.' ;
    rdfs:domain ind:TicketOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:deliveryMethod rdf:type rdf:Property ;
    rdfs:label 'Delivery Method' ;
    rdfs:comment 'The method by which tickets are delivered to the fan after purchase. Supports digital delivery tracking, will-call management, and access control integration with Ticketmaster/AXS.' ;
    rdfs:domain ind:Ticketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryStatus rdf:type rdf:Property ;
    rdfs:label 'Delivery Status' ;
    rdfs:comment 'Current fulfillment status of ticket delivery to the fan. Tracks whether digital or physical tickets have been successfully delivered, are pending, or encountered a delivery failure.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discountAmount rdf:type rdf:Property ;
    rdfs:label 'Discount Amount' ;
    rdfs:comment 'Total discount applied to this order, including promotional codes, season ticket holder discounts, group rate reductions, or sponsor-funded offers. Used for promotional effectiveness analysis and revenue leakage tracking.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gdprConsentFlag rdf:type rdf:Property ;
    rdfs:label 'Gdpr Consent Flag' ;
    rdfs:comment 'Indicates whether the fan provided explicit GDPR-compliant data processing consent at the time of this order. True = consent given. Required for EU market compliance and fan data usage governance.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:loyaltyPointsEarned rdf:type rdf:Property ;
    rdfs:label 'Loyalty Points Earned' ;
    rdfs:comment 'Number of fan loyalty or rewards points earned through this ticket purchase. Supports fan engagement analytics, loyalty program ROI measurement, and CRM-driven personalization via Adobe Experience Platform.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:loyaltyPointsRedeemed rdf:type rdf:Property ;
    rdfs:label 'Loyalty Points Redeemed' ;
    rdfs:comment 'Number of fan loyalty or rewards points redeemed as part of payment or discount for this order. Used for loyalty liability accounting and fan engagement reporting.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:orderNotes rdf:type rdf:Property ;
    rdfs:label 'Order Notes' ;
    rdfs:comment 'Free-text notes or special instructions associated with this order, entered by the fan, box office agent, or group sales coordinator. May include accessibility requests, VIP service notes, or group coordinator instructions.' ;
    rdfs:domain ind:TicketOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderTotalAmount rdf:type rdf:Property ;
    rdfs:label 'Order Total Amount' ;
    rdfs:comment 'Net total amount charged to the fan for this order, equal to face_value_amount + service_fee_amount + tax_amount minus any discounts. This is the authoritative total for payment processing and revenue recognition.' ;
    rdfs:domain ind:TicketOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentReference rdf:type rdf:Property ;
    rdfs:label 'Payment Reference' ;
    rdfs:comment 'PCI-DSS compliant tokenized payment reference (e.g., Ticketmaster/AXS payment token or SAP payment document number). NEVER stores raw card numbers or CVV. Used for payment reconciliation, refund processing, and chargeback management.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentStatus rdf:type rdf:Property ;
    rdfs:label 'Payment Status' ;
    rdfs:comment 'Current status of the payment transaction associated with this order. Distinct from order_status — an order may be confirmed while payment is still in settlement. Critical for financial reconciliation and PCI-DSS audit.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ppvFlag rdf:type rdf:Property ;
    rdfs:label 'Ppv Flag' ;
    rdfs:comment 'Indicates whether this order is for a Pay-Per-View (PPV) digital access entitlement rather than a physical venue ticket. True = PPV digital order. Supports broadcast revenue attribution and OTT/DTC channel analytics.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pricingModel rdf:type rdf:Property ;
    rdfs:label 'Pricing Model' ;
    rdfs:comment 'The pricing strategy applied to this order. FIXED (standard face value), DYNAMIC (demand-based variable pricing), SEASON_PACKAGE (season ticket bundle), GROUP_RATE (bulk group discount), or RESALE (secondary market). Supports revenue management analytics.' ;
    rdfs:domain ind:TicketOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchaseTimestamp rdf:type rdf:Property ;
    rdfs:label 'Purchase Timestamp' ;
    rdfs:comment 'The exact date and time (with timezone offset) at which the fan completed the ticket purchase transaction. This is the principal business event timestamp for the order. Used for revenue attribution, demand analysis, and PCI-DSS audit trails.' ;
    rdfs:domain ind:TicketOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:refundAmount rdf:type rdf:Property ;
    rdfs:label 'Refund Amount' ;
    rdfs:comment 'Total amount refunded to the fan for this order. Populated when order_status is \'refunded\' or \'partially_refunded\'. Used for revenue adjustment, financial reconciliation, and fan satisfaction reporting.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:refundReasonCode rdf:type rdf:Property ;
    rdfs:label 'Refund Reason Code' ;
    rdfs:comment 'Standardized reason code explaining why a refund was issued for this order. Populated when refund_amount > 0. Supports refund trend analysis, event cancellation impact reporting, and fraud detection.' ;
    rdfs:domain ind:TicketOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resaleFlag rdf:type rdf:Property ;
    rdfs:label 'Resale Flag' ;
    rdfs:comment 'Indicates whether this order was placed through the secondary/resale marketplace rather than the primary ticketing channel. True = resale order. Used for primary vs. secondary market revenue segmentation and league governance reporting.' ;
    rdfs:domain ind:TicketOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:salesChannelCode rdf:type rdf:Property ;
    rdfs:label 'Sales Channel Code' ;
    rdfs:comment 'Identifies the commerce channel through which the ticket order was placed. Supports multi-channel revenue attribution and reconciliation. [ENUM-REF-CANDIDATE: TICKETMASTER|AXS|BOX_OFFICE|GROUP_SALES|DTC|KIOSK|PARTNER_API — promote to reference product]' ;
    rdfs:domain ind:TicketOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Service Fee Amount' ;
    rdfs:comment 'Total service and convenience fees charged on this order by the ticketing platform or box office. Distinct from face value and taxes. Key component for revenue-share reconciliation with Ticketmaster/AXS.' ;
    rdfs:domain ind:Ticketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sourceSystemOrderCode rdf:type rdf:Property ;
    rdfs:label 'Source System Order Code' ;
    rdfs:comment 'The native order identifier from the originating ticketing platform (e.g., Ticketmaster order ID, AXS confirmation number, Archtics transaction ID). Enables bi-directional reconciliation between the Silver Layer and the operational system of record.' ;
    rdfs:domain ind:TicketOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxAmount rdf:type rdf:Property ;
    rdfs:label 'Tax Amount' ;
    rdfs:comment 'Total tax amount applied to this order, including applicable sales tax, VAT, or entertainment tax based on the venue jurisdiction. Required for financial reporting and tax remittance.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ticketQuantity rdf:type rdf:Property ;
    rdfs:label 'Ticket Quantity' ;
    rdfs:comment 'Total number of individual tickets included in this order. Used for capacity management, demand forecasting, and per-ticket revenue calculations.' ;
    rdfs:domain ind:Ticketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ticketTier rdf:type rdf:Property ;
    rdfs:label 'Ticket Tier' ;
    rdfs:comment 'Pricing and access tier classification for the tickets in this order. GA (General Admission), VIP (Very Important Person), SRO (Standing Room Only), PREMIUM, SUITE, or ACCESSIBLE. Drives pricing, access control, and fan experience segmentation.' ;
    rdfs:domain ind:TicketOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ticketOrderLineId rdf:type rdf:Property ;
    rdfs:label 'Ticket Order Line Id' ;
    rdfs:comment 'Unique surrogate identifier for a single ticket order line item within the ticketing system. Represents one ticket unit sold within a parent order.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TicketOrderLine .

ind:accessStatus rdf:type rdf:Property ;
    rdfs:label 'Access Status' ;
    rdfs:comment 'The current access control entitlement status for this ticket at the venue. Tracks whether the ticket holder has entered, exited, or been denied entry. Sourced from AXS/Ticketmaster access control scanners.' ;
    rdfs:domain ind:TicketOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:barcode rdf:type rdf:Property ;
    rdfs:label 'Barcode' ;
    rdfs:comment 'The unique barcode or token printed or encoded on the ticket used for access control scanning at venue entry points. May be a traditional barcode, QR code value, or NFC token identifier.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cancelledTimestamp rdf:type rdf:Property ;
    rdfs:label 'Cancelled Timestamp' ;
    rdfs:comment 'The date and time when this ticket order line was cancelled or voided. Populated only when line_status is \'cancelled\' or \'voided\'. Required for refund processing and revenue reversal tracking.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:compReasonCode rdf:type rdf:Property ;
    rdfs:label 'Comp Reason Code' ;
    rdfs:comment 'The reason code explaining why a complimentary ticket was issued. Required for comp ticket audit and financial controls. Only populated when is_comp is True. [ENUM-REF-CANDIDATE: media|sponsor|athlete|staff|promotion|accessibility — promote to reference product]' ;
    rdfs:domain ind:TicketOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveredTimestamp rdf:type rdf:Property ;
    rdfs:label 'Delivered Timestamp' ;
    rdfs:comment 'The date and time when the ticket was successfully delivered to the fan via the specified delivery method. Used for fulfillment SLA tracking and fan experience reporting.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:dynamicPrice rdf:type rdf:Property ;
    rdfs:label 'Dynamic Price' ;
    rdfs:comment 'The actual selling price applied to this ticket after dynamic pricing model adjustments (demand-based, algorithmic, or promotional). May differ from face_value when dynamic pricing is active.' ;
    rdfs:domain ind:TicketOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:externalLineRef rdf:type rdf:Property ;
    rdfs:label 'External Line Ref' ;
    rdfs:comment 'The externally-known line item identifier assigned by the source ticketing system (Ticketmaster/AXS or Archtics). Used for reconciliation with the operational system of record.' ;
    rdfs:domain ind:TicketOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:faceValue rdf:type rdf:Property ;
    rdfs:label 'Face Value' ;
    rdfs:comment 'The printed or base face value of the ticket before any service fees, facility fees, or dynamic pricing adjustments. Used for regulatory reporting, resale market compliance, and revenue attribution.' ;
    rdfs:domain ind:Ticketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:facilityFee rdf:type rdf:Property ;
    rdfs:label 'Facility Fee' ;
    rdfs:comment 'The venue facility fee charged per ticket to fund venue operations, maintenance, and capital improvements. Distinct from the service fee and retained by the venue operator.' ;
    rdfs:domain ind:Ticketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gateEntryPoint rdf:type rdf:Property ;
    rdfs:label 'Gate Entry Point' ;
    rdfs:comment 'The designated gate or entry point at the venue through which the ticket holder is authorized to enter (e.g., \'Gate A\', \'North Entrance\', \'VIP Entrance\'). Supports venue operations and crowd management.' ;
    rdfs:domain ind:TicketOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isComp rdf:type rdf:Property ;
    rdfs:label 'Is Comp' ;
    rdfs:comment 'Indicates whether this ticket was issued as a complimentary (comp) ticket at no charge. Comp tickets require audit tracking for financial controls and league governance compliance.' ;
    rdfs:domain ind:Ticketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isResale rdf:type rdf:Property ;
    rdfs:label 'Is Resale' ;
    rdfs:comment 'Indicates whether this ticket was sold through the secondary/resale marketplace rather than primary sale. Distinguishes primary and secondary market revenue streams for analytics and league reporting.' ;
    rdfs:domain ind:TicketOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:issuedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Issued Timestamp' ;
    rdfs:comment 'The date and time when this ticket order line was created and the ticket was issued in the ticketing system. Represents the principal business event time for this transaction line.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lineNumber rdf:type rdf:Property ;
    rdfs:label 'Line Number' ;
    rdfs:comment 'Sequential position of this ticket line within the parent order, starting at 1. Used for ordering, display, and reconciliation of multi-ticket orders.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lineStatus rdf:type rdf:Property ;
    rdfs:label 'Line Status' ;
    rdfs:comment 'Current lifecycle state of this ticket order line. Drives fulfillment workflows, access control entitlement, and revenue recognition. [ENUM-REF-CANDIDATE: issued|cancelled|refunded|transferred|voided|reissued — promote to reference product]' ;
    rdfs:domain ind:TicketOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineTotal rdf:type rdf:Property ;
    rdfs:label 'Line Total' ;
    rdfs:comment 'The total amount charged for this ticket order line, calculated as dynamic_price + service_fee + facility_fee + tax_amount. Represents the net amount collected from the purchaser for this single ticket unit.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentMethod rdf:type rdf:Property ;
    rdfs:label 'Payment Method' ;
    rdfs:comment 'The payment instrument used to purchase this ticket line (e.g., credit card, digital wallet, voucher). Supports PCI-DSS compliance reporting and payment channel analytics. [ENUM-REF-CANDIDATE: credit_card|debit_card|digital_wallet|cash|voucher|comp — promote to reference product]' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantity rdf:type rdf:Property ;
    rdfs:label 'Quantity' ;
    rdfs:comment 'The number of ticket units represented by this line item. Typically 1 for individually assigned seats; may be greater than 1 for GA (General Admission) or SRO (Standing Room Only) allocations.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:resaleOriginalPrice rdf:type rdf:Property ;
    rdfs:label 'Resale Original Price' ;
    rdfs:comment 'The original face value price at which the ticket was first sold in the primary market, retained for resale margin analysis and league resale policy compliance. Only populated when is_resale is True.' ;
    rdfs:domain ind:TicketOrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:salesChannel rdf:type rdf:Property ;
    rdfs:label 'Sales Channel' ;
    rdfs:comment 'The channel through which this ticket was sold (e.g., online, box office, mobile app, group sales). Supports DTC (Direct-To-Consumer) analytics, channel performance reporting, and fan acquisition cost analysis. [ENUM-REF-CANDIDATE: online|box_office|mobile_app|kiosk|group_sales|resale — promote to reference product]' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scanTimestamp rdf:type rdf:Property ;
    rdfs:label 'Scan Timestamp' ;
    rdfs:comment 'The date and time when the ticket barcode was scanned at the venue access control point. Used for attendance analytics, gate throughput reporting, and security compliance.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:seatNumber rdf:type rdf:Property ;
    rdfs:label 'Seat Number' ;
    rdfs:comment 'The individual seat number within the assigned row and section. Together with seat_section and seat_row, forms the complete seat assignment for access control and fan experience.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seatRow rdf:type rdf:Property ;
    rdfs:label 'Seat Row' ;
    rdfs:comment 'The row designation within the assigned section (e.g., \'A\', \'12\', \'AA\'). Combined with seat_section and seat_number to uniquely identify the physical seat.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seatSection rdf:type rdf:Property ;
    rdfs:label 'Seat Section' ;
    rdfs:comment 'The section designation within the venue where the assigned seat is located (e.g., \'A\', \'101\', \'Lower Bowl\'). Sourced from Archtics seating inventory.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceFee rdf:type rdf:Property ;
    rdfs:label 'Service Fee' ;
    rdfs:comment 'The service/convenience fee charged by the ticketing platform (Ticketmaster/AXS) on top of the face value. A key revenue component for ticketing operations and partner settlement.' ;
    rdfs:domain ind:Ticketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ticketType rdf:type rdf:Property ;
    rdfs:label 'Ticket Type' ;
    rdfs:comment 'Classification of the ticket unit indicating the commercial nature of the sale. Distinguishes single-event tickets, season ticket packages, group sales, complimentary tickets, resale marketplace tickets, and bundled packages. [ENUM-REF-CANDIDATE: single|season|group|comp|resale|package — promote to reference product]' ;
    rdfs:domain ind:Ticketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:typeId rdf:type rdf:Property ;
    rdfs:label 'Type Id' ;
    rdfs:comment 'Reference to the event type (e.g., regular season, playoff, concert, special event) for which this pricing tier applies. Pricing tiers may differ by event type — playoff tiers typically carry higher face values than regular season tiers.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Type .

ind:accessLevel rdf:type rdf:Property ;
    rdfs:label 'Access Level' ;
    rdfs:comment 'Access control level granted by tickets at this tier, determining which venue zones and areas the ticket holder may enter. Mapped to access control zones in Ticketmaster/AXS and venue access control hardware (scanners, turnstiles).' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adaCompliant rdf:type rdf:Property ;
    rdfs:label 'Ada Compliant' ;
    rdfs:comment 'Indicates whether this pricing tier is designated as ADA (Americans with Disabilities Act) accessible seating, meeting federal accessibility requirements for wheelchair spaces, companion seating, and accessible routes. Required for ADA compliance reporting.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dynamicPricingEnabled rdf:type rdf:Property ;
    rdfs:label 'Dynamic Pricing Enabled' ;
    rdfs:comment 'Indicates whether this pricing tier participates in the dynamic pricing engine, allowing face value to fluctuate based on demand, time-to-event, and inventory levels. When True, the face_value represents the base floor price. Integrates with Ticketmaster dynamic pricing module.' ;
    rdfs:domain ind:Ticketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:effectiveFrom rdf:type rdf:Property ;
    rdfs:label 'Effective From' ;
    rdfs:comment 'The date from which this pricing tier configuration is valid and binding. Supports temporal versioning of tier definitions — a tier may be reconfigured for a new season while retaining historical records for prior seasons.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveUntil rdf:type rdf:Property ;
    rdfs:label 'Effective Until' ;
    rdfs:comment 'The date until which this pricing tier configuration remains valid. Null indicates the tier is open-ended with no planned expiry. Used for seasonal pricing tier versioning and historical audit.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eligibilityRule rdf:type rdf:Property ;
    rdfs:label 'Eligibility Rule' ;
    rdfs:comment 'Free-text or structured rule expression defining who is eligible to purchase tickets at this tier (e.g., \'Season ticket holders only\', \'Members with Gold status\', \'Military/First Responder ID required\', \'Age 12 and under\'). Enforced at point of sale in Ticketmaster/AXS.' ;
    rdfs:domain ind:PriceTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalTierCode rdf:type rdf:Property ;
    rdfs:label 'External Tier Code' ;
    rdfs:comment 'The pricing tier identifier as assigned by the external ticketing system of record (Ticketmaster/AXS or Archtics). Used for system integration, reconciliation, and cross-system data lineage. Enables mapping between the internal BIGINT PK and the source system\'s native identifier.' ;
    rdfs:domain ind:PriceTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:includesHospitality rdf:type rdf:Property ;
    rdfs:label 'Includes Hospitality' ;
    rdfs:comment 'Indicates whether hospitality benefits (food and beverage, lounge access, pre-event reception) are bundled with this pricing tier. Applicable to VIP, suite, and premium club tiers. Drives hospitality operations planning.' ;
    rdfs:domain ind:PriceTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:includesMerchandise rdf:type rdf:Property ;
    rdfs:label 'Includes Merchandise' ;
    rdfs:comment 'Indicates whether a merchandise item or voucher (e.g., team jersey, program, gift bag) is bundled with tickets at this pricing tier as part of the package offering.' ;
    rdfs:domain ind:PriceTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:includesParking rdf:type rdf:Property ;
    rdfs:label 'Includes Parking' ;
    rdfs:comment 'Indicates whether a parking pass is bundled with tickets at this pricing tier as part of the ticket package (e.g., VIP and suite tiers often include complimentary parking).' ;
    rdfs:domain ind:Ticketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inventoryClass rdf:type rdf:Property ;
    rdfs:label 'Inventory Class' ;
    rdfs:comment 'Archtics inventory classification that maps this pricing tier to a physical seating inventory class within the venue manifest. Drives seat map allocation and capacity planning in Archtics Venue Seating Inventory system.' ;
    rdfs:domain ind:PriceTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxPrice rdf:type rdf:Property ;
    rdfs:label 'Max Price' ;
    rdfs:comment 'The maximum allowable price for this tier when dynamic pricing is active. The dynamic pricing engine will not price tickets above this ceiling value. Null when dynamic_pricing_enabled is False.' ;
    rdfs:domain ind:PriceTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxTicketsPerOrder rdf:type rdf:Property ;
    rdfs:label 'Max Tickets Per Order' ;
    rdfs:comment 'Maximum number of tickets at this tier that a single fan/customer may purchase in one order transaction. Enforces anti-scalping and fair access policies. Configured in Ticketmaster/AXS order rules.' ;
    rdfs:domain ind:PriceTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:memberExclusive rdf:type rdf:Property ;
    rdfs:label 'Member Exclusive' ;
    rdfs:comment 'Indicates whether this pricing tier is exclusively available to registered members or season ticket holders, restricting general public purchase. Integrates with Salesforce CRM membership validation at checkout.' ;
    rdfs:domain ind:PriceTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:minPrice rdf:type rdf:Property ;
    rdfs:label 'Min Price' ;
    rdfs:comment 'The minimum allowable price for this tier when dynamic pricing is active. The dynamic pricing engine will not price tickets below this floor value. Null when dynamic_pricing_enabled is False.' ;
    rdfs:domain ind:PriceTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minTicketsPerOrder rdf:type rdf:Property ;
    rdfs:label 'Min Tickets Per Order' ;
    rdfs:comment 'Minimum number of tickets at this tier required per order transaction. Primarily applicable to group sales tiers where a minimum group size must be met (e.g., minimum 10 tickets for group pricing).' ;
    rdfs:domain ind:PriceTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:presaleEligible rdf:type rdf:Property ;
    rdfs:label 'Presale Eligible' ;
    rdfs:comment 'Indicates whether tickets at this tier are available during presale windows (e.g., fan club presale, sponsor presale, credit card presale) before general public on-sale. Drives presale campaign configuration in Ticketmaster/AXS.' ;
    rdfs:domain ind:PriceTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priceTierDescription rdf:type rdf:Property ;
    rdfs:label 'Price Tier Description' ;
    rdfs:comment 'Detailed marketing and operational description of the pricing tier, including benefits, inclusions, and eligibility notes. Displayed to fans on the ticketing platform and used by box office staff for customer service.' ;
    rdfs:domain ind:PriceTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceTierStatus rdf:type rdf:Property ;
    rdfs:label 'Price Tier Status' ;
    rdfs:comment 'Current lifecycle state of the pricing tier: active (available for sale), inactive (temporarily unavailable), draft (under configuration, not yet published), archived (retired, historical reference only), suspended (paused pending review). Controls availability in the dynamic pricing engine and order processing.' ;
    rdfs:domain ind:PriceTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueCategory rdf:type rdf:Property ;
    rdfs:label 'Revenue Category' ;
    rdfs:comment 'Financial revenue category classification for this pricing tier used in SAP S/4HANA revenue reporting and Workday Adaptive Planning financial forecasting. Segments ticket revenue streams for EBITDA and ARR (Annual Recurring Revenue) analysis.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:saleEndDate rdf:type rdf:Property ;
    rdfs:label 'Sale End Date' ;
    rdfs:comment 'The date on which tickets at this pricing tier are no longer available for purchase. After this date, the tier is automatically closed in the ticketing system. Null indicates the tier remains on sale until event day.' ;
    rdfs:domain ind:Ticketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:saleStartDate rdf:type rdf:Property ;
    rdfs:label 'Sale Start Date' ;
    rdfs:comment 'The date on which tickets at this pricing tier become available for general public purchase. Used to control on-sale windows in Ticketmaster/AXS and coordinate marketing campaigns.' ;
    rdfs:domain ind:Ticketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:seatingType rdf:type rdf:Property ;
    rdfs:label 'Seating Type' ;
    rdfs:comment 'Physical seating configuration associated with this pricing tier: RESERVED (assigned seat), GENERAL_ADMISSION (first-come seating), STANDING (standing area), SUITE (private suite), BOX (premium box), or ACCESSIBLE (ADA-compliant seating). Determines access control and entry validation logic.' ;
    rdfs:domain ind:PriceTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sortOrder rdf:type rdf:Property ;
    rdfs:label 'Sort Order' ;
    rdfs:comment 'Numeric display sort order for presenting pricing tiers in the correct sequence on ticketing platforms, box office interfaces, and fan-facing purchase flows. Lower values appear first.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:taxRate rdf:type rdf:Property ;
    rdfs:label 'Tax Rate' ;
    rdfs:comment 'Applicable tax rate (as a decimal fraction, e.g., 0.0875 for 8.75%) applied to the face value for this pricing tier, based on the jurisdiction of the venue. Used by the order processing system for tax calculation and SAP S/4HANA tax reporting.' ;
    rdfs:domain ind:PriceTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tierCategory rdf:type rdf:Property ;
    rdfs:label 'Tier Category' ;
    rdfs:comment 'High-level classification of the pricing tier aligned with industry-standard seating categories: GA (General Admission), VIP (Very Important Person), SRO (Standing Room Only), PREMIUM, SUITE, ACCESSIBLE (ADA-compliant), CLUB, or FIELD level. Drives dynamic pricing engine segmentation and reporting. [ENUM-REF-CANDIDATE: GA|VIP|SRO|PREMIUM|SUITE|ACCESSIBLE|CLUB|FIELD — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PriceTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tierCode rdf:type rdf:Property ;
    rdfs:label 'Tier Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying the pricing tier across systems (e.g., GA01, VIP_PLAT, SRO_STD, SUITE_A). Used as the business key in Ticketmaster/AXS and Archtics integrations.' ;
    rdfs:domain ind:PriceTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tierName rdf:type rdf:Property ;
    rdfs:label 'Tier Name' ;
    rdfs:comment 'Human-readable display name for the pricing tier as shown to fans and box office staff (e.g., \'General Admission\', \'VIP Platinum\', \'Standing Room Only\', \'Club Level Premium\').' ;
    rdfs:domain ind:PriceTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tierType rdf:type rdf:Property ;
    rdfs:label 'Tier Type' ;
    rdfs:comment 'Classifies the commercial packaging type of the tier: SINGLE_EVENT (per-event ticket), SEASON_PACKAGE (full season ticket), GROUP_SALES (bulk group purchase), MINI_PLAN (partial season plan), or FLEX_PLAN (flexible game selection plan). Determines eligibility rules and order processing logic.' ;
    rdfs:domain ind:PriceTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calendarId rdf:type rdf:Property ;
    rdfs:label 'Calendar Id' ;
    rdfs:comment 'Foreign key linking to event.event_calendar. Business justification: Season ticket packages are scoped to a season defined in event_calendar, which governs blackout dates, playoff structure, and international windows. Season ticket operations teams use event_calendar t' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Calendar .

ind:loyaltyProgramId rdf:type rdf:Property ;
    rdfs:label 'Loyalty Program Id' ;
    rdfs:comment 'Foreign key linking to fan.loyalty_program. Business justification: STH loyalty points configuration — season_ticket_package.sth_loyalty_points_awarded must reference the loyalty program under which points are issued to correctly apply earning rules, tier qualificatio' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LoyaltyProgram .

ind:primarySeasonFranchiseId rdf:type rdf:Property ;
    rdfs:label 'Primary Season Franchise Id' ;
    rdfs:comment 'Reference to the home team or franchise for which this season ticket package is sold. Determines the event schedule, venue, and STH (Season Ticket Holder) benefit entitlements associated with the package.' ;
    rdfs:domain ind:SeasonTicketPackage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Franchise .

ind:archticsPlanCode rdf:type rdf:Property ;
    rdfs:label 'Archtics Plan Code' ;
    rdfs:comment 'The native plan identifier assigned to this season ticket package in the Archtics venue seating and inventory management system. Used for cross-system reconciliation between the Silver Layer and the operational Archtics source of record.' ;
    rdfs:domain ind:SeasonTicketPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:benefitTier rdf:type rdf:Property ;
    rdfs:label 'Benefit Tier' ;
    rdfs:comment 'The STH (Season Ticket Holder) benefit tier associated with this package, determining the level of perks, exclusive access, merchandise discounts, and concierge services. Drives benefit fulfillment workflows in Salesforce CRM and Adobe Experience Platform personalization.' ;
    rdfs:domain ind:SeasonTicketPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bundleDiscountPct rdf:type rdf:Property ;
    rdfs:label 'Bundle Discount Pct' ;
    rdfs:comment 'The percentage discount applied to the PPV consumer price for this specific season ticket package and PPV package combination. Varies per bundle pairing and cannot reside on either parent product.' ;
    rdfs:domain ind:SeasonTicketPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bundlePrice rdf:type rdf:Property ;
    rdfs:label 'Bundle Price' ;
    rdfs:comment 'The negotiated price charged for this specific PPV package when accessed through the season ticket bundle. Differs from the standalone consumer_price on ppv_package and belongs to this pairing only.' ;
    rdfs:domain ind:SeasonTicketPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:digitalDeliveryMethod rdf:type rdf:Property ;
    rdfs:label 'Digital Delivery Method' ;
    rdfs:comment 'The method by which digital tickets for events in this package are delivered to the STH (Season Ticket Holder). Drives the ticket fulfillment workflow in Ticketmaster/AXS and determines the access control technology used at venue entry points.' ;
    rdfs:domain ind:SeasonTicketPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:includesMerchandiseCredit rdf:type rdf:Property ;
    rdfs:label 'Includes Merchandise Credit' ;
    rdfs:comment 'Indicates whether a merchandise store credit or discount entitlement is bundled with this season ticket package. Triggers integration with Shopify Plus for credit issuance to the STH account.' ;
    rdfs:domain ind:SeasonTicketPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:installmentCount rdf:type rdf:Property ;
    rdfs:label 'Installment Count' ;
    rdfs:comment 'Number of payment installments configured for this package when payment_plan_type is monthly_installment or quarterly_installment. Null for full_upfront plans. Used by SAP FI to generate the accounts receivable schedule.' ;
    rdfs:domain ind:Ticketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inventoryCount rdf:type rdf:Property ;
    rdfs:label 'Inventory Count' ;
    rdfs:comment 'Total number of this season ticket package available for sale in the current season. Represents the maximum allocatable units in Archtics seating inventory. Drives sold_out status transitions.' ;
    rdfs:domain ind:SeasonTicketPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:merchandiseCreditAmount rdf:type rdf:Property ;
    rdfs:label 'Merchandise Credit Amount' ;
    rdfs:comment 'The monetary value of merchandise store credit included in this season ticket package when includes_merchandise_credit is True. Denominated in the package currency_code. Null when includes_merchandise_credit is False.' ;
    rdfs:domain ind:SeasonTicketPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:packageCode rdf:type rdf:Property ;
    rdfs:label 'Package Code' ;
    rdfs:comment 'Externally-known alphanumeric code that uniquely identifies the season ticket package across systems (Archtics, Ticketmaster/AXS, SAP SD). Used as the business key for cross-system reconciliation and fan-facing communications.' ;
    rdfs:domain ind:SeasonTicketPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packageDescription rdf:type rdf:Property ;
    rdfs:label 'Package Description' ;
    rdfs:comment 'Long-form marketing and operational description of the season ticket package, including included events, seat location narrative, and STH benefit highlights. Used in fan-facing communications, CRM campaigns, and the Ticketmaster/AXS product listing.' ;
    rdfs:domain ind:SeasonTicketPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packageName rdf:type rdf:Property ;
    rdfs:label 'Package Name' ;
    rdfs:comment 'Human-readable marketing name of the season ticket package as displayed to fans and used in CRM communications (e.g., \'Full Season Gold Plan\', \'Half-Season Flex Pack\'). Sourced from Salesforce CRM product catalog.' ;
    rdfs:domain ind:SeasonTicketPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packageStatus rdf:type rdf:Property ;
    rdfs:label 'Package Status' ;
    rdfs:comment 'Current lifecycle state of the season ticket package product definition. Active packages are available for sale or renewal; sold_out indicates inventory exhaustion; suspended indicates temporary hold; retired indicates end-of-life for the product definition.' ;
    rdfs:domain ind:SeasonTicketPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentPlanType rdf:type rdf:Property ;
    rdfs:label 'Payment Plan Type' ;
    rdfs:comment 'The payment schedule configuration available for this season ticket package. Determines how the face value is collected from the STH (Season Ticket Holder) — either as a single upfront payment or spread across installment periods. Drives SAP FI accounts receivable scheduling.' ;
    rdfs:domain ind:Ticketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalDeadlineDate rdf:type rdf:Property ;
    rdfs:label 'Renewal Deadline Date' ;
    rdfs:comment 'The date by which an existing STH (Season Ticket Holder) must exercise their renewal right for this package before it is released to the general waitlist. Drives CRM renewal campaign scheduling in Salesforce.' ;
    rdfs:domain ind:Ticketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:renewalPriorityRank rdf:type rdf:Property ;
    rdfs:label 'Renewal Priority Rank' ;
    rdfs:comment 'Numeric rank determining the STH (Season Ticket Holder) renewal priority order for this package tier. Lower values indicate higher priority (e.g., rank 1 = first right of renewal). Critical for managing the annual renewal window and STH retention strategy.' ;
    rdfs:domain ind:SeasonTicketPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sapMaterialNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Material Number' ;
    rdfs:comment 'The SAP S/4HANA MM material number assigned to this season ticket package as a sellable product in the ERP system. Enables financial posting, revenue recognition, and SD order management alignment.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seatQuantity rdf:type rdf:Property ;
    rdfs:label 'Seat Quantity' ;
    rdfs:comment 'Number of seats included in this season ticket package definition. Typically 1 for individual packages; higher values for group plans or suite packages. Drives inventory allocation in Archtics.' ;
    rdfs:domain ind:SeasonTicketPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:soldCount rdf:type rdf:Property ;
    rdfs:label 'Sold Count' ;
    rdfs:comment 'Number of this season ticket package units that have been sold or confirmed for the current season. Used for inventory tracking, revenue forecasting in Workday Adaptive Planning, and sold_out threshold monitoring.' ;
    rdfs:domain ind:SeasonTicketPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sthLoyaltyPointsAwarded rdf:type rdf:Property ;
    rdfs:label 'Sth Loyalty Points Awarded' ;
    rdfs:comment 'Number of fan loyalty points awarded to the STH (Season Ticket Holder) upon purchase or renewal of this package. Feeds into the fan engagement and NPS (Net Promoter Score) program managed via Adobe Experience Platform.' ;
    rdfs:domain ind:SeasonTicketPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:termsAndConditionsVersion rdf:type rdf:Property ;
    rdfs:label 'Terms And Conditions Version' ;
    rdfs:comment 'Version identifier of the legal terms and conditions governing this season ticket package (e.g., \'v2.1\'). Required for GDPR, CCPA, and SOX compliance to ensure the correct contractual terms are associated with each package sold.' ;
    rdfs:domain ind:SeasonTicketPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalEventCount rdf:type rdf:Property ;
    rdfs:label 'Total Event Count' ;
    rdfs:comment 'Total number of home events (games, matches, or performances) included in this season ticket package. Defines the scope of the package and is used to calculate per-event cost for fan communications and analytics.' ;
    rdfs:domain ind:SeasonTicketPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:transferable rdf:type rdf:Property ;
    rdfs:label 'Transferable' ;
    rdfs:comment 'Indicates whether the STH (Season Ticket Holder) may transfer individual game tickets within this package to another person via the Ticketmaster/AXS platform. Distinct from resale eligibility — transfer is a non-commercial action.' ;
    rdfs:domain ind:SeasonTicketPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:waitlistEligible rdf:type rdf:Property ;
    rdfs:label 'Waitlist Eligible' ;
    rdfs:comment 'Indicates whether fans can join a waitlist for this season ticket package when it is sold out. Drives the waitlist management workflow in Salesforce CRM and Archtics inventory management.' ;
    rdfs:domain ind:SeasonTicketPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fanAccountId rdf:type rdf:Property ;
    rdfs:label 'Fan Account Id' ;
    rdfs:comment 'Reference to the fan/customer account that holds this season ticket agreement. Links the season ticket account to the fan master record in the CRM system.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Account .

ind:accountBalance rdf:type rdf:Property ;
    rdfs:label 'Account Balance' ;
    rdfs:comment 'Current outstanding balance on the season ticket account. Positive value indicates amount owed by the fan; negative value indicates a credit. Sourced from SAP S/4HANA AR sub-ledger.' ;
    rdfs:domain ind:SeasonTicketAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:accountNumber rdf:type rdf:Property ;
    rdfs:label 'Account Number' ;
    rdfs:comment 'Externally-known alphanumeric account number assigned to the season ticket holder (STH) by the ticketing system (Archtics/Ticketmaster). Used in all fan-facing communications, invoices, and access control lookups. Satisfies MASTER_AGREEMENT BUSINESS_IDENTIFIER category.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountStatus rdf:type rdf:Property ;
    rdfs:label 'Account Status' ;
    rdfs:comment 'Current lifecycle state of the season ticket account. Drives access control, renewal workflows, and CRM segmentation. Satisfies MASTER_AGREEMENT LIFECYCLE_STATUS category.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountType rdf:type rdf:Property ;
    rdfs:label 'Account Type' ;
    rdfs:comment 'Classification of the season ticket account by holder category. Drives pricing eligibility, tax treatment, and benefit entitlements. Satisfies MASTER_AGREEMENT CLASSIFICATION_OR_TYPE category.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adaAccommodation rdf:type rdf:Property ;
    rdfs:label 'Ada Accommodation' ;
    rdfs:comment 'Indicates whether the season ticket account has an Americans with Disabilities Act (ADA) accessibility accommodation on record, such as wheelchair-accessible seating or companion seat requirements.' ;
    rdfs:domain ind:SeasonTicketAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:communicationPreference rdf:type rdf:Property ;
    rdfs:label 'Communication Preference' ;
    rdfs:comment 'Preferred communication channel for season ticket account notifications, renewal reminders, and promotional messages. Drives outbound campaign routing in Salesforce CRM and Adobe Experience Platform.' ;
    rdfs:domain ind:SeasonTicketAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentDate rdf:type rdf:Property ;
    rdfs:label 'Enrollment Date' ;
    rdfs:comment 'Calendar date on which the fan formally enrolled in the season ticket package. Marks the start of the contractual relationship. Satisfies MASTER_AGREEMENT EFFECTIVE_FROM category.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:expirationDate rdf:type rdf:Property ;
    rdfs:label 'Expiration Date' ;
    rdfs:comment 'Calendar date on which the season ticket account expires or the current season package ends. Null for multi-year rolling agreements. Satisfies MASTER_AGREEMENT EFFECTIVE_UNTIL category.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:forwardTicketOptIn rdf:type rdf:Property ;
    rdfs:label 'Forward Ticket Opt In' ;
    rdfs:comment 'Indicates whether the season ticket holder has enabled the ticket forwarding feature, allowing them to digitally transfer individual game tickets to guests via the Ticketmaster/AXS platform.' ;
    rdfs:domain ind:SeasonTicketAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastNpsSurveyDate rdf:type rdf:Property ;
    rdfs:label 'Last Nps Survey Date' ;
    rdfs:comment 'Date on which the most recent Net Promoter Score (NPS) survey was completed by the season ticket holder. Used to control survey frequency and track sentiment trends over time.' ;
    rdfs:domain ind:SeasonTicketAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:marketingOptIn rdf:type rdf:Property ;
    rdfs:label 'Marketing Opt In' ;
    rdfs:comment 'Indicates whether the season ticket holder has provided consent to receive marketing communications from the organization. Required for GDPR and CCPA compliance.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:netPackageAmount rdf:type rdf:Property ;
    rdfs:label 'Net Package Amount' ;
    rdfs:comment 'Net amount payable for the season ticket package after all discounts are applied (face_value_amount minus discount_amount). Represents the contractual obligation amount. Satisfies MONETARY_TRIPLET net-total component.' ;
    rdfs:domain ind:SeasonTicketAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nextPaymentDate rdf:type rdf:Property ;
    rdfs:label 'Next Payment Date' ;
    rdfs:comment 'Date on which the next scheduled payment is due for this season ticket account. Used to trigger payment reminders and auto-payment processing.' ;
    rdfs:domain ind:SeasonTicketAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:npsScore rdf:type rdf:Property ;
    rdfs:label 'Nps Score' ;
    rdfs:comment 'Most recent Net Promoter Score (NPS) survey response from the season ticket holder, on a scale of 0–10. Used to segment promoters, passives, and detractors for retention and experience improvement programs.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parkingIncluded rdf:type rdf:Property ;
    rdfs:label 'Parking Included' ;
    rdfs:comment 'Indicates whether the season ticket package includes a parking pass entitlement for home events at the venue.' ;
    rdfs:domain ind:SeasonTicketAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:parkingZone rdf:type rdf:Property ;
    rdfs:label 'Parking Zone' ;
    rdfs:comment 'Designated parking zone or lot code assigned to this season ticket account when parking is included in the package (e.g., \'LOT-A\', \'GARAGE-2\', \'VIP-NORTH\').' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentPlanStatus rdf:type rdf:Property ;
    rdfs:label 'Payment Plan Status' ;
    rdfs:comment 'Current status of the payment plan for this season ticket account. Drives collections workflows, account suspension triggers, and financial reporting.' ;
    rdfs:domain ind:SeasonTicketAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalStatus rdf:type rdf:Property ;
    rdfs:label 'Renewal Status' ;
    rdfs:comment 'Current renewal decision status for the upcoming season. Tracks whether the season ticket holder (STH) has committed to renewing, declined, or is pending a decision. Critical for revenue forecasting and retention campaigns.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resaleOptIn rdf:type rdf:Property ;
    rdfs:label 'Resale Opt In' ;
    rdfs:comment 'Indicates whether the season ticket holder has opted into the official resale marketplace program, allowing unused tickets to be listed for resale through the organization\'s authorized platform.' ;
    rdfs:domain ind:SeasonTicketAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rowCode rdf:type rdf:Property ;
    rdfs:label 'Row Code' ;
    rdfs:comment 'Row identifier within the assigned section for the season ticket seats (e.g., \'A\', \'B\', \'12\'). Used for access control and seat map display.' ;
    rdfs:domain ind:SeasonTicketAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seatCount rdf:type rdf:Property ;
    rdfs:label 'Seat Count' ;
    rdfs:comment 'Total number of seats assigned to this season ticket account. A single account may hold multiple contiguous or non-contiguous seats.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:seatNumbers rdf:type rdf:Property ;
    rdfs:label 'Seat Numbers' ;
    rdfs:comment 'Comma-separated list of seat numbers within the assigned row for this account (e.g., \'5,6,7\'). Stored as a delimited string since seat assignments are managed atomically at the account level in Archtics.' ;
    rdfs:domain ind:SeasonTicketAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sectionCode rdf:type rdf:Property ;
    rdfs:label 'Section Code' ;
    rdfs:comment 'Alphanumeric code identifying the venue section where the season ticket seats are located (e.g., \'101\', \'CLUB-A\', \'SUITE-12\'). Sourced from Archtics seating inventory.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemAccountRef rdf:type rdf:Property ;
    rdfs:label 'Source System Account Ref' ;
    rdfs:comment 'Native account identifier from the originating operational system (Archtics or Ticketmaster/AXS) used for reconciliation and lineage tracing between the Silver Layer and the system of record.' ;
    rdfs:domain ind:SeasonTicketAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tenureYears rdf:type rdf:Property ;
    rdfs:label 'Tenure Years' ;
    rdfs:comment 'Number of consecutive seasons the fan has held a season ticket account with the organization. Used to calculate STH loyalty tier eligibility and long-term retention metrics.' ;
    rdfs:domain ind:SeasonTicketAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ticketDeliveryMethod rdf:type rdf:Property ;
    rdfs:label 'Ticket Delivery Method' ;
    rdfs:comment 'Preferred method for delivering season tickets to the holder. Determines fulfillment channel and associated costs.' ;
    rdfs:domain ind:Ticketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryGroupEventFixtureId rdf:type rdf:Property ;
    rdfs:label 'Primary Group Event Fixture Id' ;
    rdfs:comment 'Reference to the specific event for which the group ticket sale is being processed. Links to the event master record.' ;
    rdfs:domain ind:GroupSale ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Fixture .

ind:approvalDate rdf:type rdf:Property ;
    rdfs:label 'Approval Date' ;
    rdfs:comment 'The date on which the pricing authority approval was granted for this group sale. Null if approval was not required or is still pending.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:approvedBy rdf:type rdf:Property ;
    rdfs:label 'Approved By' ;
    rdfs:comment 'Name or identifier of the pricing authority manager who approved the group sale discount rate. Null if approval was not required.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cancellationDate rdf:type rdf:Property ;
    rdfs:label 'Cancellation Date' ;
    rdfs:comment 'The date on which the group sale was cancelled, if applicable. Null for active or fulfilled sales. Triggers refund and inventory release workflows.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cateringAmount rdf:type rdf:Property ;
    rdfs:label 'Catering Amount' ;
    rdfs:comment 'The monetary value of catering and food and beverage services included in or added to the group sale. Null if catering_included is false.' ;
    rdfs:domain ind:GroupSale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cateringIncluded rdf:type rdf:Property ;
    rdfs:label 'Catering Included' ;
    rdfs:comment 'Indicates whether a catering or food and beverage add-on is included as part of the group sale package. Triggers catering coordination workflow with venue operations.' ;
    rdfs:domain ind:GroupSale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:coordinatorEmail rdf:type rdf:Property ;
    rdfs:label 'Coordinator Email' ;
    rdfs:comment 'Primary email address of the group coordinator used for booking confirmations, ticket delivery, and event-day communications.' ;
    rdfs:domain ind:GroupSale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coordinatorName rdf:type rdf:Property ;
    rdfs:label 'Coordinator Name' ;
    rdfs:comment 'Full name of the primary contact person at the purchasing organization who is responsible for coordinating the group experience on the day of the event.' ;
    rdfs:domain ind:GroupSale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coordinatorPhone rdf:type rdf:Property ;
    rdfs:label 'Coordinator Phone' ;
    rdfs:comment 'Primary phone number of the group coordinator for day-of-event logistics, access control, and urgent communications.' ;
    rdfs:domain ind:GroupSale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:depositAmount rdf:type rdf:Property ;
    rdfs:label 'Deposit Amount' ;
    rdfs:comment 'The initial deposit amount required to confirm and hold the group ticket block. Typically a percentage of the net_amount per group sales policy.' ;
    rdfs:domain ind:GroupSale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:depositDueDate rdf:type rdf:Property ;
    rdfs:label 'Deposit Due Date' ;
    rdfs:comment 'The date by which the deposit payment must be received to maintain the group ticket block reservation. Expiry triggers automatic release of inventory.' ;
    rdfs:domain ind:GroupSale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:depositReceivedDate rdf:type rdf:Property ;
    rdfs:label 'Deposit Received Date' ;
    rdfs:comment 'The actual date on which the deposit payment was received and confirmed. Null if deposit has not yet been received.' ;
    rdfs:domain ind:GroupSale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:discountRate rdf:type rdf:Property ;
    rdfs:label 'Discount Rate' ;
    rdfs:comment 'The percentage discount applied to the face value price for this group sale, expressed as a decimal (e.g., 0.15 = 15%). Governed by group pricing authority tiers.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:faceValuePrice rdf:type rdf:Property ;
    rdfs:label 'Face Value Price' ;
    rdfs:comment 'The standard published per-ticket face value price before any group discount is applied. Used as the baseline for discount calculation and revenue reporting.' ;
    rdfs:domain ind:GroupSale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:finalPaymentDueDate rdf:type rdf:Property ;
    rdfs:label 'Final Payment Due Date' ;
    rdfs:comment 'The date by which the remaining balance (net_amount minus deposit_amount) must be paid in full. Typically set relative to the event date per group sales policy.' ;
    rdfs:domain ind:GroupSale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:finalPaymentReceivedDate rdf:type rdf:Property ;
    rdfs:label 'Final Payment Received Date' ;
    rdfs:comment 'The actual date on which the final balance payment was received and confirmed, completing the payment obligation for the group sale.' ;
    rdfs:domain ind:GroupSale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fulfillmentDate rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Date' ;
    rdfs:comment 'The date on which ticket fulfillment was completed and all tickets were successfully delivered to the group coordinator.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fulfillmentStatus rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Status' ;
    rdfs:comment 'Current status of the ticket fulfillment process, tracking whether tickets have been issued and delivered to the group coordinator or attendees.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grossAmount rdf:type rdf:Property ;
    rdfs:label 'Gross Amount' ;
    rdfs:comment 'Total gross revenue for the group sale before taxes and fees, calculated as negotiated_price multiplied by ticket_quantity. Represents the top-line transaction value.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:groupName rdf:type rdf:Property ;
    rdfs:label 'Group Name' ;
    rdfs:comment 'The name of the purchasing group or organization (e.g., \'Acme Corp Corporate Outing\', \'Lincoln Elementary School Field Trip\', \'Birthday Party - Smith Family\'). Used for fulfillment, signage, and hospitality coordination.' ;
    rdfs:domain ind:GroupSale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:groupType rdf:type rdf:Property ;
    rdfs:label 'Group Type' ;
    rdfs:comment 'Classification of the purchasing group by organizational category, used for pricing authority, package eligibility, and reporting segmentation. [ENUM-REF-CANDIDATE: corporate|school|community_org|birthday_party|suite_buyout|military|nonprofit|other — promote to reference product]' ;
    rdfs:domain ind:GroupSale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hospitalityPackageCode rdf:type rdf:Property ;
    rdfs:label 'Hospitality Package Code' ;
    rdfs:comment 'Code identifying the group experience or hospitality package selected (e.g., pre-game buffet, suite catering, meet-and-greet, field access). References the hospitality package catalog.' ;
    rdfs:domain ind:GroupSale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:negotiatedPrice rdf:type rdf:Property ;
    rdfs:label 'Negotiated Price' ;
    rdfs:comment 'The agreed per-ticket price after group discount negotiation. Requires pricing authority approval when below standard group floor price.' ;
    rdfs:domain ind:GroupSale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netAmount rdf:type rdf:Property ;
    rdfs:label 'Net Amount' ;
    rdfs:comment 'Total net amount due from the organizational buyer including gross amount, taxes, and service fees. This is the final invoice total for the group sale.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:saleDate rdf:type rdf:Property ;
    rdfs:label 'Sale Date' ;
    rdfs:comment 'The calendar date on which the group sale agreement was formally executed and confirmed by the organizational buyer.' ;
    rdfs:domain ind:GroupSale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:saleNumber rdf:type rdf:Property ;
    rdfs:label 'Sale Number' ;
    rdfs:comment 'Externally-visible, human-readable reference number for the group sale transaction used in customer communications, invoices, and fulfillment workflows. Format: GRP-YYYY-NNNNNN.' ;
    rdfs:domain ind:GroupSale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:saleStatus rdf:type rdf:Property ;
    rdfs:label 'Sale Status' ;
    rdfs:comment 'Current lifecycle state of the group sale transaction, tracking progression from initial inquiry through fulfillment. [ENUM-REF-CANDIDATE: draft|pending_approval|confirmed|deposit_received|paid|fulfilled|cancelled — promote to reference product]' ;
    rdfs:domain ind:GroupSale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seatingRow rdf:type rdf:Property ;
    rdfs:label 'Seating Row' ;
    rdfs:comment 'The row designation within the assigned seating section for the group block (e.g., \'A\', \'B\', \'12\'). Null for GA or SRO allocations.' ;
    rdfs:domain ind:GroupSale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resaleId rdf:type rdf:Property ;
    rdfs:label 'Resale Id' ;
    rdfs:comment 'Primary key for resale' ;
    rdfs:domain ind:Resale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:buyerTicketOrderId rdf:type rdf:Property ;
    rdfs:label 'Buyer Ticket Order Id' ;
    rdfs:comment 'Foreign key linking to ticketing.ticket_order. Business justification: When a resale transaction completes, a new ticket_order is generated for the buyer. The resale record should reference this new buyer order (buyer_ticket_order_id → ticket_order.ticket_order_id) to cl' ;
    rdfs:domain ind:Resale ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TicketOrder .

ind:obligationId rdf:type rdf:Property ;
    rdfs:label 'Obligation Id' ;
    rdfs:comment 'Foreign key linking to compliance.obligation. Business justification: Resale transactions must comply with specific regulatory obligations (anti-scalping laws, consumer protection statutes). resale has anti_scalping_rule_code. Linking each resale to its governing obliga' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Obligation .

ind:originalAccessEntitlementId rdf:type rdf:Property ;
    rdfs:label 'Original Access Entitlement Id' ;
    rdfs:comment 'Foreign key linking to ticketing.access_entitlement. Business justification: A resale transaction invalidates the original access entitlement and triggers issuance of a new one. Linking resale to the original access_entitlement via original_access_entitlement_id enables full l' ;
    rdfs:domain ind:Resale ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AccessEntitlement .

ind:originalTicketOrderLineId rdf:type rdf:Property ;
    rdfs:label 'Original Ticket Order Line Id' ;
    rdfs:comment 'Foreign key linking to ticketing.ticket_order_line. Business justification: A resale transaction originates from a specific ticket that was originally purchased as a line item in a ticket order. Linking resale to the original ticket_order_line via original_ticket_order_line_i' ;
    rdfs:domain ind:Resale ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TicketOrderLine .

ind:resaleBuyerFanFanProfileId rdf:type rdf:Property ;
    rdfs:label 'Resale Buyer Fan Fan Profile Id' ;
    rdfs:comment 'Reference to the fan/account record of the individual who purchased or received the resale ticket. Populated upon transaction completion or transfer acceptance.' ;
    rdfs:domain ind:Resale ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FanProfile .

ind:resaleEventFixtureId rdf:type rdf:Property ;
    rdfs:label 'Resale Event Fixture Id' ;
    rdfs:comment 'Reference to the event for which the resale ticket is valid. Used for event-level resale volume reporting and anti-scalping rule enforcement.' ;
    rdfs:domain ind:Resale ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Fixture .

ind:resaleFanProfileId rdf:type rdf:Property ;
    rdfs:label 'Resale Fan Profile Id' ;
    rdfs:comment 'Reference to the fan/account record of the individual or entity listing the ticket for resale or transfer. Used for seller identity verification and anti-scalping compliance.' ;
    rdfs:domain ind:Resale ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FanProfile .

ind:resaleFixtureId rdf:type rdf:Property ;
    rdfs:label 'Resale Fixture Id' ;
    rdfs:comment 'Reference to the event for which the resale ticket is valid. Used for event-level resale volume reporting and anti-scalping rule enforcement.' ;
    rdfs:domain ind:Resale ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Fixture .

ind:resaleOriginalTicketTicketInventoryId rdf:type rdf:Property ;
    rdfs:label 'Resale Original Ticket Ticket Inventory Id' ;
    rdfs:comment 'Reference to the primary market ticket record from which this resale lifecycle originated. Links the secondary market activity back to the original ticketing entitlement.' ;
    rdfs:domain ind:Resale ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TicketInventory .

ind:resaleTicketInventoryId rdf:type rdf:Property ;
    rdfs:label 'Resale Ticket Inventory Id' ;
    rdfs:comment 'Reference to the primary market ticket record from which this resale lifecycle originated. Links the secondary market activity back to the original ticketing entitlement.' ;
    rdfs:domain ind:Resale ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TicketInventory .

ind:antiScalpingCompliant rdf:type rdf:Property ;
    rdfs:label 'Anti Scalping Compliant' ;
    rdfs:comment 'Indicates whether the resale transaction complies with applicable anti-scalping rules (e.g., price cap relative to face value, seller type restrictions, event-specific resale windows). True = compliant; False = violation flagged for review.' ;
    rdfs:domain ind:Resale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:antiScalpingRuleCode rdf:type rdf:Property ;
    rdfs:label 'Anti Scalping Rule Code' ;
    rdfs:comment 'The specific anti-scalping rule or policy code applied to evaluate this transaction (e.g., \'PRICE_CAP_150PCT\', \'STH_ONLY_RESALE\', \'BLACKOUT_WINDOW\'). Populated when anti_scalping_compliant is False to identify the violated rule.' ;
    rdfs:domain ind:Resale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dynamicPricingApplied rdf:type rdf:Property ;
    rdfs:label 'Dynamic Pricing Applied' ;
    rdfs:comment 'Indicates whether the marketplace applied dynamic pricing algorithms to adjust the listing price during the active listing period. True = dynamic pricing was applied; False = static listing price maintained.' ;
    rdfs:domain ind:Resale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gdprConsentVerified rdf:type rdf:Property ;
    rdfs:label 'Gdpr Consent Verified' ;
    rdfs:comment 'Indicates whether the seller\'s and buyer\'s GDPR data processing consent has been verified prior to processing the resale transaction. Mandatory for EU-market transactions. True = consent verified; False = consent not confirmed.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:listingCreatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Listing Created Timestamp' ;
    rdfs:comment 'The date and time when the seller created the resale listing on the marketplace platform. Represents the start of the resale lifecycle. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:Resale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:listingExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Listing Expiry Date' ;
    rdfs:comment 'The date on which the resale listing automatically expires if not sold or withdrawn. Typically set to the event date. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:Resale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:listingPrice rdf:type rdf:Property ;
    rdfs:label 'Listing Price' ;
    rdfs:comment 'The asking price set by the seller at the time of listing creation, in the transaction currency. Represents the gross amount the buyer is expected to pay before marketplace fees.' ;
    rdfs:domain ind:Resale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:listingReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Listing Reference Number' ;
    rdfs:comment 'Externally visible alphanumeric identifier assigned to the resale listing by the marketplace platform (e.g., Ticketmaster Fan-to-Fan, AXS Marketplace). Used by sellers and buyers to reference a specific listing.' ;
    rdfs:domain ind:Resale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:movementType rdf:type rdf:Property ;
    rdfs:label 'Movement Type' ;
    rdfs:comment 'Classifies the nature of the secondary market activity: resale (commercial sale at a price), gift_transfer (no-cost transfer to another fan), forward_transfer (ticket forwarded to another account), peer_to_peer (direct fan-to-fan exchange outside marketplace).' ;
    rdfs:domain ind:Resale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:newEntitlementToken rdf:type rdf:Property ;
    rdfs:label 'New Entitlement Token' ;
    rdfs:comment 'The new digital access token or barcode issued to the buyer/recipient upon completion of the resale or transfer. Replaces the original ticket token and is used for venue access control via Ticketmaster/AXS or Archtics.' ;
    rdfs:domain ind:Ticketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalEntitlementToken rdf:type rdf:Property ;
    rdfs:label 'Original Entitlement Token' ;
    rdfs:comment 'The digital access token or barcode of the original ticket that was invalidated upon resale or transfer. Retained for audit trail and anti-fraud verification purposes.' ;
    rdfs:domain ind:Ticketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalFaceValue rdf:type rdf:Property ;
    rdfs:label 'Original Face Value' ;
    rdfs:comment 'The primary market face value of the ticket at the time of original purchase. Used to calculate price uplift, anti-scalping cap compliance, and revenue share calculations.' ;
    rdfs:domain ind:Resale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:platformFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Platform Fee Amount' ;
    rdfs:comment 'The fee charged by the marketplace platform (e.g., Ticketmaster, AXS) for facilitating the resale transaction. Deducted from the sale price before calculating seller proceeds.' ;
    rdfs:domain ind:Resale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceUpliftPct rdf:type rdf:Property ;
    rdfs:label 'Price Uplift Pct' ;
    rdfs:comment 'The percentage by which the sale_price exceeds the original_face_value, calculated as ((sale_price - original_face_value) / original_face_value) * 100. Used for anti-scalping compliance monitoring and dynamic pricing analytics.' ;
    rdfs:domain ind:Resale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revenueShareAmount rdf:type rdf:Property ;
    rdfs:label 'Revenue Share Amount' ;
    rdfs:comment 'The portion of the resale sale price allocated back to the league, team, or rights holder per the applicable revenue share agreement. Calculated based on revenue_share_rate applied to the sale price.' ;
    rdfs:domain ind:Resale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revenueShareRate rdf:type rdf:Property ;
    rdfs:label 'Revenue Share Rate' ;
    rdfs:comment 'The contractual percentage rate (expressed as a decimal, e.g., 0.0500 = 5%) applied to the sale price to calculate the revenue_share_amount owed to the rights holder. Sourced from the applicable league or team revenue share agreement.' ;
    rdfs:domain ind:Resale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:salePrice rdf:type rdf:Property ;
    rdfs:label 'Sale Price' ;
    rdfs:comment 'The final price at which the ticket was sold on the secondary market. May differ from listing_price due to dynamic pricing adjustments or negotiated changes. Populated only when lifecycle_status is \'sold\'.' ;
    rdfs:domain ind:Resale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sellerProceeds rdf:type rdf:Property ;
    rdfs:label 'Seller Proceeds' ;
    rdfs:comment 'Net amount remitted to the seller after deducting platform fees and any applicable revenue share from the sale price. Represents the seller\'s actual payout for the transaction.' ;
    rdfs:domain ind:Resale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sellerType rdf:type rdf:Property ;
    rdfs:label 'Seller Type' ;
    rdfs:comment 'Classification of the seller entity: season_ticket_holder (STH reselling allocated seats), individual_fan (casual reseller), broker (licensed ticket broker), corporate_account (business account holder). Drives anti-scalping rule applicability and revenue share tiers.' ;
    rdfs:domain ind:Resale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemListingCode rdf:type rdf:Property ;
    rdfs:label 'Source System Listing Code' ;
    rdfs:comment 'The native listing identifier from the originating marketplace system (Ticketmaster, AXS, or other platform). Enables reconciliation between the Silver layer resale record and the operational source system record.' ;
    rdfs:domain ind:Resale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Transaction Timestamp' ;
    rdfs:comment 'The date and time when the resale transaction was executed (purchase completed or transfer accepted). This is the principal business event timestamp for sold and transferred records. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:transferRestrictionFlag rdf:type rdf:Property ;
    rdfs:label 'Transfer Restriction Flag' ;
    rdfs:comment 'Indicates whether the original ticket carried a transfer restriction (e.g., non-transferable VIP package, restricted season ticket). True = transfer restrictions applied; False = no restrictions. Used to validate eligibility for resale or transfer.' ;
    rdfs:domain ind:Resale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:transferTimestamp rdf:type rdf:Property ;
    rdfs:label 'Transfer Timestamp' ;
    rdfs:comment 'The date and time when a peer-to-peer ticket transfer (gift or forward) was completed and the new entitlement was issued to the recipient. Distinct from transaction_timestamp which applies to commercial sales. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:Resale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:accessEntitlementId rdf:type rdf:Property ;
    rdfs:label 'Access Entitlement Id' ;
    rdfs:comment 'Unique surrogate identifier for the digital access entitlement record. Primary key for the access_entitlement data product in the ticketing domain. SSOT for access control decisions at the gate.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AccessEntitlement .

ind:beneficiaryAthleteProfileId rdf:type rdf:Property ;
    rdfs:label 'Beneficiary Athlete Profile Id' ;
    rdfs:comment 'Foreign key linking to athlete.athlete_profile. Business justification: Access entitlements issued as player allotment tickets must be traceable to the beneficiary athlete for CBA compliance, credential audits, and revocation workflows (e.g., suspension triggers allotment' ;
    rdfs:domain ind:AccessEntitlement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AthleteProfile .

ind:companionEntitlementId rdf:type rdf:Property ;
    rdfs:label 'Companion Entitlement Id' ;
    rdfs:comment 'Reference to a linked companion entitlement for ADA accessible seating, where a companion seat is paired with an accessible seat. Null if no companion pairing exists. Supports ADA compliance and seating management.' ;
    rdfs:domain ind:AccessEntitlement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AccessEntitlement .

ind:credentialId rdf:type rdf:Property ;
    rdfs:label 'Credential Id' ;
    rdfs:comment 'Foreign key linking to security.credential. Business justification: VIP/field-access dual-validation: high-tier entitlements (hospitality, field passes, backstage) require a physical security credential issued by accreditation. Ticketing access control systems must re' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Credential .

ind:loyaltyEnrollmentId rdf:type rdf:Property ;
    rdfs:label 'Loyalty Enrollment Id' ;
    rdfs:comment 'Foreign key linking to fan.loyalty_enrollment. Business justification: Loyalty point redemption audit requires linking access entitlements granted via loyalty redemption to the specific enrollment record. Enables redemption fulfillment tracking, points deduction reconcil' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LoyaltyEnrollment .

ind:primaryAccessEventFixtureId rdf:type rdf:Property ;
    rdfs:label 'Primary Access Event Fixture Id' ;
    rdfs:comment 'Reference to the specific event for which this entitlement grants access. Links the entitlement to the event scheduling and operations domain.' ;
    rdfs:domain ind:AccessEntitlement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Fixture .

ind:primaryAccessFanProfileId rdf:type rdf:Property ;
    rdfs:label 'Primary Access Fan Profile Id' ;
    rdfs:comment 'Reference to the fan (ticket holder) who holds this entitlement. Identifies the individual granted access rights for the event. Used for CRM integration and fan engagement analytics.' ;
    rdfs:domain ind:AccessEntitlement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FanProfile .

ind:primaryAccessTicketInventoryId rdf:type rdf:Property ;
    rdfs:label 'Primary Access Ticket Inventory Id' ;
    rdfs:comment 'Reference to the parent ticket record from which this entitlement was generated. Links the entitlement to the originating ticket purchase or transfer transaction.' ;
    rdfs:domain ind:AccessEntitlement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TicketInventory .

ind:tertiaryAccessOriginalFanFanProfileId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Access Original Fan Fan Profile Id' ;
    rdfs:comment 'Reference to the fan who originally purchased this entitlement before any transfers occurred. Null if no transfer has taken place. Used for season ticket holder analytics and NIL (Name Image and Likeness) attribution.' ;
    rdfs:domain ind:AccessEntitlement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FanProfile .

ind:admissionType rdf:type rdf:Property ;
    rdfs:label 'Admission Type' ;
    rdfs:comment 'Defines the re-entry policy for this entitlement. SINGLE_USE = one-time entry only; MULTI_USE = multiple entries permitted (e.g., festival passes); RE_ENTRY = exit and re-entry allowed within the validity window.' ;
    rdfs:domain ind:AccessEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ageRestrictionFlag rdf:type rdf:Property ;
    rdfs:label 'Age Restriction Flag' ;
    rdfs:comment 'Indicates whether this entitlement is subject to an age restriction requirement (e.g., 18+ or 21+ events). Gate staff must verify age documentation when this flag is true.' ;
    rdfs:domain ind:AccessEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:entitlementNotes rdf:type rdf:Property ;
    rdfs:label 'Entitlement Notes' ;
    rdfs:comment 'Free-text operational notes associated with this entitlement, such as special access instructions, VIP hospitality details, or box office agent comments. Used by venue operations staff.' ;
    rdfs:domain ind:AccessEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entitlementStatus rdf:type rdf:Property ;
    rdfs:label 'Entitlement Status' ;
    rdfs:comment 'Current lifecycle state of the access entitlement. VALID = active and unused; USED = scanned and admitted; VOIDED = cancelled or invalidated; TRANSFERRED = ownership transferred to another fan; EXPIRED = validity window passed without use; SUSPENDED = temporarily blocked pending review.' ;
    rdfs:domain ind:AccessEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entitlementToken rdf:type rdf:Property ;
    rdfs:label 'Entitlement Token' ;
    rdfs:comment 'The unique cryptographic token (barcode, QR code, or NFC credential value) used for physical gate access validation. This is the machine-readable credential presented at the access control point. Classified confidential as it is the operative access credential.' ;
    rdfs:domain ind:Ticketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entitlementType rdf:type rdf:Property ;
    rdfs:label 'Entitlement Type' ;
    rdfs:comment 'Classification of the access entitlement by ticket tier or access category. GA (General Admission), VIP (Very Important Person), SRO (Standing Room Only), SEASON (Season Ticket), GROUP (Group Sales), COMP (Complimentary), PRESS (Media/Press credential. [ENUM-REF-CANDIDATE: GA|VIP|SRO|SEASON|GROUP|COMP|PRESS|SUITE|HOSPITALITY — promote to reference product]' ;
    rdfs:domain ind:AccessEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalEntitlementRef rdf:type rdf:Property ;
    rdfs:label 'External Entitlement Ref' ;
    rdfs:comment 'The entitlement or ticket identifier as recorded in the originating source system (Ticketmaster, AXS, or Archtics). Used for cross-system reconciliation and support case resolution.' ;
    rdfs:domain ind:AccessEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gateCode rdf:type rdf:Property ;
    rdfs:label 'Gate Code' ;
    rdfs:comment 'The identifier of the physical gate or access control point where this entitlement was scanned and validated. Null if not yet scanned. Used for gate throughput analysis and crowd flow management.' ;
    rdfs:domain ind:AccessEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isResaleable rdf:type rdf:Property ;
    rdfs:label 'Is Resaleable' ;
    rdfs:comment 'Indicates whether this entitlement is eligible for listing on the official resale marketplace. Distinct from transferability — resale implies a monetary transaction on the secondary market, subject to league and venue resale policies.' ;
    rdfs:domain ind:AccessEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isTransferable rdf:type rdf:Property ;
    rdfs:label 'Is Transferable' ;
    rdfs:comment 'Indicates whether this entitlement can be transferred to another fan via the resale marketplace or peer-to-peer transfer. Controlled by league rules, event promoter policy, and CBA restrictions.' ;
    rdfs:domain ind:Ticketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scanAttemptCount rdf:type rdf:Property ;
    rdfs:label 'Scan Attempt Count' ;
    rdfs:comment 'The total number of scan attempts recorded against this entitlement at access control points, including both successful and failed attempts. Used for fraud detection and duplicate entry prevention.' ;
    rdfs:domain ind:AccessEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tokenFormat rdf:type rdf:Property ;
    rdfs:label 'Token Format' ;
    rdfs:comment 'The physical or digital format of the entitlement credential presented at the gate. Determines the scanning hardware and validation protocol used at access control points. [ENUM-REF-CANDIDATE: BARCODE|QR_CODE|NFC|MOBILE_WALLET|RFID|PAPER — promote to reference product if additional formats are added]' ;
    rdfs:domain ind:Ticketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferCount rdf:type rdf:Property ;
    rdfs:label 'Transfer Count' ;
    rdfs:comment 'The number of times this entitlement has been transferred between fans. Used to enforce maximum transfer limits set by league policy and to detect potential scalping activity.' ;
    rdfs:domain ind:Ticketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:transferredTimestamp rdf:type rdf:Property ;
    rdfs:label 'Transferred Timestamp' ;
    rdfs:comment 'The date and time when ownership of this entitlement was transferred to another fan via the resale marketplace or peer-to-peer transfer. Null if no transfer has occurred.' ;
    rdfs:domain ind:AccessEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:validFromTimestamp rdf:type rdf:Property ;
    rdfs:label 'Valid From Timestamp' ;
    rdfs:comment 'The date and time from which this entitlement becomes active and can be used for venue access. Defines the start of the validity window. Gate systems reject scans before this timestamp.' ;
    rdfs:domain ind:AccessEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:validUntilTimestamp rdf:type rdf:Property ;
    rdfs:label 'Valid Until Timestamp' ;
    rdfs:comment 'The date and time after which this entitlement expires and can no longer be used for venue access. Defines the end of the validity window. Gate systems reject scans after this timestamp.' ;
    rdfs:domain ind:AccessEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:voidReasonCode rdf:type rdf:Property ;
    rdfs:label 'Void Reason Code' ;
    rdfs:comment 'Standardised reason code explaining why this entitlement was voided. Null if not voided. Used for refund processing, fraud analytics, and compliance reporting. [ENUM-REF-CANDIDATE: REFUND|FRAUD|DUPLICATE|EVENT_CANCELLED|POLICY_VIOLATION|SYSTEM_ERROR|CHARGEBACK — promote to reference product]' ;
    rdfs:domain ind:AccessEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:voidedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Voided Timestamp' ;
    rdfs:comment 'The date and time when this entitlement was voided or cancelled. Null if the entitlement has not been voided. Required for audit trail and refund processing compliance.' ;
    rdfs:domain ind:AccessEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:gateScanId rdf:type rdf:Property ;
    rdfs:label 'Gate Scan Id' ;
    rdfs:comment 'Unique surrogate identifier for each gate scan event record in the access control system. Primary key for the gate_scan data product in the Databricks Silver Layer.' ;
    rdfs:domain ind:GateScan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryGateEventFixtureId rdf:type rdf:Property ;
    rdfs:label 'Primary Gate Event Fixture Id' ;
    rdfs:comment 'Reference to the live event (game, concert, match) for which this gate scan was performed. Links the scan to the event scheduling and attendance tracking domain.' ;
    rdfs:domain ind:GateScan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Fixture .

ind:primaryGateFanFanProfileId rdf:type rdf:Property ;
    rdfs:label 'Primary Gate Fan Fan Profile Id' ;
    rdfs:comment 'Reference to the fan/patron account associated with the scanned ticket. Enables real-time attendance tracking, fan engagement analytics, and post-event access audit. Sourced from Salesforce CRM and Adobe Experience Platform fan profiles.' ;
    rdfs:domain ind:GateScan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FanProfile .

ind:primaryGateTicketInventoryId rdf:type rdf:Property ;
    rdfs:label 'Primary Gate Ticket Inventory Id' ;
    rdfs:comment 'Reference to the specific ticket entitlement record that was presented and scanned at the gate. Core link between the scan event and the ticketing inventory.' ;
    rdfs:domain ind:GateScan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TicketInventory .

ind:screeningCheckpointId rdf:type rdf:Property ;
    rdfs:label 'Screening Checkpoint Id' ;
    rdfs:comment 'Foreign key linking to security.screening_checkpoint. Business justification: Every fan gate scan occurs at or adjacent to a security screening checkpoint. Linking gate_scan to screening_checkpoint enables throughput analysis per checkpoint, equipment performance reporting, que' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ScreeningCheckpoint .

ind:denialReasonCode rdf:type rdf:Property ;
    rdfs:label 'Denial Reason Code' ;
    rdfs:comment 'Standardized code indicating the specific reason access was denied or flagged. Populated only when scan_result is \'denied\', \'duplicate\', or \'error\'. Used for fraud detection, access control audits, and operational troubleshooting. [ENUM-REF-CANDIDATE: EXPIRED|INVALID_BARCODE|DUPLICATE_USE|WRONG_EVENT|WRONG_GATE|VOIDED|BLACKLISTED|SYSTEM_ERROR — promote to reference product]' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviceCode rdf:type rdf:Property ;
    rdfs:label 'Device Code' ;
    rdfs:comment 'Unique identifier of the scanning hardware device (handheld scanner, fixed turnstile reader) that processed the scan event. Used for device performance monitoring, firmware version tracking, and hardware fault diagnosis.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviceType rdf:type rdf:Property ;
    rdfs:label 'Device Type' ;
    rdfs:comment 'Classification of the scanning hardware used to process the gate scan. Distinguishes between fixed turnstile readers, handheld scanners used by staff, mobile app scans, self-service kiosks, and staff tablets. Informs device fleet management and scan performance benchmarking.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventDate rdf:type rdf:Property ;
    rdfs:label 'Event Date' ;
    rdfs:comment 'Calendar date of the event for which the ticket was scanned. Denormalized from the event record to support efficient date-partitioned querying of scan data and attendance reporting without requiring a join to the event table.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:firmwareVersion rdf:type rdf:Property ;
    rdfs:label 'Firmware Version' ;
    rdfs:comment 'Version identifier of the firmware running on the scanning device at the time of the scan. Used for device fleet management, compatibility tracking, and correlating scan anomalies with specific firmware releases.' ;
    rdfs:domain ind:GateScan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gateIdentifier rdf:type rdf:Property ;
    rdfs:label 'Gate Identifier' ;
    rdfs:comment 'Alphanumeric code identifying the specific gate or entry point at the venue where the scan occurred (e.g., \'GATE-A\', \'GATE-NW-01\'). Used for ingress flow analysis, bottleneck detection, and venue operations management. Sourced from Archtics venue configuration.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isAdaAccessibleEntry rdf:type rdf:Property ;
    rdfs:label 'Is Ada Accessible Entry' ;
    rdfs:comment 'Indicates whether the gate/entry point used for this scan is designated as an Americans with Disabilities Act (ADA) accessible entry point. Supports ADA compliance reporting and accessibility audit requirements.' ;
    rdfs:domain ind:GateScan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isMobileTicket rdf:type rdf:Property ;
    rdfs:label 'Is Mobile Ticket' ;
    rdfs:comment 'Indicates whether the scanned ticket was delivered and presented as a digital mobile ticket (via app or mobile wallet) as opposed to a printed or physical ticket. Tracks digital ticket delivery adoption rates and supports DTC (Direct-To-Consumer) digital strategy analytics.' ;
    rdfs:domain ind:GateScan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isReentryPermitted rdf:type rdf:Property ;
    rdfs:label 'Is Reentry Permitted' ;
    rdfs:comment 'Indicates whether the ticket type and event policy allow re-entry after an exit scan. Drives access control logic at the gate and supports policy compliance auditing.' ;
    rdfs:domain ind:GateScan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:minutesBeforeEventStart rdf:type rdf:Property ;
    rdfs:label 'Minutes Before Event Start' ;
    rdfs:comment 'Calculated number of minutes before the scheduled event start time that the scan occurred. Negative values indicate scans after event start. Supports ingress flow analysis, gate staffing optimization, and fan arrival behavior analytics.' ;
    rdfs:domain ind:GateScan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:networkMode rdf:type rdf:Property ;
    rdfs:label 'Network Mode' ;
    rdfs:comment 'Connectivity state of the scanning device at the time of the scan. \'online\' = real-time validation against central entitlement database; \'offline\' = scan processed using locally cached entitlement list; \'degraded\' = partial connectivity with reduced validation capability. Affects scan result reliability and audit requirements.' ;
    rdfs:domain ind:GateScan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overrideFlag rdf:type rdf:Property ;
    rdfs:label 'Override Flag' ;
    rdfs:comment 'Indicates whether the scan result was manually overridden by an authorized operator (e.g., granting access despite a system denial). Overrides require operator accountability and are flagged for post-event security audit.' ;
    rdfs:domain ind:GateScan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:overrideReason rdf:type rdf:Property ;
    rdfs:label 'Override Reason' ;
    rdfs:comment 'Free-text or coded reason provided by the operator when manually overriding a scan result. Populated only when override_flag is True. Required for security audit and operator accountability reporting.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processingDurationMs rdf:type rdf:Property ;
    rdfs:label 'Processing Duration Ms' ;
    rdfs:comment 'Time in milliseconds taken by the access control device to process the scan and return a result. Used for device performance benchmarking, SLA monitoring, and identifying hardware or network latency issues at entry points.' ;
    rdfs:domain ind:GateScan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:scanDirection rdf:type rdf:Property ;
    rdfs:label 'Scan Direction' ;
    rdfs:comment 'Indicates whether the scan represents an initial entry into the venue, an exit, or a re-entry after leaving. Supports real-time occupancy tracking, re-entry policy enforcement, and post-event ingress/egress flow analysis.' ;
    rdfs:domain ind:GateScan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scanReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Scan Reference Number' ;
    rdfs:comment 'Externally-known alphanumeric reference number assigned by the Ticketmaster/AXS access control hardware to uniquely identify this scan transaction. Used for cross-system reconciliation and audit trail.' ;
    rdfs:domain ind:GateScan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scanResult rdf:type rdf:Property ;
    rdfs:label 'Scan Result' ;
    rdfs:comment 'Outcome of the gate scan attempt as returned by the access control system. \'granted\' = valid entitlement, access permitted; \'denied\' = invalid or expired entitlement, access refused; \'duplicate\' = entitlement already used, re-entry attempt flagged; \'void\' = ticket voided prior to scan; \'error\' = device or system error during scan processing.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scanSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Scan Sequence Number' ;
    rdfs:comment 'Sequential count of scan attempts for this specific entitlement token within the event. A value of 1 indicates the first scan; values greater than 1 indicate re-entry or duplicate scan attempts. Critical for duplicate detection and re-entry policy enforcement.' ;
    rdfs:domain ind:GateScan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sourceEventKey rdf:type rdf:Property ;
    rdfs:label 'Source Event Key' ;
    rdfs:comment 'Natural key or transaction identifier from the originating source system (Ticketmaster/AXS) for this scan record. Enables traceability back to the source system for reconciliation, reprocessing, and audit purposes in the Silver Layer.' ;
    rdfs:domain ind:GateScan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ticketSourceChannel rdf:type rdf:Property ;
    rdfs:label 'Ticket Source Channel' ;
    rdfs:comment 'Distribution channel through which the scanned ticket was originally acquired. Distinguishes primary market sales, resale marketplace, season ticket packages, group sales, complimentary allocations, will-call, and mobile transfers. Supports channel attribution and revenue analytics. [ENUM-REF-CANDIDATE: primary_market|resale_marketplace|season_package|group_sales|comp|will_call|mobile_transfer — promote to reference product]' ;
    rdfs:domain ind:GateScan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:turnstileIdentifier rdf:type rdf:Property ;
    rdfs:label 'Turnstile Identifier' ;
    rdfs:comment 'Unique identifier for the specific turnstile or lane within a gate where the scan was processed. Enables granular throughput analysis and maintenance tracking at the individual turnstile level.' ;
    rdfs:domain ind:GateScan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ticketPaymentId rdf:type rdf:Property ;
    rdfs:label 'Ticket Payment Id' ;
    rdfs:comment 'Unique surrogate identifier for each ticket payment transaction record in the ticketing domain. Primary key for the ticket_payment data product.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TicketPayment .

ind:arInvoiceId rdf:type rdf:Property ;
    rdfs:label 'Ar Invoice Id' ;
    rdfs:comment 'Foreign key linking to finance.ar_invoice. Business justification: Ticket payments settle specific AR invoices; this link enables AR clearing and open-item management. Finance teams need to match ticket_payment records to ar_invoice for cash application workflows. No' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ArInvoice .

ind:paymentRunId rdf:type rdf:Property ;
    rdfs:label 'Payment Run Id' ;
    rdfs:comment 'Foreign key linking to finance.payment_run. Business justification: Season ticket installment payments and batch renewal payments are grouped into payment runs for treasury reconciliation. Linking ticket_payment to payment_run enables batch payment processing reconcil' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PaymentRun .

ind:authorizationCode rdf:type rdf:Property ;
    rdfs:label 'Authorization Code' ;
    rdfs:comment 'Alphanumeric code returned by the card network or payment processor confirming that the payment was authorized. Required for dispute resolution, chargeback management, and financial audit trails. Null for failed or pending transactions.' ;
    rdfs:domain ind:TicketPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorizedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Authorized Timestamp' ;
    rdfs:comment 'The precise date and time when the payment was authorized by the card network or payment processor. This is the principal business event timestamp for the payment lifecycle. Used for fraud detection time-window analysis and PCI-DSS audit trails.' ;
    rdfs:domain ind:TicketPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:capturedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Captured Timestamp' ;
    rdfs:comment 'The precise date and time when the authorized payment was captured (funds actually charged). Distinct from authorization timestamp; the gap between authorization and capture is monitored for compliance with card network rules. Null for non-captured transactions.' ;
    rdfs:domain ind:TicketPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:cardExpiryMonth rdf:type rdf:Property ;
    rdfs:label 'Card Expiry Month' ;
    rdfs:comment 'The expiration month of the payment card (1–12). Stored in compliance with PCI-DSS to support recurring payment validation and card-on-file management for season ticket holders. Null for non-card payment methods.' ;
    rdfs:domain ind:TicketPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cardExpiryYear rdf:type rdf:Property ;
    rdfs:label 'Card Expiry Year' ;
    rdfs:comment 'The four-digit expiration year of the payment card. Stored in compliance with PCI-DSS to support recurring payment validation and card-on-file management for season ticket holders. Null for non-card payment methods.' ;
    rdfs:domain ind:TicketPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cardNetwork rdf:type rdf:Property ;
    rdfs:label 'Card Network' ;
    rdfs:comment 'The card network or scheme associated with the payment instrument (e.g., Visa, Mastercard, American Express, Discover, UnionPay). Used for interchange fee analysis, network-specific reporting, and chargeback routing.' ;
    rdfs:domain ind:TicketPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chargebackStatus rdf:type rdf:Property ;
    rdfs:label 'Chargeback Status' ;
    rdfs:comment 'Current status of any chargeback dispute associated with this payment transaction. Tracks the chargeback lifecycle from initiation through resolution. Used for fraud management, financial loss reporting, and card network compliance. Default is \'none\' for transactions with no chargeback.' ;
    rdfs:domain ind:TicketPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exchangeRate rdf:type rdf:Property ;
    rdfs:label 'Exchange Rate' ;
    rdfs:comment 'The foreign exchange rate applied at the time of payment when the transaction currency differs from the organization\'s functional currency (USD). Used for multi-currency financial reporting and SAP S/4HANA FI currency revaluation. Null for transactions in the functional currency.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:failureReasonCode rdf:type rdf:Property ;
    rdfs:label 'Failure Reason Code' ;
    rdfs:comment 'Standardized decline or failure code returned by the payment processor or card network when a payment is not authorized (e.g., insufficient_funds, card_expired, do_not_honor, fraud_suspected). Used for failed payment analysis, retry logic, and fan communication. Null for successful transactions.' ;
    rdfs:domain ind:TicketPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failureReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Failure Reason Description' ;
    rdfs:comment 'Human-readable description of the payment failure reason corresponding to the failure_reason_code. Used by customer service teams in Salesforce CRM for fan outreach and dispute resolution. Null for successful transactions.' ;
    rdfs:domain ind:TicketPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fraudScore rdf:type rdf:Property ;
    rdfs:label 'Fraud Score' ;
    rdfs:comment 'Numeric fraud risk score assigned by the payment processor\'s fraud detection engine or an internal fraud scoring model at the time of payment (0.00–100.00, where higher values indicate greater fraud risk). Used for real-time payment decisioning, fraud trend analysis, and PCI-DSS fraud monitoring requirements.' ;
    rdfs:domain ind:TicketPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:installmentNumber rdf:type rdf:Property ;
    rdfs:label 'Installment Number' ;
    rdfs:comment 'The sequential installment number for recurring or installment-based payments (e.g., 1 of 4 for a season ticket payment plan). Null for one-time payments. Used for installment plan tracking and revenue recognition scheduling.' ;
    rdfs:domain ind:TicketPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:installmentTotalCount rdf:type rdf:Property ;
    rdfs:label 'Installment Total Count' ;
    rdfs:comment 'The total number of installments in the payment plan for season ticket or group sales installment arrangements (e.g., 4 for a quarterly payment plan). Null for one-time payments. Used alongside installment_number for plan completion tracking.' ;
    rdfs:domain ind:TicketPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:is3dsAuthenticated rdf:type rdf:Property ;
    rdfs:label 'Is 3ds Authenticated' ;
    rdfs:comment 'Indicates whether the payment was authenticated using 3D Secure (3DS) protocol (e.g., Visa Secure, Mastercard Identity Check). True if 3DS authentication was completed. Used for fraud liability shift determination and PCI-DSS compliance reporting.' ;
    rdfs:domain ind:TicketPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRecurring rdf:type rdf:Property ;
    rdfs:label 'Is Recurring' ;
    rdfs:comment 'Indicates whether this payment is part of a recurring payment arrangement, such as a season ticket installment plan or subscription-based fan membership. True for recurring charges. Drives card-on-file compliance and CBA-related payment plan management.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maskedCardReference rdf:type rdf:Property ;
    rdfs:label 'Masked Card Reference' ;
    rdfs:comment 'Masked representation of the payment card number or digital wallet identifier (e.g., last 4 digits of card, masked wallet token). Stored in PCI-DSS compliant masked format for customer service, receipt display, and dispute identification without exposing full PAN.' ;
    rdfs:domain ind:TicketPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentChannel rdf:type rdf:Property ;
    rdfs:label 'Payment Channel' ;
    rdfs:comment 'The interface or touchpoint through which the fan submitted the payment (e.g., web browser, mobile app, venue box office, self-service kiosk, call center, third-party resale platform). Distinct from payment method type; used for channel analytics and fraud detection.' ;
    rdfs:domain ind:TicketPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentMethodType rdf:type rdf:Property ;
    rdfs:label 'Payment Method Type' ;
    rdfs:comment 'Classification of the payment instrument used by the fan (e.g., credit card, debit card, digital wallet such as Apple Pay/Google Pay, bank transfer, gift card, cash at box office). Drives PCI-DSS scope determination and payment processing routing.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentNotes rdf:type rdf:Property ;
    rdfs:label 'Payment Notes' ;
    rdfs:comment 'Free-text notes or comments associated with the payment transaction, entered by customer service agents or system processes (e.g., manual override justification, special handling instructions for VIP fan payments, dispute context). Used in Salesforce CRM case management.' ;
    rdfs:domain ind:TicketPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Payment Reference Number' ;
    rdfs:comment 'Externally-known, human-readable payment reference number assigned by the payment processor or ticketing platform (e.g., Ticketmaster/AXS transaction reference). Used for customer-facing receipts, dispute resolution, and reconciliation with external systems.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pciScopeFlag rdf:type rdf:Property ;
    rdfs:label 'Pci Scope Flag' ;
    rdfs:comment 'Indicates whether this payment record falls within the PCI-DSS cardholder data environment (CDE) scope. True for card-based payments subject to PCI-DSS controls. Used for PCI-DSS scope boundary management, audit reporting, and data classification governance.' ;
    rdfs:domain ind:TicketPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:processorTransactionToken rdf:type rdf:Property ;
    rdfs:label 'Processor Transaction Token' ;
    rdfs:comment 'Tokenized reference assigned by the payment processor to uniquely identify this transaction within the processor\'s system. Replaces raw card data per PCI-DSS tokenization requirements. Used for refund initiation, dispute management, and settlement reconciliation.' ;
    rdfs:domain ind:TicketPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refundReason rdf:type rdf:Property ;
    rdfs:label 'Refund Reason' ;
    rdfs:comment 'Categorized reason for the refund when payment_status is \'refunded\'. Supports refund trend analysis, event cancellation financial impact reporting, and fraud detection. Null for non-refunded transactions.' ;
    rdfs:domain ind:TicketPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refundedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Refunded Timestamp' ;
    rdfs:comment 'The precise date and time when the refund was processed and submitted to the payment processor. Null for non-refunded transactions. Used for refund SLA monitoring and fan experience reporting.' ;
    rdfs:domain ind:TicketPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:settlementDate rdf:type rdf:Property ;
    rdfs:label 'Settlement Date' ;
    rdfs:comment 'The date on which the payment was settled by the acquiring bank and funds were transferred to the organization\'s account. Critical for cash flow reporting, SAP S/4HANA FI bank reconciliation, and revenue recognition timing.' ;
    rdfs:domain ind:TicketPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:settlementReference rdf:type rdf:Property ;
    rdfs:label 'Settlement Reference' ;
    rdfs:comment 'The batch settlement reference number assigned by the payment processor or acquiring bank when the transaction is included in a settlement batch. Used for bank reconciliation, SAP S/4HANA FI bank statement matching, and financial close processes.' ;
    rdfs:domain ind:TicketPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:walletProvider rdf:type rdf:Property ;
    rdfs:label 'Wallet Provider' ;
    rdfs:comment 'Name of the digital wallet provider used for payment when payment_method_type is digital_wallet (e.g., Apple Pay, Google Pay, PayPal, Venmo). Null for non-wallet payment methods. Supports DTC fan engagement analytics and wallet adoption reporting.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refundId rdf:type rdf:Property ;
    rdfs:label 'Refund Id' ;
    rdfs:comment 'Unique system-generated surrogate identifier for the ticket refund record. Primary key for the refund data product in the ticketing domain Silver layer.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Refund .

ind:refundEventFixtureId rdf:type rdf:Property ;
    rdfs:label 'Refund Event Fixture Id' ;
    rdfs:comment 'Reference to the sports or entertainment event associated with the refunded ticket. Enables event-level refund aggregation for cancellation and postponement analysis.' ;
    rdfs:domain ind:Refund ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Fixture .

ind:refundFanFanProfileId rdf:type rdf:Property ;
    rdfs:label 'Refund Fan Fan Profile Id' ;
    rdfs:comment 'Reference to the fan (customer) account requesting or receiving the refund. Supports CRM-linked fan engagement tracking and PCI-DSS audit trail for cardholder refund activity.' ;
    rdfs:domain ind:Refund ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FanProfile .

ind:refundFanProfileId rdf:type rdf:Property ;
    rdfs:label 'Refund Fan Profile Id' ;
    rdfs:comment 'Reference to the fan (customer) account requesting or receiving the refund. Supports CRM-linked fan engagement tracking and PCI-DSS audit trail for cardholder refund activity.' ;
    rdfs:domain ind:Refund ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FanProfile .

ind:refundFixtureId rdf:type rdf:Property ;
    rdfs:label 'Refund Fixture Id' ;
    rdfs:comment 'Reference to the sports or entertainment event associated with the refunded ticket. Enables event-level refund aggregation for cancellation and postponement analysis.' ;
    rdfs:domain ind:Refund ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Fixture .

ind:refundTicketInventoryId rdf:type rdf:Property ;
    rdfs:label 'Refund Ticket Inventory Id' ;
    rdfs:comment 'Reference to the specific ticket being refunded. A single order may contain multiple tickets; this field identifies the individual ticket entitlement subject to the refund.' ;
    rdfs:domain ind:Refund ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TicketInventory .

ind:refundTicketTicketInventoryId rdf:type rdf:Property ;
    rdfs:label 'Refund Ticket Ticket Inventory Id' ;
    rdfs:comment 'Reference to the specific ticket being refunded. A single order may contain multiple tickets; this field identifies the individual ticket entitlement subject to the refund.' ;
    rdfs:domain ind:Refund ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TicketInventory .

ind:approvalLevel rdf:type rdf:Property ;
    rdfs:label 'Approval Level' ;
    rdfs:comment 'The authorization tier at which the refund was approved. AUTO indicates system-triggered approval (e.g., event cancellation policy); AGENT, SUPERVISOR, and FINANCE indicate escalating human approval tiers based on refund amount thresholds.' ;
    rdfs:domain ind:Refund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grossRefundAmount rdf:type rdf:Property ;
    rdfs:label 'Gross Refund Amount' ;
    rdfs:comment 'The total face value of the ticket(s) being refunded before any deductions such as service fees or processing charges. Represents the base monetary amount subject to reversal in SAP FI.' ;
    rdfs:domain ind:Refund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isEventInitiated rdf:type rdf:Property ;
    rdfs:label 'Is Event Initiated' ;
    rdfs:comment 'Indicates whether the refund was triggered by an event-level action (cancellation, postponement, force majeure) rather than a fan-initiated request. Drives bulk refund processing workflows and league governance reporting.' ;
    rdfs:domain ind:Refund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isFraudRelated rdf:type rdf:Property ;
    rdfs:label 'Is Fraud Related' ;
    rdfs:comment 'Indicates whether the refund was initiated due to a confirmed or suspected fraudulent transaction. When true, triggers PCI-DSS fraud incident reporting and Salesforce CRM fraud case creation.' ;
    rdfs:domain ind:Refund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:netRefundAmount rdf:type rdf:Property ;
    rdfs:label 'Net Refund Amount' ;
    rdfs:comment 'The actual monetary amount returned to the fan after deducting any non-refundable fees or processing charges from the gross refund amount. This is the amount posted to the fan\'s payment instrument or credit wallet.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:originalPaymentMethod rdf:type rdf:Property ;
    rdfs:label 'Original Payment Method' ;
    rdfs:comment 'The payment instrument used in the original ticket purchase transaction. Determines eligibility for ORIGINAL_PAYMENT refund routing and informs PCI-DSS cardholder data handling requirements.' ;
    rdfs:domain ind:Refund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentTransactionRef rdf:type rdf:Property ;
    rdfs:label 'Payment Transaction Ref' ;
    rdfs:comment 'The external payment processor transaction reference number for the refund settlement (e.g., Stripe charge ID, Adyen PSP reference). Used for reconciliation between Ticketmaster/AXS and the payment gateway. Never stores raw card data.' ;
    rdfs:domain ind:Refund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Processed Timestamp' ;
    rdfs:comment 'The date and time when the refund was submitted to the payment processor or credit wallet system for execution. Distinct from approved_timestamp; marks the point of financial commitment.' ;
    rdfs:domain ind:Refund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:reasonCode rdf:type rdf:Property ;
    rdfs:label 'Reason Code' ;
    rdfs:comment 'Standardized code classifying the business reason for the refund. EVENT_CANCELLED and EVENT_POSTPONED are league/venue-initiated; FAN_REQUEST is voluntary; FRAUD triggers PCI-DSS fraud reporting. [ENUM-REF-CANDIDATE: EVENT_CANCELLED|EVENT_POSTPONED|FAN_REQUEST|FRAUD|DUPLICATE_PURCHASE|VENUE_ISSUE|WEATHER — promote to reference product]' ;
    rdfs:domain ind:Refund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reasonDescription rdf:type rdf:Property ;
    rdfs:label 'Reason Description' ;
    rdfs:comment 'Free-text narrative providing additional context for the refund reason beyond the standardized reason code. Captured by customer service agents or automated system messages in Salesforce CRM.' ;
    rdfs:domain ind:Refund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refundMethod rdf:type rdf:Property ;
    rdfs:label 'Refund Method' ;
    rdfs:comment 'The channel or instrument through which the refund value is returned to the fan. ORIGINAL_PAYMENT reverses to the card/account used at purchase; CREDIT_WALLET posts to the fan\'s digital wallet; VOUCHER issues a future-use ticket credit. Governs SAP FI posting type.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refundNumber rdf:type rdf:Property ;
    rdfs:label 'Refund Number' ;
    rdfs:comment 'Externally visible, human-readable refund reference number issued to the fan and used in customer service communications. Formatted as RFD- followed by a 10-digit sequence. Sourced from Ticketmaster/AXS refund workflow.' ;
    rdfs:domain ind:Refund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refundStatus rdf:type rdf:Property ;
    rdfs:label 'Refund Status' ;
    rdfs:comment 'Current lifecycle state of the refund request within the approval and processing workflow. Drives operational queues in Ticketmaster/AXS and SAP FI posting logic.' ;
    rdfs:domain ind:Refund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refundType rdf:type rdf:Property ;
    rdfs:label 'Refund Type' ;
    rdfs:comment 'Indicates whether the refund covers the full ticket face value (FULL), a portion of the ticket value (PARTIAL), or is issued as a credit/voucher rather than a monetary return (CREDIT). Drives revenue recognition reversal logic in SAP CO.' ;
    rdfs:domain ind:Refund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rejectionReason rdf:type rdf:Property ;
    rdfs:label 'Rejection Reason' ;
    rdfs:comment 'Free-text explanation provided when a refund request is rejected. Populated only when refund_status is \'rejected\'. Required for customer service follow-up and regulatory dispute resolution under GDPR Article 12.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Requested Timestamp' ;
    rdfs:comment 'The date and time when the fan or system initiated the refund request. Represents the principal business event time for the refund lifecycle. Used for SLA measurement and PCI-DSS audit trail.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:resaleRefundFlag rdf:type rdf:Property ;
    rdfs:label 'Resale Refund Flag' ;
    rdfs:comment 'Indicates whether the refund relates to a ticket purchased through the secondary/resale marketplace rather than the primary box office. Resale refunds may follow different policy rules and fee structures.' ;
    rdfs:domain ind:Refund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:serviceFeeRefundAmount rdf:type rdf:Property ;
    rdfs:label 'Service Fee Refund Amount' ;
    rdfs:comment 'The portion of the refund attributable to service fees originally charged on the ticket purchase. May be zero if service fees are non-refundable per the event\'s refund policy. Tracked separately for revenue accounting in SAP CO.' ;
    rdfs:domain ind:Refund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:slaBreachFlag rdf:type rdf:Property ;
    rdfs:label 'Sla Breach Flag' ;
    rdfs:comment 'Indicates whether the refund processing exceeded the defined SLA target hours. Set to true when the elapsed time between approved_timestamp and processed_timestamp exceeds sla_target_hours. Drives escalation workflows.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:slaTargetHours rdf:type rdf:Property ;
    rdfs:label 'Sla Target Hours' ;
    rdfs:comment 'The contracted or policy-defined maximum number of hours within which the refund must be processed from the point of approval. Used for SLA compliance monitoring and customer service KPI reporting.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemRefundCode rdf:type rdf:Property ;
    rdfs:label 'Source System Refund Code' ;
    rdfs:comment 'The native refund identifier as recorded in the originating operational system (e.g., Ticketmaster refund transaction ID, SAP FI document number). Enables cross-system reconciliation and audit trail back to the system of record.' ;
    rdfs:domain ind:Refund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxRefundAmount rdf:type rdf:Property ;
    rdfs:label 'Tax Refund Amount' ;
    rdfs:comment 'The tax component being reversed as part of the refund. Required for VAT/GST compliance reporting in applicable jurisdictions and SAP FI tax reversal postings.' ;
    rdfs:domain ind:Refund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:voucherCode rdf:type rdf:Property ;
    rdfs:label 'Voucher Code' ;
    rdfs:comment 'The unique alphanumeric voucher code issued to the fan when refund_method is VOUCHER. Redeemable against future ticket purchases in Ticketmaster/AXS. Null for non-voucher refund methods.' ;
    rdfs:domain ind:Refund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:voucherExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Voucher Expiry Date' ;
    rdfs:comment 'The date on which the issued refund voucher expires and can no longer be redeemed. Applicable only when refund_method is VOUCHER. Null for monetary refund methods.' ;
    rdfs:domain ind:Refund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:holdAllocationId rdf:type rdf:Property ;
    rdfs:label 'Hold Allocation Id' ;
    rdfs:comment 'Unique surrogate identifier for each hold allocation record in the ticketing inventory management system. Primary key for the hold_allocation data product.' ;
    rdfs:domain ind:HoldAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:clubId rdf:type rdf:Property ;
    rdfs:label 'Club Id' ;
    rdfs:comment 'Foreign key linking to fan.fan_club. Business justification: Official fan club ticket allocation management — leagues and venues allocate seat holds to registered fan clubs for away fixtures and cup finals. Linking hold_allocation to fan_club enables allocation' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Club .

ind:contractId rdf:type rdf:Property ;
    rdfs:label 'Contract Id' ;
    rdfs:comment 'Foreign key linking to athlete.contract. Business justification: CBA Contract Comp Ticket Fulfillment: Player contracts specify exact comp ticket quantities, tiers, and game types. hold_allocation.contract_reference is a denormalized text field; a proper FK to athl' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Contract .

ind:primaryHoldEventFixtureId rdf:type rdf:Property ;
    rdfs:label 'Primary Hold Event Fixture Id' ;
    rdfs:comment 'Reference to the event for which this hold allocation applies. Links the hold block to the specific sporting or entertainment event in the event master.' ;
    rdfs:domain ind:HoldAllocation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Fixture .

ind:rosterId rdf:type rdf:Property ;
    rdfs:label 'Roster Id' ;
    rdfs:comment 'Foreign key linking to athlete.roster. Business justification: CBA Comp Ticket Hold Allocation: Active roster status directly governs which players receive comp ticket holds each game. Linking hold_allocation to roster enables automated CBA compliance — holds are' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Roster .

ind:segmentId rdf:type rdf:Property ;
    rdfs:label 'Segment Id' ;
    rdfs:comment 'Foreign key linking to fan.segment. Business justification: Segment-based presale hold management requires linking ticket holds to the fan segment they are reserved for (e.g., loyalty member presale, VIP segment holds). The existing `eligibility_criteria` plai' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Segment .

ind:accessCode rdf:type rdf:Property ;
    rdfs:label 'Access Code' ;
    rdfs:comment 'Alphanumeric code required by eligible buyers to access a presale window associated with this hold allocation. Confidential as it controls access to restricted inventory. Null for non-presale hold types.' ;
    rdfs:domain ind:HoldAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Approval Timestamp' ;
    rdfs:comment 'Date and time when this hold allocation was formally approved by the designated authority. Supports SOX audit trail requirements for complimentary and high-value hold approvals.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:eligibilityCriteria rdf:type rdf:Property ;
    rdfs:label 'Eligibility Criteria' ;
    rdfs:comment 'Free-text or structured description of the rules governing who is eligible to access this hold allocation (e.g., \'Season ticket holders only\', \'Fan club members with active membership\', \'Sponsor guest list\'). Supports access control enforcement in Ticketmaster/AXS.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdCreatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Hold Created Timestamp' ;
    rdfs:comment 'Date and time when this hold allocation was first placed in the ticketing system. Represents the principal business event timestamp — the moment inventory was removed from general availability. Sourced from Ticketmaster/AXS or Archtics system of record.' ;
    rdfs:domain ind:HoldAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:holdOwner rdf:type rdf:Property ;
    rdfs:label 'Hold Owner' ;
    rdfs:comment 'Name or identifier of the business unit, partner, or individual responsible for managing this hold allocation (e.g., sponsor name, artist management agency, media partner, venue operations team). Operational accountability field used in Archtics hold management workflows.' ;
    rdfs:domain ind:HoldAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdReason rdf:type rdf:Property ;
    rdfs:label 'Hold Reason' ;
    rdfs:comment 'Narrative description of the business justification for placing this hold allocation (e.g., \'Platinum sponsor contractual comp entitlement Q3\', \'Artist rider requirement - 50 house seats\', \'Media credential access - broadcast partners\'). Supports audit and compliance review.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdStatus rdf:type rdf:Property ;
    rdfs:label 'Hold Status' ;
    rdfs:comment 'Current lifecycle state of the hold allocation. Tracks whether the hold is active, has been fully or partially released back to general inventory, has expired past its hold expiry timestamp, or has been cancelled by the hold owner.' ;
    rdfs:domain ind:HoldAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdType rdf:type rdf:Property ;
    rdfs:label 'Hold Type' ;
    rdfs:comment 'Classification of the purpose for which the inventory block is held. Drives downstream release sequencing and eligibility rules. [ENUM-REF-CANDIDATE: sponsor_comp|artist_athlete|media|ada|operational|presale|group_sales — promote to reference product]' ;
    rdfs:domain ind:HoldAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isAdaHold rdf:type rdf:Property ;
    rdfs:label 'Is Ada Hold' ;
    rdfs:comment 'Indicates whether this hold allocation is designated for Americans with Disabilities Act (ADA) accessible seating. ADA holds are subject to specific regulatory requirements for accessible seat inventory management.' ;
    rdfs:domain ind:HoldAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isDynamicPricingEligible rdf:type rdf:Property ;
    rdfs:label 'Is Dynamic Pricing Eligible' ;
    rdfs:comment 'Indicates whether tickets in this hold allocation are subject to dynamic pricing adjustments when released to general inventory. False for comp, ADA, and fixed-price sponsor holds.' ;
    rdfs:domain ind:HoldAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maxTicketsPerBuyer rdf:type rdf:Property ;
    rdfs:label 'Max Tickets Per Buyer' ;
    rdfs:comment 'Maximum number of tickets a single eligible buyer may purchase from this hold allocation during the presale or comp distribution window. Enforces per-buyer limits to prevent bulk purchasing and ensure equitable access.' ;
    rdfs:domain ind:HoldAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:presaleWindowEnd rdf:type rdf:Property ;
    rdfs:label 'Presale Window End' ;
    rdfs:comment 'Date and time when the presale window closes for this hold allocation. Unreleased inventory after this timestamp is subject to release rules defined by hold_expiry_timestamp or manual release.' ;
    rdfs:domain ind:HoldAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:presaleWindowStart rdf:type rdf:Property ;
    rdfs:label 'Presale Window Start' ;
    rdfs:comment 'Date and time when the presale window opens for this hold allocation, allowing eligible buyers to purchase before general public on-sale. Applicable when hold_type is presale. Drives tiered on-sale sequencing.' ;
    rdfs:domain ind:HoldAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:publicOnsaleTimestamp rdf:type rdf:Property ;
    rdfs:label 'Public Onsale Timestamp' ;
    rdfs:comment 'Date and time of the general public on-sale for the event. Used to calculate the lead time between hold creation and public availability, and to enforce release deadlines for presale and comp holds.' ;
    rdfs:domain ind:HoldAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:quantityConsumed rdf:type rdf:Property ;
    rdfs:label 'Quantity Consumed' ;
    rdfs:comment 'Number of tickets from this hold allocation that have been issued, distributed, or sold (e.g., comps distributed to sponsor, presale tickets sold). Tracks actual utilization of the hold block.' ;
    rdfs:domain ind:HoldAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:quantityHeld rdf:type rdf:Property ;
    rdfs:label 'Quantity Held' ;
    rdfs:comment 'Total number of tickets/seats placed on hold under this allocation record. Represents the gross inventory block size at the time the hold was created.' ;
    rdfs:domain ind:HoldAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:quantityReleased rdf:type rdf:Property ;
    rdfs:label 'Quantity Released' ;
    rdfs:comment 'Number of tickets from this hold allocation that have been released back to general on-sale inventory. Enables tracking of partial releases and remaining hold balance.' ;
    rdfs:domain ind:HoldAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:releaseTimestamp rdf:type rdf:Property ;
    rdfs:label 'Release Timestamp' ;
    rdfs:comment 'Actual date and time when the hold was released (fully or partially) back to general inventory or to a presale window. Null if the hold has not yet been released. Supports audit trail for inventory lifecycle.' ;
    rdfs:domain ind:HoldAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:releaseToPool rdf:type rdf:Property ;
    rdfs:label 'Release To Pool' ;
    rdfs:comment 'Designates the inventory pool to which unreleased tickets from this hold will be returned upon expiry or manual release. Controls tiered on-sale sequencing and resale marketplace eligibility.' ;
    rdfs:domain ind:HoldAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountTier rdf:type rdf:Property ;
    rdfs:label 'Account Tier' ;
    rdfs:comment 'Commercial tier classification of the sponsorship relationship indicating the level of investment, exclusivity, and activation rights. Title sponsors receive the highest prominence; associate sponsors receive baseline rights. Drives benefit entitlement and activation priority.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:activationRegion rdf:type rdf:Property ;
    rdfs:label 'Activation Region' ;
    rdfs:comment 'Geographic scope of the sponsor\'s activation rights (e.g., \'Global\', \'North America\', \'USA\', \'GBR\', \'DEU\'). Determines where brand activations, broadcast integrations, and digital placements may be executed. Uses ISO 3166-1 alpha-3 for country-level or named region for multi-country scopes.' ;
    rdfs:domain ind:Sponsor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agencyName rdf:type rdf:Property ;
    rdfs:label 'Agency Name' ;
    rdfs:comment 'Name of the sports marketing or media agency representing the sponsor in deal negotiations and activation management (e.g., IMG, Octagon, WME Sports). Relevant when the sponsor engages through an intermediary rather than directly.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:annualInvestmentUsd rdf:type rdf:Property ;
    rdfs:label 'Annual Investment Usd' ;
    rdfs:comment 'Total contracted annual cash investment value of the sponsorship in US Dollars. Represents the base financial commitment excluding value-in-kind (VIK) contributions. Used for revenue forecasting, EBITDA (Earnings Before Interest Taxes Depreciation and Amortization) reporting, and tier qualification.' ;
    rdfs:domain ind:Sponsor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:brandName rdf:type rdf:Property ;
    rdfs:label 'Brand Name' ;
    rdfs:comment 'Commercial or trade name of the sponsor brand as displayed in activations, signage, broadcast integrations, and fan-facing materials. May differ from the legal entity name (e.g., parent company vs. product brand).' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:broadcastIntegrationFlag rdf:type rdf:Property ;
    rdfs:label 'Broadcast Integration Flag' ;
    rdfs:comment 'Indicates whether this sponsor has contracted broadcast integration rights including virtual signage, sponsored segments, on-screen billboards, or OTT (Over-The-Top Streaming) branded content placements.' ;
    rdfs:domain ind:Sponsor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:categoryExclusivityFlag rdf:type rdf:Property ;
    rdfs:label 'Category Exclusivity Flag' ;
    rdfs:comment 'Indicates whether this sponsor holds exclusive rights within their industry category, preventing competing brands in the same category from entering into sponsorship agreements. Critical for conflict-of-interest checks during new deal prospecting.' ;
    rdfs:domain ind:Sponsor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:crmAccountCode rdf:type rdf:Property ;
    rdfs:label 'Crm Account Code' ;
    rdfs:comment 'Salesforce CRM Account record identifier linking this sponsor to the authoritative B2B relationship record in Salesforce CRM. Used for bi-directional sync of contact, opportunity, and activity data.' ;
    rdfs:domain ind:Sponsor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataPrivacyConsentFlag rdf:type rdf:Property ;
    rdfs:label 'Data Privacy Consent Flag' ;
    rdfs:comment 'Indicates whether the sponsoring organization\'s primary contact has provided consent for data processing activities under applicable privacy regulations. Required for GDPR-compliant B2B contact data management in EU markets.' ;
    rdfs:domain ind:Sponsor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:digitalPlatformFlag rdf:type rdf:Property ;
    rdfs:label 'Digital Platform Flag' ;
    rdfs:comment 'Indicates whether this sponsor has contracted digital platform partnership rights including DTC (Direct-To-Consumer) app integrations, social media activations, OTT branded content, or API-driven data partnerships.' ;
    rdfs:domain ind:Sponsor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:exclusivityCategory rdf:type rdf:Property ;
    rdfs:label 'Exclusivity Category' ;
    rdfs:comment 'The specific product or service category for which this sponsor holds exclusivity rights (e.g., \'Official Beer\', \'Official Automotive Partner\', \'Official Financial Services Partner\'). Populated only when category_exclusivity_flag is true. Used to enforce category conflict checks during new deal origination.' ;
    rdfs:domain ind:Sponsorship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gdprApplicableFlag rdf:type rdf:Property ;
    rdfs:label 'Gdpr Applicable Flag' ;
    rdfs:comment 'Indicates whether GDPR (General Data Protection Regulation) applies to this sponsor relationship based on the sponsor\'s headquarters jurisdiction or the markets in which activations are executed. Triggers enhanced data handling and consent management workflows.' ;
    rdfs:domain ind:Sponsor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:headquartersCity rdf:type rdf:Property ;
    rdfs:label 'Headquarters City' ;
    rdfs:comment 'City of the sponsor\'s global headquarters. Used for geographic market analysis, regional partnership segmentation, and event proximity reporting.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersCountry rdf:type rdf:Property ;
    rdfs:label 'Headquarters Country' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the sponsor\'s global headquarters. Used for jurisdictional compliance (GDPR, CCPA), tax treaty application, and international partnership reporting.' ;
    rdfs:domain ind:Sponsor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersStateProvince rdf:type rdf:Property ;
    rdfs:label 'Headquarters State Province' ;
    rdfs:comment 'State or province of the sponsor\'s global headquarters. Used for regional market segmentation, tax jurisdiction determination, and compliance with state-level privacy laws such as CCPA.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:industryCategory rdf:type rdf:Property ;
    rdfs:label 'Industry Category' ;
    rdfs:comment 'Primary industry sector of the sponsoring organization using standard classification (e.g., Automotive, Financial Services, Consumer Packaged Goods, Technology, Telecommunications, Apparel). Used for category exclusivity management and competitive conflict checks. [ENUM-REF-CANDIDATE: automotive|financial_services|consumer_packaged_goods|technology|telecommunications|apparel|healthcare|food_beverage|insurance|retail|energy|media — promote to reference product]' ;
    rdfs:domain ind:Sponsor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isPubliclyTraded rdf:type rdf:Property ;
    rdfs:label 'Is Publicly Traded' ;
    rdfs:comment 'Indicates whether the sponsoring organization is a publicly traded company listed on a recognized stock exchange. Drives SEC disclosure obligations, financial due diligence requirements, and SOX compliance considerations.' ;
    rdfs:domain ind:Sponsor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jerseySponsorshipFlag rdf:type rdf:Property ;
    rdfs:label 'Jersey Sponsorship Flag' ;
    rdfs:comment 'Indicates whether this sponsor holds jersey or kit sponsorship rights for one or more teams or athletes. Jersey sponsorships carry premium brand visibility and are governed by league IP and uniform regulations.' ;
    rdfs:domain ind:Sponsor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:legalName rdf:type rdf:Property ;
    rdfs:label 'Legal Name' ;
    rdfs:comment 'Full registered legal name of the sponsoring organization as it appears on executed contracts and regulatory filings. Used for invoicing, contract execution, and compliance reporting.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:naicsCode rdf:type rdf:Property ;
    rdfs:label 'Naics Code' ;
    rdfs:comment 'Six-digit NAICS code identifying the sponsor\'s primary business activity. Used for industry benchmarking, regulatory reporting, and category exclusivity conflict detection.' ;
    rdfs:domain ind:Sponsor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:namingRightsFlag rdf:type rdf:Property ;
    rdfs:label 'Naming Rights Flag' ;
    rdfs:comment 'Indicates whether this sponsor holds naming rights for one or more venues. Naming rights are among the highest-value sponsorship assets and require specific contractual, signage, and broadcast integration management.' ;
    rdfs:domain ind:Sponsor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nilPartnershipFlag rdf:type rdf:Property ;
    rdfs:label 'Nil Partnership Flag' ;
    rdfs:comment 'Indicates whether this sponsor has active NIL (Name, Image, and Likeness) agreements with individual athletes managed through the sports-entertainment ecosystem. NIL deals require separate compliance tracking under applicable state laws and league policies.' ;
    rdfs:domain ind:Sponsor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:parentOrganizationName rdf:type rdf:Property ;
    rdfs:label 'Parent Organization Name' ;
    rdfs:comment 'Name of the ultimate parent corporation in the sponsor\'s corporate hierarchy. Supports consolidated revenue reporting, conflict-of-interest checks, and category exclusivity enforcement across subsidiary brands.' ;
    rdfs:domain ind:Sponsor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredLanguage rdf:type rdf:Property ;
    rdfs:label 'Preferred Language' ;
    rdfs:comment 'BCP 47 language tag representing the sponsor\'s preferred language for contract communications, activation briefs, and reporting (e.g., \'en\', \'fr\', \'de\', \'es\'). Supports multilingual partnership management across global markets.' ;
    rdfs:domain ind:Sponsor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prospectingSource rdf:type rdf:Property ;
    rdfs:label 'Prospecting Source' ;
    rdfs:comment 'Channel or method through which this sponsor was originally identified or acquired. Used for CAC (Customer Acquisition Cost) analysis, sales pipeline attribution, and partnership development strategy reporting. [ENUM-REF-CANDIDATE: inbound|outbound|referral|agency|renewal|conference|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Sponsor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipStartDate rdf:type rdf:Property ;
    rdfs:label 'Relationship Start Date' ;
    rdfs:comment 'Calendar date on which the first commercial sponsorship relationship with this organization was established. Supports tenure calculations, loyalty tier assessments, and long-term partner recognition programs.' ;
    rdfs:domain ind:Sponsor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:relationshipStatus rdf:type rdf:Property ;
    rdfs:label 'Relationship Status' ;
    rdfs:comment 'Current lifecycle status of the sponsor relationship. Drives workflow routing, activation eligibility, and CRM pipeline reporting. Prospect indicates pre-contract; active indicates a live deal; suspended indicates a temporary hold; terminated indicates a closed relationship.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalProbability rdf:type rdf:Property ;
    rdfs:label 'Renewal Probability' ;
    rdfs:comment 'Estimated probability (0.00–100.00) that the sponsor will renew their agreement at the end of the current contract term. Assessed by the account manager and updated in Salesforce CRM. Used for revenue forecasting and pipeline management.' ;
    rdfs:domain ind:Sponsor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stockTicker rdf:type rdf:Property ;
    rdfs:label 'Stock Ticker' ;
    rdfs:comment 'Exchange-listed stock ticker symbol for publicly traded sponsoring organizations. Used for financial health monitoring, SEC disclosure cross-referencing, and investor relations reporting.' ;
    rdfs:domain ind:Sponsor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valueInKindUsd rdf:type rdf:Property ;
    rdfs:label 'Value In Kind Usd' ;
    rdfs:comment 'Estimated USD value of non-cash contributions provided by the sponsor in lieu of or in addition to cash investment (e.g., product supply, media inventory, technology services). Included in total deal value calculations and EBITDA reporting.' ;
    rdfs:domain ind:Sponsor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wadaComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Wada Compliance Flag' ;
    rdfs:comment 'Indicates whether this sponsor is subject to WADA (World Anti-Doping Agency) compliance requirements due to NIL athlete partnerships or direct involvement in athlete performance programs. Triggers PED (Performance Enhancing Drug) policy review obligations.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:websiteUrl rdf:type rdf:Property ;
    rdfs:label 'Website Url' ;
    rdfs:comment 'Official public website URL of the sponsoring organization or brand. Used for digital activation link-throughs, brand verification, and partner directory listings.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceObligationId rdf:type rdf:Property ;
    rdfs:label 'Compliance Obligation Id' ;
    rdfs:comment 'Foreign key linking to compliance.obligation. Business justification: Sponsorship deals create specific compliance obligations (WADA NIL rules, FCC broadcast disclosure, GDPR data sharing). Linking a deal to its primary compliance obligation enables obligation tracking,' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Obligation .

ind:fanSegmentId rdf:type rdf:Property ;
    rdfs:label 'Fan Segment Id' ;
    rdfs:comment 'Foreign key linking this targeting commitment to the fan segment being targeted under the sponsorship deal.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Segment .

ind:governingBodyId rdf:type rdf:Property ;
    rdfs:label 'Governing Body Id' ;
    rdfs:comment 'Foreign key linking to compliance.governing_body. Business justification: Sponsorship deals (naming rights, broadcast integrations, NIL) must comply with the rules of the relevant governing body (NFL, FIFA, FCC). Deal managers need to know which governing body\'s rules apply' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GoverningBody .

ind:jurisdictionId rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Id' ;
    rdfs:comment 'Foreign key linking to gaming.gaming_jurisdiction. Business justification: Sponsorship deals with betting operators are jurisdiction-scoped — activations are only permitted in jurisdictions where the operator holds a license. Compliance teams validate deal activations agains' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Jurisdiction .

ind:activationDeliverablesSummary rdf:type rdf:Property ;
    rdfs:label 'Activation Deliverables Summary' ;
    rdfs:comment 'High-level summary of the key activation deliverables committed under this deal (e.g., jersey patch, LED signage, broadcast mentions, social media posts, hospitality packages). Supports fulfillment tracking and partner reporting.' ;
    rdfs:domain ind:Deal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:annualContractValue rdf:type rdf:Property ;
    rdfs:label 'Annual Contract Value' ;
    rdfs:comment 'Annualized monetary value of the sponsorship deal, derived from TCV divided by contract term years. Used for ARR reporting, budget planning in Workday Adaptive Planning, and year-over-year comparisons.' ;
    rdfs:domain ind:Deal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:arpuImpactEstimate rdf:type rdf:Property ;
    rdfs:label 'Arpu Impact Estimate' ;
    rdfs:comment 'Estimated incremental ARPU attributable to the digital sponsorship activation, expressed in deal currency. Used for DTC and OTT partnership ROI modeling and Workday Adaptive Planning forecasts.' ;
    rdfs:domain ind:Deal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:audienceCommitmentSize rdf:type rdf:Property ;
    rdfs:label 'Audience Commitment Size' ;
    rdfs:comment 'The contractually committed number of fan profiles from this segment that the deal is obligated to reach during the targeting flight window. This is a per-segment-per-deal contractual figure that belongs to the targeting relationship, not to the deal total or the segment\'s overall fan_count.' ;
    rdfs:domain ind:Deal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:audienceDeliveryStatus rdf:type rdf:Property ;
    rdfs:label 'Audience Delivery Status' ;
    rdfs:comment 'Current fulfillment state of the audience commitment for this segment-deal pairing. Tracks whether the contractual audience reach obligation is being met. Belongs to the targeting relationship — a segment may be fully delivered under one deal while underdelivered under another simultaneously.' ;
    rdfs:domain ind:Deal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:broadcastMentionRequirement rdf:type rdf:Property ;
    rdfs:label 'Broadcast Mention Requirement' ;
    rdfs:comment 'Contractual specification for how and how often the sponsor or named asset must be verbally or visually referenced during broadcast coverage (e.g., \'Minimum 3 verbal mentions per broadcast hour\'). Applicable to naming rights and broadcast integration deals.' ;
    rdfs:domain ind:Sponsorship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:campaignFlightEndDate rdf:type rdf:Property ;
    rdfs:label 'Campaign Flight End Date' ;
    rdfs:comment 'End date of the active campaign flight period for digital partnership activations. Defines the window during which impression and CTR commitments must be fulfilled.' ;
    rdfs:domain ind:Deal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:campaignFlightStartDate rdf:type rdf:Property ;
    rdfs:label 'Campaign Flight Start Date' ;
    rdfs:comment 'Start date of the active campaign flight period for digital partnership activations. May differ from the overall deal start date if the digital campaign runs within a sub-window of the contract term.' ;
    rdfs:domain ind:Deal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contractDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Contract Document Reference' ;
    rdfs:comment 'Reference identifier or URL to the executed contract document stored in the document management system. Enables audit trail and legal review access for SOX and SEC compliance.' ;
    rdfs:domain ind:Deal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ctrTarget rdf:type rdf:Property ;
    rdfs:label 'Ctr Target' ;
    rdfs:comment 'Contractually committed click-through rate target for digital sponsorship activations, expressed as a decimal proportion (e.g., 0.0250 = 2.50%). Applicable to digital platform partnership deals. Used for performance benchmarking and ROI reporting.' ;
    rdfs:domain ind:Deal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dataSharingConsentScope rdf:type rdf:Property ;
    rdfs:label 'Data Sharing Consent Scope' ;
    rdfs:comment 'GDPR/CCPA-compliant scope of fan data that may be shared with the sponsor under this deal. Governs data exchange in digital platform partnerships and Adobe Experience Platform personalization activations. Values: none, anonymized_aggregate, pseudonymized, identified_opt_in, full_consent.' ;
    rdfs:domain ind:Deal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dealName rdf:type rdf:Property ;
    rdfs:label 'Deal Name' ;
    rdfs:comment 'Human-readable commercial name of the sponsorship deal (e.g., \'Acme Corp Jersey Sponsorship 2025\', \'GlobalBank Arena Naming Rights\'). Used in reporting, presentations, and CRM.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:digitalPartnershipType rdf:type rdf:Property ;
    rdfs:label 'Digital Partnership Type' ;
    rdfs:comment 'Sub-classification of digital platform partnership deals. Specifies the nature of the digital activation: app title sponsor, OTT streaming sponsor, social media co-branding, DTC campaign integration, API data partnership, or Adobe Experience Platform personalization. Values: app_title_sponsor, ott_streaming_sponsor, social_media_co_branding, dtc_campaign_integration, api_data_partnership, adobe_personalization.' ;
    rdfs:domain ind:Deal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:digitalPropertyUrl rdf:type rdf:Property ;
    rdfs:label 'Digital Property Url' ;
    rdfs:comment 'Web URL of the digital property associated with the deal, such as a renamed stadium website, OTT platform landing page, or DTC campaign microsite. Applicable to naming rights and digital platform partnership deals.' ;
    rdfs:domain ind:Deal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exclusivityScope rdf:type rdf:Property ;
    rdfs:label 'Exclusivity Scope' ;
    rdfs:comment 'Geographic or organizational scope of the sponsor\'s exclusivity rights. Determines where competing sponsors in the same category may not be activated. Values: global, national, regional, local, league, team, event. [ENUM-REF-CANDIDATE: global|national|regional|local|league|team|event — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:executedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Executed Timestamp' ;
    rdfs:comment 'Date and time at which the sponsorship deal was formally executed (signed by all parties). Represents the principal business event timestamp for this agreement. Used for revenue recognition and legal effective date tracking.' ;
    rdfs:domain ind:Deal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:grpCommitment rdf:type rdf:Property ;
    rdfs:label 'Grp Commitment' ;
    rdfs:comment 'Total Gross Rating Points (GRP) committed to the sponsor for broadcast and media activations under this deal. GRP = Reach % × Frequency. Used for broadcast integration performance tracking and ROI reporting.' ;
    rdfs:domain ind:Sponsorship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hospitalityEntitlements rdf:type rdf:Property ;
    rdfs:label 'Hospitality Entitlements' ;
    rdfs:comment 'Description of VIP hospitality entitlements included in the deal (e.g., number of suite tickets, GA tickets, VIP passes, meet-and-greet access per event). Managed through Archtics venue inventory.' ;
    rdfs:domain ind:Deal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impressionCommitment rdf:type rdf:Property ;
    rdfs:label 'Impression Commitment' ;
    rdfs:comment 'Total number of guaranteed digital or broadcast impressions committed to the sponsor under the deal terms. Used for CPM and GRP performance tracking and ROI reporting.' ;
    rdfs:domain ind:Deal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ipRightsIncluded rdf:type rdf:Property ;
    rdfs:label 'Ip Rights Included' ;
    rdfs:comment 'Indicates whether the deal grants the sponsor rights to use Sports Entertainment\'s Intellectual Property (IP), including logos, trademarks, team marks, and league marks in their own marketing and advertising.' ;
    rdfs:domain ind:Deal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:namedAsset rdf:type rdf:Property ;
    rdfs:label 'Named Asset' ;
    rdfs:comment 'For venue naming rights deals: the specific asset whose name is being licensed to the sponsor (e.g., stadium, arena, practice facility, trophy, award, league division). Null or \'none\' for non-naming-rights deal types. [ENUM-REF-CANDIDATE: stadium|arena|practice_facility|trophy|award|league_division|none — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Deal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nilRightsIncluded rdf:type rdf:Property ;
    rdfs:label 'Nil Rights Included' ;
    rdfs:comment 'Indicates whether the deal includes Name, Image, and Likeness (NIL) rights for athletes or talent associated with the sponsoring entity\'s activations. Relevant for athlete endorsement components of sponsorship deals.' ;
    rdfs:domain ind:Deal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:paymentScheduleType rdf:type rdf:Property ;
    rdfs:label 'Payment Schedule Type' ;
    rdfs:comment 'Defines the contractual payment cadence for the deal\'s total contract value. Drives accounts receivable scheduling in SAP S/4HANA FI and cash flow forecasting in Workday Adaptive Planning.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalOptionDeadline rdf:type rdf:Property ;
    rdfs:label 'Renewal Option Deadline' ;
    rdfs:comment 'Date by which the sponsor must exercise their contractual renewal option. Null if renewal_option_flag is false. Drives CRM renewal pipeline alerts in Salesforce.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:renewalOptionFlag rdf:type rdf:Property ;
    rdfs:label 'Renewal Option Flag' ;
    rdfs:comment 'Indicates whether the deal includes a contractual renewal option clause that grants the sponsor the right of first refusal or automatic renewal at defined terms.' ;
    rdfs:domain ind:Sponsorship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:renewalOptionTerms rdf:type rdf:Property ;
    rdfs:label 'Renewal Option Terms' ;
    rdfs:comment 'Summary description of the contractual renewal option terms, including any escalation clauses, right-of-first-refusal conditions, or pricing adjustments applicable upon renewal.' ;
    rdfs:domain ind:Sponsorship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesforceOpportunityCode rdf:type rdf:Property ;
    rdfs:label 'Salesforce Opportunity Code' ;
    rdfs:comment 'Reference to the originating opportunity record in Salesforce CRM (Fan and Sponsor Relationship Management). Enables traceability from prospecting through deal execution.' ;
    rdfs:domain ind:Deal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signageSpecification rdf:type rdf:Property ;
    rdfs:label 'Signage Specification' ;
    rdfs:comment 'Description of physical or digital signage deliverables committed under the deal, including placement locations, dimensions, and display frequency (e.g., \'LED perimeter board, 4 placements, 30-second rotation\'). Applicable to venue and broadcast deals.' ;
    rdfs:domain ind:Deal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stage rdf:type rdf:Property ;
    rdfs:label 'Stage' ;
    rdfs:comment 'Current lifecycle stage of the sponsorship deal from initial prospecting through renewal. Drives pipeline reporting and revenue recognition scheduling. Values: prospecting, negotiation, executed, active, expired, renewed.' ;
    rdfs:domain ind:Deal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetingPriority rdf:type rdf:Property ;
    rdfs:label 'Targeting Priority' ;
    rdfs:comment 'The priority rank of this fan segment within the deal\'s overall audience targeting strategy. Indicates whether this segment is the primary audience commitment or a supplemental targeting layer. Belongs to the relationship, not to the deal or segment independently.' ;
    rdfs:domain ind:Deal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:territory rdf:type rdf:Property ;
    rdfs:label 'Territory' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code representing the primary territory in which the sponsorship deal is active and rights are granted. For multi-territory deals, references the primary market.' ;
    rdfs:domain ind:Deal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalContractValue rdf:type rdf:Property ;
    rdfs:label 'Total Contract Value' ;
    rdfs:comment 'Total committed monetary value of the sponsorship deal across its full term, expressed in the deal currency. Key metric for pipeline valuation, EBITDA forecasting, and ARR reporting.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dealTermId rdf:type rdf:Property ;
    rdfs:label 'Deal Term Id' ;
    rdfs:comment 'Unique surrogate identifier for a sponsorship deal term record in the Silver Layer lakehouse. Primary key for this entity.' ;
    rdfs:domain ind:Sponsorship ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DealTerm .

ind:productCategoryId rdf:type rdf:Property ;
    rdfs:label 'Product Category Id' ;
    rdfs:comment 'Foreign key linking to merchandise.product_category. Business justification: Sponsorship deal terms contractually specify which merchandise product categories are covered by exclusivity or licensing rights (e.g., apparel rights vs. hard goods). Linking deal_term to product_cat' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProductCategory .

ind:activationDeliverableCount rdf:type rdf:Property ;
    rdfs:label 'Activation Deliverable Count' ;
    rdfs:comment 'Total number of distinct brand activation deliverables committed under this deal term (e.g., in-venue signage placements, broadcast integrations, digital content pieces, hospitality events). Drives activation fulfillment tracking.' ;
    rdfs:domain ind:DealTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:broadcastIntegrationType rdf:type rdf:Property ;
    rdfs:label 'Broadcast Integration Type' ;
    rdfs:comment 'Specifies the type of broadcast integration deliverable included in this deal term. Virtual_led = virtual pitch-side LED branding; on_screen_graphic = branded lower-third or overlay; presenter_mention = verbal sponsor mention by broadcaster; sponsored_segment = branded content segment; halftime_show = halftime entertainment sponsorship; replay_sponsor = branded replay sequence. Null if term_type is not broadcast_integration.' ;
    rdfs:domain ind:DealTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cashFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Cash Fee Amount' ;
    rdfs:comment 'The portion of the total contract fee to be paid in cash by the sponsor. Distinguishes cash from Value-in-Kind (VIK) contributions for revenue recognition and EBITDA reporting purposes.' ;
    rdfs:domain ind:DealTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:disputeResolutionMechanism rdf:type rdf:Property ;
    rdfs:label 'Dispute Resolution Mechanism' ;
    rdfs:comment 'The contractually agreed mechanism for resolving disputes arising under this deal term. Arbitration typically references CAS (Court of Arbitration for Sport) or ICC; litigation refers to national courts; mediation is non-binding; expert_determination applies to technical valuation disputes.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationBasis rdf:type rdf:Property ;
    rdfs:label 'Escalation Basis' ;
    rdfs:comment 'The basis on which the escalation rate is calculated. Fixed_rate applies a predetermined percentage; cpi_linked ties escalation to the Consumer Price Index; revenue_linked ties it to the organization\'s revenue growth; negotiated means the rate is renegotiated at each interval.' ;
    rdfs:domain ind:DealTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationRatePct rdf:type rdf:Property ;
    rdfs:label 'Escalation Rate Pct' ;
    rdfs:comment 'Annual percentage rate by which the contract fee escalates over the term (e.g., 3.00 = 3% per annum). Supports multi-year deal modeling and SAP S/4HANA SD billing plan escalation configuration. Null if no escalation clause applies.' ;
    rdfs:domain ind:DealTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:forceMajeureClauseFlag rdf:type rdf:Property ;
    rdfs:label 'Force Majeure Clause Flag' ;
    rdfs:comment 'Indicates whether this deal term contains a force majeure clause that suspends or modifies obligations in the event of extraordinary circumstances beyond either party\'s control (e.g., pandemic, natural disaster, government prohibition of events). True = force majeure clause present.' ;
    rdfs:domain ind:DealTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:governingLawJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Governing Law Jurisdiction' ;
    rdfs:comment 'Three-letter ISO 3166-1 Alpha-3 country code identifying the legal jurisdiction whose laws govern this deal term in the event of a dispute (e.g., USA, GBR, CHE). Determines applicable regulatory frameworks including GDPR, CCPA, and local contract law.' ;
    rdfs:domain ind:DealTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grpDeliveryCommitment rdf:type rdf:Property ;
    rdfs:label 'Grp Delivery Commitment' ;
    rdfs:comment 'The contractually committed Gross Rating Point (GRP) delivery target for broadcast or media placements associated with this deal term. GRP measures the total advertising weight delivered to the target audience. Used for ROI tracking and make-good calculations.' ;
    rdfs:domain ind:DealTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:invoiceMilestoneCount rdf:type rdf:Property ;
    rdfs:label 'Invoice Milestone Count' ;
    rdfs:comment 'Total number of billing milestones or invoice installments defined under this deal term\'s payment schedule. Used to validate completeness of the SAP S/4HANA SD billing plan and track invoicing progress.' ;
    rdfs:domain ind:DealTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ipRightsGrantedFlag rdf:type rdf:Property ;
    rdfs:label 'Ip Rights Granted Flag' ;
    rdfs:comment 'Indicates whether this deal term grants the sponsor rights to use the organization\'s Intellectual Property (IP) — including logos, trademarks, athlete likenesses, and league marks — in their own marketing and advertising. True = IP rights granted; False = no IP rights granted. Relevant to NIL (Name, Image, and Likeness) compliance.' ;
    rdfs:domain ind:DealTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jerseyPlacementLocation rdf:type rdf:Property ;
    rdfs:label 'Jersey Placement Location' ;
    rdfs:comment 'Specifies the physical location on the team kit where the sponsor\'s branding is placed under a jersey sponsorship deal term. Null if term_type is not jersey_sponsorship. [ENUM-REF-CANDIDATE: front_chest|back_upper|sleeve_left|sleeve_right|collar|shorts|training_kit|goalkeeper_kit — promote to reference product]' ;
    rdfs:domain ind:DealTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:killClauseFlag rdf:type rdf:Property ;
    rdfs:label 'Kill Clause Flag' ;
    rdfs:comment 'Indicates whether this deal term contains a kill clause (early termination right) that either party may invoke upon breach of defined thresholds. True = kill clause present; False = no kill clause.' ;
    rdfs:domain ind:DealTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:killClauseThreshold rdf:type rdf:Property ;
    rdfs:label 'Kill Clause Threshold' ;
    rdfs:comment 'Narrative description of the specific condition or metric threshold that triggers the kill clause (e.g., \'Sponsor brand NPS falls below 20\', \'Broadcast audience drops below 500,000 for 2 consecutive events\', \'Regulatory sanction imposed on either party\'). Null if kill_clause_flag is False.' ;
    rdfs:domain ind:DealTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Updated Timestamp' ;
    rdfs:comment 'System timestamp recording when this deal term record was most recently modified in the lakehouse Silver Layer. Supports change data capture, audit trail, and SOX compliance.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:latePaymentPenaltyRatePct rdf:type rdf:Property ;
    rdfs:label 'Late Payment Penalty Rate Pct' ;
    rdfs:comment 'Annual percentage rate applied to overdue sponsor payments as a contractual late payment penalty (e.g., 1.50 = 1.5% per annum on outstanding balance). Null if no late payment penalty clause exists. Used in SAP S/4HANA FI dunning configuration.' ;
    rdfs:domain ind:DealTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:namingRightsAsset rdf:type rdf:Property ;
    rdfs:label 'Naming Rights Asset' ;
    rdfs:comment 'Description of the specific asset (venue, stadium, arena, event, competition, or league) for which naming rights are granted under this deal term (e.g., \'Main Stadium — Exterior and Interior Branding\', \'Annual Championship Series\'). Null if term_type is not naming_rights.' ;
    rdfs:domain ind:DealTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nilAthleteRightsFlag rdf:type rdf:Property ;
    rdfs:label 'Nil Athlete Rights Flag' ;
    rdfs:comment 'Indicates whether this deal term specifically includes Name, Image, and Likeness (NIL) rights for one or more individual athletes, allowing the sponsor to use athlete identity in commercial activations. True = NIL rights included; False = no individual athlete NIL rights.' ;
    rdfs:domain ind:DealTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:performanceBonusAmount rdf:type rdf:Property ;
    rdfs:label 'Performance Bonus Amount' ;
    rdfs:comment 'Additional monetary amount payable by the sponsor upon achievement of defined performance milestones (e.g., team reaching playoffs, broadcast audience exceeding GRP threshold, NPS target met). Null if no performance bonus clause exists.' ;
    rdfs:domain ind:DealTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:performanceBonusTrigger rdf:type rdf:Property ;
    rdfs:label 'Performance Bonus Trigger' ;
    rdfs:comment 'Narrative description of the specific performance condition(s) that must be met to trigger the performance bonus payment (e.g., \'Team qualifies for championship final\', \'Broadcast CPM exceeds $25 for 3 consecutive quarters\', \'GRP delivery exceeds 500 in target demographic\').' ;
    rdfs:domain ind:DealTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalOptionPeriods rdf:type rdf:Property ;
    rdfs:label 'Renewal Option Periods' ;
    rdfs:comment 'Number of additional renewal periods the sponsor may exercise under the renewal option clause (e.g., 2 = two additional one-year terms). Null if renewal_option_flag is False.' ;
    rdfs:domain ind:DealTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rofrFlag rdf:type rdf:Property ;
    rdfs:label 'Rofr Flag' ;
    rdfs:comment 'Indicates whether the sponsor holds a Right of First Refusal (ROFR) on the renewal of this deal term, giving them priority to match any competing offer before the rights are offered to a third party. True = ROFR granted; False = no ROFR.' ;
    rdfs:domain ind:DealTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sapBillingPlanType rdf:type rdf:Property ;
    rdfs:label 'Sap Billing Plan Type' ;
    rdfs:comment 'The SAP S/4HANA SD billing plan type code assigned to this deal term, controlling how and when invoices are generated (e.g., \'01\' for milestone billing, \'02\' for periodic billing). Directly maps to SAP billing plan configuration.' ;
    rdfs:domain ind:DealTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapContractNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Contract Number' ;
    rdfs:comment 'The SAP S/4HANA SD sales contract document number associated with this deal term, used for billing plan integration, invoice generation, and revenue recognition. Enables traceability between the lakehouse Silver Layer and the ERP system of record.' ;
    rdfs:domain ind:DealTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:termReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Term Reference Number' ;
    rdfs:comment 'Externally-known alphanumeric reference code for this deal term record, used in SAP S/4HANA SD billing and contract correspondence. Format: <ORG_CODE>-DT-<SEQUENCE>.' ;
    rdfs:domain ind:DealTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:termStatus rdf:type rdf:Property ;
    rdfs:label 'Term Status' ;
    rdfs:comment 'Current lifecycle state of the deal term. Draft indicates terms under negotiation; active indicates binding and in-force; suspended indicates temporarily paused (e.g., force majeure); terminated indicates early exit via kill clause; expired indicates natural end-of-term; pending_renewal indicates renewal option under evaluation.' ;
    rdfs:domain ind:DealTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:termType rdf:type rdf:Property ;
    rdfs:label 'Term Type' ;
    rdfs:comment 'Classification of the deal term by its commercial nature. Financial covers cash payment obligations; activation covers brand activation deliverables; naming_rights covers venue or event naming; broadcast_integration covers in-broadcast placements; digital_platform covers OTT/DTC digital integrations; jersey_sponsorship covers kit branding rights. [ENUM-REF-CANDIDATE: financial|activation|naming_rights|broadcast_integration|digital_platform|jersey_sponsorship|merchandise_licensing|hospitality — promote to reference product]' ;
    rdfs:domain ind:DealTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalContractFee rdf:type rdf:Property ;
    rdfs:label 'Total Contract Fee' ;
    rdfs:comment 'Gross total monetary value of this deal term over its full effective period, expressed in the contract currency. Represents the face value of the sponsorship obligation before any escalation, bonus, or VIK adjustments. Key input for EBITDA and ARR reporting.' ;
    rdfs:domain ind:DealTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vikAmount rdf:type rdf:Property ;
    rdfs:label 'Vik Amount' ;
    rdfs:comment 'The portion of the total contract fee fulfilled through non-cash Value-in-Kind (VIK) contributions such as goods, services, media inventory, or hospitality provided by the sponsor. Tracked separately from cash for accounting and ROI analysis.' ;
    rdfs:domain ind:DealTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vikDescription rdf:type rdf:Property ;
    rdfs:label 'Vik Description' ;
    rdfs:comment 'Narrative description of the non-cash Value-in-Kind (VIK) goods or services provided by the sponsor as part of their contractual obligation (e.g., \'Official airline partner — 500 business class flights per season\', \'Official vehicle fleet — 50 SUVs for event logistics\').' ;
    rdfs:domain ind:Sponsorship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:activationEventFixtureId rdf:type rdf:Property ;
    rdfs:label 'Activation Event Fixture Id' ;
    rdfs:comment 'Reference to the specific sporting or entertainment event at which this activation is scheduled or was delivered.' ;
    rdfs:domain ind:Activation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Fixture .

ind:activationFixtureId rdf:type rdf:Property ;
    rdfs:label 'Activation Fixture Id' ;
    rdfs:comment 'Reference to the specific sporting or entertainment event at which this activation is scheduled or was delivered.' ;
    rdfs:domain ind:Activation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Fixture .

ind:broadcastChannelId rdf:type rdf:Property ;
    rdfs:label 'Broadcast Channel Id' ;
    rdfs:comment 'Foreign key linking to broadcast.channel. Business justification: Sponsorship activations (virtual overlays, branded segments, ad insertions) are delivered on specific broadcast channels. Channel attributes (ad_insertion_enabled, platform_type, territory) govern act' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Channel .

ind:creativeAssetId rdf:type rdf:Property ;
    rdfs:label 'Creative Asset Id' ;
    rdfs:comment 'Foreign key linking to content.asset. Business justification: Activation managers must link each activation to its approved creative asset in the DAM for brand safety review, FCC disclosure verification, and proof-of-performance audits. No existing FK covers act' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Asset .

ind:namingRightId rdf:type rdf:Property ;
    rdfs:label 'Naming Right Id' ;
    rdfs:comment 'Foreign key linking to sponsorship.naming_right. Business justification: sponsorship_activation has a naming_rights: BOOLEAN flag indicating when an activation is of the naming rights type. When naming_rights=true, the activation should reference the specific naming_right ' ;
    rdfs:domain ind:Sponsorship ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NamingRight .

ind:activationCode rdf:type rdf:Property ;
    rdfs:label 'Activation Code' ;
    rdfs:comment 'Externally-known alphanumeric reference code for this activation deliverable, used in deal documentation, invoicing, and partner communications.' ;
    rdfs:domain ind:Activation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:activationName rdf:type rdf:Property ;
    rdfs:label 'Activation Name' ;
    rdfs:comment 'Human-readable name or title of the brand activation deliverable (e.g., \'Halftime Show Title Sponsor Billboard\', \'Jersey Sleeve Patch — Season 2025\').' ;
    rdfs:domain ind:Activation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:activationType rdf:type rdf:Property ;
    rdfs:label 'Activation Type' ;
    rdfs:comment 'The specific commercial activation format applied to this deal\'s coverage of this betting market — e.g., branded odds feed, broadcast mention during live in-play, or co-branded market name. Belongs to the activation record, not to the deal or market independently.' ;
    rdfs:domain ind:Sponsorship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:airtimeSeconds rdf:type rdf:Property ;
    rdfs:label 'Airtime Seconds' ;
    rdfs:comment 'Contracted or delivered airtime duration in seconds for broadcast and audio activations (e.g., 30-second billboard, 15-second PA announcement).' ;
    rdfs:domain ind:Activation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contractedImpressions rdf:type rdf:Property ;
    rdfs:label 'Contracted Impressions' ;
    rdfs:comment 'The number of guaranteed impressions committed for this specific deal-market combination. Distinct from the deal-level impression_commitment on the deal master, which aggregates across all market activations.' ;
    rdfs:domain ind:Activation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contractedQuantity rdf:type rdf:Property ;
    rdfs:label 'Contracted Quantity' ;
    rdfs:comment 'Number of activation units committed in the sponsorship deal (e.g., number of broadcast spots, number of in-venue signage placements, number of social posts).' ;
    rdfs:domain ind:Activation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contractedValue rdf:type rdf:Property ;
    rdfs:label 'Contracted Value' ;
    rdfs:comment 'Monetary value attributed to this individual activation deliverable as allocated from the parent sponsorship deal. Used for ROI tracking and revenue recognition.' ;
    rdfs:domain ind:Activation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deliveredQuantity rdf:type rdf:Property ;
    rdfs:label 'Delivered Quantity' ;
    rdfs:comment 'Actual number of activation units delivered to date. Compared against contracted_quantity to determine fulfillment rate and identify shortfalls.' ;
    rdfs:domain ind:Activation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:drmCompliant rdf:type rdf:Property ;
    rdfs:label 'Drm Compliant' ;
    rdfs:comment 'Indicates whether the digital activation asset has been verified as compliant with DRM (Digital Rights Management) policies, including IP licensing and content protection requirements.' ;
    rdfs:domain ind:Activation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fccDisclosureRequired rdf:type rdf:Property ;
    rdfs:label 'Fcc Disclosure Required' ;
    rdfs:comment 'Indicates whether this broadcast activation requires a sponsorship identification disclosure per FCC regulations (47 CFR §317 and §507). Mandatory for paid broadcast integrations.' ;
    rdfs:domain ind:Activation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fccDisclosureText rdf:type rdf:Property ;
    rdfs:label 'Fcc Disclosure Text' ;
    rdfs:comment 'Exact on-air or on-screen disclosure text required by FCC regulations for this broadcast activation (e.g., \'Paid for by [Sponsor Name]\'). Null if FCC disclosure is not required.' ;
    rdfs:domain ind:Activation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grpContracted rdf:type rdf:Property ;
    rdfs:label 'Grp Contracted' ;
    rdfs:comment 'Gross Rating Points committed in the sponsorship deal for broadcast activations. GRP = Reach % × Frequency, used for broadcast media valuation.' ;
    rdfs:domain ind:Sponsorship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:grpDelivered rdf:type rdf:Property ;
    rdfs:label 'Grp Delivered' ;
    rdfs:comment 'Actual Gross Rating Points delivered for broadcast activations as measured post-airing. Used for sponsor ROI reporting and make-good calculations.' ;
    rdfs:domain ind:Sponsorship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:impressionsContracted rdf:type rdf:Property ;
    rdfs:label 'Impressions Contracted' ;
    rdfs:comment 'Number of audience impressions (CPM basis) committed in the sponsorship deal for this activation. Used for GRP/CPM performance measurement.' ;
    rdfs:domain ind:Sponsorship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:impressionsDelivered rdf:type rdf:Property ;
    rdfs:label 'Impressions Delivered' ;
    rdfs:comment 'Actual audience impressions delivered for this activation as measured by third-party or internal analytics. Compared against contracted impressions for ROI reporting.' ;
    rdfs:domain ind:Sponsorship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:jerseyPlacementPosition rdf:type rdf:Property ;
    rdfs:label 'Jersey Placement Position' ;
    rdfs:comment 'Specific position on the athlete kit where the sponsor brand appears. Applicable only for jersey/kit channel activations.' ;
    rdfs:domain ind:Activation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:kitManufacturer rdf:type rdf:Property ;
    rdfs:label 'Kit Manufacturer' ;
    rdfs:comment 'Name of the official kit/apparel manufacturer (e.g., Nike, Adidas, Under Armour) relevant for jersey placement activations, as kit manufacturer approval may be required per CBA or league rules.' ;
    rdfs:domain ind:Activation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketCategoryExclusivity rdf:type rdf:Property ;
    rdfs:label 'Market Category Exclusivity' ;
    rdfs:comment 'Indicates whether the sponsoring brand holds exclusive rights within this betting market category under this deal. Cannot reside on deal (which spans many categories) nor on betting_market (which is a shared catalog definition).' ;
    rdfs:domain ind:Activation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:namingRights rdf:type rdf:Property ;
    rdfs:label 'Naming Rights' ;
    rdfs:comment 'Indicates whether this activation constitutes or is associated with a venue or event naming rights arrangement.' ;
    rdfs:domain ind:Activation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:placementDimensions rdf:type rdf:Property ;
    rdfs:label 'Placement Dimensions' ;
    rdfs:comment 'Physical or pixel dimensions of the activation placement (e.g., \'3m x 1m\', \'728x90px\', \'30s airtime\'). Supports fulfillment verification and creative asset compliance.' ;
    rdfs:domain ind:Activation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:placementLocation rdf:type rdf:Property ;
    rdfs:label 'Placement Location' ;
    rdfs:comment 'Specific physical or digital location of the activation (e.g., \'North End Zone LED Board Row 1\', \'Left Sleeve\', \'Pre-Roll Slot — ESPN OTT\', \'Homepage Banner Position 1\').' ;
    rdfs:domain ind:Sponsorship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proofOfPerformanceUrl rdf:type rdf:Property ;
    rdfs:label 'Proof Of Performance Url' ;
    rdfs:comment 'URL or DAM (Digital Asset Management) reference link to the proof-of-performance documentation (photos, broadcast clips, screenshots) confirming activation delivery.' ;
    rdfs:domain ind:Activation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsibleTeam rdf:type rdf:Property ;
    rdfs:label 'Responsible Team' ;
    rdfs:comment 'Internal business team or department accountable for delivering this activation (e.g., \'Broadcast Partnerships\', \'In-Venue Operations\', \'Digital Marketing\', \'Merchandise & Licensing\').' ;
    rdfs:domain ind:Activation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledEndDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled End Date' ;
    rdfs:comment 'Planned date on which the activation deliverable is scheduled to conclude (e.g., last game of season, campaign end date).' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scheduledStartDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Start Date' ;
    rdfs:comment 'Planned date on which the activation deliverable is scheduled to begin (e.g., first game of season, campaign launch date).' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sponsorApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Sponsor Approval Status' ;
    rdfs:comment 'Status of the sponsor\'s review and approval of the activation creative assets and placement specifications prior to delivery.' ;
    rdfs:domain ind:Activation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sponsorApprovedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Sponsor Approved Timestamp' ;
    rdfs:comment 'Date and time when the sponsor formally approved the activation creative and placement specifications.' ;
    rdfs:domain ind:Activation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sponsorshipActivationCategory rdf:type rdf:Property ;
    rdfs:label 'Sponsorship Activation Category' ;
    rdfs:comment 'High-level classification of the activation type. [ENUM-REF-CANDIDATE: in_venue_signage|jersey_placement|broadcast_billboard|virtual_led_overlay|sponsored_segment|branded_replay|digital_banner|social_media_post|experiential|naming_rights_display|pa_announcement|led_perimeter_board|halftime_show_integration|broadcast_integration — promote to reference product]' ;
    rdfs:domain ind:Activation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:virtualOverlay rdf:type rdf:Property ;
    rdfs:label 'Virtual Overlay' ;
    rdfs:comment 'Indicates whether this activation uses virtual LED overlay technology (digitally inserted signage visible only in broadcast, not physically present in venue).' ;
    rdfs:domain ind:Activation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:visibilityTier rdf:type rdf:Property ;
    rdfs:label 'Visibility Tier' ;
    rdfs:comment 'Commercial tier indicating the prominence and audience reach of the placement (Premium = highest visibility/CPM, Standard, Value = lowest).' ;
    rdfs:domain ind:Activation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:activationFulfillmentId rdf:type rdf:Property ;
    rdfs:label 'Activation Fulfillment Id' ;
    rdfs:comment 'Unique surrogate identifier for each brand activation fulfillment record in the sponsorship domain. Primary key for this transactional entity.' ;
    rdfs:domain ind:ActivationFulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:audienceRatingId rdf:type rdf:Property ;
    rdfs:label 'Audience Rating Id' ;
    rdfs:comment 'Foreign key linking to broadcast.audience_rating. Business justification: Activation fulfillment tracks grp_achieved, cpm_realized, and audience_reach. These values are sourced from audience_rating measurement records. Linking provides the measurement record that validates ' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AudienceRating .

ind:inventoryAllocationId rdf:type rdf:Property ;
    rdfs:label 'Inventory Allocation Id' ;
    rdfs:comment 'Foreign key linking to sponsorship.inventory_allocation. Business justification: activation_fulfillment records the actual proof-of-performance execution for a brand activation. inventory_allocation is the transactional record linking specific ad inventory units to deals and activ' ;
    rdfs:domain ind:Sponsorship ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InventoryAllocation .

ind:primaryActivationEventFixtureId rdf:type rdf:Property ;
    rdfs:label 'Primary Activation Event Fixture Id' ;
    rdfs:comment 'Reference to the sports or entertainment event during which this activation was fulfilled (e.g., game, concert, match). Nullable for non-event-tied digital or broadcast activations.' ;
    rdfs:domain ind:ActivationFulfillment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Fixture .

ind:primarySponsorshipActivationId rdf:type rdf:Property ;
    rdfs:label 'Primary Sponsorship Activation Id' ;
    rdfs:comment 'Reference to the parent brand activation deliverable that this fulfillment record is executing against. Links fulfillment to the contracted activation obligation.' ;
    rdfs:domain ind:ActivationFulfillment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Activation .

ind:audienceDemographicTarget rdf:type rdf:Property ;
    rdfs:label 'Audience Demographic Target' ;
    rdfs:comment 'The contracted target demographic segment for this activation (e.g., \'Adults 18-49\', \'Males 25-54\', \'Households with income >$75K\'). Used to assess whether delivered impressions matched the sponsor\'s intended audience profile.' ;
    rdfs:domain ind:ActivationFulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:audienceReach rdf:type rdf:Property ;
    rdfs:label 'Audience Reach' ;
    rdfs:comment 'Estimated number of unique individuals reached by this activation fulfillment, distinct from total impressions which may count repeat exposures. Used alongside GRP to calculate frequency and assess campaign effectiveness.' ;
    rdfs:domain ind:ActivationFulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:brandSafetyCompliant rdf:type rdf:Property ;
    rdfs:label 'Brand Safety Compliant' ;
    rdfs:comment 'Indicates whether the activation fulfillment met all brand safety requirements as defined in the sponsorship contract (e.g., no adjacency to prohibited content, correct placement context). Critical for broadcast and digital channel fulfillments.' ;
    rdfs:domain ind:ActivationFulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:broadcastLogTimestamp rdf:type rdf:Property ;
    rdfs:label 'Broadcast Log Timestamp' ;
    rdfs:comment 'The precise timestamp recorded in the broadcast transmission log (Dalet Galaxy) confirming the exact air time of the sponsored content or advertisement. Used for broadcast fulfillment verification and FCC compliance documentation.' ;
    rdfs:domain ind:ActivationFulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:cpmContracted rdf:type rdf:Property ;
    rdfs:label 'Cpm Contracted' ;
    rdfs:comment 'The Cost Per Mille (CPM) rate contractually agreed with the sponsor, representing the cost per 1,000 impressions. Confidential commercial term used to calculate the monetary value of delivered impressions and assess ROI.' ;
    rdfs:domain ind:ActivationFulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cpmRealized rdf:type rdf:Property ;
    rdfs:label 'Cpm Realized' ;
    rdfs:comment 'The effective Cost Per Mille (CPM) achieved based on actual impressions delivered versus the contracted value. Calculated as (contract_value / impressions_delivered) * 1000. Used in ROI reporting and renewal pricing benchmarking.' ;
    rdfs:domain ind:Sponsorship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fulfillmentChannel rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Channel' ;
    rdfs:comment 'The media or physical channel through which the brand activation was delivered to the audience. Broadcast covers linear TV/radio; OTT covers streaming platforms; digital covers web/app; social covers social media platforms; in_venue covers physical stadium/arena placements. [ENUM-REF-CANDIDATE: broadcast|in_venue|digital|social|ott|print|podcast|out_of_home — promote to reference product if additional channels are added]' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fulfillmentQualityRating rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Quality Rating' ;
    rdfs:comment 'Numeric quality score (1.0 to 5.0) assigned to this activation fulfillment based on placement prominence, brand safety compliance, creative execution fidelity, and audience alignment. Used in sponsor satisfaction reporting and renewal scoring.' ;
    rdfs:domain ind:ActivationFulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fulfillmentReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Reference Number' ;
    rdfs:comment 'Externally-known alphanumeric business identifier for this fulfillment record, used in proof-of-performance reports, sponsor invoices, and renewal negotiations. Format: ACT-FUL-YYYYMMDD-XXXX.' ;
    rdfs:domain ind:ActivationFulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fulfillmentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Timestamp' ;
    rdfs:comment 'Precise date and time at which the activation was executed, including timezone offset. Used for broadcast log reconciliation, OTT stream timestamping, and in-venue display scheduling verification.' ;
    rdfs:domain ind:ActivationFulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:fulfillmentValueUsd rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Value Usd' ;
    rdfs:comment 'The monetary value attributed to this specific activation fulfillment in US Dollars, derived from the contracted rate and delivered impressions. Used for revenue recognition, sponsor invoicing, and EBITDA reporting under SAP S/4HANA FI/CO.' ;
    rdfs:domain ind:ActivationFulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:grpAchieved rdf:type rdf:Property ;
    rdfs:label 'Grp Achieved' ;
    rdfs:comment 'Actual Gross Rating Points (GRP) delivered for this activation fulfillment as reported by the audience measurement provider. Compared against grp_contracted to determine fulfillment compliance and trigger make-good obligations.' ;
    rdfs:domain ind:ActivationFulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:makegoodRequired rdf:type rdf:Property ;
    rdfs:label 'Makegood Required' ;
    rdfs:comment 'Indicates whether a make-good (compensatory activation) is required due to under-delivery against contracted impressions or GRP targets. True triggers a make-good workflow in Salesforce CRM for scheduling a replacement activation.' ;
    rdfs:domain ind:ActivationFulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:proofOfPlayReference rdf:type rdf:Property ;
    rdfs:label 'Proof Of Play Reference' ;
    rdfs:comment 'Unique identifier or URI pointing to the proof-of-performance artifact (e.g., screenshot filename, broadcast log timestamp key, photo asset ID in DAM, or OTT stream clip reference). Used to substantiate fulfillment claims in sponsor reporting and dispute resolution.' ;
    rdfs:domain ind:ActivationFulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proofType rdf:type rdf:Property ;
    rdfs:label 'Proof Type' ;
    rdfs:comment 'Classification of the proof-of-performance artifact submitted for this fulfillment. Determines the verification workflow and the level of evidentiary weight assigned during sponsor audit or dispute resolution.' ;
    rdfs:domain ind:ActivationFulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shortfallImpressions rdf:type rdf:Property ;
    rdfs:label 'Shortfall Impressions' ;
    rdfs:comment 'The gap between contracted impressions and delivered impressions (impressions_contracted minus impressions_delivered). Positive values indicate under-delivery triggering make-good obligations. Zero or negative values indicate full or over-delivery.' ;
    rdfs:domain ind:ActivationFulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:shortfallNotes rdf:type rdf:Property ;
    rdfs:label 'Shortfall Notes' ;
    rdfs:comment 'Free-text explanation of any under-delivery or fulfillment gap, including root cause (e.g., event cancellation, broadcast preemption, technical failure, weather). Used in sponsor communications, make-good planning, and renewal negotiations.' ;
    rdfs:domain ind:ActivationFulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sponsorAcknowledged rdf:type rdf:Property ;
    rdfs:label 'Sponsor Acknowledged' ;
    rdfs:comment 'Indicates whether the sponsor has formally acknowledged and accepted this fulfillment record as proof-of-performance. True enables revenue recognition and closes the fulfillment obligation in SAP S/4HANA.' ;
    rdfs:domain ind:ActivationFulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sponsorAcknowledgementDate rdf:type rdf:Property ;
    rdfs:label 'Sponsor Acknowledgement Date' ;
    rdfs:comment 'Date on which the sponsor formally acknowledged and accepted the fulfillment proof-of-performance. Nullable until acknowledgement is received. Used as the trigger date for revenue recognition and invoice generation.' ;
    rdfs:domain ind:ActivationFulfillment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:verificationDate rdf:type rdf:Property ;
    rdfs:label 'Verification Date' ;
    rdfs:comment 'Date on which the fulfillment record was formally verified and approved by the responsible party or third-party measurement provider. Marks the transition from \'pending\' to \'fulfilled\' or \'shortfall\' status.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:propertyId rdf:type rdf:Property ;
    rdfs:label 'Property Id' ;
    rdfs:comment 'Foreign key linking to sponsorship.property. Business justification: A naming right agreement is fundamentally tied to a specific property (stadium, arena, field, etc.). The naming_right table has named_asset_name and named_asset_type as free-text attributes, but the p' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Property .

ind:activationBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Activation Budget Amount' ;
    rdfs:comment 'Total budget allocated by the sponsor for brand activation activities associated with the naming rights agreement (events, promotions, fan engagement, digital campaigns). Tracked in SAP S/4HANA CO.' ;
    rdfs:domain ind:NamingRight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:agreementNumber rdf:type rdf:Property ;
    rdfs:label 'Agreement Number' ;
    rdfs:comment 'Externally-known contract or deal reference number assigned by the commercial/legal team and used in Salesforce CRM and SAP S/4HANA SD module to uniquely identify this naming rights agreement across systems.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agreementStatus rdf:type rdf:Property ;
    rdfs:label 'Agreement Status' ;
    rdfs:comment 'Current lifecycle state of the naming rights agreement. Drives operational workflows including signage activation, broadcast mention compliance, and renewal outreach. Valid values: draft, active, suspended, expired, terminated, pending_renewal.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agreementType rdf:type rdf:Property ;
    rdfs:label 'Agreement Type' ;
    rdfs:comment 'Classification of the named asset category covered by this agreement. Distinguishes stadium/arena naming rights from trophy, league division, award, practice facility, or digital property naming rights. [ENUM-REF-CANDIDATE: venue_naming_right|trophy_naming_right|division_naming_right|award_naming_right|practice_facility|digital_property — promote to reference product]' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:annualFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Annual Fee Amount' ;
    rdfs:comment 'Annual fee payable by the naming rights holder to the rights owner, as stipulated in the agreement. Used for annual revenue recognition and Workday Adaptive Planning financial forecasting.' ;
    rdfs:domain ind:NamingRight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:broadcastMentionCountMin rdf:type rdf:Property ;
    rdfs:label 'Broadcast Mention Count Min' ;
    rdfs:comment 'Minimum number of on-air brand mentions of the named asset\'s sponsor name contractually required per broadcast event or season, as specified in the naming rights agreement.' ;
    rdfs:domain ind:NamingRight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:digitalUrl rdf:type rdf:Property ;
    rdfs:label 'Digital Url' ;
    rdfs:comment 'The official digital property URL (website or primary digital destination) for the named asset reflecting the sponsor\'s brand, as required by the naming rights agreement.' ;
    rdfs:domain ind:NamingRight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:digitalUrlChangeRequired rdf:type rdf:Property ;
    rdfs:label 'Digital Url Change Required' ;
    rdfs:comment 'Indicates whether the naming rights agreement requires changes to digital property URLs (website domains, social media handles, app store listings) to reflect the sponsor\'s brand name.' ;
    rdfs:domain ind:NamingRight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:disputeResolutionBody rdf:type rdf:Property ;
    rdfs:label 'Dispute Resolution Body' ;
    rdfs:comment 'Name of the arbitration or dispute resolution body specified in the naming rights agreement for resolving contractual disputes (e.g., CAS - Court of Arbitration for Sport, ICC International Court of Arbitration).' ;
    rdfs:domain ind:NamingRight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feeCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Fee Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code in which the naming rights fees are denominated (e.g., USD, GBP, EUR). Required for multi-currency financial consolidation in SAP S/4HANA.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feeEscalationRate rdf:type rdf:Property ;
    rdfs:label 'Fee Escalation Rate' ;
    rdfs:comment 'Annual percentage rate at which the naming rights fee escalates over the term of the agreement (e.g., 0.0300 = 3% per annum). Used in Workday Adaptive Planning for multi-year revenue projections.' ;
    rdfs:domain ind:NamingRight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gdprCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Gdpr Compliant Flag' ;
    rdfs:comment 'Indicates whether the data processing activities associated with this naming rights agreement (fan data used in activation campaigns) have been reviewed for GDPR compliance. Relevant for EU market activations.' ;
    rdfs:domain ind:NamingRight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:governingLawCountry rdf:type rdf:Property ;
    rdfs:label 'Governing Law Country' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the jurisdiction whose laws govern the naming rights agreement. Relevant for dispute resolution and compliance with local regulations.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ipRightsIncludedFlag rdf:type rdf:Property ;
    rdfs:label 'Ip Rights Included Flag' ;
    rdfs:comment 'Indicates whether the naming rights agreement grants the sponsor Intellectual Property (IP) usage rights, such as the right to use league logos, team marks, or event trademarks in their own marketing.' ;
    rdfs:domain ind:NamingRight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:namedAssetName rdf:type rdf:Property ;
    rdfs:label 'Named Asset Name' ;
    rdfs:comment 'The official branded name of the asset as it appears publicly following the naming rights agreement (e.g., \'Acme Arena\', \'TechCorp Stadium\'). This is the name used in all broadcast mentions, signage, and digital properties.' ;
    rdfs:domain ind:NamingRight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:namedAssetPriorName rdf:type rdf:Property ;
    rdfs:label 'Named Asset Prior Name' ;
    rdfs:comment 'The name of the asset prior to the current naming rights agreement. Used for historical reference, fan communications, and transition period signage management.' ;
    rdfs:domain ind:NamingRight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:namedAssetType rdf:type rdf:Property ;
    rdfs:label 'Named Asset Type' ;
    rdfs:comment 'Category of the physical or intangible property subject to the naming rights. Determines applicable signage, broadcast, and digital obligations. [ENUM-REF-CANDIDATE: stadium|arena|practice_facility|trophy|award|league_division|digital_property|broadcast_segment — promote to reference product]' ;
    rdfs:domain ind:NamingRight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nilComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Nil Compliance Flag' ;
    rdfs:comment 'Indicates whether the naming rights agreement has been reviewed and confirmed compliant with applicable Name Image and Likeness (NIL) regulations, particularly relevant when athlete names or likenesses are incorporated into the named asset branding.' ;
    rdfs:domain ind:NamingRight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:roiTargetPct rdf:type rdf:Property ;
    rdfs:label 'Roi Target Pct' ;
    rdfs:comment 'Contractually agreed or internally benchmarked Return on Investment (ROI) target percentage for the naming rights agreement, used to evaluate sponsor value delivery and guide renewal negotiations.' ;
    rdfs:domain ind:NamingRight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:signageCount rdf:type rdf:Property ;
    rdfs:label 'Signage Count' ;
    rdfs:comment 'Total number of physical and digital signage units contractually required to display the sponsor\'s brand name under the naming rights agreement.' ;
    rdfs:domain ind:NamingRight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:signageSpecDescription rdf:type rdf:Property ;
    rdfs:label 'Signage Spec Description' ;
    rdfs:comment 'Detailed description of the physical and digital signage obligations under the naming rights agreement, including placement locations, dimensions, illumination requirements, and brand standards compliance.' ;
    rdfs:domain ind:NamingRight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:soxReportableFlag rdf:type rdf:Property ;
    rdfs:label 'Sox Reportable Flag' ;
    rdfs:comment 'Indicates whether this naming rights agreement meets the materiality threshold requiring disclosure under SOX financial controls for public company reporting. Drives inclusion in SEC financial reporting.' ;
    rdfs:domain ind:NamingRight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:termYears rdf:type rdf:Property ;
    rdfs:label 'Term Years' ;
    rdfs:comment 'Total contractual duration of the naming rights agreement expressed in whole years. Supports long-term revenue planning and renewal pipeline management.' ;
    rdfs:domain ind:NamingRight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:terminationClauseFlag rdf:type rdf:Property ;
    rdfs:label 'Termination Clause Flag' ;
    rdfs:comment 'Indicates whether the agreement contains an early termination clause allowing either party to exit the agreement before the effective end date under defined conditions.' ;
    rdfs:domain ind:NamingRight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:terminationFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Termination Fee Amount' ;
    rdfs:comment 'Contractual penalty or fee payable upon early termination of the naming rights agreement. Expressed in the contract currency. Applicable only when termination_clause_flag is True.' ;
    rdfs:domain ind:NamingRight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Total Fee Amount' ;
    rdfs:comment 'Total contractual value of the naming rights agreement over the full term, expressed in the contract currency. Used for financial reporting under SAP S/4HANA FI/CO and SOX compliance disclosures.' ;
    rdfs:domain ind:NamingRight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:adInventoryId rdf:type rdf:Property ;
    rdfs:label 'Ad Inventory Id' ;
    rdfs:comment 'Unique surrogate identifier for each sponsorship and advertising inventory asset record in the master catalog. Primary key for the sponsorship_ad_inventory product.' ;
    rdfs:domain ind:Sponsorship ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AdInventory .

ind:inventoryUnitId rdf:type rdf:Property ;
    rdfs:label 'Inventory Unit Id' ;
    rdfs:comment 'Foreign key linking to sponsorship.inventory_unit. Business justification: sponsorship_ad_inventory is the catalog of available sponsorship and advertising inventory assets. inventory_unit is the master reference table defining the unit types, formats, pricing benchmarks, an' ;
    rdfs:domain ind:Sponsorship ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InventoryUnit .

ind:assessedValuePerUnit rdf:type rdf:Property ;
    rdfs:label 'Assessed Value Per Unit' ;
    rdfs:comment 'The independently assessed fair market value of a single unit of this inventory asset, expressed in the valuation currency. Represents the SSOT for what each asset unit is worth in the current market. Used as the floor price in sponsor negotiations and for ROI (Return on Investment) reporting.' ;
    rdfs:domain ind:AdInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assetCode rdf:type rdf:Property ;
    rdfs:label 'Asset Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying the inventory asset across all Sports Entertainment properties and Salesforce CRM. Used in sponsor proposals, contracts, and activation briefs as the canonical asset reference.' ;
    rdfs:domain ind:AdInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetName rdf:type rdf:Property ;
    rdfs:label 'Asset Name' ;
    rdfs:comment 'Human-readable name of the inventory asset (e.g., \'Main Pitch LED Perimeter Board East Side\', \'OTT Pre-Roll 30s Slot — League Pass App\', \'Naming Rights Unit — North Stand\'). Used in sales decks, activation plans, and reporting.' ;
    rdfs:domain ind:AdInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:audienceDemographicProfile rdf:type rdf:Property ;
    rdfs:label 'Audience Demographic Profile' ;
    rdfs:comment 'Description of the primary audience demographic profile associated with this inventory asset (e.g., \'Male 18-34, ABC1, sports enthusiast\', \'Family audience, mixed gender, 25-54\'). Sourced from Adobe Experience Platform fan analytics or Nielsen audience measurement. Used in sponsor targeting and CPM justification.' ;
    rdfs:domain ind:AdInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:availabilityStatus rdf:type rdf:Property ;
    rdfs:label 'Availability Status' ;
    rdfs:comment 'Current availability state of the inventory asset in the sponsorship sales lifecycle. \'available\' indicates the asset is open for sale; \'sold\' indicates it is committed to a sponsor; \'reserved\' indicates a hold pending contract execution; \'held\' indicates a short-term sales hold; \'retired\' indicates the asset is no longer offered; \'pending_approval\' indicates the asset is awaiting internal sign-off before listing.' ;
    rdfs:domain ind:AdInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cpmBenchmark rdf:type rdf:Property ;
    rdfs:label 'Cpm Benchmark' ;
    rdfs:comment 'The industry benchmark CPM (Cost Per Mille) rate for this asset type and channel, expressed in the asset\'s valuation currency. Represents the market cost per 1,000 impressions used to benchmark assessed value against industry norms. Sourced from Nielsen, independent agency, or Sports Entertainment commercial intelligence.' ;
    rdfs:domain ind:AdInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:effectiveToDate rdf:type rdf:Property ;
    rdfs:label 'Effective To Date' ;
    rdfs:comment 'The date after which this inventory asset record is no longer valid or available for sale. Null indicates the record is currently active. Used for temporal versioning and historical audit of the inventory catalog.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:estimatedImpressions rdf:type rdf:Property ;
    rdfs:label 'Estimated Impressions' ;
    rdfs:comment 'Estimated number of audience impressions delivered per unit activation of this inventory asset, based on Nielsen media measurement, broadcast ratings, or venue attendance data. Used as the primary input for CPM (Cost Per Mille) valuation and GRP (Gross Rating Point) calculations in sponsor proposals.' ;
    rdfs:domain ind:AdInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:eventTypeEligibility rdf:type rdf:Property ;
    rdfs:label 'Event Type Eligibility' ;
    rdfs:comment 'Defines the types of events for which this inventory asset is eligible to be activated (e.g., \'regular_season\', \'playoffs\', \'finals\', \'international\', \'concert\', \'all\'). Restricts asset availability to appropriate event contexts and supports event-specific packaging.' ;
    rdfs:domain ind:AdInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gdprDataUsageFlag rdf:type rdf:Property ;
    rdfs:label 'Gdpr Data Usage Flag' ;
    rdfs:comment 'Indicates whether activation of this inventory asset involves the collection or processing of fan personal data (True), triggering GDPR (General Data Protection Regulation) or CCPA compliance obligations. Applicable to digital assets such as in-app banners, OTT pre-rolls, and personalized digital overlays that use fan behavioral data for targeting.' ;
    rdfs:domain ind:AdInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:grpRating rdf:type rdf:Property ;
    rdfs:label 'Grp Rating' ;
    rdfs:comment 'The GRP (Gross Rating Point) value assigned to this inventory asset, representing the percentage of the target audience reached multiplied by the average frequency of exposure. Used for broadcast and media inventory valuation and sponsor ROI (Return on Investment) reporting. Sourced from Nielsen or independent agency assessment.' ;
    rdfs:domain ind:AdInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:internalOwnerTeam rdf:type rdf:Property ;
    rdfs:label 'Internal Owner Team' ;
    rdfs:comment 'The internal Sports Entertainment business unit or team responsible for managing and selling this inventory asset (e.g., \'Global Partnerships\', \'Broadcast Sales\', \'Venue Commercial\', \'Digital Partnerships\'). Used for revenue attribution, KPI (Key Performance Indicator) reporting, and workflow routing.' ;
    rdfs:domain ind:AdInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isBroadcastIntegrated rdf:type rdf:Property ;
    rdfs:label 'Is Broadcast Integrated' ;
    rdfs:comment 'Indicates whether this inventory asset is integrated into a broadcast or OB (Outside Broadcast) production feed (True), meaning it appears in the televised or streamed broadcast of an event. Broadcast-integrated assets carry higher CPM values and are subject to FCC broadcast regulation and RSN (Regional Sports Network) rights restrictions.' ;
    rdfs:domain ind:AdInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isDigital rdf:type rdf:Property ;
    rdfs:label 'Is Digital' ;
    rdfs:comment 'Indicates whether this inventory asset is a digital placement (True) or a physical/static placement (False). Digital assets include OTT pre-rolls, in-app banners, digital overlays, and social media posts. Physical assets include static signage, LED boards, and naming rights plaques. Drives DRM (Digital Rights Management) and DAM (Digital Asset Management) workflow routing.' ;
    rdfs:domain ind:AdInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isNamingRights rdf:type rdf:Property ;
    rdfs:label 'Is Naming Rights' ;
    rdfs:comment 'Indicates whether this inventory asset represents a naming rights unit (True), such as a venue naming rights package or a competition naming rights package. Naming rights assets have distinct legal, IP (Intellectual Property), and valuation characteristics and require separate governance approval.' ;
    rdfs:domain ind:AdInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:listPricePerUnit rdf:type rdf:Property ;
    rdfs:label 'List Price Per Unit' ;
    rdfs:comment 'The standard published list price for a single unit of this inventory asset, expressed in the valuation currency. Represents the starting price point in sponsor negotiations before any package discounts or deal-specific adjustments. Distinct from assessed_value_per_unit which reflects independent market valuation.' ;
    rdfs:domain ind:AdInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxUnitsPerSponsor rdf:type rdf:Property ;
    rdfs:label 'Max Units Per Sponsor' ;
    rdfs:comment 'The maximum number of units of this inventory asset that a single sponsor may purchase, enforcing competitive separation and preventing monopolization of high-visibility placements. Null indicates no per-sponsor cap.' ;
    rdfs:domain ind:AdInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minCommitmentUnits rdf:type rdf:Property ;
    rdfs:label 'Min Commitment Units' ;
    rdfs:comment 'The minimum number of units a sponsor must purchase to activate this inventory asset. Enforces commercial packaging rules and prevents sub-economic placements. For example, a broadcast billboard may require a minimum of 10 spots per broadcast.' ;
    rdfs:domain ind:AdInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:placementLocationDescription rdf:type rdf:Property ;
    rdfs:label 'Placement Location Description' ;
    rdfs:comment 'Detailed description of the physical or digital placement location of the inventory asset (e.g., \'East perimeter board, pitch-side, between 18-yard box and halfway line\', \'Pre-roll slot on League Pass OTT app home screen\', \'North Stand fascia, upper tier\'). Provides the specificity required for activation briefs and sponsor approval.' ;
    rdfs:domain ind:AdInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionSpecNotes rdf:type rdf:Property ;
    rdfs:label 'Production Spec Notes' ;
    rdfs:comment 'Technical production specifications and creative requirements for this inventory asset, such as artwork dimensions, file format requirements, broadcast safe zones, LED pixel pitch, audio specifications for PA announcements, or digital ad unit specifications (IAB standards). Used by the activation and production teams.' ;
    rdfs:domain ind:AdInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sponsorCategory rdf:type rdf:Property ;
    rdfs:label 'Sponsor Category' ;
    rdfs:comment 'The industry or product category of the sponsor occupying or targeted for this inventory asset (e.g., automotive, financial services, beverage, technology, insurance, apparel). Used for competitive exclusivity enforcement and category-based inventory packaging. [ENUM-REF-CANDIDATE: automotive|financial_services|beverage|technology|insurance|apparel|healthcare|telecommunications|retail|energy — promote to reference product]' ;
    rdfs:domain ind:AdInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitCount rdf:type rdf:Property ;
    rdfs:label 'Unit Count' ;
    rdfs:comment 'Total number of discrete units available for this inventory asset type at the associated property. For example, the number of LED perimeter board panels, the number of OTT pre-roll slots per broadcast, or the number of PA announcement slots per event. Drives capacity planning and sell-through rate analysis.' ;
    rdfs:domain ind:AdInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:unitDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Unit Duration Seconds' ;
    rdfs:comment 'Duration in seconds of a single inventory unit for time-based assets such as broadcast billboards, OTT pre-roll slots, PA announcements, and digital overlays. Null for non-time-based assets such as naming rights or jersey patches. Standard broadcast durations include 15, 30, and 60 seconds.' ;
    rdfs:domain ind:AdInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:valuationCurrency rdf:type rdf:Property ;
    rdfs:label 'Valuation Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code in which the assessed value per unit and CPM benchmark are denominated (e.g., USD, GBP, EUR). Supports multi-currency operations across global Sports Entertainment markets.' ;
    rdfs:domain ind:AdInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valuationDate rdf:type rdf:Property ;
    rdfs:label 'Valuation Date' ;
    rdfs:comment 'The date on which the current assessed value per unit was determined. Used to track valuation currency and trigger re-valuation workflows when the valuation exceeds the maximum age threshold defined by Sports Entertainment commercial policy.' ;
    rdfs:domain ind:AdInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:valuationMethodology rdf:type rdf:Property ;
    rdfs:label 'Valuation Methodology' ;
    rdfs:comment 'The methodology used to derive the assessed value per unit for this inventory asset. \'broadcast_equivalency\' values the asset based on equivalent broadcast airtime cost; \'nielsen_media_value\' uses Nielsen-measured audience data; \'independent_agency\' reflects a third-party agency appraisal; \'internal_assessment\' reflects Sports Entertainment commercial team valuation; \'comparable_market\' uses comparable asset transactions.' ;
    rdfs:domain ind:AdInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valuationSource rdf:type rdf:Property ;
    rdfs:label 'Valuation Source' ;
    rdfs:comment 'The name of the organization or system that provided the assessed value (e.g., \'Nielsen Sports\', \'Repucom\', \'Two Circles\', \'Sports Entertainment Internal Commercial Team\', \'Octagon\'). Provides audit traceability for valuation figures used in sponsor proposals and financial reporting.' ;
    rdfs:domain ind:AdInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:broadcastWindowId rdf:type rdf:Property ;
    rdfs:label 'Broadcast Window Id' ;
    rdfs:comment 'Reference to the broadcast or media window (e.g., pre-game, halftime, post-game, OTT stream slot) during which this inventory allocation is scheduled for delivery.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BroadcastWindow .

ind:originalAllocationInventoryAllocationId rdf:type rdf:Property ;
    rdfs:label 'Original Allocation Inventory Allocation Id' ;
    rdfs:comment 'Reference to the original inventory allocation record that this make-good allocation is compensating for. Populated only when make_good_flag is True. Enables traceability of make-good chains.' ;
    rdfs:domain ind:InventoryAllocation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InventoryAllocation .

ind:primaryInventoryEventFixtureId rdf:type rdf:Property ;
    rdfs:label 'Primary Inventory Event Fixture Id' ;
    rdfs:comment 'Reference to the specific sporting or entertainment event during which this inventory allocation is to be delivered (e.g., match, game, concert, tournament round).' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Fixture .

ind:actualImpressionsDelivered rdf:type rdf:Property ;
    rdfs:label 'Actual Impressions Delivered' ;
    rdfs:comment 'The actual number of audience impressions or exposures recorded upon delivery of this inventory allocation. Compared against impression_target to assess performance and trigger make-good provisions.' ;
    rdfs:domain ind:InventoryAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualQuantityDelivered rdf:type rdf:Property ;
    rdfs:label 'Actual Quantity Delivered' ;
    rdfs:comment 'The actual number of inventory units delivered upon fulfillment of this allocation. Compared against allocated_quantity to determine fulfillment rate and identify make-good obligations.' ;
    rdfs:domain ind:InventoryAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:allocatedQuantity rdf:type rdf:Property ;
    rdfs:label 'Allocated Quantity' ;
    rdfs:comment 'Number of inventory units allocated in this record (e.g., number of broadcast spots, number of digital impressions blocks, number of signage panels). Represents the principal quantitative fact of this allocation transaction.' ;
    rdfs:domain ind:InventoryAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:allocatedValue rdf:type rdf:Property ;
    rdfs:label 'Allocated Value' ;
    rdfs:comment 'The commercial value assigned to this specific inventory allocation, representing the portion of the sponsorship deal\'s total contract value attributable to this unit. Used for revenue recognition, ROI tracking, and deal fulfillment reporting.' ;
    rdfs:domain ind:InventoryAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allocationDate rdf:type rdf:Property ;
    rdfs:label 'Allocation Date' ;
    rdfs:comment 'The calendar date on which this inventory unit was formally allocated to the sponsorship deal or activation. Represents the principal business event date for this transaction.' ;
    rdfs:domain ind:InventoryAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:allocationReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Allocation Reference Number' ;
    rdfs:comment 'Externally-known business identifier for this allocation transaction, used in sponsor-facing communications, fulfillment reports, and cross-system reconciliation (e.g., CRM opportunity line reference, SAP SD delivery order number).' ;
    rdfs:domain ind:InventoryAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationStatus rdf:type rdf:Property ;
    rdfs:label 'Allocation Status' ;
    rdfs:comment 'Current lifecycle state of this inventory allocation. \'reserved\' indicates a hold pending confirmation; \'confirmed\' indicates a committed booking; \'delivered\' indicates fulfillment is complete; \'cancelled\' indicates the allocation was voided; \'pending_approval\' indicates awaiting internal or sponsor sign-off.' ;
    rdfs:domain ind:InventoryAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Allocation Timestamp' ;
    rdfs:comment 'Precise date and time when this inventory allocation record was created in the system, capturing the exact moment of reservation or booking action.' ;
    rdfs:domain ind:InventoryAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:approvalRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Approval Required Flag' ;
    rdfs:comment 'Indicates whether this inventory allocation requires explicit approval from a league governing body, broadcast rights holder, or internal compliance team before it can be confirmed and delivered.' ;
    rdfs:domain ind:InventoryAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:channel rdf:type rdf:Property ;
    rdfs:label 'Channel' ;
    rdfs:comment 'The media or activation channel through which this inventory allocation is delivered (e.g., broadcast TV, OTT streaming, in-venue, digital web, social media). Drives measurement methodology and reporting standards. [ENUM-REF-CANDIDATE: broadcast_tv|ott_streaming|in_venue|digital_web|social_media|mobile_app|radio|print — promote to reference product]' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confirmedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Confirmed Timestamp' ;
    rdfs:comment 'Date and time when this inventory allocation was formally confirmed by both the sponsorship operations team and the sponsor, transitioning from \'reserved\' to \'confirmed\' status.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:deliveryEndDate rdf:type rdf:Property ;
    rdfs:label 'Delivery End Date' ;
    rdfs:comment 'The date by which this inventory allocation must be fully delivered or activated. Defines the closing boundary of the fulfillment window and drives SLA compliance tracking.' ;
    rdfs:domain ind:InventoryAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:deliveryStartDate rdf:type rdf:Property ;
    rdfs:label 'Delivery Start Date' ;
    rdfs:comment 'The date from which this inventory allocation is scheduled to begin delivery or activation. Defines the opening boundary of the fulfillment window.' ;
    rdfs:domain ind:InventoryAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:geographicMarket rdf:type rdf:Property ;
    rdfs:label 'Geographic Market' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code representing the primary geographic market for this inventory allocation. Supports multi-market sponsorship deals and regional rights management.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grpTarget rdf:type rdf:Property ;
    rdfs:label 'Grp Target' ;
    rdfs:comment 'The target Gross Rating Point (GRP) value committed for this inventory allocation, representing the expected audience reach multiplied by frequency. Used for broadcast and media inventory performance measurement and sponsor ROI reporting.' ;
    rdfs:domain ind:InventoryAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:impressionTarget rdf:type rdf:Property ;
    rdfs:label 'Impression Target' ;
    rdfs:comment 'The target number of audience impressions or exposures committed for this inventory allocation. Used for digital and broadcast inventory performance tracking and sponsor proof-of-performance reporting.' ;
    rdfs:domain ind:InventoryAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:makeGoodFlag rdf:type rdf:Property ;
    rdfs:label 'Make Good Flag' ;
    rdfs:comment 'Indicates whether this inventory allocation was created as a make-good (compensatory replacement) for a previously under-delivered or cancelled allocation. Make-goods are contractual obligations to sponsors when original delivery commitments are not met.' ;
    rdfs:domain ind:InventoryAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:placementPosition rdf:type rdf:Property ;
    rdfs:label 'Placement Position' ;
    rdfs:comment 'Specific placement position or location descriptor for this inventory allocation (e.g., \'North End LED Row 1\', \'Halftime Break Slot 2\', \'Homepage Banner Top\', \'Left Sleeve Jersey Patch\'). Provides granular fulfillment and proof-of-performance detail.' ;
    rdfs:domain ind:InventoryAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorityTier rdf:type rdf:Property ;
    rdfs:label 'Priority Tier' ;
    rdfs:comment 'Commercial priority tier assigned to this allocation, reflecting the sponsor\'s deal level and governing conflict resolution when inventory is oversubscribed. Higher tiers receive preferential placement and first-right-of-refusal on premium inventory.' ;
    rdfs:domain ind:InventoryAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateCardValue rdf:type rdf:Property ;
    rdfs:label 'Rate Card Value' ;
    rdfs:comment 'The published or standard rate card value for this inventory unit prior to any negotiated discount or deal adjustment. Enables calculation of discount depth and benchmarking of deal terms against market rates.' ;
    rdfs:domain ind:InventoryAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Unit Of Measure' ;
    rdfs:comment 'The unit in which the allocated quantity is expressed (e.g., \'spots\' for broadcast, \'impressions\' for digital, \'panels\' for venue signage, \'seconds\' for broadcast duration, \'placements\' for jersey or naming rights).' ;
    rdfs:domain ind:Sponsorship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:performanceMetricId rdf:type rdf:Property ;
    rdfs:label 'Performance Metric Id' ;
    rdfs:comment 'Unique surrogate identifier for each sponsorship performance metric record in the Silver Layer lakehouse. Primary key for this transactional measurement entity.' ;
    rdfs:domain ind:PerformanceMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:auditEngagementId rdf:type rdf:Property ;
    rdfs:label 'Audit Engagement Id' ;
    rdfs:comment 'Foreign key linking to compliance.audit_engagement. Business justification: Sponsorship performance metrics (GRP delivery, impression fulfillment) are subject to compliance audit engagements to verify accuracy of reported figures for sponsor ROI reporting. Auditors need to tr' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AuditEngagement .

ind:primaryPerformanceEventFixtureId rdf:type rdf:Property ;
    rdfs:label 'Primary Performance Event Fixture Id' ;
    rdfs:comment 'Reference to the specific sports or entertainment event during which this performance metric was captured, if applicable (e.g., a specific match, concert, or broadcast window).' ;
    rdfs:domain ind:PerformanceMetric ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Fixture .

ind:activationChannel rdf:type rdf:Property ;
    rdfs:label 'Activation Channel' ;
    rdfs:comment 'The specific channel or placement through which the sponsorship was activated and measured. Covers broadcast TV, OTT (Over-The-Top) streaming, in-venue signage, jersey sponsorship, naming rights, digital display, social media, PPV (Pay-Per-View), and other channels. [ENUM-REF-CANDIDATE: broadcast_tv|ott_streaming|in_venue_signage|jersey_sponsorship|naming_rights|digital_display|social_media|print|radio|ppv — promote to reference product]' ;
    rdfs:domain ind:PerformanceMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualValue rdf:type rdf:Property ;
    rdfs:label 'Actual Value' ;
    rdfs:comment 'The measured actual value delivered for this sponsorship KPI during the measurement period. Sourced from third-party measurement providers (Nielsen, Kantar) or internal analytics systems.' ;
    rdfs:domain ind:PerformanceMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:brandRecallScore rdf:type rdf:Property ;
    rdfs:label 'Brand Recall Score' ;
    rdfs:comment 'Unaided or aided brand recall score measured via consumer survey panels (Kantar, Nielsen) during the measurement period. Expressed as a percentage of surveyed audience who recalled the sponsor brand in the context of the sports/entertainment property.' ;
    rdfs:domain ind:PerformanceMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:broadcastAirtimeSeconds rdf:type rdf:Property ;
    rdfs:label 'Broadcast Airtime Seconds' ;
    rdfs:comment 'Total number of seconds of broadcast airtime during which the sponsor\'s brand was visible or mentioned during the measurement period. Tracked via Dalet Galaxy broadcast workflow and third-party monitoring services.' ;
    rdfs:domain ind:PerformanceMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contractedTargetValue rdf:type rdf:Property ;
    rdfs:label 'Contracted Target Value' ;
    rdfs:comment 'The agreed-upon target value for this KPI as stipulated in the sponsorship contract. Serves as the benchmark against which actual performance is measured for fulfillment and ROI reporting.' ;
    rdfs:domain ind:PerformanceMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dataSource rdf:type rdf:Property ;
    rdfs:label 'Data Source' ;
    rdfs:comment 'The originating data source or measurement provider that supplied the actual metric value. Used for data lineage, audit, and credibility assessment in sponsor-facing ROI reports. [ENUM-REF-CANDIDATE: nielsen|kantar|internal_analytics|adobe_experience_platform|social_platform_api|venue_analytics|manual — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSourceReportReference rdf:type rdf:Property ;
    rdfs:label 'Data Source Report Reference' ;
    rdfs:comment 'The external report or file identifier from the measurement data source (e.g., Nielsen report ID, Kantar study reference number) that this metric record was derived from. Enables traceability back to the source measurement report.' ;
    rdfs:domain ind:PerformanceMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:frequency rdf:type rdf:Property ;
    rdfs:label 'Frequency' ;
    rdfs:comment 'Average number of times the target audience was exposed to the sponsorship asset (logo, brand mention, advertisement) during the measurement period. Component of GRP calculation.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:impressions rdf:type rdf:Property ;
    rdfs:label 'Impressions' ;
    rdfs:comment 'Total number of times the sponsor\'s brand asset (logo, advertisement, naming rights mention) was served or displayed across all channels (broadcast, digital, in-venue) during the measurement period.' ;
    rdfs:domain ind:PerformanceMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inVenueDwellTimeSeconds rdf:type rdf:Property ;
    rdfs:label 'In Venue Dwell Time Seconds' ;
    rdfs:comment 'Average number of seconds fans spent in proximity to or engaged with in-venue sponsor activations (branded zones, experiential areas, digital signage) during the measurement period. Captured via venue analytics systems.' ;
    rdfs:domain ind:PerformanceMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isContractedKpi rdf:type rdf:Property ;
    rdfs:label 'Is Contracted Kpi' ;
    rdfs:comment 'Indicates whether this metric corresponds to a formally contracted KPI obligation in the sponsorship agreement (True) or is a supplementary/bonus metric tracked for additional insight (False). Drives fulfillment compliance reporting.' ;
    rdfs:domain ind:PerformanceMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:makeGoodRequired rdf:type rdf:Property ;
    rdfs:label 'Make Good Required' ;
    rdfs:comment 'Indicates whether a make-good (compensatory delivery of additional sponsorship inventory) is required due to under-delivery against the contracted KPI target. Triggers make-good workflow in sponsorship fulfillment operations.' ;
    rdfs:domain ind:PerformanceMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:measurementMethodology rdf:type rdf:Property ;
    rdfs:label 'Measurement Methodology' ;
    rdfs:comment 'The methodology used to capture and validate this performance metric. Determines the reliability and comparability of the measurement. Examples: panel survey (Nielsen/Kantar), set-top box data, digital pixel tracking, AI image recognition for logo exposure, manual audit. [ENUM-REF-CANDIDATE: panel_survey|set_top_box|digital_pixel|manual_audit|ai_image_recognition|third_party_monitor|internal_analytics — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementPeriodEnd rdf:type rdf:Property ;
    rdfs:label 'Measurement Period End' ;
    rdfs:comment 'End date of the measurement window during which the sponsorship KPI data was collected. Together with measurement_period_start defines the reporting interval.' ;
    rdfs:domain ind:PerformanceMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:measurementPeriodStart rdf:type rdf:Property ;
    rdfs:label 'Measurement Period Start' ;
    rdfs:comment 'Start date of the measurement window during which the sponsorship KPI data was collected. Aligns with contracted reporting periods (weekly, monthly, quarterly, seasonal).' ;
    rdfs:domain ind:PerformanceMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:measurementStatus rdf:type rdf:Property ;
    rdfs:label 'Measurement Status' ;
    rdfs:comment 'Current lifecycle state of this performance metric record. Tracks the workflow from initial capture through sponsor verification and final acceptance used in renewal negotiations.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementTimestamp rdf:type rdf:Property ;
    rdfs:label 'Measurement Timestamp' ;
    rdfs:comment 'The precise date and time when this performance metric observation was recorded or ingested from the measurement data source (Nielsen, Kantar, internal analytics platform). Represents the principal real-world event time.' ;
    rdfs:domain ind:PerformanceMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:metricCategory rdf:type rdf:Property ;
    rdfs:label 'Metric Category' ;
    rdfs:comment 'High-level category grouping the metric type for reporting and ROI analysis. Enables aggregation across activation channels (broadcast, digital, in-venue, brand health, social media, print).' ;
    rdfs:domain ind:PerformanceMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:metricReferenceCode rdf:type rdf:Property ;
    rdfs:label 'Metric Reference Code' ;
    rdfs:comment 'Externally-known business identifier for this performance metric record, used in ROI reports, renewal negotiations, and sponsor-facing dashboards. Format: PM-YYYYMMDD-XXXX.' ;
    rdfs:domain ind:PerformanceMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:metricType rdf:type rdf:Property ;
    rdfs:label 'Metric Type' ;
    rdfs:comment 'Classification of the sponsorship KPI being measured. Covers broadcast, digital, in-venue, and brand health metrics. [ENUM-REF-CANDIDATE: grp_delivered|cpm_realized|impressions|reach|frequency|brand_recall_score|nps_lift|social_engagement_rate|broadcast_airtime_seconds|in_venue_dwell_time|jersey_logo_exposure|naming_rights_mention|digital_banner_clicks|share_of_voice — promote to reference product]' ;
    rdfs:domain ind:PerformanceMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:npsLift rdf:type rdf:Property ;
    rdfs:label 'Nps Lift' ;
    rdfs:comment 'Change in Net Promoter Score for the sponsor brand attributable to the sponsorship activation, measured via fan/consumer surveys. Positive values indicate brand sentiment improvement driven by the partnership.' ;
    rdfs:domain ind:PerformanceMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reach000s rdf:type rdf:Property ;
    rdfs:label 'Reach 000s' ;
    rdfs:comment 'Total unique audience reached by the sponsorship activation during the measurement period, expressed in thousands. Sourced from Nielsen or Kantar audience measurement panels.' ;
    rdfs:domain ind:PerformanceMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reportingPeriodType rdf:type rdf:Property ;
    rdfs:label 'Reporting Period Type' ;
    rdfs:comment 'The cadence or granularity of the measurement reporting period. Aligns with contractual reporting obligations to sponsors (weekly, monthly, quarterly, seasonal, annual, or tied to a specific event).' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:socialEngagementRate rdf:type rdf:Property ;
    rdfs:label 'Social Engagement Rate' ;
    rdfs:comment 'Percentage engagement rate for sponsor-related social media content during the measurement period ((likes + comments + shares + saves) / total impressions × 100). Sourced from Adobe Experience Platform social analytics.' ;
    rdfs:domain ind:PerformanceMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sponsorVerified rdf:type rdf:Property ;
    rdfs:label 'Sponsor Verified' ;
    rdfs:comment 'Indicates whether the sponsor has formally reviewed and accepted this performance metric measurement as accurate. Required for final ROI reporting and renewal negotiation documentation.' ;
    rdfs:domain ind:PerformanceMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sponsorVerifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Sponsor Verified Timestamp' ;
    rdfs:comment 'Date and time when the sponsor formally verified and accepted this performance metric measurement. Null if sponsor_verified is False.' ;
    rdfs:domain ind:PerformanceMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:variancePct rdf:type rdf:Property ;
    rdfs:label 'Variance Pct' ;
    rdfs:comment 'Percentage variance of actual performance against the contracted target value ((actual - target) / target * 100). Used in sponsor ROI dashboards and renewal negotiation scorecards.' ;
    rdfs:domain ind:PerformanceMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceValue rdf:type rdf:Property ;
    rdfs:label 'Variance Value' ;
    rdfs:comment 'Absolute difference between actual_value and contracted_target_value (actual minus target). Positive values indicate over-delivery; negative values indicate under-delivery against contracted KPI obligations.' ;
    rdfs:domain ind:PerformanceMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentScheduleId rdf:type rdf:Property ;
    rdfs:label 'Payment Schedule Id' ;
    rdfs:comment 'Unique surrogate identifier for the payment schedule milestone record within the sponsorship domain. Primary key for this entity.' ;
    rdfs:domain ind:PaymentSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:companyCodeId rdf:type rdf:Property ;
    rdfs:label 'Company Code Id' ;
    rdfs:comment 'Foreign key linking to finance.company_code. Business justification: Payment schedules must post to the correct legal entity\'s books for intercompany billing, tax compliance, and SOX reporting. The existing sap_company_code plain attribute is a denormalized code; repla' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CompanyCode .

ind:adjustmentAmount rdf:type rdf:Property ;
    rdfs:label 'Adjustment Amount' ;
    rdfs:comment 'Monetary adjustment applied to the scheduled amount for this milestone, including contractual discounts, performance-based deductions, early payment incentives, or penalty surcharges. Negative values represent reductions; positive values represent surcharges.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costCenterCode rdf:type rdf:Property ;
    rdfs:label 'Cost Center Code' ;
    rdfs:comment 'SAP S/4HANA Controlling (CO) cost center code associated with the business unit responsible for fulfilling the sponsorship obligations tied to this payment milestone. Supports internal profitability analysis and EBITDA reporting.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:daysOverdue rdf:type rdf:Property ;
    rdfs:label 'Days Overdue' ;
    rdfs:comment 'Number of calendar days this payment milestone is past its due_date without confirmed receipt. Calculated as current date minus due_date when payment_status is \'overdue\'. Used for accounts receivable aging buckets and collections escalation triggers.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:disputeRaisedDate rdf:type rdf:Property ;
    rdfs:label 'Dispute Raised Date' ;
    rdfs:comment 'Date on which the sponsor formally raised a dispute for this payment milestone. Null if no dispute has been raised. Used to track dispute resolution SLA compliance and aging.' ;
    rdfs:domain ind:PaymentSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:disputeReason rdf:type rdf:Property ;
    rdfs:label 'Dispute Reason' ;
    rdfs:comment 'Free-text description of the reason provided by the sponsor for disputing this payment milestone. Populated when payment_status is \'disputed\'. Supports dispute resolution tracking and contract management.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dueDate rdf:type rdf:Property ;
    rdfs:label 'Due Date' ;
    rdfs:comment 'Contractually agreed date by which the sponsor must remit this payment milestone. Used for accounts receivable aging, overdue detection, and cash flow forecasting in Workday Adaptive Planning.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dunningDate rdf:type rdf:Property ;
    rdfs:label 'Dunning Date' ;
    rdfs:comment 'Date on which the most recent dunning (collections) notice was issued to the sponsor for this overdue payment milestone. Null if no dunning has been initiated. Used to track collections activity and enforce escalation timelines.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dunningLevel rdf:type rdf:Property ;
    rdfs:label 'Dunning Level' ;
    rdfs:comment 'Current dunning (collections escalation) level for this overdue payment milestone, as managed in SAP S/4HANA FI dunning procedures. Level 0 = no dunning initiated; higher levels indicate escalating collection notices sent to the sponsor.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:earlyPaymentDiscountDate rdf:type rdf:Property ;
    rdfs:label 'Early Payment Discount Date' ;
    rdfs:comment 'Last date by which the sponsor must remit payment to qualify for the early payment discount on this milestone. Null if no early payment discount applies.' ;
    rdfs:domain ind:PaymentSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:earlyPaymentDiscountPct rdf:type rdf:Property ;
    rdfs:label 'Early Payment Discount Pct' ;
    rdfs:comment 'Percentage discount offered to the sponsor for early payment of this milestone, as defined in the payment terms (e.g., 2.00 for a 2% early payment discount). Null if no early payment discount applies.' ;
    rdfs:domain ind:PaymentSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:forecastPeriod rdf:type rdf:Property ;
    rdfs:label 'Forecast Period' ;
    rdfs:comment 'Fiscal quarter in which this payment milestone is expected to be received for cash flow forecasting purposes, formatted as YYYY-Q{N} (e.g., 2025-Q2). Used in Workday Adaptive Planning for sponsorship revenue forecasting and EBITDA projections.' ;
    rdfs:domain ind:PaymentSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceDate rdf:type rdf:Property ;
    rdfs:label 'Invoice Date' ;
    rdfs:comment 'Date on which the invoice was formally issued to the sponsor for this payment milestone. Establishes the billing cycle start for payment terms calculation and revenue recognition timing.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lateFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Late Fee Amount' ;
    rdfs:comment 'Contractual late payment penalty fee assessed against the sponsor for overdue payment of this milestone, as defined in the sponsorship deal terms. Expressed in the deal currency. Zero or null if no late fee applies or has been assessed.' ;
    rdfs:domain ind:PaymentSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:milestoneName rdf:type rdf:Property ;
    rdfs:label 'Milestone Name' ;
    rdfs:comment 'Descriptive label for this payment milestone as defined in the sponsorship contract (e.g., \'Q1 Installment\', \'Season Opener Activation Fee\', \'Signing Bonus\', \'Annual Naming Rights Fee\'). Used in sponsor communications and invoice descriptions.' ;
    rdfs:domain ind:PaymentSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:milestoneSequence rdf:type rdf:Property ;
    rdfs:label 'Milestone Sequence' ;
    rdfs:comment 'Ordinal position of this payment milestone within the overall deal payment schedule (e.g., 1 = first installment, 2 = second installment). Supports chronological ordering and installment tracking.' ;
    rdfs:domain ind:PaymentSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:paymentTermsCode rdf:type rdf:Property ;
    rdfs:label 'Payment Terms Code' ;
    rdfs:comment 'SAP S/4HANA payment terms code governing the due date calculation and early payment discount conditions for this milestone (e.g., \'NET30\', \'NET60\', \'2/10NET30\'). Derived from the sponsorship deal contract terms.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentType rdf:type rdf:Property ;
    rdfs:label 'Payment Type' ;
    rdfs:comment 'Classification of the payment consideration form. \'cash\' = monetary wire/ACH/check; \'VIK\' = Value-In-Kind (goods or services in lieu of cash); \'barter\' = reciprocal exchange of services; \'offset\' = applied against a credit balance; \'credit_note\' = formal credit adjustment. Drives revenue recognition treatment under ASC 606.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profitCenterCode rdf:type rdf:Property ;
    rdfs:label 'Profit Center Code' ;
    rdfs:comment 'SAP S/4HANA Controlling (CO) profit center code for revenue attribution of this payment milestone. Enables segment-level P&L reporting by league, venue, or business unit for management accounting and ROI analysis.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivedAmount rdf:type rdf:Property ;
    rdfs:label 'Received Amount' ;
    rdfs:comment 'Actual amount received from the sponsor for this milestone. May differ from net_amount in cases of partial payment, short payment, or currency conversion variance. Null until payment is received.' ;
    rdfs:domain ind:PaymentSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:receivedDate rdf:type rdf:Property ;
    rdfs:label 'Received Date' ;
    rdfs:comment 'Actual date on which the sponsor\'s payment was confirmed as received and cleared in the bank or SAP FI clearing account. Null when payment has not yet been received. Used for days-sales-outstanding (DSO) calculation and cash flow actuals.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:revenueRecognitionDate rdf:type rdf:Property ;
    rdfs:label 'Revenue Recognition Date' ;
    rdfs:comment 'Date on which the revenue associated with this payment milestone is recognized in the financial statements under ASC 606 / IFRS 15. May differ from the received_date for multi-period or performance-obligation-based sponsorship deals.' ;
    rdfs:domain ind:PaymentSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sapFiDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Fi Document Number' ;
    rdfs:comment 'SAP S/4HANA Financial Accounting document number associated with the accounts receivable posting for this payment milestone. Serves as the primary cross-reference between the sponsorship data product and the general ledger for audit and reconciliation purposes.' ;
    rdfs:domain ind:PaymentSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleNumber rdf:type rdf:Property ;
    rdfs:label 'Schedule Number' ;
    rdfs:comment 'Externally-visible business identifier for this payment schedule milestone, formatted as PS-{YYYY}-{NNNNNN}. Used in sponsor-facing invoices, SAP FI correspondence, and accounts receivable reconciliation.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledAmount rdf:type rdf:Property ;
    rdfs:label 'Scheduled Amount' ;
    rdfs:comment 'Gross contractual amount due for this payment milestone as specified in the sponsorship deal. Represents the base obligation before any adjustments, discounts, or withholding taxes. Expressed in the deal currency.' ;
    rdfs:domain ind:PaymentSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:withholdingTaxAmount rdf:type rdf:Property ;
    rdfs:label 'Withholding Tax Amount' ;
    rdfs:comment 'Amount of withholding tax deducted from this payment milestone by the sponsor, applicable for cross-border sponsorship deals subject to bilateral tax treaties. Impacts net cash received and requires separate GL posting in SAP S/4HANA.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:conferenceId rdf:type rdf:Property ;
    rdfs:label 'Conference Id' ;
    rdfs:comment 'Foreign key linking to league.conference. Business justification: Conference-game classification is essential for standings calculation, scheduling compliance, and broadcast rights (conference vs. non-conference games). Fixture must be tagged to a conference for int' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Conference .

ind:fixtureAwayTeamFranchiseId rdf:type rdf:Property ;
    rdfs:label 'Fixture Away Team Franchise Id' ;
    rdfs:comment 'Reference to the visiting team or secondary performing entity for this fixture. Nullable for non-competitive events such as concerts or award ceremonies.' ;
    rdfs:domain ind:Fixture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Franchise .

ind:fixtureBroadcastChannelId rdf:type rdf:Property ;
    rdfs:label 'Fixture Broadcast Channel Id' ;
    rdfs:comment 'Reference to the primary broadcast network or OTT platform assigned to carry this fixture under media rights agreements. Links to broadcast domain for RSN, national network, and streaming rights activation.' ;
    rdfs:domain ind:Fixture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Channel .

ind:fixtureChannelId rdf:type rdf:Property ;
    rdfs:label 'Fixture Channel Id' ;
    rdfs:comment 'Reference to the primary broadcast network or OTT platform assigned to carry this fixture under media rights agreements. Links to broadcast domain for RSN, national network, and streaming rights activation.' ;
    rdfs:domain ind:Fixture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Channel .

ind:fixtureFranchiseId rdf:type rdf:Property ;
    rdfs:label 'Fixture Franchise Id' ;
    rdfs:comment 'Reference to the home team or primary performing entity for this fixture. Used for scheduling, standings calculation, and home/away revenue split logic in SAP S/4HANA FI/CO.' ;
    rdfs:domain ind:Fixture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Franchise .

ind:actualAttendance rdf:type rdf:Property ;
    rdfs:label 'Actual Attendance' ;
    rdfs:comment 'Verified count of attendees who physically entered the venue for this fixture, reconciled from gate scan data in Ticketmaster/AXS. Used for KPI reporting, revenue reconciliation, and league governance submissions.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual End Timestamp' ;
    rdfs:comment 'The real-world date and time the fixture actually concluded. Used for broadcast rights window compliance, overtime/extra-time tracking, and venue operations post-event reconciliation.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Start Timestamp' ;
    rdfs:comment 'The real-world date and time the fixture actually commenced. Populated post-event for reconciliation, broadcast rights compliance reporting, and performance analytics in SportsCode/Hudl.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:announcedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Announced Timestamp' ;
    rdfs:comment 'Date and time when the fixture was officially announced to the public. Marks the start of the fixture lifecycle and triggers fan engagement and ticketing on-sale countdown workflows in Adobe Experience Platform.' ;
    rdfs:domain ind:Fixture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:attendanceCapacity rdf:type rdf:Property ;
    rdfs:label 'Attendance Capacity' ;
    rdfs:comment 'Maximum approved attendance capacity for this specific fixture, which may differ from the venue\'s total capacity due to configuration, safety restrictions, or event-specific setup. Used for ticketing inventory management in Archtics and ADA compliance reporting.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:awayScore rdf:type rdf:Property ;
    rdfs:label 'Away Score' ;
    rdfs:comment 'Final score or result for the away team or secondary competitor at the conclusion of the fixture. Populated post-event. Nullable for non-competitive events.' ;
    rdfs:domain ind:Fixture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:doorsOpenTimestamp rdf:type rdf:Property ;
    rdfs:label 'Doors Open Timestamp' ;
    rdfs:comment 'Scheduled date and time when venue gates open to ticket holders. Critical for access control configuration in Ticketmaster/AXS gate scan systems and fan arrival experience planning.' ;
    rdfs:domain ind:Fixture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:eventClassification rdf:type rdf:Property ;
    rdfs:label 'Event Classification' ;
    rdfs:comment 'Competition or programming classification of the fixture indicating its governing framework (e.g., league regular season match, cup knockout tie, friendly/exhibition, touring concert). Used for league governance reporting and CBA compliance.' ;
    rdfs:domain ind:Fixture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventTier rdf:type rdf:Property ;
    rdfs:label 'Event Tier' ;
    rdfs:comment 'Competitive tier or significance level of the fixture within its season or tournament structure. Determines pricing strategy, broadcast rights activation, and sponsorship inventory allocation. Drives dynamic pricing rules in Ticketmaster/AXS.' ;
    rdfs:domain ind:Fixture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:extraTimePlayed rdf:type rdf:Property ;
    rdfs:label 'Extra Time Played' ;
    rdfs:comment 'Indicates whether the fixture required extra time or overtime periods beyond regulation. Affects broadcast window compliance, venue operations scheduling, and revenue reconciliation for extended event durations.' ;
    rdfs:domain ind:Fixture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fixtureCode rdf:type rdf:Property ;
    rdfs:label 'Fixture Code' ;
    rdfs:comment 'Externally-known alphanumeric business identifier for the fixture, used in operational systems such as Ticketmaster/AXS, Archtics, and SAP S/4HANA SD. Serves as the cross-system reference key for event scheduling and revenue management workflows.' ;
    rdfs:domain ind:Fixture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fixtureName rdf:type rdf:Property ;
    rdfs:label 'Fixture Name' ;
    rdfs:comment 'Official human-readable name of the fixture as published to fans, broadcasters, and sponsors (e.g., \'NBA Finals Game 7\', \'UFC 300\', \'FIFA World Cup Final\'). Used in ticketing, broadcast schedules, and fan engagement platforms.' ;
    rdfs:domain ind:Fixture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:homeScore rdf:type rdf:Property ;
    rdfs:label 'Home Score' ;
    rdfs:comment 'Final score or result for the home team or primary competitor at the conclusion of the fixture. Populated post-event. Used for standings calculation, WAR (Wins Above Replacement) analytics, and league governance reporting.' ;
    rdfs:domain ind:Fixture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isBroadcastEligible rdf:type rdf:Property ;
    rdfs:label 'Is Broadcast Eligible' ;
    rdfs:comment 'Indicates whether this fixture is eligible for broadcast distribution under existing media rights agreements. Drives activation of broadcast workflows in Dalet Galaxy and content rights management.' ;
    rdfs:domain ind:Fixture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isNeutralSite rdf:type rdf:Property ;
    rdfs:label 'Is Neutral Site' ;
    rdfs:comment 'Indicates whether the fixture is played at a neutral venue with no designated home team advantage. Affects revenue sharing agreements, ticketing allocation rules, and broadcast designation.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:legNumber rdf:type rdf:Property ;
    rdfs:label 'Leg Number' ;
    rdfs:comment 'Leg sequence number for two-legged ties or multi-game series (e.g., Leg 1, Leg 2 of a UEFA tie; Game 3 of an NBA playoff series). Nullable for single-leg fixtures.' ;
    rdfs:domain ind:Fixture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:localTimezone rdf:type rdf:Property ;
    rdfs:label 'Local Timezone' ;
    rdfs:comment 'IANA timezone identifier for the venue\'s local timezone (e.g., \'America/New_York\', \'Europe/London\'). Required for accurate local time display in fan-facing platforms, broadcast scheduling, and ticket delivery.' ;
    rdfs:domain ind:Event ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:matchdayNumber rdf:type rdf:Property ;
    rdfs:label 'Matchday Number' ;
    rdfs:comment 'Sequential matchday or game week number within the season or competition phase (e.g., Matchday 1, Week 12). Used for fixture calendar display, standings calculation, and broadcast scheduling.' ;
    rdfs:domain ind:Fixture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:penaltyShootout rdf:type rdf:Property ;
    rdfs:label 'Penalty Shootout' ;
    rdfs:comment 'Indicates whether the fixture was decided by a penalty shootout or tiebreaker procedure. Used for competition result reporting and broadcast content tagging in Dalet Galaxy.' ;
    rdfs:domain ind:Fixture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:resultStatus rdf:type rdf:Property ;
    rdfs:label 'Result Status' ;
    rdfs:comment 'Official outcome classification of the fixture as determined by the governing body. Distinct from lifecycle_status — this captures the competitive result rather than the operational state. Used for standings, CAS (Court of Arbitration for Sport) appeals, and league governance.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Scheduled End Timestamp' ;
    rdfs:comment 'Planned end date and time of the fixture in UTC. Used for broadcast window allocation, venue turnaround scheduling, and post-event reconciliation triggers in SAP S/4HANA.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scheduledStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Scheduled Start Timestamp' ;
    rdfs:comment 'The principal real-world scheduled date and time when the fixture is planned to begin, stored in UTC with timezone offset. Used as the primary business event timestamp for broadcast scheduling, ticketing on-sale windows, and fan engagement notifications via Adobe Experience Platform.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:surfaceType rdf:type rdf:Property ;
    rdfs:label 'Surface Type' ;
    rdfs:comment 'Type of playing surface used for this fixture. Relevant for athlete injury risk management, CBA (Collective Bargaining Agreement) surface compliance requirements, and performance analytics. [ENUM-REF-CANDIDATE: natural_grass|artificial_turf|hardwood|ice|clay|grass|carpet — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:varUsed rdf:type rdf:Property ;
    rdfs:label 'Var Used' ;
    rdfs:comment 'Indicates whether Video Assistant Referee (VAR) or equivalent video review technology (e.g., TMO in rugby) was deployed during this fixture. Required for competition governance reporting and broadcast production metadata.' ;
    rdfs:domain ind:Fixture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:weatherCondition rdf:type rdf:Property ;
    rdfs:label 'Weather Condition' ;
    rdfs:comment 'Recorded weather condition at the venue during the fixture. Used for performance analytics in SportsCode/Hudl, insurance claims, and post-event operational reporting. \'indoor\' applies to enclosed venues. [ENUM-REF-CANDIDATE: clear|cloudy|rain|snow|fog|extreme_heat|indoor — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calendarGoverningBodyId rdf:type rdf:Property ;
    rdfs:label 'Calendar Governing Body Id' ;
    rdfs:comment 'Reference to the organisational unit or external body responsible for publishing and maintaining the official fixture schedule for this season.' ;
    rdfs:domain ind:Calendar ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GoverningBody .

ind:calendarSchedulingAuthorityGoverningBodyId rdf:type rdf:Property ;
    rdfs:label 'Calendar Scheduling Authority Governing Body Id' ;
    rdfs:comment 'Reference to the organisational unit or external body responsible for publishing and maintaining the official fixture schedule for this season.' ;
    rdfs:domain ind:Calendar ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GoverningBody .

ind:blackoutDates rdf:type rdf:Property ;
    rdfs:label 'Blackout Dates' ;
    rdfs:comment 'Comma-separated list of specific dates on which no fixtures may be scheduled due to regulatory, contractual, or operational constraints (e.g., broadcast blackout windows, public holidays, conflicting major events). Enforced by the scheduling authority.' ;
    rdfs:domain ind:Calendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:byeWeeks rdf:type rdf:Property ;
    rdfs:label 'Bye Weeks' ;
    rdfs:comment 'Comma-separated list of round/week numbers designated as bye weeks (no fixtures scheduled). Relevant primarily for NFL and similar league formats. Used by broadcast schedulers in Dalet Galaxy to fill programming gaps and by venue operations for maintenance windows.' ;
    rdfs:domain ind:Calendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calendarStatus rdf:type rdf:Property ;
    rdfs:label 'Calendar Status' ;
    rdfs:comment 'Current publication status of the fixture calendar. Controls downstream visibility and consumption: \'draft\' is internal only; \'published\' is the official release to broadcast, ticketing, and venue operations; \'amended\' indicates a post-publication revision; \'suspended\' indicates a temporary halt; \'archived\' is end-of-life.' ;
    rdfs:domain ind:Calendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cbaApplicable rdf:type rdf:Property ;
    rdfs:label 'Cba Applicable' ;
    rdfs:comment 'Indicates whether the season schedule is governed by an active Collective Bargaining Agreement (CBA) between the league and players\' association. When true, CBA constraints on game counts, rest days, and travel windows must be validated against the fixture calendar.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gdprApplicable rdf:type rdf:Property ;
    rdfs:label 'Gdpr Applicable' ;
    rdfs:comment 'Indicates whether GDPR data privacy obligations apply to fan and participant data collected during this season, based on the host country and market reach. When true, data processing activities must comply with GDPR Articles 5-7 and fan consent management in Adobe Experience Platform.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hasPlayoffStructure rdf:type rdf:Property ;
    rdfs:label 'Has Playoff Structure' ;
    rdfs:comment 'Indicates whether this season includes a post-season playoff or knockout tournament phase beyond the regular season. When true, playoff-specific broadcast rights, ticketing tiers, and venue contracts are activated.' ;
    rdfs:domain ind:Calendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hostCountryCode rdf:type rdf:Property ;
    rdfs:label 'Host Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the primary host nation for this season (e.g., \'USA\', \'GBR\', \'FRA\'). Determines applicable regulatory frameworks (GDPR, CCPA, local tax), venue safety standards (OSHA, ADA), and broadcast licensing requirements (FCC).' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:internationalWindowDates rdf:type rdf:Property ;
    rdfs:label 'International Window Dates' ;
    rdfs:comment 'Comma-separated list of date ranges reserved for international competition windows (e.g., FIFA international breaks, Olympic qualifying periods) during which domestic league fixtures are suspended. Critical for fixture scheduling compliance with FIFA and IOC calendars.' ;
    rdfs:domain ind:Calendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isInternationalSeason rdf:type rdf:Property ;
    rdfs:label 'Is International Season' ;
    rdfs:comment 'Indicates whether this season includes fixtures played in multiple countries or international markets. When true, multi-jurisdiction regulatory compliance (GDPR, local broadcast licensing, visa/work permit requirements) is triggered.' ;
    rdfs:domain ind:Calendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:numberOfParticipatingTeams rdf:type rdf:Property ;
    rdfs:label 'Number Of Participating Teams' ;
    rdfs:comment 'Total count of teams, clubs, or acts participating in this season. Used for fixture generation, venue capacity planning in Archtics, and broadcast slot allocation. For concert series, represents the number of performing acts.' ;
    rdfs:domain ind:Calendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:playoffFormatDescription rdf:type rdf:Property ;
    rdfs:label 'Playoff Format Description' ;
    rdfs:comment 'Narrative description of the playoff bracket or knockout structure (e.g., \'Single-elimination 12-team bracket\', \'Best-of-7 series, 16 teams\'). Supports broadcast production planning and fan engagement content in Adobe Experience Platform.' ;
    rdfs:domain ind:Calendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:playoffStartDate rdf:type rdf:Property ;
    rdfs:label 'Playoff Start Date' ;
    rdfs:comment 'Scheduled start date of the post-season playoff phase. Null if has_playoff_structure is false. Used to define the playoff broadcast rights window and premium ticketing on-sale dates in Ticketmaster/AXS.' ;
    rdfs:domain ind:Calendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:publicationDate rdf:type rdf:Property ;
    rdfs:label 'Publication Date' ;
    rdfs:comment 'The official date on which the fixture calendar was publicly released by the scheduling authority. Triggers downstream on-sale windows in Ticketmaster/AXS and broadcast scheduling in Dalet Galaxy.' ;
    rdfs:domain ind:Calendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:seasonEndDate rdf:type rdf:Property ;
    rdfs:label 'Season End Date' ;
    rdfs:comment 'Official end date of the competitive or programming season, inclusive of any playoff or championship rounds. Defines the effective-until boundary for broadcast rights, venue contracts, and sponsorship activation periods.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:seasonFormat rdf:type rdf:Property ;
    rdfs:label 'Season Format' ;
    rdfs:comment 'Structural format of the season indicating whether it follows the standard schedule length or a modified format (e.g., shortened due to CBA disputes or COVID, expanded due to league growth). Critical for CBA compliance tracking and broadcast rights valuation.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seasonPhase rdf:type rdf:Property ;
    rdfs:label 'Season Phase' ;
    rdfs:comment 'Current active phase of the season lifecycle. Drives phase-specific business rules across ticketing (Ticketmaster/AXS), broadcast (Dalet Galaxy), and venue operations. \'pre_season\' = warm-up fixtures; \'regular_season\' = main competition; \'post_season\' = playoffs/finals; \'off_season\' = between seasons.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seasonStartDate rdf:type rdf:Property ;
    rdfs:label 'Season Start Date' ;
    rdfs:comment 'Official start date of the competitive or programming season as published by the governing body. Used as the effective-from boundary for broadcast rights windows, ticketing on-sale periods, and venue booking calendars.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:seasonStatus rdf:type rdf:Property ;
    rdfs:label 'Season Status' ;
    rdfs:comment 'Operational lifecycle state of the season itself (distinct from calendar publication status). \'planning\' = pre-season setup; \'active\' = season in progress; \'completed\' = all fixtures concluded; \'cancelled\' = season abandoned; \'suspended\' = temporarily halted (e.g., force majeure, labour dispute).' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seasonYear rdf:type rdf:Property ;
    rdfs:label 'Season Year' ;
    rdfs:comment 'The primary calendar year associated with this season (e.g., 2025). For multi-year seasons (e.g., 2024-25), this represents the start year. Used for year-over-year reporting and financial period alignment in SAP S/4HANA FI/CO.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sourceSystemRecordReference rdf:type rdf:Property ;
    rdfs:label 'Source System Record Reference' ;
    rdfs:comment 'The native primary key or record identifier of this season calendar record in the originating operational system (e.g., SAP S/4HANA season object ID, Archtics season ID). Enables reconciliation and bi-directional traceability between the lakehouse Silver Layer and source systems.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sportEntertainmentType rdf:type rdf:Property ;
    rdfs:label 'Sport Entertainment Type' ;
    rdfs:comment 'High-level classification of the season content type, distinguishing competitive sports leagues from entertainment programming series (e.g., concerts, esports). Drives downstream routing to broadcast, ticketing, and venue operations workflows.' ;
    rdfs:domain ind:Calendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sustainabilityStandard rdf:type rdf:Property ;
    rdfs:label 'Sustainability Standard' ;
    rdfs:comment 'Environmental sustainability standard applied to the management of this season\'s events (e.g., \'ISO_20121\' for ISO 20121 Event Sustainability Management Systems). Supports ESG reporting and venue operations compliance.' ;
    rdfs:domain ind:Calendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tiebreakerRulesReference rdf:type rdf:Property ;
    rdfs:label 'Tiebreaker Rules Reference' ;
    rdfs:comment 'Reference code or document identifier for the official tiebreaker rules applicable to this season\'s standings and playoff qualification (e.g., \'NFL-2024-TIEBREAK-v2\', \'FIFA-RANKING-2024\'). Ensures consistent application of competition governance rules.' ;
    rdfs:domain ind:Calendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalScheduledFixtures rdf:type rdf:Property ;
    rdfs:label 'Total Scheduled Fixtures' ;
    rdfs:comment 'Total number of individual fixtures (games, matches, events, shows) planned across the entire season. Drives capacity planning for ticketing inventory in Archtics and broadcast slot allocation in Dalet Galaxy.' ;
    rdfs:domain ind:Calendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalScheduledRounds rdf:type rdf:Property ;
    rdfs:label 'Total Scheduled Rounds' ;
    rdfs:comment 'Total number of competitive rounds, match weeks, or programming weeks planned for this season. For NFL this represents weeks; for soccer it represents match rounds; for concert series it represents show dates. Used for broadcast slot planning and revenue forecasting in Workday Adaptive Planning.' ;
    rdfs:domain ind:Calendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:varTechnologyEnabled rdf:type rdf:Property ;
    rdfs:label 'Var Technology Enabled' ;
    rdfs:comment 'Indicates whether Video Assistant Referee (VAR) or Television Match Official (TMO) technology is deployed for fixtures in this season. Affects broadcast production requirements, OB (Outside Broadcast) unit specifications, and officiating governance.' ;
    rdfs:domain ind:Calendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:version rdf:type rdf:Property ;
    rdfs:label 'Version' ;
    rdfs:comment 'Version identifier of the fixture calendar (e.g., \'v1.0\', \'v2.3\'). Incremented each time the calendar is amended post-publication. Enables downstream consumers (broadcast, ticketing, venue) to detect and reconcile schedule changes.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wadaComplianceRequired rdf:type rdf:Property ;
    rdfs:label 'Wada Compliance Required' ;
    rdfs:comment 'Indicates whether WADA anti-doping testing protocols are mandated for this season. When true, athlete testing schedules and PED (Performance Enhancing Drug) compliance reporting obligations are activated for all participating athletes.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:actualsAmount rdf:type rdf:Property ;
    rdfs:label 'Actuals Amount' ;
    rdfs:comment 'Actual expenditure or revenue posted against this tournament from this budget line year-to-date. Sourced from detection phase relationship data. Enables tournament-level actuals tracking within the broader budget line.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:adaComplianceStatus rdf:type rdf:Property ;
    rdfs:label 'Ada Compliance Status' ;
    rdfs:comment 'ADA (Americans with Disabilities Act) accessibility compliance status for the tournament\'s venues and event operations. Required for US-hosted events and venue certification.' ;
    rdfs:domain ind:Tournament ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ageCategory rdf:type rdf:Property ;
    rdfs:label 'Age Category' ;
    rdfs:comment 'Age classification bracket for tournament eligibility (e.g., Senior, Under-23, Under-18, Masters). Governs participant eligibility per CBA and governing body regulations. [ENUM-REF-CANDIDATE: senior|under_23|under_21|under_18|youth|masters|open — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:announcementDate rdf:type rdf:Property ;
    rdfs:label 'Announcement Date' ;
    rdfs:comment 'Date on which the tournament was officially announced to the public and media. Marks the start of the tournament lifecycle for marketing, sponsorship, and fan engagement planning.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:editionNumber rdf:type rdf:Property ;
    rdfs:label 'Edition Number' ;
    rdfs:comment 'Sequential edition or iteration number of the tournament (e.g., 23rd FIFA World Cup, 75th NBA Playoffs). Enables historical trend analysis and year-over-year performance comparisons.' ;
    rdfs:domain ind:Tournament ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:editionYear rdf:type rdf:Property ;
    rdfs:label 'Edition Year' ;
    rdfs:comment 'Calendar year associated with this tournament edition (e.g., 2026 for FIFA World Cup 2026). Used as a human-readable identifier for the edition in reporting and fan-facing content.' ;
    rdfs:domain ind:Tournament ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:externalCode rdf:type rdf:Property ;
    rdfs:label 'External Code' ;
    rdfs:comment 'Externally recognized unique code or identifier assigned by the governing body or data provider (e.g., FIFA tournament ID, Opta competition code). Used for data exchange and integration with third-party systems.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:formatType rdf:type rdf:Property ;
    rdfs:label 'Format Type' ;
    rdfs:comment 'Structural competition format that defines how participants advance through the tournament. Drives bracket logic, scheduling, and elimination rules. [ENUM-REF-CANDIDATE: single_elimination|double_elimination|round_robin|group_stage_knockout|multi_stage|league_playoff|swiss — promote to reference product if additional formats are needed]' ;
    rdfs:domain ind:Tournament ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:genderCategory rdf:type rdf:Property ;
    rdfs:label 'Gender Category' ;
    rdfs:comment 'Gender classification of the tournament competition (e.g., Men\'s World Cup, Women\'s NBA). Required for scheduling, eligibility, and regulatory compliance with governing body rules.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hostRegion rdf:type rdf:Property ;
    rdfs:label 'Host Region' ;
    rdfs:comment 'Geographic region or confederation where the tournament is hosted (e.g., North America, Europe, Asia-Pacific). Used for broadcast rights distribution, regional sponsorship packages, and fan engagement targeting.' ;
    rdfs:domain ind:Tournament ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:officialWebsiteUrl rdf:type rdf:Property ;
    rdfs:label 'Official Website Url' ;
    rdfs:comment 'URL of the official tournament website used for fan engagement, media accreditation, and digital content distribution. Integrated with Adobe Experience Platform for fan personalization.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedAmount rdf:type rdf:Property ;
    rdfs:label 'Planned Amount' ;
    rdfs:comment 'The original planned budget amount allocated to this specific tournament from this budget line for the applicable fiscal period. Sourced from detection phase relationship data. Belongs to the allocation relationship, not the tournament or budget record alone.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:prizePoolAmount rdf:type rdf:Property ;
    rdfs:label 'Prize Pool Amount' ;
    rdfs:comment 'Total monetary prize pool allocated for distribution to tournament participants and winners, expressed in the tournament\'s base currency. Used for financial planning, sponsor negotiations, and athlete contract compliance.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:prizePoolCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Prize Pool Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the prize pool amount (e.g., USD, EUR, GBP). Required for multi-currency financial reporting and SAP S/4HANA FI integration.' ;
    rdfs:domain ind:Tournament ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualificationMethod rdf:type rdf:Property ;
    rdfs:label 'Qualification Method' ;
    rdfs:comment 'Primary method by which participants earn entry into the tournament (e.g., direct qualification via league standings, playoff qualifier, wild card selection, invitation by governing body, ranking points accumulation).' ;
    rdfs:domain ind:Tournament ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recurrenceType rdf:type rdf:Property ;
    rdfs:label 'Recurrence Type' ;
    rdfs:comment 'Frequency at which this tournament recurs (e.g., annual for NBA Playoffs, quadrennial for FIFA World Cup, one-time for special events). Supports long-range event planning and broadcast rights negotiation cycles.' ;
    rdfs:domain ind:Tournament ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationDeadline rdf:type rdf:Property ;
    rdfs:label 'Registration Deadline' ;
    rdfs:comment 'Final date by which teams or athletes must complete registration and eligibility verification to participate in the tournament. Enforced per governing body regulations.' ;
    rdfs:domain ind:Tournament ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:revisedAmount rdf:type rdf:Property ;
    rdfs:label 'Revised Amount' ;
    rdfs:comment 'The most recently approved revised budget amount allocated to this tournament after reforecast cycles. Sourced from detection phase relationship data. Reflects mid-cycle adjustments specific to this tournament-budget pairing.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:seedingMethodology rdf:type rdf:Property ;
    rdfs:label 'Seeding Methodology' ;
    rdfs:comment 'Method used to assign seeds and bracket positions to participants (e.g., ranking-based using WAR or QBR metrics, committee selection, random draw). Governs competitive fairness and bracket integrity.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shortName rdf:type rdf:Property ;
    rdfs:label 'Short Name' ;
    rdfs:comment 'Abbreviated or commonly used name for the tournament used in broadcast graphics, digital platforms, and fan-facing displays (e.g., \'World Cup 2026\', \'NBA Playoffs\').' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:socialMediaHashtag rdf:type rdf:Property ;
    rdfs:label 'Social Media Hashtag' ;
    rdfs:comment 'Official social media hashtag designated for the tournament (e.g., #WorldCup2026, #NBAPlayoffs). Used for fan engagement tracking, UGC (User Generated Content) monitoring, and NPS (Net Promoter Score) sentiment analysis.' ;
    rdfs:domain ind:Tournament ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sportType rdf:type rdf:Property ;
    rdfs:label 'Sport Type' ;
    rdfs:comment 'The sport or entertainment discipline associated with this tournament (e.g., \'Football\', \'Basketball\', \'Mixed Martial Arts\', \'Tennis\', \'Concert Series\'). [ENUM-REF-CANDIDATE: football|basketball|baseball|ice_hockey|soccer|tennis|mma|golf|esports|concert — promote to reference product]' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sustainabilityCertified rdf:type rdf:Property ;
    rdfs:label 'Sustainability Certified' ;
    rdfs:comment 'Indicates whether the tournament has achieved or is pursuing ISO 20121 Event Sustainability Management System certification. Supports ESG reporting and sponsor sustainability commitments.' ;
    rdfs:domain ind:Tournament ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ticketSalesEnabled rdf:type rdf:Property ;
    rdfs:label 'Ticket Sales Enabled' ;
    rdfs:comment 'Indicates whether public ticket sales are enabled for this tournament. When false, the tournament may be closed-door, invitation-only, or broadcast-only. Drives Ticketmaster/AXS inventory activation.' ;
    rdfs:domain ind:Tournament ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tiebreakerRules rdf:type rdf:Property ;
    rdfs:label 'Tiebreaker Rules' ;
    rdfs:comment 'Description of the rules applied to resolve tied standings or scores within the tournament (e.g., head-to-head record, goal difference, penalty shootout, sudden death overtime). Governed by the sanctioning body.' ;
    rdfs:domain ind:Tournament ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalMatchesScheduled rdf:type rdf:Property ;
    rdfs:label 'Total Matches Scheduled' ;
    rdfs:comment 'Total number of matches or games scheduled across all rounds of the tournament (e.g., 64 matches for FIFA World Cup group + knockout stages). Used for venue scheduling, broadcast slot planning, and officiating resource allocation.' ;
    rdfs:domain ind:Tournament ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalParticipants rdf:type rdf:Property ;
    rdfs:label 'Total Participants' ;
    rdfs:comment 'Maximum number of teams or individual athletes eligible to compete in the tournament (e.g., 32 teams for FIFA World Cup, 16 teams for NBA Playoffs). Defines bracket size and seeding structure.' ;
    rdfs:domain ind:Tournament ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalRounds rdf:type rdf:Property ;
    rdfs:label 'Total Rounds' ;
    rdfs:comment 'Total number of competitive rounds or stages in the tournament bracket (e.g., 7 rounds for NBA Playoffs, 6 rounds for FIFA World Cup knockout stage). Drives bracket generation and scheduling logic.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tournamentName rdf:type rdf:Property ;
    rdfs:label 'Tournament Name' ;
    rdfs:comment 'Official full name of the tournament as sanctioned by the governing body (e.g., \'FIFA World Cup 2026\', \'NBA Playoffs 2025\', \'UFC Championship Series Season 3\').' ;
    rdfs:domain ind:Tournament ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tournamentStatus rdf:type rdf:Property ;
    rdfs:label 'Tournament Status' ;
    rdfs:comment 'Current lifecycle state of the tournament from announcement through post-event reconciliation. Drives operational workflows, ticketing availability, and broadcast scheduling.' ;
    rdfs:domain ind:Tournament ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:varEnabled rdf:type rdf:Property ;
    rdfs:label 'Var Enabled' ;
    rdfs:comment 'Indicates whether VAR (Video Assistant Referee) or TMO (Television Match Official) technology is deployed for officiating decisions during this tournament. Relevant for football, rugby, and other applicable sports.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:advancementRule rdf:type rdf:Property ;
    rdfs:label 'Advancement Rule' ;
    rdfs:comment 'Rule governing how participants advance from one round to the next within this bracket. Determines winner progression logic used to fill subsequent bracket slots.' ;
    rdfs:domain ind:Event ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bracketCode rdf:type rdf:Property ;
    rdfs:label 'Bracket Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying this bracket within the tournament management system. Used in broadcast overlays, fan engagement platforms, and league governance communications.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bracketName rdf:type rdf:Property ;
    rdfs:label 'Bracket Name' ;
    rdfs:comment 'Human-readable display name for the bracket (e.g., \'Men\'s Singles Main Draw\', \'Western Conference Playoffs Bracket\'). Used in broadcast overlays, fan engagement platforms, and digital content.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bracketStatus rdf:type rdf:Property ;
    rdfs:label 'Bracket Status' ;
    rdfs:comment 'Current lifecycle state of the bracket from initial draft through post-event reconciliation. Drives workflow routing in league governance, broadcast scheduling, and fan engagement platforms. [ENUM-REF-CANDIDATE: draft|announced|seeding_complete|in_progress|completed|cancelled|suspended — promote to reference product]' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bracketType rdf:type rdf:Property ;
    rdfs:label 'Bracket Type' ;
    rdfs:comment 'Classification of the bracket format governing advancement rules. Determines how winners and losers progress through the draw. [ENUM-REF-CANDIDATE: single_elimination|double_elimination|round_robin|swiss|group_stage|repechage — promote to reference product if additional formats are required]' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:broadcastOverlayEnabled rdf:type rdf:Property ;
    rdfs:label 'Broadcast Overlay Enabled' ;
    rdfs:comment 'Indicates whether real-time bracket visualization data is enabled for broadcast overlay graphics. When true, bracket progression data is streamed to broadcast production systems for on-screen display.' ;
    rdfs:domain ind:Bracket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:byeCount rdf:type rdf:Property ;
    rdfs:label 'Bye Count' ;
    rdfs:comment 'Number of bye assignments in the first round of the bracket, granted when total entrants do not fill a power-of-two draw. Byes automatically advance the assigned participant to the next round.' ;
    rdfs:domain ind:Bracket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:consolationBracket rdf:type rdf:Property ;
    rdfs:label 'Consolation Bracket' ;
    rdfs:comment 'Indicates whether a consolation or losers bracket exists alongside this main bracket, as in double-elimination formats. When true, loser advancement rules apply and a separate bracket reset may be triggered.' ;
    rdfs:domain ind:Bracket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:currentRound rdf:type rdf:Property ;
    rdfs:label 'Current Round' ;
    rdfs:comment 'The round number currently in progress within the bracket. Updated in real-time as results are confirmed and participants advance. Drives real-time bracket visualization for broadcast overlays and fan engagement platforms.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:drawDate rdf:type rdf:Property ;
    rdfs:label 'Draw Date' ;
    rdfs:comment 'Calendar date on which the official bracket draw ceremony was or is scheduled to be conducted. Marks the transition from seeding_complete to announced status.' ;
    rdfs:domain ind:Bracket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:drawTimestamp rdf:type rdf:Property ;
    rdfs:label 'Draw Timestamp' ;
    rdfs:comment 'Precise date and time at which the official bracket draw was executed, including timezone offset. Used for broadcast scheduling and audit trail of bracket creation.' ;
    rdfs:domain ind:Bracket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:fanEngagementVisible rdf:type rdf:Property ;
    rdfs:label 'Fan Engagement Visible' ;
    rdfs:comment 'Indicates whether this bracket is published and visible on fan engagement platforms (Adobe Experience Platform, DTC apps, OTT services). Controls public-facing bracket display and fan prediction features.' ;
    rdfs:domain ind:Bracket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:governingBodyCode rdf:type rdf:Property ;
    rdfs:label 'Governing Body Code' ;
    rdfs:comment 'Code identifying the international or national governing body whose rules and regulations apply to this bracket. Determines applicable competition rules, anti-doping requirements, and dispute resolution via CAS. [ENUM-REF-CANDIDATE: FIFA|IOC|NFL|NBA|MLB|NHL|MLS|ATP|UFC|WADA — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastResultTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Result Timestamp' ;
    rdfs:comment 'Timestamp of the most recent match result that triggered a bracket slot update. Used for real-time bracket synchronization with broadcast overlays and fan engagement platforms.' ;
    rdfs:domain ind:Bracket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:phase rdf:type rdf:Property ;
    rdfs:label 'Phase' ;
    rdfs:comment 'Specific competition phase or stage this bracket represents within the overall tournament structure (e.g., qualifying, group stage, knockout rounds). [ENUM-REF-CANDIDATE: qualifying|group_stage|round_of_64|round_of_32|round_of_16|quarterfinal|semifinal|third_place|final — promote to reference product]' ;
    rdfs:domain ind:Bracket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:predictionGameEnabled rdf:type rdf:Property ;
    rdfs:label 'Prediction Game Enabled' ;
    rdfs:comment 'Indicates whether fan bracket prediction and pick\'em games are activated for this bracket on fan engagement platforms. Drives fan engagement KPI tracking and NPS measurement.' ;
    rdfs:domain ind:Bracket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:resetRule rdf:type rdf:Property ;
    rdfs:label 'Reset Rule' ;
    rdfs:comment 'Rule defining whether and how the bracket resets in double-elimination formats when the losers bracket winner faces the undefeated winners bracket champion. Governs whether a grand final reset match is required.' ;
    rdfs:domain ind:Bracket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resultSource rdf:type rdf:Property ;
    rdfs:label 'Result Source' ;
    rdfs:comment 'Source system or process from which match results are ingested to update bracket slot progression. Includes VAR (Video Assistant Referee) and TMO (Television Match Official) review outcomes for result verification.' ;
    rdfs:domain ind:Bracket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seedingLocked rdf:type rdf:Property ;
    rdfs:label 'Seeding Locked' ;
    rdfs:comment 'Indicates whether the seeding assignments for this bracket have been finalized and locked, preventing further modifications. Set to true after the official draw ceremony.' ;
    rdfs:domain ind:Bracket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:seedingMethod rdf:type rdf:Property ;
    rdfs:label 'Seeding Method' ;
    rdfs:comment 'Method used to assign seeding positions to participants in the bracket draw. Determines competitive fairness and scheduling of top seeds to avoid early high-profile matchups.' ;
    rdfs:domain ind:Bracket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slotFillMethod rdf:type rdf:Property ;
    rdfs:label 'Slot Fill Method' ;
    rdfs:comment 'Method by which future bracket slots are populated as results are confirmed. \'Automatic\' fills slots immediately upon result confirmation; \'manual\' requires league office intervention; \'pending_result\' holds slot until result is verified.' ;
    rdfs:domain ind:Bracket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thirdPlaceMatch rdf:type rdf:Property ;
    rdfs:label 'Third Place Match' ;
    rdfs:comment 'Indicates whether this bracket includes a third-place playoff match between the two semifinal losers. Relevant for broadcast scheduling and ticketing inventory allocation.' ;
    rdfs:domain ind:Bracket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tiebreakerRule rdf:type rdf:Property ;
    rdfs:label 'Tiebreaker Rule' ;
    rdfs:comment 'Description of the tiebreaker rule applied when participants are level on points or score at the end of regulation (e.g., \'away goals\', \'penalty shootout\', \'sudden death overtime\', \'head-to-head record\'). Governs conditional scheduling of additional fixtures. [ENUM-REF-CANDIDATE: promote to reference product for full tiebreaker taxonomy]' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalEntrants rdf:type rdf:Property ;
    rdfs:label 'Total Entrants' ;
    rdfs:comment 'Number of teams, athletes, or participants entered into this bracket. May differ from total_slots when byes are assigned to fill power-of-two draw sizes.' ;
    rdfs:domain ind:Bracket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalSlots rdf:type rdf:Property ;
    rdfs:label 'Total Slots' ;
    rdfs:comment 'Total number of matchup slots in the bracket across all rounds. Determines the capacity of the draw and is used for seeding assignment and bye allocation.' ;
    rdfs:domain ind:Bracket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:weightClass rdf:type rdf:Property ;
    rdfs:label 'Weight Class' ;
    rdfs:comment 'Weight class designation for combat sports brackets (e.g., UFC lightweight, heavyweight). Null for non-combat sports. Governs participant eligibility and WADA weigh-in compliance requirements.' ;
    rdfs:domain ind:Bracket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mvpAthleteProfileId rdf:type rdf:Property ;
    rdfs:label 'Mvp Athlete Profile Id' ;
    rdfs:comment 'Foreign key linking to athlete.athlete_profile. Business justification: Player-of-the-Match/MVP designation is a core post-match reporting, broadcast, and awards process in sports-entertainment. League statistical systems, broadcast overlays, and fan engagement platforms ' ;
    rdfs:domain ind:MatchResult ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AthleteProfile .

ind:primaryMatchCompetitionTournamentId rdf:type rdf:Property ;
    rdfs:label 'Primary Match Competition Tournament Id' ;
    rdfs:comment 'Reference to the league, cup, or tournament competition governing this fixture. Enables competition-scoped standings and bracket progression.' ;
    rdfs:domain ind:MatchResult ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Tournament .

ind:primaryMatchFranchiseId rdf:type rdf:Property ;
    rdfs:label 'Primary Match Franchise Id' ;
    rdfs:comment 'Reference to the home team or home-side participant in the fixture. Used for league standings, head-to-head analytics, and broadcast attribution.' ;
    rdfs:domain ind:MatchResult ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Franchise .

ind:primaryMatchOfficialId rdf:type rdf:Property ;
    rdfs:label 'Primary Match Official Id' ;
    rdfs:comment 'Reference to the primary match official (referee, umpire, or head official) who officiated the match. Used for officiating performance analytics, assignment tracking, and governing body compliance.' ;
    rdfs:domain ind:MatchResult ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Official .

ind:quaternaryMatchWinningTeamFranchiseId rdf:type rdf:Property ;
    rdfs:label 'Quaternary Match Winning Team Franchise Id' ;
    rdfs:comment 'Reference to the team that won the match. Null for draws or no-result outcomes. Used for bracket progression in knockout competitions, playoff seeding, and broadcast winner attribution.' ;
    rdfs:domain ind:MatchResult ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Franchise .

ind:tertiaryMatchFranchiseId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Match Franchise Id' ;
    rdfs:comment 'Reference to the home team or home-side participant in the fixture. Used for league standings, head-to-head analytics, and broadcast attribution.' ;
    rdfs:domain ind:MatchResult ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Franchise .

ind:tertiaryMatchWinningTeamFranchiseId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Match Winning Team Franchise Id' ;
    rdfs:comment 'Reference to the team that won the match. Null for draws or no-result outcomes. Used for bracket progression in knockout competitions, playoff seeding, and broadcast winner attribution.' ;
    rdfs:domain ind:MatchResult ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Franchise .

ind:attendance rdf:type rdf:Property ;
    rdfs:label 'Attendance' ;
    rdfs:comment 'Official announced attendance figure (number of spectators present) for the match. Used for venue capacity utilization reporting, revenue reconciliation, and league attendance KPI tracking.' ;
    rdfs:domain ind:MatchResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:awayScoreFinal rdf:type rdf:Property ;
    rdfs:label 'Away Score Final' ;
    rdfs:comment 'Official final score (goals, points, runs, etc.) for the away team at the conclusion of regulation and any extra time/overtime/shootout. This is the authoritative scoreline used for standings and wagering settlement.' ;
    rdfs:domain ind:MatchResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:awayScoreRegulation rdf:type rdf:Property ;
    rdfs:label 'Away Score Regulation' ;
    rdfs:comment 'Away team score at the end of regulation time only (excluding overtime, extra time, or shootout). Required for sports where regulation draws carry different standings points than overtime losses.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:broadcastMatchReference rdf:type rdf:Property ;
    rdfs:label 'Broadcast Match Reference' ;
    rdfs:comment 'External identifier assigned to this match result by the broadcast or media rights partner (e.g., RSN, OTT platform, Dalet Galaxy MAM system). Used to link match result data to broadcast highlight packages, content rights windows, and CDN distribution metadata.' ;
    rdfs:domain ind:MatchResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dopingControlConducted rdf:type rdf:Property ;
    rdfs:label 'Doping Control Conducted' ;
    rdfs:comment 'Indicates whether WADA-mandated PED (Performance Enhancing Drug) doping control testing was conducted in connection with this match. Supports WADA compliance reporting and anti-doping program audit trails.' ;
    rdfs:domain ind:MatchResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:homeScoreFinal rdf:type rdf:Property ;
    rdfs:label 'Home Score Final' ;
    rdfs:comment 'Official final score (goals, points, runs, etc.) for the home team at the conclusion of regulation and any extra time/overtime/shootout. This is the authoritative scoreline used for standings and wagering settlement.' ;
    rdfs:domain ind:MatchResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:homeScoreRegulation rdf:type rdf:Property ;
    rdfs:label 'Home Score Regulation' ;
    rdfs:comment 'Home team score at the end of regulation time only (excluding overtime, extra time, or shootout). Required for sports where regulation draws carry different standings points than overtime losses (e.g., NHL, MLS).' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:kickoffTimestamp rdf:type rdf:Property ;
    rdfs:label 'Kickoff Timestamp' ;
    rdfs:comment 'Precise UTC timestamp of the official match start (kickoff, tip-off, first pitch, puck drop, etc.). Distinct from match_date — provides sub-day precision for broadcast scheduling, SLA measurement, and wagering in-play event sequencing.' ;
    rdfs:domain ind:MatchResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:marginOfVictory rdf:type rdf:Property ;
    rdfs:label 'Margin Of Victory' ;
    rdfs:comment 'Absolute difference between the winning and losing team\'s final scores (e.g., 3 goals, 14 points). Null for draws. Used for strength-of-schedule analytics, WAR (Wins Above Replacement) calculations, and wagering handicap settlement.' ;
    rdfs:domain ind:MatchResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:matchDate rdf:type rdf:Property ;
    rdfs:label 'Match Date' ;
    rdfs:comment 'Calendar date on which the match was played (local venue time). Used for fixture calendar reporting, standings date-range filtering, and broadcast scheduling alignment.' ;
    rdfs:domain ind:MatchResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:matchDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Match Duration Minutes' ;
    rdfs:comment 'Total actual playing time in minutes from kickoff to final whistle, including stoppage time and overtime but excluding pre-match and half-time intervals. Used for broadcast scheduling, venue operations planning, and SLA compliance.' ;
    rdfs:domain ind:MatchResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:matchOutcome rdf:type rdf:Property ;
    rdfs:label 'Match Outcome' ;
    rdfs:comment 'Categorical result of the match from the perspective of home vs. away: \'home_win\', \'away_win\', \'draw\', or \'no_result\' (abandoned/forfeited). Primary field for league standings points allocation and wagering market settlement.' ;
    rdfs:domain ind:MatchResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:neutralVenue rdf:type rdf:Property ;
    rdfs:label 'Neutral Venue' ;
    rdfs:comment 'Indicates whether the match was played at a neutral venue (neither team\'s home ground). Affects home/away advantage analytics, standings point allocation rules, and ticket revenue attribution.' ;
    rdfs:domain ind:MatchResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:overtimePlayed rdf:type rdf:Property ;
    rdfs:label 'Overtime Played' ;
    rdfs:comment 'Indicates whether the match required overtime, extra time, or additional periods beyond regulation to determine a winner. Drives standings point allocation logic (e.g., NHL OTL point) and broadcast scheduling overrun management.' ;
    rdfs:domain ind:MatchResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:periodScoresAway rdf:type rdf:Property ;
    rdfs:label 'Period Scores Away' ;
    rdfs:comment 'Pipe-delimited string of away team scores by period, quarter, half, set, or inning (e.g., \'7|21|14|3\' for NFL quarters). Enables granular in-game momentum analytics and broadcast segment attribution.' ;
    rdfs:domain ind:MatchResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:periodScoresHome rdf:type rdf:Property ;
    rdfs:label 'Period Scores Home' ;
    rdfs:comment 'Pipe-delimited string of home team scores by period, quarter, half, set, or inning (e.g., \'21|14|7|10\' for NFL quarters, or \'1|0|2\' for NHL periods). Enables granular in-game momentum analytics and broadcast segment attribution.' ;
    rdfs:domain ind:MatchResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pitchCondition rdf:type rdf:Property ;
    rdfs:label 'Pitch Condition' ;
    rdfs:comment 'Official assessment of the playing surface condition at the time of the match. Used for player welfare analytics, venue maintenance scheduling, and governing body compliance reporting.' ;
    rdfs:domain ind:MatchResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:protestReference rdf:type rdf:Property ;
    rdfs:label 'Protest Reference' ;
    rdfs:comment 'Official reference number of any formal protest or appeal lodged against this match result with the governing body or CAS (Court of Arbitration for Sport). Null if no protest filed. Supports legal and compliance tracking.' ;
    rdfs:domain ind:MatchResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resultConfirmedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Result Confirmed Timestamp' ;
    rdfs:comment 'UTC timestamp at which the governing body or league operations officially confirmed and locked the match result. Triggers downstream processes: standings updates, wagering settlement, broadcast highlights release, and fantasy sports scoring.' ;
    rdfs:domain ind:MatchResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:resultNotes rdf:type rdf:Property ;
    rdfs:label 'Result Notes' ;
    rdfs:comment 'Free-text field for official notes or annotations related to the match result, such as protest grounds, abandonment reasons, score correction explanations, or governing body directives. Supports compliance documentation and operational context.' ;
    rdfs:domain ind:MatchResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resultReferenceCode rdf:type rdf:Property ;
    rdfs:label 'Result Reference Code' ;
    rdfs:comment 'Externally-known alphanumeric code assigned to this match result by the governing body or league operations system. Used for official reporting, wagering integrations, and broadcast metadata tagging. Example: \'NFL-2024-WK12-DAL-PHI-RESULT\'.' ;
    rdfs:domain ind:MatchResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resultSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Result Source System' ;
    rdfs:comment 'Identifies the originating system or feed from which the match result data was ingested. Supports data lineage, audit trail, and Silver layer quality validation. Values include SportsCode/Hudl performance analytics platform, governing body official data feeds, or manual entry.' ;
    rdfs:domain ind:MatchResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shootoutPlayed rdf:type rdf:Property ;
    rdfs:label 'Shootout Played' ;
    rdfs:comment 'Indicates whether the match was decided by a penalty shootout or shootout format (e.g., FIFA penalty shootout, NHL shootout). Distinct from overtime_played — a match can have overtime without a shootout.' ;
    rdfs:domain ind:MatchResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:shootoutScoreAway rdf:type rdf:Property ;
    rdfs:label 'Shootout Score Away' ;
    rdfs:comment 'Number of successful shootout attempts by the away team during a penalty shootout. Null if shootout_played is false. Used for detailed shootout analytics and historical records.' ;
    rdfs:domain ind:MatchResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:shootoutScoreHome rdf:type rdf:Property ;
    rdfs:label 'Shootout Score Home' ;
    rdfs:comment 'Number of successful shootout attempts by the home team during a penalty shootout. Null if shootout_played is false. Used for detailed shootout analytics and historical records.' ;
    rdfs:domain ind:MatchResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:stoppageTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Stoppage Time Minutes' ;
    rdfs:comment 'Total additional stoppage/injury time added by the referee across all periods. Relevant for soccer/football and rugby. Used for broadcast scheduling overrun management and officiating analytics.' ;
    rdfs:domain ind:MatchResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:varIntervention rdf:type rdf:Property ;
    rdfs:label 'Var Intervention' ;
    rdfs:comment 'Indicates whether a Video Assistant Referee (VAR) or Television Match Official (TMO) intervention occurred during the match that affected the official result (e.g., goal disallowed, red card issued, try awarded). Supports officiating quality analytics and governing body review processes.' ;
    rdfs:domain ind:MatchResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:varInterventionCount rdf:type rdf:Property ;
    rdfs:label 'Var Intervention Count' ;
    rdfs:comment 'Total number of VAR (Video Assistant Referee) or TMO (Television Match Official) review incidents during the match. Supports officiating quality analytics and governing body compliance reporting.' ;
    rdfs:domain ind:MatchResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:scoringEventId rdf:type rdf:Property ;
    rdfs:label 'Scoring Event Id' ;
    rdfs:comment 'Unique surrogate identifier for each individual in-game scoring moment captured in the system. Primary key for the scoring_event data product.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ScoringEvent .

ind:highlightAssetId rdf:type rdf:Property ;
    rdfs:label 'Highlight Asset Id' ;
    rdfs:comment 'Foreign key linking to content.asset. Business justification: Scoring events (goals, touchdowns) are directly linked to highlight clips — a core content monetization workflow in sports entertainment. broadcast_clip_reference is a denormalized string; replacing i' ;
    rdfs:domain ind:ScoringEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Asset .

ind:mediaAssetId rdf:type rdf:Property ;
    rdfs:label 'Media Asset Id' ;
    rdfs:comment 'Foreign key linking to broadcast.media_asset. Business justification: Highlight clip production workflow: each scoring event must be linked to its broadcast media asset for replay packaging, highlight reels, and clip licensing. Sports broadcasters routinely tag scoring ' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MediaAsset .

ind:primaryScoringAthleteProfileId rdf:type rdf:Property ;
    rdfs:label 'Primary Scoring Athlete Profile Id' ;
    rdfs:comment 'Reference to the athlete credited with the scoring event (goal scorer, touchdown passer/rusher, basket maker, run batter, etc.).' ;
    rdfs:domain ind:ScoringEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AthleteProfile .

ind:primaryScoringFranchiseId rdf:type rdf:Property ;
    rdfs:label 'Primary Scoring Franchise Id' ;
    rdfs:comment 'Reference to the team that scored this scoring event. Determines which team\'s score is incremented.' ;
    rdfs:domain ind:ScoringEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Franchise .

ind:tertiaryScoringAthleteProfileId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Scoring Athlete Profile Id' ;
    rdfs:comment 'Reference to the athlete credited with the scoring event (goal scorer, touchdown passer/rusher, basket maker, run batter, etc.).' ;
    rdfs:domain ind:ScoringEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AthleteProfile .

ind:awayScoreAfter rdf:type rdf:Property ;
    rdfs:label 'Away Score After' ;
    rdfs:comment 'The cumulative score of the away team immediately after this scoring event was recorded. Paired with home_score_after to represent the full score state at the moment of the event.' ;
    rdfs:domain ind:ScoringEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bodyPart rdf:type rdf:Property ;
    rdfs:label 'Body Part' ;
    rdfs:comment 'The body part or implement used by the athlete to execute the scoring action (e.g., right foot, left foot, head for soccer; bat for baseball; club for golf). Supports detailed performance analytics and broadcast commentary. [ENUM-REF-CANDIDATE: right_foot|left_foot|head|right_hand|left_hand|body|bat|club|other — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competitionPhase rdf:type rdf:Property ;
    rdfs:label 'Competition Phase' ;
    rdfs:comment 'The phase of the competition or tournament in which this scoring event occurred. Distinguishes regular season scoring from playoff or knockout stage scoring for statistical segmentation. [ENUM-REF-CANDIDATE: regular_season|playoffs|knockout|group_stage|final|semifinal|quarterfinal|wildcard|round_of_16|round_of_32 — promote to reference product]' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coordinateX rdf:type rdf:Property ;
    rdfs:label 'Coordinate X' ;
    rdfs:comment 'The X-axis coordinate on the standardised pitch or field coordinate system representing the horizontal position from which the scoring action originated. Used for spatial heatmaps and performance analytics in SportsCode/Hudl.' ;
    rdfs:domain ind:ScoringEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coordinateY rdf:type rdf:Property ;
    rdfs:label 'Coordinate Y' ;
    rdfs:comment 'The Y-axis coordinate on the standardised pitch or field coordinate system representing the vertical position from which the scoring action originated. Paired with coordinate_x for full spatial positioning.' ;
    rdfs:domain ind:ScoringEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dataQualityFlag rdf:type rdf:Property ;
    rdfs:label 'Data Quality Flag' ;
    rdfs:comment 'Indicates the data quality status of this scoring event record. Clean means fully validated; under_review means flagged for investigation; corrected means the record was amended after initial ingestion; disputed means conflicting data from multiple sources.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventStatus rdf:type rdf:Property ;
    rdfs:label 'Event Status' ;
    rdfs:comment 'Current lifecycle status of the scoring event record. Provisional indicates the event is pending official confirmation; confirmed means officially validated; overturned means disallowed after review; amended means corrected post-confirmation; voided means removed from official records.' ;
    rdfs:domain ind:ScoringEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventTimestamp rdf:type rdf:Property ;
    rdfs:label 'Event Timestamp' ;
    rdfs:comment 'The precise real-world date and time at which the scoring event occurred, expressed in ISO 8601 format with timezone offset. Used for broadcast overlays, play-by-play timelines, and content production.' ;
    rdfs:domain ind:ScoringEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:externalEventCode rdf:type rdf:Property ;
    rdfs:label 'External Event Code' ;
    rdfs:comment 'Externally-known unique code or reference number for this scoring event as assigned by the official league data provider or broadcast system (e.g., Opta event ID, Stats Perform ID, Sportradar event ID). Used for cross-system reconciliation.' ;
    rdfs:domain ind:ScoringEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:homeScoreAfter rdf:type rdf:Property ;
    rdfs:label 'Home Score After' ;
    rdfs:comment 'The cumulative score of the home team immediately after this scoring event was recorded. Captures the score state for broadcast overlays, play-by-play reconstruction, and fan engagement platforms.' ;
    rdfs:domain ind:ScoringEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hudlEventReference rdf:type rdf:Property ;
    rdfs:label 'Hudl Event Reference' ;
    rdfs:comment 'The native event identifier assigned by the SportsCode or Hudl performance analytics platform for this scoring event. Used for cross-system reconciliation between the lakehouse silver layer and the performance analytics system of record.' ;
    rdfs:domain ind:ScoringEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isConfirmed rdf:type rdf:Property ;
    rdfs:label 'Is Confirmed' ;
    rdfs:comment 'Indicates whether this scoring event has been officially confirmed and validated by the match officials or league data operations team. False for provisional or pending events awaiting VAR review or official confirmation.' ;
    rdfs:domain ind:ScoringEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isLeadChange rdf:type rdf:Property ;
    rdfs:label 'Is Lead Change' ;
    rdfs:comment 'Indicates whether this scoring event resulted in a change of lead between the two competing teams. True when the scoring team overtook the previously leading team. Key metric for broadcast drama and fan engagement analytics.' ;
    rdfs:domain ind:ScoringEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isOwnGoal rdf:type rdf:Property ;
    rdfs:label 'Is Own Goal' ;
    rdfs:comment 'Indicates whether this scoring event was an own goal (scored by a player against their own team). Affects attribution logic and statistical reporting for the credited athlete.' ;
    rdfs:domain ind:ScoringEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isTie rdf:type rdf:Property ;
    rdfs:label 'Is Tie' ;
    rdfs:comment 'Indicates whether this scoring event resulted in a tied score between the two competing teams. True when the score differential after the event equals zero.' ;
    rdfs:domain ind:ScoringEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:matchClockSeconds rdf:type rdf:Property ;
    rdfs:label 'Match Clock Seconds' ;
    rdfs:comment 'Elapsed match clock time in seconds at the moment the scoring event occurred within the current period. Enables precise play-by-play positioning and broadcast overlay synchronisation.' ;
    rdfs:domain ind:ScoringEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:officiatingDecisionCode rdf:type rdf:Property ;
    rdfs:label 'Officiating Decision Code' ;
    rdfs:comment 'Official code or reference assigned by the match officiating team or league operations to document any officiating decision associated with this scoring event (e.g., penalty awarded, foul called, offside check). Supports league governance and compliance reporting.' ;
    rdfs:domain ind:ScoringEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:periodNumber rdf:type rdf:Property ;
    rdfs:label 'Period Number' ;
    rdfs:comment 'The period, quarter, half, inning, or round number within the match in which the scoring event occurred (e.g., 1 = first half/quarter/period, 2 = second, etc.). Supports sport-agnostic period-level analytics.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:periodType rdf:type rdf:Property ;
    rdfs:label 'Period Type' ;
    rdfs:comment 'Classification of the period in which the scoring event occurred, distinguishing regular play from overtime, extra time, penalty shootout, or sudden death. Critical for statistical integrity and broadcast context.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pitchZone rdf:type rdf:Property ;
    rdfs:label 'Pitch Zone' ;
    rdfs:comment 'The designated zone or area of the playing field from which the scoring action was initiated (e.g., penalty area, midfield, three-point arc, red zone, paint area). Supports spatial analytics and performance analysis in SportsCode/Hudl. [ENUM-REF-CANDIDATE: penalty_area|six_yard_box|outside_box|three_point_arc|paint|mid_range|red_zone|end_zone|infield|outfield — promote to reference product]' ;
    rdfs:domain ind:ScoringEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:playPattern rdf:type rdf:Property ;
    rdfs:label 'Play Pattern' ;
    rdfs:comment 'The tactical play pattern or situation from which the scoring event originated (e.g., open play, set piece, counter attack, fast break, corner, free kick). Supports tactical analysis and content production. [ENUM-REF-CANDIDATE: open_play|set_piece|counter_attack|fast_break|corner|free_kick|penalty|throw_in|other — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ScoringEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pointsValue rdf:type rdf:Property ;
    rdfs:label 'Points Value' ;
    rdfs:comment 'The number of points awarded to the scoring team as a result of this scoring event (e.g., 1 for a free throw, 2 for a basket, 3 for a three-pointer, 6 for a touchdown, 1 for a goal in soccer). Core quantitative fact of the scoring event.' ;
    rdfs:domain ind:ScoringEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:scoreDifferentialAfter rdf:type rdf:Property ;
    rdfs:label 'Score Differential After' ;
    rdfs:comment 'The signed score differential (home minus away) immediately after this scoring event. Positive values indicate home team lead; negative values indicate away team lead; zero indicates a tie. Supports win probability and momentum analytics.' ;
    rdfs:domain ind:ScoringEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:scoringMethod rdf:type rdf:Property ;
    rdfs:label 'Scoring Method' ;
    rdfs:comment 'The specific method by which the score was achieved (e.g., penalty kick, free kick, header, slam dunk, three-pointer, home run, touchdown pass, field goal, try, conversion). Sport-specific enumeration managed as a reference product. [ENUM-REF-CANDIDATE: penalty_kick|free_kick|header|open_play|slam_dunk|three_pointer|home_run|touchdown_pass|rushing_touchdown|field_goal|try|conversion|free_throw|layup|own_goal — promote to reference product]' ;
    rdfs:domain ind:ScoringEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Sequence Number' ;
    rdfs:comment 'Sequential ordinal number of this scoring event within the match, ordered chronologically. The first score of the match is 1, the second is 2, etc. Enables ordered play-by-play reconstruction and broadcast timeline sequencing.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:varReviewFlag rdf:type rdf:Property ;
    rdfs:label 'Var Review Flag' ;
    rdfs:comment 'Indicates whether this scoring event was subject to a Video Assistant Referee (VAR) or Television Match Official (TMO) review process. True when a review was initiated. Supports officiating analytics and broadcast commentary.' ;
    rdfs:domain ind:ScoringEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:varReviewOutcome rdf:type rdf:Property ;
    rdfs:label 'Var Review Outcome' ;
    rdfs:comment 'The outcome of the VAR or TMO review for this scoring event. Upheld means the original decision stands; overturned means the scoring event was disallowed or modified; inconclusive means no definitive determination was reached. Null or not_reviewed when var_review_flag is false.' ;
    rdfs:domain ind:ScoringEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:broadcastProductionId rdf:type rdf:Property ;
    rdfs:label 'Broadcast Production Id' ;
    rdfs:comment 'Foreign key linking to broadcast.production. Business justification: Event-to-broadcast production coordination: the venue event production schedule (doors open, halftime, player walkout) must be synchronized with the broadcast production plan. Broadcast directors depe' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Production .

ind:emergencyResponsePlanId rdf:type rdf:Property ;
    rdfs:label 'Emergency Response Plan Id' ;
    rdfs:comment 'Foreign key linking to security.emergency_response_plan. Business justification: Production schedule contains a \'weather_contingency_plan\' field and broadcast interruption cues that must reference the active emergency response plan. Broadcast suspension, evacuation announcement cu' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EmergencyResponsePlan .

ind:performerAthleteProfileId rdf:type rdf:Property ;
    rdfs:label 'Performer Athlete Profile Id' ;
    rdfs:comment 'Foreign key linking to athlete.athlete_profile. Business justification: Halftime and pre-show performer scheduling requires linking to the athlete/performer\'s profile for NIL agreement verification, broadcast rights clearance, appearance fee processing, and rider fulfillm' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AthleteProfile .

ind:runOfShowAssetId rdf:type rdf:Property ;
    rdfs:label 'Run Of Show Asset Id' ;
    rdfs:comment 'Foreign key linking to content.asset. Business justification: Production schedules reference a run-of-show document stored as a content asset in the DAM. run_of_show_document_url is a denormalized URL; replacing it with a proper FK to content.asset enables versi' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Asset .

ind:broadcastGoLiveTime rdf:type rdf:Property ;
    rdfs:label 'Broadcast Go Live Time' ;
    rdfs:comment 'Scheduled timestamp at which the broadcast feed goes live to air or OTT (Over-The-Top Streaming) platforms. Coordinated with the OB (Outside Broadcast) truck and network partners. Critical for FCC compliance and RSN (Regional Sports Network) scheduling.' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:changeoverDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Changeover Duration Minutes' ;
    rdfs:comment 'Planned duration in minutes for the changeover of the playing surface or stage between the halftime show and the resumption of competition. Critical for league compliance with CBA timing rules.' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:doorsOpenTime rdf:type rdf:Property ;
    rdfs:label 'Doors Open Time' ;
    rdfs:comment 'Scheduled timestamp at which venue doors open to the public. Drives fan ingress planning, concession staffing, and security deployment timelines.' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:eventEndTime rdf:type rdf:Property ;
    rdfs:label 'Event End Time' ;
    rdfs:comment 'Estimated timestamp for the conclusion of the main event. Used for post-event activity planning, venue clearance scheduling, and broadcast window management.' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:eventStartTime rdf:type rdf:Property ;
    rdfs:label 'Event Start Time' ;
    rdfs:comment 'Scheduled timestamp for the official start of the main event (e.g., opening whistle, first pitch, curtain up). The principal real-world business event timestamp for this production schedule.' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:halftimeDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Halftime Duration Minutes' ;
    rdfs:comment 'Planned duration in minutes of the halftime or intermission break. Governed by league CBA (Collective Bargaining Agreement) and broadcast commercial break requirements.' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:halftimeStageConfig rdf:type rdf:Property ;
    rdfs:label 'Halftime Stage Config' ;
    rdfs:comment 'Stage layout configuration for the halftime or intermission performance. Determines field/court protection requirements, rigging points, and changeover time from competition surface. [ENUM-REF-CANDIDATE: center_stage|end_stage|thrust|in_the_round|field_full|court_full|no_stage — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:halftimeStartTime rdf:type rdf:Property ;
    rdfs:label 'Halftime Start Time' ;
    rdfs:comment 'Scheduled timestamp for the start of the halftime or intermission break. Drives performer cue, stage crew deployment, and sponsor activation window execution.' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:isBroadcastLive rdf:type rdf:Property ;
    rdfs:label 'Is Broadcast Live' ;
    rdfs:comment 'Indicates whether the event is being broadcast live (True) or is a tape-delayed or pre-recorded production (False). Affects broadcast go-live coordination and OB truck scheduling.' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mediaAccreditationDeadline rdf:type rdf:Property ;
    rdfs:label 'Media Accreditation Deadline' ;
    rdfs:comment 'Deadline timestamp by which media representatives must complete accreditation and credential check-in at the venue. Drives press operations and broadcast partner access management.' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:nationalAnthemCueTime rdf:type rdf:Property ;
    rdfs:label 'National Anthem Cue Time' ;
    rdfs:comment 'Scheduled timestamp for the national anthem performance cue. Broadcast-critical timing element coordinated with the OB truck director and league operations.' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:obTruckArrivalTime rdf:type rdf:Property ;
    rdfs:label 'Ob Truck Arrival Time' ;
    rdfs:comment 'Scheduled timestamp for the OB (Outside Broadcast) truck to arrive at the venue for broadcast setup and signal testing. Drives broadcast production crew scheduling and venue loading dock coordination.' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:playerWalkoutTime rdf:type rdf:Property ;
    rdfs:label 'Player Walkout Time' ;
    rdfs:comment 'Scheduled timestamp for the athlete or team walkout onto the field, court, or stage. Broadcast-critical cue that triggers pre-match ceremony sequences and sponsor LED activations.' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:postEventStartTime rdf:type rdf:Property ;
    rdfs:label 'Post Event Start Time' ;
    rdfs:comment 'Scheduled timestamp for the commencement of post-event activities including trophy presentations, press conferences, fan meet-and-greet, and sponsor hospitality wrap-up.' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:preShowStartTime rdf:type rdf:Property ;
    rdfs:label 'Pre Show Start Time' ;
    rdfs:comment 'Scheduled timestamp for the commencement of pre-show entertainment programming (e.g., opening acts, fan activation zones, national anthem, player warm-up ceremonies).' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:productionType rdf:type rdf:Property ;
    rdfs:label 'Production Type' ;
    rdfs:comment 'Classification of the production context. \'home\' and \'away\' apply to league fixtures; \'neutral_site\' for finals and showcase events; \'studio\' for non-live productions; \'virtual\' for esports or digital-only events.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleLockTimestamp rdf:type rdf:Property ;
    rdfs:label 'Schedule Lock Timestamp' ;
    rdfs:comment 'Timestamp at which the production schedule was formally locked and frozen for game-day execution. No further edits are permitted after this point without an approved change request.' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scheduleName rdf:type rdf:Property ;
    rdfs:label 'Schedule Name' ;
    rdfs:comment 'Human-readable name or title for this production schedule (e.g., \'NBA Finals Game 5 – Chase Center Run-of-Show v3\'). Used for identification in planning tools and communications.' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleReferenceCode rdf:type rdf:Property ;
    rdfs:label 'Schedule Reference Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying this production schedule across operational systems. Used by event production teams, broadcast partners, and venue operations for cross-system coordination.' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleStatus rdf:type rdf:Property ;
    rdfs:label 'Schedule Status' ;
    rdfs:comment 'Current lifecycle state of the production schedule. Drives workflow routing and edit permissions. \'locked\' indicates the schedule has been frozen for game-day execution. [ENUM-REF-CANDIDATE: draft|pending_approval|approved|locked|in_progress|completed|cancelled — promote to reference product]' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleVersion rdf:type rdf:Property ;
    rdfs:label 'Schedule Version' ;
    rdfs:comment 'Monotonically incrementing version number of the production schedule. Incremented each time the schedule is revised and re-issued. Version 1 is the initial approved plan.' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:securityBriefingTime rdf:type rdf:Property ;
    rdfs:label 'Security Briefing Time' ;
    rdfs:comment 'Scheduled timestamp for the pre-event security briefing with venue security, law enforcement liaisons, and event safety officers. Required for OSHA and ADA compliance documentation.' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sponsorActivationWindowEnd rdf:type rdf:Property ;
    rdfs:label 'Sponsor Activation Window End' ;
    rdfs:comment 'Scheduled end timestamp for sponsor activation activities. Marks the close of the contractual activation window for fulfilment reporting and ROI (Return on Investment) measurement.' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sponsorActivationWindowStart rdf:type rdf:Property ;
    rdfs:label 'Sponsor Activation Window Start' ;
    rdfs:comment 'Scheduled start timestamp for sponsor activation activities within the venue (e.g., branded fan zones, product sampling, LED board takeovers). Linked to sponsorship deal fulfilment obligations.' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:technicalRiderNotes rdf:type rdf:Property ;
    rdfs:label 'Technical Rider Notes' ;
    rdfs:comment 'Free-text summary of the halftime or pre-show performer\'s technical rider requirements including audio specifications, lighting rigs, pyrotechnics, video wall usage, and power requirements.' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:venueClearanceTime rdf:type rdf:Property ;
    rdfs:label 'Venue Clearance Time' ;
    rdfs:comment 'Scheduled timestamp by which all fans, non-essential staff, and performers must have vacated the venue. Drives security staffing, transport coordination, and venue handback to facility management.' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:venueSetupStartTime rdf:type rdf:Property ;
    rdfs:label 'Venue Setup Start Time' ;
    rdfs:comment 'Scheduled timestamp for the commencement of pre-event venue setup activities including stage rigging, AV installation, field/court preparation, and sponsor activation builds.' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:vipHospitalityStartTime rdf:type rdf:Property ;
    rdfs:label 'Vip Hospitality Start Time' ;
    rdfs:comment 'Scheduled timestamp for the opening of VIP (Very Important Person) hospitality suites and premium experience areas. Drives catering, host staffing, and sponsor entertainment obligations.' ;
    rdfs:domain ind:ProductionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:weatherContingencyPlan rdf:type rdf:Property ;
    rdfs:label 'Weather Contingency Plan' ;
    rdfs:comment 'Designated contingency plan for adverse weather conditions applicable to outdoor or open-air venues. Drives communication protocols with fans, broadcasters, and league operations.' ;
    rdfs:domain ind:Event ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:participantId rdf:type rdf:Property ;
    rdfs:label 'Participant Id' ;
    rdfs:comment 'Unique surrogate identifier for each event participant record. Primary key for the event_participant data product in the Silver Layer lakehouse.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Participant .

ind:eligibilityCertificationId rdf:type rdf:Property ;
    rdfs:label 'Eligibility Certification Id' ;
    rdfs:comment 'Foreign key linking to compliance.eligibility_certification. Business justification: Event participants (athletes, performers) must have verified eligibility certifications before participation is confirmed. event_participant has eligibility_status and eligibility_verified_date fields' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EligibilityCertification .

ind:eligibilityStatusId rdf:type rdf:Property ;
    rdfs:label 'Eligibility Status Id' ;
    rdfs:comment 'Foreign key linking to athlete.eligibility_status. Business justification: Game-day eligibility verification is a mandatory compliance process: leagues must confirm each athlete\'s authoritative eligibility_status record before allowing participation. Replaces the denormalize' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EligibilityStatus .

ind:replacementParticipantId rdf:type rdf:Property ;
    rdfs:label 'Replacement Participant Id' ;
    rdfs:comment 'Reference to the event_participant record of the entity that replaced this participant following a withdrawal or disqualification. Enables lineage tracking of substitutions and replacements for broadcast and competition governance.' ;
    rdfs:domain ind:Participant ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Participant .

ind:accreditationCode rdf:type rdf:Property ;
    rdfs:label 'Accreditation Code' ;
    rdfs:comment 'Official accreditation or credential code issued to the participant for venue access and event operations purposes. Sourced from the venue access control system (Ticketmaster/AXS). Required for gate access, broadcast zone entry, and VIP area clearance.' ;
    rdfs:domain ind:Participant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualEndTime rdf:type rdf:Property ;
    rdfs:label 'Actual End Time' ;
    rdfs:comment 'Actual date and time when the participant\'s competition or performance concluded. Used for duration calculation, broadcast scheduling, and post-event reconciliation.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualStartTime rdf:type rdf:Property ;
    rdfs:label 'Actual Start Time' ;
    rdfs:comment 'Actual date and time when the participant\'s competition or performance commenced. Compared against scheduled_start_time for operational punctuality reporting and broadcast SLA compliance.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:appearanceFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Appearance Fee Amount' ;
    rdfs:comment 'Contracted appearance fee or performance guarantee amount payable to the participant for this event, denominated in appearance_fee_currency. Confidential financial data. Used for event cost management, EBITDA reporting, and SAP S/4HANA FI/CO reconciliation.' ;
    rdfs:domain ind:Participant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:appearanceFeeCurrency rdf:type rdf:Property ;
    rdfs:label 'Appearance Fee Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the appearance fee or performance guarantee payable to the participant for this event. Confidential financial data. Applicable primarily to entertainment performers and exhibition athletes.' ;
    rdfs:domain ind:Participant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:broadcastFeatureFlag rdf:type rdf:Property ;
    rdfs:label 'Broadcast Feature Flag' ;
    rdfs:comment 'Indicates whether this participant has been designated as a featured participant for broadcast production purposes (e.g., pre-match spotlight, in-game feature segment, post-match interview). Consumed by Dalet Galaxy broadcast workflow and content production teams.' ;
    rdfs:domain ind:Participant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:competitionResult rdf:type rdf:Property ;
    rdfs:label 'Competition Result' ;
    rdfs:comment 'Official outcome of the event for this participant as determined by the officiating body. Win, loss, or draw for standard fixtures; no_contest for abandoned events; disqualified for rule violations; walkover for uncontested advancement. Populated post-event.' ;
    rdfs:domain ind:Participant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractType rdf:type rdf:Property ;
    rdfs:label 'Contract Type' ;
    rdfs:comment 'Classification of the contractual arrangement under which the participant is engaged for this event. CBA (Collective Bargaining Agreement) player contracts are governed by league CBAs; guest_performer applies to entertainment acts; exhibition applies to non-competitive appearances; developmental applies to academy or minor league participants. Confidential business data.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crmContactReference rdf:type rdf:Property ;
    rdfs:label 'Crm Contact Reference' ;
    rdfs:comment 'Salesforce CRM contact or account identifier for the participant or their management entity. Enables fan engagement, sponsor activation, and NIL campaign targeting through Adobe Experience Platform and Salesforce CRM.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eligibilityVerifiedDate rdf:type rdf:Property ;
    rdfs:label 'Eligibility Verified Date' ;
    rdfs:comment 'Date on which the participant\'s eligibility for this event was formally verified by the league compliance or event operations team. Supports audit trail requirements under governing body regulations.' ;
    rdfs:domain ind:Participant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:entityReference rdf:type rdf:Property ;
    rdfs:label 'Entity Reference' ;
    rdfs:comment 'Reference to the athlete, team, performer, or competing entity participating in the event. Polymorphic identifier resolved by entity_type.' ;
    rdfs:domain ind:Participant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:entityType rdf:type rdf:Property ;
    rdfs:label 'Entity Type' ;
    rdfs:comment 'Discriminator indicating whether the participant is an individual athlete, a team, a musical performer, a support act, or a wildcard entry. Drives downstream routing to broadcast, ticketing, and fan engagement domains.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entryMethod rdf:type rdf:Property ;
    rdfs:label 'Entry Method' ;
    rdfs:comment 'Method by which the participant qualified or was selected to participate in the event. Direct qualification indicates earned entry through league standings; wildcard indicates discretionary selection; invitation applies to exhibition and all-star events; playoff_seed applies to post-season competition; draft applies to league draft events; bid applies to hosted events. [ENUM-REF-CANDIDATE: direct_qualification|wildcard|invitation|playoff_seed|draft|bid|other — promote to reference product]' ;
    rdfs:domain ind:Participant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:homeVenueFlag rdf:type rdf:Property ;
    rdfs:label 'Home Venue Flag' ;
    rdfs:comment 'Indicates whether the event is being held at the participant\'s designated home venue. True for home fixtures; False for away or neutral venue fixtures. Drives ticketing allocation, fan engagement targeting, and revenue attribution.' ;
    rdfs:domain ind:Participant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hudlProfileCode rdf:type rdf:Property ;
    rdfs:label 'Hudl Profile Code' ;
    rdfs:comment 'Unique identifier linking this participant to their performance analytics profile in SportsCode/Hudl. Enables downstream performance video analysis, WAR (Wins Above Replacement), QBR (Quarterback Rating), and ERA (Earned Run Average) metric computation for this event.' ;
    rdfs:domain ind:Participant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCaptainOrLead rdf:type rdf:Property ;
    rdfs:label 'Is Captain Or Lead' ;
    rdfs:comment 'Indicates whether the participant holds the captain designation (sports) or lead performer designation (entertainment) for this specific event. True when the participant is the designated captain or headlining lead.' ;
    rdfs:domain ind:Participant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jerseyNumber rdf:type rdf:Property ;
    rdfs:label 'Jersey Number' ;
    rdfs:comment 'Official jersey or kit number assigned to the athlete or team representative for this specific event. Applicable to sports fixtures. Null for entertainment events. Sourced from league registration systems.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lineupConfirmed rdf:type rdf:Property ;
    rdfs:label 'Lineup Confirmed' ;
    rdfs:comment 'Indicates whether the submitted lineup has been officially confirmed and accepted by the league or event operations team. True when confirmed; False when pending or rejected.' ;
    rdfs:domain ind:Participant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lineupSubmissionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Lineup Submission Timestamp' ;
    rdfs:comment 'Date and time when the official lineup, roster, or set list was formally submitted by the participant\'s management or coaching staff to the league or event organiser. Critical for compliance with pre-match lineup deadlines mandated by governing bodies.' ;
    rdfs:domain ind:Participant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:mediaRightsClearanceStatus rdf:type rdf:Property ;
    rdfs:label 'Media Rights Clearance Status' ;
    rdfs:comment 'Status of media rights clearance for this participant\'s appearance in the event. Cleared indicates full broadcast and digital distribution rights are confirmed; pending indicates rights are under negotiation; restricted indicates partial rights only; blocked indicates no broadcast rights. Consumed by content and broadcast domains for DRM (Digital Rights Management) enforcement.' ;
    rdfs:domain ind:Participant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nationalityCountry rdf:type rdf:Property ;
    rdfs:label 'Nationality Country' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code representing the nationality of the participant or the country of registration for a team. Used for international competition eligibility, governing body reporting, and broadcast rights geo-targeting.' ;
    rdfs:domain ind:Participant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nilAgreementActive rdf:type rdf:Property ;
    rdfs:label 'Nil Agreement Active' ;
    rdfs:comment 'Indicates whether the participant has an active NIL (Name, Image and Likeness) agreement in effect at the time of this event. Relevant for collegiate and amateur participants. Drives content rights, merchandise licensing, and sponsorship activation restrictions.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:participantRole rdf:type rdf:Property ;
    rdfs:label 'Participant Role' ;
    rdfs:comment 'Designates the competitive or performance role of the participant within the event. For sports fixtures: home_team or away_team. For concerts and live experiences: headliner, support_act. Wildcard and neutral apply to tournament and exhibition contexts.' ;
    rdfs:domain ind:Participant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:participationStatus rdf:type rdf:Property ;
    rdfs:label 'Participation Status' ;
    rdfs:comment 'Current lifecycle status of the participant\'s involvement in the event. Confirmed indicates full clearance; withdrawn indicates voluntary or involuntary removal; suspended reflects disciplinary action per league CBA or governing body ruling; TBD (To Be Determined) indicates pending confirmation; disqualified reflects post-event ruling; pending_review indicates an active compliance or eligibility review. [ENUM-REF-CANDIDATE: confirmed|withdrawn|suspended|tbd|disqualified|pending_review — promote to reference product]' ;
    rdfs:domain ind:Participant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:performanceSlotOrder rdf:type rdf:Property ;
    rdfs:label 'Performance Slot Order' ;
    rdfs:comment 'Sequential order in which the participant is scheduled to perform or compete within the event programme. For concerts: set list order. For multi-bout events: bout sequence. Null for single-match sports fixtures.' ;
    rdfs:domain ind:Participant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rankingPointsEarned rdf:type rdf:Property ;
    rdfs:label 'Ranking Points Earned' ;
    rdfs:comment 'Official ranking or standing points awarded to the participant as a result of their performance in this event. Used to update league tables, world rankings, or tournament standings. Governed by the relevant league or governing body points allocation rules.' ;
    rdfs:domain ind:Participant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recordCreatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Record Created Timestamp' ;
    rdfs:comment 'Date and time when this event participant record was first created in the Silver Layer lakehouse. Supports audit trail, data lineage, and GDPR data subject request processing.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:recordUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Record Updated Timestamp' ;
    rdfs:comment 'Date and time when this event participant record was most recently modified. Supports incremental data processing, change data capture, and audit trail requirements in the Databricks Silver Layer.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scheduledStartTime rdf:type rdf:Property ;
    rdfs:label 'Scheduled Start Time' ;
    rdfs:comment 'Planned date and time when the participant\'s competition bout, match, or performance set is scheduled to begin. Distinct from the overall event start time when multiple participants perform sequentially.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:score rdf:type rdf:Property ;
    rdfs:label 'Score' ;
    rdfs:comment 'Final score, points, or goals recorded for this participant in the event. Applicable to sports fixtures. Null for entertainment events. Sourced from official match data systems.' ;
    rdfs:domain ind:Participant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:seedingRank rdf:type rdf:Property ;
    rdfs:label 'Seeding Rank' ;
    rdfs:comment 'Numeric seeding rank assigned to the participant for tournament bracket placement or competition draw purposes. Lower values indicate higher seeding. Null for non-seeded events such as regular season fixtures or concerts.' ;
    rdfs:domain ind:Participant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:travelOriginCountry rdf:type rdf:Property ;
    rdfs:label 'Travel Origin Country' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code representing the country from which the participant is travelling to the event. Used for logistics planning, visa and work permit compliance, and international governing body reporting.' ;
    rdfs:domain ind:Participant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:uniformColorCode rdf:type rdf:Property ;
    rdfs:label 'Uniform Color Code' ;
    rdfs:comment 'Designated uniform or kit color code for the participant in this event (e.g., HOME, AWAY, THIRD, ALTERNATE). Ensures broadcast production and officiating clarity. Governed by league uniform regulations.' ;
    rdfs:domain ind:Participant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:withdrawalReason rdf:type rdf:Property ;
    rdfs:label 'Withdrawal Reason' ;
    rdfs:comment 'Categorised reason for participant withdrawal from the event. Populated only when participation_status is withdrawn or disqualified. Supports injury reporting, disciplinary tracking, and force majeure documentation. [ENUM-REF-CANDIDATE: injury|suspension|personal_reasons|scheduling_conflict|disqualification|force_majeure|other — promote to reference product]' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:withdrawalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Withdrawal Timestamp' ;
    rdfs:comment 'Date and time when the participant\'s withdrawal or disqualification was officially recorded. Null when participation_status is not withdrawn or disqualified. Used for downstream broadcast, ticketing, and fan notification workflows.' ;
    rdfs:domain ind:Participant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:officiatingAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Officiating Assignment Id' ;
    rdfs:comment 'Unique surrogate identifier for each officiating assignment record in the Silver layer lakehouse. Primary key for this transactional entity.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OfficiatingAssignment .

ind:primaryOfficiatingOfficialId rdf:type rdf:Property ;
    rdfs:label 'Primary Officiating Official Id' ;
    rdfs:comment 'Reference to the match official (referee, linesman, VAR operator, TMO, judge, or scorer) being assigned to the fixture.' ;
    rdfs:domain ind:OfficiatingAssignment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Official .

ind:assignmentDate rdf:type rdf:Property ;
    rdfs:label 'Assignment Date' ;
    rdfs:comment 'The calendar date on which the officiating assignment was formally issued by the governing body or league officiating department.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assignmentMethod rdf:type rdf:Property ;
    rdfs:label 'Assignment Method' ;
    rdfs:comment 'The method by which the official was assigned to this fixture — manual selection by officiating coordinator, automated rotation algorithm, rotational schedule, direct appointment by governing body, or emergency replacement.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Assignment Reference Number' ;
    rdfs:comment 'Externally-known alphanumeric reference code for this officiating assignment, used in league governance communications, official notifications, and compliance audit trails.' ;
    rdfs:domain ind:OfficiatingAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentStatus rdf:type rdf:Property ;
    rdfs:label 'Assignment Status' ;
    rdfs:comment 'Current lifecycle status of the officiating assignment, tracking the workflow from initial proposal through confirmation, acceptance, or withdrawal. Supports governance and scheduling workflows.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confirmationDate rdf:type rdf:Property ;
    rdfs:label 'Confirmation Date' ;
    rdfs:comment 'The date on which the assigned official formally confirmed acceptance of the assignment. Null if not yet confirmed.' ;
    rdfs:domain ind:OfficiatingAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:conflictOfInterestFlag rdf:type rdf:Property ;
    rdfs:label 'Conflict Of Interest Flag' ;
    rdfs:comment 'Indicates whether a potential conflict of interest has been identified for this official in relation to the assigned fixture (e.g., prior affiliation with a competing team, financial interest). True = conflict identified; False = no conflict.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:conflictOfInterestNotes rdf:type rdf:Property ;
    rdfs:label 'Conflict Of Interest Notes' ;
    rdfs:comment 'Free-text description of the nature of the identified conflict of interest, if applicable. Populated only when conflict_of_interest_flag is True. Treated as confidential governance data.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crewChiefFlag rdf:type rdf:Property ;
    rdfs:label 'Crew Chief Flag' ;
    rdfs:comment 'Indicates whether this official is designated as the crew chief or lead referee for the fixture. True = crew chief; False = supporting official.' ;
    rdfs:domain ind:OfficiatingAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:disciplinaryIncidentFlag rdf:type rdf:Property ;
    rdfs:label 'Disciplinary Incident Flag' ;
    rdfs:comment 'Indicates whether a disciplinary incident or formal complaint was raised in connection with this officiating assignment. True = incident recorded; False = no incident. Triggers governance review workflow.' ;
    rdfs:domain ind:OfficiatingAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:expenseAllowanceAmount rdf:type rdf:Property ;
    rdfs:label 'Expense Allowance Amount' ;
    rdfs:comment 'The approved expense allowance payable to the official for travel, accommodation, and per diem costs associated with this assignment, per governing body policy.' ;
    rdfs:domain ind:OfficiatingAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:notificationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Notification Timestamp' ;
    rdfs:comment 'The precise date and time at which the official was notified of the assignment, supporting SLA compliance tracking for officiating notification windows.' ;
    rdfs:domain ind:OfficiatingAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:officialRole rdf:type rdf:Property ;
    rdfs:label 'Official Role' ;
    rdfs:comment 'The specific officiating role assigned to the official for this fixture (e.g., Referee, Assistant Referee, Fourth Official, VAR Operator, TMO, Linesman, Judge, Scorer, Video Review Official). [ENUM-REF-CANDIDATE: referee|assistant_referee|fourth_official|var_operator|tmo|linesman|judge|scorer|video_review_official|head_linesman|back_judge|umpire — promote to reference product]' ;
    rdfs:domain ind:OfficiatingAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:officiatingCrewSize rdf:type rdf:Property ;
    rdfs:label 'Officiating Crew Size' ;
    rdfs:comment 'The total number of officials assigned to the fixture as part of the officiating crew, including all roles (referee, assistants, VAR, TMO, etc.).' ;
    rdfs:domain ind:OfficiatingAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:officiatingFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Officiating Fee Amount' ;
    rdfs:comment 'The gross fee payable to the official for this assignment, as defined by the governing body\'s officiating pay scale or collective bargaining agreement (CBA). Expressed in the league\'s base currency.' ;
    rdfs:domain ind:OfficiatingAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:performanceRating rdf:type rdf:Property ;
    rdfs:label 'Performance Rating' ;
    rdfs:comment 'Numeric performance rating assigned to the official for this fixture by the officiating assessor or governing body evaluator, typically on a standardized scale (e.g., 1.00–10.00). Supports officiating quality management and career development.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:postMatchReportDate rdf:type rdf:Property ;
    rdfs:label 'Post Match Report Date' ;
    rdfs:comment 'The date on which the post-match officiating report was submitted by the official. Null if not yet submitted.' ;
    rdfs:domain ind:OfficiatingAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:postMatchReportReference rdf:type rdf:Property ;
    rdfs:label 'Post Match Report Reference' ;
    rdfs:comment 'Reference identifier or document number for the post-match officiating report submitted by the lead official after the fixture. Links to the report stored in the DAM or document management system.' ;
    rdfs:domain ind:OfficiatingAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postMatchReportSubmittedFlag rdf:type rdf:Property ;
    rdfs:label 'Post Match Report Submitted Flag' ;
    rdfs:comment 'Indicates whether the post-match officiating report has been submitted by the official following the fixture. True = submitted; False = pending. Supports compliance monitoring.' ;
    rdfs:domain ind:OfficiatingAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:preMatchBriefingTimestamp rdf:type rdf:Property ;
    rdfs:label 'Pre Match Briefing Timestamp' ;
    rdfs:comment 'The scheduled date and time of the pre-match officiating crew briefing, where the lead referee reviews match protocols, VAR/TMO procedures, and competition-specific directives with the crew.' ;
    rdfs:domain ind:OfficiatingAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:replacementReason rdf:type rdf:Property ;
    rdfs:label 'Replacement Reason' ;
    rdfs:comment 'The reason an official was replaced or withdrew from this assignment. Populated only when assignment_status is \'replaced\' or \'withdrawn\'. Supports officiating continuity and governance reporting. [ENUM-REF-CANDIDATE: injury|illness|conflict_of_interest|scheduling_conflict|disciplinary|withdrawal|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:OfficiatingAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tmoEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Tmo Enabled Flag' ;
    rdfs:comment 'Indicates whether a Television Match Official (TMO) is active for this fixture, applicable in rugby and other sports using TMO review protocols.' ;
    rdfs:domain ind:OfficiatingAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:travelOriginCity rdf:type rdf:Property ;
    rdfs:label 'Travel Origin City' ;
    rdfs:comment 'The city from which the official will travel to the fixture venue, used for logistics planning and travel cost estimation.' ;
    rdfs:domain ind:OfficiatingAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:travelRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Travel Required Flag' ;
    rdfs:comment 'Indicates whether the official requires travel arrangements (flights, accommodation) to attend the assigned fixture. Supports logistics and expense management.' ;
    rdfs:domain ind:OfficiatingAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:varEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Var Enabled Flag' ;
    rdfs:comment 'Indicates whether Video Assistant Referee (VAR) technology is active for this fixture, determining whether a VAR operator role is required in the officiating crew.' ;
    rdfs:domain ind:OfficiatingAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:wadaComplianceVerifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Wada Compliance Verified Flag' ;
    rdfs:comment 'Indicates whether the assigned official\'s WADA compliance status (anti-doping clearance) has been verified prior to the fixture. Applicable for international competitions. True = verified; False = not verified.' ;
    rdfs:domain ind:OfficiatingAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:eventIncidentId rdf:type rdf:Property ;
    rdfs:label 'Event Incident Id' ;
    rdfs:comment 'Unique surrogate identifier for each in-event incident record. Primary key for the event_incident data product in the Silver Layer lakehouse.' ;
    rdfs:domain ind:EventIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:officialId rdf:type rdf:Property ;
    rdfs:label 'Official Id' ;
    rdfs:comment 'Foreign key linking to league.official. Business justification: Incidents involving match officials (assaults, threats, interference) require direct official attribution for disciplinary reporting, official safety tracking, and governing body regulatory submission' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Official .

ind:primaryEventAthleteAthleteProfileId rdf:type rdf:Property ;
    rdfs:label 'Primary Event Athlete Athlete Profile Id' ;
    rdfs:comment 'Identifier of the athlete directly involved in the incident (e.g., player receiving a red card, injured athlete). Null for non-athlete incidents such as crowd disturbances or equipment failures. Links to the athlete master data product.' ;
    rdfs:domain ind:EventIncident ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AthleteProfile .

ind:primaryEventFixtureId rdf:type rdf:Property ;
    rdfs:label 'Primary Event Fixture Id' ;
    rdfs:comment 'Identifier of the parent live sports or entertainment event during which this incident occurred. Links to the event master data product.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Fixture .

ind:suspensionRecordId rdf:type rdf:Property ;
    rdfs:label 'Suspension Record Id' ;
    rdfs:comment 'Foreign key linking to athlete.suspension_record. Business justification: Disciplinary workflow requires tracing an on-field incident (violent conduct, doping detection) directly to the resulting suspension record for regulatory filings, league disciplinary hearings, and in' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SuspensionRecord .

ind:broadcastDelayMinutes rdf:type rdf:Property ;
    rdfs:label 'Broadcast Delay Minutes' ;
    rdfs:comment 'Duration in minutes that the live broadcast was delayed or interrupted as a result of this incident. Zero if no broadcast delay occurred. Supports RSN and OTT rights holder SLA reporting and FCC compliance.' ;
    rdfs:domain ind:EventIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:broadcastImpact rdf:type rdf:Property ;
    rdfs:label 'Broadcast Impact' ;
    rdfs:comment 'Indicates whether the incident caused a disruption to live broadcast operations (signal loss, unplanned cut-away, OB unit failure, broadcast delay). Triggers notification to broadcast rights holders and Dalet Galaxy media workflow.' ;
    rdfs:domain ind:EventIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:createdAt rdf:type rdf:Property ;
    rdfs:label 'Created At' ;
    rdfs:comment 'Timestamp when this incident record was first created in the system. Audit trail field for data lineage, Silver Layer ingestion tracking, and compliance record retention.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:detectedAt rdf:type rdf:Property ;
    rdfs:label 'Detected At' ;
    rdfs:comment 'Timestamp when the incident was formally detected and logged by operations staff or automated monitoring systems. May differ from occurred_at when there is a reporting lag. Used to measure detection latency for SLA compliance.' ;
    rdfs:domain ind:EventIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:fanImpactCount rdf:type rdf:Property ;
    rdfs:label 'Fan Impact Count' ;
    rdfs:comment 'Estimated number of fans directly affected by the incident (e.g., evacuated, medically treated, displaced from seating). Used for post-event fan experience reporting, NPS impact analysis, and insurance liability assessment.' ;
    rdfs:domain ind:EventIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fieldSurfaceCondition rdf:type rdf:Property ;
    rdfs:label 'Field Surface Condition' ;
    rdfs:comment 'Assessed condition of the playing surface or field at the time of the incident. Populated for field/surface condition change incidents and weather delays. Supports governing body match-day inspection reporting and player safety compliance. [ENUM-REF-CANDIDATE: playable|unplayable|waterlogged|frozen|damaged|under_repair|acceptable|not_applicable — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:EventIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gameDelayDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Game Delay Duration Minutes' ;
    rdfs:comment 'Total duration in minutes that the event or match was delayed or suspended as a direct result of this incident. Zero if no delay occurred. Critical for broadcast scheduling, insurance claims, and governing body reporting.' ;
    rdfs:domain ind:EventIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:incidentDescription rdf:type rdf:Property ;
    rdfs:label 'Incident Description' ;
    rdfs:comment 'Free-text narrative description of the incident, capturing contextual details not covered by structured fields. Authored by the reporting operations staff member at time of logging. Used in post-event reports, insurance documentation, and governing body submissions.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentStatus rdf:type rdf:Property ;
    rdfs:label 'Incident Status' ;
    rdfs:comment 'Current lifecycle state of the incident record, tracking workflow from initial detection through resolution and post-event closure. Drives operational dashboards and compliance reporting completeness checks.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentType rdf:type rdf:Property ;
    rdfs:label 'Incident Type' ;
    rdfs:comment 'Categorical classification of the incident nature. Covers the full spectrum of in-event operational incidents. [ENUM-REF-CANDIDATE: red_card|ejection|player_injury|crowd_disturbance|equipment_failure|weather_delay|power_outage|medical_emergency|field_condition_change|security_breach|fire_alarm|structural_concern|broadcast_failure|protest|other — promote to reference product]' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceClaimReference rdf:type rdf:Property ;
    rdfs:label 'Insurance Claim Reference' ;
    rdfs:comment 'External reference number assigned by the insurance carrier for the claim associated with this incident. Populated once a claim is formally opened. Confidential business data used for financial reconciliation in SAP S/4HANA.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceClaimRequired rdf:type rdf:Property ;
    rdfs:label 'Insurance Claim Required' ;
    rdfs:comment 'Indicates whether this incident is expected to generate an insurance claim (event cancellation, liability, workers compensation, medical). Triggers insurance documentation workflow and financial provisioning in SAP S/4HANA FI.' ;
    rdfs:domain ind:EventIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:locationZone rdf:type rdf:Property ;
    rdfs:label 'Location Zone' ;
    rdfs:comment 'Designated zone or area within the venue where the incident occurred (e.g., playing_field, north_stand, concourse_level_2, media_tribune, locker_room, parking_lot, broadcast_compound). Supports venue operations analysis and ADA/OSHA compliance mapping.' ;
    rdfs:domain ind:EventIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:matchClockTimeSeconds rdf:type rdf:Property ;
    rdfs:label 'Match Clock Time Seconds' ;
    rdfs:comment 'Elapsed match or event clock time in seconds at the moment the incident occurred. Enables precise temporal correlation with broadcast footage, VAR/TMO review, and performance analytics in SportsCode/Hudl. Null for non-competition events (concerts, ceremonies).' ;
    rdfs:domain ind:EventIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:matchPeriod rdf:type rdf:Property ;
    rdfs:label 'Match Period' ;
    rdfs:comment 'Designated period or segment of the event during which the incident occurred. Supports competition governance reporting and broadcast clip indexing. \'full_event\' used for non-segmented live experiences such as concerts. [ENUM-REF-CANDIDATE: pre_match|1st_half|2nd_half|extra_time_1|extra_time_2|penalty_shootout|intermission|post_match|full_event — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:EventIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mediaCoverageFlag rdf:type rdf:Property ;
    rdfs:label 'Media Coverage Flag' ;
    rdfs:comment 'Indicates whether the incident received external media coverage (broadcast, digital, print). Triggers communications and PR response workflow. Supports reputation management and sponsor impact assessment.' ;
    rdfs:domain ind:EventIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:occurredAt rdf:type rdf:Property ;
    rdfs:label 'Occurred At' ;
    rdfs:comment 'Wall-clock timestamp (ISO 8601 with timezone offset) recording the precise real-world moment the incident was first observed or reported. Principal business event timestamp for the incident lifecycle. Distinct from match clock time.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:pedRelated rdf:type rdf:Property ;
    rdfs:label 'Ped Related' ;
    rdfs:comment 'Indicates whether the incident involves a suspected or confirmed Performance Enhancing Drug (PED) violation or related medical event. Triggers mandatory WADA reporting workflow and CAS arbitration tracking.' ;
    rdfs:domain ind:EventIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:precipitationMm rdf:type rdf:Property ;
    rdfs:label 'Precipitation Mm' ;
    rdfs:comment 'Recorded precipitation level in millimetres at the time of the incident. Supports weather-delay documentation, field/surface condition assessment, and insurance claim substantiation.' ;
    rdfs:domain ind:EventIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:referenceNumber rdf:type rdf:Property ;
    rdfs:label 'Reference Number' ;
    rdfs:comment 'Externally-known alphanumeric reference code assigned to the incident at time of occurrence, used for cross-system tracking, insurance documentation, and regulatory reporting. Format: INC-{YYYY}-{NNNNNN}.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryReportSubmitted rdf:type rdf:Property ;
    rdfs:label 'Regulatory Report Submitted' ;
    rdfs:comment 'Indicates whether the required regulatory report has been formally submitted to the relevant governing body or authority. Null when regulatory_reporting_required is False. Supports compliance audit and SLA tracking.' ;
    rdfs:domain ind:EventIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryReportSubmittedAt rdf:type rdf:Property ;
    rdfs:label 'Regulatory Report Submitted At' ;
    rdfs:comment 'Timestamp when the regulatory report was formally submitted to the governing body or authority. Null if not yet submitted. Used to verify compliance with mandatory reporting deadlines (e.g., OSHA 8-hour fatality reporting window).' ;
    rdfs:domain ind:EventIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:regulatoryReportingRequired rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reporting Required' ;
    rdfs:comment 'Indicates whether this incident triggers a mandatory regulatory reporting obligation to an external governing body or regulatory authority (OSHA, FIFA, NFL, NBA, WADA, FCC, etc.). Drives automated compliance workflow routing in post-event reconciliation.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:resolutionNotes rdf:type rdf:Property ;
    rdfs:label 'Resolution Notes' ;
    rdfs:comment 'Free-text notes documenting the resolution actions taken, outcome achieved, and any follow-up actions required. Populated at incident closure. Supports post-event reconciliation, lessons-learned analysis, and insurance claim documentation.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolvedAt rdf:type rdf:Property ;
    rdfs:label 'Resolved At' ;
    rdfs:comment 'Timestamp when the incident was operationally resolved and normal event operations resumed or the incident was formally closed. Null if incident remains open. Used to calculate response duration and SLA adherence.' ;
    rdfs:domain ind:EventIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:responseActionTaken rdf:type rdf:Property ;
    rdfs:label 'Response Action Taken' ;
    rdfs:comment 'Structured description of the primary operational response action executed in reaction to the incident (e.g., medical_evacuation, play_suspended, crowd_dispersal, equipment_replaced, power_restored, venue_section_cleared, VAR_review_initiated). [ENUM-REF-CANDIDATE: medical_evacuation|play_suspended|crowd_dispersal|equipment_replaced|power_restored|venue_section_cleared|var_review_initiated|match_abandoned|emergency_services_called|shelter_in_place — promote to reference product]' ;
    rdfs:domain ind:EventIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseTeamType rdf:type rdf:Property ;
    rdfs:label 'Response Team Type' ;
    rdfs:comment 'Category of the primary response team deployed to address the incident. Supports post-event resource utilization analysis and emergency preparedness planning. [ENUM-REF-CANDIDATE: medical|security|fire_safety|technical|operations|governing_body|external_emergency_services|broadcast — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:EventIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:severityLevel rdf:type rdf:Property ;
    rdfs:label 'Severity Level' ;
    rdfs:comment 'Operational severity rating assigned to the incident at time of occurrence, driving escalation protocols, response resource allocation, and regulatory reporting obligations. Critical = life-safety or event-stopping; High = significant operational impact; Medium = notable but manageable; Low = minor; Informational = logged for record only.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureCelsius rdf:type rdf:Property ;
    rdfs:label 'Temperature Celsius' ;
    rdfs:comment 'Recorded ambient air temperature in degrees Celsius at the venue at the time of the incident. Critical for heat-related medical incidents, weather-delay justification, and OSHA heat illness prevention compliance.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:updatedAt rdf:type rdf:Property ;
    rdfs:label 'Updated At' ;
    rdfs:comment 'Timestamp of the most recent update to this incident record. Supports change data capture (CDC) in the Databricks Silver Layer and audit trail maintenance for compliance reporting.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:varTmoOutcome rdf:type rdf:Property ;
    rdfs:label 'Var Tmo Outcome' ;
    rdfs:comment 'Result of the Video Assistant Referee (VAR) or Television Match Official (TMO) review triggered by this incident. Null when var_tmo_review_triggered is False. Supports competition governance reporting and post-match analysis.' ;
    rdfs:domain ind:EventIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:varTmoReviewTriggered rdf:type rdf:Property ;
    rdfs:label 'Var Tmo Review Triggered' ;
    rdfs:comment 'Indicates whether the incident triggered a Video Assistant Referee (VAR) or Television Match Official (TMO) review process. Applicable to football, rugby, and other sports with video review protocols. Supports competition governance and SportsCode/Hudl video analysis integration.' ;
    rdfs:domain ind:EventIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:windSpeedKmh rdf:type rdf:Property ;
    rdfs:label 'Wind Speed Kmh' ;
    rdfs:comment 'Recorded wind speed in kilometres per hour at the venue at the time of the incident. Used for weather-delay justification, structural safety assessments, and insurance documentation.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:venueAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Venue Assignment Id' ;
    rdfs:comment 'Unique surrogate identifier for the event-to-venue assignment record. Primary key for this association entity.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VenueAssignment .

ind:primaryVenueId rdf:type rdf:Property ;
    rdfs:label 'Primary Venue Id' ;
    rdfs:comment 'Reference to the venue facility being assigned to host the event. Links to the venue master record.' ;
    rdfs:domain ind:VenueAssignment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Venue .

ind:adaAccessibleSeatCount rdf:type rdf:Property ;
    rdfs:label 'Ada Accessible Seat Count' ;
    rdfs:comment 'Number of ADA-compliant accessible seats allocated for this event at this venue configuration. Used by ticketing domain to configure accessible inventory in Archtics and ensure compliance with ADA minimum accessible seating ratios.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approvedCapacity rdf:type rdf:Property ;
    rdfs:label 'Approved Capacity' ;
    rdfs:comment 'Maximum number of attendees approved for this specific event at this venue, reflecting the capacity configuration type. May differ from the venue\'s total rated capacity due to event-specific restrictions, safety requirements, or reduced-capacity mandates. Used by ticketing domain to cap inventory in Archtics and Ticketmaster/AXS.' ;
    rdfs:domain ind:VenueAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assignmentCode rdf:type rdf:Property ;
    rdfs:label 'Assignment Code' ;
    rdfs:comment 'Externally-known business identifier for this venue assignment, used in operational communications, venue operations work orders, and ticketing system configuration (e.g., Archtics seating inventory setup). Format: EVA- followed by 4-12 alphanumeric characters.' ;
    rdfs:domain ind:VenueAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Assignment Effective Date' ;
    rdfs:comment 'Calendar date from which this venue assignment is operationally effective. Venue operations teams use this date to begin facility preparation scheduling, and ticketing teams use it to open inventory configuration in Archtics.' ;
    rdfs:domain ind:VenueAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assignmentExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Assignment Expiry Date' ;
    rdfs:comment 'Calendar date after which this venue assignment is no longer valid. Used for provisional or alternate assignments that have a defined validity window. Null for confirmed primary assignments with no expiry.' ;
    rdfs:domain ind:VenueAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assignmentNotes rdf:type rdf:Property ;
    rdfs:label 'Assignment Notes' ;
    rdfs:comment 'Free-text operational notes related to this venue assignment, capturing special conditions, exceptions, or instructions for venue operations, ticketing, and broadcast teams that are not captured in structured fields.' ;
    rdfs:domain ind:VenueAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:broadcastInfrastructureReady rdf:type rdf:Property ;
    rdfs:label 'Broadcast Infrastructure Ready' ;
    rdfs:comment 'Indicates whether the venue\'s broadcast infrastructure (OB (Outside Broadcast) unit connections, fiber feeds, camera positions, commentary positions) has been confirmed as ready for this event. Used by broadcast operations and Dalet Galaxy workflow planning.' ;
    rdfs:domain ind:VenueAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:changeHistoryFlag rdf:type rdf:Property ;
    rdfs:label 'Change History Flag' ;
    rdfs:comment 'Indicates whether this venue assignment record has been modified or superseded since initial creation, signaling that a prior assignment existed for this event. Used for audit trail tracking and downstream notification to venue operations and ticketing teams of venue changes.' ;
    rdfs:domain ind:VenueAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:changeReason rdf:type rdf:Property ;
    rdfs:label 'Change Reason' ;
    rdfs:comment 'Free-text description of the reason for a venue assignment change, such as venue unavailability, weather conditions, safety concerns, league mandate, or contractual renegotiation. Populated when change_history_flag is True.' ;
    rdfs:domain ind:VenueAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confirmationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Confirmation Timestamp' ;
    rdfs:comment 'Date and time when the venue assignment was formally confirmed, triggering downstream venue operations preparation and ticketing inventory configuration in Archtics. Null if assignment is still in proposed or provisional state.' ;
    rdfs:domain ind:Event ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:designationType rdf:type rdf:Property ;
    rdfs:label 'Designation Type' ;
    rdfs:comment 'Indicates whether this venue is the primary assigned venue, an alternate venue held in reserve, a neutral-site venue (neither team\'s home ground, common in playoff or championship contexts), or a backup venue activated only if the primary is unavailable.' ;
    rdfs:domain ind:VenueAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fieldSetupType rdf:type rdf:Property ;
    rdfs:label 'Field Setup Type' ;
    rdfs:comment 'Specifies the physical configuration of the playing surface, court, or stage for this event. Determines sightline mapping, seating kill zones, and production logistics. \'standard\' applies to normal league-regulation field/court layout; concert and stage variants apply to live entertainment events. [ENUM-REF-CANDIDATE: standard|concert_stage|in_the_round|end_stage|thrust_stage|custom|floor_only|half_house — promote to reference product]' ;
    rdfs:domain ind:VenueAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gaSectionEnabled rdf:type rdf:Property ;
    rdfs:label 'Ga Section Enabled' ;
    rdfs:comment 'Indicates whether General Admission (GA) standing sections are enabled for this event at this venue. Affects ticketing inventory configuration, crowd management planning, and OSHA safety compliance for standing areas.' ;
    rdfs:domain ind:VenueAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gateOpenTime rdf:type rdf:Property ;
    rdfs:label 'Gate Open Time' ;
    rdfs:comment 'Scheduled date and time when venue gates open to the public for this event. Used by venue operations, security staffing, and access control configuration in Ticketmaster/AXS gate scan systems.' ;
    rdfs:domain ind:VenueAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:loadInDate rdf:type rdf:Property ;
    rdfs:label 'Load In Date' ;
    rdfs:comment 'Date on which production equipment, staging, and event infrastructure begins loading into the venue. Critical for venue operations scheduling, HVAC (Heating Ventilation and Air Conditioning) activation, and BMS (Building Management System) configuration.' ;
    rdfs:domain ind:VenueAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:loadOutDate rdf:type rdf:Property ;
    rdfs:label 'Load Out Date' ;
    rdfs:comment 'Date by which all production equipment and event infrastructure must be removed from the venue. Used for venue turnaround scheduling and back-to-back event planning.' ;
    rdfs:domain ind:VenueAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mediaRightsZone rdf:type rdf:Property ;
    rdfs:label 'Media Rights Zone' ;
    rdfs:comment 'Geographic media rights zone classification for this venue assignment, determining which RSN (Regional Sports Network), OTT (Over-The-Top Streaming), or broadcast network holds distribution rights for events at this venue. Used in broadcast rights management and content distribution.' ;
    rdfs:domain ind:VenueAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:neutralSiteFlag rdf:type rdf:Property ;
    rdfs:label 'Neutral Site Flag' ;
    rdfs:comment 'Indicates whether this venue assignment represents a neutral-site event where neither competing team or performer has a home-ground advantage. Common in playoff games, championship events, bowl games, and international fixtures. Affects revenue-sharing, ticketing allocation, and broadcast rights.' ;
    rdfs:domain ind:VenueAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:parkingCapacity rdf:type rdf:Property ;
    rdfs:label 'Parking Capacity' ;
    rdfs:comment 'Total number of parking spaces available at or designated for this venue for this event. Used in fan experience planning, transportation logistics, and ancillary revenue forecasting.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rentalFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Rental Fee Amount' ;
    rdfs:comment 'Contracted rental fee payable to the venue operator for hosting this event. Used in event P&L (Profit and Loss) analysis and financial planning in Workday Adaptive Planning. Classified as confidential due to commercial sensitivity.' ;
    rdfs:domain ind:VenueAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rentalFeeCurrency rdf:type rdf:Property ;
    rdfs:label 'Rental Fee Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the venue rental fee amount (e.g., USD, GBP, EUR). Required for multi-currency financial reporting and SAP S/4HANA FI integration.' ;
    rdfs:domain ind:VenueAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seatingManifestVersion rdf:type rdf:Property ;
    rdfs:label 'Seating Manifest Version' ;
    rdfs:comment 'Version identifier of the seating manifest (kill zones, accessible sections, GA (General Admission) areas, SRO (Standing Room Only) sections) configured in Archtics for this event-venue assignment. Tracks changes to seating layout between events at the same venue.' ;
    rdfs:domain ind:VenueAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:securityLevel rdf:type rdf:Property ;
    rdfs:label 'Security Level' ;
    rdfs:comment 'Designated security threat level for this event at this venue, driving staffing levels, screening protocols, and law enforcement coordination. Levels align with internal security classification framework and OSHA venue safety requirements.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sustainabilityCertification rdf:type rdf:Property ;
    rdfs:label 'Sustainability Certification' ;
    rdfs:comment 'ISO 20121 or equivalent sustainability certification status for this venue assignment, documenting environmental management compliance for the event. Supports ESG (Environmental Social Governance) reporting and league sustainability mandates.' ;
    rdfs:domain ind:VenueAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ticketingSystemVenueCode rdf:type rdf:Property ;
    rdfs:label 'Ticketing System Venue Code' ;
    rdfs:comment 'Venue identifier code as configured in the ticketing platform (Ticketmaster/AXS or Archtics) for this specific event assignment. Used to map seating inventory, price tiers, and access control zones to the correct venue configuration.' ;
    rdfs:domain ind:VenueAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:venueContractReference rdf:type rdf:Property ;
    rdfs:label 'Venue Contract Reference' ;
    rdfs:comment 'Reference number of the venue rental or usage contract governing this assignment. Links to the contract management system for financial terms, liability clauses, and cancellation provisions. Classified as confidential due to commercial sensitivity.' ;
    rdfs:domain ind:VenueAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vipHospitalityEnabled rdf:type rdf:Property ;
    rdfs:label 'Vip Hospitality Enabled' ;
    rdfs:comment 'Indicates whether VIP (Very Important Person) hospitality suites, premium clubs, and sponsor hospitality entitlements are activated for this event at this venue. Triggers hospitality operations preparation and sponsor entitlement fulfillment workflows.' ;
    rdfs:domain ind:VenueAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:actualEndDate rdf:type rdf:Property ;
    rdfs:label 'Actual End Date' ;
    rdfs:comment 'Actual calendar date on which the last fixture of this round concluded. May differ from scheduled_end_date. Used for post-event reconciliation, standings finalization, and broadcast rights settlement.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actualStartDate rdf:type rdf:Property ;
    rdfs:label 'Actual Start Date' ;
    rdfs:comment 'Actual calendar date on which the first fixture of this round commenced. May differ from scheduled_start_date due to postponements, weather events, or force majeure. Used for post-event reconciliation and compliance reporting.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:broadcastWindowEnd rdf:type rdf:Property ;
    rdfs:label 'Broadcast Window End' ;
    rdfs:comment 'End timestamp of the broadcast rights window for this competition round. Marks the expiry of live and near-live broadcast entitlements for OTT, RSN, and linear TV distribution.' ;
    rdfs:domain ind:CompetitionRound ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:broadcastWindowStart rdf:type rdf:Property ;
    rdfs:label 'Broadcast Window Start' ;
    rdfs:comment 'Start timestamp of the broadcast rights window for this competition round. Used by Dalet Galaxy and broadcast rights management to schedule OTT, RSN, and linear TV distribution slots.' ;
    rdfs:domain ind:CompetitionRound ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:byeWeekFlag rdf:type rdf:Property ;
    rdfs:label 'Bye Week Flag' ;
    rdfs:comment 'Indicates whether this round is designated as a bye week or rest round in which some or all teams do not compete. Common in NFL scheduling. Affects standings calculation and fixture generation logic.' ;
    rdfs:domain ind:CompetitionRound ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:completedFixtureCount rdf:type rdf:Property ;
    rdfs:label 'Completed Fixture Count' ;
    rdfs:comment 'Number of fixtures within this round that have been fully played and results confirmed. Used to track round completion progress and trigger standings recalculation workflows.' ;
    rdfs:domain ind:CompetitionRound ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:externalRoundReference rdf:type rdf:Property ;
    rdfs:label 'External Round Reference' ;
    rdfs:comment 'Identifier for this competition round as assigned by an external governing body or source system (e.g., FIFA round ID, NFL schedule system ID, Ticketmaster event group ID). Used for cross-system reconciliation and API integration.' ;
    rdfs:domain ind:CompetitionRound ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fixtureCount rdf:type rdf:Property ;
    rdfs:label 'Fixture Count' ;
    rdfs:comment 'Total number of fixtures (matches, games, bouts) scheduled within this competition round. Used for scheduling validation, broadcast slot planning, and venue operations capacity planning.' ;
    rdfs:domain ind:CompetitionRound ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:neutralVenueFlag rdf:type rdf:Property ;
    rdfs:label 'Neutral Venue Flag' ;
    rdfs:comment 'Indicates whether all fixtures in this round are played at a neutral venue rather than home/away venues (e.g., Super Bowl, FIFA World Cup Final, NBA All-Star Game). Affects ticketing allocation and venue operations planning.' ;
    rdfs:domain ind:CompetitionRound ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:overtimeRule rdf:type rdf:Property ;
    rdfs:label 'Overtime Rule' ;
    rdfs:comment 'Rule governing how drawn or tied fixtures in this round are resolved beyond regulation time (e.g., extra time followed by penalty shootout in FIFA knockout rounds, overtime period in NHL, shootout in NHL regular season). Affects fixture duration planning and broadcast scheduling.' ;
    rdfs:domain ind:CompetitionRound ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pointsForDraw rdf:type rdf:Property ;
    rdfs:label 'Points For Draw' ;
    rdfs:comment 'Number of competition points awarded to each team for a draw/tie in this round. Typically 1 in soccer/football formats; 0 in elimination formats. Drives standings calculation.' ;
    rdfs:domain ind:CompetitionRound ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pointsForLoss rdf:type rdf:Property ;
    rdfs:label 'Points For Loss' ;
    rdfs:comment 'Number of competition points awarded to a team or athlete for a loss in this round. Typically 0, but some leagues award 1 point for an overtime/shootout loss (e.g., NHL). Drives standings calculation.' ;
    rdfs:domain ind:CompetitionRound ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pointsForWin rdf:type rdf:Property ;
    rdfs:label 'Points For Win' ;
    rdfs:comment 'Number of competition points awarded to a team or athlete for a win in this round. May vary by stage (e.g., 3 points in group stage, not applicable in knockout). Drives standings calculation.' ;
    rdfs:domain ind:CompetitionRound ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:roundCode rdf:type rdf:Property ;
    rdfs:label 'Round Code' ;
    rdfs:comment 'Externally-known alphanumeric business identifier for the competition round used in scheduling systems, broadcast feeds, and fixture APIs (e.g., NFL-2024-WK01, FIFA-WC-QF1, NBA-2024-R1). Unique within a season or tournament.' ;
    rdfs:domain ind:CompetitionRound ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roundName rdf:type rdf:Property ;
    rdfs:label 'Round Name' ;
    rdfs:comment 'Human-readable display name of the competition round as used in broadcast, ticketing, and fan-facing platforms (e.g., \'Week 1\', \'Matchday 3\', \'Quarter-Final\', \'Wild Card Round\', \'Conference Championship\', \'Super Bowl\', \'Group Stage Round 2\').' ;
    rdfs:domain ind:CompetitionRound ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roundNumber rdf:type rdf:Property ;
    rdfs:label 'Round Number' ;
    rdfs:comment 'Sequential numeric position of this round within its parent season or tournament (e.g., 1 for Week 1, 3 for Matchday 3). Used for ordering, standings calculation, and bracket progression logic.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:roundStatus rdf:type rdf:Property ;
    rdfs:label 'Round Status' ;
    rdfs:comment 'Current lifecycle state of the competition round. Drives fixture scheduling workflows, standings publication, and broadcast planning. Transitions from scheduled → in_progress → completed, or to postponed/cancelled/suspended for disrupted rounds.' ;
    rdfs:domain ind:CompetitionRound ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roundType rdf:type rdf:Property ;
    rdfs:label 'Round Type' ;
    rdfs:comment 'Format of competition within this round — whether fixtures are single-leg, two-legged (home and away), best-of series (e.g., NBA Playoffs best-of-7), round-robin, or elimination format. Governs fixture generation and advancement rules.' ;
    rdfs:domain ind:CompetitionRound ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seasonTicketApplicableFlag rdf:type rdf:Property ;
    rdfs:label 'Season Ticket Applicable Flag' ;
    rdfs:comment 'Indicates whether season ticket holders\' entitlements apply to fixtures in this round. Some playoff or special event rounds may require separate ticket purchases even for season ticket holders.' ;
    rdfs:domain ind:CompetitionRound ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sponsorshipActivationFlag rdf:type rdf:Property ;
    rdfs:label 'Sponsorship Activation Flag' ;
    rdfs:comment 'Indicates whether dedicated sponsorship activations are planned for this competition round (e.g., title sponsorship of a playoff round, naming rights for a championship week). Triggers Salesforce CRM sponsorship workflow.' ;
    rdfs:domain ind:CompetitionRound ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:stageType rdf:type rdf:Property ;
    rdfs:label 'Stage Type' ;
    rdfs:comment 'Classification of the competition stage this round belongs to, distinguishing regular season weeks from playoff brackets, group stages, knockout rounds, and championship finals. Drives standings calculation rules and bracket progression logic. [ENUM-REF-CANDIDATE: regular_season|group_stage|knockout|playoff|final|wildcard|conference_championship|all_star|preseason — promote to reference product]' ;
    rdfs:domain ind:CompetitionRound ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ticketSaleEndDate rdf:type rdf:Property ;
    rdfs:label 'Ticket Sale End Date' ;
    rdfs:comment 'Date on which ticket sales close for fixtures in this competition round. Used by Ticketmaster/AXS and Archtics to manage inventory cutoff and gate access configuration.' ;
    rdfs:domain ind:CompetitionRound ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ticketSaleStartDate rdf:type rdf:Property ;
    rdfs:label 'Ticket Sale Start Date' ;
    rdfs:comment 'Date on which ticket sales open for fixtures in this competition round. Used by Ticketmaster/AXS and Archtics to configure on-sale windows and dynamic pricing rules.' ;
    rdfs:domain ind:CompetitionRound ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:varApplicableFlag rdf:type rdf:Property ;
    rdfs:label 'Var Applicable Flag' ;
    rdfs:comment 'Indicates whether Video Assistant Referee (VAR) technology is in use for fixtures in this competition round. Relevant for FIFA, MLS, and other football competitions. Affects match officiating logistics and broadcast production planning.' ;
    rdfs:domain ind:CompetitionRound ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:wadaTestingRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Wada Testing Required Flag' ;
    rdfs:comment 'Indicates whether WADA-mandated Performance Enhancing Drug (PED) testing is required for athletes competing in this round. Triggers compliance workflows and athlete notification processes per WADA Anti-Doping Code.' ;
    rdfs:domain ind:CompetitionRound ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:agentId rdf:type rdf:Property ;
    rdfs:label 'Agent Id' ;
    rdfs:comment 'Reference to the certified player agent or agency representing the athlete for this roster record. Used for contract negotiations, trade communications, and CBA-mandated agent certification compliance.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Agent .

ind:announcementAssetId rdf:type rdf:Property ;
    rdfs:label 'Announcement Asset Id' ;
    rdfs:comment 'Foreign key linking to content.asset. Business justification: Roster transactions (trades, waivers, activations, releases) generate announcement content assets for media and fan communications. roster.transaction_type and transaction_date confirm this is a trans' ;
    rdfs:domain ind:Athlete ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Asset .

ind:primaryRosterFranchiseId rdf:type rdf:Property ;
    rdfs:label 'Primary Roster Franchise Id' ;
    rdfs:comment 'Reference to the team or franchise master record to which the athlete is currently rostered. Establishes the athlete-team affiliation for the given season.' ;
    rdfs:domain ind:Roster ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Franchise .

ind:rosterAthleteAthleteProfileId rdf:type rdf:Property ;
    rdfs:label 'Roster Athlete Athlete Profile Id' ;
    rdfs:comment 'Reference to the athlete master record. Identifies the specific player registered on this roster slot. Used as the primary link to athlete identity, contract, and performance data.' ;
    rdfs:domain ind:Roster ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AthleteProfile .

ind:rosterAthleteProfileId rdf:type rdf:Property ;
    rdfs:label 'Roster Athlete Profile Id' ;
    rdfs:comment 'Reference to the athlete master record. Identifies the specific player registered on this roster slot. Used as the primary link to athlete identity, contract, and performance data.' ;
    rdfs:domain ind:Roster ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AthleteProfile .

ind:rosterFranchiseId rdf:type rdf:Property ;
    rdfs:label 'Roster Franchise Id' ;
    rdfs:comment 'FK to league.franchise.franchise_id — Roster-to-franchise linkage — must know which franchise a roster belongs to for cap compliance, trade eligibility, and league governance.' ;
    rdfs:domain ind:Roster ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Franchise .

ind:rosterLoanedFromTeamFranchiseId rdf:type rdf:Property ;
    rdfs:label 'Roster Loaned From Team Franchise Id' ;
    rdfs:comment 'Reference to the originating team from which the athlete is on loan to the current roster. Applicable in soccer (MLS, FIFA) and hockey (NHL) loan/conditioning assignment scenarios. Null if the athlete is not on loan.' ;
    rdfs:domain ind:Roster ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Franchise .

ind:transactionWindowId rdf:type rdf:Property ;
    rdfs:label 'Transaction Window Id' ;
    rdfs:comment 'Foreign key linking to league.transaction_window. Business justification: Roster activations, deactivations, and IR designations must occur within valid transaction windows. Linking roster to transaction_window enables transaction window compliance validation for roster mov' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TransactionWindow .

ind:activationDate rdf:type rdf:Property ;
    rdfs:label 'Activation Date' ;
    rdfs:comment 'The date on which the athlete was officially activated onto this roster slot. Marks the effective start of the athlete-team affiliation for this record. Critical for CBA compliance, salary cap calculations, and eligibility verification.' ;
    rdfs:domain ind:Roster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:capHitCurrency rdf:type rdf:Property ;
    rdfs:label 'Cap Hit Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the salary cap hit amount (e.g., USD, CAD, EUR, GBP). Required for multi-league international operations where cap values may be denominated in different currencies.' ;
    rdfs:domain ind:Roster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deactivationDate rdf:type rdf:Property ;
    rdfs:label 'Deactivation Date' ;
    rdfs:comment 'The date on which the athlete was removed from this roster slot (via trade, waiver, release, retirement, or season end). Null if the roster record is currently active. Enables point-in-time roster reconstruction for any historical date.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:depthChartRank rdf:type rdf:Property ;
    rdfs:label 'Depth Chart Rank' ;
    rdfs:comment 'The athlete\'s positional depth chart ranking within the team (1 = starter, 2 = first backup, etc.). Used for game-day roster decisions, broadcast graphics, and performance analytics. Updated by coaching staff via SportsCode/Hudl.' ;
    rdfs:domain ind:Roster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:draftPickNumber rdf:type rdf:Property ;
    rdfs:label 'Draft Pick Number' ;
    rdfs:comment 'The overall pick number at which the athlete was selected in the league draft. Used for historical analysis, WAR (Wins Above Replacement) benchmarking, and broadcast content. Null for undrafted players.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:draftRound rdf:type rdf:Property ;
    rdfs:label 'Draft Round' ;
    rdfs:comment 'The round in which the athlete was selected during the league draft. Used for historical analysis, broadcast content, and talent evaluation benchmarking. Null for undrafted players.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:draftYear rdf:type rdf:Property ;
    rdfs:label 'Draft Year' ;
    rdfs:comment 'The calendar year in which the athlete was originally drafted into the league, if applicable. Used for service time calculations, CBA eligibility tiers, and broadcast storytelling. Null for undrafted free agents or international transfers.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:internationalSlotFlag rdf:type rdf:Property ;
    rdfs:label 'International Slot Flag' ;
    rdfs:comment 'Indicates whether this roster slot is designated as an international player slot under league rules (e.g., MLS international roster designation, NHL Entry Level Contract international provisions). Affects roster construction compliance and salary cap treatment.' ;
    rdfs:domain ind:Roster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isCaptain rdf:type rdf:Property ;
    rdfs:label 'Is Captain' ;
    rdfs:comment 'Indicates whether the athlete holds the official team captain designation for the current season. Used in broadcast graphics, fan engagement content, and league ceremonial protocols.' ;
    rdfs:domain ind:Roster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nationalityCode rdf:type rdf:Property ;
    rdfs:label 'Nationality Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code representing the athlete\'s primary nationality. Used for international roster compliance (e.g., MLS international roster slots, FIFA international transfer rules), visa tracking, and broadcast content.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nilAgreementFlag rdf:type rdf:Property ;
    rdfs:label 'Nil Agreement Flag' ;
    rdfs:comment 'Indicates whether the athlete has an active NIL (Name, Image, and Likeness) agreement registered with the league or team. Relevant for collegiate athletes transitioning to professional rosters and for compliance with NIL disclosure rules.' ;
    rdfs:domain ind:Athlete ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:positionCode rdf:type rdf:Property ;
    rdfs:label 'Position Code' ;
    rdfs:comment 'Standardized league-defined code for the athlete\'s primary playing position (e.g., QB, WR, C, PG, SG, SP, RP, LW, RW, FWD, MID, DEF, GK). Used in performance analytics, broadcast overlays, and roster compliance checks. [ENUM-REF-CANDIDATE: QB|WR|RB|TE|OL|DL|LB|DB|K|P|PG|SG|SF|PF|C|SP|RP|CP|1B|2B|3B|SS|OF|LW|RW|FWD|MID|DEF|GK — promote to reference product]' ;
    rdfs:domain ind:Roster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:positionName rdf:type rdf:Property ;
    rdfs:label 'Position Name' ;
    rdfs:comment 'Human-readable full name of the athlete\'s primary playing position (e.g., \'Quarterback\', \'Point Guard\', \'Starting Pitcher\', \'Left Wing\', \'Goalkeeper\'). Used in broadcast graphics, fan-facing content, and reporting.' ;
    rdfs:domain ind:Roster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:practiceSquadElevationFlag rdf:type rdf:Property ;
    rdfs:label 'Practice Squad Elevation Flag' ;
    rdfs:comment 'Indicates whether the athlete has been temporarily elevated from the practice squad to the active roster for a specific game week, per NFL and other league rules allowing short-term elevations without permanently activating the player.' ;
    rdfs:domain ind:Roster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rosterNumber rdf:type rdf:Property ;
    rdfs:label 'Roster Number' ;
    rdfs:comment 'Externally-known business identifier for this roster record, typically assigned by the league operations system. Used in official league communications, broadcast graphics, and regulatory filings. Example: \'NFL-2024-KC-0042\'.' ;
    rdfs:domain ind:Roster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rosterStatus rdf:type rdf:Property ;
    rdfs:label 'Roster Status' ;
    rdfs:comment 'Current lifecycle status of the athlete\'s roster slot. Drives eligibility for game participation, payroll processing, and broadcast credentialing. \'active\' = eligible to play; \'inactive\' = on roster but not eligible for current game; \'injured_reserve\' = on IR per league rules; \'practice_squad\' = developmental squad; \'waived\' = released from roster pending waiver wire.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salaryCapHit rdf:type rdf:Property ;
    rdfs:label 'Salary Cap Hit' ;
    rdfs:comment 'The annual salary cap charge attributed to this athlete\'s roster slot for the current season, expressed in USD. Used for cap compliance reporting, trade analysis, and financial planning. Governed by CBA salary cap rules.' ;
    rdfs:domain ind:Roster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:serviceYears rdf:type rdf:Property ;
    rdfs:label 'Service Years' ;
    rdfs:comment 'Accumulated years of professional service for the athlete within the league, calculated per CBA rules. Determines eligibility for free agency, arbitration rights, minimum salary tiers, and pension benefits. Expressed as a decimal (e.g., 3.172 years).' ;
    rdfs:domain ind:Roster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:slotType rdf:type rdf:Property ;
    rdfs:label 'Slot Type' ;
    rdfs:comment 'Classification of the roster slot category as defined by league rules. Determines salary cap implications, game eligibility, and CBA compliance. \'active_roster\' = primary game-day roster; \'practice_squad\' = developmental; \'injured_reserve\' = IR designation; \'reserve\' = non-IR reserve list; \'taxi_squad\' = NHL-specific developmental designation.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionDate rdf:type rdf:Property ;
    rdfs:label 'Transaction Date' ;
    rdfs:comment 'The official date on which the roster transaction (signing, trade, waiver, draft, transfer) was executed and reported to the league. May differ from activation_date if there is a processing lag.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:transactionType rdf:type rdf:Property ;
    rdfs:label 'Transaction Type' ;
    rdfs:comment 'The type of transaction that created this roster record. Indicates how the athlete came to be on this roster slot. Used for league transaction reporting, broadcast graphics, and historical analysis. [ENUM-REF-CANDIDATE: signed|traded|waived|released|drafted|transferred|loaned|retired — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:visaExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Visa Expiry Date' ;
    rdfs:comment 'The expiration date of the athlete\'s current work visa or immigration authorization. Used to trigger renewal workflows and ensure continuous roster eligibility for international players. Confidential HR/immigration data.' ;
    rdfs:domain ind:Athlete ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:visaType rdf:type rdf:Property ;
    rdfs:label 'Visa Type' ;
    rdfs:comment 'Type of work visa or immigration authorization held by the athlete for the jurisdiction in which they are rostered (e.g., P-1A for internationally recognized athletes in the USA, O-1 for extraordinary ability). Required for international roster compliance and HR onboarding. [ENUM-REF-CANDIDATE: P-1A|O-1|TN|H-1B|J-1|work_permit|citizen|permanent_resident — promote to reference product]' ;
    rdfs:domain ind:Roster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wadaClearanceStatus rdf:type rdf:Property ;
    rdfs:label 'Wada Clearance Status' ;
    rdfs:comment 'Current anti-doping clearance status for the athlete as reported by WADA or the applicable league anti-doping program. \'cleared\' = no active violations; \'pending\' = test results under review; \'suspended\' = serving a PED (Performance Enhancing Drug) suspension; \'exempted\' = holds a Therapeutic Use Exemption (TUE).' ;
    rdfs:domain ind:Athlete ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wadaLastTestDate rdf:type rdf:Property ;
    rdfs:label 'Wada Last Test Date' ;
    rdfs:comment 'Date of the athlete\'s most recent WADA-compliant anti-doping test. Used to verify testing frequency compliance and support league anti-doping audit trails.' ;
    rdfs:domain ind:Roster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:teamId rdf:type rdf:Property ;
    rdfs:label 'Team Id' ;
    rdfs:comment 'FK to league.team' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Team .

ind:athleteType rdf:type rdf:Property ;
    rdfs:label 'Athlete Type' ;
    rdfs:comment 'Classification of the individual\'s role within the sports organization. Distinguishes active players from coaching staff, officials, prospects, and support personnel for roster management and credentialing.' ;
    rdfs:domain ind:AthleteProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bio rdf:type rdf:Property ;
    rdfs:label 'Bio' ;
    rdfs:comment 'Official short-form biographical narrative for the athlete, approved for public use in broadcast, digital platforms, and media guides. Managed through the content production workflow.' ;
    rdfs:domain ind:AthleteProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:careerStatus rdf:type rdf:Property ;
    rdfs:label 'Career Status' ;
    rdfs:comment 'Current lifecycle status of the athlete\'s professional career. Drives roster eligibility, broadcast availability, contract activation, and league reporting. [ENUM-REF-CANDIDATE: active|retired|suspended|injured_reserve|deceased|inactive — promote to reference product]' ;
    rdfs:domain ind:AthleteProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countryOfBirthCode rdf:type rdf:Property ;
    rdfs:label 'Country Of Birth Code' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code for the country where the athlete was born. Distinct from nationality; used for eligibility determinations, international federation registration, and demographic analytics.' ;
    rdfs:domain ind:AthleteProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Data Source System' ;
    rdfs:comment 'Identifies the operational system of record from which this athlete profile record was sourced or last updated (e.g., \'successfactors\', \'league_registration\'). Used for data lineage, reconciliation, and audit purposes in the Databricks Silver Layer.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dateOfBirth rdf:type rdf:Property ;
    rdfs:label 'Date Of Birth' ;
    rdfs:comment 'Athlete\'s date of birth in ISO 8601 format (yyyy-MM-dd). Used for age eligibility verification, draft classification, CBA compliance, and league registration.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dominantFoot rdf:type rdf:Property ;
    rdfs:label 'Dominant Foot' ;
    rdfs:comment 'The athlete\'s dominant foot for sports where foot preference is analytically significant (e.g., soccer, rugby). Used in performance analytics, tactical planning, and broadcast commentary.' ;
    rdfs:domain ind:AthleteProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dominantHand rdf:type rdf:Property ;
    rdfs:label 'Dominant Hand' ;
    rdfs:comment 'The athlete\'s dominant hand (throwing, batting, or shooting hand). Critical for performance analytics, matchup strategy, broadcast commentary, and scouting reports.' ;
    rdfs:domain ind:AthleteProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eligibilityStatus rdf:type rdf:Property ;
    rdfs:label 'Eligibility Status' ;
    rdfs:comment 'Current league eligibility status of the athlete, reflecting compliance with CBA (Collective Bargaining Agreement), anti-doping (WADA), and disciplinary rules. Distinct from career_status — an athlete may be active but temporarily ineligible.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headshotImageUrl rdf:type rdf:Property ;
    rdfs:label 'Headshot Image Url' ;
    rdfs:comment 'URL reference to the athlete\'s official headshot photograph stored in the Digital Asset Management (DAM) system. Used for broadcast overlays, fan-facing platforms, merchandise, and media kits.' ;
    rdfs:domain ind:AthleteProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:heightCm rdf:type rdf:Property ;
    rdfs:label 'Height Cm' ;
    rdfs:comment 'Athlete\'s official measured height in centimetres as recorded at league registration or combine. Used for scouting analytics, broadcast graphics, merchandise sizing, and physical eligibility assessments.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:injuryStatus rdf:type rdf:Property ;
    rdfs:label 'Injury Status' ;
    rdfs:comment 'Current injury designation for the athlete as reported to the league. Drives roster availability, broadcast commentary, fantasy sports data feeds, and medical staff workflows. [ENUM-REF-CANDIDATE: healthy|day_to_day|injured_reserve|physically_unable|out_for_season — promote to reference product]' ;
    rdfs:domain ind:Athlete ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leagueRegistrationNumber rdf:type rdf:Property ;
    rdfs:label 'League Registration Number' ;
    rdfs:comment 'Externally-known unique identifier assigned by the governing league or federation upon official registration (e.g., NFL Player ID, FIFA Registration Number). Used for inter-system reconciliation, transfer clearances, and regulatory filings.' ;
    rdfs:domain ind:AthleteProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalFirstName rdf:type rdf:Property ;
    rdfs:label 'Legal First Name' ;
    rdfs:comment 'Athlete\'s legal given name as recorded on government-issued identification documents. Used for contract execution, league registration, and regulatory compliance filings.' ;
    rdfs:domain ind:AthleteProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalLastName rdf:type rdf:Property ;
    rdfs:label 'Legal Last Name' ;
    rdfs:comment 'Athlete\'s legal family/surname as recorded on government-issued identification documents. Used for contract execution, league registration, and regulatory compliance filings.' ;
    rdfs:domain ind:AthleteProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalMiddleName rdf:type rdf:Property ;
    rdfs:label 'Legal Middle Name' ;
    rdfs:comment 'Athlete\'s legal middle name or initial as recorded on government-issued identification. May be required for full legal name matching in contract and compliance contexts.' ;
    rdfs:domain ind:AthleteProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredName rdf:type rdf:Property ;
    rdfs:label 'Preferred Name' ;
    rdfs:comment 'The name the athlete prefers to be publicly known by, such as a nickname or shortened name (e.g., \'LeBron\' or \'Messi\'). Used in broadcast graphics, merchandise, and fan-facing content.' ;
    rdfs:domain ind:AthleteProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryPosition rdf:type rdf:Property ;
    rdfs:label 'Primary Position' ;
    rdfs:comment 'The athlete\'s primary playing position as designated by the league or team (e.g., \'Quarterback\', \'Center Forward\', \'Pitcher\', \'Point Guard\'). Critical for performance analytics, WAR/ERA/QBR calculations, and broadcast commentary.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proDebutDate rdf:type rdf:Property ;
    rdfs:label 'Pro Debut Date' ;
    rdfs:comment 'The date on which the athlete made their first official professional appearance. Used for career tenure calculations, milestone tracking, broadcast storytelling, and eligibility determinations.' ;
    rdfs:domain ind:AthleteProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:retirementDate rdf:type rdf:Property ;
    rdfs:label 'Retirement Date' ;
    rdfs:comment 'The official date on which the athlete formally retired from professional competition. Nullable for active athletes. Used for career lifecycle reporting, contract termination processing, and alumni engagement programs.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:socialMediaHandleInstagram rdf:type rdf:Property ;
    rdfs:label 'Social Media Handle Instagram' ;
    rdfs:comment 'Athlete\'s official Instagram social media handle. Used for fan engagement campaigns, NIL (Name, Image, and Likeness) tracking, digital partnership activations, and influencer analytics.' ;
    rdfs:domain ind:AthleteProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:socialMediaHandleTwitter rdf:type rdf:Property ;
    rdfs:label 'Social Media Handle Twitter' ;
    rdfs:comment 'Athlete\'s official X (formerly Twitter) social media handle. Used for fan engagement campaigns, NIL (Name, Image, and Likeness) tracking, digital partnership activations, and social media analytics.' ;
    rdfs:domain ind:AthleteProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemAthleteCode rdf:type rdf:Property ;
    rdfs:label 'Source System Athlete Code' ;
    rdfs:comment 'The native identifier for this athlete in the originating operational system of record (e.g., SAP SuccessFactors Employee ID, league registration system player ID). Used for cross-system reconciliation and data lineage tracing.' ;
    rdfs:domain ind:AthleteProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wadaRegisteredTestingPool rdf:type rdf:Property ;
    rdfs:label 'Wada Registered Testing Pool' ;
    rdfs:comment 'Indicates whether the athlete is enrolled in the WADA (World Anti-Doping Agency) Registered Testing Pool (RTP), requiring whereabouts reporting and out-of-competition testing. Critical for anti-doping compliance management.' ;
    rdfs:domain ind:AthleteProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:weightKg rdf:type rdf:Property ;
    rdfs:label 'Weight Kg' ;
    rdfs:comment 'Athlete\'s official measured weight in kilograms as recorded at league registration or combine. Used for scouting analytics, broadcast graphics, health monitoring, and physical eligibility assessments.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contractAthleteAthleteProfileId rdf:type rdf:Property ;
    rdfs:label 'Contract Athlete Athlete Profile Id' ;
    rdfs:comment 'Reference to the athlete (player) who is the primary party to this contract. Links to the athlete master record.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AthleteProfile .

ind:contractAthleteProfileId rdf:type rdf:Property ;
    rdfs:label 'Contract Athlete Profile Id' ;
    rdfs:comment 'Reference to the athlete (player) who is the primary party to this contract. Links to the athlete master record.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AthleteProfile .

ind:contractFranchiseId rdf:type rdf:Property ;
    rdfs:label 'Contract Franchise Id' ;
    rdfs:comment 'Reference to the team or franchise that is the employing party on this contract.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Franchise .

ind:contractTeamFranchiseId rdf:type rdf:Property ;
    rdfs:label 'Contract Team Franchise Id' ;
    rdfs:comment 'Reference to the team or franchise that is the employing party on this contract.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Franchise .

ind:aav rdf:type rdf:Property ;
    rdfs:label 'Aav' ;
    rdfs:comment 'The Annual Average Value (AAV) of the contract, calculated as total contract value divided by contract years. Industry-standard metric used for salary cap comparisons, market benchmarking, and broadcast commentary.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:baseSalaryYear1 rdf:type rdf:Property ;
    rdfs:label 'Base Salary Year1' ;
    rdfs:comment 'The base salary amount for the first year of the contract term. Used for payroll processing in SAP SuccessFactors and salary cap hit calculation in year one.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capHit rdf:type rdf:Property ;
    rdfs:label 'Cap Hit' ;
    rdfs:comment 'The amount of the team\'s salary cap consumed by this contract in the current league year, calculated per CBA rules (base salary + prorated signing bonus + likely incentives). Critical for roster construction and financial planning.' ;
    rdfs:domain ind:Athlete ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contractNumber rdf:type rdf:Property ;
    rdfs:label 'Contract Number' ;
    rdfs:comment 'Externally-known, league-assigned or organization-assigned unique contract reference number used in official filings, league submissions, and SAP S/4HANA SD sales contract documents.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractStatus rdf:type rdf:Property ;
    rdfs:label 'Contract Status' ;
    rdfs:comment 'Current lifecycle state of the contract. Active: currently in force. Expired: term has concluded. Voided: nullified due to breach, failed physical, or mutual agreement. Restructured: terms modified via amendment. Suspended: temporarily inactive due to disciplinary action or league sanction.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deadCapAmount rdf:type rdf:Property ;
    rdfs:label 'Dead Cap Amount' ;
    rdfs:comment 'The salary cap charge that remains against the team\'s cap after the athlete is released or traded, representing unearned prorated signing bonus and guaranteed money. Used for financial planning and roster management.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:freeAgencyClass rdf:type rdf:Property ;
    rdfs:label 'Free Agency Class' ;
    rdfs:comment 'The athlete\'s free agency classification upon contract expiration. UFA (Unrestricted Free Agent): no team rights retained. RFA (Restricted Free Agent): team retains right of first refusal. ERFA (Exclusive Rights Free Agent): team holds exclusive negotiating rights. Franchise tag and transition tag are team-applied designations preventing free agency.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:freeAgencyOpenDate rdf:type rdf:Property ;
    rdfs:label 'Free Agency Open Date' ;
    rdfs:comment 'The date on which the athlete becomes eligible to negotiate with other teams as a free agent, as defined by the league calendar and CBA provisions.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:guaranteedAmount rdf:type rdf:Property ;
    rdfs:label 'Guaranteed Amount' ;
    rdfs:comment 'The portion of the total contract value that is fully guaranteed regardless of injury, performance, or termination. Critical for salary cap dead money calculations and financial liability reporting.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:negotiationStatus rdf:type rdf:Property ;
    rdfs:label 'Negotiation Status' ;
    rdfs:comment 'Current status of free agency or contract renewal negotiations for this athlete. Tracks the negotiation lifecycle from initial contact through signing or expiration of negotiating rights.' ;
    rdfs:domain ind:Athlete ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:noCutClause rdf:type rdf:Property ;
    rdfs:label 'No Cut Clause' ;
    rdfs:comment 'Indicates whether the contract contains a no-cut clause preventing the team from releasing the athlete. True = no-cut clause present; False = standard release provisions apply.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:noTradeClause rdf:type rdf:Property ;
    rdfs:label 'No Trade Clause' ;
    rdfs:comment 'Indicates whether the contract contains a no-trade clause (NTC) preventing the team from trading the athlete without their consent. True = NTC present; False = no restriction. Critical for roster transaction processing.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:optionDeadline rdf:type rdf:Property ;
    rdfs:label 'Option Deadline' ;
    rdfs:comment 'The deadline date by which the option-holding party must notify the other party of their intent to exercise or decline the option year(s). Missing this deadline typically results in automatic option declination.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:optionType rdf:type rdf:Property ;
    rdfs:label 'Option Type' ;
    rdfs:comment 'Specifies which party holds the right to exercise the option year(s): team option (team decides), player option (athlete decides), mutual option (both parties must agree), or vesting option (automatically vests upon meeting performance thresholds).' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:optionYears rdf:type rdf:Property ;
    rdfs:label 'Option Years' ;
    rdfs:comment 'Number of option years appended to the base contract term. Option years may be exercisable by the team, the player, or mutually, as specified in the contract. Zero if no option years exist.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:performanceBonusEligible rdf:type rdf:Property ;
    rdfs:label 'Performance Bonus Eligible' ;
    rdfs:comment 'Indicates whether the contract includes performance-based incentive bonuses (e.g., statistical thresholds, award bonuses, playoff bonuses). True = performance bonuses are included in the contract terms.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:performanceBonusMax rdf:type rdf:Property ;
    rdfs:label 'Performance Bonus Max' ;
    rdfs:comment 'The maximum total amount the athlete can earn in performance-based incentive bonuses over the life of the contract. Used for salary cap likely/unlikely incentive classification per CBA rules.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:physicalDate rdf:type rdf:Property ;
    rdfs:label 'Physical Date' ;
    rdfs:comment 'The date on which the athlete underwent the pre-contract medical examination. Used for compliance tracking and contract contingency resolution.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:physicalPassed rdf:type rdf:Property ;
    rdfs:label 'Physical Passed' ;
    rdfs:comment 'Indicates whether the athlete successfully passed the team\'s pre-contract medical examination. Contracts are typically contingent on passing the physical; failure may result in contract voiding or restructuring.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:qualifyingOfferAmount rdf:type rdf:Property ;
    rdfs:label 'Qualifying Offer Amount' ;
    rdfs:comment 'The one-year salary amount tendered to a Restricted Free Agent (RFA) as a qualifying offer, which preserves the team\'s right of first refusal. Calculated per CBA formula based on prior year salary.' ;
    rdfs:domain ind:Athlete ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rightOfFirstRefusal rdf:type rdf:Property ;
    rdfs:label 'Right Of First Refusal' ;
    rdfs:comment 'Indicates whether the team retains the Right of First Refusal (ROFR) to match any offer sheet signed by the athlete with another team. Applicable to Restricted Free Agents (RFA). True = ROFR applies.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sapContractDocNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Contract Doc Number' ;
    rdfs:comment 'The document number assigned to this contract in SAP S/4HANA SD module for financial obligation tracking, payroll integration with SAP SuccessFactors, and accounts payable processing. Serves as the cross-system integration key.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signingBonus rdf:type rdf:Property ;
    rdfs:label 'Signing Bonus' ;
    rdfs:comment 'One-time bonus paid to the athlete upon contract execution. For salary cap purposes, signing bonuses are typically prorated across the contract years. Processed via SAP SuccessFactors Payroll and recorded in SAP S/4HANA FI.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:signingDate rdf:type rdf:Property ;
    rdfs:label 'Signing Date' ;
    rdfs:comment 'The calendar date on which the athlete and team executed (signed) the contract. This is the principal business event timestamp for the contract lifecycle, distinct from the effective start date.' ;
    rdfs:domain ind:Athlete ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:signingDeadline rdf:type rdf:Property ;
    rdfs:label 'Signing Deadline' ;
    rdfs:comment 'The deadline by which the athlete must sign a new contract or tender to remain with the team or enter free agency. Defined by CBA and league calendar (e.g., franchise tag signing deadline).' ;
    rdfs:domain ind:Athlete ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:totalValue rdf:type rdf:Property ;
    rdfs:label 'Total Value' ;
    rdfs:comment 'The gross total compensation value of the contract across all years, including base salary, signing bonus, and performance incentives as stated in the contract. Expressed in the contract currency. Used for salary cap accounting and financial obligation reporting in SAP S/4HANA FI/CO.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wadaCompliant rdf:type rdf:Property ;
    rdfs:label 'Wada Compliant' ;
    rdfs:comment 'Indicates whether the contract includes WADA anti-doping compliance clauses and the athlete has acknowledged their obligations under the World Anti-Doping Agency (WADA) code. True = WADA compliance clause present and acknowledged.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:years rdf:type rdf:Property ;
    rdfs:label 'Years' ;
    rdfs:comment 'Total number of years covered by the contract term, including option years if exercised. Used for AAV calculation, salary cap projection, and roster planning.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:performanceStatId rdf:type rdf:Property ;
    rdfs:label 'Performance Stat Id' ;
    rdfs:comment 'Unique surrogate identifier for each performance statistic record in the Silver layer lakehouse. Represents one statistical line for one athlete in one game or aggregated period.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PerformanceStat .

ind:primaryPerformanceAthleteAthleteProfileId rdf:type rdf:Property ;
    rdfs:label 'Primary Performance Athlete Athlete Profile Id' ;
    rdfs:comment 'Reference to the athlete whose performance statistics are captured in this record. Links to the athlete master data product in the talent management domain.' ;
    rdfs:domain ind:PerformanceStat ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AthleteProfile .

ind:primaryPerformanceFranchiseId rdf:type rdf:Property ;
    rdfs:label 'Primary Performance Franchise Id' ;
    rdfs:comment 'Reference to the team the athlete represented during this statistical period. Captures the team context at the time of the stat, which may differ from current roster assignment due to trades or transfers.' ;
    rdfs:domain ind:PerformanceStat ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Franchise .

ind:tertiaryPerformanceOpponentTeamFranchiseId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Performance Opponent Team Franchise Id' ;
    rdfs:comment 'Reference to the opposing team faced during this game. Enables head-to-head performance analysis, matchup-based scouting reports, and broadcast narrative generation. Null for season or career aggregate records.' ;
    rdfs:domain ind:PerformanceStat ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Franchise .

ind:aggregationMethodOverride rdf:type rdf:Property ;
    rdfs:label 'Aggregation Method Override' ;
    rdfs:comment 'An optional override to the KPI definition\'s default aggregation method, applied specifically when this stat record contributes to this KPI. Allows governance teams to specify non-standard aggregation for edge-case stat-KPI combinations without altering the master KPI definition.' ;
    rdfs:domain ind:PerformanceStat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assists rdf:type rdf:Property ;
    rdfs:label 'Assists' ;
    rdfs:comment 'Number of assists credited to the athlete — passes or actions directly leading to a goal or score. Applicable across soccer, hockey, basketball, and other team sports. Key metric for broadcast overlays and fantasy sports scoring.' ;
    rdfs:domain ind:PerformanceStat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:battingAverage rdf:type rdf:Property ;
    rdfs:label 'Batting Average' ;
    rdfs:comment 'Baseball-specific metric representing the ratio of hits to official at-bats (H/AB), expressed as a three-decimal fraction (e.g., 0.315). Null for non-baseball records. Foundational hitting metric for broadcast overlays, fantasy sports, and contract evaluation.' ;
    rdfs:domain ind:PerformanceStat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:blocks rdf:type rdf:Property ;
    rdfs:label 'Blocks' ;
    rdfs:comment 'Number of blocked shots or blocked passes credited to the athlete. Applicable to basketball (NBA shot blocks) and soccer/hockey (blocked shots). Null for non-applicable sport/position combinations.' ;
    rdfs:domain ind:PerformanceStat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:certificationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Certification Timestamp' ;
    rdfs:comment 'The date and time at which the statistical record was officially certified by the league or governing body. Formatted as yyyy-MM-ddTHH:mm:ss.SSSXXX. Null for provisional or pending records. Required for official standings calculations and regulatory reporting.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:contributionWeight rdf:type rdf:Property ;
    rdfs:label 'Contribution Weight' ;
    rdfs:comment 'The numeric weight (e.g., 0.0 to 1.0 or a raw multiplier) applied to this performance stat record when computing the target KPI value. Belongs to the relationship because the same stat may carry different weights for different KPIs.' ;
    rdfs:domain ind:PerformanceStat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:era rdf:type rdf:Property ;
    rdfs:label 'Era' ;
    rdfs:comment 'Earned Run Average (ERA) — baseball-specific pitching metric representing the average number of earned runs allowed per nine innings pitched. Null for non-baseball records. Primary pitching performance indicator for broadcast overlays, fantasy sports, and contract evaluation.' ;
    rdfs:domain ind:PerformanceStat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fieldGoalPercentage rdf:type rdf:Property ;
    rdfs:label 'Field Goal Percentage' ;
    rdfs:comment 'Ratio of successful field goals made to field goals attempted. Applicable to basketball (NBA) and American football (NFL kickers). Null for non-applicable sport/position combinations. Key shooting efficiency metric for broadcast overlays.' ;
    rdfs:domain ind:PerformanceStat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:foulsCommitted rdf:type rdf:Property ;
    rdfs:label 'Fouls Committed' ;
    rdfs:comment 'Total number of fouls committed by the athlete in this statistical period. Applicable to basketball (NBA personal fouls), soccer (FIFA/MLS), and hockey (NHL penalties). Tracks disciplinary and gameplay conduct for compliance and broadcast context.' ;
    rdfs:domain ind:PerformanceStat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:gamesPlayed rdf:type rdf:Property ;
    rdfs:label 'Games Played' ;
    rdfs:comment 'Number of games in which the athlete appeared and was credited with participation. For game-level records this is always 1; for season or career records this represents the cumulative count. Used in rate-stat calculations and eligibility determinations.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:gamesStarted rdf:type rdf:Property ;
    rdfs:label 'Games Started' ;
    rdfs:comment 'Number of games in which the athlete was in the starting lineup. Distinguishes starter versus substitute contributions for roster management, contract incentive tracking, and broadcast narrative context.' ;
    rdfs:domain ind:PerformanceStat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:goals rdf:type rdf:Property ;
    rdfs:label 'Goals' ;
    rdfs:comment 'Number of goals scored by the athlete in this statistical period. Applicable to soccer (MLS/FIFA), ice hockey (NHL), and other goal-scoring sports. Null for sports where goals are not a primary scoring unit.' ;
    rdfs:domain ind:PerformanceStat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hudlStatRecordReference rdf:type rdf:Property ;
    rdfs:label 'Hudl Stat Record Reference' ;
    rdfs:comment 'The native record identifier assigned by the SportsCode/Hudl performance analytics platform for this statistical entry. Used for source system traceability and reconciliation against the operational system of record.' ;
    rdfs:domain ind:PerformanceStat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inningsPitched rdf:type rdf:Property ;
    rdfs:label 'Innings Pitched' ;
    rdfs:comment 'Total innings pitched by a baseball pitcher in this statistical period, expressed in thirds of an inning (e.g., 6.2 = 6 innings and 2 outs). Null for non-pitcher or non-baseball records. Denominator for ERA and other rate-based pitching metrics.' ;
    rdfs:domain ind:PerformanceStat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isHomeGame rdf:type rdf:Property ;
    rdfs:label 'Is Home Game' ;
    rdfs:comment 'Indicates whether the athlete\'s team was the home team during this game. True = home team; False = away team. Null for season or career aggregate records. Enables home/away performance split analysis for broadcast storytelling and scouting.' ;
    rdfs:domain ind:PerformanceStat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPrimaryInput rdf:type rdf:Property ;
    rdfs:label 'Is Primary Input' ;
    rdfs:comment 'Indicates whether this performance stat record is the primary driver of the KPI value (true) or a secondary/supplementary input (false). Used by reporting systems to prioritise which stat to surface in broadcast overlays and governance dashboards.' ;
    rdfs:domain ind:PerformanceStat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:minutesPlayed rdf:type rdf:Property ;
    rdfs:label 'Minutes Played' ;
    rdfs:comment 'Total minutes of active participation recorded for the athlete in this statistical period. Used for per-minute rate statistics, workload management, and injury risk analytics. Applicable to basketball, soccer, hockey, and other timed sports.' ;
    rdfs:domain ind:PerformanceStat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:onBasePercentage rdf:type rdf:Property ;
    rdfs:label 'On Base Percentage' ;
    rdfs:comment 'Baseball-specific metric measuring how frequently a batter reaches base per plate appearance, including hits, walks, and hit-by-pitch. Null for non-baseball records. Advanced hitting metric used alongside batting average for comprehensive offensive evaluation.' ;
    rdfs:domain ind:PerformanceStat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:passingYards rdf:type rdf:Property ;
    rdfs:label 'Passing Yards' ;
    rdfs:comment 'Total passing yards accumulated by the athlete in this statistical period. NFL-specific metric for quarterbacks and passing plays. Null for non-football records or non-passing positions. Key broadcast overlay and fantasy sports metric.' ;
    rdfs:domain ind:PerformanceStat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:plusMinus rdf:type rdf:Property ;
    rdfs:label 'Plus Minus' ;
    rdfs:comment 'The plus/minus differential representing the net score differential when the athlete was on the ice or court. Applicable to ice hockey (NHL) and basketball (NBA). Positive values indicate the team outscored opponents during the athlete\'s time on the field. Key advanced analytics input.' ;
    rdfs:domain ind:PerformanceStat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pointsScored rdf:type rdf:Property ;
    rdfs:label 'Points Scored' ;
    rdfs:comment 'Total points scored by the athlete in this statistical period. Applicable to basketball (NBA), American football (NFL touchdowns/field goals), and other point-based sports. Null for sports where points are not individually attributed.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:positionPlayed rdf:type rdf:Property ;
    rdfs:label 'Position Played' ;
    rdfs:comment 'The on-field position the athlete occupied during this game or statistical period (e.g., Quarterback, Pitcher, Point Guard, Center Forward, Goalkeeper). Position context is critical for sport-specific metric interpretation and broadcast overlays.' ;
    rdfs:domain ind:PerformanceStat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qbr rdf:type rdf:Property ;
    rdfs:label 'Qbr' ;
    rdfs:comment 'Quarterback Rating (QBR) — NFL-specific composite passing efficiency metric scaled 0–100 measuring a quarterback\'s overall performance including passing, rushing, and situational adjustments. Null for non-quarterback or non-football records. Used for broadcast overlays and fantasy sports feeds.' ;
    rdfs:domain ind:PerformanceStat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rebounds rdf:type rdf:Property ;
    rdfs:label 'Rebounds' ;
    rdfs:comment 'Total number of rebounds (offensive plus defensive) credited to the athlete. Basketball-specific metric (NBA). Null for non-basketball records. Used in broadcast overlays, fantasy sports feeds, and player valuation models.' ;
    rdfs:domain ind:PerformanceStat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:receivingYards rdf:type rdf:Property ;
    rdfs:label 'Receiving Yards' ;
    rdfs:comment 'Total receiving yards accumulated by the athlete in this statistical period. NFL-specific metric for wide receivers, tight ends, and running backs. Null for non-football records. Key fantasy sports and broadcast overlay metric.' ;
    rdfs:domain ind:PerformanceStat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:redCards rdf:type rdf:Property ;
    rdfs:label 'Red Cards' ;
    rdfs:comment 'Number of red cards (ejections) received by the athlete in this statistical period. Soccer-specific (FIFA/MLS) disciplinary metric. Null for non-soccer records. Triggers automatic suspension and is tracked for league compliance and CBA reporting.' ;
    rdfs:domain ind:PerformanceStat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rushingYards rdf:type rdf:Property ;
    rdfs:label 'Rushing Yards' ;
    rdfs:comment 'Total rushing yards accumulated by the athlete in this statistical period. NFL-specific metric for running backs, quarterbacks, and other ball carriers. Null for non-football records. Used in broadcast overlays and fantasy sports scoring.' ;
    rdfs:domain ind:PerformanceStat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:saves rdf:type rdf:Property ;
    rdfs:label 'Saves' ;
    rdfs:comment 'Number of saves recorded by the athlete. Applicable to goalkeepers in soccer and hockey, and to relief pitchers in baseball (MLB save rule). Null for non-applicable sport/position combinations.' ;
    rdfs:domain ind:PerformanceStat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sluggingPercentage rdf:type rdf:Property ;
    rdfs:label 'Slugging Percentage' ;
    rdfs:comment 'Baseball-specific advanced hitting metric measuring total bases per at-bat, reflecting extra-base hit power. Null for non-baseball records. Combined with on-base percentage to produce OPS (On-Base Plus Slugging) for comprehensive offensive evaluation.' ;
    rdfs:domain ind:PerformanceStat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:statDate rdf:type rdf:Property ;
    rdfs:label 'Stat Date' ;
    rdfs:comment 'The calendar date on which the game was played or the date representing the end of the aggregation period for season/career records. Formatted as yyyy-MM-dd per enterprise data standards.' ;
    rdfs:domain ind:PerformanceStat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:statPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Stat Period End Date' ;
    rdfs:comment 'The end date of the window over which this performance stat record is considered a valid input to the KPI calculation. Together with stat_period_start_date, defines the contribution scope for this specific mapping.' ;
    rdfs:domain ind:PerformanceStat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:statPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Stat Period Start Date' ;
    rdfs:comment 'The start date of the window over which this performance stat record is considered a valid input to the KPI calculation. Scopes the contribution temporally without altering the stat record or the KPI definition.' ;
    rdfs:domain ind:PerformanceStat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:statStatus rdf:type rdf:Property ;
    rdfs:label 'Stat Status' ;
    rdfs:comment 'Current lifecycle status of the statistical record. Official records are certified by the league; provisional records are pending official certification; revised records have been corrected post-certification; voided records are invalidated due to forfeit, protest, or data error; pending_review records are under investigation.' ;
    rdfs:domain ind:PerformanceStat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statType rdf:type rdf:Property ;
    rdfs:label 'Stat Type' ;
    rdfs:comment 'Classifies whether this record represents a single-game statistical line, a season-level aggregate, a career-level aggregate, a playoff period, or a tournament-specific accumulation. Drives how the record is consumed by broadcast overlays, fantasy feeds, and standings engines.' ;
    rdfs:domain ind:PerformanceStat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:steals rdf:type rdf:Property ;
    rdfs:label 'Steals' ;
    rdfs:comment 'Number of steals credited to the athlete. Primarily a basketball (NBA) defensive metric. Also applicable to baseball (stolen bases). Null for non-applicable sport/position combinations.' ;
    rdfs:domain ind:PerformanceStat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:strikeouts rdf:type rdf:Property ;
    rdfs:label 'Strikeouts' ;
    rdfs:comment 'Number of strikeouts recorded. For pitchers (MLB), this is the count of batters struck out. For batters, this is the count of times struck out. Null for non-baseball records. Key pitching and batting evaluation metric.' ;
    rdfs:domain ind:PerformanceStat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tackles rdf:type rdf:Property ;
    rdfs:label 'Tackles' ;
    rdfs:comment 'Number of tackles made by the athlete. Applicable to American football (NFL) defensive players and soccer (FIFA/MLS) players. Null for sports or positions where tackles are not a tracked metric.' ;
    rdfs:domain ind:PerformanceStat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:touchdowns rdf:type rdf:Property ;
    rdfs:label 'Touchdowns' ;
    rdfs:comment 'Total touchdowns scored or thrown by the athlete in this statistical period. NFL-specific metric covering passing touchdowns, rushing touchdowns, and receiving touchdowns. Null for non-football records.' ;
    rdfs:domain ind:PerformanceStat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:war rdf:type rdf:Property ;
    rdfs:label 'War' ;
    rdfs:comment 'Wins Above Replacement (WAR) — a composite advanced metric estimating the total number of additional wins the athlete contributed to their team compared to a replacement-level player. Sourced from SportsCode/Hudl analytics engine. Used for contract valuation, trade analysis, and broadcast storytelling.' ;
    rdfs:domain ind:PerformanceStat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:yellowCards rdf:type rdf:Property ;
    rdfs:label 'Yellow Cards' ;
    rdfs:comment 'Number of yellow cards (cautions) received by the athlete in this statistical period. Soccer-specific (FIFA/MLS) disciplinary metric. Null for non-soccer records. Relevant for suspension tracking and league compliance reporting.' ;
    rdfs:domain ind:PerformanceStat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:injuryRecordId rdf:type rdf:Property ;
    rdfs:label 'Injury Record Id' ;
    rdfs:comment 'Unique surrogate identifier for each athlete injury or medical event record in the system. Primary key for the injury_record data product.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InjuryRecord .

ind:primaryInjuryAthleteAthleteProfileId rdf:type rdf:Property ;
    rdfs:label 'Primary Injury Athlete Athlete Profile Id' ;
    rdfs:comment 'Reference to the athlete who sustained the injury or medical event. Links to the athlete master record in the talent management domain.' ;
    rdfs:domain ind:InjuryRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AthleteProfile .

ind:primaryInjuryEventFixtureId rdf:type rdf:Property ;
    rdfs:label 'Primary Injury Event Fixture Id' ;
    rdfs:comment 'Reference to the game, match, or competition event during which the injury occurred, if applicable. Null for practice or non-event injuries.' ;
    rdfs:domain ind:InjuryRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Fixture .

ind:primaryInjuryFranchiseId rdf:type rdf:Property ;
    rdfs:label 'Primary Injury Franchise Id' ;
    rdfs:comment 'Reference to the team roster the athlete was assigned to at the time of injury. Used for roster eligibility impact analysis and league reporting.' ;
    rdfs:domain ind:InjuryRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Franchise .

ind:priorInjuryRecordId rdf:type rdf:Property ;
    rdfs:label 'Prior Injury Record Id' ;
    rdfs:comment 'Self-referencing identifier linking this recurrent injury to the original injury record for the same body part. Populated only when is_recurrence is True. Enables injury recurrence chain analysis and longitudinal athlete health tracking.' ;
    rdfs:domain ind:InjuryRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InjuryRecord .

ind:actualRtpDate rdf:type rdf:Property ;
    rdfs:label 'Actual Rtp Date' ;
    rdfs:comment 'Actual date on which the athlete was medically cleared and returned to full competitive play. Distinct from expected_rtp_date; the variance between these dates is a key metric for medical staff performance and recovery protocol effectiveness.' ;
    rdfs:domain ind:InjuryRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:bodySide rdf:type rdf:Property ;
    rdfs:label 'Body Side' ;
    rdfs:comment 'Laterality of the injured body part indicating which side of the body is affected. \'bilateral\' applies when both sides are involved; \'central\' for midline structures (spine, head); \'not_applicable\' for systemic conditions or illnesses.' ;
    rdfs:domain ind:InjuryRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:broadcastDisclosureApproved rdf:type rdf:Property ;
    rdfs:label 'Broadcast Disclosure Approved' ;
    rdfs:comment 'Indicates whether the athlete and team have approved disclosure of this injury for broadcast and media communications. When True, injury status and expected RTP may be shared with broadcast partners and media. Supports DTC fan engagement and broadcast content production.' ;
    rdfs:domain ind:InjuryRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:broadcastInjuryNote rdf:type rdf:Property ;
    rdfs:label 'Broadcast Injury Note' ;
    rdfs:comment 'Approved public-facing injury description for use in broadcast, media, and fan communications. Sanitized version of the clinical description that omits protected health information. Populated only when broadcast_disclosure_approved is True. Used by Dalet Galaxy broadcast workflow for on-air injury reporting.' ;
    rdfs:domain ind:InjuryRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseNumber rdf:type rdf:Property ;
    rdfs:label 'Case Number' ;
    rdfs:comment 'Externally-known alphanumeric case reference assigned by the team medical staff system at the time of injury intake. Used for cross-referencing with insurance claims, OSHA logs, and league medical reporting. Format: INJ-YYYY-NNNNNN.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:concussionProtocolTriggered rdf:type rdf:Property ;
    rdfs:label 'Concussion Protocol Triggered' ;
    rdfs:comment 'Indicates whether the league\'s mandatory concussion evaluation and graduated return-to-play protocol was triggered for this injury. Drives specific compliance tracking requirements distinct from standard injury management. Required for league concussion protocol reporting.' ;
    rdfs:domain ind:InjuryRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:daysLostActual rdf:type rdf:Property ;
    rdfs:label 'Days Lost Actual' ;
    rdfs:comment 'Actual number of calendar days the athlete was unavailable for competition, calculated upon return to play or case closure. Used for OSHA recordkeeping (days away from work), insurance settlement, and injury analytics benchmarking.' ;
    rdfs:domain ind:InjuryRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:daysLostEstimated rdf:type rdf:Property ;
    rdfs:label 'Days Lost Estimated' ;
    rdfs:comment 'Physician-estimated number of calendar days the athlete is expected to be unavailable for competition due to the injury. Used for roster planning, insurance claim valuation, and broadcast availability reporting. Distinct from actual days lost which is calculated from actual RTP date.' ;
    rdfs:domain ind:InjuryRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:expectedRtpDate rdf:type rdf:Property ;
    rdfs:label 'Expected Rtp Date' ;
    rdfs:comment 'Physician-projected date on which the athlete is expected to return to full competitive play (Return-to-Play / RTP). Used for roster management, broadcast scheduling, and fan communications. May be updated as recovery progresses.' ;
    rdfs:domain ind:InjuryRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:icd10Code rdf:type rdf:Property ;
    rdfs:label 'Icd10 Code' ;
    rdfs:comment 'International Classification of Diseases, 10th Revision (ICD-10-CM) diagnosis code assigned by the treating physician. Standardizes injury classification for insurance claims, OSHA reporting, league medical databases, and cross-team analytics. Required for workers\' compensation and insurance claim processing.' ;
    rdfs:domain ind:InjuryRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:injuryDate rdf:type rdf:Property ;
    rdfs:label 'Injury Date' ;
    rdfs:comment 'Calendar date on which the injury or medical event was first sustained or identified. Principal business event date for the injury lifecycle. Used for OSHA recordkeeping, insurance claim filing windows, and roster eligibility calculations.' ;
    rdfs:domain ind:InjuryRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:injuryDescription rdf:type rdf:Property ;
    rdfs:label 'Injury Description' ;
    rdfs:comment 'Free-text clinical narrative describing the nature, mechanism, and circumstances of the injury or medical event as documented by the treating physician or athletic trainer. Supports detailed medical review and insurance claim documentation.' ;
    rdfs:domain ind:InjuryRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:injuryLocation rdf:type rdf:Property ;
    rdfs:label 'Injury Location' ;
    rdfs:comment 'Setting or context in which the injury occurred. Distinguishes game-time injuries from practice, training facility, or travel-related incidents. Affects OSHA recordability determination, workers\' compensation eligibility, and league reporting obligations.' ;
    rdfs:domain ind:InjuryRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:injuryMechanism rdf:type rdf:Property ;
    rdfs:label 'Injury Mechanism' ;
    rdfs:comment 'Mechanism by which the injury was sustained. \'contact\' indicates collision with another player or object; \'non_contact\' indicates injury without external contact (e.g., ACL tear during cutting); \'overexertion\' indicates fatigue or training load-related; \'environmental\' indicates field/court surface or weather-related cause. Critical for OSHA incident classification and injury prevention analytics.' ;
    rdfs:domain ind:InjuryRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:injuryType rdf:type rdf:Property ;
    rdfs:label 'Injury Type' ;
    rdfs:comment 'High-level clinical classification of the injury or medical event. \'acute\' refers to sudden-onset traumatic injuries; \'chronic\' refers to long-standing conditions; \'overuse\' refers to repetitive stress injuries; \'concussion\' is tracked separately per league concussion protocol requirements. [ENUM-REF-CANDIDATE: acute|chronic|overuse|illness|concussion|fracture|laceration|dislocation|sprain|strain — promote to reference product]' ;
    rdfs:domain ind:InjuryRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceReserveAmount rdf:type rdf:Property ;
    rdfs:label 'Insurance Reserve Amount' ;
    rdfs:comment 'Financial reserve amount (in USD) set aside by the team\'s insurance carrier for this injury claim. Represents the estimated total cost of the claim including medical treatment, salary continuation, and rehabilitation. Used for financial planning and SAP S/4HANA FI/CO reserve posting.' ;
    rdfs:domain ind:InjuryRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:irDesignation rdf:type rdf:Property ;
    rdfs:label 'Ir Designation' ;
    rdfs:comment 'Formal league roster designation for the injured athlete per Collective Bargaining Agreement (CBA) rules. \'ir_standard\' = standard Injured Reserve placement; \'ir_return_designated\' = IR with designation to return (allows one return per season); \'ir_non_football\' = injury unrelated to sport; \'pup_list\' = Physically Unable to Perform list (pre-season). Drives roster count compliance and salary cap implications.' ;
    rdfs:domain ind:InjuryRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isOshaRecordable rdf:type rdf:Property ;
    rdfs:label 'Is Osha Recordable' ;
    rdfs:comment 'Indicates whether this injury meets OSHA recordability criteria under 29 CFR 1904 (i.e., results in days away from work, restricted duty, medical treatment beyond first aid, loss of consciousness, or diagnosis of a significant condition). Required for OSHA 300 Log annual reporting.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRecurrence rdf:type rdf:Property ;
    rdfs:label 'Is Recurrence' ;
    rdfs:comment 'Indicates whether this injury is a recurrence of a previously documented injury to the same body part. Recurrent injuries are tracked separately for medical analytics, contract risk assessment, and insurance underwriting purposes.' ;
    rdfs:domain ind:InjuryRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isWadaReportable rdf:type rdf:Property ;
    rdfs:label 'Is Wada Reportable' ;
    rdfs:comment 'Indicates whether this medical event requires reporting to the World Anti-Doping Agency (WADA), typically when treatment involves substances on the WADA Prohibited List requiring a Therapeutic Use Exemption (TUE). Critical for anti-doping compliance.' ;
    rdfs:domain ind:InjuryRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isWorkersCompClaim rdf:type rdf:Property ;
    rdfs:label 'Is Workers Comp Claim' ;
    rdfs:comment 'Indicates whether a workers\' compensation insurance claim has been filed for this injury. Triggers coordination with the insurance and finance teams for claim processing and reserve setting.' ;
    rdfs:domain ind:InjuryRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:medicalStaffNotes rdf:type rdf:Property ;
    rdfs:label 'Medical Staff Notes' ;
    rdfs:comment 'Confidential clinical notes from the team\'s medical staff including athletic trainers, physical therapists, and team physicians documenting daily progress, treatment adjustments, and rehabilitation milestones. Restricted to authorized medical personnel per HIPAA and CBA medical privacy provisions.' ;
    rdfs:domain ind:InjuryRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportedDate rdf:type rdf:Property ;
    rdfs:label 'Reported Date' ;
    rdfs:comment 'Date on which the injury was formally reported to team medical staff or league operations. May differ from injury_date for delayed-onset conditions or injuries initially unreported. Critical for OSHA recordkeeping compliance windows.' ;
    rdfs:domain ind:InjuryRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rtpClearanceStage rdf:type rdf:Property ;
    rdfs:label 'Rtp Clearance Stage' ;
    rdfs:comment 'Current stage in the graduated Return-to-Play (RTP) protocol as defined by league medical standards and CBA. Tracks progression from initial rest through limited activity, non-contact practice, full practice, and final medical clearance. Critical for concussion protocol compliance.' ;
    rdfs:domain ind:InjuryRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:severityGrade rdf:type rdf:Property ;
    rdfs:label 'Severity Grade' ;
    rdfs:comment 'Clinical severity classification of the injury based on expected time loss and functional impact. \'minor\' = <7 days; \'moderate\' = 7-28 days; \'severe\' = >28 days; \'career_threatening\' = potential permanent impact on playing career. Used for insurance valuation, roster planning, and broadcast communications.' ;
    rdfs:domain ind:InjuryRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surgeryDate rdf:type rdf:Property ;
    rdfs:label 'Surgery Date' ;
    rdfs:comment 'Date on which surgical procedure was performed, if applicable. Null when surgery_required is False. Used as a key milestone in recovery timeline planning and insurance claim documentation.' ;
    rdfs:domain ind:InjuryRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:surgeryRequired rdf:type rdf:Property ;
    rdfs:label 'Surgery Required' ;
    rdfs:comment 'Indicates whether surgical intervention is required or has been performed as part of the treatment protocol. Surgical cases typically have significantly longer recovery timelines and higher insurance claim values.' ;
    rdfs:domain ind:InjuryRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:treatingPhysicianReference rdf:type rdf:Property ;
    rdfs:label 'Treating Physician Reference' ;
    rdfs:comment 'Reference to the licensed medical professional (team physician, orthopedic surgeon, or specialist) who diagnosed and is managing the athlete\'s treatment protocol.' ;
    rdfs:domain ind:InjuryRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:treatmentProtocol rdf:type rdf:Property ;
    rdfs:label 'Treatment Protocol' ;
    rdfs:comment 'Structured description of the prescribed medical treatment plan including surgical intervention, physical therapy regimen, medication management, and rehabilitation milestones as documented by the treating physician. Supports medical staff coordination and insurance documentation.' ;
    rdfs:domain ind:InjuryRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tueReference rdf:type rdf:Property ;
    rdfs:label 'Tue Reference' ;
    rdfs:comment 'Reference number for the WADA Therapeutic Use Exemption (TUE) application or approval associated with this injury\'s treatment protocol. Populated when is_wada_reportable is True and treatment involves a prohibited substance. Required for anti-doping compliance documentation.' ;
    rdfs:domain ind:InjuryRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:draftSelectionId rdf:type rdf:Property ;
    rdfs:label 'Draft Selection Id' ;
    rdfs:comment 'Unique surrogate identifier for each draft selection record in the lakehouse silver layer. Primary key for the draft_selection data product.' ;
    rdfs:domain ind:DraftSelection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:draftPickId rdf:type rdf:Property ;
    rdfs:label 'Draft Pick Id' ;
    rdfs:comment 'Foreign key linking to league.draft_pick. Business justification: A draft selection consumes a specific tradeable draft pick asset. Linking draft_selection to the draft_pick it exercised is essential for pick inventory reconciliation, trade compensation tracking, an' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DraftPick .

ind:primaryDraftAthleteAthleteProfileId rdf:type rdf:Property ;
    rdfs:label 'Primary Draft Athlete Athlete Profile Id' ;
    rdfs:comment 'Reference to the athlete record for the player selected in this draft pick. Links to the athlete master record capturing identity, eligibility, and career lifecycle.' ;
    rdfs:domain ind:DraftSelection ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AthleteProfile .

ind:primaryDraftClassDraftId rdf:type rdf:Property ;
    rdfs:label 'Primary Draft Class Draft Id' ;
    rdfs:comment 'Reference to the draft class cohort record grouping all athletes eligible for a specific draft year and league. Supports draft class analytics and historical comparisons.' ;
    rdfs:domain ind:DraftSelection ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Draft .

ind:primaryDraftFranchiseId rdf:type rdf:Property ;
    rdfs:label 'Primary Draft Franchise Id' ;
    rdfs:comment 'Reference to the franchise or club that exercised this draft pick and holds the rights to the selected athlete. May differ from original_team_id if the pick was traded.' ;
    rdfs:domain ind:DraftSelection ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Franchise .

ind:tertiaryDraftOriginalTeamFranchiseId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Draft Original Team Franchise Id' ;
    rdfs:comment 'Reference to the team that originally owned this draft pick before any trade. Null if the pick was never traded. Critical for trade history and compensatory pick tracking.' ;
    rdfs:domain ind:DraftSelection ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Franchise .

ind:actualSigningBonus rdf:type rdf:Property ;
    rdfs:label 'Actual Signing Bonus' ;
    rdfs:comment 'The actual signing bonus amount in USD agreed upon in the athlete\'s rookie contract. May differ from signing_slot_value due to negotiations within CBA-permitted ranges. Used for salary cap accounting and financial reporting.' ;
    rdfs:domain ind:DraftSelection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:athleteCollege rdf:type rdf:Property ;
    rdfs:label 'Athlete College' ;
    rdfs:comment 'Name of the college, university, or prior professional club from which the athlete was drafted. Used for draft class analytics, alumni tracking, and broadcast storytelling content.' ;
    rdfs:domain ind:DraftSelection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:athleteNationality rdf:type rdf:Property ;
    rdfs:label 'Athlete Nationality' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code representing the athlete\'s nationality at the time of the draft. Relevant for international player rules, visa requirements, and global broadcast analytics.' ;
    rdfs:domain ind:DraftSelection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:athletePosition rdf:type rdf:Property ;
    rdfs:label 'Athlete Position' ;
    rdfs:comment 'The primary playing position of the athlete at the time of the draft (e.g., QB, WR, PG, SP, ST). Position is sport-specific and drives positional scarcity analytics and roster construction. [ENUM-REF-CANDIDATE: QB|WR|RB|TE|OL|DL|LB|DB|K|P|PG|SG|SF|PF|C|SP|RP|SS|GK|DEF|MID|FWD — promote to reference product]' ;
    rdfs:domain ind:DraftSelection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionalPickTerms rdf:type rdf:Property ;
    rdfs:label 'Conditional Pick Terms' ;
    rdfs:comment 'Free-text description of the conditions governing a conditional pick (e.g., \'Becomes 1st round if team makes playoffs; otherwise 2nd round\'). Populated only when is_conditional_pick is True.' ;
    rdfs:domain ind:DraftSelection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractOptionYears rdf:type rdf:Property ;
    rdfs:label 'Contract Option Years' ;
    rdfs:comment 'Number of team option years available beyond the base rookie contract term (e.g., 5th-year option in NFL for 1st-round picks). Null if no option applies under the CBA.' ;
    rdfs:domain ind:DraftSelection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contractYears rdf:type rdf:Property ;
    rdfs:label 'Contract Years' ;
    rdfs:comment 'Number of years in the standard rookie contract associated with this draft selection as defined by the applicable CBA (e.g., 4-year rookie deal in NFL, 2+2 in NBA). Drives roster planning and cap projection.' ;
    rdfs:domain ind:DraftSelection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:draftDate rdf:type rdf:Property ;
    rdfs:label 'Draft Date' ;
    rdfs:comment 'Calendar date on which this specific pick was made during the draft event. Multi-day drafts (e.g., NFL Draft spans 3 days) require day-level precision for scheduling and broadcast.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eligibilityYear rdf:type rdf:Property ;
    rdfs:label 'Eligibility Year' ;
    rdfs:comment 'The year in which the athlete first became eligible for the draft under league rules (e.g., 3 years post-high school for NFL, 1 year post-high school for NBA). Used for eligibility compliance and age-based analytics.' ;
    rdfs:domain ind:DraftSelection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isCompensatoryPick rdf:type rdf:Property ;
    rdfs:label 'Is Compensatory Pick' ;
    rdfs:comment 'Indicates whether this pick was awarded as a compensatory selection by the league office, typically for losing qualifying free agents. Compensatory picks have specific CBA rules on tradability.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isConditionalPick rdf:type rdf:Property ;
    rdfs:label 'Is Conditional Pick' ;
    rdfs:comment 'Indicates whether this pick was subject to conditions (e.g., round changes based on player performance or team standings) at the time of the trade agreement.' ;
    rdfs:domain ind:DraftSelection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isTradedPick rdf:type rdf:Property ;
    rdfs:label 'Is Traded Pick' ;
    rdfs:comment 'Indicates whether this draft pick was acquired through a trade from another team. True when selecting_team_id differs from original_team_id. Critical for trade value analytics and salary cap management.' ;
    rdfs:domain ind:DraftSelection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:medicalClearanceStatus rdf:type rdf:Property ;
    rdfs:label 'Medical Clearance Status' ;
    rdfs:comment 'Medical clearance status resulting from the team\'s pre-draft physical examination. \'cleared\' = fully fit; \'conditional\' = cleared with noted conditions; \'not_cleared\' = failed physical; \'pending\' = exam not yet completed. Impacts signing decision and contract terms.' ;
    rdfs:domain ind:DraftSelection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overallPickNumber rdf:type rdf:Property ;
    rdfs:label 'Overall Pick Number' ;
    rdfs:comment 'The absolute sequential pick number across all rounds of the draft (e.g., pick 33 is the first pick of round 2 in a 32-team league). Primary ranking metric for draft analytics and historical comparisons.' ;
    rdfs:domain ind:DraftSelection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pickNumberInRound rdf:type rdf:Property ;
    rdfs:label 'Pick Number In Round' ;
    rdfs:comment 'The sequential pick number within the specific round (e.g., pick 3 in round 2). Combined with round_number to identify the pick within its round context.' ;
    rdfs:domain ind:DraftSelection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pickType rdf:type rdf:Property ;
    rdfs:label 'Pick Type' ;
    rdfs:comment 'Classification of the draft pick by its origin. \'standard\' = regular draft order pick; \'compensatory\' = awarded by league for losing free agents; \'supplemental\' = special draft outside normal cycle; \'conditional\' = pick contingent on performance conditions; \'traded\' = pick acquired via trade.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preDraftGrade rdf:type rdf:Property ;
    rdfs:label 'Pre Draft Grade' ;
    rdfs:comment 'Numerical scouting grade assigned to the athlete prior to the draft on a standardized scale (e.g., 0.00–100.00 or 1.00–8.00 per NFL scouting convention). Reflects overall prospect evaluation by the team\'s scouting department.' ;
    rdfs:domain ind:DraftSelection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:preDraftRanking rdf:type rdf:Property ;
    rdfs:label 'Pre Draft Ranking' ;
    rdfs:comment 'The consensus pre-draft ranking of the athlete among all eligible prospects, as published by the league or a recognized scouting service prior to the draft. Used to measure draft value (reach vs. value picks) and scouting accuracy analytics.' ;
    rdfs:domain ind:DraftSelection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:selectionCode rdf:type rdf:Property ;
    rdfs:label 'Selection Code' ;
    rdfs:comment 'Externally-known business identifier for this draft pick in the format LEAGUE-YEAR-ROUND-PICK (e.g., NFL-2024-R1-P01). Used in league communications, broadcast graphics, and official records.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:selectionStatus rdf:type rdf:Property ;
    rdfs:label 'Selection Status' ;
    rdfs:comment 'Current lifecycle status of the draft selection. \'announced\' = pick made but contract not yet signed; \'signed\' = athlete under contract; \'unsigned\' = deadline passed without signing; \'voided\' = selection invalidated; \'traded_rights\' = negotiating rights traded post-draft; \'forfeited\' = pick forfeited due to league penalty.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:selectionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Selection Timestamp' ;
    rdfs:comment 'Precise date and time when the pick was officially announced and recorded during the draft event. Used for broadcast sequencing, official league records, and audit trail.' ;
    rdfs:domain ind:DraftSelection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:signingSlotValue rdf:type rdf:Property ;
    rdfs:label 'Signing Slot Value' ;
    rdfs:comment 'The CBA-mandated signing bonus slot value in USD assigned to this pick based on its round and overall pick number. Governs the maximum signing bonus a team may offer without penalty. Critical for salary cap management and EBITDA reporting.' ;
    rdfs:domain ind:DraftSelection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:primaryEligibilityAthleteAthleteProfileId rdf:type rdf:Property ;
    rdfs:label 'Primary Eligibility Athlete Athlete Profile Id' ;
    rdfs:comment 'Reference to the athlete whose eligibility is being tracked. Links to the athlete master record.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AthleteProfile .

ind:ageEligibilityVerified rdf:type rdf:Property ;
    rdfs:label 'Age Eligibility Verified' ;
    rdfs:comment 'Indicates whether the athlete\'s age has been formally verified against the minimum or maximum age requirements of the applicable competition or governing body (e.g., FIFA U-17 age verification, NBA draft age rule).' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:amateurProfessionalStatus rdf:type rdf:Property ;
    rdfs:label 'Amateur Professional Status' ;
    rdfs:comment 'Indicates whether the athlete holds amateur, professional, student-athlete, or Name Image and Likeness (NIL) eligible status under the applicable governing body rules. Drives eligibility for specific competitions and NIL agreement compliance.' ;
    rdfs:domain ind:EligibilityStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appealFiledDate rdf:type rdf:Property ;
    rdfs:label 'Appeal Filed Date' ;
    rdfs:comment 'Date on which the athlete or governing body formally filed an appeal against this eligibility determination. Null if no appeal has been filed.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:appealOutcomeDate rdf:type rdf:Property ;
    rdfs:label 'Appeal Outcome Date' ;
    rdfs:comment 'Date on which the appellate body (CAS, league arbitration panel) issued its final ruling on the appeal. Null if appeal is still pending or no appeal was filed.' ;
    rdfs:domain ind:EligibilityStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:appealOutcomeNotes rdf:type rdf:Property ;
    rdfs:label 'Appeal Outcome Notes' ;
    rdfs:comment 'Summary of the appellate body\'s ruling, including any modification to the original sanction (e.g., reduction in suspension length, fine adjustment, full exoneration). Null if no appeal or outcome not yet determined.' ;
    rdfs:domain ind:EligibilityStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appealStatus rdf:type rdf:Property ;
    rdfs:label 'Appeal Status' ;
    rdfs:comment 'Current status of any appeal filed against this eligibility determination. Tracks the appeal lifecycle from filing through final outcome at CAS or relevant appellate body.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:broadcastClearanceFlag rdf:type rdf:Property ;
    rdfs:label 'Broadcast Clearance Flag' ;
    rdfs:comment 'Indicates whether this athlete\'s eligibility status has been cleared for broadcast rights purposes. Ineligible or suspended athletes may require content redaction or rights clearance review for broadcast and OTT distribution.' ;
    rdfs:domain ind:EligibilityStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:decisionDate rdf:type rdf:Property ;
    rdfs:label 'Decision Date' ;
    rdfs:comment 'Date on which the governing body or issuing authority formally rendered the eligibility determination or disciplinary decision. Distinct from effective_date, which is when the restriction begins.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectiveDate rdf:type rdf:Property ;
    rdfs:label 'Effective Date' ;
    rdfs:comment 'The date on which this eligibility status becomes binding and enforceable. For suspensions, this is the first day the athlete is prohibited from competing.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:eligibilityReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Eligibility Reference Number' ;
    rdfs:comment 'Externally-known alphanumeric reference number assigned by the governing body or league office to uniquely identify this eligibility determination. Used for cross-system reconciliation and official correspondence.' ;
    rdfs:domain ind:EligibilityStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eligibilityType rdf:type rdf:Property ;
    rdfs:label 'Eligibility Type' ;
    rdfs:comment 'Classification of the eligibility event. Covers all participation-granting and participation-restricting categories including registration, amateur/professional status, visa and work permit, age eligibility, and all disciplinary actions. [ENUM-REF-CANDIDATE: registration|amateur_status|professional_status|visa_work_permit|age_eligibility|disciplinary_suspension|doping_suspension|conduct_violation|game_misconduct_ban|cba_disciplinary|transfer_clearance|reinstatement — promote to reference product]' ;
    rdfs:domain ind:EligibilityStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialPenaltyAmount rdf:type rdf:Property ;
    rdfs:label 'Financial Penalty Amount' ;
    rdfs:comment 'Monetary fine levied against the athlete as part of the disciplinary action, expressed in the currency defined by penalty_currency_code. Zero or null for eligibility events with no financial penalty.' ;
    rdfs:domain ind:Athlete ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gameDayEligible rdf:type rdf:Property ;
    rdfs:label 'Game Day Eligible' ;
    rdfs:comment 'Real-time flag indicating whether the athlete is eligible to participate in the next scheduled game or event as of the current date. Derived from effective_date, expiry_date, and eligibility_status for operational game-day roster verification.' ;
    rdfs:domain ind:EligibilityStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gamesRemaining rdf:type rdf:Property ;
    rdfs:label 'Games Remaining' ;
    rdfs:comment 'Number of games still to be served in a game-based suspension as of the last update. Decremented each time the athlete sits out a qualifying game. Null for day-based or indefinite suspensions.' ;
    rdfs:domain ind:EligibilityStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:issuingAuthority rdf:type rdf:Property ;
    rdfs:label 'Issuing Authority' ;
    rdfs:comment 'Name of the specific authority, panel, or office that issued the eligibility determination or disciplinary decision (e.g., \'NFL Commissioner Office\', \'WADA Independent Tribunal\', \'FIFA Disciplinary Committee\', \'CAS Panel\').' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:penaltyCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Penalty Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the financial penalty amount (e.g., USD, EUR, GBP). Null when no financial penalty applies.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:penaltyPaid rdf:type rdf:Property ;
    rdfs:label 'Penalty Paid' ;
    rdfs:comment 'Indicates whether the athlete has satisfied the financial penalty associated with this disciplinary eligibility event. True when payment is confirmed; False when outstanding. Null when no financial penalty applies.' ;
    rdfs:domain ind:EligibilityStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:registrationDate rdf:type rdf:Property ;
    rdfs:label 'Registration Date' ;
    rdfs:comment 'Date on which the athlete was formally registered with the league or governing body under this eligibility record.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:registrationNumber rdf:type rdf:Property ;
    rdfs:label 'Registration Number' ;
    rdfs:comment 'Official registration number assigned by the league or governing body confirming the athlete\'s registration as a professional or amateur competitor. Required for roster submission and game-day eligibility verification.' ;
    rdfs:domain ind:EligibilityStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reinstatementConditions rdf:type rdf:Property ;
    rdfs:label 'Reinstatement Conditions' ;
    rdfs:comment 'Free-text description of the specific conditions the athlete must satisfy to be reinstated to eligibility (e.g., completion of drug treatment program, payment of fine, community service hours, counselling). Null when no conditions are required.' ;
    rdfs:domain ind:Athlete ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reinstatementDate rdf:type rdf:Property ;
    rdfs:label 'Reinstatement Date' ;
    rdfs:comment 'Actual date on which the athlete was formally reinstated to eligible status following completion of a suspension or satisfaction of reinstatement conditions. Null if not yet reinstated.' ;
    rdfs:domain ind:Athlete ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:restrictionScope rdf:type rdf:Property ;
    rdfs:label 'Restriction Scope' ;
    rdfs:comment 'Defines the competitive scope of an eligibility restriction — whether the athlete is banned from all competitions globally, only league competitions, only international fixtures, a specific event, or is subject to a training ban.' ;
    rdfs:domain ind:EligibilityStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleCollectionDate rdf:type rdf:Property ;
    rdfs:label 'Sample Collection Date' ;
    rdfs:comment 'Date on which the biological sample (urine, blood) was collected from the athlete as part of the anti-doping testing process. Establishes chain of custody for WADA adjudication. Null for non-doping eligibility events.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:transferClearanceStatus rdf:type rdf:Property ;
    rdfs:label 'Transfer Clearance Status' ;
    rdfs:comment 'Status of the international transfer certificate (ITC) or transfer clearance required for athletes moving between clubs or leagues across national associations. Applicable for FIFA-governed sports and international transfers.' ;
    rdfs:domain ind:EligibilityStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:visaIssuingCountry rdf:type rdf:Property ;
    rdfs:label 'Visa Issuing Country' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the nation that issued the visa or work permit. Used for international transfer compliance and immigration tracking.' ;
    rdfs:domain ind:EligibilityStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:visaPermitNumber rdf:type rdf:Property ;
    rdfs:label 'Visa Permit Number' ;
    rdfs:comment 'Official visa or work permit document number issued by the relevant immigration authority, applicable when eligibility_type is visa_work_permit. Required for international athlete transfers and cross-border competition clearance.' ;
    rdfs:domain ind:EligibilityStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:whereaboutsCompliant rdf:type rdf:Property ;
    rdfs:label 'Whereabouts Compliant' ;
    rdfs:comment 'Indicates whether the athlete is currently compliant with WADA whereabouts filing requirements under the Registered Testing Pool (RTP). False triggers a whereabouts failure flag that may lead to a doping violation.' ;
    rdfs:domain ind:EligibilityStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:whereaboutsFailureCount rdf:type rdf:Property ;
    rdfs:label 'Whereabouts Failure Count' ;
    rdfs:comment 'Cumulative count of whereabouts filing failures or missed tests within the rolling 12-month window. Three failures within 12 months constitutes an anti-doping rule violation under WADA Code Article 2.4.' ;
    rdfs:domain ind:EligibilityStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryNilAthleteAthleteProfileId rdf:type rdf:Property ;
    rdfs:label 'Primary Nil Athlete Athlete Profile Id' ;
    rdfs:comment 'Reference to the athlete who is the subject of this NIL or endorsement agreement.' ;
    rdfs:domain ind:NilAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AthleteProfile .

ind:primaryNilBrandPartnerSponsorId rdf:type rdf:Property ;
    rdfs:label 'Primary Nil Brand Partner Sponsor Id' ;
    rdfs:comment 'Reference to the brand, company, or sponsor entity entering into the NIL or endorsement agreement with the athlete.' ;
    rdfs:domain ind:NilAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Sponsor .

ind:annualValueAmount rdf:type rdf:Property ;
    rdfs:label 'Annual Value Amount' ;
    rdfs:comment 'Annualized value of the agreement used for ARR (Annual Recurring Revenue) reporting, athlete commercial valuation, and financial planning in Workday Adaptive Planning.' ;
    rdfs:domain ind:NilAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:appearanceCount rdf:type rdf:Property ;
    rdfs:label 'Appearance Count' ;
    rdfs:comment 'Number of personal appearances (events, activations, media days) the athlete is contractually obligated to make for the brand partner over the agreement term.' ;
    rdfs:domain ind:NilAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:broadcastUsageRights rdf:type rdf:Property ;
    rdfs:label 'Broadcast Usage Rights' ;
    rdfs:comment 'Indicates whether the brand partner has rights to use the athlete\'s name, image, or likeness in broadcast advertising (TV, OTT, RSN). Critical for broadcast rights clearance workflows in Dalet Galaxy.' ;
    rdfs:domain ind:NilAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cbaComplianceStatus rdf:type rdf:Property ;
    rdfs:label 'Cba Compliance Status' ;
    rdfs:comment 'Status of the agreement\'s compliance with the applicable CBA (Collective Bargaining Agreement) endorsement and sponsor conflict provisions. Not applicable for amateur/collegiate NIL deals.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dealCategory rdf:type rdf:Property ;
    rdfs:label 'Deal Category' ;
    rdfs:comment 'Classification of the agreement type. NIL-amateur and NIL-collegiate are subject to NCAA/conference NIL policies; professional endorsement and licensing deals are governed by CBA and league sponsor conflict rules.' ;
    rdfs:domain ind:NilAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dealValueAmount rdf:type rdf:Property ;
    rdfs:label 'Deal Value Amount' ;
    rdfs:comment 'Total gross contractual value of the NIL or endorsement agreement in the agreed currency. Represents the full deal value over the contract term before any performance incentives.' ;
    rdfs:domain ind:NilAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:digitalUsageRights rdf:type rdf:Property ;
    rdfs:label 'Digital Usage Rights' ;
    rdfs:comment 'Indicates whether the brand partner has rights to use the athlete\'s name, image, or likeness in digital advertising (web, OTT streaming, DTC platforms, IPTV).' ;
    rdfs:domain ind:NilAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:disclosureDate rdf:type rdf:Property ;
    rdfs:label 'Disclosure Date' ;
    rdfs:comment 'The date on which the NIL agreement was formally disclosed to the applicable governing body (NCAA, conference office, or league). Required for compliance reporting.' ;
    rdfs:domain ind:NilAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:disclosureStatus rdf:type rdf:Property ;
    rdfs:label 'Disclosure Status' ;
    rdfs:comment 'Compliance disclosure status of the agreement with applicable governing bodies (NCAA, conference, league). Tracks whether the required disclosure has been filed, is pending, or is overdue.' ;
    rdfs:domain ind:NilAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exclusivityTerritory rdf:type rdf:Property ;
    rdfs:label 'Exclusivity Territory' ;
    rdfs:comment 'Comma-separated list of ISO 3166-1 alpha-3 country codes defining the geographic territory in which exclusivity applies. Supports global multi-market rights management.' ;
    rdfs:domain ind:NilAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:executionDate rdf:type rdf:Property ;
    rdfs:label 'Execution Date' ;
    rdfs:comment 'The date on which all parties formally signed and executed the agreement. May differ from the effective date if the agreement is backdated or post-dated.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:inVenueUsageRights rdf:type rdf:Property ;
    rdfs:label 'In Venue Usage Rights' ;
    rdfs:comment 'Indicates whether the brand partner has rights to use the athlete\'s name, image, or likeness in venue signage, jumbotron displays, or in-venue activations.' ;
    rdfs:domain ind:NilAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:incentiveValueAmount rdf:type rdf:Property ;
    rdfs:label 'Incentive Value Amount' ;
    rdfs:comment 'Total potential value of performance-based incentives included in the agreement (e.g., bonuses tied to statistical milestones, award wins, or social media engagement thresholds).' ;
    rdfs:domain ind:NilAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:internalNotes rdf:type rdf:Property ;
    rdfs:label 'Internal Notes' ;
    rdfs:comment 'Free-text field for internal legal, compliance, or commercial team notes regarding the agreement. Not shared externally. Supports deal management and audit workflows.' ;
    rdfs:domain ind:NilAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leagueSponsorConflictFlag rdf:type rdf:Property ;
    rdfs:label 'League Sponsor Conflict Flag' ;
    rdfs:comment 'Indicates whether this agreement has been flagged as potentially conflicting with an official league or team sponsor in the same product category. Triggers a sponsorship conflict-of-interest review.' ;
    rdfs:domain ind:NilAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:merchandiseUsageRights rdf:type rdf:Property ;
    rdfs:label 'Merchandise Usage Rights' ;
    rdfs:comment 'Indicates whether the brand partner has rights to use the athlete\'s name, image, or likeness on licensed merchandise and retail products (SKU-level). Relevant for Shopify Plus merchandise operations.' ;
    rdfs:domain ind:NilAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:moralityClauseIncluded rdf:type rdf:Property ;
    rdfs:label 'Morality Clause Included' ;
    rdfs:comment 'Indicates whether the agreement contains a morality clause allowing the brand partner to terminate the deal if the athlete engages in conduct deemed harmful to the brand\'s reputation.' ;
    rdfs:domain ind:NilAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:moralityClauseTerms rdf:type rdf:Property ;
    rdfs:label 'Morality Clause Terms' ;
    rdfs:comment 'Textual description of the specific morality clause terms and triggering conditions included in the agreement. Populated only when morality_clause_included is True.' ;
    rdfs:domain ind:NilAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentStructure rdf:type rdf:Property ;
    rdfs:label 'Payment Structure' ;
    rdfs:comment 'Defines how the deal value is paid to the athlete: as a single lump sum, periodic installments, milestone-triggered payments, royalty-based (percentage of sales), or a hybrid combination.' ;
    rdfs:domain ind:NilAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productCategory rdf:type rdf:Property ;
    rdfs:label 'Product Category' ;
    rdfs:comment 'The product or service category of the brand partner\'s offering covered by this agreement (e.g., athletic footwear, sports nutrition, financial services, automotive, apparel). Used for league sponsor conflict-of-interest checks. [ENUM-REF-CANDIDATE: athletic_footwear|apparel|sports_nutrition|financial_services|automotive|technology|beverage|healthcare|gaming|media — promote to reference product]' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:royaltyRateOverride rdf:type rdf:Property ;
    rdfs:label 'Royalty Rate Override' ;
    rdfs:comment 'Per-SKU royalty rate expressed as a decimal fraction that overrides the master agreement\'s deal value terms for this specific SKU. Enables differentiated royalty structures within a single NIL deal (e.g., higher rate for autographed memorabilia vs. standard apparel).' ;
    rdfs:domain ind:NilAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:socialMediaPostCount rdf:type rdf:Property ;
    rdfs:label 'Social Media Post Count' ;
    rdfs:comment 'Number of sponsored social media posts the athlete is contractually obligated to publish for the brand partner over the agreement term. Relevant for NCAA NIL social media deal tracking.' ;
    rdfs:domain ind:NilAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:socialMediaUsageRights rdf:type rdf:Property ;
    rdfs:label 'Social Media Usage Rights' ;
    rdfs:comment 'Indicates whether the brand partner has rights to use the athlete\'s name, image, or likeness in social media campaigns. Relevant for NCAA NIL social media deal compliance.' ;
    rdfs:domain ind:NilAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:terminationDate rdf:type rdf:Property ;
    rdfs:label 'Termination Date' ;
    rdfs:comment 'The date on which the agreement was early-terminated by either party. Null if the agreement ran to its natural expiration. Distinct from expiration_date which represents the scheduled end.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:terminationReason rdf:type rdf:Property ;
    rdfs:label 'Termination Reason' ;
    rdfs:comment 'Reason code for early termination of the agreement. Populated only when termination_date is set. Supports compliance reporting and legal dispute tracking. [ENUM-REF-CANDIDATE: mutual_agreement|morality_clause|breach_of_contract|athlete_retirement|league_suspension|brand_withdrawal|regulatory_violation — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:territoryRestriction rdf:type rdf:Property ;
    rdfs:label 'Territory Restriction' ;
    rdfs:comment 'Comma-separated list of ISO 3166-1 alpha-3 country codes defining the geographic scope for this specific SKU authorization. May be narrower than the master agreement\'s exclusivity_territory — for example, a jersey SKU may only be authorized for US and CAN markets even if the master deal covers global rights.' ;
    rdfs:domain ind:NilAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usageRightsScope rdf:type rdf:Property ;
    rdfs:label 'Usage Rights Scope' ;
    rdfs:comment 'Defines which specific usage rights (broadcast, digital, social, in-venue, merchandise) apply to this SKU under this NIL agreement. May be a subset of the master agreement\'s usage rights flags, allowing per-SKU restriction of rights.' ;
    rdfs:domain ind:NilAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agentRelationshipId rdf:type rdf:Property ;
    rdfs:label 'Agent Relationship Id' ;
    rdfs:comment 'Unique surrogate identifier for the agent-athlete relationship record in the lakehouse silver layer. Primary key for this association entity.' ;
    rdfs:domain ind:AgentRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:agencyId rdf:type rdf:Property ;
    rdfs:label 'Agency Id' ;
    rdfs:comment 'Reference to the sports agency or firm through which the agent operates. An agent may be affiliated with a larger agency entity.' ;
    rdfs:domain ind:Athlete ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Agency .

ind:primaryAgentAthleteAthleteProfileId rdf:type rdf:Property ;
    rdfs:label 'Primary Agent Athlete Athlete Profile Id' ;
    rdfs:comment 'Reference to the athlete who is represented under this agent relationship. Links to the athlete master record.' ;
    rdfs:domain ind:AgentRelationship ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AthleteProfile .

ind:agentLicenseJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Agent License Jurisdiction' ;
    rdfs:comment 'The country or state/province jurisdiction in which the agent holds a valid sports agent license or registration, where required by law (e.g., US state athlete agent acts, EU member state regulations). Stored as ISO 3166-1 alpha-2 or alpha-3 country code.' ;
    rdfs:domain ind:AgentRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agreementDocumentRef rdf:type rdf:Property ;
    rdfs:label 'Agreement Document Ref' ;
    rdfs:comment 'Reference identifier or URL pointing to the executed representation agreement document stored in the digital asset management (DAM) or document management system. Enables retrieval of the signed contract for compliance audits.' ;
    rdfs:domain ind:AgentRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Certification Expiry Date' ;
    rdfs:comment 'The date on which the agent\'s players association certification expires and must be renewed. Used to trigger compliance alerts and prevent unauthorized representation activity.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:certificationNumber rdf:type rdf:Property ;
    rdfs:label 'Certification Number' ;
    rdfs:comment 'Official certification or license number issued by the relevant players association (e.g., NFLPA, NBPA, MLBPA, NHLPA) confirming the agent is authorized to represent athletes in contract negotiations. Required for league compliance validation.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commissionBasis rdf:type rdf:Property ;
    rdfs:label 'Commission Basis' ;
    rdfs:comment 'Defines the income base upon which the agent\'s commission rate is applied. Determines whether commission is calculated on gross salary, net salary, signing bonus, endorsement income, NIL (Name Image and Likeness) income, or all income streams.' ;
    rdfs:domain ind:AgentRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commissionRatePct rdf:type rdf:Property ;
    rdfs:label 'Commission Rate Pct' ;
    rdfs:comment 'The contractually agreed commission rate (expressed as a decimal fraction, e.g., 0.0300 = 3%) that the agent earns on the athlete\'s compensation under this representation agreement. Subject to CBA (Collective Bargaining Agreement) maximum commission caps per league.' ;
    rdfs:domain ind:AgentRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:complianceReviewDate rdf:type rdf:Property ;
    rdfs:label 'Compliance Review Date' ;
    rdfs:comment 'The date of the most recent compliance review of this agent-athlete relationship, verifying that the agent\'s certification is current, commission rates comply with CBA caps, and no conflicts of interest exist.' ;
    rdfs:domain ind:AgentRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:complianceReviewOutcome rdf:type rdf:Property ;
    rdfs:label 'Compliance Review Outcome' ;
    rdfs:comment 'Result of the most recent compliance review of this agent-athlete relationship. Passed indicates all requirements met; failed indicates one or more violations identified; pending indicates review in progress; waived indicates review exempted by league authority.' ;
    rdfs:domain ind:AgentRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractNegotiationAuthority rdf:type rdf:Property ;
    rdfs:label 'Contract Negotiation Authority' ;
    rdfs:comment 'Indicates whether this agent is authorized to negotiate the athlete\'s playing contract (salary, bonuses, incentives) with team management on the athlete\'s behalf. Core authority granted under standard player representation agreements.' ;
    rdfs:domain ind:AgentRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:crmRecordReference rdf:type rdf:Property ;
    rdfs:label 'Crm Record Reference' ;
    rdfs:comment 'The unique identifier of the corresponding agent-athlete relationship record in Salesforce CRM, used for system-of-record traceability and bi-directional synchronization between the lakehouse and the CRM platform.' ;
    rdfs:domain ind:AgentRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endorsementRepresentation rdf:type rdf:Property ;
    rdfs:label 'Endorsement Representation' ;
    rdfs:comment 'Indicates whether this agent relationship includes authority to negotiate commercial endorsement deals on behalf of the athlete, separate from the athlete\'s playing contract.' ;
    rdfs:domain ind:AgentRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPrimaryAgent rdf:type rdf:Property ;
    rdfs:label 'Is Primary Agent' ;
    rdfs:comment 'Indicates whether this agent is the athlete\'s primary (lead) representative when the athlete has multiple agents covering different representation scopes. Only one agent relationship per athlete should be flagged as primary at any given time.' ;
    rdfs:domain ind:AgentRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:leagueApprovalDate rdf:type rdf:Property ;
    rdfs:label 'League Approval Date' ;
    rdfs:comment 'The date on which the relevant league office or players association formally approved the agent-athlete representation agreement, authorizing the agent to act on the athlete\'s behalf.' ;
    rdfs:domain ind:AgentRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:leagueFilingDate rdf:type rdf:Property ;
    rdfs:label 'League Filing Date' ;
    rdfs:comment 'The date on which the agent-athlete representation agreement was formally filed with the relevant league office or players association for approval and registration.' ;
    rdfs:domain ind:AgentRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:leagueFilingStatus rdf:type rdf:Property ;
    rdfs:label 'League Filing Status' ;
    rdfs:comment 'Status of the agent relationship filing with the relevant league office or players association. Leagues require formal notification and approval of agent-athlete representation agreements before the agent may negotiate on the athlete\'s behalf.' ;
    rdfs:domain ind:AgentRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalRepresentation rdf:type rdf:Property ;
    rdfs:label 'Legal Representation' ;
    rdfs:comment 'Indicates whether this relationship includes legal representation authority (e.g., grievance filings, arbitration proceedings, disciplinary hearings). May require the agent to also be a licensed attorney depending on jurisdiction.' ;
    rdfs:domain ind:AgentRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nilRepresentation rdf:type rdf:Property ;
    rdfs:label 'Nil Representation' ;
    rdfs:comment 'Indicates whether this agent relationship includes authority to negotiate NIL (Name Image and Likeness) deals on behalf of the athlete. NIL representation may be scoped separately from contract negotiation authority.' ;
    rdfs:domain ind:AgentRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:powerOfAttorney rdf:type rdf:Property ;
    rdfs:label 'Power Of Attorney' ;
    rdfs:comment 'Indicates whether the athlete has granted the agent a formal power of attorney, authorizing the agent to execute contracts and legal documents on the athlete\'s behalf without requiring the athlete\'s direct signature.' ;
    rdfs:domain ind:AgentRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:powerOfAttorneyScope rdf:type rdf:Property ;
    rdfs:label 'Power Of Attorney Scope' ;
    rdfs:comment 'Describes the specific scope and limitations of the power of attorney granted to the agent, if applicable. May specify which transaction types, dollar thresholds, or legal actions are covered. Null if power_of_attorney is False. [ENUM-REF-CANDIDATE: full|contract_only|endorsement_only|financial_only|limited — promote to reference product]' ;
    rdfs:domain ind:AgentRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactEmail rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Email' ;
    rdfs:comment 'Primary email address used to contact the agent for contract negotiation communications, league notifications, and official correspondence related to this athlete representation.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactPhone rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Phone' ;
    rdfs:comment 'Primary phone number for reaching the agent regarding this athlete representation relationship. Stored in E.164 international format.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipNumber rdf:type rdf:Property ;
    rdfs:label 'Relationship Number' ;
    rdfs:comment 'Externally-known business identifier for this agent-athlete relationship, used in correspondence, contract filings, and league submissions. Format: AR-YYYYNNNN.' ;
    rdfs:domain ind:AgentRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalOption rdf:type rdf:Property ;
    rdfs:label 'Renewal Option' ;
    rdfs:comment 'Indicates whether the representation agreement contains an automatic renewal clause or a mutual option to extend the relationship beyond the initial term without executing a new agreement.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:representationAgreementDate rdf:type rdf:Property ;
    rdfs:label 'Representation Agreement Date' ;
    rdfs:comment 'The date on which the formal representation agreement between the athlete and agent was executed (signed by both parties). May differ from the effective_date if there is a delayed commencement clause.' ;
    rdfs:domain ind:AgentRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:representationScope rdf:type rdf:Property ;
    rdfs:label 'Representation Scope' ;
    rdfs:comment 'Defines the scope of authority granted to the agent under this relationship. Typical values include contract_negotiation, endorsements, nil_agreements, legal, media, financial_advisory, full_service. [ENUM-REF-CANDIDATE: contract_negotiation|endorsements|nil_agreements|legal|media|financial_advisory|full_service — promote to reference product]' ;
    rdfs:domain ind:AgentRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dopingViolationId rdf:type rdf:Property ;
    rdfs:label 'Doping Violation Id' ;
    rdfs:comment 'Foreign key linking to compliance.doping_violation. Business justification: Doping-triggered suspensions must reference the underlying compliance.doping_violation for CAS appeals, results disqualification processing, and WADA reporting. Legal and compliance teams require this' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DopingViolation .

ind:ejectionRecordId rdf:type rdf:Property ;
    rdfs:label 'Ejection Record Id' ;
    rdfs:comment 'Foreign key linking to security.ejection_record. Business justification: Game ejections are the primary trigger for suspension reviews in professional sports. Linking suspension_record to the originating ejection_record supports league discipline workflows, appeals process' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EjectionRecord .

ind:incidentFixtureId rdf:type rdf:Property ;
    rdfs:label 'Incident Fixture Id' ;
    rdfs:comment 'Foreign key linking to event.fixture. Business justification: Suspension records must reference the specific fixture where the suspendable violation occurred for disciplinary hearing evidence, regulatory filings, broadcast disclosure scheduling, and determining ' ;
    rdfs:domain ind:SuspensionRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Fixture .

ind:primarySuspensionAthleteAthleteProfileId rdf:type rdf:Property ;
    rdfs:label 'Primary Suspension Athlete Athlete Profile Id' ;
    rdfs:comment 'Reference to the athlete who is subject to this disciplinary suspension or ban.' ;
    rdfs:domain ind:SuspensionRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AthleteProfile .

ind:primarySuspensionFranchiseId rdf:type rdf:Property ;
    rdfs:label 'Primary Suspension Franchise Id' ;
    rdfs:comment 'Reference to the team or franchise the athlete was rostered on at the time the suspension was issued.' ;
    rdfs:domain ind:SuspensionRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Franchise .

ind:triggeringSecurityIncidentId rdf:type rdf:Property ;
    rdfs:label 'Triggering Security Incident Id' ;
    rdfs:comment 'Foreign key linking to security.security_incident. Business justification: On-field altercations and venue security incidents directly trigger athlete suspension proceedings. Linking suspension_record to the originating security_incident supports league discipline documentat' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SecurityIncident .

ind:appealBody rdf:type rdf:Property ;
    rdfs:label 'Appeal Body' ;
    rdfs:comment 'The body or tribunal that is hearing or heard the appeal (e.g., CAS (Court of Arbitration for Sport), WADA, League Appeals Panel, Arbitration, Federal Court). Null or \'None\' if no appeal was filed.' ;
    rdfs:domain ind:SuspensionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appealResolutionDate rdf:type rdf:Property ;
    rdfs:label 'Appeal Resolution Date' ;
    rdfs:comment 'Date on which the appeal was formally resolved by the appellate body (e.g., CAS, league appeals panel). Null if the appeal is still pending or no appeal was filed.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:broadcastRestrictionFlag rdf:type rdf:Property ;
    rdfs:label 'Broadcast Restriction Flag' ;
    rdfs:comment 'Indicates whether the suspension includes restrictions on the athlete\'s appearance in broadcast content, media, or promotional materials during the suspension period. Relevant for broadcast rights compliance and content production scheduling.' ;
    rdfs:domain ind:SuspensionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:caseReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Case Reference Number' ;
    rdfs:comment 'Externally-known disciplinary case number or docket identifier assigned by the issuing authority (e.g., league office, WADA, CAS). Used for cross-referencing with legal and compliance systems.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competitionScope rdf:type rdf:Property ;
    rdfs:label 'Competition Scope' ;
    rdfs:comment 'Defines the scope of competitions from which the athlete is suspended. Some suspensions apply to all competitions (including international), while others are limited to specific competition types (e.g., league games only, international fixtures only).' ;
    rdfs:domain ind:SuspensionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hearingDate rdf:type rdf:Property ;
    rdfs:label 'Hearing Date' ;
    rdfs:comment 'Date on which the formal disciplinary hearing was conducted before the suspension was issued. Null if no formal hearing was held (e.g., automatic suspensions for certain violations).' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:hearingOfficer rdf:type rdf:Property ;
    rdfs:label 'Hearing Officer' ;
    rdfs:comment 'Name or title of the independent arbitrator, hearing officer, or disciplinary panel chair who presided over the disciplinary hearing. Null if no formal hearing was held.' ;
    rdfs:domain ind:SuspensionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isIndefinite rdf:type rdf:Property ;
    rdfs:label 'Is Indefinite' ;
    rdfs:comment 'Indicates whether the suspension is indefinite with no fixed end date. True when the athlete is banned until further review or reinstatement conditions are met. When True, effective_end_date will be null.' ;
    rdfs:domain ind:SuspensionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isLifetimeBan rdf:type rdf:Property ;
    rdfs:label 'Is Lifetime Ban' ;
    rdfs:comment 'Indicates whether the suspension constitutes a permanent lifetime ban from the sport or league. Typically applied for second PED (Performance Enhancing Drug) violations under WADA or severe integrity violations such as match fixing.' ;
    rdfs:domain ind:SuspensionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPublicAnnouncement rdf:type rdf:Property ;
    rdfs:label 'Is Public Announcement' ;
    rdfs:comment 'Indicates whether the suspension has been publicly announced by the league or issuing authority. Some suspensions (particularly early-stage PED violations) may be kept confidential until the appeals process is exhausted.' ;
    rdfs:domain ind:SuspensionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSuspensionStayed rdf:type rdf:Property ;
    rdfs:label 'Is Suspension Stayed' ;
    rdfs:comment 'Indicates whether the suspension has been temporarily stayed (paused) pending the outcome of an appeal. When True, the athlete may continue to participate while the appeal is resolved.' ;
    rdfs:domain ind:SuspensionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:issuedDate rdf:type rdf:Property ;
    rdfs:label 'Issued Date' ;
    rdfs:comment 'The date on which the suspension decision was formally issued or announced by the issuing authority. Represents the principal real-world business event timestamp (BUSINESS_EVENT_TIMESTAMP category).' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nilAgreementImpact rdf:type rdf:Property ;
    rdfs:label 'Nil Agreement Impact' ;
    rdfs:comment 'Status of the athlete\'s NIL (Name, Image, and Likeness) agreements during the suspension period. Indicates whether NIL deals are suspended, terminated by sponsors, unaffected, or under review. Critical for commercial and sponsorship compliance tracking.' ;
    rdfs:domain ind:SuspensionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorViolationCount rdf:type rdf:Property ;
    rdfs:label 'Prior Violation Count' ;
    rdfs:comment 'Number of prior disciplinary violations of the same type on the athlete\'s record at the time this suspension was issued. Used to determine escalating penalty tiers under WADA and league policies (e.g., first offense vs. second offense).' ;
    rdfs:domain ind:SuspensionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:prohibitedSubstanceCode rdf:type rdf:Property ;
    rdfs:label 'Prohibited Substance Code' ;
    rdfs:comment 'WADA-assigned code or name of the prohibited substance detected in the anti-doping violation (e.g., \'S1.1 — Testosterone\', \'S6.A — Stimulants\'). Null for non-PED (Performance Enhancing Drug) suspensions. Classified confidential due to sensitive health-adjacent nature.' ;
    rdfs:domain ind:SuspensionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salaryWithheldAmount rdf:type rdf:Property ;
    rdfs:label 'Salary Withheld Amount' ;
    rdfs:comment 'Total salary amount withheld from the athlete during the suspension period as a consequence of the disciplinary action, expressed in the applicable currency. Distinct from financial_penalty_amount which is a separate fine. Tracked for payroll and CBA compliance.' ;
    rdfs:domain ind:SuspensionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sourceSystemReference rdf:type rdf:Property ;
    rdfs:label 'Source System Reference' ;
    rdfs:comment 'Identifier or reference code from the originating operational system of record where this suspension was first captured (e.g., SAP SuccessFactors case ID, Salesforce CRM case number). Enables traceability back to the source system for reconciliation.' ;
    rdfs:domain ind:SuspensionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:suspensionLengthDays rdf:type rdf:Property ;
    rdfs:label 'Suspension Length Days' ;
    rdfs:comment 'Number of calendar days the athlete is suspended, as specified in the suspension ruling. Null if the suspension is measured in games or is indefinite. Common in WADA anti-doping cases and FIFA disciplinary proceedings.' ;
    rdfs:domain ind:SuspensionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:suspensionLengthGames rdf:type rdf:Property ;
    rdfs:label 'Suspension Length Games' ;
    rdfs:comment 'Number of games the athlete is suspended from participating in, as specified in the suspension ruling. Null if the suspension is measured in days or is indefinite. Used for game-based suspensions common in NFL, NBA, MLB, NHL.' ;
    rdfs:domain ind:SuspensionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:suspensionStatus rdf:type rdf:Property ;
    rdfs:label 'Suspension Status' ;
    rdfs:comment 'Current lifecycle state of the suspension record. \'Active\' means the athlete is currently serving the suspension; \'Served\' means the suspension period has been completed; \'Appealed\' means the athlete has filed an appeal and the suspension may be stayed; \'Overturned\' means the suspension was reversed on appeal; \'Reduced\' means the original penalty was reduced; \'Pending\' means the suspension has been issued but not yet commenced.' ;
    rdfs:domain ind:SuspensionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:suspensionType rdf:type rdf:Property ;
    rdfs:label 'Suspension Type' ;
    rdfs:comment 'Classification of the disciplinary action by the nature of the violation. PED (Performance Enhancing Drug) violations are governed by WADA; conduct violations relate to personal conduct policies; game misconduct covers in-game rule infractions; league discipline covers CBA-governed actions; match fixing and financial breach are integrity-related. [ENUM-REF-CANDIDATE: ped_violation|conduct_violation|game_misconduct|league_discipline|match_fixing|financial_breach|eligibility_violation|anti-doping — promote to reference product]' ;
    rdfs:domain ind:SuspensionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testingAuthority rdf:type rdf:Property ;
    rdfs:label 'Testing Authority' ;
    rdfs:comment 'Name of the anti-doping organization (ADO) or testing authority that conducted the drug test resulting in the violation (e.g., USADA, UKAD, WADA, NADO). Null for non-PED suspensions.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unionGrievanceNumber rdf:type rdf:Property ;
    rdfs:label 'Union Grievance Number' ;
    rdfs:comment 'The formal grievance or arbitration case number filed by the players\' union (e.g., NFLPA, NBPA, MLBPA) on behalf of the athlete under the CBA (Collective Bargaining Agreement) grievance procedures. Null if no union grievance was filed.' ;
    rdfs:domain ind:SuspensionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:violationCategory rdf:type rdf:Property ;
    rdfs:label 'Violation Category' ;
    rdfs:comment 'Specific sub-category or rule code of the violation that triggered the suspension (e.g., \'Prohibited Substance — S1 Anabolic Agents\', \'Domestic Violence\', \'Gambling\', \'Unsportsmanlike Conduct\'). Provides granular classification beyond suspension_type for compliance reporting. [ENUM-REF-CANDIDATE: promote to reference product given large enumeration across leagues]' ;
    rdfs:domain ind:SuspensionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salaryCapEntryId rdf:type rdf:Property ;
    rdfs:label 'Salary Cap Entry Id' ;
    rdfs:comment 'Unique surrogate identifier for each athlete-level salary cap accounting record within the Silver Layer lakehouse. Primary key for this product.' ;
    rdfs:domain ind:SalaryCapEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ledgerId rdf:type rdf:Property ;
    rdfs:label 'Ledger Id' ;
    rdfs:comment 'Foreign key linking to finance.ledger. Business justification: Cap entries must be posted to a specific accounting ledger (leading vs. parallel IFRS/GAAP ledger) for multi-GAAP reporting. Finance teams require ledger assignment on cap entries for period-close rec' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Ledger .

ind:primarySalaryAthleteAthleteProfileId rdf:type rdf:Property ;
    rdfs:label 'Primary Salary Athlete Athlete Profile Id' ;
    rdfs:comment 'Reference to the athlete whose contract generates this cap entry. Links to the athlete master record in the talent management domain.' ;
    rdfs:domain ind:SalaryCapEntry ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AthleteProfile .

ind:primarySalaryFranchiseId rdf:type rdf:Property ;
    rdfs:label 'Primary Salary Franchise Id' ;
    rdfs:comment 'Reference to the team (franchise) against whose salary cap this entry is charged. Determines which team\'s cap space is consumed.' ;
    rdfs:domain ind:SalaryCapEntry ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Franchise .

ind:salaryCapId rdf:type rdf:Property ;
    rdfs:label 'Salary Cap Id' ;
    rdfs:comment 'Foreign key linking to league.salary_cap. Business justification: Each salary_cap_entry (individual player cap hit) must be validated against the franchise\'s total salary_cap record for the season. Linking enables cap space remaining calculations, luxury tax liabili' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SalaryCap .

ind:baseSalary rdf:type rdf:Property ;
    rdfs:label 'Base Salary' ;
    rdfs:comment 'The athlete\'s annual base salary for this cap year as defined in the contract. This is the cash compensation component before bonuses or restructuring. Feeds directly into SAP S/4HANA FI/CO payroll cost centers.' ;
    rdfs:domain ind:SalaryCapEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capAccelerationDate rdf:type rdf:Property ;
    rdfs:label 'Cap Acceleration Date' ;
    rdfs:comment 'The date on which remaining prorated bonuses were accelerated into the current cap year due to a release or trade. Triggers the dead cap charge. Null if no acceleration has occurred.' ;
    rdfs:domain ind:SalaryCapEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:capEntryReference rdf:type rdf:Property ;
    rdfs:label 'Cap Entry Reference' ;
    rdfs:comment 'Externally-known business identifier for this salary cap entry record, used in cross-system reconciliation with SAP S/4HANA FI/CO and Workday Adaptive Planning. Format typically includes league code, team code, cap year, and sequence (e.g., NFL-DAL-2024-0042).' ;
    rdfs:domain ind:SalaryCapEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capHoldAmount rdf:type rdf:Property ;
    rdfs:label 'Cap Hold Amount' ;
    rdfs:comment 'The cap space reserved for a restricted free agent (RFA) or unsigned draft pick while the team retains their rights. Prevents teams from circumventing the cap by leaving players unsigned. Amount is set by league rules based on prior salary or draft position.' ;
    rdfs:domain ind:Athlete ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capRelief rdf:type rdf:Property ;
    rdfs:label 'Cap Relief' ;
    rdfs:comment 'The reduction in cap hit achieved through a contract restructure, typically by converting base salary into a signing bonus that is then prorated. Represents the net cap space freed in the current year as a result of the restructure.' ;
    rdfs:domain ind:SalaryCapEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capYear rdf:type rdf:Property ;
    rdfs:label 'Cap Year' ;
    rdfs:comment 'The league-defined fiscal/competitive year (e.g., 2024) to which this salary cap entry applies. Cap years may not align with calendar years depending on the league\'s CBA definition.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:capYearEndDate rdf:type rdf:Property ;
    rdfs:label 'Cap Year End Date' ;
    rdfs:comment 'The last date of the league-defined cap year period during which this entry is active. Marks the boundary for cap accounting obligations in this record.' ;
    rdfs:domain ind:SalaryCapEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:capYearStartDate rdf:type rdf:Property ;
    rdfs:label 'Cap Year Start Date' ;
    rdfs:comment 'The first date of the league-defined cap year period during which this entry is active. Used for proration calculations and cap forecasting in Workday Adaptive Planning.' ;
    rdfs:domain ind:SalaryCapEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contractTotalYears rdf:type rdf:Property ;
    rdfs:label 'Contract Total Years' ;
    rdfs:comment 'Total number of years in the underlying contract. Used as the denominator for signing bonus proration calculations across cap years.' ;
    rdfs:domain ind:SalaryCapEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contractYearNumber rdf:type rdf:Property ;
    rdfs:label 'Contract Year Number' ;
    rdfs:comment 'The sequential year number within the multi-year contract that this cap entry represents (e.g., Year 1, Year 2, Year 3 of a 5-year deal). Used to track proration schedules and contract progression.' ;
    rdfs:domain ind:SalaryCapEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deadCapValue rdf:type rdf:Property ;
    rdfs:label 'Dead Cap Value' ;
    rdfs:comment 'The remaining prorated bonus and other accelerated cap charges that count against the team\'s cap after an athlete is released, traded, or their contract is terminated. Represents the cap penalty for parting ways with the athlete before contract expiry.' ;
    rdfs:domain ind:SalaryCapEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:entryStatus rdf:type rdf:Property ;
    rdfs:label 'Entry Status' ;
    rdfs:comment 'Current lifecycle state of this salary cap entry. \'active\' = currently counting against cap; \'restructured\' = contract has been restructured, new entry supersedes; \'voided\' = contract voided/nullified; \'dead_cap\' = player released but cap charge remains; \'cap_hold\' = restricted free agent tender hold; \'historical\' = prior year closed record.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entryType rdf:type rdf:Property ;
    rdfs:label 'Entry Type' ;
    rdfs:comment 'Classification of the cap entry by contract category per CBA rules. Determines applicable cap calculation methodology. [ENUM-REF-CANDIDATE: standard|rookie_scale|veteran_minimum|franchise_tag|transition_tag|cap_hold|two_way|10_day|rest_of_season — promote to reference product]' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incentiveEarnedPriorYear rdf:type rdf:Property ;
    rdfs:label 'Incentive Earned Prior Year' ;
    rdfs:comment 'Indicates whether the athlete earned incentives in the prior cap year that were classified as \'unlikely\' at the time, triggering a cap charge carryover into this cap year. True = prior year unlikely incentive was earned and creates a charge in this year.' ;
    rdfs:domain ind:SalaryCapEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isCapHold rdf:type rdf:Property ;
    rdfs:label 'Is Cap Hold' ;
    rdfs:comment 'Indicates whether this entry is a cap hold for a restricted free agent or unsigned draft pick rather than an active contract. True = cap hold; False = active contract cap entry.' ;
    rdfs:domain ind:SalaryCapEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isDeadCap rdf:type rdf:Property ;
    rdfs:label 'Is Dead Cap' ;
    rdfs:comment 'Indicates whether this entry represents a dead cap charge (athlete has been released or traded but remaining prorated bonuses still count against the team\'s cap). True = athlete is no longer on roster but cap charge persists.' ;
    rdfs:domain ind:SalaryCapEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRestructured rdf:type rdf:Property ;
    rdfs:label 'Is Restructured' ;
    rdfs:comment 'Indicates whether this cap entry reflects a contract restructure that converted base salary to prorated bonus, generating cap relief in the current year. True = restructure has been applied to this entry.' ;
    rdfs:domain ind:SalaryCapEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:leagueReportedDate rdf:type rdf:Property ;
    rdfs:label 'League Reported Date' ;
    rdfs:comment 'The date on which this cap entry was officially reported to and acknowledged by the league office. Required for compliance with league transaction reporting deadlines under CBA rules.' ;
    rdfs:domain ind:SalaryCapEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:likelyIncentiveAmount rdf:type rdf:Property ;
    rdfs:label 'Likely Incentive Amount' ;
    rdfs:comment 'Total value of performance incentives classified as \'likely to be earned\' per CBA rules based on the athlete\'s prior year performance. Likely incentives count against the current cap year. Per CBA definition, an incentive is \'likely\' if the athlete achieved the same threshold in the prior season.' ;
    rdfs:domain ind:SalaryCapEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:optionBonusProrated rdf:type rdf:Property ;
    rdfs:label 'Option Bonus Prorated' ;
    rdfs:comment 'The prorated portion of any option bonus (e.g., option year exercise bonus, void year bonus) allocated to this cap year. Option bonuses are prorated over remaining contract years when exercised.' ;
    rdfs:domain ind:SalaryCapEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:perGameRosterBonus rdf:type rdf:Property ;
    rdfs:label 'Per Game Roster Bonus' ;
    rdfs:comment 'Bonus amount earned on a per-game-active basis for each game the athlete is on the active roster. Common in NFL contracts. Total potential value for the cap year is tracked here for cap forecasting purposes.' ;
    rdfs:domain ind:SalaryCapEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priorYearIncentiveCarryover rdf:type rdf:Property ;
    rdfs:label 'Prior Year Incentive Carryover' ;
    rdfs:comment 'The dollar amount of incentives earned in the prior cap year (classified as \'unlikely\') that carry over as an additional cap charge in this cap year per CBA rules. Distinct from current-year incentive amounts.' ;
    rdfs:domain ind:SalaryCapEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:restructureDate rdf:type rdf:Property ;
    rdfs:label 'Restructure Date' ;
    rdfs:comment 'The date on which the contract restructure was executed, converting base salary to prorated signing bonus and generating cap relief. Null if no restructure has occurred for this entry.' ;
    rdfs:domain ind:SalaryCapEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rosterBonus rdf:type rdf:Property ;
    rdfs:label 'Roster Bonus' ;
    rdfs:comment 'Bonus amount payable to the athlete for being on the active roster on a specified date in this cap year. Counts fully against the cap in the year it is earned per CBA rules.' ;
    rdfs:domain ind:SalaryCapEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:signingBonusProrated rdf:type rdf:Property ;
    rdfs:label 'Signing Bonus Prorated' ;
    rdfs:comment 'The portion of the total signing bonus allocated to this specific cap year after proration across the contract length per CBA rules. This amount is included in the cap hit calculation.' ;
    rdfs:domain ind:SalaryCapEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:signingBonusTotal rdf:type rdf:Property ;
    rdfs:label 'Signing Bonus Total' ;
    rdfs:comment 'Total signing bonus paid to the athlete at contract execution. This amount is prorated across the contract years for cap purposes per CBA rules. Stored as the full contract-level total for reference.' ;
    rdfs:domain ind:SalaryCapEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unlikelyIncentiveAmount rdf:type rdf:Property ;
    rdfs:label 'Unlikely Incentive Amount' ;
    rdfs:comment 'Total value of performance incentives classified as \'unlikely to be earned\' per CBA rules. Unlikely incentives do NOT count against the current cap year but create a cap charge in the following year if earned. Per CBA definition, an incentive is \'unlikely\' if the athlete did NOT achieve the threshold in the prior season.' ;
    rdfs:domain ind:SalaryCapEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:voidYearFlag rdf:type rdf:Property ;
    rdfs:label 'Void Year Flag' ;
    rdfs:comment 'Indicates whether this cap year is a void year — a contract year that automatically voids, causing all remaining prorated bonuses to accelerate into the final non-void year. Common NFL cap management technique. True = this is a void year.' ;
    rdfs:domain ind:SalaryCapEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:workdayPlanReference rdf:type rdf:Property ;
    rdfs:label 'Workday Plan Reference' ;
    rdfs:comment 'Reference identifier linking this cap entry to the corresponding cap forecast scenario in Workday Adaptive Planning. Enables reconciliation between actual cap accounting records and forward-looking cap projections.' ;
    rdfs:domain ind:SalaryCapEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workoutBonus rdf:type rdf:Property ;
    rdfs:label 'Workout Bonus' ;
    rdfs:comment 'Bonus amount payable to the athlete for attending and completing mandatory off-season workout programs. Cap treatment varies by league CBA — may be fully or partially counted.' ;
    rdfs:domain ind:SalaryCapEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:freeAgencyStatusId rdf:type rdf:Property ;
    rdfs:label 'Free Agency Status Id' ;
    rdfs:comment 'Unique surrogate identifier for the free agency status record. Primary key for the athlete.free_agency_status data product in the Databricks Silver Layer.' ;
    rdfs:domain ind:FreeAgencyStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:compensatoryDraftPickId rdf:type rdf:Property ;
    rdfs:label 'Compensatory Draft Pick Id' ;
    rdfs:comment 'Foreign key linking to league.draft_pick. Business justification: When a franchise loses a free agent, compensatory draft picks are awarded. free_agency_status has draft_pick_compensation_flag but no FK to the actual pick awarded. Linking to the specific draft_pick ' ;
    rdfs:domain ind:FreeAgencyStatus ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DraftPick .

ind:primaryFreeAthleteAthleteProfileId rdf:type rdf:Property ;
    rdfs:label 'Primary Free Athlete Athlete Profile Id' ;
    rdfs:comment 'Reference to the athlete whose free agency status is being tracked. Links to the athlete master record.' ;
    rdfs:domain ind:FreeAgencyStatus ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AthleteProfile .

ind:primaryFreeAthleteContractId rdf:type rdf:Property ;
    rdfs:label 'Primary Free Athlete Contract Id' ;
    rdfs:comment 'Reference to the athlete\'s most recently expired or expiring contract that triggered this free agency status record.' ;
    rdfs:domain ind:FreeAgencyStatus ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Contract .

ind:primaryFreeFranchiseId rdf:type rdf:Property ;
    rdfs:label 'Primary Free Franchise Id' ;
    rdfs:comment 'Reference to the team that last held the athlete\'s rights prior to free agency. Used to determine right of first refusal and tender obligations.' ;
    rdfs:domain ind:FreeAgencyStatus ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Franchise .

ind:tertiaryFreeSigningTeamFranchiseId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Free Signing Team Franchise Id' ;
    rdfs:comment 'Reference to the team that ultimately signed the athlete upon conclusion of free agency. Null until negotiation_status reaches \'signed\'. Used for transaction reporting and broadcast ticker updates.' ;
    rdfs:domain ind:FreeAgencyStatus ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Franchise .

ind:accruedSeasons rdf:type rdf:Property ;
    rdfs:label 'Accrued Seasons' ;
    rdfs:comment 'The number of CBA-qualifying seasons the athlete has accrued with the league. Determines free agency eligibility tier (e.g., UFA vs RFA vs ERFA) and vesting rights. Calculated per CBA accrued season definition.' ;
    rdfs:domain ind:FreeAgencyStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:arbitrationEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Arbitration Eligible Flag' ;
    rdfs:comment 'Indicates whether the athlete is eligible for salary arbitration in lieu of free agency, based on years of service and CBA thresholds. Particularly relevant in MLB where Super Two eligibility applies.' ;
    rdfs:domain ind:FreeAgencyStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:arbitrationFilingDeadline rdf:type rdf:Property ;
    rdfs:label 'Arbitration Filing Deadline' ;
    rdfs:comment 'The deadline by which the athlete or team must file for salary arbitration. Null when arbitration_eligible_flag is False. Governed by the applicable CBA calendar.' ;
    rdfs:domain ind:FreeAgencyStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:capHoldReleasedFlag rdf:type rdf:Property ;
    rdfs:label 'Cap Hold Released Flag' ;
    rdfs:comment 'Indicates whether the original team has formally renounced the athlete\'s rights, releasing the associated salary cap hold. Once renounced, the athlete becomes an unrestricted free agent and the team loses all rights.' ;
    rdfs:domain ind:FreeAgencyStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:compensationTier rdf:type rdf:Property ;
    rdfs:label 'Compensation Tier' ;
    rdfs:comment 'The draft pick compensation tier assigned to this free agent based on prior contract value and performance metrics. Determines the round and value of compensatory draft picks owed. None: no compensation required; Tier 1-3: graduated compensation levels; Qualifying: qualifying offer compensation applies.' ;
    rdfs:domain ind:FreeAgencyStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:draftPickCompensationFlag rdf:type rdf:Property ;
    rdfs:label 'Draft Pick Compensation Flag' ;
    rdfs:comment 'Indicates whether the signing team is required to provide draft pick compensation to the original team upon signing this athlete. Applicable in leagues with compensatory pick systems (e.g., NFL compensatory picks, MLB Type A/B free agents).' ;
    rdfs:domain ind:FreeAgencyStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:faOpenDate rdf:type rdf:Property ;
    rdfs:label 'Fa Open Date' ;
    rdfs:comment 'The calendar date on which the athlete\'s free agency period officially opens and the athlete becomes eligible to negotiate with other teams. Governed by the applicable CBA calendar.' ;
    rdfs:domain ind:FreeAgencyStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:faReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Fa Reference Number' ;
    rdfs:comment 'Externally-known business identifier for this free agency transaction, formatted as FA-{LEAGUE}-{YEAR}-{SEQUENCE}. Used in league transaction reporting, broadcast transaction tickers, and CBA compliance filings.' ;
    rdfs:domain ind:FreeAgencyStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:faType rdf:type rdf:Property ;
    rdfs:label 'Fa Type' ;
    rdfs:comment 'Classification of the athlete\'s free agency designation under the applicable CBA. Unrestricted Free Agent (UFA) may sign with any team; Restricted Free Agent (RFA) allows original team right of first refusal; Exclusive Rights Free Agent (ERFA) may only negotiate with original team; Franchise Tag and Transition Tag are one-year designations applied by the original team; Waiver indicates release via waiver wire. [ENUM-REF-CANDIDATE: unrestricted|restricted|exclusive_rights|franchise_tag|transition_tag|waiver — promote to reference product]' ;
    rdfs:domain ind:FreeAgencyStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:franchiseTagAmount rdf:type rdf:Property ;
    rdfs:label 'Franchise Tag Amount' ;
    rdfs:comment 'The one-year salary value assigned to the athlete under a franchise tag designation. Calculated as the average of the top-N salaries at the athlete\'s position or a percentage of the salary cap, per CBA formula. Expressed in USD.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:injuryReserveFlag rdf:type rdf:Property ;
    rdfs:label 'Injury Reserve Flag' ;
    rdfs:comment 'Indicates whether the athlete was on the injured reserve list at the time of contract expiration. May affect free agency timeline, qualifying offer calculations, and salary cap treatment under CBA provisions.' ;
    rdfs:domain ind:FreeAgencyStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:leagueFilingTimestamp rdf:type rdf:Property ;
    rdfs:label 'League Filing Timestamp' ;
    rdfs:comment 'The precise date and time at which the free agency transaction was officially filed with the league office. Used for compliance verification, transaction ordering, and broadcast reporting. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:FreeAgencyStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:offerSheetReceivedFlag rdf:type rdf:Property ;
    rdfs:label 'Offer Sheet Received Flag' ;
    rdfs:comment 'Indicates whether the athlete has received and signed an offer sheet from a team other than the original team. Triggers the original team\'s right of first refusal window when right_of_first_refusal_flag is True.' ;
    rdfs:domain ind:FreeAgencyStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:optOutDeadline rdf:type rdf:Property ;
    rdfs:label 'Opt Out Deadline' ;
    rdfs:comment 'The deadline by which the athlete must formally notify the team of their decision to exercise or decline their player option. Null when player_option_flag is False.' ;
    rdfs:domain ind:FreeAgencyStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:playerOptionFlag rdf:type rdf:Property ;
    rdfs:label 'Player Option Flag' ;
    rdfs:comment 'Indicates whether the athlete holds a player option on their contract for the upcoming season. If the athlete opts out, they enter free agency; if they exercise the option, they remain under contract.' ;
    rdfs:domain ind:FreeAgencyStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priorTeamOptionFlag rdf:type rdf:Property ;
    rdfs:label 'Prior Team Option Flag' ;
    rdfs:comment 'Indicates whether the original team holds a club option or team option on the athlete\'s services for the upcoming season, which if exercised would prevent free agency. Distinct from franchise and transition tag designations.' ;
    rdfs:domain ind:FreeAgencyStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:renouncementDate rdf:type rdf:Property ;
    rdfs:label 'Renouncement Date' ;
    rdfs:comment 'The date on which the original team formally renounced the athlete\'s rights, releasing the cap hold and converting the athlete to an unrestricted free agent. Null when cap_hold_released_flag is False.' ;
    rdfs:domain ind:FreeAgencyStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rightOfFirstRefusalFlag rdf:type rdf:Property ;
    rdfs:label 'Right Of First Refusal Flag' ;
    rdfs:comment 'Indicates whether the original team retains the right of first refusal to match any offer sheet signed by the athlete with another team. True for restricted free agents where the original team has tendered a qualifying offer. Governed by CBA provisions.' ;
    rdfs:domain ind:FreeAgencyStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rofrExercisedFlag rdf:type rdf:Property ;
    rdfs:label 'Rofr Exercised Flag' ;
    rdfs:comment 'Indicates whether the original team formally exercised its right of first refusal to match the offer sheet and retain the athlete. Null or False when no offer sheet was received or ROFR was waived.' ;
    rdfs:domain ind:FreeAgencyStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rofrResponseDeadline rdf:type rdf:Property ;
    rdfs:label 'Rofr Response Deadline' ;
    rdfs:comment 'The date by which the original team must exercise or waive its right of first refusal after receiving a signed offer sheet from the athlete. Null when offer_sheet_received_flag is False.' ;
    rdfs:domain ind:FreeAgencyStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:tagDesignationDeadline rdf:type rdf:Property ;
    rdfs:label 'Tag Designation Deadline' ;
    rdfs:comment 'The deadline by which the original team must formally apply a franchise tag or transition tag designation to the athlete. Applicable only when fa_type is franchise_tag or transition_tag.' ;
    rdfs:domain ind:FreeAgencyStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:tenderAmount rdf:type rdf:Property ;
    rdfs:label 'Tender Amount' ;
    rdfs:comment 'The one-year salary amount tendered by the original team for an exclusive rights or restricted free agent. Distinct from the qualifying offer amount; represents the minimum the team must offer to retain rights. Expressed in USD.' ;
    rdfs:domain ind:FreeAgencyStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tenderDeadline rdf:type rdf:Property ;
    rdfs:label 'Tender Deadline' ;
    rdfs:comment 'The date by which the original team must submit a qualifying offer or tender to retain restricted free agency rights over the athlete. Failure to tender by this date converts the athlete to an unrestricted free agent.' ;
    rdfs:domain ind:FreeAgencyStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:transitionTagAmount rdf:type rdf:Property ;
    rdfs:label 'Transition Tag Amount' ;
    rdfs:comment 'The one-year salary value assigned to the athlete under a transition tag designation. Typically lower than the franchise tag amount and calculated as the average of the top-N salaries at the athlete\'s position per CBA formula. Expressed in USD.' ;
    rdfs:domain ind:FreeAgencyStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:yearsOfService rdf:type rdf:Property ;
    rdfs:label 'Years Of Service' ;
    rdfs:comment 'Total years of professional service credited to the athlete across all teams in the league. Used alongside accrued seasons for salary arbitration eligibility and pension vesting. Expressed as a decimal (e.g., 3.17 years).' ;
    rdfs:domain ind:FreeAgencyStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:accountChangedBy rdf:type rdf:Property ;
    rdfs:label 'Account Changed By' ;
    rdfs:comment 'SAP user ID of the person who last modified this GL account master record (SKA1.AEDTM user). Required for SOX audit trail, segregation of duties compliance, and internal audit reviews. Supports detection of unauthorized changes to chart of accounts master data.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountChangedDate rdf:type rdf:Property ;
    rdfs:label 'Account Changed Date' ;
    rdfs:comment 'Date on which this GL account master record was last modified (SKA1.LAEDA). Used for change management tracking, SOX compliance, and data lineage in the Databricks Silver Layer. Triggers downstream reprocessing of dependent financial reporting datasets when account attributes change.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:accountCreatedBy rdf:type rdf:Property ;
    rdfs:label 'Account Created By' ;
    rdfs:comment 'SAP user ID of the person who created this GL account master record (SKA1.ERNAM). Required for SOX audit trail and segregation of duties (SoD) compliance. Enables identification of unauthorized account creation and supports internal audit reviews of chart of accounts governance.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountCreatedDate rdf:type rdf:Property ;
    rdfs:label 'Account Created Date' ;
    rdfs:comment 'Date on which this GL account master record was first created in the chart of accounts (SKA1.ERDAT). Used for audit trail, SOX compliance documentation, and chart of accounts change management reporting. Supports identification of accounts created outside of standard change control processes.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:accountGroupCode rdf:type rdf:Property ;
    rdfs:label 'Account Group Code' ;
    rdfs:comment 'SAP account group (SKA1.KTOKS) that controls the number range and field selection for the GL account. Groups accounts by business function, e.g., revenue accounts, expense accounts, balance sheet accounts. Determines which fields are required, optional, or suppressed during account maintenance.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountLongName rdf:type rdf:Property ;
    rdfs:label 'Account Long Name' ;
    rdfs:comment 'Extended descriptive name of the GL account (SKAT.TXT50) providing full business context. Used in detailed financial disclosures, audit documentation, and SEC reporting narratives.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountName rdf:type rdf:Property ;
    rdfs:label 'Account Name' ;
    rdfs:comment 'Short descriptive name of the GL account as maintained in SAP S/4HANA (SKAT.TXT20). Used on financial reports, trial balances, and chart of accounts listings. Examples: \'Ticket Revenue\', \'Broadcast Rights Income\', \'Player Salary Expense\', \'Naming Rights Deferred Revenue\'.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alternativeAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Alternative Account Number' ;
    rdfs:comment 'Alternative account number used for country-specific or group reporting chart of accounts mapping (SKA1.ALTKT). Enables mapping between the operational chart of accounts and a group consolidation chart of accounts or statutory reporting chart of accounts for international league entities operating under different GAAP/IFRS frameworks.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:balanceSheetAccount rdf:type rdf:Property ;
    rdfs:label 'Balance Sheet Account' ;
    rdfs:comment 'Indicates whether this GL account is a balance sheet account (True) or a profit and loss (P&L) income statement account (False) (SKA1.XBILK). Balance sheet accounts carry forward balances at year-end; P&L accounts are closed to retained earnings. Fundamental for period-end close processing and financial statement preparation.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:chartOfAccountsCode rdf:type rdf:Property ;
    rdfs:label 'Chart Of Accounts Code' ;
    rdfs:comment 'Four-character SAP chart of accounts key (SKA1.KTOPL) to which this GL account belongs. Sports Entertainment may maintain multiple charts of accounts for different legal entity frameworks (e.g., US GAAP vs IFRS for international leagues). Determines the account structure and financial statement mapping.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commitmentManagement rdf:type rdf:Property ;
    rdfs:label 'Commitment Management' ;
    rdfs:comment 'Indicates whether commitment management (purchase order commitments and funds reservations) is active for this GL account. When True, purchase orders and contracts posted against this account create budget commitments visible in FP&A reporting. Relevant for player contract commitments, venue capital expenditure, and broadcast production cost commitments.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:controllingArea rdf:type rdf:Property ;
    rdfs:label 'Controlling Area' ;
    rdfs:comment 'Four-character SAP Controlling area code to which this GL account\'s cost element is assigned (SKA1 CO integration). The controlling area defines the organizational unit within which cost and revenue accounting is performed. Enables cross-company-code cost allocation, internal order settlement, and EBITDA reporting across Sports Entertainment\'s multi-entity structure.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterRequired rdf:type rdf:Property ;
    rdfs:label 'Cost Center Required' ;
    rdfs:comment 'Indicates whether a cost center assignment is mandatory when posting to this GL account. When True, all journal entries must include a valid cost center (e.g., venue operations cost center, broadcast production cost center, athlete management cost center). Enforces cost allocation discipline for EBITDA reporting and FP&A variance analysis.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:costElementCategory rdf:type rdf:Property ;
    rdfs:label 'Cost Element Category' ;
    rdfs:comment 'Defines the cost element category in SAP Controlling (CO) module when this GL account is also a primary cost element (SKA1.KATYP). \'primary\' cost elements correspond directly to P&L GL accounts (e.g., player salary expense, venue operating cost, broadcast production cost); \'secondary\' cost elements are used for internal allocations and settlements between cost centers; \'none\' for balance sheet accounts not used in CO. Critical for EBITDA reporting and cost center allocation in FP&A.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deletionFlag rdf:type rdf:Property ;
    rdfs:label 'Deletion Flag' ;
    rdfs:comment 'Indicates whether this GL account has been flagged for deletion from the chart of accounts (SKA1.XLOEV). Accounts flagged for deletion cannot receive new postings and are scheduled for archival after all dependent records are cleared. Supports chart of accounts rationalization and SOX control compliance.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fieldStatusGroup rdf:type rdf:Property ;
    rdfs:label 'Field Status Group' ;
    rdfs:comment 'SAP field status group code assigned to the GL account that controls which fields are required, optional, or suppressed during document entry (SKB1.FSTAG). Ensures data completeness for postings — for example, cost center is required on expense accounts, profit center on revenue accounts, and business area on intercompany settlement accounts.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialStatementItem rdf:type rdf:Property ;
    rdfs:label 'Financial Statement Item' ;
    rdfs:comment 'The financial statement version item code to which this GL account is assigned for external reporting (SKA1.BILKT). Maps the account to a specific line on the income statement, balance sheet, or cash flow statement as required for SEC 10-K/10-Q filings and EBITDA reporting.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:functionalArea rdf:type rdf:Property ;
    rdfs:label 'Functional Area' ;
    rdfs:comment 'Business functional area to which this GL account is assigned for segment and functional reporting (SKA1.FUNC_AREA). Enables profit and loss reporting by business function such as event operations, broadcast, athlete management, venue operations, merchandise, sponsorship, and corporate. Supports SEC segment reporting requirements under GAAP ASC 280.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:houseBankAccount rdf:type rdf:Property ;
    rdfs:label 'House Bank Account' ;
    rdfs:comment 'Indicates whether this GL account is a house bank account used for cash management and bank reconciliation (SKB1.XINTB). When True, the account is linked to a physical bank account for automated bank statement processing, cash pooling, and treasury operations. Relevant for Sports Entertainment\'s multi-entity cash management across leagues and venues.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:intercompanyAccount rdf:type rdf:Property ;
    rdfs:label 'Intercompany Account' ;
    rdfs:comment 'Indicates whether this GL account is designated for intercompany transactions between Sports Entertainment legal entities (e.g., between the league holding company, individual team entities, broadcast subsidiaries, and venue operating companies). When True, intercompany partner must be specified on postings for automated elimination in consolidated financial statements. Required for SOX-compliant intercompany reconciliation.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:interestCalculation rdf:type rdf:Property ;
    rdfs:label 'Interest Calculation' ;
    rdfs:comment 'Indicates whether automatic interest calculation is activated for this GL account (SKB1.XINTB for interest indicator). Relevant for intercompany loan accounts, deferred revenue accounts (naming rights, multi-year broadcast deals), and overdue receivable accounts where interest accrual is contractually required.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lineItemDisplay rdf:type rdf:Property ;
    rdfs:label 'Line Item Display' ;
    rdfs:comment 'Indicates whether individual line items are stored and displayable for this GL account (SKB1.XKRES). When True, each posting line is retained for drill-down reporting and audit trail purposes. Required for SOX-compliant audit trails on revenue accounts (ticket revenue, broadcast rights income, sponsorship fees) and significant expense accounts (player salaries, venue operating costs).' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:openItemManagement rdf:type rdf:Property ;
    rdfs:label 'Open Item Management' ;
    rdfs:comment 'Indicates whether open item management is activated for this GL account (SKB1.XOPVW). When True, individual line items remain open until explicitly cleared against an offsetting entry (e.g., deferred revenue accounts for naming rights, advance ticket deposits, broadcast rights prepayments). Enables aging analysis and outstanding item tracking for FP&A.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:planningLevel rdf:type rdf:Property ;
    rdfs:label 'Planning Level' ;
    rdfs:comment 'Planning level code that controls how this GL account participates in financial planning and budgeting processes in SAP CO and Workday Adaptive Planning integration. Determines the granularity at which budget vs. actual variance analysis is performed — account level, cost center level, or profit center level. Supports FP&A EBITDA budgeting and ARR tracking.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postingBlock rdf:type rdf:Property ;
    rdfs:label 'Posting Block' ;
    rdfs:comment 'Flag indicating whether postings to this GL account are currently blocked at the chart of accounts level (SKA1.XSPEA). When True, no journal entries can be posted to this account regardless of company code settings. Used during account restructuring, period-end close, or SOX control enforcement.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:profitCenterRequired rdf:type rdf:Property ;
    rdfs:label 'Profit Center Required' ;
    rdfs:comment 'Indicates whether a profit center assignment is mandatory when posting to this GL account. When True, all postings must include a valid profit center enabling segment-level profitability reporting (e.g., by league, by venue, by broadcast network). Supports SEC segment reporting under GAAP ASC 280 and internal EBITDA reporting by business unit.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reconciliationAccountType rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Account Type' ;
    rdfs:comment 'Indicates whether this GL account serves as a reconciliation account for a subledger and, if so, which subledger type (SKA1.MITKZ). \'customer\' reconciliation accounts aggregate accounts receivable subledger balances (e.g., fan ticket receivables, sponsor invoices); \'vendor\' for accounts payable (e.g., venue contractor payables); \'asset\' for fixed asset subledger (e.g., stadium infrastructure); \'none\' for non-reconciliation accounts. Direct postings to reconciliation accounts are blocked.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueRecognitionCategory rdf:type rdf:Property ;
    rdfs:label 'Revenue Recognition Category' ;
    rdfs:comment 'Classification of the revenue recognition pattern applicable to this GL account under GAAP ASC 606 / IFRS 15. \'point_in_time\' for single-event revenues (e.g., individual ticket sales, PPV events, merchandise sales); \'over_time\' for performance obligations satisfied over a period (e.g., season ticket packages, multi-year broadcast rights, naming rights); \'deferred\' for advance payments not yet earned (e.g., prepaid sponsorship fees, advance broadcast rights payments); \'not_applicable\' for non-revenue accounts. Critical for SEC revenue disclosure and audit compliance.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sortKey rdf:type rdf:Property ;
    rdfs:label 'Sort Key' ;
    rdfs:comment 'Three-digit sort key code that determines the assignment field populated in the allocation field of line items posted to this account (SKB1.ZUAWA). Controls how line items are sorted and grouped in account displays and reports. Common sort keys include posting date, document number, and external document reference for reconciliation purposes.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sportsRevenueStream rdf:type rdf:Property ;
    rdfs:label 'Sports Revenue Stream' ;
    rdfs:comment 'Sports Entertainment-specific revenue stream classification for this GL account, enabling industry-specific financial analytics and KPI reporting. Examples: \'ticket_revenue\', \'broadcast_rights_income\', \'naming_rights_revenue\', \'sponsorship_fees\', \'merchandise_licensing\', \'ppv_revenue\', \'concession_revenue\', \'player_transfer_fee\', \'nil_licensing_income\', \'venue_rental\'. Used for EBITDA decomposition, ARR tracking, and league financial reporting. [ENUM-REF-CANDIDATE: ticket_revenue|broadcast_rights_income|naming_rights_revenue|sponsorship_fees|merchandise_licensing|ppv_revenue|concession_revenue|player_transfer_fee|nil_licensing_income|venue_rental — promote to reference product]' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxCategory rdf:type rdf:Property ;
    rdfs:label 'Tax Category' ;
    rdfs:comment 'Tax category assigned to the GL account controlling tax code entry behavior during posting (SKB1.MWSKZ). Determines whether tax codes are required, optional, or not allowed on journal entries to this account. Relevant for VAT/GST on international broadcast rights, ticket sales tax, merchandise sales tax, and venue concession tax compliance.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxRelevant rdf:type rdf:Property ;
    rdfs:label 'Tax Relevant' ;
    rdfs:comment 'Indicates whether this GL account is subject to tax reporting and requires a tax code on postings (SKB1.XMWNO negated). When True, postings must include a valid tax code for VAT, sales tax, or withholding tax compliance. Critical for international broadcast rights distribution, PPV revenue, and merchandise sales across jurisdictions.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:toleranceGroup rdf:type rdf:Property ;
    rdfs:label 'Tolerance Group' ;
    rdfs:comment 'Tolerance group code assigned to the GL account that defines acceptable variance thresholds for payment differences, rounding, and clearing (SKB1.ZUAWA tolerance reference). Controls automatic clearing of small differences on high-volume accounts such as ticket revenue clearing, merchandise POS settlement, and concession cash accounts. Supports SOX-compliant payment processing controls.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validFromDate rdf:type rdf:Property ;
    rdfs:label 'Valid From Date' ;
    rdfs:comment 'Date from which this GL account is valid and available for posting. Supports time-dependent account activation for new business lines (e.g., a new OTT streaming revenue account activated at the start of a new broadcast deal, or a new NIL licensing income account activated upon regulatory approval). Enables historical accuracy in financial reporting.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:validToDate rdf:type rdf:Property ;
    rdfs:label 'Valid To Date' ;
    rdfs:comment 'Date until which this GL account is valid for posting. Null indicates the account has no planned expiry. Used to retire accounts associated with discontinued business lines (e.g., a closed venue, an expired broadcast rights agreement, a divested team entity) while preserving historical posting data for audit and SEC reporting.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:activityTypeCode rdf:type rdf:Property ;
    rdfs:label 'Activity Type Code' ;
    rdfs:comment 'Primary SAP CO activity type associated with this cost center, representing the unit of output or service provided (e.g., \'BROADCAST_HR\' for broadcast production hours, \'VENUE_DAY\' for venue operating days). Used for activity-based cost allocation and internal service pricing.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationMethod rdf:type rdf:Property ;
    rdfs:label 'Allocation Method' ;
    rdfs:comment 'Method used to allocate or settle costs from this cost center to other cost objects at period end: direct (direct activity allocation), assessment (using assessment cycles), distribution (using distribution cycles), activity_based (ABC costing), or statistical (for reporting only, no actual settlement).' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetAmount rdf:type rdf:Property ;
    rdfs:label 'Budget Amount' ;
    rdfs:comment 'Total approved annual budget allocated to this cost center for the current fiscal year, expressed in the cost center\'s primary currency. Sourced from Workday Adaptive Planning and loaded into SAP CO for variance reporting. Used in EBITDA forecasting and FP&A dashboards.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:businessDomain rdf:type rdf:Property ;
    rdfs:label 'Business Domain' ;
    rdfs:comment 'Sports Entertainment business domain that this cost center primarily supports. Enables cross-domain EBITDA analysis and cost attribution across the enterprise (e.g., \'venue\' for arena operations, \'broadcast\' for OTT/RSN production costs). [ENUM-REF-CANDIDATE: venue|broadcast|athlete|league|sponsorship|merchandise|ticketing|fan_engagement|content|finance|workforce|compliance|digital_platform — promote to reference product]' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessUnit rdf:type rdf:Property ;
    rdfs:label 'Business Unit' ;
    rdfs:comment 'Sports Entertainment business unit or division that owns this cost center (e.g., \'NFL Operations\', \'OTT Streaming\', \'Venue Management\', \'Athlete Performance\'). Used for segment-level EBITDA reporting and ARR tracking.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controllingAreaCode rdf:type rdf:Property ;
    rdfs:label 'Controlling Area Code' ;
    rdfs:comment 'SAP CO controlling area to which this cost center belongs. The controlling area defines the organizational unit within which cost accounting is performed and cross-company cost allocations are managed (e.g., \'SE01\' for Sports Entertainment North America).' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterCategory rdf:type rdf:Property ;
    rdfs:label 'Cost Center Category' ;
    rdfs:comment 'Single-character or two-character SAP CO cost center category code that controls which activity types and statistical key figures can be posted (e.g., \'A\' = general, \'B\' = production, \'F\' = financial). Determines default allocation rules and reporting groupings.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterDescription rdf:type rdf:Property ;
    rdfs:label 'Cost Center Description' ;
    rdfs:comment 'Free-text description of the cost center\'s business purpose, scope of operations, and cost accountability. Provides context for financial analysts, auditors, and FP&A teams beyond what the name and code convey (e.g., \'Responsible for all operational costs of the home venue including HVAC, BMS, security, and event-day staffing\').' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterName rdf:type rdf:Property ;
    rdfs:label 'Cost Center Name' ;
    rdfs:comment 'Full descriptive name of the cost center as maintained in SAP CO master data (e.g., \'Venue Operations — Staples Center\', \'Broadcast Production — NFL Sunday Package\'). Used in financial reports, budget dashboards, and FP&A outputs.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterStatus rdf:type rdf:Property ;
    rdfs:label 'Cost Center Status' ;
    rdfs:comment 'Current lifecycle status of the cost center in SAP CO: active (accepting postings), inactive (temporarily suspended), locked (blocked for all postings), pending_activation (created but not yet effective), or archived (historical, no postings allowed). Drives period-end close controls and SOX compliance checks.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterType rdf:type rdf:Property ;
    rdfs:label 'Cost Center Type' ;
    rdfs:comment 'SAP CO cost center category classifying the nature of cost incurrence: overhead (administrative/support), production (direct event/broadcast output), service (shared services), profit (revenue-generating unit tracked as cost center), or investment (capital project support). Drives allocation methodology and EBITDA reporting treatment.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costElementGroup rdf:type rdf:Property ;
    rdfs:label 'Cost Element Group' ;
    rdfs:comment 'SAP CO cost element group defining the set of primary cost elements (GL accounts) that can be posted to this cost center. Controls which expense categories are tracked here (e.g., \'VENUE_OPEX\' for venue operating expenses, \'TALENT_COSTS\' for athlete/performer costs).' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countryCode rdf:type rdf:Property ;
    rdfs:label 'Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the primary country where this cost center operates. Used for statutory reporting, VAT/tax jurisdiction assignment, and GDPR/CCPA data residency compliance.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:departmentCode rdf:type rdf:Property ;
    rdfs:label 'Department Code' ;
    rdfs:comment 'Organizational department code associated with this cost center, aligned to the SAP SuccessFactors organizational hierarchy. Enables workforce cost attribution and headcount-to-cost analysis across Sports Entertainment business units.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fiscalYear rdf:type rdf:Property ;
    rdfs:label 'Fiscal Year' ;
    rdfs:comment 'Fiscal year to which the budget amount and planning data for this cost center applies (e.g., 2024, 2025). Aligns with the Sports Entertainment fiscal calendar defined in SAP FI company code settings.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:functionalAreaCode rdf:type rdf:Property ;
    rdfs:label 'Functional Area Code' ;
    rdfs:comment 'SAP FI/CO functional area classifying the cost center by business function for cost-of-sales accounting and segment reporting (e.g., \'ADMIN\', \'SALES\', \'PROD\', \'R&D\'). Required for SEC income statement presentation under US GAAP.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicRegion rdf:type rdf:Property ;
    rdfs:label 'Geographic Region' ;
    rdfs:comment 'Geographic region or market where this cost center primarily operates (e.g., \'North America\', \'EMEA\', \'APAC\'). Supports regional cost allocation, transfer pricing compliance, and multi-market EBITDA reporting.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:glAccountGroup rdf:type rdf:Property ;
    rdfs:label 'Gl Account Group' ;
    rdfs:comment 'SAP FI GL account group associated with this cost center, defining the range of general ledger accounts used for cost postings. Ensures chart-of-accounts alignment and supports automated financial statement mapping for SEC reporting.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:intercompanyFlag rdf:type rdf:Property ;
    rdfs:label 'Intercompany Flag' ;
    rdfs:comment 'Indicates whether this cost center participates in intercompany cost settlements between Sports Entertainment legal entities (True = intercompany). Triggers intercompany elimination entries in consolidated financial statements and SEC reporting.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:planLock rdf:type rdf:Property ;
    rdfs:label 'Plan Lock' ;
    rdfs:comment 'Indicates whether budget/plan postings to this cost center are currently blocked (True = locked). Prevents changes to approved budgets after the planning cycle is closed in Workday Adaptive Planning and SAP CO.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:postingLock rdf:type rdf:Property ;
    rdfs:label 'Posting Lock' ;
    rdfs:comment 'Indicates whether actual cost postings to this cost center are currently blocked (True = locked, no postings allowed). Used during period-end close, organizational restructuring, or SOX audit freeze periods to prevent unauthorized cost entries.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sapChangedBy rdf:type rdf:Property ;
    rdfs:label 'Sap Changed By' ;
    rdfs:comment 'SAP user ID of the person who last modified this cost center master record. Required for SOX change management controls and audit trail. Stored as the SAP logon ID.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapCreatedBy rdf:type rdf:Property ;
    rdfs:label 'Sap Created By' ;
    rdfs:comment 'SAP user ID of the person who created this cost center master record in SAP CO. Required for SOX segregation-of-duties controls and audit trail documentation. Stored as the SAP logon ID (not personal name).' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentCode rdf:type rdf:Property ;
    rdfs:label 'Segment Code' ;
    rdfs:comment 'SEC/IFRS 8 reportable segment to which this cost center belongs for external financial disclosure (e.g., \'LIVE_EVENTS\', \'MEDIA_RIGHTS\', \'MERCHANDISE\'). Drives segment footnote disclosures in SEC Form 10-K and quarterly 10-Q filings.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:soxRelevant rdf:type rdf:Property ;
    rdfs:label 'Sox Relevant' ;
    rdfs:comment 'Indicates whether this cost center is in scope for Sarbanes-Oxley (SOX) internal control testing and audit (True = SOX relevant). SOX-relevant cost centers require documented controls, segregation of duties, and periodic management certification per SOX Sections 302 and 404.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:validFrom rdf:type rdf:Property ;
    rdfs:label 'Valid From' ;
    rdfs:comment 'Date from which this cost center is active and eligible to receive cost postings in SAP CO. Defines the start of the cost center\'s validity period for budget planning, actual cost collection, and period-end closing.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validTo rdf:type rdf:Property ;
    rdfs:label 'Valid To' ;
    rdfs:comment 'Date until which this cost center is active and eligible to receive cost postings. After this date, the cost center is locked for new postings. Null indicates an open-ended validity period. Used for fiscal year planning and organizational restructuring.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:annualCapexBudget rdf:type rdf:Property ;
    rdfs:label 'Annual Capex Budget' ;
    rdfs:comment 'Approved annual capital expenditure budget for this profit center in local currency. Relevant for venue operations and broadcast infrastructure profit centers. Used in FP&A and SEC capital allocation disclosures.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:annualOpexBudget rdf:type rdf:Property ;
    rdfs:label 'Annual Opex Budget' ;
    rdfs:comment 'Approved annual operating expenditure budget for this profit center in local currency, as set in Workday Adaptive Planning. Includes direct costs and allocated overhead. Used for EBITDA margin planning and cost control.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:annualRevenueBudget rdf:type rdf:Property ;
    rdfs:label 'Annual Revenue Budget' ;
    rdfs:comment 'Approved annual revenue budget for this profit center in the profit center\'s local currency, as set in Workday Adaptive Planning FP&A. Used for budget vs. actual variance analysis and EBITDA forecasting.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:arrTrackingFlag rdf:type rdf:Property ;
    rdfs:label 'Arr Tracking Flag' ;
    rdfs:comment 'Indicates whether this profit center tracks Annual Recurring Revenue (ARR) as a primary financial metric. Applicable to OTT streaming, digital subscription, and DTC platform profit centers where ARR is a key investor KPI.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:broadcastRightsType rdf:type rdf:Property ;
    rdfs:label 'Broadcast Rights Type' ;
    rdfs:comment 'Classification of broadcast rights revenue stream associated with this profit center where applicable. Drives revenue recognition treatment under ASC 606 for media rights deals. Values: RSN (Regional Sports Network), national_tv, OTT (Over-The-Top Streaming), PPV (Pay-Per-View), international, radio, none. [ENUM-REF-CANDIDATE: rsn|national_tv|ott|ppv|international|radio|none — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessUnitType rdf:type rdf:Property ;
    rdfs:label 'Business Unit Type' ;
    rdfs:comment 'Classification of the revenue-generating business unit represented by this profit center within Sports Entertainment\'s portfolio. Drives EBITDA reporting structure and profitability analysis by segment. [ENUM-REF-CANDIDATE: league_franchise|venue|ott_platform|broadcast_network|merchandise_line|athlete_management|concert_series|sponsorship_unit|corporate — promote to reference product]' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eliminationFlag rdf:type rdf:Property ;
    rdfs:label 'Elimination Flag' ;
    rdfs:comment 'Indicates whether postings to this profit center are subject to elimination during group financial consolidation. Prevents double-counting of intercompany revenues and costs in consolidated EBITDA and SEC financial statements.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fiscalYearVariant rdf:type rdf:Property ;
    rdfs:label 'Fiscal Year Variant' ;
    rdfs:comment 'SAP fiscal year variant code defining the fiscal calendar applicable to this profit center (e.g., \'K4\' for calendar year, \'V3\' for April–March). Critical for period-end EBITDA and ARR reporting alignment. Maps to SAP field PERIV.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hierarchyNodeCode rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Node Code' ;
    rdfs:comment 'Code of the profit center group/node in the standard hierarchy (SAP EC-PCA hierarchy) to which this profit center belongs. Enables roll-up reporting from individual profit centers to business segments and enterprise level. Maps to SAP field KHINR.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manager rdf:type rdf:Property ;
    rdfs:label 'Manager' ;
    rdfs:comment 'Name or employee ID of the person responsible for the profit center\'s financial performance and budget accountability. Used for management reporting, variance analysis, and SOX control ownership. Maps to SAP field VERAK.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nilRevenueEligible rdf:type rdf:Property ;
    rdfs:label 'Nil Revenue Eligible' ;
    rdfs:comment 'Indicates whether this profit center is eligible to record NIL (Name, Image, and Likeness) revenue streams from athlete endorsement and licensing arrangements. Relevant for athlete management and league franchise profit centers under NCAA and professional league NIL rules.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:profitCenterDescription rdf:type rdf:Property ;
    rdfs:label 'Profit Center Description' ;
    rdfs:comment 'Long-form business description of the profit center\'s purpose, scope, and the revenue-generating activities it encompasses. Provides context for financial analysts, auditors, and FP&A teams. Maps to SAP field LTEXT.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profitCenterName rdf:type rdf:Property ;
    rdfs:label 'Profit Center Name' ;
    rdfs:comment 'Full descriptive name of the profit center as defined in SAP CO master data (e.g., \'Los Angeles Lakers Franchise\', \'OTT Streaming Platform - North America\', \'Madison Square Garden Venue Operations\'). Maps to SAP field KTEXT.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profitCenterStatus rdf:type rdf:Property ;
    rdfs:label 'Profit Center Status' ;
    rdfs:comment 'Current lifecycle status of the profit center in SAP CO. \'active\' = postings allowed; \'locked\' = postings blocked (e.g., during restructuring); \'inactive\' = not yet activated; \'archived\' = historical record retained for audit. Maps to SAP field LOCK_IND and activation status.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regionCode rdf:type rdf:Property ;
    rdfs:label 'Region Code' ;
    rdfs:comment 'Geographic region code for this profit center used in regional EBITDA roll-up and management reporting (e.g., \'NA-EAST\', \'NA-WEST\', \'EMEA\', \'APAC\'). Supports multi-regional financial analysis for global sports entertainment operations.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:soxControlOwner rdf:type rdf:Property ;
    rdfs:label 'Sox Control Owner' ;
    rdfs:comment 'Name or employee ID of the designated SOX internal control owner responsible for financial reporting controls associated with this profit center. Required for SOX Section 302/404 compliance documentation and audit evidence.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:soxRiskRating rdf:type rdf:Property ;
    rdfs:label 'Sox Risk Rating' ;
    rdfs:comment 'SOX financial reporting risk rating assigned to this profit center based on materiality, transaction volume, and complexity. Determines the frequency and depth of internal control testing required by the external auditor.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetEbitdaMarginPct rdf:type rdf:Property ;
    rdfs:label 'Target Ebitda Margin Pct' ;
    rdfs:comment 'Planned EBITDA margin percentage for this profit center as a target set during annual budgeting in Workday Adaptive Planning. Expressed as a percentage of revenue. Used as the primary KPI for profitability performance management.' ;
    rdfs:domain ind:ProfitCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:accountingStandard rdf:type rdf:Property ;
    rdfs:label 'Accounting Standard' ;
    rdfs:comment 'The accounting standard framework applied to the financial statements of this company code. US_GAAP for SEC-registered US entities, IFRS for international subsidiaries, LOCAL_GAAP for statutory reporting in specific jurisdictions.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessArea rdf:type rdf:Property ;
    rdfs:label 'Business Area' ;
    rdfs:comment 'SAP S/4HANA business area code assigned to this company code for cross-company-code segment reporting. Represents a distinct business segment such as League Operations, Broadcast, Venue Management, or Merchandise. Supports EBITDA reporting by business segment per SEC ASC 280.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chartOfAccounts rdf:type rdf:Property ;
    rdfs:label 'Chart Of Accounts' ;
    rdfs:comment 'Four-character SAP S/4HANA chart of accounts key assigned to this company code (e.g., \'SPRT\'). Defines the general ledger account structure, account groups, and account number ranges used for all financial postings. Required for SOX-compliant financial controls and SEC reporting.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:city rdf:type rdf:Property ;
    rdfs:label 'City' ;
    rdfs:comment 'City of the registered office or principal place of business. Used in conjunction with street address for regulatory filings and legal correspondence.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:companyCodeCode rdf:type rdf:Property ;
    rdfs:label 'Company Code Code' ;
    rdfs:comment 'The four-character alphanumeric SAP S/4HANA company code that uniquely identifies the legal entity within the enterprise organizational structure. Aligns with the SAP FI company code field (BUKRS). Used in all intercompany postings, chart of accounts assignments, and SEC financial reporting.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:companyCodeStatus rdf:type rdf:Property ;
    rdfs:label 'Company Code Status' ;
    rdfs:comment 'Current lifecycle status of the company code within the SAP S/4HANA organizational structure. Controls whether new financial postings, purchase orders, and sales documents can be created against this entity. \'in_liquidation\' triggers SOX disclosure requirements.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consolidationUnit rdf:type rdf:Property ;
    rdfs:label 'Consolidation Unit' ;
    rdfs:comment 'The consolidation unit identifier in SAP S/4HANA Group Reporting that maps this company code to the group consolidation structure. Used for automated intercompany elimination, minority interest calculation, and SEC consolidated financial statement preparation.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditControlArea rdf:type rdf:Property ;
    rdfs:label 'Credit Control Area' ;
    rdfs:comment 'SAP S/4HANA credit control area assigned to this company code, governing credit limit management for sponsorship deals, broadcast rights receivables, and merchandise licensing. Controls credit exposure across the SD (Sales and Distribution) module.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentNumberRange rdf:type rdf:Property ;
    rdfs:label 'Document Number Range' ;
    rdfs:comment 'SAP S/4HANA document number range interval assigned to this company code for financial document numbering. Ensures sequential, gap-free document numbering required for SOX audit trails and SEC financial reporting integrity.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fieldStatusVariant rdf:type rdf:Property ;
    rdfs:label 'Field Status Variant' ;
    rdfs:comment 'SAP S/4HANA field status variant assigned to this company code, controlling which fields are required, optional, or suppressed during financial document entry. Enforces data quality standards for SOX-compliant financial postings.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:functionalCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Functional Currency Code' ;
    rdfs:comment 'ISO 4217 functional currency code as defined under IFRS IAS 21 or US GAAP ASC 830, representing the currency of the primary economic environment in which the entity operates. May differ from local currency for entities with predominantly USD-denominated broadcast rights or sponsorship revenues.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:groupCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Group Currency Code' ;
    rdfs:comment 'ISO 4217 currency code for the group (parent) reporting currency used in consolidated financial statements (e.g., \'USD\' for the Sports Entertainment parent). All company code financials are translated to this currency for SEC consolidated reporting and EBITDA roll-up.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hardCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Hard Currency Code' ;
    rdfs:comment 'ISO 4217 currency code for the hard currency (index currency) used in high-inflation countries per SAP S/4HANA parallel valuation. Applicable for Sports Entertainment entities operating in hyperinflationary economies per IFRS IAS 29.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incorporationDate rdf:type rdf:Property ;
    rdfs:label 'Incorporation Date' ;
    rdfs:comment 'The date on which the legal entity was formally incorporated or registered with the relevant government authority. Used in SEC filings, SOX attestations, and legal entity lifecycle management.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:intercompanyClearingAccount rdf:type rdf:Property ;
    rdfs:label 'Intercompany Clearing Account' ;
    rdfs:comment 'General ledger account number used for intercompany clearing transactions between Sports Entertainment subsidiaries (e.g., broadcast rights fees from broadcast network entity to league operating company). Critical for SOX-compliant intercompany elimination in consolidated SEC reporting.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:languageKey rdf:type rdf:Property ;
    rdfs:label 'Language Key' ;
    rdfs:comment 'ISO 639-1 two-letter language code representing the primary business language for this company code in SAP S/4HANA (e.g., \'EN\', \'DE\', \'FR\'). Governs the language used for financial documents, correspondence, and system output for this entity.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalEntityIdentifier rdf:type rdf:Property ;
    rdfs:label 'Legal Entity Identifier' ;
    rdfs:comment '20-character ISO 17442 Legal Entity Identifier (LEI) assigned by a Local Operating Unit (LOU) for publicly traded or regulated Sports Entertainment entities. Required for SEC financial reporting, derivatives reporting under Dodd-Frank, and international regulatory filings.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minorityInterestPct rdf:type rdf:Property ;
    rdfs:label 'Minority Interest Pct' ;
    rdfs:comment 'Percentage of the legal entity\'s equity not owned by the Sports Entertainment parent, representing non-controlling interest. Used in SEC consolidated financial statements for minority interest disclosure and EBITDA attribution. Range 0.00 to 100.00.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:parentCompanyCode rdf:type rdf:Property ;
    rdfs:label 'Parent Company Code' ;
    rdfs:comment 'The SAP S/4HANA company code of the immediate parent entity in the legal entity hierarchy. Enables hierarchical traversal of the Sports Entertainment corporate structure for intercompany settlement, consolidation, and segment reporting. Null for the ultimate parent holding company.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postalCode rdf:type rdf:Property ;
    rdfs:label 'Postal Code' ;
    rdfs:comment 'Postal or ZIP code of the registered office address. Used for tax jurisdiction determination, regulatory filings, and ADA venue accessibility compliance mapping.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postingPeriodVariant rdf:type rdf:Property ;
    rdfs:label 'Posting Period Variant' ;
    rdfs:comment 'SAP S/4HANA posting period variant assigned to this company code, controlling which fiscal periods are open or closed for financial postings. Enforces period-end close discipline and SOX-compliant financial controls by preventing backdated entries.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profitCenterStandardHierarchy rdf:type rdf:Property ;
    rdfs:label 'Profit Center Standard Hierarchy' ;
    rdfs:comment 'Name of the SAP S/4HANA profit center standard hierarchy node to which this company code\'s profit centers are assigned. Enables segment-level EBITDA reporting and management accounting roll-ups across league, broadcast, venue, and merchandise business units.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:secReportingEntity rdf:type rdf:Property ;
    rdfs:label 'Sec Reporting Entity' ;
    rdfs:comment 'Indicates whether this company code is a registrant or consolidated subsidiary required to be included in SEC financial filings (10-K, 10-Q, 8-K). Drives inclusion in the consolidation perimeter for group financial reporting.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:streetAddress rdf:type rdf:Property ;
    rdfs:label 'Street Address' ;
    rdfs:comment 'Street address of the registered office or principal place of business for the legal entity. Used in SEC filings, regulatory correspondence, and legal notices. Classified as confidential organizational contact data.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxRegistrationNumber rdf:type rdf:Property ;
    rdfs:label 'Tax Registration Number' ;
    rdfs:comment 'Government-issued tax identification number for the legal entity (e.g., US Employer Identification Number (EIN), EU VAT registration number). Required for tax filings, vendor invoicing, and regulatory reporting. Stored as confidential business data.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vatRegistrationNumber rdf:type rdf:Property ;
    rdfs:label 'Vat Registration Number' ;
    rdfs:comment 'Value Added Tax (VAT) registration number for entities operating in VAT-applicable jurisdictions (EU, UK, etc.). Used on broadcast rights invoices, sponsorship agreements, and merchandise licensing contracts. Distinct from the domestic tax registration number.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:journalEntryId rdf:type rdf:Property ;
    rdfs:label 'Journal Entry Id' ;
    rdfs:comment 'Unique surrogate identifier for each journal entry record in the Silver Layer lakehouse. Primary key for this data product. Role: TRANSACTION_HEADER.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:JournalEntry .

ind:documentDate rdf:type rdf:Property ;
    rdfs:label 'Document Date' ;
    rdfs:comment 'The date of the originating source document (e.g., invoice date, payment date, contract date) that triggered this journal entry. May differ from posting date when documents are processed with a lag. Corresponds to BKPF.BLDAT.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:documentNumber rdf:type rdf:Property ;
    rdfs:label 'Document Number' ;
    rdfs:comment 'SAP-assigned ten-digit accounting document number uniquely identifying the journal entry within a company code and fiscal year. This is the externally-known business identifier used in audit trails, reconciliations, and cross-system references. Corresponds to BKPF.BELNR.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentType rdf:type rdf:Property ;
    rdfs:label 'Document Type' ;
    rdfs:comment 'Two-character SAP document type code classifying the nature of the journal entry (e.g., SA=GL posting, KR=vendor invoice, DZ=customer payment, AB=accrual, IC=intercompany, AA=asset posting, ZP=payment run). Drives number range assignment and account type restrictions. [ENUM-REF-CANDIDATE: SA|KR|DZ|AB|IC|AA|ZP|RE|KZ|DR — promote to reference product]' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Entry Timestamp' ;
    rdfs:comment 'System timestamp recording when this journal entry record was first created in SAP FI. Serves as the RECORD_AUDIT_CREATED field for audit trail and SOX compliance. Corresponds to BKPF.CPUDT + BKPF.CPUTM.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:groupCurrencyAmount rdf:type rdf:Property ;
    rdfs:label 'Group Currency Amount' ;
    rdfs:comment 'Total amount of the journal entry translated into the group (consolidation) currency (typically USD for Sports Entertainment). Used for consolidated EBITDA reporting, SEC filings, and group-level financial analysis. Corresponds to the aggregate of BSEG.KZBTR.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:headerText rdf:type rdf:Property ;
    rdfs:label 'Header Text' ;
    rdfs:comment 'Free-text description at the journal entry header level providing business context for the posting (e.g., \'Q3 Ticket Revenue Accrual — NFL Season\', \'Broadcast Rights Amortization — RSN Deal\', \'Intercompany Settlement — Venue Ops\'). Corresponds to BKPF.BKTXT.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:intercompanyIndicator rdf:type rdf:Property ;
    rdfs:label 'Intercompany Indicator' ;
    rdfs:comment 'Flag indicating whether this journal entry represents an intercompany transaction between two legal entities within the Sports Entertainment group (True) or an external third-party transaction (False). Critical for consolidation elimination and intercompany reconciliation.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:internalOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Internal Order Number' ;
    rdfs:comment 'SAP CO internal order number used to track costs and revenues for specific projects or events (e.g., a specific concert tour, stadium renovation project, or broadcast production). Enables project-level P&L and budget vs. actual analysis. Corresponds to BSEG.AUFNR.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastChangedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Changed Timestamp' ;
    rdfs:comment 'System timestamp of the most recent modification to this journal entry record. Serves as the RECORD_AUDIT_UPDATED field for change tracking and SOX audit trail. Corresponds to BKPF.AEDAT.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lineItemCount rdf:type rdf:Property ;
    rdfs:label 'Line Item Count' ;
    rdfs:comment 'Total number of accounting line items (debit and credit rows) embedded within this journal entry document. A balanced double-entry posting requires a minimum of two line items. Supports validation of entry completeness and complexity classification.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:localCurrencyAmount rdf:type rdf:Property ;
    rdfs:label 'Local Currency Amount' ;
    rdfs:comment 'Total amount of the journal entry translated into the company code local (functional) currency. Used for statutory financial reporting, balance sheet, and P&L in local GAAP. Part of the MONETARY_TRIPLET. Corresponds to the aggregate of BSEG.DMBTR.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:localCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Local Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter code for the company code local currency (functional currency) used for statutory reporting. Distinct from transaction currency when cross-currency postings occur. Corresponds to BKPF.HWAER.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postingDate rdf:type rdf:Property ;
    rdfs:label 'Posting Date' ;
    rdfs:comment 'The date on which the journal entry is posted to the general ledger and affects account balances. Determines the fiscal period assignment. Distinct from document date and entry date. Corresponds to BKPF.BUDAT. This is the principal business event date (BUSINESS_EVENT_TIMESTAMP category).' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:postingKey rdf:type rdf:Property ;
    rdfs:label 'Posting Key' ;
    rdfs:comment 'SAP two-digit posting key controlling the debit/credit indicator and account type for the primary line item of this journal entry (e.g., \'40\'=GL debit, \'50\'=GL credit, \'01\'=customer debit, \'31\'=vendor credit). Determines how the entry affects account balances. Corresponds to BSEG.BSCHL.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postingStatus rdf:type rdf:Property ;
    rdfs:label 'Posting Status' ;
    rdfs:comment 'Current lifecycle state of the journal entry within the SAP FI workflow. \'posted\' = fully committed to GL; \'parked\' = saved but not yet posted pending approval; \'held\' = incomplete draft; \'reversed\' = offset by a reversal document; \'simulated\' = test posting not committed; \'error\' = failed validation. Serves as the LIFECYCLE_STATUS field.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referenceDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Reference Document Number' ;
    rdfs:comment 'External reference number linking this journal entry to the originating source document (e.g., vendor invoice number, ticket sales batch ID, broadcast rights contract number, sponsorship deal reference). Enables cross-system traceability. Corresponds to BKPF.XBLNR.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversalDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Reversal Document Number' ;
    rdfs:comment 'Document number of the corresponding reversal entry if this journal entry has been reversed, or the original document number if this entry IS the reversal. Null if no reversal relationship exists. Enables audit trail for correction postings. Corresponds to BKPF.STBLG.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversalIndicator rdf:type rdf:Property ;
    rdfs:label 'Reversal Indicator' ;
    rdfs:comment 'Flag indicating whether this journal entry is a reversal document (True) or an original posting (False). Reversal entries offset prior postings for corrections, accrual reversals, or error remediation. Corresponds to BKPF.STBLG presence.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reversalReasonCode rdf:type rdf:Property ;
    rdfs:label 'Reversal Reason Code' ;
    rdfs:comment 'SAP two-digit reason code explaining why this journal entry was reversed (e.g., \'01\'=incorrect posting, \'02\'=accrual reversal, \'03\'=period-end correction). Null if not reversed. Corresponds to BKPF.STGRD.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:soxApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Sox Approval Status' ;
    rdfs:comment 'Current status of the SOX-mandated approval workflow for this journal entry. \'pending\' = awaiting approver action; \'approved\' = authorized by designated control owner; \'rejected\' = returned for correction; \'escalated\' = routed to senior approver; \'exempt\' = system-generated entry below materiality threshold. Required for SOX Section 404 internal controls over financial reporting.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:soxApprovalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Sox Approval Timestamp' ;
    rdfs:comment 'Date and time when the SOX approval was granted for this journal entry. Null if pending or exempt. Provides immutable audit evidence for SOX Section 404 compliance and external auditor review.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:taxCode rdf:type rdf:Property ;
    rdfs:label 'Tax Code' ;
    rdfs:comment 'SAP two-character tax code applied to this journal entry for VAT, sales tax, or withholding tax calculation (e.g., \'I1\'=input tax, \'O1\'=output tax, \'W1\'=withholding). Null for non-taxable postings. Corresponds to BSEG.MWSKZ.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradingPartnerCode rdf:type rdf:Property ;
    rdfs:label 'Trading Partner Code' ;
    rdfs:comment 'Four-character company code of the intercompany trading partner entity when this is an intercompany journal entry. Used for automated intercompany elimination during group consolidation. Null for external transactions. Corresponds to BKPF.VBUND.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionAmount rdf:type rdf:Property ;
    rdfs:label 'Transaction Amount' ;
    rdfs:comment 'Gross total amount of the journal entry in the transaction currency. Represents the sum of all debit line items (which must equal the sum of all credit line items for a balanced entry). Part of the MONETARY_TRIPLET. Corresponds to the aggregate of BSEG.WRBTR across line items.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetName rdf:type rdf:Property ;
    rdfs:label 'Budget Name' ;
    rdfs:comment 'Human-readable descriptive name for the budget record (e.g., \'FY2025 Event Operations OPEX Base Budget\'). Used in FP&A reporting and investor relations presentations.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetNumber rdf:type rdf:Property ;
    rdfs:label 'Budget Number' ;
    rdfs:comment 'Externally-known alphanumeric identifier for the budget record as assigned in Workday Adaptive Planning or SAP CO. Used for cross-system reconciliation and audit traceability.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetType rdf:type rdf:Property ;
    rdfs:label 'Budget Type' ;
    rdfs:comment 'Classification of the budget by expenditure or revenue category: OPEX (Operating Expenditure), CAPEX (Capital Expenditure), headcount (workforce cost plan), or revenue (income plan). Drives chart of accounts mapping in SAP CO.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:committedAmount rdf:type rdf:Property ;
    rdfs:label 'Committed Amount' ;
    rdfs:comment 'Amount of the budget that has been legally committed via purchase orders, contracts, or reservations in SAP MM/SD but not yet invoiced. Represents encumbered funds for budget availability control.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costElementCode rdf:type rdf:Property ;
    rdfs:label 'Cost Element Code' ;
    rdfs:comment 'SAP CO cost element code that classifies the nature of the planned expenditure (e.g., salaries, venue hire, broadcast rights fees). Enables cost element-level variance analysis.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forecastAmount rdf:type rdf:Property ;
    rdfs:label 'Forecast Amount' ;
    rdfs:comment 'Latest rolling forecast amount for the fiscal period as updated in Workday Adaptive Planning. Reflects the most current expectation of financial outcome, incorporating actuals-to-date and revised forward projections.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isIntercompany rdf:type rdf:Property ;
    rdfs:label 'Is Intercompany' ;
    rdfs:comment 'Indicates whether this budget record relates to an intercompany transaction between legal entities within the Sports Entertainment group. True = intercompany; False = third-party. Required for intercompany elimination in consolidated financial reporting.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lockDate rdf:type rdf:Property ;
    rdfs:label 'Lock Date' ;
    rdfs:comment 'Date on which the budget record was locked in SAP CO, preventing further manual adjustments. Ensures integrity of the approved baseline for variance reporting.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:periodGranularity rdf:type rdf:Property ;
    rdfs:label 'Period Granularity' ;
    rdfs:comment 'Indicates whether the budget record is expressed at monthly, quarterly, or annual granularity. Determines how fiscal_period is interpreted in FP&A reporting.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planType rdf:type rdf:Property ;
    rdfs:label 'Plan Type' ;
    rdfs:comment 'Distinguishes the planning horizon: annual_budget (single fiscal year), multi_year_plan (3–5 year strategic plan), or rolling_forecast (continuous 12–18 month forward view). Supports FP&A and investor relations cycles.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorYearActualAmount rdf:type rdf:Property ;
    rdfs:label 'Prior Year Actual Amount' ;
    rdfs:comment 'Actual amount posted for the equivalent fiscal period in the prior fiscal year. Used as a benchmark for year-over-year variance analysis and budget calibration in FP&A.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reportingCurrencyAmount rdf:type rdf:Property ;
    rdfs:label 'Reporting Currency Amount' ;
    rdfs:comment 'Planned amount translated to the group reporting currency (USD) using the exchange_rate. Enables consolidated EBITDA reporting and SEC financial disclosures across multi-currency global operations.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scenarioType rdf:type rdf:Property ;
    rdfs:label 'Scenario Type' ;
    rdfs:comment 'Financial planning scenario classification: base (most likely), upside (optimistic), downside (pessimistic), or stress (extreme adverse). Used for EBITDA projections and investor relations guidance.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionDate rdf:type rdf:Property ;
    rdfs:label 'Submission Date' ;
    rdfs:comment 'Date on which the budget record was formally submitted for approval in Workday Adaptive Planning. Supports FP&A calendar management and SOX audit trail.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:varianceExplanation rdf:type rdf:Property ;
    rdfs:label 'Variance Explanation' ;
    rdfs:comment 'Structured narrative provided by the budget owner explaining material variances between planned and actual amounts. Required for FP&A monthly close reporting and investor relations commentary.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerAccountId rdf:type rdf:Property ;
    rdfs:label 'Customer Account Id' ;
    rdfs:comment 'Reference to the customer master record (debtor/payer) in the AR sub-ledger. Corresponds to the SAP FI-AR customer (KUNNR) account to whom the invoice is issued — sponsors, broadcast rights licensees, merchandise wholesale buyers, or premium suite holders.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Account .

ind:amountPaid rdf:type rdf:Property ;
    rdfs:label 'Amount Paid' ;
    rdfs:comment 'Cumulative amount received from the customer against this invoice to date. Enables partial payment tracking and outstanding balance calculation (net_amount - amount_paid). Updated upon each payment clearing in SAP FI-AR.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:billingDate rdf:type rdf:Property ;
    rdfs:label 'Billing Date' ;
    rdfs:comment 'The date on which the invoice was issued and sent to the customer. Represents the principal business event date for revenue recognition purposes. Maps to SAP FKDAT (billing date on SD billing document) or BLDAT (document date on FI posting).' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:clearingDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Clearing Document Number' ;
    rdfs:comment 'SAP FI clearing document number (AUGBL) assigned when the invoice is fully or partially cleared by a payment, credit memo, or write-off. Null if the invoice remains open. Provides the AR-to-payment audit trail.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deferredRevenueAmount rdf:type rdf:Property ;
    rdfs:label 'Deferred Revenue Amount' ;
    rdfs:comment 'Portion of the gross_amount that has been billed but not yet recognized as revenue because the associated performance obligation (e.g., season sponsorship activation, multi-year broadcast rights) has not been fully satisfied. Feeds the deferred revenue liability on the balance sheet.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:disputeReasonCode rdf:type rdf:Property ;
    rdfs:label 'Dispute Reason Code' ;
    rdfs:comment 'Standardized code identifying the reason a customer has disputed this invoice (e.g., pricing discrepancy, delivery shortfall, contract breach). Populated when payment_status = \'disputed\'. Supports AR dispute management workflow in SAP FI-AR Collections Management.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dunningBlock rdf:type rdf:Property ;
    rdfs:label 'Dunning Block' ;
    rdfs:comment 'Indicates whether dunning is blocked for this invoice (MANSP in SAP). True = dunning is suppressed (e.g., invoice under dispute or special arrangement). False = dunning proceeds normally.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:invoiceNumber rdf:type rdf:Property ;
    rdfs:label 'Invoice Number' ;
    rdfs:comment 'Externally-visible, human-readable invoice document number assigned by SAP FI-AR (e.g., AR-202400012345). Used on billing documents sent to sponsors, broadcast licensees, merchandise wholesale buyers, and premium suite holders. Maps to SAP BELNR field on BKPF/VBRK.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceType rdf:type rdf:Property ;
    rdfs:label 'Invoice Type' ;
    rdfs:comment 'Classification of the invoice document type. \'standard\' = regular customer invoice; \'credit_memo\' = reduction of a prior invoice; \'debit_memo\' = additional charge; \'pro_forma\' = non-posting preview invoice; \'intercompany\' = settlement between Sports Entertainment legal entities.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentBlock rdf:type rdf:Property ;
    rdfs:label 'Payment Block' ;
    rdfs:comment 'Indicates whether the invoice is blocked from being cleared by an incoming payment (ZLSPR in SAP). True = payment blocked pending resolution (e.g., dispute, credit check). False = payment can be applied.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:paymentDate rdf:type rdf:Property ;
    rdfs:label 'Payment Date' ;
    rdfs:comment 'Date on which the invoice was fully cleared/paid in SAP FI-AR (AUGDT). Null if not yet paid. Used for DSO calculation, cash flow actuals, and AR aging analysis.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:revenueRecognitionStatus rdf:type rdf:Property ;
    rdfs:label 'Revenue Recognition Status' ;
    rdfs:comment 'Indicates the ASC 606 / IFRS 15 revenue recognition status of this invoice. \'pending\' = performance obligation not yet satisfied; \'recognized\' = revenue fully recognized; \'deferred\' = billed in advance of performance; \'partially_recognized\' = multi-element arrangement partially satisfied.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapDocumentType rdf:type rdf:Property ;
    rdfs:label 'Sap Document Type' ;
    rdfs:comment 'SAP FI document type code (BLART) classifying the accounting document (e.g., \'RV\' = billing document transfer, \'DR\' = customer invoice, \'DG\' = customer credit memo). Preserves source system classification for reconciliation and audit.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:writeOffAmount rdf:type rdf:Property ;
    rdfs:label 'Write Off Amount' ;
    rdfs:comment 'Amount of the invoice that has been written off as uncollectable bad debt. Populated when payment_status = \'written_off\'. Feeds the bad debt expense account and allowance for doubtful accounts on the balance sheet.' ;
    rdfs:domain ind:ArInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:apInvoiceId rdf:type rdf:Property ;
    rdfs:label 'Ap Invoice Id' ;
    rdfs:comment 'Unique surrogate identifier for the accounts payable invoice record in the Databricks Silver Layer. Primary key generated by the lakehouse ingestion pipeline from SAP FI-AP.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ApInvoice .

ind:baselineDate rdf:type rdf:Property ;
    rdfs:label 'Baseline Date' ;
    rdfs:comment 'The reference date from which payment terms are calculated in SAP FI-AP. May differ from invoice date or receipt date depending on payment terms configuration.' ;
    rdfs:domain ind:ApInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:expenseCategory rdf:type rdf:Property ;
    rdfs:label 'Expense Category' ;
    rdfs:comment 'Financial classification of the invoice as capital expenditure (CAPEX), operating expenditure (OPEX), prepaid expense, accrual, or intercompany charge. Drives balance sheet vs. P&L treatment and EBITDA impact.' ;
    rdfs:domain ind:ApInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:goodsReceiptNumber rdf:type rdf:Property ;
    rdfs:label 'Goods Receipt Number' ;
    rdfs:comment 'The SAP material document number for the goods receipt or service entry sheet that confirms delivery of goods/services from the vendor. Required for three-way match and accrual reversal.' ;
    rdfs:domain ind:ApInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceStatus rdf:type rdf:Property ;
    rdfs:label 'Invoice Status' ;
    rdfs:comment 'Current workflow status of the invoice in the AP processing lifecycle. [ENUM-REF-CANDIDATE: RECEIVED|UNDER_REVIEW|APPROVED|POSTED|SCHEDULED|PAID|BLOCKED|CANCELLED — promote to reference product]' ;
    rdfs:domain ind:ApInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentBlockReason rdf:type rdf:Property ;
    rdfs:label 'Payment Block Reason' ;
    rdfs:comment 'Reason code explaining why the invoice payment has been blocked in SAP FI-AP. [ENUM-REF-CANDIDATE: MANUAL_HOLD|PRICE_VARIANCE|QUANTITY_VARIANCE|DUPLICATE|MISSING_PO|PENDING_APPROVAL|DISPUTE|NONE — promote to reference product]' ;
    rdfs:domain ind:ApInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Payment Document Number' ;
    rdfs:comment 'SAP FI document number of the outgoing payment that cleared this invoice. Used for bank reconciliation, audit trail, and dispute resolution with vendors.' ;
    rdfs:domain ind:ApInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receiptDate rdf:type rdf:Property ;
    rdfs:label 'Receipt Date' ;
    rdfs:comment 'The date the invoice was physically or electronically received by the accounts payable department. Determines the start of the payment terms clock and early payment discount eligibility.' ;
    rdfs:domain ind:ApInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sapDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Document Number' ;
    rdfs:comment 'The 10-digit SAP FI document number assigned upon posting of the invoice in SAP S/4HANA. Serves as the system-of-record identifier for audit trail and journal entry cross-reference.' ;
    rdfs:domain ind:ApInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:threeWayMatchStatus rdf:type rdf:Property ;
    rdfs:label 'Three Way Match Status' ;
    rdfs:comment 'Result of the three-way match validation between the Purchase Order (PO), Goods Receipt (GR), and Invoice Receipt (IR) in SAP MM-IV. MATCHED: all three documents align within tolerance; PARTIAL_MATCH: partial quantity or price variance; UNMATCHED: significant discrepancy; NOT_APPLICABLE: non-PO invoice.' ;
    rdfs:domain ind:ApInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorCategory rdf:type rdf:Property ;
    rdfs:label 'Vendor Category' ;
    rdfs:comment 'Business classification of the vendor type for spend analytics and category management. [ENUM-REF-CANDIDATE: VENUE_SERVICES|BROADCAST_EQUIPMENT|ATHLETE_AGENT|MERCHANDISE_MFG|MEDIA_RIGHTS|CONTENT_PRODUCTION|FACILITY_MGMT|TECHNOLOGY|PROFESSIONAL_SERVICES|OTHER — promote to reference product]' ;
    rdfs:domain ind:ApInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorInvoiceNumber rdf:type rdf:Property ;
    rdfs:label 'Vendor Invoice Number' ;
    rdfs:comment 'The invoice number as printed on the vendor\'s source document. Used for three-way match reconciliation and vendor dispute resolution. Must be unique per vendor account.' ;
    rdfs:domain ind:ApInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentId rdf:type rdf:Property ;
    rdfs:label 'Payment Id' ;
    rdfs:comment 'Unique surrogate identifier for each payment transaction record in the Sports Entertainment finance domain. Primary key for the payment data product in the Databricks Silver Layer.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fanProfileId rdf:type rdf:Property ;
    rdfs:label 'Fan Profile Id' ;
    rdfs:comment 'Reference to the customer master record for inbound AR receipts. Identifies the payer for ticket sales, sponsorship receipts, merchandise revenue, and broadcast rights settlements. Null for outbound vendor disbursements.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FanProfile .

ind:achTraceNumber rdf:type rdf:Property ;
    rdfs:label 'Ach Trace Number' ;
    rdfs:comment 'The NACHA ACH trace number assigned to this payment entry for ACH transactions. Used for ACH return processing, NOC (Notification of Change) handling, and bank reconciliation. Null for non-ACH payment methods.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankKey rdf:type rdf:Property ;
    rdfs:label 'Bank Key' ;
    rdfs:comment 'The SAP FI house bank key (HBKID) identifying the financial institution through which this payment is routed. Used for bank reconciliation, liquidity planning, and treasury management reporting.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blockIndicator rdf:type rdf:Property ;
    rdfs:label 'Block Indicator' ;
    rdfs:comment 'SAP FI payment block code (ZLSPR) indicating whether the payment is blocked from processing and the reason (e.g., manual block, dispute, audit hold, compliance review). Blank/null indicates no block. Critical for AP payment control and SOX compliance.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checkNumber rdf:type rdf:Property ;
    rdfs:label 'Check Number' ;
    rdfs:comment 'The physical or electronic check number assigned to this payment when payment_method is \'check\'. Used for check register management, positive pay file submission to banks, and stop-payment processing. Null for non-check payment methods.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:direction rdf:type rdf:Property ;
    rdfs:label 'Direction' ;
    rdfs:comment 'Indicates whether the payment is an outbound disbursement (AP vendor payment) or an inbound receipt (AR customer collection). Fundamental discriminator for cash flow classification and treasury reporting under IAS 7.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reference rdf:type rdf:Property ;
    rdfs:label 'Reference' ;
    rdfs:comment 'Free-form reference text transmitted with the payment to the beneficiary bank (e.g., invoice number, contract reference, event name). Appears on bank statements and remittance advice. Corresponds to BVTYP/XBLNR in SAP FI. Critical for counterparty cash application.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remittanceAdviceSent rdf:type rdf:Property ;
    rdfs:label 'Remittance Advice Sent' ;
    rdfs:comment 'Indicates whether a remittance advice notification has been sent to the payee or payer detailing the invoices cleared by this payment. Supports vendor and customer communication workflows in SAP FI output management.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:specialGlIndicator rdf:type rdf:Property ;
    rdfs:label 'Special Gl Indicator' ;
    rdfs:comment 'SAP FI special GL indicator (UMSKZ) classifying non-standard postings such as down payments, guarantees, or security deposits associated with this payment. Blank for standard payment postings. Used for balance sheet sub-classification.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:swiftReference rdf:type rdf:Property ;
    rdfs:label 'Swift Reference' ;
    rdfs:comment 'The SWIFT end-to-end transaction reference (UETR or TRN) for wire transfer payments. Enables real-time payment tracking via SWIFT gpi and bank confirmation matching. Null for non-wire payment methods.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:termsCode rdf:type rdf:Property ;
    rdfs:label 'Terms Code' ;
    rdfs:comment 'The SAP FI payment terms key (ZTERM) governing the due date calculation and early payment discount conditions for this transaction (e.g., NT30, 2/10NET30). Inherited from the invoice or vendor/customer master. Drives DSO and DPO analytics.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accumulatedDepreciation rdf:type rdf:Property ;
    rdfs:label 'Accumulated Depreciation' ;
    rdfs:comment 'Total depreciation charged against the asset from the in-service date to the current reporting period. Contra-asset balance used to calculate net book value. Sourced from SAP FI-AA depreciation simulation/posting runs.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:acquisitionCost rdf:type rdf:Property ;
    rdfs:label 'Acquisition Cost' ;
    rdfs:comment 'Original historical cost of the fixed asset at the time of acquisition or capitalization, in the company code currency. Includes purchase price, import duties, and directly attributable costs to bring the asset to its intended use. CAPEX SSOT figure.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:acquisitionDate rdf:type rdf:Property ;
    rdfs:label 'Acquisition Date' ;
    rdfs:comment 'Date on which the fixed asset was acquired, purchased, or constructed and capitalized. Used as the start date for depreciation calculation and CAPEX reporting. Corresponds to SAP FI-AA \'Capitalization Date\'.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:annualDepreciationCharge rdf:type rdf:Property ;
    rdfs:label 'Annual Depreciation Charge' ;
    rdfs:comment 'Planned annual depreciation expense for the current fiscal year as calculated by SAP FI-AA. Used in FP&A budgeting, EBITDA bridge analysis, and Workday Adaptive Planning depreciation forecasts.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assetCategory rdf:type rdf:Property ;
    rdfs:label 'Asset Category' ;
    rdfs:comment 'High-level classification distinguishing tangible assets (stadium structures, OB trucks, scoreboards), intangible assets (broadcast rights, software licenses, NIL-related IP), right-of-use assets (IFRS 16 leases), and investment property. Drives balance sheet line-item presentation.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetClassCode rdf:type rdf:Property ;
    rdfs:label 'Asset Class Code' ;
    rdfs:comment 'SAP FI-AA asset class code that determines the depreciation area, useful life defaults, and GL account determination (e.g., \'1000\' for Buildings, \'2000\' for Machinery, \'3000\' for Intangible Assets, \'4000\' for Broadcast Rights). Drives CAPEX categorization and balance sheet classification.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetClassName rdf:type rdf:Property ;
    rdfs:label 'Asset Class Name' ;
    rdfs:comment 'Human-readable name of the SAP asset class (e.g., \'Stadium Structures\', \'Broadcast Equipment\', \'OB Trucks\', \'Digital Platform Infrastructure\', \'Acquired Broadcast Rights\', \'Scoreboards & LED Systems\'). Used in financial reporting and CAPEX dashboards.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetLocationCode rdf:type rdf:Property ;
    rdfs:label 'Asset Location Code' ;
    rdfs:comment 'Physical or logical location code where the asset is deployed (e.g., venue code, broadcast facility code, data center identifier). Supports asset tracking, insurance valuation, and ADA/OSHA compliance reporting for venue assets.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetLocationDescription rdf:type rdf:Property ;
    rdfs:label 'Asset Location Description' ;
    rdfs:comment 'Human-readable description of the asset\'s physical location (e.g., \'Main Stadium – East Stand\', \'Broadcast Tower – Roof Level 3\', \'OB Truck Depot – Training Facility\'). Used in physical asset verification and insurance schedules.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetNumber rdf:type rdf:Property ;
    rdfs:label 'Asset Number' ;
    rdfs:comment 'Externally-known SAP FI-AA asset number (main asset number) assigned at capitalization. Used as the primary business identifier on CAPEX reports, depreciation schedules, and audit trails. Format follows SAP company-code-prefixed numbering convention.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetStatus rdf:type rdf:Property ;
    rdfs:label 'Asset Status' ;
    rdfs:comment 'Current lifecycle state of the fixed asset. \'under_construction\' = Assets Under Construction (AUC) not yet capitalized; \'in_service\' = actively depreciated; \'idle\' = temporarily out of service; \'impaired\' = impairment loss recognized; \'disposed\' = sold, scrapped, or retired; \'transferred\' = intercompany or intra-company transfer in progress.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetSubnumber rdf:type rdf:Property ;
    rdfs:label 'Asset Subnumber' ;
    rdfs:comment 'SAP FI-AA sub-number identifying a component or addition to the main asset (e.g., a scoreboard upgrade added to the main stadium structure asset). Enables component-level depreciation tracking.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:broadcastRightsExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Broadcast Rights Expiry Date' ;
    rdfs:comment 'For intangible assets representing acquired broadcast rights (e.g., RSN rights, OTT streaming rights, PPV event rights), the contractual expiry date of the rights. Drives amortization end date and rights renewal planning. Null for tangible assets.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:capexBudgetCode rdf:type rdf:Property ;
    rdfs:label 'Capex Budget Code' ;
    rdfs:comment 'Reference to the approved CAPEX budget line item or investment program code in Workday Adaptive Planning / SAP IM (Investment Management) that authorized the acquisition of this asset. Supports CAPEX vs. budget variance reporting.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:depreciationAreaCode rdf:type rdf:Property ;
    rdfs:label 'Depreciation Area Code' ;
    rdfs:comment 'SAP FI-AA depreciation area identifier representing the valuation basis (e.g., \'01\' for book depreciation per local GAAP, \'15\' for tax depreciation, \'30\' for IFRS). Enables parallel valuation for SEC reporting and tax compliance.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:depreciationMethodCode rdf:type rdf:Property ;
    rdfs:label 'Depreciation Method Code' ;
    rdfs:comment 'SAP FI-AA depreciation key/method code defining the calculation method (e.g., \'LINR\' for straight-line, \'DG30\' for declining balance 30%, \'MANU\' for manual, \'UNIT\' for units-of-production). Determines how accumulated depreciation is calculated each period.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disposalDate rdf:type rdf:Property ;
    rdfs:label 'Disposal Date' ;
    rdfs:comment 'Date on which the asset was retired, sold, scrapped, or otherwise disposed of. Triggers the derecognition of the asset from the balance sheet and recognition of any gain or loss on disposal in SAP FI-AA.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:disposalProceeds rdf:type rdf:Property ;
    rdfs:label 'Disposal Proceeds' ;
    rdfs:comment 'Net proceeds received upon disposal or sale of the asset. Used to calculate the gain or loss on disposal recognized in the income statement. Relevant for stadium asset sales, OB truck fleet disposals, and broadcast rights expirations.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:disposalType rdf:type rdf:Property ;
    rdfs:label 'Disposal Type' ;
    rdfs:comment 'Method by which the asset was disposed of. \'sale\' = sold to third party; \'scrap\' = physically scrapped; \'transfer\' = intercompany or intra-company transfer; \'donation\' = donated; \'write_off\' = written off; \'insurance_claim\' = disposed via insurance settlement (e.g., storm-damaged broadcast tower).' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impairmentLoss rdf:type rdf:Property ;
    rdfs:label 'Impairment Loss' ;
    rdfs:comment 'Cumulative impairment loss recognized on the asset where the carrying amount exceeds the recoverable amount (per IAS 36 / ASC 360). Reduces net book value. Relevant for broadcast rights, goodwill-adjacent intangibles, and underperforming venue assets.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inServiceDate rdf:type rdf:Property ;
    rdfs:label 'In Service Date' ;
    rdfs:comment 'Date the asset was placed into active service and depreciation commenced. May differ from acquisition_date for assets under construction. Drives the depreciation start period in SAP FI-AA.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:insurancePolicyNumber rdf:type rdf:Property ;
    rdfs:label 'Insurance Policy Number' ;
    rdfs:comment 'Reference number of the insurance policy covering this asset against loss, damage, or liability. Critical for venue assets (stadium structures), broadcast infrastructure (OB trucks, towers), and high-value equipment. Supports risk management and claims processing.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuredValue rdf:type rdf:Property ;
    rdfs:label 'Insured Value' ;
    rdfs:comment 'Declared insured replacement value of the asset as agreed with the insurer. May differ from net book value (NBV) for high-value venue and broadcast infrastructure assets. Used for insurance adequacy reviews.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isFullyDepreciated rdf:type rdf:Property ;
    rdfs:label 'Is Fully Depreciated' ;
    rdfs:comment 'Indicates whether the asset has been fully depreciated (net book value equals residual value). Fully depreciated assets still in service are flagged for management review and potential useful life extension assessment per IAS 16.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isLeased rdf:type rdf:Property ;
    rdfs:label 'Is Leased' ;
    rdfs:comment 'Indicates whether the asset is a right-of-use (ROU) asset recognized under IFRS 16 / ASC 842 (e.g., leased venue, leased OB truck, leased broadcast satellite capacity). Drives separate balance sheet presentation and lease liability linkage.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastPhysicalVerificationDate rdf:type rdf:Property ;
    rdfs:label 'Last Physical Verification Date' ;
    rdfs:comment 'Date of the most recent physical inventory count or asset verification exercise confirming the asset\'s existence and condition. Required for SOX internal controls and annual audit procedures.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:netBookValue rdf:type rdf:Property ;
    rdfs:label 'Net Book Value' ;
    rdfs:comment 'Current carrying amount of the fixed asset: acquisition_cost plus subsequent_acquisition_cost minus accumulated_depreciation minus impairment_loss. Reported on the balance sheet. Refreshed each period-end close from SAP FI-AA.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:purchaseOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Purchase Order Number' ;
    rdfs:comment 'SAP MM purchase order number associated with the acquisition of the asset. Provides the procurement-to-capitalization audit trail required for SOX compliance and CAPEX authorization controls.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:residualValue rdf:type rdf:Property ;
    rdfs:label 'Residual Value' ;
    rdfs:comment 'Estimated amount the entity expects to recover from the asset at the end of its useful life (salvage value). Deducted from acquisition cost to determine the depreciable base. Reviewed annually per IAS 16.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revaluationAmount rdf:type rdf:Property ;
    rdfs:label 'Revaluation Amount' ;
    rdfs:comment 'Cumulative upward or downward revaluation adjustment to the asset\'s carrying amount under the IAS 16 revaluation model (where adopted). Recorded in the revaluation surplus in equity. Applicable to stadium land and property assets.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:serialNumber rdf:type rdf:Property ;
    rdfs:label 'Serial Number' ;
    rdfs:comment 'Manufacturer\'s serial number or unique physical identifier for the asset (e.g., OB truck chassis number, scoreboard controller serial, broadcast transmitter serial). Used for physical verification, warranty claims, and insurance schedules.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subsequentAcquisitionCost rdf:type rdf:Property ;
    rdfs:label 'Subsequent Acquisition Cost' ;
    rdfs:comment 'Cumulative cost of subsequent capital additions or improvements to the asset (e.g., stadium seat upgrades, scoreboard technology refresh, broadcast tower antenna replacement). Added to the asset\'s gross book value.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:usefulLifePeriods rdf:type rdf:Property ;
    rdfs:label 'Useful Life Periods' ;
    rdfs:comment 'Estimated useful life expressed in fiscal periods (months) for assets with sub-annual depreciation granularity. Used in SAP FI-AA period-based depreciation calculations alongside useful_life_years.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:usefulLifeYears rdf:type rdf:Property ;
    rdfs:label 'Useful Life Years' ;
    rdfs:comment 'Estimated useful economic life of the asset in years, as determined at capitalization and used to calculate straight-line or other depreciation. Reviewed annually per IAS 16 (e.g., 40 years for stadium structures, 5 years for OB trucks, 3 years for broadcast rights).' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:wbsElement rdf:type rdf:Property ;
    rdfs:label 'Wbs Element' ;
    rdfs:comment 'SAP PS Work Breakdown Structure element linked to the asset, used for CAPEX project tracking during the Assets Under Construction (AUC) phase (e.g., stadium renovation project, broadcast tower installation). Populated until the AUC is settled to a final asset.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recognizedGlAccountId rdf:type rdf:Property ;
    rdfs:label 'Recognized Gl Account Id' ;
    rdfs:comment 'Foreign key linking to finance.gl_account. Business justification: Revenue recognition schedules post recognized revenue to a specific GL account. The gl_account_code string field should be replaced with a typed FK recognized_gl_account_id → gl_account.gl_account_id.' ;
    rdfs:domain ind:RevenueRecognitionSchedule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GlAccount .

ind:constraintAppliedFlag rdf:type rdf:Property ;
    rdfs:label 'Constraint Applied Flag' ;
    rdfs:comment 'Indicates whether the variable consideration constraint has been applied to limit the recognized amount to the extent it is highly probable (IFRS 15) or probable (ASC 606) that a significant revenue reversal will not occur. Required for ASC 606 / IFRS 15 compliance documentation.' ;
    rdfs:domain ind:RevenueRecognitionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contractEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Contract Effective Date' ;
    rdfs:comment 'The date the underlying contract became legally binding and enforceable. Used as the ASC 606 contract inception date for determining transaction price and allocating to performance obligations.' ;
    rdfs:domain ind:RevenueRecognitionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contractExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Contract Expiry Date' ;
    rdfs:comment 'The date the underlying contract expires or terminates. For multi-year broadcast rights or naming rights agreements, this may be several years in the future. Nullable for evergreen contracts.' ;
    rdfs:domain ind:RevenueRecognitionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cumulativeRecognizedAmount rdf:type rdf:Property ;
    rdfs:label 'Cumulative Recognized Amount' ;
    rdfs:comment 'Total revenue recognized to date against this performance obligation since the recognition start date. Equals total_contract_value minus deferred_revenue_balance at any point in time. Used for period-end reconciliation and ASC 606 cumulative catch-up adjustment calculations.' ;
    rdfs:domain ind:RevenueRecognitionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:currentPeriodRecognitionAmount rdf:type rdf:Property ;
    rdfs:label 'Current Period Recognition Amount' ;
    rdfs:comment 'Revenue amount to be recognized in the current accounting period for this performance obligation. Drives the period-end journal entry generation in SAP S/4HANA FI/CO. For straight-line method, equals total_contract_value divided by total periods; for milestone/event-based, equals the value of the milestone achieved.' ;
    rdfs:domain ind:RevenueRecognitionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deferredRevenueBalance rdf:type rdf:Property ;
    rdfs:label 'Deferred Revenue Balance' ;
    rdfs:comment 'Current outstanding deferred revenue balance for this performance obligation — the portion of total contract value received or billed but not yet recognized as earned revenue. Drives the deferred revenue waterfall report and balance sheet liability disclosure. Updated each period-end close in SAP S/4HANA FI.' ;
    rdfs:domain ind:RevenueRecognitionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deferredRevenueGlAccountCode rdf:type rdf:Property ;
    rdfs:label 'Deferred Revenue Gl Account Code' ;
    rdfs:comment 'SAP S/4HANA GL account code for the deferred revenue liability balance sheet account. The deferred revenue balance is carried here until recognized. Required for balance sheet reporting and SOX-compliant financial controls.' ;
    rdfs:domain ind:RevenueRecognitionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastRecognitionDate rdf:type rdf:Property ;
    rdfs:label 'Last Recognition Date' ;
    rdfs:comment 'The date of the most recent revenue recognition posting for this performance obligation. Used to confirm period-end close completion and to identify schedules that have not been processed in the current period.' ;
    rdfs:domain ind:RevenueRecognitionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:modificationDate rdf:type rdf:Property ;
    rdfs:label 'Modification Date' ;
    rdfs:comment 'The effective date of the most recent contract modification affecting this recognition schedule. Null when modification_flag is false. Used to determine the prospective or cumulative catch-up adjustment period.' ;
    rdfs:domain ind:RevenueRecognitionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:modificationFlag rdf:type rdf:Property ;
    rdfs:label 'Modification Flag' ;
    rdfs:comment 'Indicates whether this recognition schedule reflects a contract modification (e.g., renegotiated broadcast rights fee, amended sponsorship scope). When true, the modification accounting treatment (prospective or cumulative catch-up) per ASC 606-10-25-12 / IFRS 15.18 must be documented.' ;
    rdfs:domain ind:RevenueRecognitionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nextRecognitionDate rdf:type rdf:Property ;
    rdfs:label 'Next Recognition Date' ;
    rdfs:comment 'The scheduled date for the next revenue recognition posting. Used by the FP&A team in Workday Adaptive Planning for revenue forecasting and by the accounting team to manage period-end close calendars.' ;
    rdfs:domain ind:RevenueRecognitionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:performanceObligationDescription rdf:type rdf:Property ;
    rdfs:label 'Performance Obligation Description' ;
    rdfs:comment 'Narrative description of the distinct performance obligation being recognized, as documented in the contract and required for ASC 606 / IFRS 15 disclosure. Examples: \'Exclusive broadcast rights for NFL regular season games FY2024-FY2026\', \'Naming rights for stadium facade and digital signage\', \'Season ticket package — 41 home games\'.' ;
    rdfs:domain ind:RevenueRecognitionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:periodsRecognized rdf:type rdf:Property ;
    rdfs:label 'Periods Recognized' ;
    rdfs:comment 'Number of accounting periods for which revenue has been recognized to date against this performance obligation. Used to track progress toward full recognition and to validate cumulative_recognized_amount in period-end reconciliation.' ;
    rdfs:domain ind:RevenueRecognitionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:recognitionBasis rdf:type rdf:Property ;
    rdfs:label 'Recognition Basis' ;
    rdfs:comment 'Indicates whether revenue is recognized over time (e.g., broadcast rights delivered continuously over a season) or at a point in time (e.g., a one-time PPV event, a single concert). Fundamental ASC 606 / IFRS 15 classification that determines the recognition pattern.' ;
    rdfs:domain ind:RevenueRecognitionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recognitionEndDate rdf:type rdf:Property ;
    rdfs:label 'Recognition End Date' ;
    rdfs:comment 'The date on which revenue recognition is expected to be fully completed for this performance obligation. For multi-year broadcast rights, this may span several fiscal years. Nullable for open-ended or usage-based obligations without a fixed end date.' ;
    rdfs:domain ind:RevenueRecognitionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:recognitionMethod rdf:type rdf:Property ;
    rdfs:label 'Recognition Method' ;
    rdfs:comment 'The accounting method used to recognize revenue over the performance obligation period. Straight-line = equal amounts per period; Milestone = upon achievement of defined deliverables; Usage-based = proportional to actual consumption (e.g., broadcast impressions, CPM); Event-based = upon occurrence of specific events (e.g., game played); Proportional performance = based on percentage of obligation fulfilled.' ;
    rdfs:domain ind:RevenueRecognitionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recognitionStartDate rdf:type rdf:Property ;
    rdfs:label 'Recognition Start Date' ;
    rdfs:comment 'The date on which revenue recognition commences for this performance obligation. Typically aligns with contract effective date or the date the entity begins satisfying the performance obligation (e.g., first broadcast date, season opener, naming rights activation).' ;
    rdfs:domain ind:RevenueRecognitionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:recognitionStatus rdf:type rdf:Property ;
    rdfs:label 'Recognition Status' ;
    rdfs:comment 'Current lifecycle state of the revenue recognition schedule. Draft = under review; Active = currently recognizing revenue; Suspended = temporarily halted (e.g., contract dispute); Completed = fully recognized; Cancelled = contract terminated before full recognition.' ;
    rdfs:domain ind:RevenueRecognitionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:significantFinancingFlag rdf:type rdf:Property ;
    rdfs:label 'Significant Financing Flag' ;
    rdfs:comment 'Indicates whether the contract contains a significant financing component requiring adjustment of the transaction price for the time value of money per ASC 606-10-32-15 / IFRS 15.60. Common in multi-year prepaid broadcast rights deals where cash is received significantly in advance of performance.' ;
    rdfs:domain ind:RevenueRecognitionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:totalRecognitionPeriods rdf:type rdf:Property ;
    rdfs:label 'Total Recognition Periods' ;
    rdfs:comment 'Total number of accounting periods over which revenue is to be recognized for this performance obligation. Used for straight-line recognition calculations and deferred revenue waterfall projections. For event-based recognition, represents the total number of qualifying events.' ;
    rdfs:domain ind:RevenueRecognitionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:variableConsiderationAmount rdf:type rdf:Property ;
    rdfs:label 'Variable Consideration Amount' ;
    rdfs:comment 'The estimated amount of variable consideration included in the transaction price at the most likely amount or expected value method per ASC 606. Applicable for contracts with performance bonuses, ratings escalators, or PPV revenue share components. Null when variable_consideration_flag is false.' ;
    rdfs:domain ind:RevenueRecognitionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:variableConsiderationFlag rdf:type rdf:Property ;
    rdfs:label 'Variable Consideration Flag' ;
    rdfs:comment 'Indicates whether the transaction price includes variable consideration components (e.g., performance bonuses, ratings-based escalators, PPV revenue share, usage-based royalties). When true, the constraint on variable consideration per ASC 606 Step 3 must be applied and reassessed each reporting period.' ;
    rdfs:domain ind:RevenueRecognitionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:addressLine1 rdf:type rdf:Property ;
    rdfs:label 'Address Line1' ;
    rdfs:comment 'Primary street address of the venue used for logistics, emergency services coordination, ADA compliance documentation, and fan-facing wayfinding. Classified as confidential organizational contact data.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressLine2 rdf:type rdf:Property ;
    rdfs:label 'Address Line2' ;
    rdfs:comment 'Secondary address detail (suite, building, gate reference) for the venue. Used in official correspondence, regulatory filings, and emergency response planning.' ;
    rdfs:domain ind:Venue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:broadcastProductionLevel rdf:type rdf:Property ;
    rdfs:label 'Broadcast Production Level' ;
    rdfs:comment 'Classification of the venue\'s broadcast infrastructure capability tier. Tier 1 = full national/international OB (Outside Broadcast) production with permanent broadcast compound; Tier 2 = RSN (Regional Sports Network) capable; Tier 3 = local/streaming only; Non-broadcast = no permanent broadcast infrastructure.' ;
    rdfs:domain ind:Venue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:concessionStandCount rdf:type rdf:Property ;
    rdfs:label 'Concession Stand Count' ;
    rdfs:comment 'Total number of fixed concession and food-and-beverage service points within the venue. Used in event-day staffing planning, POS system configuration, and revenue forecasting for food and beverage operations.' ;
    rdfs:domain ind:Venue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fieldDimensionsNotes rdf:type rdf:Property ;
    rdfs:label 'Field Dimensions Notes' ;
    rdfs:comment 'Free-text description of the primary playing field or stage dimensions including notable non-standard measurements (e.g., asymmetric outfield dimensions in MLB ballparks, stage depth for concert configurations). Used by event production and broadcast teams for pre-event planning.' ;
    rdfs:domain ind:Facility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grossSqft rdf:type rdf:Property ;
    rdfs:label 'Gross Sqft' ;
    rdfs:comment 'Total gross interior square footage of the venue facility including all concourses, concession areas, back-of-house operations, suites, and playing surface. Used for facility management cost allocation, HVAC sizing, and OSHA compliance reporting.' ;
    rdfs:domain ind:Venue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:homeTenantName rdf:type rdf:Property ;
    rdfs:label 'Home Tenant Name' ;
    rdfs:comment 'Name of the primary home team, franchise, or resident tenant organization that uses the venue as its principal home base (e.g., \'Los Angeles Rams\', \'New York Knicks\'). Used in event scheduling, broadcast rights attribution, and sponsorship agreement scoping.' ;
    rdfs:domain ind:Venue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hvacSystemType rdf:type rdf:Property ;
    rdfs:label 'Hvac System Type' ;
    rdfs:comment 'Classification of the primary HVAC system installed in the venue. Determines energy consumption benchmarks, maintenance scheduling cadence, and climate control capability for event-day comfort and ice surface management (NHL arenas).' ;
    rdfs:domain ind:Venue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:latitude rdf:type rdf:Property ;
    rdfs:label 'Latitude' ;
    rdfs:comment 'Geographic latitude coordinate of the venue in decimal degrees (WGS84 datum). Used for geo-spatial analytics, fan proximity modeling, broadcast satellite uplink positioning, and emergency services dispatch.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:longitude rdf:type rdf:Property ;
    rdfs:label 'Longitude' ;
    rdfs:comment 'Geographic longitude coordinate of the venue in decimal degrees (WGS84 datum). Used in conjunction with latitude for geo-spatial analytics, broadcast OB (Outside Broadcast) unit positioning, and fan travel distance calculations.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxEventCapacityOverride rdf:type rdf:Property ;
    rdfs:label 'Max Event Capacity Override' ;
    rdfs:comment 'Operationally approved maximum attendance figure that may differ from the certified total capacity due to event-specific configurations (e.g., stage placement reducing seating, COVID-era restrictions, or temporary expansion permits). Used by ticketing systems to set hard inventory ceilings per event.' ;
    rdfs:domain ind:Venue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:operationalStatus rdf:type rdf:Property ;
    rdfs:label 'Operational Status' ;
    rdfs:comment 'Current lifecycle state of the venue asset indicating its readiness for event hosting. \'active\' = fully operational; \'mothballed\' = temporarily closed; \'under_renovation\' = capital works in progress; \'decommissioned\' = permanently retired from service.' ;
    rdfs:domain ind:Venue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownershipStructure rdf:type rdf:Property ;
    rdfs:label 'Ownership Structure' ;
    rdfs:comment 'Legal and financial relationship between Sports Entertainment and the venue asset. Determines accounting treatment (capital vs. operating lease), maintenance obligations, and naming rights negotiation authority under SAP FI/CO asset accounting.' ;
    rdfs:domain ind:Venue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:playingSurfaceType rdf:type rdf:Property ;
    rdfs:label 'Playing Surface Type' ;
    rdfs:comment 'Type of playing surface installed in the venue\'s primary competition area. Determines sport eligibility, athlete safety protocols, and maintenance scheduling. [ENUM-REF-CANDIDATE: natural_grass|artificial_turf|hardwood|ice|clay|grass|synthetic_clay — promote to reference product if additional surface types are required]' ;
    rdfs:domain ind:Venue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:premiumSuiteCount rdf:type rdf:Property ;
    rdfs:label 'Premium Suite Count' ;
    rdfs:comment 'Total number of premium luxury suites and private boxes available in the venue. Drives VIP ticketing inventory, suite license agreement management, and premium hospitality revenue planning in Salesforce CRM and Archtics.' ;
    rdfs:domain ind:Venue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primarySportCategory rdf:type rdf:Property ;
    rdfs:label 'Primary Sport Category' ;
    rdfs:comment 'The principal sport or entertainment category for which the venue is primarily designed and configured (e.g., \'American Football\', \'Basketball\', \'Ice Hockey\', \'Soccer\', \'Concert/Live Entertainment\', \'Baseball\'). Drives default seating bowl configuration and broadcast production setup.' ;
    rdfs:domain ind:Venue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roofType rdf:type rdf:Property ;
    rdfs:label 'Roof Type' ;
    rdfs:comment 'Classification of the venue\'s roof structure indicating weather protection capability. Impacts event scheduling decisions, broadcast lighting requirements, HVAC system design, and contingency planning for weather-affected events.' ;
    rdfs:domain ind:Venue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scoreboardType rdf:type rdf:Property ;
    rdfs:label 'Scoreboard Type' ;
    rdfs:comment 'Type of primary scoreboard and video display system installed in the venue. Determines broadcast production integration capability, in-venue fan experience quality, and advertising inventory available on digital displays.' ;
    rdfs:domain ind:Venue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seatingBowlConfigCode rdf:type rdf:Property ;
    rdfs:label 'Seating Bowl Config Code' ;
    rdfs:comment 'Alphanumeric code identifying the specific seating bowl layout configuration loaded in Archtics for this venue (e.g., \'NFL-FULL\', \'CONCERT-360\', \'NBA-STANDARD\'). Maps to the seating manifest used for ticket inventory allocation and pricing zone assignment.' ;
    rdfs:domain ind:Venue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stateProvince rdf:type rdf:Property ;
    rdfs:label 'State Province' ;
    rdfs:comment 'State or province in which the venue is located. Required for tax jurisdiction determination, OSHA regulatory compliance reporting, and broadcast rights territory assignment.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timeZone rdf:type rdf:Property ;
    rdfs:label 'Time Zone' ;
    rdfs:comment 'IANA time zone identifier for the venue\'s local time (e.g., \'America/Los_Angeles\', \'Europe/London\'). Critical for event scheduling, broadcast start-time coordination, and ticketing system gate-open logic across global markets.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalCapacity rdf:type rdf:Property ;
    rdfs:label 'Total Capacity' ;
    rdfs:comment 'Maximum total number of spectators the venue can accommodate across all seating categories (GA, reserved, VIP, SRO) as certified by local fire and safety authorities. Primary capacity figure used in ticketing inventory allocation and revenue yield modeling.' ;
    rdfs:domain ind:Venue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:venueType rdf:type rdf:Property ;
    rdfs:label 'Venue Type' ;
    rdfs:comment 'Classification of the physical venue structure by its primary design and use purpose. Drives seating bowl configuration, capacity planning, and event type eligibility in scheduling and ticketing systems.' ;
    rdfs:domain ind:Venue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wifiCapacityMbps rdf:type rdf:Property ;
    rdfs:label 'Wifi Capacity Mbps' ;
    rdfs:comment 'Total available Wi-Fi network bandwidth in megabits per second provisioned for the venue\'s public fan-facing network. Supports digital fan engagement platforms, mobile ticketing, OTT streaming, and DTC content delivery during events.' ;
    rdfs:domain ind:Venue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:yearBuilt rdf:type rdf:Property ;
    rdfs:label 'Year Built' ;
    rdfs:comment 'Four-digit calendar year in which the venue was originally constructed and opened. Used for asset depreciation scheduling in SAP FI/CO, capital planning, and historical context in broadcast storytelling.' ;
    rdfs:domain ind:Venue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:yearLastRenovated rdf:type rdf:Property ;
    rdfs:label 'Year Last Renovated' ;
    rdfs:comment 'Four-digit calendar year of the most recent significant capital renovation or refurbishment of the venue. Used in asset lifecycle management, capital expenditure planning, and ADA/OSHA compliance upgrade tracking.' ;
    rdfs:domain ind:Venue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accessibleRouteAvailable rdf:type rdf:Property ;
    rdfs:label 'Accessible Route Available' ;
    rdfs:comment 'Indicates whether a fully ADA-compliant accessible route (ramp, elevator, or level pathway) is available to reach this seating section from the main venue entrance. Required for ADA compliance documentation and fan accessibility communications.' ;
    rdfs:domain ind:Venue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:adaSeatCount rdf:type rdf:Property ;
    rdfs:label 'Ada Seat Count' ;
    rdfs:comment 'Number of seats within this section that are designated as ADA-compliant accessible positions, including wheelchair spaces and companion seats. Required for ADA compliance reporting and venue accessibility audits.' ;
    rdfs:domain ind:SeatingSection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:alcoholServicePermitted rdf:type rdf:Property ;
    rdfs:label 'Alcohol Service Permitted' ;
    rdfs:comment 'Indicates whether alcohol sales and service are permitted within this seating section. Driven by local liquor licensing, venue policy, and proximity to family or all-ages zones. Affects concessions planning and POS configuration.' ;
    rdfs:domain ind:SeatingSection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:archticsSectionCode rdf:type rdf:Property ;
    rdfs:label 'Archtics Section Code' ;
    rdfs:comment 'Native section identifier as assigned within the Archtics Venue Seating and Inventory Management system. Used for system-of-record reconciliation, data lineage tracking, and integration with Ticketmaster/AXS ticketing workflows.' ;
    rdfs:domain ind:SeatingSection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:broadcastCameraZone rdf:type rdf:Property ;
    rdfs:label 'Broadcast Camera Zone' ;
    rdfs:comment 'Indicates whether this seating section falls within a designated broadcast camera or production zone, which may restrict fan movement, signage, or attire during live broadcasts. Relevant for FCC broadcast compliance and OB (Outside Broadcast) production planning.' ;
    rdfs:domain ind:SeatingSection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:companionSeatCount rdf:type rdf:Property ;
    rdfs:label 'Companion Seat Count' ;
    rdfs:comment 'Number of companion seats adjacent to ADA wheelchair positions within this section. Required for ADA compliance to ensure accessible patrons can be accompanied. Distinct from total ADA seat count.' ;
    rdfs:domain ind:SeatingSection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:concourseLevel rdf:type rdf:Property ;
    rdfs:label 'Concourse Level' ;
    rdfs:comment 'Identifier of the concourse or service corridor level associated with this seating section (e.g., \'Main Concourse\', \'Club Concourse\', \'Upper Concourse\'). Used for concessions assignment, restroom mapping, and fan services logistics.' ;
    rdfs:domain ind:Venue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emergencyExitRoute rdf:type rdf:Property ;
    rdfs:label 'Emergency Exit Route' ;
    rdfs:comment 'Designated emergency evacuation route identifier or description for this seating section, as defined in the venue\'s life safety plan. Required for OSHA compliance, fire marshal approval, and event-day safety briefings.' ;
    rdfs:domain ind:SeatingSection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entryGateCode rdf:type rdf:Property ;
    rdfs:label 'Entry Gate Code' ;
    rdfs:comment 'Code identifying the primary entry gate or access point assigned to this seating section for fan ingress and egress. Used in access control configuration within Ticketmaster/AXS and for event-day crowd flow management.' ;
    rdfs:domain ind:SeatingSection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:floorLevelNumber rdf:type rdf:Property ;
    rdfs:label 'Floor Level Number' ;
    rdfs:comment 'Numeric floor or deck level within the venue structure where this section is physically located (e.g., 1 = ground/field level, 2 = concourse level, 3 = upper deck). Used for building management, emergency egress planning, and OSHA compliance.' ;
    rdfs:domain ind:SeatingSection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hearingLoopInstalled rdf:type rdf:Property ;
    rdfs:label 'Hearing Loop Installed' ;
    rdfs:comment 'Indicates whether an assistive listening hearing loop (induction loop) system is installed in this seating section to support patrons with hearing impairments. Required for ADA compliance and venue accessibility certification.' ;
    rdfs:domain ind:SeatingSection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hvacZoneCode rdf:type rdf:Property ;
    rdfs:label 'Hvac Zone Code' ;
    rdfs:comment 'Code identifying the HVAC climate control zone assigned to this seating section within the Building Management System (BMS). Used for environmental comfort management, energy efficiency reporting, and OSHA indoor air quality compliance.' ;
    rdfs:domain ind:Venue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCovered rdf:type rdf:Property ;
    rdfs:label 'Is Covered' ;
    rdfs:comment 'Indicates whether the seating section is covered by a roof, overhang, or canopy structure, providing weather protection for patrons. Relevant for outdoor venues and open-air stadiums; used in fan experience communications and premium pricing decisions.' ;
    rdfs:domain ind:SeatingSection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isIndoor rdf:type rdf:Property ;
    rdfs:label 'Is Indoor' ;
    rdfs:comment 'Indicates whether the seating section is located within a fully enclosed indoor environment (arena, indoor stadium). Distinct from is_covered which may apply to partially covered outdoor sections. Drives HVAC system assignment and environmental comfort planning.' ;
    rdfs:domain ind:SeatingSection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastInspectionDate rdf:type rdf:Property ;
    rdfs:label 'Last Inspection Date' ;
    rdfs:comment 'Date of the most recent structural or safety inspection conducted for this seating section. Required for OSHA compliance documentation and venue operational readiness certification prior to live events.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:levelName rdf:type rdf:Property ;
    rdfs:label 'Level Name' ;
    rdfs:comment 'Vertical bowl level designation indicating the physical tier of the venue where this section is located (e.g., field, lower bowl, club level, upper bowl, mezzanine, roof deck). Used for pricing, sightline analysis, and fan wayfinding.' ;
    rdfs:domain ind:SeatingSection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxEventCapacity rdf:type rdf:Property ;
    rdfs:label 'Max Event Capacity' ;
    rdfs:comment 'Maximum permitted occupancy for this section under applicable fire code, local authority, and OSHA safety regulations. May differ from total_capacity due to regulatory constraints, temporary staging, or reduced-capacity configurations for specific event types.' ;
    rdfs:domain ind:SeatingSection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:obstructedView rdf:type rdf:Property ;
    rdfs:label 'Obstructed View' ;
    rdfs:comment 'Indicates whether any seats in this section have a partially or fully obstructed sightline due to structural columns, equipment, or other physical barriers. Required for consumer disclosure compliance and ticket pricing adjustments.' ;
    rdfs:domain ind:SeatingSection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:premiumAmenityFlag rdf:type rdf:Property ;
    rdfs:label 'Premium Amenity Flag' ;
    rdfs:comment 'Indicates whether this section includes premium amenities such as in-seat food and beverage service, dedicated wait staff, private restrooms, or exclusive lounge access. Used for premium product packaging, sponsorship activation, and VIP fan experience design.' ;
    rdfs:domain ind:SeatingSection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rowCount rdf:type rdf:Property ;
    rdfs:label 'Row Count' ;
    rdfs:comment 'Total number of physical rows within the seating section. Used for capacity planning, seat mapping, and inventory configuration in Archtics. Not applicable (null) for GA or SRO sections.' ;
    rdfs:domain ind:SeatingSection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rowLabelEnd rdf:type rdf:Property ;
    rdfs:label 'Row Label End' ;
    rdfs:comment 'Label of the last row in this seating section as printed on tickets and venue maps (e.g., \'Z\', \'30\', \'ZZ\'). Used alongside row_label_start to define the full row range for seat map configuration.' ;
    rdfs:domain ind:SeatingSection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rowLabelStart rdf:type rdf:Property ;
    rdfs:label 'Row Label Start' ;
    rdfs:comment 'Label of the first row in this seating section as printed on tickets and venue maps (e.g., \'A\', \'1\', \'AA\'). Used for seat map rendering and fan wayfinding in Archtics and Ticketmaster/AXS.' ;
    rdfs:domain ind:SeatingSection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seasonTicketEligible rdf:type rdf:Property ;
    rdfs:label 'Season Ticket Eligible' ;
    rdfs:comment 'Indicates whether seats in this section are eligible for season ticket packages and multi-game subscription products. Drives season ticket inventory allocation in Archtics and Ticketmaster/AXS.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:seatsPerRow rdf:type rdf:Property ;
    rdfs:label 'Seats Per Row' ;
    rdfs:comment 'Standard number of seats in each row of the section. May vary by row; this field captures the modal or configured default value used for capacity calculations. Null for variable-row or GA sections.' ;
    rdfs:domain ind:SeatingSection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sectionName rdf:type rdf:Property ;
    rdfs:label 'Section Name' ;
    rdfs:comment 'Human-readable display name of the seating section as presented to fans on tickets, venue maps, and digital platforms (e.g., \'Lower Bowl Section 101\', \'Club Level East\', \'North End Zone\').' ;
    rdfs:domain ind:SeatingSection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sectionNotes rdf:type rdf:Property ;
    rdfs:label 'Section Notes' ;
    rdfs:comment 'Free-text operational notes or remarks about this seating section, such as temporary restrictions, special configurations, or event-specific instructions. Used by venue operations staff for event-day logistics and facility management.' ;
    rdfs:domain ind:SeatingSection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sectionOrientation rdf:type rdf:Property ;
    rdfs:label 'Section Orientation' ;
    rdfs:comment 'Cardinal or relative directional orientation of the seating section within the venue bowl (e.g., north end zone, south sideline, east corner). Used for wayfinding, broadcast camera positioning, and sun/shadow exposure analysis for outdoor venues. [ENUM-REF-CANDIDATE: north|south|east|west|northeast|northwest|southeast|southwest|center — promote to reference product]' ;
    rdfs:domain ind:SeatingSection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sectionStatus rdf:type rdf:Property ;
    rdfs:label 'Section Status' ;
    rdfs:comment 'Current operational lifecycle status of the seating section. Active: available for ticketing and event assignment; Inactive: temporarily unavailable; Under Renovation: physically inaccessible due to construction; Decommissioned: permanently removed from inventory; Seasonal: available only during specific seasons or event types.' ;
    rdfs:domain ind:SeatingSection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sectionType rdf:type rdf:Property ;
    rdfs:label 'Section Type' ;
    rdfs:comment 'Operational classification of the seating section by access and seating arrangement. Reserved: assigned seats; General Admission (GA): open floor/standing; Standing Room Only (SRO): no fixed seats; Suite: premium enclosed box; Accessible: ADA-compliant designated area; Press: media/broadcast credential holders; VIP: premium hospitality. [ENUM-REF-CANDIDATE: reserved|general_admission|sro|suite|accessible|press|vip — promote to reference product]' ;
    rdfs:domain ind:SeatingSection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sightlineRating rdf:type rdf:Property ;
    rdfs:label 'Sightline Rating' ;
    rdfs:comment 'Numeric quality score (e.g., 1.0–10.0) representing the quality of the view from this section to the primary event surface (field, stage, court, ice). Derived from venue geometry and used in pricing strategy, fan experience scoring, and premium product differentiation.' ;
    rdfs:domain ind:SeatingSection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:smokingPermitted rdf:type rdf:Property ;
    rdfs:label 'Smoking Permitted' ;
    rdfs:comment 'Indicates whether smoking or vaping is permitted within this seating section. Governed by local ordinances, venue policy, and OSHA indoor air quality standards. Used for fan communications and compliance documentation.' ;
    rdfs:domain ind:SeatingSection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:suiteCapacity rdf:type rdf:Property ;
    rdfs:label 'Suite Capacity' ;
    rdfs:comment 'Maximum occupancy of the private suite or box associated with this section, applicable only when section_type is \'suite\'. Includes both seated and standing reception capacity. Used for suite licensing agreements and hospitality event planning.' ;
    rdfs:domain ind:Venue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:wifiZoneCode rdf:type rdf:Property ;
    rdfs:label 'Wifi Zone Code' ;
    rdfs:comment 'Identifier of the wireless network access zone covering this seating section. Used for digital platform connectivity planning, fan engagement app performance monitoring, and Adobe Experience Platform audience activation.' ;
    rdfs:domain ind:SeatingSection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accessibilityFeatures rdf:type rdf:Property ;
    rdfs:label 'Accessibility Features' ;
    rdfs:comment 'Free-text description of specific accessibility accommodations available at or near this seat, such as hearing loop proximity, assistive listening device availability, or transfer seat specifications. Supports ADA compliance documentation and fan service.' ;
    rdfs:domain ind:Seat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:colorCode rdf:type rdf:Property ;
    rdfs:label 'Color Code' ;
    rdfs:comment 'Hexadecimal color code of the seat\'s upholstery or shell, used for venue mapping visualizations, brand compliance, and replacement procurement matching.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:condition rdf:type rdf:Property ;
    rdfs:label 'Condition' ;
    rdfs:comment 'Current physical condition of the seat hardware (frame, cushion, armrests, cup holder). Used for maintenance prioritization, capital expenditure planning, and fan experience quality management.' ;
    rdfs:domain ind:Seat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:elevationM rdf:type rdf:Property ;
    rdfs:label 'Elevation M' ;
    rdfs:comment 'Vertical elevation of the seat above the playing field or stage floor level, measured in meters. Used for sightline quality scoring, broadcast camera planning, and premium seat valuation.' ;
    rdfs:domain ind:Seat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:entryGate rdf:type rdf:Property ;
    rdfs:label 'Entry Gate' ;
    rdfs:comment 'The recommended or assigned entry gate or turnstile through which a fan holding a ticket for this seat should enter the venue. Used for access control routing, crowd flow management, and fan experience optimization.' ;
    rdfs:domain ind:Seat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gaAreaCode rdf:type rdf:Property ;
    rdfs:label 'Ga Area Code' ;
    rdfs:comment 'For General Admission (GA) or Standing Room Only (SRO) areas, the code identifying the GA zone to which this inventory record belongs. Null for reserved seating. Used to manage GA capacity and access control.' ;
    rdfs:domain ind:Seat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hasCupholder rdf:type rdf:Property ;
    rdfs:label 'Has Cupholder' ;
    rdfs:comment 'Indicates whether this seat is equipped with a built-in cup holder. True = cup holder present; False = no cup holder. Used for fan amenity reporting and concessions upsell targeting.' ;
    rdfs:domain ind:Seat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hasPowerOutlet rdf:type rdf:Property ;
    rdfs:label 'Has Power Outlet' ;
    rdfs:comment 'Indicates whether this seat has an accessible power outlet or USB charging port. True = power outlet available; False = no power outlet. Relevant for premium and club-level seat differentiation and fan engagement platform connectivity.' ;
    rdfs:domain ind:Seat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:installDate rdf:type rdf:Property ;
    rdfs:label 'Install Date' ;
    rdfs:comment 'Date on which this seat was physically installed in the venue. Used for asset lifecycle management, warranty tracking, and capital expenditure depreciation schedules.' ;
    rdfs:domain ind:Seat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isAda rdf:type rdf:Property ;
    rdfs:label 'Is Ada' ;
    rdfs:comment 'Indicates whether this seat is designated as an ADA-compliant accessible space (wheelchair space or transfer seat) per Americans with Disabilities Act requirements. True = ADA-designated; False = standard seat. Critical for regulatory compliance reporting and accessible inventory management.' ;
    rdfs:domain ind:Seat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isAisle rdf:type rdf:Property ;
    rdfs:label 'Is Aisle' ;
    rdfs:comment 'Indicates whether this seat is positioned directly adjacent to an aisle, providing easier ingress/egress. True = aisle seat; False = non-aisle seat. Used for premium seat selection, accessibility routing, and emergency egress planning.' ;
    rdfs:domain ind:Seat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isCompanion rdf:type rdf:Property ;
    rdfs:label 'Is Companion' ;
    rdfs:comment 'Indicates whether this seat is designated as a companion seat immediately adjacent to an ADA accessible space, reserved for a companion of a wheelchair user. True = companion seat; False = not a companion seat. Required for ADA compliance inventory tracking.' ;
    rdfs:domain ind:Seat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isKill rdf:type rdf:Property ;
    rdfs:label 'Is Kill' ;
    rdfs:comment 'Indicates whether this seat is permanently structurally unavailable and must never be sold or activated. Kill seats arise from structural obstructions, safety requirements, or permanent equipment installations. True = kill seat; False = not a kill seat.' ;
    rdfs:domain ind:Seat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPremium rdf:type rdf:Property ;
    rdfs:label 'Is Premium' ;
    rdfs:comment 'Indicates whether this seat is classified as a premium inventory seat (club, loge, courtside, field-level, or VIP designation) commanding a premium price tier. True = premium; False = standard. Drives revenue management and sponsorship inventory reporting.' ;
    rdfs:domain ind:Seat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:manifestCode rdf:type rdf:Property ;
    rdfs:label 'Manifest Code' ;
    rdfs:comment 'The Archtics manifest identifier that governs this seat\'s configuration, pricing, and availability rules for a given event or season. A venue may have multiple manifests (e.g., hockey vs. basketball configurations in a multi-sport arena).' ;
    rdfs:domain ind:Seat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextInspectionDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Inspection Due Date' ;
    rdfs:comment 'Scheduled date by which the next physical inspection of this seat must be completed to maintain OSHA and venue safety compliance. Drives preventive maintenance scheduling.' ;
    rdfs:domain ind:Seat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:seatCode rdf:type rdf:Property ;
    rdfs:label 'Seat Code' ;
    rdfs:comment 'Externally-known alphanumeric code that uniquely identifies the seat within its section, as printed on a ticket or displayed on a seat placard. Corresponds to the Archtics seat identifier used in Ticketmaster/AXS ticketing workflows.' ;
    rdfs:domain ind:Seat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seatType rdf:type rdf:Property ;
    rdfs:label 'Seat Type' ;
    rdfs:comment 'Classification of the seat by its physical configuration and service tier. Drives pricing, accessibility compliance, and inventory allocation rules. Values: standard (general bowl seat), accessible (ADA wheelchair space), companion (adjacent to accessible space for a companion), premium (club/loge/VIP seat), stool (bar-height stool in standing/lounge areas), suite (private suite seat).' ;
    rdfs:domain ind:Seat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sequence rdf:type rdf:Property ;
    rdfs:label 'Sequence' ;
    rdfs:comment 'Numeric ordinal position of the seat within the row, used for physical layout ordering and adjacent-seat grouping logic in ticketing systems.' ;
    rdfs:domain ind:Seat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sightlineQuality rdf:type rdf:Property ;
    rdfs:label 'Sightline Quality' ;
    rdfs:comment 'Qualitative rating of the seat\'s sightline to the primary viewing area (field, stage, or court), derived from physical geometry and obstruction analysis. Used for pricing, fan experience design, and ticket disclosure requirements.' ;
    rdfs:domain ind:Seat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:xCoordinate rdf:type rdf:Property ;
    rdfs:label 'X Coordinate' ;
    rdfs:comment 'Horizontal Cartesian coordinate of the seat\'s physical position within the venue floor plan, measured in meters from a defined venue origin point. Used for venue mapping, sightline analysis, and digital twin applications.' ;
    rdfs:domain ind:Seat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:yCoordinate rdf:type rdf:Property ;
    rdfs:label 'Y Coordinate' ;
    rdfs:comment 'Vertical Cartesian coordinate of the seat\'s physical position within the venue floor plan, measured in meters from a defined venue origin point. Used for venue mapping, sightline analysis, and spatial analytics.' ;
    rdfs:domain ind:Seat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:accessibleCapacity rdf:type rdf:Property ;
    rdfs:label 'Accessible Capacity' ;
    rdfs:comment 'Number of ADA-compliant accessible seating positions designated within this configuration, including wheelchair spaces and companion seats. Mandatory for ADA compliance reporting.' ;
    rdfs:domain ind:CapacityConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:adaComplianceVerified rdf:type rdf:Property ;
    rdfs:label 'Ada Compliance Verified' ;
    rdfs:comment 'Indicates whether this capacity configuration has been formally verified as compliant with ADA (Americans with Disabilities Act) accessible seating requirements, including minimum accessible seat ratios and companion seat placement.' ;
    rdfs:domain ind:CapacityConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:archticsConfigCode rdf:type rdf:Property ;
    rdfs:label 'Archtics Config Code' ;
    rdfs:comment 'Source system identifier for this capacity configuration as recorded in the Archtics Venue Seating and Inventory Management system. Used for system-of-record reconciliation and data lineage tracing.' ;
    rdfs:domain ind:CapacityConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bowlOrientation rdf:type rdf:Property ;
    rdfs:label 'Bowl Orientation' ;
    rdfs:comment 'Describes which sections of the seating bowl are open and in use for this configuration. Drives section-level inventory activation in Archtics and determines sightline-based kill-seat patterns.' ;
    rdfs:domain ind:CapacityConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:broadcastCameraPositions rdf:type rdf:Property ;
    rdfs:label 'Broadcast Camera Positions' ;
    rdfs:comment 'Number of designated broadcast camera positions activated within this capacity configuration. Impacts kill-seat counts and sightline planning; relevant to OB (Outside Broadcast) and RSN (Regional Sports Network) production requirements.' ;
    rdfs:domain ind:CapacityConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:complimentaryHoldCount rdf:type rdf:Property ;
    rdfs:label 'Complimentary Hold Count' ;
    rdfs:comment 'Number of seats held as complimentary allocations for athletes, staff, sponsors, and league officials under this configuration. Reduces sellable inventory and is tracked for financial reporting and CBA (Collective Bargaining Agreement) compliance.' ;
    rdfs:domain ind:CapacityConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:configCode rdf:type rdf:Property ;
    rdfs:label 'Config Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying this capacity configuration within the venue management system (e.g., \'FULL-BOWL-SPORTS\', \'END-STAGE-CONCERT\'). Used as the business key in Archtics and Ticketmaster/AXS integrations.' ;
    rdfs:domain ind:CapacityConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:configDescription rdf:type rdf:Property ;
    rdfs:label 'Config Description' ;
    rdfs:comment 'Detailed narrative describing the purpose, layout rationale, and operational context of this capacity configuration, including any special setup notes for event-day logistics.' ;
    rdfs:domain ind:CapacityConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:configName rdf:type rdf:Property ;
    rdfs:label 'Config Name' ;
    rdfs:comment 'Human-readable name describing the capacity configuration profile (e.g., \'Full Bowl — NFL Game\', \'End-Stage Concert\', \'Half-House Theater\'). Used in operational scheduling and event planning workflows.' ;
    rdfs:domain ind:CapacityConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:configStatus rdf:type rdf:Property ;
    rdfs:label 'Config Status' ;
    rdfs:comment 'Current lifecycle state of the capacity configuration. \'active\' indicates the configuration is approved and available for event assignment; \'draft\' indicates it is under review; \'archived\' indicates it is retired from use.' ;
    rdfs:domain ind:CapacityConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fieldFloorCapacity rdf:type rdf:Property ;
    rdfs:label 'Field Floor Capacity' ;
    rdfs:comment 'Number of positions allocated on the field, floor, or stage-adjacent area for this configuration. Includes floor-level VIP (Very Important Person) standing, pit areas, and on-field hospitality zones.' ;
    rdfs:domain ind:CapacityConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fireCodeApproved rdf:type rdf:Property ;
    rdfs:label 'Fire Code Approved' ;
    rdfs:comment 'Indicates whether this capacity configuration has received fire marshal or local authority approval confirming that egress paths, aisle widths, and occupancy limits meet applicable fire safety codes.' ;
    rdfs:domain ind:CapacityConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:floorPlanVersion rdf:type rdf:Property ;
    rdfs:label 'Floor Plan Version' ;
    rdfs:comment 'Version identifier of the venue floor plan drawing associated with this capacity configuration (e.g., \'v3.2\'). Ensures traceability to the approved architectural drawing used for seating layout.' ;
    rdfs:domain ind:CapacityConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gaCapacity rdf:type rdf:Property ;
    rdfs:label 'Ga Capacity' ;
    rdfs:comment 'Number of General Admission (GA) standing or unreserved floor positions allocated within this configuration. Used for festival-style and floor-level event formats.' ;
    rdfs:domain ind:CapacityConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:killSeatCount rdf:type rdf:Property ;
    rdfs:label 'Kill Seat Count' ;
    rdfs:comment 'Number of seats removed from sellable inventory (\'killed\') in this configuration due to obstructed sightlines, staging equipment, production rigging, or operational requirements. Reduces effective sellable capacity from total configured capacity.' ;
    rdfs:domain ind:CapacityConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:leagueApproved rdf:type rdf:Property ;
    rdfs:label 'League Approved' ;
    rdfs:comment 'Indicates whether this capacity configuration has been formally approved by the relevant league or governing body (e.g., NFL, NBA, FIFA) as meeting minimum venue standards for sanctioned competition.' ;
    rdfs:domain ind:CapacityConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maxOccupancyLimit rdf:type rdf:Property ;
    rdfs:label 'Max Occupancy Limit' ;
    rdfs:comment 'Regulatory or fire-code maximum occupancy limit for the venue under this configuration as certified by local authorities. May differ from total configured capacity and governs hard attendance caps for safety compliance.' ;
    rdfs:domain ind:CapacityConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:operationalHoldCount rdf:type rdf:Property ;
    rdfs:label 'Operational Hold Count' ;
    rdfs:comment 'Number of seats withheld from sale for operational purposes such as security personnel, event staff, emergency egress, and venue operations under this configuration.' ;
    rdfs:domain ind:CapacityConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:parkingSpacesAllocated rdf:type rdf:Property ;
    rdfs:label 'Parking Spaces Allocated' ;
    rdfs:comment 'Total number of parking spaces designated for patron use under this capacity configuration, including accessible parking. Used in event-day logistics, traffic management, and ancillary revenue planning.' ;
    rdfs:domain ind:CapacityConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pressMediaCapacity rdf:type rdf:Property ;
    rdfs:label 'Press Media Capacity' ;
    rdfs:comment 'Number of credentialed press, broadcast, and media positions allocated within this configuration, including press box, commentary positions, and camera platforms.' ;
    rdfs:domain ind:CapacityConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reducedCapacityPct rdf:type rdf:Property ;
    rdfs:label 'Reduced Capacity Pct' ;
    rdfs:comment 'Percentage of total configured capacity at which this configuration operates when a reduced-capacity mode is in effect (e.g., public health restrictions, partial-fill events, or socially distanced seating). Expressed as a decimal percentage (e.g., 50.00 for 50%).' ;
    rdfs:domain ind:CapacityConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reservedSeatingCapacity rdf:type rdf:Property ;
    rdfs:label 'Reserved Seating Capacity' ;
    rdfs:comment 'Number of individually assigned reserved seats available in this configuration, excluding suites, accessible, press, and field/floor allocations. Core inventory for standard ticket sales.' ;
    rdfs:domain ind:CapacityConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:seatingMode rdf:type rdf:Property ;
    rdfs:label 'Seating Mode' ;
    rdfs:comment 'Physical seating arrangement mode for this configuration. \'fixed\' indicates permanent bowl seating; \'festival\' indicates floor-level General Admission (GA) standing; \'retractable\' indicates use of retractable seating sections; \'portable\' indicates temporary staging.' ;
    rdfs:domain ind:CapacityConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sellableCapacity rdf:type rdf:Property ;
    rdfs:label 'Sellable Capacity' ;
    rdfs:comment 'Net number of ticketable positions available for public sale under this configuration, calculated as total configured capacity minus kill seats, operational holds, and complimentary allocations. The operative figure for revenue management and ticket inventory.' ;
    rdfs:domain ind:CapacityConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:setupDurationHours rdf:type rdf:Property ;
    rdfs:label 'Setup Duration Hours' ;
    rdfs:comment 'Estimated number of hours required to physically configure the venue to match this capacity configuration (e.g., installing portable seating, rigging stage, repositioning retractable sections). Used in event-day logistics and venue scheduling.' ;
    rdfs:domain ind:CapacityConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sroCapacity rdf:type rdf:Property ;
    rdfs:label 'Sro Capacity' ;
    rdfs:comment 'Number of Standing Room Only (SRO) positions available in this configuration, typically in concourse or designated standing areas beyond the primary seating bowl.' ;
    rdfs:domain ind:CapacityConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:stageConfiguration rdf:type rdf:Property ;
    rdfs:label 'Stage Configuration' ;
    rdfs:comment 'Physical stage layout used in this capacity configuration, which directly determines seating bowl shape and kill-seat patterns. \'end_stage\' is standard for concerts; \'center_stage\' for boxing/UFC; \'none\' for sports without a stage. [ENUM-REF-CANDIDATE: none|end_stage|center_stage|thrust|in_the_round|half_house|traverse — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CapacityConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:teardownDurationHours rdf:type rdf:Property ;
    rdfs:label 'Teardown Duration Hours' ;
    rdfs:comment 'Estimated number of hours required to dismantle and restore the venue from this capacity configuration back to a neutral state. Critical for back-to-back event scheduling and venue turnaround planning.' ;
    rdfs:domain ind:CapacityConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ticketmasterManifestCode rdf:type rdf:Property ;
    rdfs:label 'Ticketmaster Manifest Code' ;
    rdfs:comment 'Identifier of the seating manifest in the Ticketmaster / AXS ticketing platform that corresponds to this capacity configuration. Enables direct linkage between capacity setup and ticket inventory manifests.' ;
    rdfs:domain ind:CapacityConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalConfiguredCapacity rdf:type rdf:Property ;
    rdfs:label 'Total Configured Capacity' ;
    rdfs:comment 'Total number of seats or standing positions available under this configuration. Represents the principal quantitative fact for this resource and is the master capacity figure used in ticketing inventory allocation and revenue management.' ;
    rdfs:domain ind:CapacityConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:vipCapacity rdf:type rdf:Property ;
    rdfs:label 'Vip Capacity' ;
    rdfs:comment 'Number of premium VIP (Very Important Person) positions designated in this configuration, covering club-level seats, hospitality lounges, and premium floor access beyond standard suite allocations.' ;
    rdfs:domain ind:CapacityConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:parkingLotId rdf:type rdf:Property ;
    rdfs:label 'Parking Lot Id' ;
    rdfs:comment 'Unique surrogate identifier for each parking lot or parking facility record in the venue domain. Primary key for the parking_lot master resource.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ParkingLot .

ind:entryScreeningCheckpointId rdf:type rdf:Property ;
    rdfs:label 'Entry Screening Checkpoint Id' ;
    rdfs:comment 'Foreign key linking to security.screening_checkpoint. Business justification: Vehicle entry screening checkpoints serve specific parking lots. Security operations and staffing plans need to know which screening checkpoint controls entry to each parking lot for vehicle credentia' ;
    rdfs:domain ind:ParkingLot ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ScreeningCheckpoint .

ind:accessControlType rdf:type rdf:Property ;
    rdfs:label 'Access Control Type' ;
    rdfs:comment 'Method used to control vehicle entry and exit at this parking lot: open (no control), ticket_scan (barcode/QR scan via Ticketmaster/AXS), permit_display (visual permit check), license_plate_recognition (automated LPR system), rfid (RFID transponder-based access).' ;
    rdfs:domain ind:ParkingLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accessibleSpaces rdf:type rdf:Property ;
    rdfs:label 'Accessible Spaces' ;
    rdfs:comment 'Number of parking spaces designated for persons with disabilities in compliance with ADA requirements. Used for ADA compliance reporting and event-day accessibility planning.' ;
    rdfs:domain ind:ParkingLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:baseEventRate rdf:type rdf:Property ;
    rdfs:label 'Base Event Rate' ;
    rdfs:comment 'Standard per-event parking fee charged to general patrons for this lot, expressed in the venue\'s operating currency. Used as the baseline for dynamic pricing calculations and revenue forecasting.' ;
    rdfs:domain ind:ParkingLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bmsZoneCode rdf:type rdf:Property ;
    rdfs:label 'Bms Zone Code' ;
    rdfs:comment 'Zone identifier within the venue\'s Building Management System (BMS) that monitors environmental and operational systems for this parking facility (e.g., lighting controls, barrier systems, HVAC in garages).' ;
    rdfs:domain ind:ParkingLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capacityLastVerifiedDate rdf:type rdf:Property ;
    rdfs:label 'Capacity Last Verified Date' ;
    rdfs:comment 'Date on which the total space count and space-type breakdown for this parking lot was last physically verified or audited. Ensures accuracy of capacity data used in event-day logistics and ADA compliance reporting.' ;
    rdfs:domain ind:ParkingLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:closureDate rdf:type rdf:Property ;
    rdfs:label 'Closure Date' ;
    rdfs:comment 'Date on which this parking lot was permanently closed or decommissioned. Null if the lot is still operational. Supports asset lifecycle management and historical reporting.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:covered rdf:type rdf:Property ;
    rdfs:label 'Covered' ;
    rdfs:comment 'Indicates whether the parking lot or garage provides overhead cover/shelter for vehicles. Relevant for premium pricing differentiation and fan experience communications.' ;
    rdfs:domain ind:ParkingLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:distanceFromEntranceM rdf:type rdf:Property ;
    rdfs:label 'Distance From Entrance M' ;
    rdfs:comment 'Measured walking distance in meters from the nearest lot entry point to the venue\'s main public entrance. Used for fan wayfinding, ADA accessibility assessments, and shuttle route planning.' ;
    rdfs:domain ind:ParkingLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:evChargingSpaces rdf:type rdf:Property ;
    rdfs:label 'Ev Charging Spaces' ;
    rdfs:comment 'Number of parking spaces equipped with electric vehicle (EV) charging stations. Supports sustainability reporting, fan amenity communications, and ISO 20121 event sustainability management.' ;
    rdfs:domain ind:ParkingLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastAdaInspectionDate rdf:type rdf:Property ;
    rdfs:label 'Last Ada Inspection Date' ;
    rdfs:comment 'Date of the most recent ADA accessibility compliance inspection conducted for this parking lot. Supports regulatory audit trails and proactive compliance management.' ;
    rdfs:domain ind:ParkingLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastSafetyInspectionDate rdf:type rdf:Property ;
    rdfs:label 'Last Safety Inspection Date' ;
    rdfs:comment 'Date of the most recent OSHA safety inspection or internal safety audit conducted for this parking lot. Required for venue safety compliance documentation.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lightingType rdf:type rdf:Property ;
    rdfs:label 'Lighting Type' ;
    rdfs:comment 'Type of lighting infrastructure installed in the parking lot. Relevant for OSHA safety compliance, energy management, and ISO 20121 sustainability reporting.' ;
    rdfs:domain ind:ParkingLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lotCode rdf:type rdf:Property ;
    rdfs:label 'Lot Code' ;
    rdfs:comment 'Externally-known alphanumeric short code uniquely identifying the parking lot within the venue (e.g., \'NGA\', \'VIP-A\', \'RSL-03\'). Used on signage, ticketing systems, and access control.' ;
    rdfs:domain ind:ParkingLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lotName rdf:type rdf:Property ;
    rdfs:label 'Lot Name' ;
    rdfs:comment 'Human-readable name of the parking lot as displayed to fans and operations staff (e.g., \'North Garage\', \'VIP Lot A\', \'Remote Shuttle Lot 3\').' ;
    rdfs:domain ind:ParkingLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lotType rdf:type rdf:Property ;
    rdfs:label 'Lot Type' ;
    rdfs:comment 'Categorical classification of the parking facility structure and service tier: surface (open-air flat lot), garage (multi-level structured parking), remote (off-site shuttle-served lot), vip (premium reserved lot), accessible (ADA-designated accessible parking area).' ;
    rdfs:domain ind:ParkingLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:openDate rdf:type rdf:Property ;
    rdfs:label 'Open Date' ;
    rdfs:comment 'Date on which this parking lot was first opened for operational use. Supports asset lifecycle management and depreciation tracking in SAP S/4HANA Fixed Assets.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oversizedSpaces rdf:type rdf:Property ;
    rdfs:label 'Oversized Spaces' ;
    rdfs:comment 'Number of spaces designated for oversized vehicles such as buses, RVs, and trailers. Relevant for tailgating event planning and large-vehicle logistics.' ;
    rdfs:domain ind:ParkingLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:preSaleAvailable rdf:type rdf:Property ;
    rdfs:label 'Pre Sale Available' ;
    rdfs:comment 'Indicates whether parking spaces in this lot can be purchased in advance through online or DTC (Direct-To-Consumer) ticketing channels prior to event day.' ;
    rdfs:domain ind:ParkingLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reservedSpaces rdf:type rdf:Property ;
    rdfs:label 'Reserved Spaces' ;
    rdfs:comment 'Number of spaces pre-allocated for season ticket holders, sponsors, VIP guests, or other reserved parking programs. Supports Ticketmaster/AXS parking inventory management.' ;
    rdfs:domain ind:ParkingLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:seasonPassEligible rdf:type rdf:Property ;
    rdfs:label 'Season Pass Eligible' ;
    rdfs:comment 'Indicates whether this parking lot accepts season parking passes or annual parking permits. Drives eligibility logic in Ticketmaster/AXS access control and CRM entitlement management.' ;
    rdfs:domain ind:ParkingLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:shuttleRouteCode rdf:type rdf:Property ;
    rdfs:label 'Shuttle Route Code' ;
    rdfs:comment 'Identifier for the shuttle bus route assigned to service this parking lot. Populated only when shuttle_served is True. Used for event-day logistics coordination and fan communications.' ;
    rdfs:domain ind:ParkingLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shuttleServed rdf:type rdf:Property ;
    rdfs:label 'Shuttle Served' ;
    rdfs:comment 'Indicates whether this parking lot is served by a shuttle bus service transporting patrons to and from the venue. Relevant for remote lot operations and fan experience planning.' ;
    rdfs:domain ind:ParkingLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:totalSpaces rdf:type rdf:Property ;
    rdfs:label 'Total Spaces' ;
    rdfs:comment 'Total number of vehicle parking spaces in the lot, including all space types (standard, accessible, EV, VIP, oversized). Principal capacity metric for event-day logistics and revenue planning.' ;
    rdfs:domain ind:ParkingLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maintenanceWorkOrderId rdf:type rdf:Property ;
    rdfs:label 'Maintenance Work Order Id' ;
    rdfs:comment 'Unique surrogate identifier for the maintenance work order record in the Silver Layer lakehouse. Primary key for this entity. Role: TRANSACTION_HEADER.' ;
    rdfs:domain ind:MaintenanceWorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accessibilityFeatureId rdf:type rdf:Property ;
    rdfs:label 'Accessibility Feature Id' ;
    rdfs:comment 'Foreign key linking to venue.accessibility_feature. Business justification: ADA accessibility features (wheelchair ramps, elevators, hearing loops) require regular maintenance and compliance-driven repair work orders. accessibility_feature has last_maintenance_date, next_main' ;
    rdfs:domain ind:Venue ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AccessibilityFeature .

ind:auditFindingId rdf:type rdf:Property ;
    rdfs:label 'Audit Finding Id' ;
    rdfs:comment 'Foreign key linking to compliance.audit_finding. Business justification: Compliance audit findings (ADA non-conformance, fire safety deficiencies) generate corrective-action maintenance work orders. Linking the work order to the triggering audit_finding enables auditors to' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AuditFinding .

ind:concessionStandId rdf:type rdf:Property ;
    rdfs:label 'Concession Stand Id' ;
    rdfs:comment 'Foreign key linking to venue.concession_stand. Business justification: Maintenance work orders are performed on specific physical assets within a facility. Concession stands require regular maintenance (equipment servicing, fire suppression system checks, POS terminal ma' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ConcessionStand .

ind:primaryMaintenanceEventFixtureId rdf:type rdf:Property ;
    rdfs:label 'Primary Maintenance Event Fixture Id' ;
    rdfs:comment 'Reference to the live event (game, concert, or show) associated with this work order, if the maintenance is event-driven or must be completed before a specific event. Supports event-day readiness tracking and operational risk management.' ;
    rdfs:domain ind:MaintenanceWorkOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Fixture .

ind:triggeringSafetyIncidentId rdf:type rdf:Property ;
    rdfs:label 'Triggering Safety Incident Id' ;
    rdfs:comment 'Foreign key linking to venue.safety_incident. Business justification: Safety incidents frequently trigger corrective maintenance work orders (e.g., a fan injury due to a broken seat triggers a repair work order). This FK on maintenance_work_order references the safety_i' ;
    rdfs:domain ind:MaintenanceWorkOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SafetyIncident .

ind:triggeringSafetyInspectionId rdf:type rdf:Property ;
    rdfs:label 'Triggering Safety Inspection Id' ;
    rdfs:comment 'Foreign key linking to venue.safety_inspection. Business justification: Safety inspections with corrective_actions_required=TRUE generate maintenance work orders to remediate findings. This FK on maintenance_work_order references the safety_inspection that identified the ' ;
    rdfs:domain ind:MaintenanceWorkOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SafetyInspection .

ind:actualCost rdf:type rdf:Property ;
    rdfs:label 'Actual Cost' ;
    rdfs:comment 'Total actual cost incurred for the maintenance work order including confirmed labor, goods issued from inventory, and external service charges, as settled in SAP PM/CO. Used for budget variance reporting and EBITDA impact analysis.' ;
    rdfs:domain ind:MaintenanceWorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualLaborHours rdf:type rdf:Property ;
    rdfs:label 'Actual Labor Hours' ;
    rdfs:comment 'Actual number of labor hours recorded by the technician upon work order confirmation in SAP PM. Used for variance analysis against estimated hours, payroll costing, and productivity KPI reporting.' ;
    rdfs:domain ind:MaintenanceWorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assetSystemCategory rdf:type rdf:Property ;
    rdfs:label 'Asset System Category' ;
    rdfs:comment 'High-level categorization of the venue infrastructure system or asset type being maintained. Supports maintenance trend analysis by system type and regulatory compliance reporting. HVAC: Heating Ventilation and Air Conditioning. BMS: Building Management System. [ENUM-REF-CANDIDATE: hvac|bms|electrical|plumbing|structural|seating|concessions|av_systems|security|parking|lighting — promote to reference product]' ;
    rdfs:domain ind:MaintenanceWorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:completionNotes rdf:type rdf:Property ;
    rdfs:label 'Completion Notes' ;
    rdfs:comment 'Free-text field capturing the technician\'s observations, findings, and actions taken upon completion of the work order. Includes any deviations from the planned scope, follow-up recommendations, or residual risks identified during execution.' ;
    rdfs:domain ind:MaintenanceWorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:damageCode rdf:type rdf:Property ;
    rdfs:label 'Damage Code' ;
    rdfs:comment 'Standardized SAP PM catalog code describing the type of damage observed on the asset (e.g., corrosion, fracture, leakage, contamination). Used in conjunction with failure code for root cause analysis and insurance claims.' ;
    rdfs:domain ind:MaintenanceWorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedCost rdf:type rdf:Property ;
    rdfs:label 'Estimated Cost' ;
    rdfs:comment 'Total planned cost of the maintenance work order including estimated labor, materials, and overhead charges, expressed in the local operating currency. Used for budget planning and cost center pre-commitment.' ;
    rdfs:domain ind:MaintenanceWorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedLaborHours rdf:type rdf:Property ;
    rdfs:label 'Estimated Labor Hours' ;
    rdfs:comment 'Planned number of labor hours required to complete the maintenance work order, as estimated during work order creation or planning. Used for resource capacity planning and budget estimation.' ;
    rdfs:domain ind:MaintenanceWorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:externalServiceCost rdf:type rdf:Property ;
    rdfs:label 'External Service Cost' ;
    rdfs:comment 'Cost of external contractor or vendor services procured via purchase order and charged to this work order. Relevant for specialized maintenance (e.g., elevator servicing, fire suppression systems) requiring licensed third-party contractors.' ;
    rdfs:domain ind:MaintenanceWorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:failureCode rdf:type rdf:Property ;
    rdfs:label 'Failure Code' ;
    rdfs:comment 'Standardized SAP PM catalog code identifying the root cause or failure mode of the defect that triggered a corrective or emergency work order (e.g., mechanical wear, electrical fault, vandalism). Enables failure mode analysis and reliability-centered maintenance (RCM) reporting.' ;
    rdfs:domain ind:MaintenanceWorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:functionalLocationCode rdf:type rdf:Property ;
    rdfs:label 'Functional Location Code' ;
    rdfs:comment 'SAP PM functional location identifier representing the hierarchical physical location within the venue where the work is performed (e.g., ARENA-01-HVAC-ZONE-B). Enables spatial analysis of maintenance activity across venue infrastructure.' ;
    rdfs:domain ind:MaintenanceWorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isAdaComplianceRelated rdf:type rdf:Property ;
    rdfs:label 'Is Ada Compliance Related' ;
    rdfs:comment 'Indicates whether this work order is related to Americans with Disabilities Act (ADA) accessibility compliance, such as repairs to accessible seating, ramps, elevators, or accessible restrooms. Flags orders requiring ADA compliance sign-off.' ;
    rdfs:domain ind:MaintenanceWorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSafetyCritical rdf:type rdf:Property ;
    rdfs:label 'Is Safety Critical' ;
    rdfs:comment 'Indicates whether this work order involves a safety-critical system or structural element where failure could pose risk to personnel, fans, or athletes. Safety-critical orders require expedited processing and mandatory sign-off per OSHA regulations.' ;
    rdfs:domain ind:MaintenanceWorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:notificationNumber rdf:type rdf:Property ;
    rdfs:label 'Notification Number' ;
    rdfs:comment 'SAP PM notification number associated with the defect or malfunction report that triggered this work order. Links the work order back to the originating fault notification for full traceability.' ;
    rdfs:domain ind:MaintenanceWorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partsCost rdf:type rdf:Property ;
    rdfs:label 'Parts Cost' ;
    rdfs:comment 'Actual cost of spare parts and materials consumed during the maintenance work order, as recorded through SAP MM goods issue against the order. Enables materials cost breakdown separate from labor costs.' ;
    rdfs:domain ind:MaintenanceWorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:partsUsedDescription rdf:type rdf:Property ;
    rdfs:label 'Parts Used Description' ;
    rdfs:comment 'Free-text or structured description of spare parts, materials, and consumables used during the maintenance activity. Includes part names, quantities, and SAP material numbers where applicable. Supports inventory replenishment and parts usage trend analysis.' ;
    rdfs:domain ind:MaintenanceWorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:permitToWorkNumber rdf:type rdf:Property ;
    rdfs:label 'Permit To Work Number' ;
    rdfs:comment 'Reference number of the formal permit to work (PTW) issued for this maintenance activity, required for high-risk tasks such as hot work, confined space entry, or electrical isolation. Mandatory for OSHA compliance documentation.' ;
    rdfs:domain ind:MaintenanceWorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorityLevel rdf:type rdf:Property ;
    rdfs:label 'Priority Level' ;
    rdfs:comment 'Business priority assigned to the work order indicating urgency of execution. Critical: immediate safety or event-day risk. High: must be resolved within 24 hours. Medium: within 7 days. Low: scheduled maintenance window. Drives technician dispatch sequencing and SLA compliance.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiresShutdown rdf:type rdf:Property ;
    rdfs:label 'Requires Shutdown' ;
    rdfs:comment 'Indicates whether execution of this work order requires a partial or full shutdown of a venue zone, system, or utility (e.g., power isolation, HVAC shutdown). Drives coordination with venue operations and event scheduling teams.' ;
    rdfs:domain ind:MaintenanceWorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:signOffTimestamp rdf:type rdf:Property ;
    rdfs:label 'Sign Off Timestamp' ;
    rdfs:comment 'Date and time when the facility manager formally reviewed and signed off on the completed work order, confirming the work meets quality and safety standards. Required for work order closure in SAP PM and regulatory audit trail.' ;
    rdfs:domain ind:MaintenanceWorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:workDescription rdf:type rdf:Property ;
    rdfs:label 'Work Description' ;
    rdfs:comment 'Detailed narrative description of the maintenance task to be performed, including the nature of the fault or scheduled activity, scope of work, and any special instructions for the technician. Sourced from SAP PM short and long text fields.' ;
    rdfs:domain ind:MaintenanceWorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Work Order Number' ;
    rdfs:comment 'Externally-known alphanumeric identifier assigned by SAP S/4HANA Plant Maintenance (PM) module to uniquely identify this maintenance work order across operational systems. Used for cross-system traceability and field technician reference.' ;
    rdfs:domain ind:MaintenanceWorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workOrderStatus rdf:type rdf:Property ;
    rdfs:label 'Work Order Status' ;
    rdfs:comment 'Current lifecycle state of the maintenance work order within the SAP PM workflow. Draft: created but not yet released. Open: released and awaiting execution. In Progress: technician actively working. On Hold: paused pending parts or approval. Completed: work finished, awaiting sign-off. Closed: fully signed off and costed. Cancelled: voided before execution. [ENUM-REF-CANDIDATE: draft|open|in_progress|on_hold|completed|closed|cancelled — promote to reference product]' ;
    rdfs:domain ind:MaintenanceWorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workOrderType rdf:type rdf:Property ;
    rdfs:label 'Work Order Type' ;
    rdfs:comment 'Classification of the maintenance activity by its trigger and nature. Preventive: scheduled routine maintenance. Corrective: repair of a known fault. Emergency: unplanned critical failure response. Inspection: condition assessment. Predictive: data-driven proactive maintenance. Capital: improvement or replacement project. [ENUM-REF-CANDIDATE: preventive|corrective|emergency|inspection|predictive|capital — promote to reference product]' ;
    rdfs:domain ind:MaintenanceWorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyInspectionId rdf:type rdf:Property ;
    rdfs:label 'Safety Inspection Id' ;
    rdfs:comment 'Unique surrogate identifier for each safety inspection record within the venue compliance management system.' ;
    rdfs:domain ind:SafetyInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primarySafetyEventFixtureId rdf:type rdf:Property ;
    rdfs:label 'Primary Safety Event Fixture Id' ;
    rdfs:comment 'Reference to the specific live event (game, concert, or match) associated with this inspection when the inspection was triggered by or conducted in preparation for a specific event.' ;
    rdfs:domain ind:Venue ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Fixture .

ind:priorInspectionSafetyInspectionId rdf:type rdf:Property ;
    rdfs:label 'Prior Inspection Safety Inspection Id' ;
    rdfs:comment 'Reference to the immediately preceding inspection of the same type at this venue, enabling inspection history chaining and trend analysis across inspection cycles.' ;
    rdfs:domain ind:SafetyInspection ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SafetyInspection .

ind:reportAssetId rdf:type rdf:Property ;
    rdfs:label 'Report Asset Id' ;
    rdfs:comment 'Foreign key linking to content.asset. Business justification: Regulatory compliance requires inspection reports to be stored as versioned, managed content assets for audit trails and regulatory submission. safety_inspection has report_document_ref (plain string)' ;
    rdfs:domain ind:SafetyInspection ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Asset .

ind:adaComplianceChecked rdf:type rdf:Property ;
    rdfs:label 'Ada Compliance Checked' ;
    rdfs:comment 'Indicates whether ADA (Americans with Disabilities Act) accessibility requirements — including accessible seating, ramps, restrooms, signage, and assistive listening systems — were specifically evaluated during this inspection.' ;
    rdfs:domain ind:SafetyInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:areasInspected rdf:type rdf:Property ;
    rdfs:label 'Areas Inspected' ;
    rdfs:comment 'Descriptive list of the specific venue zones, sections, or systems covered during the inspection (e.g., concourse level A, HVAC — Heating Ventilation and Air Conditioning plant room, emergency exits, accessible seating sections, electrical switchgear rooms, concession stands). Free-text narrative or comma-delimited zone codes.' ;
    rdfs:domain ind:SafetyInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bmsSystemChecked rdf:type rdf:Property ;
    rdfs:label 'Bms System Checked' ;
    rdfs:comment 'Indicates whether the Building Management System (BMS) — including HVAC, fire suppression, emergency lighting, and access control integrations — was reviewed as part of this inspection.' ;
    rdfs:domain ind:SafetyInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:certificateExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Certificate Expiry Date' ;
    rdfs:comment 'The date on which the compliance certificate issued from this inspection expires and a renewal inspection is required. Drives proactive scheduling of future inspections.' ;
    rdfs:domain ind:SafetyInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:certificateIssued rdf:type rdf:Property ;
    rdfs:label 'Certificate Issued' ;
    rdfs:comment 'Indicates whether a formal compliance certificate, clearance letter, or occupancy permit was issued as a result of this inspection. True when a certificate has been formally issued by the regulatory authority.' ;
    rdfs:domain ind:SafetyInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:certificateNumber rdf:type rdf:Property ;
    rdfs:label 'Certificate Number' ;
    rdfs:comment 'The unique reference number printed on the compliance certificate or clearance document issued by the regulatory authority following a successful inspection. Null when no certificate was issued.' ;
    rdfs:domain ind:SafetyInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionDueDate rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Due Date' ;
    rdfs:comment 'The deadline by which all mandated corrective actions from this inspection must be completed and verified. Set by the regulatory body or agreed with the inspector. Drives compliance escalation workflows.' ;
    rdfs:domain ind:Venue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:correctiveActionNotes rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Notes' ;
    rdfs:comment 'Narrative description of the corrective actions required, including specific remediation steps, responsible parties, and any interim mitigation measures mandated by the inspector or regulatory authority.' ;
    rdfs:domain ind:SafetyInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionsRequired rdf:type rdf:Property ;
    rdfs:label 'Corrective Actions Required' ;
    rdfs:comment 'Indicates whether one or more corrective actions have been mandated as a result of this inspection. True when any finding requires a formal remediation response tracked in the corrective action management system.' ;
    rdfs:domain ind:SafetyInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:criticalFindingsCount rdf:type rdf:Property ;
    rdfs:label 'Critical Findings Count' ;
    rdfs:comment 'Number of findings classified as critical or serious — those posing immediate risk to life safety, structural integrity, or regulatory non-compliance requiring urgent corrective action. Subset of total findings_count.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:findingsCount rdf:type rdf:Property ;
    rdfs:label 'Findings Count' ;
    rdfs:comment 'Total number of non-conformances, violations, or observations identified during the inspection, including all severity levels. Used for trend analysis and compliance KPI reporting.' ;
    rdfs:domain ind:SafetyInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fireSafetyChecked rdf:type rdf:Property ;
    rdfs:label 'Fire Safety Checked' ;
    rdfs:comment 'Indicates whether fire safety systems — including sprinklers, extinguishers, emergency exits, evacuation routes, and fire suppression equipment — were evaluated during this inspection.' ;
    rdfs:domain ind:SafetyInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:followUpDueDate rdf:type rdf:Property ;
    rdfs:label 'Follow Up Due Date' ;
    rdfs:comment 'The deadline by which the follow-up or re-inspection must be completed. Populated only when follow_up_required is True. Used to schedule and track re-inspection compliance.' ;
    rdfs:domain ind:SafetyInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:followUpRequired rdf:type rdf:Property ;
    rdfs:label 'Follow Up Required' ;
    rdfs:comment 'Indicates whether a follow-up or re-inspection has been mandated by the regulatory authority or internal compliance team to verify completion of corrective actions.' ;
    rdfs:domain ind:SafetyInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inspectionDate rdf:type rdf:Property ;
    rdfs:label 'Inspection Date' ;
    rdfs:comment 'The calendar date on which the physical inspection was conducted at the venue. Used as the primary business event date for regulatory reporting and compliance tracking.' ;
    rdfs:domain ind:SafetyInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:inspectionEndTime rdf:type rdf:Property ;
    rdfs:label 'Inspection End Time' ;
    rdfs:comment 'Precise date and time when the inspection walkthrough or audit concluded on-site. Combined with start time to derive inspection duration for operational planning.' ;
    rdfs:domain ind:SafetyInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:inspectionMethod rdf:type rdf:Property ;
    rdfs:label 'Inspection Method' ;
    rdfs:comment 'Indicates how the inspection was conducted — physical on-site walkthrough, remote/virtual audit via documentation and video, or a hybrid combining both methods.' ;
    rdfs:domain ind:SafetyInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionNumber rdf:type rdf:Property ;
    rdfs:label 'Inspection Number' ;
    rdfs:comment 'Externally-known alphanumeric reference code assigned to this inspection, used in regulatory correspondence, certificates, and corrective action tracking. Format: INS-{YYYY}-{NNNNNN}.' ;
    rdfs:domain ind:SafetyInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionScope rdf:type rdf:Property ;
    rdfs:label 'Inspection Scope' ;
    rdfs:comment 'Indicates whether the inspection covered the entire facility or was limited to specific zones, systems, or follow-up items from a prior inspection. Supports risk-based compliance planning.' ;
    rdfs:domain ind:SafetyInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionStartTime rdf:type rdf:Property ;
    rdfs:label 'Inspection Start Time' ;
    rdfs:comment 'Precise date and time when the inspection walkthrough or audit commenced on-site. Used for duration tracking and scheduling coordination with venue operations.' ;
    rdfs:domain ind:SafetyInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:inspectionStatus rdf:type rdf:Property ;
    rdfs:label 'Inspection Status' ;
    rdfs:comment 'Current lifecycle state of the inspection record, from scheduling through completion or cancellation. Drives workflow routing and compliance dashboard visibility.' ;
    rdfs:domain ind:SafetyInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionTrigger rdf:type rdf:Property ;
    rdfs:label 'Inspection Trigger' ;
    rdfs:comment 'The reason or event that initiated this inspection. Distinguishes between routine periodic inspections, those triggered by an incident or complaint, pre-event readiness checks, and post-event assessments.' ;
    rdfs:domain ind:SafetyInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionType rdf:type rdf:Property ;
    rdfs:label 'Inspection Type' ;
    rdfs:comment 'Classification of the inspection by regulatory or operational category. Drives which checklist, regulatory body, and certificate type apply. [ENUM-REF-CANDIDATE: OSHA_WALKTHROUGH|FIRE_MARSHAL|ADA_AUDIT|STRUCTURAL_ENGINEERING|ISO_20121_SUSTAINABILITY|ELECTRICAL|HVAC|FOOD_SAFETY|SECURITY|ENVIRONMENTAL — promote to reference product]' ;
    rdfs:domain ind:SafetyInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectorCredentials rdf:type rdf:Property ;
    rdfs:label 'Inspector Credentials' ;
    rdfs:comment 'Professional certifications, license numbers, or regulatory authority credentials held by the lead inspector (e.g., Certified Safety Professional (CSP), OSHA 30-hour, Certified Access Specialist (CASp), Professional Engineer (PE) license number). Validates inspector authority and competency.' ;
    rdfs:domain ind:SafetyInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectorName rdf:type rdf:Property ;
    rdfs:label 'Inspector Name' ;
    rdfs:comment 'Full name of the lead inspector or auditor who conducted the inspection. May be an external regulatory official or a certified internal safety officer.' ;
    rdfs:domain ind:SafetyInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:internalReviewDate rdf:type rdf:Property ;
    rdfs:label 'Internal Review Date' ;
    rdfs:comment 'The date on which the internal venue safety officer or compliance manager completed their review of the inspection findings and acknowledged the corrective action plan.' ;
    rdfs:domain ind:SafetyInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:majorFindingsCount rdf:type rdf:Property ;
    rdfs:label 'Major Findings Count' ;
    rdfs:comment 'Number of findings classified as major — significant non-conformances that require corrective action within a defined timeframe but do not pose immediate life-safety risk. Distinct from critical findings.' ;
    rdfs:domain ind:SafetyInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minorFindingsCount rdf:type rdf:Property ;
    rdfs:label 'Minor Findings Count' ;
    rdfs:comment 'Number of findings classified as minor — low-risk observations or housekeeping items that should be addressed but do not materially impact safety or compliance status.' ;
    rdfs:domain ind:SafetyInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:outcome rdf:type rdf:Property ;
    rdfs:label 'Outcome' ;
    rdfs:comment 'The formal pass/fail determination issued at the conclusion of the inspection. CONDITIONAL_PASS indicates the venue passed subject to completion of specified corrective actions within the due date.' ;
    rdfs:domain ind:SafetyInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatorySubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Regulatory Submission Date' ;
    rdfs:comment 'The date on which the inspection report or corrective action response was formally submitted to the relevant regulatory authority (e.g., OSHA, local fire marshal, ADA compliance office). Supports SOX and regulatory audit trails.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:riskRating rdf:type rdf:Property ;
    rdfs:label 'Risk Rating' ;
    rdfs:comment 'Overall risk classification assigned to the venue based on the aggregate findings of this inspection. Informs prioritization of corrective actions, insurance reporting, and event-day operational readiness decisions.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:structuralIntegrityChecked rdf:type rdf:Property ;
    rdfs:label 'Structural Integrity Checked' ;
    rdfs:comment 'Indicates whether a structural engineering assessment of the venue\'s load-bearing elements, seating bowl, roof, and temporary structures (e.g., stages, rigging) was conducted as part of this inspection.' ;
    rdfs:domain ind:SafetyInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:safetyIncidentId rdf:type rdf:Property ;
    rdfs:label 'Safety Incident Id' ;
    rdfs:comment 'Unique surrogate identifier for each safety or security incident record in the venue domain. Primary key for the safety_incident data product.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SafetyIncident .

ind:eventDayOpsId rdf:type rdf:Property ;
    rdfs:label 'Event Day Ops Id' ;
    rdfs:comment 'Foreign key linking to venue.event_day_ops. Business justification: A safety incident occurs during a specific event day operation. safety_incident already has event_fixture_id and facility_id, but linking directly to event_day_ops_id allows incident_count on event_da' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EventDayOps .

ind:evidenceAssetId rdf:type rdf:Property ;
    rdfs:label 'Evidence Asset Id' ;
    rdfs:comment 'Foreign key linking to content.asset. Business justification: Incident investigation, insurance claims, and OSHA regulatory submissions require linking safety incidents to specific video/CCTV evidence assets. safety_incident already has cctv_footage_available fl' ;
    rdfs:domain ind:SafetyIncident ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Asset .

ind:affectedPartyType rdf:type rdf:Property ;
    rdfs:label 'Affected Party Type' ;
    rdfs:comment 'Classification of the primary category of person(s) affected by the incident. Determines applicable regulatory framework (OSHA for workers, general liability for fans/visitors). [ENUM-REF-CANDIDATE: fan|employee|contractor|athlete|vendor|media|other — promote to reference product]' ;
    rdfs:domain ind:SafetyIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bodyPartAffected rdf:type rdf:Property ;
    rdfs:label 'Body Part Affected' ;
    rdfs:comment 'Description of the body part(s) injured or affected (e.g., head, left knee, lower back). Required for OSHA 301 incident report and insurance claim documentation.' ;
    rdfs:domain ind:SafetyIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cctvFootageAvailable rdf:type rdf:Property ;
    rdfs:label 'Cctv Footage Available' ;
    rdfs:comment 'Indicates whether closed-circuit television (CCTV) or security camera footage of the incident is available and has been preserved. Critical for investigation, legal proceedings, and insurance claims.' ;
    rdfs:domain ind:SafetyIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:correctiveActionPlan rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Plan' ;
    rdfs:comment 'Free-text description of the planned corrective and preventive actions to address the root cause and prevent recurrence (e.g., install non-slip flooring, retrain crowd management staff, replace faulty equipment). Required for OSHA compliance and insurance risk management.' ;
    rdfs:domain ind:SafetyIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionStatus rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Status' ;
    rdfs:comment 'Current completion status of the corrective action plan. Enables management oversight of outstanding safety remediation obligations and regulatory compliance tracking.' ;
    rdfs:domain ind:SafetyIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crowdDensityLevel rdf:type rdf:Property ;
    rdfs:label 'Crowd Density Level' ;
    rdfs:comment 'Estimated crowd density level in the affected area at the time of the incident: low, moderate, high, sold_out (at venue capacity), or SRO (Standing Room Only). Contextualizes crowd disturbance and crush incidents for risk analysis.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:daysAwayFromWork rdf:type rdf:Property ;
    rdfs:label 'Days Away From Work' ;
    rdfs:comment 'Number of calendar days an affected worker was away from work as a result of the incident. Mandatory field for OSHA 300 log (Column H) for work-related injuries and illnesses. Zero for non-worker incidents.' ;
    rdfs:domain ind:SafetyIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:daysRestrictedWork rdf:type rdf:Property ;
    rdfs:label 'Days Restricted Work' ;
    rdfs:comment 'Number of calendar days an affected worker was on restricted work activity or job transfer as a result of the incident. Mandatory field for OSHA 300 log (Column I). Zero for non-worker incidents.' ;
    rdfs:domain ind:SafetyIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:emergencyServicesType rdf:type rdf:Property ;
    rdfs:label 'Emergency Services Type' ;
    rdfs:comment 'Type of external emergency services dispatched in response to the incident. Null or \'none\' when is_emergency_services_called is false.' ;
    rdfs:domain ind:SafetyIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedLiabilityUsd rdf:type rdf:Property ;
    rdfs:label 'Estimated Liability Usd' ;
    rdfs:comment 'Estimated financial liability or cost exposure associated with the incident in US dollars, including medical costs, legal fees, and potential settlements. Used for insurance reserve setting and financial risk reporting under SOX.' ;
    rdfs:domain ind:SafetyIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:immediateResponseActions rdf:type rdf:Property ;
    rdfs:label 'Immediate Response Actions' ;
    rdfs:comment 'Free-text description of the immediate actions taken by venue staff, security, or medical personnel in response to the incident (e.g., first aid administered, area evacuated, equipment shut down). Documents duty-of-care fulfillment for legal and insurance purposes.' ;
    rdfs:domain ind:SafetyIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentDatetime rdf:type rdf:Property ;
    rdfs:label 'Incident Datetime' ;
    rdfs:comment 'The precise date and time the safety or security incident occurred, recorded in ISO 8601 format with timezone offset. This is the principal real-world event timestamp used for OSHA 300 log entries, insurance reporting, and regulatory compliance.' ;
    rdfs:domain ind:SafetyIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:incidentNumber rdf:type rdf:Property ;
    rdfs:label 'Incident Number' ;
    rdfs:comment 'Externally-known, human-readable reference number assigned to the incident at time of reporting (e.g., INC-2024-000123). Used for cross-referencing with OSHA 300 log, insurance claims, and regulatory submissions.' ;
    rdfs:domain ind:SafetyIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:injuryIllnessType rdf:type rdf:Property ;
    rdfs:label 'Injury Illness Type' ;
    rdfs:comment 'OSHA 300 log classification of the nature of the injury or illness (columns M1–M6 on OSHA Form 300). Required for OSHA 300A annual summary and regulatory reporting.' ;
    rdfs:domain ind:SafetyIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceClaimNumber rdf:type rdf:Property ;
    rdfs:label 'Insurance Claim Number' ;
    rdfs:comment 'Reference number assigned by the insurance carrier for the claim associated with this incident. Links the safety incident record to the insurance claims management system for financial tracking and subrogation.' ;
    rdfs:domain ind:SafetyIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isEmergencyServicesCalled rdf:type rdf:Property ;
    rdfs:label 'Is Emergency Services Called' ;
    rdfs:comment 'Indicates whether external emergency services (EMS, fire department, police) were dispatched to the venue in response to this incident. Triggers mandatory insurance notification and may require regulatory reporting.' ;
    rdfs:domain ind:SafetyIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isFatality rdf:type rdf:Property ;
    rdfs:label 'Is Fatality' ;
    rdfs:comment 'Indicates whether the incident resulted in one or more fatalities. Triggers mandatory OSHA reporting within 8 hours of employer knowledge under 29 CFR Part 1904.39 and activates crisis management protocols.' ;
    rdfs:domain ind:SafetyIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isHospitalizationRequired rdf:type rdf:Property ;
    rdfs:label 'Is Hospitalization Required' ;
    rdfs:comment 'Indicates whether any affected person required in-patient hospitalization as a result of the incident. Mandatory OSHA reporting trigger (within 24 hours) for work-related incidents under 29 CFR Part 1904.39.' ;
    rdfs:domain ind:SafetyIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:locationDescription rdf:type rdf:Property ;
    rdfs:label 'Location Description' ;
    rdfs:comment 'Free-text narrative describing the precise physical location of the incident within the venue, supplementing the structured zone and section fields (e.g., \'Near stairwell exit at Section 112, Row G\').' ;
    rdfs:domain ind:Venue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oshaCaseType rdf:type rdf:Property ;
    rdfs:label 'Osha Case Type' ;
    rdfs:comment 'OSHA 300 log case classification indicating the most serious outcome of the incident: death, days away from work, restricted work or job transfer, or other recordable case. Directly maps to OSHA Form 300 columns G through J.' ;
    rdfs:domain ind:SafetyIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:personsAffectedCount rdf:type rdf:Property ;
    rdfs:label 'Persons Affected Count' ;
    rdfs:comment 'Total count of individuals (fans, workers, athletes, staff) directly affected by the incident. Used for severity assessment, insurance claims, and mass casualty protocol activation thresholds.' ;
    rdfs:domain ind:SafetyIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:regulatoryNotificationDatetime rdf:type rdf:Property ;
    rdfs:label 'Regulatory Notification Datetime' ;
    rdfs:comment 'Date and time the required regulatory notification was submitted (e.g., OSHA fatality report). Null if regulatory_notification_required is false or notification is pending. Used to verify compliance with mandatory reporting deadlines.' ;
    rdfs:domain ind:SafetyIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:regulatoryNotificationRequired rdf:type rdf:Property ;
    rdfs:label 'Regulatory Notification Required' ;
    rdfs:comment 'Indicates whether the incident requires mandatory notification to a regulatory body (e.g., OSHA fatality/hospitalization reporting within 8/24 hours, FCC, local health authority). Triggers compliance workflow escalation.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reportedByName rdf:type rdf:Property ;
    rdfs:label 'Reported By Name' ;
    rdfs:comment 'Full name of the venue staff member or official who formally reported the incident. Required for OSHA 301 incident report accountability and internal audit trail.' ;
    rdfs:domain ind:SafetyIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportedDatetime rdf:type rdf:Property ;
    rdfs:label 'Reported Datetime' ;
    rdfs:comment 'The date and time the incident was formally reported to venue management or safety personnel. May differ from incident_datetime due to delayed discovery or reporting lag. Required for OSHA timeliness compliance.' ;
    rdfs:domain ind:SafetyIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:rootCause rdf:type rdf:Property ;
    rdfs:label 'Root Cause' ;
    rdfs:comment 'Identified underlying cause of the incident determined through post-incident investigation (e.g., wet floor without signage, inadequate crowd control barriers, equipment malfunction). Essential for corrective action planning and recurrence prevention.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rootCauseCategory rdf:type rdf:Property ;
    rdfs:label 'Root Cause Category' ;
    rdfs:comment 'Structured classification of the root cause to enable trend analysis and systemic risk identification across incidents. Complements the free-text root_cause field. [ENUM-REF-CANDIDATE: human_error|equipment_failure|environmental|procedural_gap|crowd_behavior|structural|third_party|unknown — promote to reference product]' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:venueZone rdf:type rdf:Property ;
    rdfs:label 'Venue Zone' ;
    rdfs:comment 'High-level zone within the venue where the incident occurred (e.g., concourse, field level, parking lot, backstage, concession stand, loading dock). Used for spatial analysis of incident hotspots.' ;
    rdfs:domain ind:Venue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:weatherConditions rdf:type rdf:Property ;
    rdfs:label 'Weather Conditions' ;
    rdfs:comment 'Prevailing weather conditions at the time of the incident for outdoor or partially-outdoor venues. Relevant for slip-and-fall liability, crowd management decisions, and structural incident analysis. \'indoor_na\' for fully enclosed venues. [ENUM-REF-CANDIDATE: clear|rain|snow|fog|extreme_heat|high_wind|indoor_na — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SafetyIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:witnessCount rdf:type rdf:Property ;
    rdfs:label 'Witness Count' ;
    rdfs:comment 'Number of witnesses identified at the time of the incident. Supports investigation completeness assessment and legal discovery preparation.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:staffPlanId rdf:type rdf:Property ;
    rdfs:label 'Staff Plan Id' ;
    rdfs:comment 'Foreign key linking to venue.staff_plan. Business justification: event_day_ops is the operational execution record for a specific event day at a facility. staff_plan is the event-day staffing plan for that same facility and event. Linking event_day_ops to the staff' ;
    rdfs:domain ind:Venue ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffPlan .

ind:adaAccessConfirmed rdf:type rdf:Property ;
    rdfs:label 'Ada Access Confirmed' ;
    rdfs:comment 'Indicates whether all Americans with Disabilities Act (ADA) accessible entrances, seating areas, restrooms, and concession points have been verified as operational and unobstructed prior to event commencement.' ;
    rdfs:domain ind:EventDayOps ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:bmsAlertCount rdf:type rdf:Property ;
    rdfs:label 'Bms Alert Count' ;
    rdfs:comment 'Total number of alerts generated by the venue\'s Building Management System (BMS) during the event-day operational window, including HVAC, electrical, plumbing, and structural alerts. Used for facility maintenance prioritization and post-event review.' ;
    rdfs:domain ind:EventDayOps ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:checklistCompletionPct rdf:type rdf:Property ;
    rdfs:label 'Checklist Completion Pct' ;
    rdfs:comment 'Percentage of pre-event readiness checklist items marked as completed at the time of facility manager approval. A value of 100.00 indicates all items were verified; values below 100.00 indicate outstanding items requiring conditional approval or rejection.' ;
    rdfs:domain ind:EventDayOps ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:checklistVersion rdf:type rdf:Property ;
    rdfs:label 'Checklist Version' ;
    rdfs:comment 'Version identifier of the pre-event readiness checklist template applied for this event-day operation. Enables audit traceability and ensures compliance with the most current OSHA and ADA inspection standards.' ;
    rdfs:domain ind:EventDayOps ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:criticalItemFailureCount rdf:type rdf:Property ;
    rdfs:label 'Critical Item Failure Count' ;
    rdfs:comment 'Number of critical checklist items that failed verification during the pre-event readiness assessment. Critical items include life-safety systems, emergency egress, and ADA access points. A non-zero count triggers conditional or rejected readiness status.' ;
    rdfs:domain ind:EventDayOps ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:damageAssessmentRequired rdf:type rdf:Property ;
    rdfs:label 'Damage Assessment Required' ;
    rdfs:comment 'Indicates whether a post-event facility damage assessment has been flagged as required based on incidents, structural observations, or facility manager discretion during event closeout.' ;
    rdfs:domain ind:EventDayOps ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:emergencySystemVerified rdf:type rdf:Property ;
    rdfs:label 'Emergency System Verified' ;
    rdfs:comment 'Indicates whether emergency communication systems, public address systems, and emergency egress lighting have been tested and verified as operational prior to event commencement.' ;
    rdfs:domain ind:EventDayOps ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:facilityManagerApprovalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Facility Manager Approval Timestamp' ;
    rdfs:comment 'Date and time at which the facility manager formally approved or rejected the pre-event readiness certification. Serves as the official certification timestamp for compliance audit trails.' ;
    rdfs:domain ind:EventDayOps ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:fireSystemVerified rdf:type rdf:Property ;
    rdfs:label 'Fire System Verified' ;
    rdfs:comment 'Indicates whether the venue\'s fire detection, suppression, and alarm systems have been tested and verified as fully operational prior to event commencement. Mandatory life-safety compliance check.' ;
    rdfs:domain ind:EventDayOps ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gatesCloseTimestamp rdf:type rdf:Property ;
    rdfs:label 'Gates Close Timestamp' ;
    rdfs:comment 'Actual date and time at which venue gates were closed following completion of fan egress post-event. Used for load-out scheduling and venue closeout reconciliation.' ;
    rdfs:domain ind:EventDayOps ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:gatesOpenTimestamp rdf:type rdf:Property ;
    rdfs:label 'Gates Open Timestamp' ;
    rdfs:comment 'Actual date and time at which venue gates were opened to allow fan ingress. Used to measure gate-open-to-event-start lead time and to reconcile against Ticketmaster/AXS access control scan data.' ;
    rdfs:domain ind:EventDayOps ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:hvacVerified rdf:type rdf:Property ;
    rdfs:label 'Hvac Verified' ;
    rdfs:comment 'Indicates whether the venue\'s Heating, Ventilation, and Air Conditioning (HVAC) system has been inspected and verified as operational prior to event commencement. Required for OSHA compliance and fan comfort standards.' ;
    rdfs:domain ind:EventDayOps ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:incidentCount rdf:type rdf:Property ;
    rdfs:label 'Incident Count' ;
    rdfs:comment 'Total number of operational, safety, or security incidents recorded during the event-day operational window. Includes medical, security, structural, and crowd management incidents. Non-zero values trigger post-event incident review.' ;
    rdfs:domain ind:EventDayOps ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:loadInEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Load In End Timestamp' ;
    rdfs:comment 'Actual date and time at which all production and equipment load-in activities were completed. Used to calculate load-in duration and assess readiness timeline adherence.' ;
    rdfs:domain ind:EventDayOps ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:loadInStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Load In Start Timestamp' ;
    rdfs:comment 'Actual date and time at which production, equipment, and talent load-in activities commenced at the venue. Critical for event-day logistics scheduling and union labor compliance under applicable Collective Bargaining Agreements (CBA).' ;
    rdfs:domain ind:EventDayOps ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:loadOutEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Load Out End Timestamp' ;
    rdfs:comment 'Actual date and time at which all post-event load-out activities were completed and the venue was returned to base operational state. Marks the end of the active event-day operational window.' ;
    rdfs:domain ind:EventDayOps ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:loadOutStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Load Out Start Timestamp' ;
    rdfs:comment 'Actual date and time at which post-event production and equipment load-out activities commenced. Used for venue turnaround scheduling and labor cost tracking.' ;
    rdfs:domain ind:EventDayOps ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:medicalStaffCount rdf:type rdf:Property ;
    rdfs:label 'Medical Staff Count' ;
    rdfs:comment 'Total number of medical and emergency medical services (EMS) personnel deployed at the venue during the event. Used for mass-gathering medical compliance and post-event incident review.' ;
    rdfs:domain ind:EventDayOps ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:medicalStationReady rdf:type rdf:Property ;
    rdfs:label 'Medical Station Ready' ;
    rdfs:comment 'Indicates whether all designated medical aid stations within the venue are staffed, stocked, and operationally ready prior to gates opening. Required for mass-gathering event compliance.' ;
    rdfs:domain ind:EventDayOps ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:opsReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Ops Reference Number' ;
    rdfs:comment 'Externally-known alphanumeric reference code assigned to this event-day operational record, used for cross-system identification and communication with venue operations teams. Format: EDO-{YYYY}-{NNNNNN}.' ;
    rdfs:domain ind:EventDayOps ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:opsStatus rdf:type rdf:Property ;
    rdfs:label 'Ops Status' ;
    rdfs:comment 'Current lifecycle stage of the event-day operational record, tracking progression from pre-event preparation through in-progress execution to post-event reconciliation and final closure.' ;
    rdfs:domain ind:EventDayOps ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:peakConcourseOccupancy rdf:type rdf:Property ;
    rdfs:label 'Peak Concourse Occupancy' ;
    rdfs:comment 'Maximum number of fans simultaneously present on the concourse level at any point during the event, as measured by crowd management systems. Used for crowd density analysis and OSHA safety compliance reporting.' ;
    rdfs:domain ind:EventDayOps ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:postEventNotes rdf:type rdf:Property ;
    rdfs:label 'Post Event Notes' ;
    rdfs:comment 'Free-text field for facility manager observations, anomalies, and recommendations captured during post-event closeout. Feeds into the post-event report and informs future event-day operational planning.' ;
    rdfs:domain ind:EventDayOps ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postEventSignoffTimestamp rdf:type rdf:Property ;
    rdfs:label 'Post Event Signoff Timestamp' ;
    rdfs:comment 'Date and time at which the facility manager formally signed off on the post-event closeout, confirming load-out completion, damage assessment disposition, and venue return to base operational state.' ;
    rdfs:domain ind:EventDayOps ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:securityStaffCount rdf:type rdf:Property ;
    rdfs:label 'Security Staff Count' ;
    rdfs:comment 'Total number of security personnel deployed at the venue during the event, including contracted and in-house security staff. Used for staffing ratio compliance and post-event security review.' ;
    rdfs:domain ind:EventDayOps ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:securitySweepCompleted rdf:type rdf:Property ;
    rdfs:label 'Security Sweep Completed' ;
    rdfs:comment 'Indicates whether a full venue security sweep has been completed prior to gates opening, confirming no unauthorized persons or prohibited items are present in the facility.' ;
    rdfs:domain ind:EventDayOps ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:adaAccessible rdf:type rdf:Property ;
    rdfs:label 'Ada Accessible' ;
    rdfs:comment 'Indicates whether this concession stand has an ADA-compliant accessible service counter meeting the required counter height, approach clearance, and signage standards. Critical for ADA compliance reporting and fan accessibility planning.' ;
    rdfs:domain ind:ConcessionStand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:alcoholLicenseFlag rdf:type rdf:Property ;
    rdfs:label 'Alcohol License Flag' ;
    rdfs:comment 'Indicates whether this concession stand holds a valid alcohol beverage service license permitting the sale of beer, wine, or spirits. Drives compliance checks, age-verification POS configuration, and regulatory reporting.' ;
    rdfs:domain ind:ConcessionStand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cashlessOnlyFlag rdf:type rdf:Property ;
    rdfs:label 'Cashless Only Flag' ;
    rdfs:comment 'Indicates whether this concession stand operates exclusively on cashless payment methods (card and mobile), with no cash acceptance. Supports venue-wide cashless transformation initiatives and POS configuration.' ;
    rdfs:domain ind:ConcessionStand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:closeDate rdf:type rdf:Property ;
    rdfs:label 'Close Date' ;
    rdfs:comment 'Date on which this concession stand was permanently closed or decommissioned. Null for currently active stands. Used for asset lifecycle management and historical reporting.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fireSuppressionSystemFlag rdf:type rdf:Property ;
    rdfs:label 'Fire Suppression System Flag' ;
    rdfs:comment 'Indicates whether this concession stand is equipped with a fire suppression system (e.g., Ansul hood suppression for cooking equipment). Required for OSHA compliance and insurance documentation.' ;
    rdfs:domain ind:ConcessionStand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:geoLatitude rdf:type rdf:Property ;
    rdfs:label 'Geo Latitude' ;
    rdfs:comment 'GPS latitude coordinate of the concession stand\'s physical location within the venue. Enables digital venue mapping, fan wayfinding applications, and indoor navigation integrations.' ;
    rdfs:domain ind:ConcessionStand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:geoLongitude rdf:type rdf:Property ;
    rdfs:label 'Geo Longitude' ;
    rdfs:comment 'GPS longitude coordinate of the concession stand\'s physical location within the venue. Enables digital venue mapping, fan wayfinding applications, and indoor navigation integrations.' ;
    rdfs:domain ind:ConcessionStand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:healthInspectionScore rdf:type rdf:Property ;
    rdfs:label 'Health Inspection Score' ;
    rdfs:comment 'Numeric score assigned by the health authority during the most recent inspection, typically on a 0–100 scale. Enables trend analysis and benchmarking of food safety performance across stands.' ;
    rdfs:domain ind:ConcessionStand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:healthInspectionStatus rdf:type rdf:Property ;
    rdfs:label 'Health Inspection Status' ;
    rdfs:comment 'Current health and food safety inspection status of the concession stand as assessed by the local health authority. Drives operational readiness decisions and compliance reporting. Values: pass, conditional_pass, fail, pending, not_inspected.' ;
    rdfs:domain ind:ConcessionStand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastEquipmentServiceDate rdf:type rdf:Property ;
    rdfs:label 'Last Equipment Service Date' ;
    rdfs:comment 'Date of the most recent preventive maintenance or equipment servicing performed at this concession stand. Supports facility management scheduling and OSHA equipment safety compliance.' ;
    rdfs:domain ind:ConcessionStand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastHealthInspectionDate rdf:type rdf:Property ;
    rdfs:label 'Last Health Inspection Date' ;
    rdfs:comment 'Date of the most recent health and food safety inspection conducted at this concession stand. Used to track inspection currency and schedule upcoming inspections per regulatory requirements.' ;
    rdfs:domain ind:ConcessionStand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:maxThroughputPerHour rdf:type rdf:Property ;
    rdfs:label 'Max Throughput Per Hour' ;
    rdfs:comment 'Engineered maximum number of transactions this stand can process per hour under full staffing and optimal conditions. Used for event-day capacity planning, queue management, and per-capita spend modeling.' ;
    rdfs:domain ind:ConcessionStand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nextHealthInspectionDate rdf:type rdf:Property ;
    rdfs:label 'Next Health Inspection Date' ;
    rdfs:comment 'Scheduled date for the next mandatory health and food safety inspection at this concession stand. Supports proactive compliance management and operational readiness planning.' ;
    rdfs:domain ind:ConcessionStand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:operatorType rdf:type rdf:Property ;
    rdfs:label 'Operator Type' ;
    rdfs:comment 'Indicates whether the concession stand is operated directly by the venue (in_house) or by an external contracted concessionaire (third_party). Drives revenue recognition treatment and contract compliance tracking.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentMethodsAccepted rdf:type rdf:Property ;
    rdfs:label 'Payment Methods Accepted' ;
    rdfs:comment 'Comma-separated list of payment methods accepted at this stand (e.g., \'cash,card,mobile\'). Drives POS terminal configuration and fan communication. [ENUM-REF-CANDIDATE: cash|card|mobile|voucher|contactless|crypto — promote to reference product]' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:posSystemCode rdf:type rdf:Property ;
    rdfs:label 'Pos System Code' ;
    rdfs:comment 'Identifier of the POS system instance or configuration profile assigned to this stand within the POS platform (e.g., Oracle MICROS, Appetize, SpotOn). Used for POS system integration and transaction reconciliation with SAP S/4HANA SD.' ;
    rdfs:domain ind:ConcessionStand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:posTerminalCount rdf:type rdf:Property ;
    rdfs:label 'Pos Terminal Count' ;
    rdfs:comment 'Number of active Point of Sale (POS) terminals installed at this concession stand. Used for capacity planning, throughput analysis, and technology asset management.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:seatingCapacity rdf:type rdf:Property ;
    rdfs:label 'Seating Capacity' ;
    rdfs:comment 'Number of guest seats available at or adjacent to this concession stand, applicable for premium club kitchens, bar stations, and sit-down food outlets. Null for walk-up or portable stands with no dedicated seating.' ;
    rdfs:domain ind:ConcessionStand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:selfServiceFlag rdf:type rdf:Property ;
    rdfs:label 'Self Service Flag' ;
    rdfs:comment 'Indicates whether this concession stand operates as a self-service kiosk or automated unit requiring no staff attendant. Relevant for labor cost modeling and fan experience design.' ;
    rdfs:domain ind:ConcessionStand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:squareFootage rdf:type rdf:Property ;
    rdfs:label 'Square Footage' ;
    rdfs:comment 'Physical floor area of the concession stand in square feet. Used for facility management, lease cost allocation, and OSHA occupancy compliance calculations.' ;
    rdfs:domain ind:Venue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:staffCountStandard rdf:type rdf:Property ;
    rdfs:label 'Staff Count Standard' ;
    rdfs:comment 'Standard number of staff members assigned to operate this concession stand during a typical event. Used for workforce planning, labor cost budgeting, and SAP SuccessFactors scheduling.' ;
    rdfs:domain ind:ConcessionStand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:standCode rdf:type rdf:Property ;
    rdfs:label 'Stand Code' ;
    rdfs:comment 'Externally-known alphanumeric business identifier for the concession stand unit, used in POS system configuration, signage, and operational reporting (e.g., CS-101, BAR-C3). Sourced from SAP S/4HANA SD plant/storage location codes.' ;
    rdfs:domain ind:ConcessionStand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standName rdf:type rdf:Property ;
    rdfs:label 'Stand Name' ;
    rdfs:comment 'Human-readable display name of the concession stand as it appears on venue maps, signage, and fan-facing applications (e.g., \'Club Level Bar\', \'Section 112 Hot Dogs\', \'Premium Lounge Kitchen\').' ;
    rdfs:domain ind:ConcessionStand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standType rdf:type rdf:Property ;
    rdfs:label 'Stand Type' ;
    rdfs:comment 'Operational classification of the concession stand unit indicating its physical configuration and service model: permanent (fixed built-in unit), portable (mobile cart), premium (club/suite kitchen), bar (licensed alcohol bar station), or specialty (themed or branded outlet).' ;
    rdfs:domain ind:ConcessionStand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageAreaCode rdf:type rdf:Property ;
    rdfs:label 'Storage Area Code' ;
    rdfs:comment 'SAP S/4HANA MM storage location code identifying the back-of-house inventory storage area associated with this concession stand. Enables inventory replenishment tracking and materials management.' ;
    rdfs:domain ind:ConcessionStand ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:suiteId rdf:type rdf:Property ;
    rdfs:label 'Suite Id' ;
    rdfs:comment 'Unique system-generated identifier for the premium hospitality suite or club box record. Primary key for the suite master data product within the venue domain.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Suite .

ind:amenityNotes rdf:type rdf:Property ;
    rdfs:label 'Amenity Notes' ;
    rdfs:comment 'Free-text description of additional suite amenities not captured by structured flags (e.g., dedicated concierge service, custom furniture, branded décor, HVAC zoning). Supports sales and marketing use cases.' ;
    rdfs:domain ind:Suite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:annualLicenseFee rdf:type rdf:Property ;
    rdfs:label 'Annual License Fee' ;
    rdfs:comment 'Annualized value of the suite license fee, normalized for multi-year agreements. Used for year-over-year revenue comparison, ARR (Annual Recurring Revenue) reporting, and per-suite P&L benchmarking.' ;
    rdfs:domain ind:Suite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cateringCreditAmount rdf:type rdf:Property ;
    rdfs:label 'Catering Credit Amount' ;
    rdfs:comment 'Dollar value of complimentary catering credit included in the suite license agreement per season or per event, as applicable. Used for food and beverage revenue netting and per-suite P&L analysis.' ;
    rdfs:domain ind:Suite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contractExecutionDate rdf:type rdf:Property ;
    rdfs:label 'Contract Execution Date' ;
    rdfs:comment 'Date on which the suite license agreement was formally signed and executed by both parties. Distinct from the license start date; used for audit trails and SOX financial controls.' ;
    rdfs:domain ind:Suite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:hasAvSystem rdf:type rdf:Property ;
    rdfs:label 'Has Av System' ;
    rdfs:comment 'Indicates whether the suite is equipped with an integrated Audio-Visual (AV) system including displays, broadcast feeds, and sound. Relevant for broadcast operations and premium experience delivery.' ;
    rdfs:domain ind:Suite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hasCateringKitchen rdf:type rdf:Property ;
    rdfs:label 'Has Catering Kitchen' ;
    rdfs:comment 'Indicates whether the suite includes a dedicated catering kitchen or prep area. Relevant for premium hospitality operations, food service licensing, and OSHA food safety compliance.' ;
    rdfs:domain ind:Suite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hasPrivateBar rdf:type rdf:Property ;
    rdfs:label 'Has Private Bar' ;
    rdfs:comment 'Indicates whether the suite includes a private bar facility. Drives premium hospitality pricing, catering credit allocation, and suite marketing collateral.' ;
    rdfs:domain ind:Suite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hasPrivateRestroom rdf:type rdf:Property ;
    rdfs:label 'Has Private Restroom' ;
    rdfs:comment 'Indicates whether the suite includes a private restroom facility. Impacts ADA compliance assessment, premium tier classification, and license fee valuation.' ;
    rdfs:domain ind:Suite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hasRenewalOption rdf:type rdf:Property ;
    rdfs:label 'Has Renewal Option' ;
    rdfs:comment 'Indicates whether the suite license agreement includes a contractual renewal option for the licensee. Drives renewal pipeline prioritization and proactive outreach in Salesforce CRM.' ;
    rdfs:domain ind:Suite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:includedEventCount rdf:type rdf:Property ;
    rdfs:label 'Included Event Count' ;
    rdfs:comment 'Total number of events included in the suite license agreement for the term. Used for per-event cost allocation, utilization tracking, and per-suite P&L analysis.' ;
    rdfs:domain ind:Suite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastRenovationDate rdf:type rdf:Property ;
    rdfs:label 'Last Renovation Date' ;
    rdfs:comment 'Date of the most recent physical renovation or refurbishment of the suite. Used for facility lifecycle management, capital expenditure planning, and premium hospitality quality assurance.' ;
    rdfs:domain ind:Suite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:licenseEndDate rdf:type rdf:Property ;
    rdfs:label 'License End Date' ;
    rdfs:comment 'Date on which the suite license agreement expires or terminates. Nullable for open-ended agreements. Drives renewal pipeline alerts and contract expiry reporting in Salesforce CRM.' ;
    rdfs:domain ind:Suite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:licenseStartDate rdf:type rdf:Property ;
    rdfs:label 'License Start Date' ;
    rdfs:comment 'Date on which the suite license agreement becomes effective and binding. Used for revenue recognition scheduling, access control activation, and contract lifecycle management.' ;
    rdfs:domain ind:Suite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:licenseTermType rdf:type rdf:Property ;
    rdfs:label 'License Term Type' ;
    rdfs:comment 'Classification of the suite license by duration structure: annual (one-year term), multi-year (multi-season commitment), or per-event (single event basis). Determines revenue recognition method and renewal cycle.' ;
    rdfs:domain ind:Suite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parkingPassesIncluded rdf:type rdf:Property ;
    rdfs:label 'Parking Passes Included' ;
    rdfs:comment 'Number of complimentary parking passes included in the suite license agreement per event or per season. Used for venue parking inventory management and license value benchmarking.' ;
    rdfs:domain ind:Suite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:paymentSchedule rdf:type rdf:Property ;
    rdfs:label 'Payment Schedule' ;
    rdfs:comment 'Frequency and structure of license fee payment installments as defined in the suite agreement. Drives accounts receivable scheduling in SAP S/4HANA FI and cash flow forecasting in Workday Adaptive Planning.' ;
    rdfs:domain ind:Suite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pipelineStage rdf:type rdf:Property ;
    rdfs:label 'Pipeline Stage' ;
    rdfs:comment 'Current stage of the suite in the commercial lease renewal or new sale pipeline. Managed in Salesforce CRM to support premium hospitality revenue forecasting and sales team activity tracking. [ENUM-REF-CANDIDATE: prospect|proposal_sent|negotiation|contract_signed|renewed|lapsed|churned — promote to reference product]' ;
    rdfs:domain ind:Suite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactName rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Name' ;
    rdfs:comment 'Full name of the primary business contact for the suite licensee, used for account management, event-day coordination, and renewal outreach in Salesforce CRM.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standingPositions rdf:type rdf:Property ;
    rdfs:label 'Standing Positions' ;
    rdfs:comment 'Number of Standing Room Only (SRO) positions within the suite beyond fixed seating. Contributes to total capacity and is used for event-day access control and OSHA compliance.' ;
    rdfs:domain ind:Suite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:suiteLevel rdf:type rdf:Property ;
    rdfs:label 'Suite Level' ;
    rdfs:comment 'Physical level or tier within the venue where the suite is located (e.g., \'Club Level\', \'Loge Level\', \'Upper Concourse\'). Used for venue mapping, wayfinding, and premium hospitality segmentation.' ;
    rdfs:domain ind:Suite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:suiteName rdf:type rdf:Property ;
    rdfs:label 'Suite Name' ;
    rdfs:comment 'Human-readable marketing or branded name of the suite (e.g., \'Champions Club Suite\', \'Founders Loge Box\'). Used in CRM, sales collateral, and fan-facing communications.' ;
    rdfs:domain ind:Suite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:suiteNumber rdf:type rdf:Property ;
    rdfs:label 'Suite Number' ;
    rdfs:comment 'Alphanumeric identifier assigned to the suite within the venue, used for wayfinding, ticketing systems, and operational staff coordination (e.g., \'S-101\', \'PL-22\'). Corresponds to the physical suite designation in Archtics seating inventory.' ;
    rdfs:domain ind:Suite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:suiteType rdf:type rdf:Property ;
    rdfs:label 'Suite Type' ;
    rdfs:comment 'Classification of the premium hospitality unit by physical and commercial configuration. Drives pricing tiers, amenity packages, and license fee structures. [ENUM-REF-CANDIDATE: private_suite|club_box|loge_box|party_suite|press_box|founders_suite — promote to reference product if additional types are added]' ;
    rdfs:domain ind:Suite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalLicenseFee rdf:type rdf:Property ;
    rdfs:label 'Total License Fee' ;
    rdfs:comment 'Total contractual license fee for the full term of the suite agreement in the venue\'s operating currency. Used for revenue recognition scheduling, P&L analysis, and EBITDA reporting. Sensitive commercial financial data.' ;
    rdfs:domain ind:Suite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:accessibleRouteConnected rdf:type rdf:Property ;
    rdfs:label 'Accessible Route Connected' ;
    rdfs:comment 'Indicates whether this feature is connected to a continuous accessible route as required by ADA Standards for Accessible Design Section 206. Critical for ADA path-of-travel compliance assessments.' ;
    rdfs:domain ind:AccessibilityFeature ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:annualMaintenanceCost rdf:type rdf:Property ;
    rdfs:label 'Annual Maintenance Cost' ;
    rdfs:comment 'Estimated or actual annual cost to maintain and inspect this accessibility feature, in USD. Used for venue operations budgeting and ADA compliance cost tracking in Workday Adaptive Planning.' ;
    rdfs:domain ind:AccessibilityFeature ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assetTag rdf:type rdf:Property ;
    rdfs:label 'Asset Tag' ;
    rdfs:comment 'Internal fixed asset tag or barcode label affixed to the physical feature unit, used for asset inventory reconciliation with SAP S/4HANA Fixed Asset Management (FI-AA).' ;
    rdfs:domain ind:AccessibilityFeature ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capacity rdf:type rdf:Property ;
    rdfs:label 'Capacity' ;
    rdfs:comment 'Maximum number of persons or devices this feature can accommodate simultaneously (e.g., elevator capacity in persons, companion seating area capacity in seats, sensory room capacity). Distinct from quantity of units.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:complianceStandard rdf:type rdf:Property ;
    rdfs:label 'Compliance Standard' ;
    rdfs:comment 'The specific regulatory or code standard this feature is evaluated against (e.g., \'ADA 2010 Standards for Accessible Design\', \'IBC 2021\', \'NFPA 101\', \'Local Municipal Code Section 11B\'). Supports multi-jurisdiction compliance tracking.' ;
    rdfs:domain ind:AccessibilityFeature ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fanFacingDescription rdf:type rdf:Property ;
    rdfs:label 'Fan Facing Description' ;
    rdfs:comment 'Consumer-friendly description of this accessibility feature for publication on the venue website, mobile app, and fan engagement platforms (Adobe Experience Platform). Supports fan accessibility experience management and DTC (Direct-To-Consumer) communications.' ;
    rdfs:domain ind:AccessibilityFeature ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:featureCategory rdf:type rdf:Property ;
    rdfs:label 'Feature Category' ;
    rdfs:comment 'Broad disability category this feature serves: mobility (ramps, elevators), sensory (hearing loops, braille), cognitive (sensory rooms), communication (assistive listening), parking, or seating (companion areas).' ;
    rdfs:domain ind:AccessibilityFeature ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:featureCode rdf:type rdf:Property ;
    rdfs:label 'Feature Code' ;
    rdfs:comment 'Externally-known unique alphanumeric code assigned to this accessibility feature, used for cross-system reference and ADA compliance reporting (e.g., WCR-101, ELV-B2, HLP-MAIN).' ;
    rdfs:domain ind:AccessibilityFeature ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:featureName rdf:type rdf:Property ;
    rdfs:label 'Feature Name' ;
    rdfs:comment 'Human-readable name of the accessibility feature (e.g., \'North Concourse Wheelchair Ramp\', \'Section 112 Hearing Loop\', \'Main Lobby Accessible Restroom Block A\').' ;
    rdfs:domain ind:AccessibilityFeature ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:featureType rdf:type rdf:Property ;
    rdfs:label 'Feature Type' ;
    rdfs:comment 'Categorical classification of the accessibility feature type. [ENUM-REF-CANDIDATE: wheelchair_ramp|elevator|accessible_restroom|hearing_loop|braille_signage|accessible_parking|companion_seating|sensory_room|accessible_entrance|tactile_pathway|assistive_listening_device|lowered_counter|accessible_concession — promote to reference product]' ;
    rdfs:domain ind:AccessibilityFeature ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionAuthority rdf:type rdf:Property ;
    rdfs:label 'Inspection Authority' ;
    rdfs:comment 'Name of the authority having jurisdiction (AHJ) or regulatory body that conducted or certified the last inspection (e.g., \'City of Los Angeles Building and Safety\', \'State Fire Marshal\', \'DOJ ADA Inspector\').' ;
    rdfs:domain ind:AccessibilityFeature ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Inspection Certificate Number' ;
    rdfs:comment 'Official certificate or permit number issued by the inspection authority upon successful compliance inspection. Required for ADA audit documentation and regulatory reporting.' ;
    rdfs:domain ind:AccessibilityFeature ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:installationCost rdf:type rdf:Property ;
    rdfs:label 'Installation Cost' ;
    rdfs:comment 'Total capital expenditure incurred for the installation of this accessibility feature, in the venue\'s operating currency (USD). Supports fixed asset capitalization in SAP S/4HANA FI-AA and ADA capital investment reporting.' ;
    rdfs:domain ind:AccessibilityFeature ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:installationDate rdf:type rdf:Property ;
    rdfs:label 'Installation Date' ;
    rdfs:comment 'Date the accessibility feature was physically installed or made operational at the venue. Used for asset lifecycle management and warranty tracking.' ;
    rdfs:domain ind:AccessibilityFeature ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isAdaCertified rdf:type rdf:Property ;
    rdfs:label 'Is Ada Certified' ;
    rdfs:comment 'Indicates whether this feature has received formal ADA (Americans with Disabilities Act) certification from an accredited inspector or authority having jurisdiction (AHJ). Distinct from compliance_status which tracks ongoing state.' ;
    rdfs:domain ind:AccessibilityFeature ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isEventDayAvailable rdf:type rdf:Property ;
    rdfs:label 'Is Event Day Available' ;
    rdfs:comment 'Indicates whether this accessibility feature is available and operational during live events. Some features (e.g., sensory rooms) may only be activated on event days. Supports event-day logistics planning.' ;
    rdfs:domain ind:AccessibilityFeature ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPublished rdf:type rdf:Property ;
    rdfs:label 'Is Published' ;
    rdfs:comment 'Indicates whether this accessibility feature is currently published and visible to fans on public-facing channels (venue website, mobile app, ticketing platforms). Controls fan-facing accessibility information display.' ;
    rdfs:domain ind:AccessibilityFeature ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastMaintenanceDate rdf:type rdf:Property ;
    rdfs:label 'Last Maintenance Date' ;
    rdfs:comment 'Date of the most recent preventive or corrective maintenance performed on this feature. Supports BMS (Building Management System) maintenance scheduling and operational readiness tracking.' ;
    rdfs:domain ind:AccessibilityFeature ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:maintenanceTeam rdf:type rdf:Property ;
    rdfs:label 'Maintenance Team' ;
    rdfs:comment 'Name or identifier of the internal or contracted maintenance team responsible for upkeep and inspection of this feature (e.g., \'Facilities Ops - Electrical\', \'Third-Party Elevator Services Inc.\'). Supports work order routing.' ;
    rdfs:domain ind:AccessibilityFeature ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manufacturer rdf:type rdf:Property ;
    rdfs:label 'Manufacturer' ;
    rdfs:comment 'Name of the manufacturer or supplier of the accessibility feature equipment (e.g., \'Otis Elevator\', \'Ampetronic Hearing Loop Systems\'). Supports warranty management and procurement.' ;
    rdfs:domain ind:AccessibilityFeature ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modelNumber rdf:type rdf:Property ;
    rdfs:label 'Model Number' ;
    rdfs:comment 'Manufacturer model number or product designation for the accessibility feature equipment. Used for spare parts procurement, warranty claims, and technical documentation.' ;
    rdfs:domain ind:AccessibilityFeature ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextInspectionDate rdf:type rdf:Property ;
    rdfs:label 'Next Inspection Date' ;
    rdfs:comment 'Date on which the next scheduled compliance or safety inspection of this feature is due. Drives maintenance scheduling and proactive compliance management.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextMaintenanceDate rdf:type rdf:Property ;
    rdfs:label 'Next Maintenance Date' ;
    rdfs:comment 'Date on which the next scheduled preventive maintenance for this feature is due. Enables proactive BMS (Building Management System) work order generation.' ;
    rdfs:domain ind:AccessibilityFeature ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:remediationNotes rdf:type rdf:Property ;
    rdfs:label 'Remediation Notes' ;
    rdfs:comment 'Free-text description of remediation actions required or in progress when compliance_status is non_compliant or remediation_in_progress. Documents corrective action plans for ADA audit purposes.' ;
    rdfs:domain ind:AccessibilityFeature ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remediationTargetDate rdf:type rdf:Property ;
    rdfs:label 'Remediation Target Date' ;
    rdfs:comment 'Target completion date for remediation of a non-compliant accessibility feature. Used for ADA compliance reporting and regulatory deadline tracking.' ;
    rdfs:domain ind:AccessibilityFeature ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requiresAdvanceBooking rdf:type rdf:Property ;
    rdfs:label 'Requires Advance Booking' ;
    rdfs:comment 'Indicates whether fans must book or reserve this accessibility feature in advance (e.g., sensory rooms, companion seating, accessible parking). Drives Ticketmaster/AXS ticketing workflow configuration.' ;
    rdfs:domain ind:AccessibilityFeature ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:signagePresent rdf:type rdf:Property ;
    rdfs:label 'Signage Present' ;
    rdfs:comment 'Indicates whether the required International Symbol of Accessibility (ISA) signage and directional signage is present and compliant at this feature location. Required under ADA Section 216.' ;
    rdfs:domain ind:AccessibilityFeature ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:venueLevel rdf:type rdf:Property ;
    rdfs:label 'Venue Level' ;
    rdfs:comment 'The floor or level within the venue where the feature is located (e.g., \'Level 1\', \'Concourse B\', \'Lower Bowl\', \'Mezzanine\'). Supports spatial analytics and accessibility mapping.' ;
    rdfs:domain ind:AccessibilityFeature ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:warrantyExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Warranty Expiry Date' ;
    rdfs:comment 'Date on which the manufacturer or vendor warranty for this accessibility feature expires. Supports procurement planning and maintenance cost forecasting.' ;
    rdfs:domain ind:AccessibilityFeature ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:primaryGoverningBodyId rdf:type rdf:Property ;
    rdfs:label 'Primary Governing Body Id' ;
    rdfs:comment 'Foreign key linking to compliance.governing_body. Business justification: Every professional sports league operates under a primary regulatory/governing body (e.g., state athletic commissions, FCC for broadcast, anti-doping authorities). Linking league to its primary govern' ;
    rdfs:domain ind:League ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GoverningBody .

ind:acronym rdf:type rdf:Property ;
    rdfs:label 'Acronym' ;
    rdfs:comment 'Widely recognized abbreviation or acronym for the league (e.g., NFL, NBA, MLB, NHL, MLS, FIFA). Used in fan-facing platforms, broadcast graphics, merchandise labeling, and digital content.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:antiDopingBody rdf:type rdf:Property ;
    rdfs:label 'Anti Doping Body' ;
    rdfs:comment 'Name of the anti-doping authority responsible for testing and enforcement within this league (e.g., WADA, USADA, UKAD). Determines PED (Performance Enhancing Drug) testing protocols and suspension adjudication processes.' ;
    rdfs:domain ind:League ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cbaExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Cba Expiry Date' ;
    rdfs:comment 'Date on which the current Collective Bargaining Agreement between the league and its players\' association expires. Critical for labor relations planning, salary cap projections, and franchise agreement renewals.' ;
    rdfs:domain ind:League ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:championshipName rdf:type rdf:Property ;
    rdfs:label 'Championship Name' ;
    rdfs:comment 'Official name of the league\'s championship event or trophy (e.g., \'Super Bowl\', \'NBA Finals\', \'World Series\', \'Stanley Cup Finals\', \'MLS Cup\'). Used in broadcast rights agreements, sponsorship contracts, merchandise licensing, and fan engagement campaigns.' ;
    rdfs:domain ind:League ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:draftEnabled rdf:type rdf:Property ;
    rdfs:label 'Draft Enabled' ;
    rdfs:comment 'Indicates whether this league conducts an annual player draft for team roster building. Drives draft scheduling, eligibility tracking, and scouting report workflows.' ;
    rdfs:domain ind:League ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:draftRoundCount rdf:type rdf:Property ;
    rdfs:label 'Draft Round Count' ;
    rdfs:comment 'Total number of rounds in the league\'s annual player draft. Null if draft_enabled is false. Used for draft scheduling, pick tracking, and athlete eligibility management.' ;
    rdfs:domain ind:League ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:expansionTeamCount rdf:type rdf:Property ;
    rdfs:label 'Expansion Team Count' ;
    rdfs:comment 'Number of expansion franchises currently approved but not yet fully operational within the league. Used for franchise agreement tracking, revenue sharing projections, and stadium development planning.' ;
    rdfs:domain ind:League ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:foundingYear rdf:type rdf:Property ;
    rdfs:label 'Founding Year' ;
    rdfs:comment 'The calendar year in which the league or governing body was officially established or chartered. Used for historical analytics, anniversary campaigns, and brand heritage reporting.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:gamesPerTeamPerSeason rdf:type rdf:Property ;
    rdfs:label 'Games Per Team Per Season' ;
    rdfs:comment 'Standard number of regular season games each team plays per season (e.g., 17 for NFL, 82 for NBA, 162 for MLB, 82 for NHL, 34 for MLS). Drives fixture scheduling, broadcast slot allocation, and ticket inventory planning.' ;
    rdfs:domain ind:League ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:headquartersCountryCode rdf:type rdf:Property ;
    rdfs:label 'Headquarters Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the country where the league\'s principal administrative offices are registered. Determines primary legal jurisdiction, tax domicile, and applicable data privacy regulations (GDPR, CCPA).' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ipOwnerEntity rdf:type rdf:Property ;
    rdfs:label 'Ip Owner Entity' ;
    rdfs:comment 'Legal entity name that holds the IP (Intellectual Property) rights for the league\'s brand, marks, and content (e.g., \'NFL Properties LLC\', \'NBA Properties Inc.\'). Critical for DRM (Digital Rights Management) enforcement, licensing agreements, and SOX IP asset reporting.' ;
    rdfs:domain ind:League ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leagueCode rdf:type rdf:Property ;
    rdfs:label 'League Code' ;
    rdfs:comment 'Externally-known short alphanumeric code uniquely identifying the league (e.g., NFL, NBA, MLB, NHL, MLS, FIFA, IOC). Used as the business-facing identifier across systems, broadcasts, and partner integrations.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leagueStatus rdf:type rdf:Property ;
    rdfs:label 'League Status' ;
    rdfs:comment 'Current operational lifecycle status of the league. \'active\' indicates the league is currently operating seasons; \'inactive\' indicates temporary cessation; \'suspended\' indicates regulatory or disciplinary hold; \'dissolved\' indicates permanent closure; \'founding\' indicates pre-launch setup phase.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leagueType rdf:type rdf:Property ;
    rdfs:label 'League Type' ;
    rdfs:comment 'Classification of the league by competitive tier and professional status. Determines CBA applicability, salary cap rules, NIL eligibility, and broadcast rights tier.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:numConferences rdf:type rdf:Property ;
    rdfs:label 'Num Conferences' ;
    rdfs:comment 'Total number of conferences within the league hierarchy. Relevant for playoff bracket construction, revenue distribution, and broadcast rights packaging.' ;
    rdfs:domain ind:League ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:numDivisions rdf:type rdf:Property ;
    rdfs:label 'Num Divisions' ;
    rdfs:comment 'Total number of competitive divisions within the league structure. Drives standings calculations, playoff qualification rules, and scheduling algorithms.' ;
    rdfs:domain ind:League ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:numTeams rdf:type rdf:Property ;
    rdfs:label 'Num Teams' ;
    rdfs:comment 'Total number of franchised or member teams currently active in the league. Used for scheduling, revenue sharing calculations, playoff seeding, and expansion planning.' ;
    rdfs:domain ind:League ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:officialName rdf:type rdf:Property ;
    rdfs:label 'Official Name' ;
    rdfs:comment 'Full legal and official name of the league or governing body as registered with the relevant governing authority (e.g., \'National Football League\', \'Fédération Internationale de Football Association\'). Used in legal documents, broadcast agreements, and regulatory filings.' ;
    rdfs:domain ind:League ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:officiatingBody rdf:type rdf:Property ;
    rdfs:label 'Officiating Body' ;
    rdfs:comment 'Name of the organization or department responsible for recruiting, training, assigning, and evaluating match officials within this league (e.g., \'NFL Officiating Department\', \'NBA Referee Operations\', \'FIFA Referees Committee\').' ;
    rdfs:domain ind:League ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ottPlatformName rdf:type rdf:Property ;
    rdfs:label 'Ott Platform Name' ;
    rdfs:comment 'Name of the league\'s owned or primary OTT (Over-The-Top Streaming) DTC (Direct-To-Consumer) streaming platform (e.g., \'NFL+\', \'NBA League Pass\', \'MLB.TV\'). Drives digital content distribution, ARPU tracking, and fan engagement analytics.' ;
    rdfs:domain ind:League ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:playoffFormat rdf:type rdf:Property ;
    rdfs:label 'Playoff Format' ;
    rdfs:comment 'Description of the playoff or championship round structure (e.g., \'Best-of-7 series\', \'Single elimination bracket\', \'16-team bracket\'). Used for event scheduling, broadcast planning, and fan engagement content. [ENUM-REF-CANDIDATE: best_of_7|best_of_5|single_elimination|double_elimination|round_robin_final|two_leg_aggregate — promote to reference product]' ;
    rdfs:domain ind:League ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueSharingModel rdf:type rdf:Property ;
    rdfs:label 'Revenue Sharing Model' ;
    rdfs:comment 'Model used to distribute league-level revenues (broadcast rights, sponsorship, merchandise licensing) among member franchises. Drives financial planning, EBITDA reporting, and franchise valuation analytics.' ;
    rdfs:domain ind:League ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salaryCapAmount rdf:type rdf:Property ;
    rdfs:label 'Salary Cap Amount' ;
    rdfs:comment 'Current season salary cap ceiling amount in USD applicable to all teams in the league. Null if salary_cap_enabled is false. Used for CBA compliance monitoring, athlete contract validation, and financial planning.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:salaryCapCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Salary Cap Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the salary cap amount (e.g., USD, EUR, GBP). Required for multi-currency leagues such as FIFA-affiliated competitions.' ;
    rdfs:domain ind:League ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salaryCapEnabled rdf:type rdf:Property ;
    rdfs:label 'Salary Cap Enabled' ;
    rdfs:comment 'Indicates whether this league enforces a salary cap on team payrolls. Drives salary cap compliance tracking, CBA enforcement, and athlete contract validation within the athlete.salary_cap_entry domain.' ;
    rdfs:domain ind:League ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:seasonEndMonth rdf:type rdf:Property ;
    rdfs:label 'Season End Month' ;
    rdfs:comment 'Calendar month (1–12) in which the league\'s regular season (excluding playoffs) typically concludes. Used for broadcast rights window planning, venue scheduling, and off-season operations.' ;
    rdfs:domain ind:League ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:seasonStartMonth rdf:type rdf:Property ;
    rdfs:label 'Season Start Month' ;
    rdfs:comment 'Calendar month (1–12) in which the league\'s regular season typically begins. Used for fixture calendar generation, broadcast scheduling, venue operations planning, and merchandise launch timing.' ;
    rdfs:domain ind:League ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:socialMediaHandle rdf:type rdf:Property ;
    rdfs:label 'Social Media Handle' ;
    rdfs:comment 'Primary social media handle or username for the league\'s official account (e.g., \'@NFL\', \'@NBA\'). Used for fan engagement tracking, UGC (User Generated Content) moderation, and digital marketing attribution.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxExemptStatus rdf:type rdf:Property ;
    rdfs:label 'Tax Exempt Status' ;
    rdfs:comment 'Indicates whether the league operates as a tax-exempt organization under applicable tax law (e.g., 501(c)(6) in the USA). Impacts financial reporting, SAP FI/CO configuration, and SOX compliance controls.' ;
    rdfs:domain ind:League ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:abbreviation rdf:type rdf:Property ;
    rdfs:label 'Abbreviation' ;
    rdfs:comment 'Short uppercase alphanumeric code used to identify the conference in standings tables, broadcast graphics, ticketing systems, and digital platforms (e.g., AFC, NFC, AL, NL, EC, WC).' ;
    rdfs:domain ind:League ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adaComplianceRequired rdf:type rdf:Property ;
    rdfs:label 'Ada Compliance Required' ;
    rdfs:comment 'Indicates whether venues and events under this conference\'s jurisdiction are required to comply with ADA (Americans with Disabilities Act) accessibility standards. Relevant for US-based conferences and venue operations management.' ;
    rdfs:domain ind:League ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:broadcastTier rdf:type rdf:Property ;
    rdfs:label 'Broadcast Tier' ;
    rdfs:comment 'Classification of the broadcast rights tier applicable to this conference\'s games and events. Determines whether media rights are distributed nationally, regionally via RSN (Regional Sports Network), internationally, locally, or exclusively via OTT (Over-The-Top Streaming) platforms.' ;
    rdfs:domain ind:League ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conferenceCode rdf:type rdf:Property ;
    rdfs:label 'Conference Code' ;
    rdfs:comment 'Externally-known alphanumeric business identifier for the conference used in system integrations, API payloads, and data exchange with broadcast partners, ticketing platforms (Ticketmaster/AXS, Archtics), and Salesforce CRM.' ;
    rdfs:domain ind:Conference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conferenceDescription rdf:type rdf:Property ;
    rdfs:label 'Conference Description' ;
    rdfs:comment 'Free-text narrative description of the conference, including its history, competitive structure, notable championships, and organizational purpose. Used in fan engagement platforms, broadcast content, and digital asset management.' ;
    rdfs:domain ind:Conference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conferenceName rdf:type rdf:Property ;
    rdfs:label 'Conference Name' ;
    rdfs:comment 'Official full name of the conference as recognized by the governing league body (e.g., American Football Conference, Eastern Conference, American League, Western Conference).' ;
    rdfs:domain ind:Conference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conferenceStatus rdf:type rdf:Property ;
    rdfs:label 'Conference Status' ;
    rdfs:comment 'Current lifecycle status of the conference. Active indicates the conference is currently operating within a live season. Inactive indicates off-season or dormant. Suspended indicates operations are paused due to regulatory or governance action. Dissolved indicates the conference no longer exists.' ;
    rdfs:domain ind:Conference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conferenceType rdf:type rdf:Property ;
    rdfs:label 'Conference Type' ;
    rdfs:comment 'Classification of the organizational subdivision type. Distinguishes between a conference (NFL AFC/NFC), association (NBA Eastern/Western), league division (MLB American/National League), group, or pool used in tournament structures.' ;
    rdfs:domain ind:Conference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:divisionCount rdf:type rdf:Property ;
    rdfs:label 'Division Count' ;
    rdfs:comment 'Number of divisions contained within this conference for the current or most recent active season. Used for standings structure validation, playoff seeding logic, and league governance reporting.' ;
    rdfs:domain ind:Conference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:foundedDate rdf:type rdf:Property ;
    rdfs:label 'Founded Date' ;
    rdfs:comment 'The official date on which the conference was formally established and recognized by its governing league body. Supports historical analytics, anniversary campaigns, and governance documentation.' ;
    rdfs:domain ind:League ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:gamesPerTeam rdf:type rdf:Property ;
    rdfs:label 'Games Per Team' ;
    rdfs:comment 'The standard number of regular season games each team within this conference is scheduled to play per season. Used for fixture calendar generation, broadcast rights valuation, and revenue forecasting in Workday Adaptive Planning.' ;
    rdfs:domain ind:League ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:geographicAlignment rdf:type rdf:Property ;
    rdfs:label 'Geographic Alignment' ;
    rdfs:comment 'Describes the geographic or regional basis for the conference grouping (e.g., East, West, North, South, Central, National, American, International). Used for standings aggregation, broadcast territory mapping (RSN alignment), and fan engagement segmentation.' ;
    rdfs:domain ind:Conference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isInternational rdf:type rdf:Property ;
    rdfs:label 'Is International' ;
    rdfs:comment 'Indicates whether this conference operates across multiple countries or is classified as an international competition body (e.g., FIFA international competitions, IOC-governed events). Drives international broadcast rights, GDPR compliance scope, and multi-currency financial reporting.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:iso20121Certified rdf:type rdf:Property ;
    rdfs:label 'Iso 20121 Certified' ;
    rdfs:comment 'Indicates whether this conference has achieved or requires ISO 20121 Event Sustainability Management System certification for its events and operations. Supports ESG reporting and sustainability governance.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:playoffBerthCount rdf:type rdf:Property ;
    rdfs:label 'Playoff Berth Count' ;
    rdfs:comment 'Number of playoff berths allocated to this conference per season under current league rules. Drives playoff seeding logic, standings aggregation, and broadcast scheduling for postseason events.' ;
    rdfs:domain ind:Conference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryTimezone rdf:type rdf:Property ;
    rdfs:label 'Primary Timezone' ;
    rdfs:comment 'IANA time zone identifier representing the primary operational time zone for scheduling conference games and events (e.g., America/New_York, America/Los_Angeles, Europe/London). Used in event scheduling, broadcast production, and fan engagement platforms.' ;
    rdfs:domain ind:Conference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regionName rdf:type rdf:Property ;
    rdfs:label 'Region Name' ;
    rdfs:comment 'Descriptive geographic region name for the conference\'s operational territory (e.g., North America, Europe, Asia-Pacific). Used for international broadcast rights distribution, OTT platform segmentation, and global fan engagement analytics.' ;
    rdfs:domain ind:Conference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salaryCapApplicable rdf:type rdf:Property ;
    rdfs:label 'Salary Cap Applicable' ;
    rdfs:comment 'Indicates whether a salary cap rule applies to teams competing within this conference. Drives salary cap compliance validation in athlete contract and roster management workflows.' ;
    rdfs:domain ind:League ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scheduleFormat rdf:type rdf:Property ;
    rdfs:label 'Schedule Format' ;
    rdfs:comment 'The game scheduling format used within this conference (e.g., balanced where all teams play each other equally, unbalanced with division-weighted scheduling, interleague with cross-conference games). Drives fixture calendar generation.' ;
    rdfs:domain ind:Conference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seasonEndYear rdf:type rdf:Property ;
    rdfs:label 'Season End Year' ;
    rdfs:comment 'The calendar year in which this conference ceased active operations. Null if the conference is currently active. Used for historical reporting, dissolved conference analytics, and governance audit trails.' ;
    rdfs:domain ind:Conference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:seasonStartYear rdf:type rdf:Property ;
    rdfs:label 'Season Start Year' ;
    rdfs:comment 'The calendar year in which this conference first became active and began competitive operations. Used to calculate conference tenure, historical analytics, and franchise agreement timelines.' ;
    rdfs:domain ind:Conference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:teamCount rdf:type rdf:Property ;
    rdfs:label 'Team Count' ;
    rdfs:comment 'Total number of franchise teams currently assigned to this conference. Supports salary cap compliance calculations, CBA compliance reporting, and playoff bracket generation.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tiebreakerRulesVersion rdf:type rdf:Property ;
    rdfs:label 'Tiebreaker Rules Version' ;
    rdfs:comment 'Version identifier of the official tiebreaker rules document governing standings tie resolution within this conference. Ensures standings calculations and playoff seeding logic reference the correct ruleset for a given season.' ;
    rdfs:domain ind:Conference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tmoEnabled rdf:type rdf:Property ;
    rdfs:label 'Tmo Enabled' ;
    rdfs:comment 'Indicates whether Television Match Official (TMO) review technology is officially enabled for officiating decisions within this conference. Relevant for rugby and other sports using TMO protocols.' ;
    rdfs:domain ind:Conference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:divisionId rdf:type rdf:Property ;
    rdfs:label 'Division Id' ;
    rdfs:comment 'Unique surrogate identifier for the division record within the Sports Entertainment lakehouse. Primary key for the league.division data product.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Division .

ind:cbaAgreementCode rdf:type rdf:Property ;
    rdfs:label 'Cba Agreement Code' ;
    rdfs:comment 'Reference code for the Collective Bargaining Agreement (CBA) governing labor relations, player contracts, salary structures, and working conditions for teams within this division. Links to the applicable CBA document version. Classified confidential as it contains sensitive labor negotiation references.' ;
    rdfs:domain ind:Division ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentTeamCount rdf:type rdf:Property ;
    rdfs:label 'Current Team Count' ;
    rdfs:comment 'Actual number of active member franchises/teams currently assigned to this division in the current season. Drives scheduling algorithms and standings table generation.' ;
    rdfs:domain ind:Division ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:divisionCode rdf:type rdf:Property ;
    rdfs:label 'Division Code' ;
    rdfs:comment 'Externally-known alphanumeric business identifier for the division used in system integrations, data exchange with broadcast partners, ticketing systems (Ticketmaster/AXS, Archtics), and ERP (SAP S/4HANA SD) configurations. Distinct from the display abbreviation.' ;
    rdfs:domain ind:Division ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:divisionName rdf:type rdf:Property ;
    rdfs:label 'Division Name' ;
    rdfs:comment 'Official full name of the division as designated by the governing league body (e.g., \'NFC East\', \'AL Central\', \'Atlantic Division\', \'Pacific Division\'). Used in standings displays, broadcast graphics, and official publications.' ;
    rdfs:domain ind:Division ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:divisionStatus rdf:type rdf:Property ;
    rdfs:label 'Division Status' ;
    rdfs:comment 'Current operational lifecycle status of the division. \'active\' indicates the division is currently competing; \'inactive\' indicates off-season or temporarily dormant; \'suspended\' indicates governance-imposed suspension; \'dissolved\' indicates the division has been permanently disbanded; \'pending\' indicates formation approved but not yet operational.' ;
    rdfs:domain ind:Division ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:divisionType rdf:type rdf:Property ;
    rdfs:label 'Division Type' ;
    rdfs:comment 'Classification of the division\'s organizational basis — whether it is structured by geographic region, competitive skill level, age group, or gender category. Informs scheduling logic and playoff qualification criteria.' ;
    rdfs:domain ind:Division ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:draftOrderMethod rdf:type rdf:Property ;
    rdfs:label 'Draft Order Method' ;
    rdfs:comment 'The method used to determine the order in which teams within this division select players in the league draft (e.g., inverse_standings where the worst team picks first, lottery for randomized selection, hybrid combining both). Governs athlete.draft_selection records.' ;
    rdfs:domain ind:Division ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalLeagueRefCode rdf:type rdf:Property ;
    rdfs:label 'External League Ref Code' ;
    rdfs:comment 'The division identifier as assigned by the governing body\'s external data feed or official API (e.g., NFL\'s official data partner code, FIFA\'s competition ID, Stats Perform division code). Used for data reconciliation with third-party broadcast and analytics data providers.' ;
    rdfs:domain ind:Division ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gamesPerTeamRegularSeason rdf:type rdf:Property ;
    rdfs:label 'Games Per Team Regular Season' ;
    rdfs:comment 'The number of regular season games each team within this division is scheduled to play per season (e.g., 17 for NFL, 82 for NBA, 162 for MLB, 82 for NHL). Drives fixture calendar generation and broadcast scheduling.' ;
    rdfs:domain ind:Division ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:intraDivisionGames rdf:type rdf:Property ;
    rdfs:label 'Intra Division Games' ;
    rdfs:comment 'Number of games each team plays against other teams within the same division per regular season. Used in fixture scheduling algorithms to enforce divisional rivalry game requirements and scheduling balance rules.' ;
    rdfs:domain ind:Division ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maxTeamCount rdf:type rdf:Property ;
    rdfs:label 'Max Team Count' ;
    rdfs:comment 'Maximum number of member franchises/teams permitted within this division as defined by the league\'s franchise agreement and CBA (Collective Bargaining Agreement). Used for expansion planning and franchise governance.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nilPolicyApplicable rdf:type rdf:Property ;
    rdfs:label 'Nil Policy Applicable' ;
    rdfs:comment 'Indicates whether Name, Image, and Likeness (NIL) agreement policies apply to athletes competing within this division. When True, athlete.nil_agreement records are subject to divisional NIL governance rules.' ;
    rdfs:domain ind:Division ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:officiatingStandard rdf:type rdf:Property ;
    rdfs:label 'Officiating Standard' ;
    rdfs:comment 'The officiating technology and review standard applied to matches within this division. Indicates whether Video Assistant Referee (VAR) or Television Match Official (TMO) review protocols are active, or whether standard officiating applies. Drives officiating_assignment configurations in the event domain.' ;
    rdfs:domain ind:Division ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:playoffQualificationSpots rdf:type rdf:Property ;
    rdfs:label 'Playoff Qualification Spots' ;
    rdfs:comment 'Number of teams from this division that qualify for post-season playoff competition. Governs divisional standings cutoff logic and tiebreaker rule application. Critical for competitive integrity and fan engagement communications.' ;
    rdfs:domain ind:Division ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryColorHex rdf:type rdf:Property ;
    rdfs:label 'Primary Color Hex' ;
    rdfs:comment 'Hexadecimal color code representing the primary brand color associated with this division (e.g., \'#013369\' for NFL). Used in broadcast graphics, digital platform UI theming, and merchandise design specifications.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueSharingApplicable rdf:type rdf:Property ;
    rdfs:label 'Revenue Sharing Applicable' ;
    rdfs:comment 'Indicates whether league-wide revenue sharing provisions apply to franchises within this division. When True, finance.profit_center and finance.intercompany_settlement records must account for divisional revenue distribution per the CBA and franchise agreement terms.' ;
    rdfs:domain ind:Division ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:salaryCapCurrency rdf:type rdf:Property ;
    rdfs:label 'Salary Cap Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the salary cap amount (e.g., \'USD\', \'CAD\', \'EUR\'). Required for international leagues (FIFA, MLS) operating across multiple currency jurisdictions.' ;
    rdfs:domain ind:League ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tiebreakerRuleSet rdf:type rdf:Property ;
    rdfs:label 'Tiebreaker Rule Set' ;
    rdfs:comment 'Identifier or descriptive label for the official tiebreaker rules applied when two or more teams are equal in divisional standings (e.g., \'NFL_2024_TIEBREAKER\', \'NBA_CONF_TIEBREAKER_V3\'). References the league\'s official competition rules document. Drives automated standings calculation logic.' ;
    rdfs:domain ind:Division ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:homeVenueId rdf:type rdf:Property ;
    rdfs:label 'Home Venue Id' ;
    rdfs:comment 'Reference to the primary home venue where this franchise plays its home games, used for scheduling, ticketing, and venue operations.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Venue .

ind:activeRosterCount rdf:type rdf:Property ;
    rdfs:label 'Active Roster Count' ;
    rdfs:comment 'Number of players currently on the franchise\'s active roster as of the most recent official roster filing snapshot. Must comply with league-mandated roster size limits under the CBA.' ;
    rdfs:domain ind:Franchise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:agreementEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Agreement Effective Date' ;
    rdfs:comment 'The date from which the current franchise agreement terms become legally binding and operationally effective.' ;
    rdfs:domain ind:Franchise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:agreementExecutionDate rdf:type rdf:Property ;
    rdfs:label 'Agreement Execution Date' ;
    rdfs:comment 'The date on which the current version of the franchise agreement was formally executed and signed by both the franchise ownership and the league governing body.' ;
    rdfs:domain ind:Franchise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:agreementExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Agreement Expiry Date' ;
    rdfs:comment 'The date on which the current franchise agreement expires and must be renewed or renegotiated. Null for perpetual agreements.' ;
    rdfs:domain ind:Franchise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:agreementVersion rdf:type rdf:Property ;
    rdfs:label 'Agreement Version' ;
    rdfs:comment 'Version identifier of the current franchise agreement governing this franchise\'s league membership (e.g., \'v3.2\', \'2022-Amendment-1\'). Tracks which contractual terms are in force.' ;
    rdfs:domain ind:Franchise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amendmentHistoryNotes rdf:type rdf:Property ;
    rdfs:label 'Amendment History Notes' ;
    rdfs:comment 'Free-text notes summarizing the history of amendments made to the franchise agreement since its original execution, including amendment dates and key changes. Full amendment documents are stored in the DAM.' ;
    rdfs:domain ind:Franchise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competitiveIntegrityFlag rdf:type rdf:Property ;
    rdfs:label 'Competitive Integrity Flag' ;
    rdfs:comment 'Indicates whether the franchise is currently under a competitive integrity review or investigation by the league (True = under review). Used for governance and disciplinary tracking.' ;
    rdfs:domain ind:League ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:disciplinarySanctionStatus rdf:type rdf:Property ;
    rdfs:label 'Disciplinary Sanction Status' ;
    rdfs:comment 'Current disciplinary sanction status of the franchise as imposed by the league governing body. Tracks active penalties affecting franchise operations, draft eligibility, or competitive standing. [ENUM-REF-CANDIDATE: none|warning_issued|fined|draft_pick_forfeited|suspended|under_investigation — promote to reference product]' ;
    rdfs:domain ind:Franchise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:draftPickOrderPriority rdf:type rdf:Property ;
    rdfs:label 'Draft Pick Order Priority' ;
    rdfs:comment 'The franchise\'s current draft selection order priority for the upcoming league draft, as determined by the prior season\'s standings and any applicable draft pick trades. Lower number = earlier selection.' ;
    rdfs:domain ind:Franchise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:expansionFeePaid rdf:type rdf:Property ;
    rdfs:label 'Expansion Fee Paid' ;
    rdfs:comment 'The one-time expansion fee paid by the ownership group upon admission of this franchise to the league. Applicable only to expansion franchises; null for original member franchises.' ;
    rdfs:domain ind:Franchise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:franchiseStatus rdf:type rdf:Property ;
    rdfs:label 'Franchise Status' ;
    rdfs:comment 'Current operational lifecycle status of the franchise within the league. \'active\' = currently competing; \'suspended\' = temporarily barred from competition; \'defunct\' = no longer operating; \'expansion_pending\' = approved but not yet competing; \'relocated\' = moved to a new market.' ;
    rdfs:domain ind:Franchise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:injuredReserveCount rdf:type rdf:Property ;
    rdfs:label 'Injured Reserve Count' ;
    rdfs:comment 'Number of players currently designated on the Injured Reserve (IR) list in the most recent official roster filing snapshot. Tracks roster compliance and cap implications of IR designations.' ;
    rdfs:domain ind:Franchise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isCbaParticipant rdf:type rdf:Property ;
    rdfs:label 'Is Cba Participant' ;
    rdfs:comment 'Indicates whether this franchise is an active participant in the current Collective Bargaining Agreement (CBA). Relevant for salary cap compliance, player relations, and labor dispute governance.' ;
    rdfs:domain ind:Franchise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isExpansionFranchise rdf:type rdf:Property ;
    rdfs:label 'Is Expansion Franchise' ;
    rdfs:comment 'Indicates whether this franchise was admitted to the league as an expansion team (True) as opposed to being an original founding member franchise (False). Affects expansion fee tracking and revenue sharing tiers.' ;
    rdfs:domain ind:Franchise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:marketCity rdf:type rdf:Property ;
    rdfs:label 'Market City' ;
    rdfs:comment 'The primary city or metropolitan area in which the franchise is based and markets itself (e.g., \'Kansas City\', \'Los Angeles\', \'New York\'). Used for territorial rights enforcement and market analysis.' ;
    rdfs:domain ind:Franchise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketCountryCode rdf:type rdf:Property ;
    rdfs:label 'Market Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code for the franchise\'s primary market (e.g., \'USA\', \'CAN\', \'GBR\'). Required for international leagues and cross-border regulatory compliance.' ;
    rdfs:domain ind:Franchise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownershipTransferRulesSummary rdf:type rdf:Property ;
    rdfs:label 'Ownership Transfer Rules Summary' ;
    rdfs:comment 'Summary of the key ownership transfer rules applicable to this franchise under the league agreement, including approval thresholds, right-of-first-refusal provisions, and prohibited ownership structures.' ;
    rdfs:domain ind:Franchise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:practiceSquadCount rdf:type rdf:Property ;
    rdfs:label 'Practice Squad Count' ;
    rdfs:comment 'Number of players currently on the franchise\'s practice squad as of the most recent official roster filing snapshot. Practice squad limits are defined by the applicable CBA.' ;
    rdfs:domain ind:Franchise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryJerseyColor rdf:type rdf:Property ;
    rdfs:label 'Primary Jersey Color' ;
    rdfs:comment 'The primary jersey color associated with the franchise\'s home uniform, used for broadcast graphics, merchandise production, and brand identity management.' ;
    rdfs:domain ind:Franchise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relocationRestrictionExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Relocation Restriction Expiry Date' ;
    rdfs:comment 'The date on which the relocation restriction clause in the franchise agreement expires, after which the franchise may apply to relocate subject to league approval. Null if no restriction or restriction is permanent.' ;
    rdfs:domain ind:Franchise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:relocationRestrictionFlag rdf:type rdf:Property ;
    rdfs:label 'Relocation Restriction Flag' ;
    rdfs:comment 'Indicates whether the franchise agreement contains an active relocation restriction clause (True) preventing the franchise from moving to a new market without league approval during the restriction period.' ;
    rdfs:domain ind:Franchise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:revenueSharingTier rdf:type rdf:Property ;
    rdfs:label 'Revenue Sharing Tier' ;
    rdfs:comment 'Classification tier that determines this franchise\'s revenue sharing obligations and entitlements under the league\'s revenue distribution model (e.g., national media rights, gate receipts). Tier definitions vary by league.' ;
    rdfs:domain ind:Franchise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rosterComplianceStatus rdf:type rdf:Property ;
    rdfs:label 'Roster Compliance Status' ;
    rdfs:comment 'Current compliance status of the franchise\'s official roster filing against league rules and CBA requirements. \'compliant\' = all roster limits met; \'non_compliant\' = violation identified; \'under_review\' = league audit in progress; \'waiver_granted\' = exception approved.' ;
    rdfs:domain ind:Franchise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rosterSnapshotDate rdf:type rdf:Property ;
    rdfs:label 'Roster Snapshot Date' ;
    rdfs:comment 'The date on which the most recent official roster filing snapshot was captured and submitted to the league for compliance verification.' ;
    rdfs:domain ind:Franchise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:salaryCapAllotment rdf:type rdf:Property ;
    rdfs:label 'Salary Cap Allotment' ;
    rdfs:comment 'The maximum total player salary expenditure permitted for this franchise in the current league season under the applicable CBA salary cap rules. Expressed in USD.' ;
    rdfs:domain ind:Franchise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:teamNickname rdf:type rdf:Property ;
    rdfs:label 'Team Nickname' ;
    rdfs:comment 'The publicly recognized team nickname or mascot name (e.g., \'Chiefs\', \'Lakers\', \'Yankees\'). Used in fan-facing communications, broadcasting, and merchandise.' ;
    rdfs:domain ind:Franchise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:territorialRightsDescription rdf:type rdf:Property ;
    rdfs:label 'Territorial Rights Description' ;
    rdfs:comment 'Narrative description of the exclusive geographic territory granted to this franchise under its league membership agreement, defining the protected market area within which no other franchise may operate.' ;
    rdfs:domain ind:Franchise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valuationEstimate rdf:type rdf:Property ;
    rdfs:label 'Valuation Estimate' ;
    rdfs:comment 'Most recent estimated market valuation of the franchise in USD, as reported by the league or a recognized financial publication (e.g., Forbes). Used for ownership transfer approvals, expansion fee benchmarking, and financial reporting.' ;
    rdfs:domain ind:Franchise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:championshipVenueId rdf:type rdf:Property ;
    rdfs:label 'Championship Venue Id' ;
    rdfs:comment 'Reference to the pre-designated venue for the championship event when a neutral site is used. Populated only when neutral_site_championship_flag is true. Drives venue operations, ADA compliance, and OSHA safety planning.' ;
    rdfs:domain ind:League ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Venue .

ind:byeTeams rdf:type rdf:Property ;
    rdfs:label 'Bye Teams' ;
    rdfs:comment 'Number of top-seeded franchises that receive a first-round bye (automatic advancement to the second round without playing). Zero if no byes are granted. Impacts bracket scheduling and revenue from first-round games.' ;
    rdfs:domain ind:Season ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:expansionSeasonFlag rdf:type rdf:Property ;
    rdfs:label 'Expansion Season Flag' ;
    rdfs:comment 'Indicates whether this season includes one or more expansion franchises entering the league for the first time. When true, expansion draft rules, schedule adjustments, and revenue sharing modifications apply.' ;
    rdfs:domain ind:Season ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:freeAgencyStartDate rdf:type rdf:Property ;
    rdfs:label 'Free Agency Start Date' ;
    rdfs:comment 'The date on which the free agency signing period opens for this season, allowing franchises to negotiate and sign unrestricted free agents. Anchors contract activity, salary cap management, and roster building timelines.' ;
    rdfs:domain ind:Season ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:homeAdvantageRule rdf:type rdf:Property ;
    rdfs:label 'Home Advantage Rule' ;
    rdfs:comment 'Description of the rule governing which franchise hosts games in a playoff series (e.g., \'Higher seed hosts games 1, 2, 5, 7\', \'Higher seed hosts all games\'). Impacts venue scheduling, ticket revenue allocation, and broadcast logistics.' ;
    rdfs:domain ind:League ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:luxuryTaxThreshold rdf:type rdf:Property ;
    rdfs:label 'Luxury Tax Threshold' ;
    rdfs:comment 'The payroll threshold above which a franchise incurs luxury tax penalties for this season, as defined in the CBA. Expressed in the salary cap currency. Used for franchise financial compliance monitoring.' ;
    rdfs:domain ind:League ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:neutralSiteChampionshipFlag rdf:type rdf:Property ;
    rdfs:label 'Neutral Site Championship Flag' ;
    rdfs:comment 'Indicates whether the championship game/series is played at a pre-selected neutral venue rather than the higher seed\'s home venue (e.g., Super Bowl, FIFA World Cup Final). Impacts venue booking, ticket allocation, and broadcast production planning.' ;
    rdfs:domain ind:Season ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:officiatingSystem rdf:type rdf:Property ;
    rdfs:label 'Officiating System' ;
    rdfs:comment 'The video review and officiating technology system in use for this season: VAR (Video Assistant Referee) for soccer/football, TMO (Television Match Official) for rugby, challenge_system for MLB/NFL, or standard for traditional officiating without video review. Governs officiating assignment and incident review workflows.' ;
    rdfs:domain ind:Season ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:playoffRounds rdf:type rdf:Property ;
    rdfs:label 'Playoff Rounds' ;
    rdfs:comment 'Total number of rounds in the postseason bracket from first round through championship (e.g., 4 rounds for NBA: First Round, Semifinals, Conference Finals, Finals). Drives bracket position assignments and series scheduling.' ;
    rdfs:domain ind:Season ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:playoffTeams rdf:type rdf:Property ;
    rdfs:label 'Playoff Teams' ;
    rdfs:comment 'Total number of franchises/teams that qualify for the postseason bracket (e.g., 12 for NFL, 16 for NBA, 16 for NHL). Determines seeding slots, bracket size, and bye eligibility.' ;
    rdfs:domain ind:Season ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:postseasonEndDate rdf:type rdf:Property ;
    rdfs:label 'Postseason End Date' ;
    rdfs:comment 'Official last date of the postseason including the championship event. Marks the close of the competitive season for all governance and compliance purposes.' ;
    rdfs:domain ind:Season ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:postseasonStartDate rdf:type rdf:Property ;
    rdfs:label 'Postseason Start Date' ;
    rdfs:comment 'Official start date of the postseason/playoff bracket. Triggers playoff ticketing, broadcast rights escalation, and championship merchandise activation.' ;
    rdfs:domain ind:Season ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regularSeasonEndDate rdf:type rdf:Property ;
    rdfs:label 'Regular Season End Date' ;
    rdfs:comment 'Official last date of the regular season schedule before postseason begins. Used to finalize standings, seeding, and playoff bracket assignments.' ;
    rdfs:domain ind:Season ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regularSeasonStartDate rdf:type rdf:Property ;
    rdfs:label 'Regular Season Start Date' ;
    rdfs:comment 'Official start date of the regular season competitive schedule, distinct from preseason. Used to trigger standings calculations, fantasy sports activations, and broadcast rights windows.' ;
    rdfs:domain ind:Season ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rosterFreezeDate rdf:type rdf:Property ;
    rdfs:label 'Roster Freeze Date' ;
    rdfs:comment 'The date by which all franchise rosters must be finalized and submitted to the league for the season. Triggers eligibility locks for regular season and postseason participation.' ;
    rdfs:domain ind:Season ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:salaryCapYearFlag rdf:type rdf:Property ;
    rdfs:label 'Salary Cap Year Flag' ;
    rdfs:comment 'Indicates whether this season constitutes a salary cap year for compliance and roster management purposes. When true, salary cap rules, luxury tax thresholds, and CBA roster limits apply to all franchises for this season.' ;
    rdfs:domain ind:Season ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:seasonCode rdf:type rdf:Property ;
    rdfs:label 'Season Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying the season across systems (e.g., \'NFL-2024-REG\', \'NBA-2024-25\'). Used as the business key in scheduling, ticketing, and broadcast rights systems.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seasonName rdf:type rdf:Property ;
    rdfs:label 'Season Name' ;
    rdfs:comment 'Human-readable display name for the season (e.g., \'2024-25 NBA Regular Season\', \'2024 NFL Season\'). Used in fan-facing platforms, broadcast graphics, and reporting dashboards.' ;
    rdfs:domain ind:Season ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seasonType rdf:type rdf:Property ;
    rdfs:label 'Season Type' ;
    rdfs:comment 'Classification of the season phase: preseason (training/exhibition games), regular (standard competitive schedule), postseason (playoff/championship bracket), allstar (mid-season showcase event), or exhibition (non-competitive friendly). Drives scheduling, standings, and broadcast rights logic.' ;
    rdfs:domain ind:Season ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seriesGamesFormat rdf:type rdf:Property ;
    rdfs:label 'Series Games Format' ;
    rdfs:comment 'The number of games in each playoff series (e.g., best_of_7 for NBA/NHL Finals, best_of_5 for early rounds, single_game for NFL playoff rounds). Drives game scheduling, broadcast rights windows, and venue booking.' ;
    rdfs:domain ind:Season ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shortenedSeasonFlag rdf:type rdf:Property ;
    rdfs:label 'Shortened Season Flag' ;
    rdfs:comment 'Indicates whether this season was shortened from the standard games_per_team count due to labor disputes, pandemic, or other force majeure events. When true, prorated salary cap and adjusted standings rules apply.' ;
    rdfs:domain ind:Season ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:theme rdf:type rdf:Property ;
    rdfs:label 'Theme' ;
    rdfs:comment 'Official marketing theme or campaign name for the season as defined by the league (e.g., \'NBA 75th Anniversary Season\', \'NFL 100\'). Used in fan engagement, merchandise, and content production campaigns.' ;
    rdfs:domain ind:Season ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradeDeadlineDate rdf:type rdf:Property ;
    rdfs:label 'Trade Deadline Date' ;
    rdfs:comment 'The last date on which franchises may execute player trades during the regular season. After this date, rosters are locked for playoff eligibility. Critical for roster management, salary cap compliance, and fan engagement.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:year rdf:type rdf:Property ;
    rdfs:label 'Year' ;
    rdfs:comment 'The primary calendar year associated with the season (e.g., 2024). For multi-year seasons (e.g., NBA 2024-25), this represents the start year. Used as the anchor year for salary cap, CBA compliance, and draft calculations.' ;
    rdfs:domain ind:League ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryLeagueHomeFranchiseId rdf:type rdf:Property ;
    rdfs:label 'Primary League Home Franchise Id' ;
    rdfs:comment 'Reference to the franchise designated as the home team for this scheduled game. Determines venue assignment, gate revenue allocation, and home/away scheduling balance tracking.' ;
    rdfs:domain ind:LeagueSchedule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Franchise .

ind:rescheduledFromLeagueScheduleId rdf:type rdf:Property ;
    rdfs:label 'Rescheduled From League Schedule Id' ;
    rdfs:comment 'Self-referencing identifier pointing to the original schedule record from which this game was rescheduled. Enables rescheduling lineage tracking, broadcast rights re-assignment audit, and ticketing system (Ticketmaster/AXS) rebooking reconciliation. Null for games that have never been rescheduled.' ;
    rdfs:domain ind:LeagueSchedule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LeagueSchedule .

ind:broadcastNetwork rdf:type rdf:Property ;
    rdfs:label 'Broadcast Network' ;
    rdfs:comment 'Name of the primary broadcast network or platform assigned to air this game (e.g., ESPN, NBC, Fox, CBS, TNT, Amazon Prime Video, Apple TV+, DAZN). Used for media rights compliance, CPM (Cost Per Mille) reporting, and RSN (Regional Sports Network) distribution tracking.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gameNumber rdf:type rdf:Property ;
    rdfs:label 'Game Number' ;
    rdfs:comment 'Externally-known official league-assigned game identifier (e.g., NFL-2024-001234). Used across ticketing systems (Ticketmaster/AXS), broadcast scheduling (Dalet Galaxy), and fan engagement platforms (Adobe Experience Platform) as the cross-system reference key.' ;
    rdfs:domain ind:LeagueSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gameType rdf:type rdf:Property ;
    rdfs:label 'Game Type' ;
    rdfs:comment 'Classification of the game within the competitive calendar. Determines standings eligibility, salary cap transaction window compliance, broadcast rights tier, and ticket pricing strategy. [ENUM-REF-CANDIDATE: regular_season|playoff|exhibition|neutral_site|all_star|championship|play_in|wild_card — promote to reference product]' ;
    rdfs:domain ind:LeagueSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gateRevenueSplitPct rdf:type rdf:Property ;
    rdfs:label 'Gate Revenue Split Pct' ;
    rdfs:comment 'The contractually agreed percentage of gate revenue allocated to the visiting (away) franchise for this game, as defined in the league\'s revenue sharing agreement. Confidential financial term used by SAP S/4HANA (SD/FI modules) for revenue recognition and intercompany settlement.' ;
    rdfs:domain ind:LeagueSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:internationalBroadcastFlag rdf:type rdf:Property ;
    rdfs:label 'International Broadcast Flag' ;
    rdfs:comment 'Indicates whether this game has international broadcast rights activated beyond the domestic market. Triggers GDPR-compliant geo-restriction logic for OTT/DTC streaming platforms and international media rights window management in Dalet Galaxy.' ;
    rdfs:domain ind:LeagueSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isHomeAwayReversed rdf:type rdf:Property ;
    rdfs:label 'Is Home Away Reversed' ;
    rdfs:comment 'Indicates whether the standard home/away designation has been reversed for this game (e.g., a team plays a \'home\' game at the opponent\'s venue due to facility unavailability or international series). Used for scheduling balance audits and CBA home game count compliance.' ;
    rdfs:domain ind:LeagueSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:matchdayLabel rdf:type rdf:Property ;
    rdfs:label 'Matchday Label' ;
    rdfs:comment 'Human-readable label for the scheduling period as published by the league (e.g., \'Matchday 12\', \'Week 7\', \'Round of 16\', \'Wild Card Weekend\', \'Opening Day\'). Used in fan-facing communications, broadcast graphics, and digital content distribution.' ;
    rdfs:domain ind:LeagueSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalScheduledDate rdf:type rdf:Property ;
    rdfs:label 'Original Scheduled Date' ;
    rdfs:comment 'The initially published league calendar date for this game before any postponement or rescheduling. Retained for audit trail, rescheduling impact analysis, and CBA transaction window compliance verification. Null if the game has never been rescheduled.' ;
    rdfs:domain ind:LeagueSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:originalStartTime rdf:type rdf:Property ;
    rdfs:label 'Original Start Time' ;
    rdfs:comment 'The initially published start timestamp for this game before any time change or rescheduling. Retained alongside original_scheduled_date for complete rescheduling audit trail and broadcast rights window compliance tracking.' ;
    rdfs:domain ind:LeagueSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:postponementReason rdf:type rdf:Property ;
    rdfs:label 'Postponement Reason' ;
    rdfs:comment 'Categorized reason for a game postponement or cancellation. Required for league governance reporting, insurance claims, broadcast rights force majeure provisions, and ISO 20121 event sustainability documentation. Null when scheduling_status is \'confirmed\'. [ENUM-REF-CANDIDATE: weather|facility_issue|public_safety|broadcast_conflict|force_majeure|covid_protocol|labor_dispute|bereavement|other — promote to reference product]' ;
    rdfs:domain ind:LeagueSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salaryCapWindowFlag rdf:type rdf:Property ;
    rdfs:label 'Salary Cap Window Flag' ;
    rdfs:comment 'Indicates whether this game date falls within a salary cap compliance reporting window as defined by the applicable CBA. Used by league finance and compliance teams to trigger cap audit checkpoints aligned to the competitive calendar.' ;
    rdfs:domain ind:LeagueSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scheduledDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Date' ;
    rdfs:comment 'The official league-published calendar date on which the game is scheduled to be played (yyyy-MM-dd). Used as the primary planning date for event operations, venue staffing, and broadcast scheduling. Represents the current confirmed date (may differ from original_scheduled_date if rescheduled).' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:schedulingStatus rdf:type rdf:Property ;
    rdfs:label 'Scheduling Status' ;
    rdfs:comment 'Current lifecycle state of the scheduled game. Drives downstream event operations, broadcast slot management, ticketing refund workflows (Ticketmaster/AXS), and standings calculation eligibility. Confirmed = league-approved and published; Postponed = delayed with new date TBD; Cancelled = permanently removed; Rescheduled = new date assigned; Pending = awaiting league confirmation; Suspended = mid-game stoppage requiring resumption.' ;
    rdfs:domain ind:LeagueSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seriesGameNumber rdf:type rdf:Property ;
    rdfs:label 'Series Game Number' ;
    rdfs:comment 'The sequential game number within a playoff or regular-season series between the same two franchises (e.g., Game 3 of 7 in an NBA Playoff series, Game 2 of 3 in an MLB series). Null for non-series single-game matchups.' ;
    rdfs:domain ind:LeagueSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:seriesGameTotal rdf:type rdf:Property ;
    rdfs:label 'Series Game Total' ;
    rdfs:comment 'The maximum number of games in the series to which this game belongs (e.g., best-of-7 = 7, best-of-5 = 5, two-game series = 2). Used alongside series_game_number for bracket progression logic and playoff scheduling management.' ;
    rdfs:domain ind:LeagueSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ticketOnSaleDate rdf:type rdf:Property ;
    rdfs:label 'Ticket On Sale Date' ;
    rdfs:comment 'The date on which tickets for this game become available for public purchase via Ticketmaster/AXS and DTC (Direct-To-Consumer) channels. Drives fan engagement campaign scheduling in Adobe Experience Platform and Salesforce CRM outreach workflows.' ;
    rdfs:domain ind:LeagueSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:timezone rdf:type rdf:Property ;
    rdfs:label 'Timezone' ;
    rdfs:comment 'IANA timezone identifier for the venue location where the game is played (e.g., \'America/New_York\', \'Europe/London\', \'Asia/Tokyo\'). Required for accurate broadcast scheduling, fan notification timing, and international rights window management.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionWindowCompliant rdf:type rdf:Property ;
    rdfs:label 'Transaction Window Compliant' ;
    rdfs:comment 'Indicates whether this game falls within a CBA-defined transaction window (e.g., trade deadline, waiver period, roster freeze). Critical for league compliance officers to validate that no prohibited roster moves occurred in the window surrounding this game.' ;
    rdfs:domain ind:League ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:weekNumber rdf:type rdf:Property ;
    rdfs:label 'Week Number' ;
    rdfs:comment 'The sequential week number within the season calendar (e.g., NFL Week 1 through Week 18). Used for standings calculations, bye week tracking, and scheduling balance analysis. Applicable primarily to weekly-format leagues (NFL, NHL, NBA). Null for round-based or matchday-based competitions.' ;
    rdfs:domain ind:LeagueSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:standingId rdf:type rdf:Property ;
    rdfs:label 'Standing Id' ;
    rdfs:comment 'Unique surrogate identifier for a competitive standing snapshot record within the league data domain.' ;
    rdfs:domain ind:Standing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:awayLosses rdf:type rdf:Property ;
    rdfs:label 'Away Losses' ;
    rdfs:comment 'Total number of losses recorded in away (road) games as of the snapshot date.' ;
    rdfs:domain ind:Standing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:awayTies rdf:type rdf:Property ;
    rdfs:label 'Away Ties' ;
    rdfs:comment 'Total number of ties or draws recorded in away (road) games. Applicable in MLS, FIFA, and NFL regular season formats.' ;
    rdfs:domain ind:Standing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:awayWins rdf:type rdf:Property ;
    rdfs:label 'Away Wins' ;
    rdfs:comment 'Total number of wins recorded in away (road) games as of the snapshot date. Used in tiebreaker resolution.' ;
    rdfs:domain ind:Standing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:clinchIndicator rdf:type rdf:Property ;
    rdfs:label 'Clinch Indicator' ;
    rdfs:comment 'Standard league clinch/elimination indicator code displayed in standings: x = clinched playoff berth, y = clinched division title, z = clinched best record in conference, e = eliminated from playoff contention, w = clinched best overall record, p = clinched home-field advantage. Null if no clinch or elimination status applies.' ;
    rdfs:domain ind:Standing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conferenceLosses rdf:type rdf:Property ;
    rdfs:label 'Conference Losses' ;
    rdfs:comment 'Total number of losses recorded against conference opponents as of the snapshot date.' ;
    rdfs:domain ind:Standing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:conferenceRank rdf:type rdf:Property ;
    rdfs:label 'Conference Rank' ;
    rdfs:comment 'Ordinal rank of the franchise within its conference as of the snapshot date. Used for playoff seeding and wild card qualification.' ;
    rdfs:domain ind:Standing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:conferenceWins rdf:type rdf:Property ;
    rdfs:label 'Conference Wins' ;
    rdfs:comment 'Total number of wins recorded against conference opponents as of the snapshot date. Used as a tiebreaker criterion in NFL, NBA, and NHL standings.' ;
    rdfs:domain ind:Standing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:currentStreakCount rdf:type rdf:Property ;
    rdfs:label 'Current Streak Count' ;
    rdfs:comment 'Number of consecutive games in the current streak of the same result type (wins, losses, or ties). Combined with current_streak_type to express the full streak.' ;
    rdfs:domain ind:Standing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:currentStreakType rdf:type rdf:Property ;
    rdfs:label 'Current Streak Type' ;
    rdfs:comment 'Type of the franchise\'s current consecutive result streak: W (Win), L (Loss), T (Tie), or D (Draw). Combined with current_streak_count to express the full streak (e.g., W5 = five consecutive wins).' ;
    rdfs:domain ind:Standing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:divisionLosses rdf:type rdf:Property ;
    rdfs:label 'Division Losses' ;
    rdfs:comment 'Total number of losses recorded against divisional opponents as of the snapshot date.' ;
    rdfs:domain ind:Standing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:divisionRank rdf:type rdf:Property ;
    rdfs:label 'Division Rank' ;
    rdfs:comment 'Ordinal rank of the franchise within its division as of the snapshot date. Rank 1 indicates the division leader. Used for playoff seeding and tiebreaker resolution.' ;
    rdfs:domain ind:Standing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:divisionWins rdf:type rdf:Property ;
    rdfs:label 'Division Wins' ;
    rdfs:comment 'Total number of wins recorded against divisional opponents as of the snapshot date. A primary tiebreaker criterion in NFL, NBA, MLB, and NHL standings.' ;
    rdfs:domain ind:Standing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:eliminationNumber rdf:type rdf:Property ;
    rdfs:label 'Elimination Number' ;
    rdfs:comment 'Combined number of losses by the trailing team and wins by the leading competitor that would result in mathematical elimination from playoff contention. Null when already eliminated or clinched.' ;
    rdfs:domain ind:Standing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:gamesBehind rdf:type rdf:Property ;
    rdfs:label 'Games Behind' ;
    rdfs:comment 'Number of games the franchise trails the division or conference leader in the standings. A value of 0.0 indicates the franchise is tied for or holds the lead. Calculated as ((leader_wins - team_wins) + (team_losses - leader_losses)) / 2.' ;
    rdfs:domain ind:Standing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:homeLosses rdf:type rdf:Property ;
    rdfs:label 'Home Losses' ;
    rdfs:comment 'Total number of losses recorded in home venue games as of the snapshot date.' ;
    rdfs:domain ind:Standing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:homeTies rdf:type rdf:Property ;
    rdfs:label 'Home Ties' ;
    rdfs:comment 'Total number of ties or draws recorded in home venue games. Applicable in MLS, FIFA, and NFL regular season formats.' ;
    rdfs:domain ind:Standing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:homeWins rdf:type rdf:Property ;
    rdfs:label 'Home Wins' ;
    rdfs:comment 'Total number of wins recorded in home venue games as of the snapshot date. Used in tiebreaker resolution and home-field advantage analysis.' ;
    rdfs:domain ind:Standing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:last10Losses rdf:type rdf:Property ;
    rdfs:label 'Last10 Losses' ;
    rdfs:comment 'Number of losses in the franchise\'s most recent 10 official games. Combined with last10_wins to express the last-10 record (e.g., 7-3).' ;
    rdfs:domain ind:Standing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:last10Wins rdf:type rdf:Property ;
    rdfs:label 'Last10 Wins' ;
    rdfs:comment 'Number of wins in the franchise\'s most recent 10 official games. Used as a recent form indicator in standings displays and playoff race analysis.' ;
    rdfs:domain ind:Standing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:leagueRank rdf:type rdf:Property ;
    rdfs:label 'League Rank' ;
    rdfs:comment 'Ordinal rank of the franchise across the entire league as of the snapshot date. Used for draft order determination and overall competitive positioning.' ;
    rdfs:domain ind:Standing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:losses rdf:type rdf:Property ;
    rdfs:label 'Losses' ;
    rdfs:comment 'Total number of official games lost by the franchise in regulation, overtime, or shootout as of the snapshot date.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:magicNumber rdf:type rdf:Property ;
    rdfs:label 'Magic Number' ;
    rdfs:comment 'Combined number of wins by the leading team and losses by the closest competitor needed to clinch a division title or playoff berth. Null when not applicable or when already clinched/eliminated.' ;
    rdfs:domain ind:Standing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:overtimeLosses rdf:type rdf:Property ;
    rdfs:label 'Overtime Losses' ;
    rdfs:comment 'Total number of games lost in overtime or shootout. Used primarily in NHL standings where an overtime loss earns one point. Null or zero for leagues without overtime loss distinction.' ;
    rdfs:domain ind:Standing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:playoffSeed rdf:type rdf:Property ;
    rdfs:label 'Playoff Seed' ;
    rdfs:comment 'Projected or confirmed playoff seeding position for the franchise based on current standings. Determines bracket placement, home-field advantage, and first-round matchups. Null if the franchise is eliminated or the playoff field is not yet determined.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:points rdf:type rdf:Property ;
    rdfs:label 'Points' ;
    rdfs:comment 'Total standings points accumulated by the franchise. Used in NHL (2 pts per win, 1 pt per OTL), MLS, and FIFA competition formats. Null for leagues using winning percentage as the primary ranking metric.' ;
    rdfs:domain ind:Standing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:runDifferential rdf:type rdf:Property ;
    rdfs:label 'Run Differential' ;
    rdfs:comment 'Net difference between total runs/goals/points scored and total runs/goals/points allowed across all games. Positive values indicate the franchise scores more than it concedes. Used as a tiebreaker and competitive health indicator across MLB (runs), NHL/MLS/FIFA (goals), and NBA (points).' ;
    rdfs:domain ind:Standing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:runsAllowed rdf:type rdf:Property ;
    rdfs:label 'Runs Allowed' ;
    rdfs:comment 'Total runs (MLB), goals (NHL/MLS/FIFA), or points (NBA/NFL) allowed by the franchise across all applicable games as of the snapshot date.' ;
    rdfs:domain ind:Standing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:runsScored rdf:type rdf:Property ;
    rdfs:label 'Runs Scored' ;
    rdfs:comment 'Total runs (MLB), goals (NHL/MLS/FIFA), or points (NBA/NFL) scored by the franchise across all applicable games as of the snapshot date.' ;
    rdfs:domain ind:Standing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:snapshotDate rdf:type rdf:Property ;
    rdfs:label 'Snapshot Date' ;
    rdfs:comment 'The calendar date on which this standings snapshot was captured, typically updated after each official game result is processed.' ;
    rdfs:domain ind:Standing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:standingStatus rdf:type rdf:Property ;
    rdfs:label 'Standing Status' ;
    rdfs:comment 'Current lifecycle status of this standing record: active (season in progress), clinched (playoff berth secured), eliminated (mathematically eliminated from playoff contention), pending (awaiting game result), or final (season concluded).' ;
    rdfs:domain ind:Standing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standingsType rdf:type rdf:Property ;
    rdfs:label 'Standings Type' ;
    rdfs:comment 'Classification of the standings context: regular season, postseason, preseason, tournament group stage, or playoff bracket. Determines which game results are included in the standing calculation.' ;
    rdfs:domain ind:Standing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strengthOfSchedule rdf:type rdf:Property ;
    rdfs:label 'Strength Of Schedule' ;
    rdfs:comment 'Composite metric representing the combined winning percentage of all opponents faced by the franchise as of the snapshot date. Used as a tiebreaker criterion in NFL standings and for playoff seeding analysis.' ;
    rdfs:domain ind:Standing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ties rdf:type rdf:Property ;
    rdfs:label 'Ties' ;
    rdfs:comment 'Total number of official games ending in a tie or draw (applicable in MLS, FIFA, and NFL regular season). Null or zero for leagues that do not permit ties.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:wildCardRank rdf:type rdf:Property ;
    rdfs:label 'Wild Card Rank' ;
    rdfs:comment 'Ordinal rank of the franchise among wild card contenders within its conference or league. Null if the franchise has clinched a division title or is eliminated from wild card contention.' ;
    rdfs:domain ind:Standing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:winPct rdf:type rdf:Property ;
    rdfs:label 'Win Pct' ;
    rdfs:comment 'Winning percentage calculated as wins divided by games played (ties count as half a win in applicable leagues). Primary ranking metric in MLB and NBA standings.' ;
    rdfs:domain ind:Standing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wins rdf:type rdf:Property ;
    rdfs:label 'Wins' ;
    rdfs:comment 'Total number of official games won by the franchise in regulation, overtime, or shootout as of the snapshot date.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:playoffMvpAthleteAthleteProfileId rdf:type rdf:Property ;
    rdfs:label 'Playoff Mvp Athlete Athlete Profile Id' ;
    rdfs:comment 'Reference to the athlete awarded the Most Valuable Player (MVP) honor for the playoff bracket/championship series. Populated upon bracket completion. Drives NIL, sponsorship, and award management processes.' ;
    rdfs:domain ind:PlayoffBracket ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AthleteProfile .

ind:primaryPlayoffBroadcastRightsPackageMediaRightsDealId rdf:type rdf:Property ;
    rdfs:label 'Primary Playoff Broadcast Rights Package Media Rights Deal Id' ;
    rdfs:comment 'Reference to the broadcast and media rights package governing playoff coverage, including OTT, RSN, PPV, and DTC distribution rights for this bracket\'s games.' ;
    rdfs:domain ind:PlayoffBracket ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MediaRightsDeal .

ind:primaryPlayoffChampionFranchiseId rdf:type rdf:Property ;
    rdfs:label 'Primary Playoff Champion Franchise Id' ;
    rdfs:comment 'Reference to the franchise that won the championship in this playoff bracket. Populated only upon bracket completion. Used for historical records, trophy management, and league governance reporting.' ;
    rdfs:domain ind:PlayoffBracket ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Franchise .

ind:bracketEndDate rdf:type rdf:Property ;
    rdfs:label 'Bracket End Date' ;
    rdfs:comment 'Calendar date on which the final championship game is scheduled or was completed. Used for season close-out, financial reporting, and broadcast rights expiry.' ;
    rdfs:domain ind:PlayoffBracket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:bracketNotes rdf:type rdf:Property ;
    rdfs:label 'Bracket Notes' ;
    rdfs:comment 'Free-text field for league administrators to record special circumstances, rule exceptions, force-majeure events, or governance decisions affecting this playoff bracket (e.g., COVID-19 bubble format, relocated games).' ;
    rdfs:domain ind:PlayoffBracket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bracketRegion rdf:type rdf:Property ;
    rdfs:label 'Bracket Region' ;
    rdfs:comment 'Geographic or organizational region label for the bracket (e.g., \'AFC\', \'NFC\', \'Eastern Conference\', \'Western Conference\', \'Americas\', \'Europe\'). Used for multi-region league structures and broadcast rights segmentation.' ;
    rdfs:domain ind:PlayoffBracket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bracketStartDate rdf:type rdf:Property ;
    rdfs:label 'Bracket Start Date' ;
    rdfs:comment 'Calendar date on which the first playoff game in this bracket is scheduled to be played. Used for scheduling, ticketing, and broadcast rights activation.' ;
    rdfs:domain ind:PlayoffBracket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:byeRoundsCount rdf:type rdf:Property ;
    rdfs:label 'Bye Rounds Count' ;
    rdfs:comment 'Number of first-round byes awarded to top-seeded teams. A value of 0 indicates no byes are granted. Bye rules are defined in the league\'s CBA and playoff format documentation.' ;
    rdfs:domain ind:PlayoffBracket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:championshipGameName rdf:type rdf:Property ;
    rdfs:label 'Championship Game Name' ;
    rdfs:comment 'Official branded name of the final championship game or series in this bracket (e.g., \'Super Bowl\', \'NBA Finals\', \'Stanley Cup Finals\', \'World Series\'). Used in broadcast, sponsorship, and fan engagement contexts.' ;
    rdfs:domain ind:PlayoffBracket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conferenceDivisionScope rdf:type rdf:Property ;
    rdfs:label 'Conference Division Scope' ;
    rdfs:comment 'Organizational scope of the bracket indicating whether it covers the full league, a single conference, a division, or a wild-card pool. Drives seeding and matchup logic.' ;
    rdfs:domain ind:PlayoffBracket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disciplinaryReviewBody rdf:type rdf:Property ;
    rdfs:label 'Disciplinary Review Body' ;
    rdfs:comment 'Name of the governing body or panel responsible for adjudicating disciplinary actions, appeals, and rule enforcement during this playoff bracket (e.g., \'NFL Commissioner\'s Office\', \'NBA Basketball Operations\', \'CAS\').' ;
    rdfs:domain ind:PlayoffBracket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:neutralSiteFinal rdf:type rdf:Property ;
    rdfs:label 'Neutral Site Final' ;
    rdfs:comment 'Indicates whether the championship game/series final is played at a pre-selected neutral venue rather than the higher seed\'s home venue. True for events like the Super Bowl, FIFA World Cup Final, and NBA All-Star Game.' ;
    rdfs:domain ind:PlayoffBracket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ppvApplicable rdf:type rdf:Property ;
    rdfs:label 'Ppv Applicable' ;
    rdfs:comment 'Indicates whether any games in this playoff bracket are distributed under a Pay-Per-View (PPV) model. Drives revenue recognition, fan access controls, and broadcast rights activation.' ;
    rdfs:domain ind:PlayoffBracket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reseedingRule rdf:type rdf:Property ;
    rdfs:label 'Reseeding Rule' ;
    rdfs:comment 'Defines whether teams are reseeded after each round based on remaining seeds or whether the bracket is fixed at the start. \'fixed_bracket\' locks matchups at bracket publication; \'reseed_each_round\' re-ranks remaining teams each round.' ;
    rdfs:domain ind:PlayoffBracket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salaryCapComplianceRequired rdf:type rdf:Property ;
    rdfs:label 'Salary Cap Compliance Required' ;
    rdfs:comment 'Indicates whether participating franchises must be in salary cap compliance at the time of bracket entry. True if the league enforces cap compliance as a condition of playoff eligibility, per CBA terms.' ;
    rdfs:domain ind:PlayoffBracket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:seriesGamesPerRound rdf:type rdf:Property ;
    rdfs:label 'Series Games Per Round' ;
    rdfs:comment 'Comma-separated list of maximum games per series for each round in order (e.g., \'7,7,7,7\' for NBA best-of-7 throughout, or \'1,1,1,1\' for NFL single-elimination). Null for single-elimination formats where each round is one game.' ;
    rdfs:domain ind:PlayoffBracket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ticketSalesOpenDate rdf:type rdf:Property ;
    rdfs:label 'Ticket Sales Open Date' ;
    rdfs:comment 'Date on which general public ticket sales for playoff games in this bracket open. Used by Ticketmaster/AXS and Archtics for inventory release and revenue management.' ;
    rdfs:domain ind:PlayoffBracket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:totalTeams rdf:type rdf:Property ;
    rdfs:label 'Total Teams' ;
    rdfs:comment 'Total number of franchises/teams that qualify and enter the playoff bracket. Determines bracket size and bye-round eligibility.' ;
    rdfs:domain ind:PlayoffBracket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:varTmoEnabled rdf:type rdf:Property ;
    rdfs:label 'Var Tmo Enabled' ;
    rdfs:comment 'Indicates whether Video Assistant Referee (VAR) or Television Match Official (TMO) technology is mandated for officiating decisions in all games within this playoff bracket. Relevant for FIFA, MLS, and rugby-governed competitions.' ;
    rdfs:domain ind:PlayoffBracket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:alt5GameWinningTeamFranchiseId rdf:type rdf:Property ;
    rdfs:label 'Alt5 Game Winning Team Franchise Id' ;
    rdfs:comment 'Reference to the franchise or team entity that won the game. Null for draws or no-contest results. Primary input for win-loss standings calculations.' ;
    rdfs:domain ind:GameResult ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Franchise .

ind:primaryGameFranchiseId rdf:type rdf:Property ;
    rdfs:label 'Primary Game Franchise Id' ;
    rdfs:comment 'Reference to the home franchise or team entity participating in this game. Used for standings calculations and franchise performance reporting.' ;
    rdfs:domain ind:GameResult ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Franchise .

ind:quaternaryGameLosingTeamFranchiseId rdf:type rdf:Property ;
    rdfs:label 'Quaternary Game Losing Team Franchise Id' ;
    rdfs:comment 'Reference to the franchise or team entity that lost the game. Null for draws or no-contest results. Used in standings and franchise performance reporting.' ;
    rdfs:domain ind:GameResult ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Franchise .

ind:quinaryGameProtestFilingTeamFranchiseId rdf:type rdf:Property ;
    rdfs:label 'Quinary Game Protest Filing Team Franchise Id' ;
    rdfs:comment 'Reference to the franchise or team entity that filed the formal protest against this result. Null if no protest has been filed. Used in disciplinary case management.' ;
    rdfs:domain ind:GameResult ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Franchise .

ind:tertiaryGameFranchiseId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Game Franchise Id' ;
    rdfs:comment 'Reference to the home franchise or team entity participating in this game. Used for standings calculations and franchise performance reporting.' ;
    rdfs:domain ind:GameResult ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Franchise .

ind:tertiaryGameWinningTeamFranchiseId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Game Winning Team Franchise Id' ;
    rdfs:comment 'Reference to the franchise or team entity that won the game. Null for draws or no-contest results. Primary input for win-loss standings calculations.' ;
    rdfs:domain ind:GameResult ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Franchise .

ind:tertiaryQuinaryGameProtestFilingTeamFranchiseId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Quinary Game Protest Filing Team Franchise Id' ;
    rdfs:comment 'Reference to the franchise or team entity that filed the formal protest against this result. Null if no protest has been filed. Used in disciplinary case management.' ;
    rdfs:domain ind:GameResult ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Franchise .

ind:awayTeamScore rdf:type rdf:Property ;
    rdfs:label 'Away Team Score' ;
    rdfs:comment 'Official final score for the away team at the conclusion of the game, including all regulation and overtime periods. The authoritative score used in standings calculations.' ;
    rdfs:domain ind:GameResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:certifiedBy rdf:type rdf:Property ;
    rdfs:label 'Certified By' ;
    rdfs:comment 'Name or identifier of the league official or commissioner\'s office representative who certified this game result as final and authoritative.' ;
    rdfs:domain ind:GameResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disciplinaryActionFlag rdf:type rdf:Property ;
    rdfs:label 'Disciplinary Action Flag' ;
    rdfs:comment 'Indicates whether any disciplinary action (red card, ejection, fine, suspension) was issued during or as a result of this game (True) or not (False). Triggers downstream disciplinary record creation.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:forfeitReason rdf:type rdf:Property ;
    rdfs:label 'Forfeit Reason' ;
    rdfs:comment 'Description of the reason a forfeit was declared, such as insufficient eligible players, failure to appear, or safety grounds. Null if result_type is not \'forfeit\'.' ;
    rdfs:domain ind:GameResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gameDate rdf:type rdf:Property ;
    rdfs:label 'Game Date' ;
    rdfs:comment 'Calendar date on which the game was played. Principal business event date used for standings calculations, scheduling, and broadcast rights reporting.' ;
    rdfs:domain ind:GameResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:gameEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Game End Timestamp' ;
    rdfs:comment 'Precise date and time (ISO 8601 with timezone offset) when the game officially concluded, including all overtime or shootout periods. Used for broadcast rights reconciliation and venue operations.' ;
    rdfs:domain ind:GameResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:gameStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Game Start Timestamp' ;
    rdfs:comment 'Precise date and time (ISO 8601 with timezone offset) when the game officially commenced. Used for broadcast scheduling, OTT streaming rights windows, and operational reporting.' ;
    rdfs:domain ind:GameResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:homeTeamScore rdf:type rdf:Property ;
    rdfs:label 'Home Team Score' ;
    rdfs:comment 'Official final score for the home team at the conclusion of the game, including all regulation and overtime periods. The authoritative score used in standings calculations.' ;
    rdfs:domain ind:GameResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isDraw rdf:type rdf:Property ;
    rdfs:label 'Is Draw' ;
    rdfs:comment 'Indicates whether the game ended in a draw or tie (True) or produced a winner (False). Applicable in sports that allow draws such as MLS, FIFA, and some NHL regular season formats.' ;
    rdfs:domain ind:GameResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:officialAttendance rdf:type rdf:Property ;
    rdfs:label 'Official Attendance' ;
    rdfs:comment 'Officially certified number of spectators in attendance at the venue as reported to the league office. Used for franchise reporting, venue capacity compliance, and fan engagement analytics.' ;
    rdfs:domain ind:GameResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:overtimePeriodsPlayed rdf:type rdf:Property ;
    rdfs:label 'Overtime Periods Played' ;
    rdfs:comment 'Number of overtime or extra-time periods played beyond regulation. Zero if the game was decided in regulation. Used for game duration analytics and broadcast scheduling.' ;
    rdfs:domain ind:GameResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:protestFlag rdf:type rdf:Property ;
    rdfs:label 'Protest Flag' ;
    rdfs:comment 'Indicates whether a formal protest has been filed against this game result by either participating franchise (True) or not (False). Triggers league disciplinary and review workflows.' ;
    rdfs:domain ind:GameResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:protestReason rdf:type rdf:Property ;
    rdfs:label 'Protest Reason' ;
    rdfs:comment 'Brief description of the grounds on which the formal protest was filed (e.g., officiating error, ineligible player, rule violation). Null if no protest filed.' ;
    rdfs:domain ind:GameResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resultReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Result Reference Number' ;
    rdfs:comment 'Externally-known official result reference number assigned by the league office. Used for regulatory filings, media distribution, and official record-keeping across NFL, NBA, MLB, NHL, MLS, and FIFA.' ;
    rdfs:domain ind:GameResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resultType rdf:type rdf:Property ;
    rdfs:label 'Result Type' ;
    rdfs:comment 'Classification of how the game result was determined. \'regulation\' indicates decided within standard playing time. \'overtime\' indicates decided in extra time/OT periods. \'shootout\' indicates decided by penalty shootout or shootout format (NHL/MLS/FIFA). \'forfeit\' indicates awarded due to a team\'s failure to compete. \'no_contest\' indicates the game was declared void without a winner.' ;
    rdfs:domain ind:GameResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tmoInterventionFlag rdf:type rdf:Property ;
    rdfs:label 'Tmo Intervention Flag' ;
    rdfs:comment 'Indicates whether a Television Match Official (TMO) review was invoked during the game (True) or not (False). Applicable to rugby and other sports using TMO protocols. Supports officiating quality review.' ;
    rdfs:domain ind:GameResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:varInterventionFlag rdf:type rdf:Property ;
    rdfs:label 'Var Intervention Flag' ;
    rdfs:comment 'Indicates whether a Video Assistant Referee (VAR) intervention occurred during the game (True) or not (False). Applicable to sports using VAR technology such as FIFA, MLS, and NFL replay review. Supports officiating quality review and competitive integrity reporting.' ;
    rdfs:domain ind:GameResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:venueCapacity rdf:type rdf:Property ;
    rdfs:label 'Venue Capacity' ;
    rdfs:comment 'Total certified seating and standing capacity of the venue at the time of the game. Used to calculate attendance utilization rate and for regulatory compliance reporting.' ;
    rdfs:domain ind:GameResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:backgroundCheckDate rdf:type rdf:Property ;
    rdfs:label 'Background Check Date' ;
    rdfs:comment 'Date on which the most recent background check and integrity screening was completed for this official. Used to ensure compliance with league-mandated periodic screening intervals.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:badgeNumber rdf:type rdf:Property ;
    rdfs:label 'Badge Number' ;
    rdfs:comment 'Externally-known unique badge or credential number assigned by the officiating body to identify the official on the field and in league records. Serves as the business-facing identifier across game sheets, broadcast graphics, and disciplinary filings.' ;
    rdfs:domain ind:Official ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationTier rdf:type rdf:Property ;
    rdfs:label 'Certification Tier' ;
    rdfs:comment 'Officiating certification level awarded by the officiating body, reflecting demonstrated competency, experience, and performance evaluations. Determines eligibility for playoff, championship, and international assignments.' ;
    rdfs:domain ind:Official ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractEndDate rdf:type rdf:Property ;
    rdfs:label 'Contract End Date' ;
    rdfs:comment 'Date on which the official\'s current contract or engagement agreement expires or is scheduled to terminate. Nullable for open-ended arrangements. Used for renewal planning and assignment eligibility cutoffs.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contractStartDate rdf:type rdf:Property ;
    rdfs:label 'Contract Start Date' ;
    rdfs:comment 'Date on which the official\'s current contract or engagement agreement with the officiating body becomes effective. Used for CBA compliance tracking, payroll activation, and assignment eligibility determination.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:disciplinaryFlag rdf:type rdf:Property ;
    rdfs:label 'Disciplinary Flag' ;
    rdfs:comment 'Indicates whether the official currently has an open disciplinary matter, investigation, or formal review initiated by the officiating bureau or league governance body. When True, assignment eligibility may be restricted pending resolution.' ;
    rdfs:domain ind:Official ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:emailAddress rdf:type rdf:Property ;
    rdfs:label 'Email Address' ;
    rdfs:comment 'Primary professional email address for the official, used for assignment notifications, crew communications, and officiating bureau correspondence.' ;
    rdfs:domain ind:Official ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:firstName rdf:type rdf:Property ;
    rdfs:label 'First Name' ;
    rdfs:comment 'Given (first) name of the official, used for broadcast graphics, crew communications, and personalized correspondence.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fullName rdf:type rdf:Property ;
    rdfs:label 'Full Name' ;
    rdfs:comment 'Full legal name of the official as registered with the officiating body and used in official game documentation, broadcast overlays, and disciplinary records.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gamesOfficiatedCareer rdf:type rdf:Property ;
    rdfs:label 'Games Officiated Career' ;
    rdfs:comment 'Cumulative total number of professional games officiated across the official\'s entire career. Used for milestone recognition, Hall of Fame eligibility, and historical analytics.' ;
    rdfs:domain ind:Official ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:gamesOfficiatedSeason rdf:type rdf:Property ;
    rdfs:label 'Games Officiated Season' ;
    rdfs:comment 'Count of games officiated by this official in the current season. Used for workload management, assignment balancing, and CBA-mandated minimum/maximum game thresholds.' ;
    rdfs:domain ind:Official ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:homeCountryCode rdf:type rdf:Property ;
    rdfs:label 'Home Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code representing the official\'s country of residence or primary domicile. Used for international assignment eligibility, tax withholding jurisdiction, and GDPR/CCPA data residency compliance.' ;
    rdfs:domain ind:Official ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:integrityClearanceStatus rdf:type rdf:Property ;
    rdfs:label 'Integrity Clearance Status' ;
    rdfs:comment 'Current competitive integrity clearance status issued by the league\'s integrity and compliance unit. Reflects background check outcomes, betting prohibition compliance, and conflict-of-interest reviews. Critical for assignment eligibility and regulatory reporting.' ;
    rdfs:domain ind:Official ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:internationalEligible rdf:type rdf:Property ;
    rdfs:label 'International Eligible' ;
    rdfs:comment 'Indicates whether the official is cleared for international competition assignments (e.g., FIFA World Cup, Olympic Games, international friendlies). Requires FIFA/IOC certification and compliance with neutrality rules.' ;
    rdfs:domain ind:Official ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:languageCodes rdf:type rdf:Property ;
    rdfs:label 'Language Codes' ;
    rdfs:comment 'Comma-separated ISO 639-1 language codes representing languages spoken by the official. Relevant for international assignment eligibility, player communication in multilingual competitions, and VAR communication protocols.' ;
    rdfs:domain ind:Official ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastName rdf:type rdf:Property ;
    rdfs:label 'Last Name' ;
    rdfs:comment 'Family (last) name of the official, used as the primary sort key in officiating rosters, game sheets, and league reports.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:officialStatus rdf:type rdf:Property ;
    rdfs:label 'Official Status' ;
    rdfs:comment 'Current lifecycle status of the official within the officiating bureau. Drives eligibility for game assignments, payroll processing, and compliance reporting. \'suspended\' indicates a disciplinary or investigative hold; \'probation\' indicates conditional active status under performance review.' ;
    rdfs:domain ind:Official ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:performanceRatingSeason rdf:type rdf:Property ;
    rdfs:label 'Performance Rating Season' ;
    rdfs:comment 'The league season identifier (e.g., \'2024-25\') for which the current performance rating applies. Ensures ratings are interpreted in the correct seasonal context for year-over-year trend analysis.' ;
    rdfs:domain ind:Official ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phoneNumber rdf:type rdf:Property ;
    rdfs:label 'Phone Number' ;
    rdfs:comment 'Primary contact phone number for the official, used for urgent assignment changes, crew coordination, and emergency contact by the officiating bureau.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:playoffEligible rdf:type rdf:Property ;
    rdfs:label 'Playoff Eligible' ;
    rdfs:comment 'Indicates whether the official is currently eligible for postseason, playoff, or championship game assignments based on performance ratings, certification tier, and disciplinary standing. Managed by the officiating bureau\'s assignment committee.' ;
    rdfs:domain ind:Official ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:professionalDebutDate rdf:type rdf:Property ;
    rdfs:label 'Professional Debut Date' ;
    rdfs:comment 'Date on which the official first officiated a professional-level game under the current or a predecessor officiating body. Establishes the official\'s career start point for seniority, pension, and historical record purposes.' ;
    rdfs:domain ind:Official ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:roleType rdf:type rdf:Property ;
    rdfs:label 'Role Type' ;
    rdfs:comment 'Categorical classification of the officiating role performed by this individual. Determines crew position, authority scope, and applicable rule sets. [ENUM-REF-CANDIDATE: referee|umpire|linesman|line_judge|var_operator|tmo|fourth_official|video_review_official — promote to reference product]' ;
    rdfs:domain ind:Official ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tmoCertified rdf:type rdf:Property ;
    rdfs:label 'Tmo Certified' ;
    rdfs:comment 'Indicates whether the official holds a current TMO (Television Match Official) certification, qualifying them for video review assignments in rugby and other applicable sports.' ;
    rdfs:domain ind:Official ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:uniformNumber rdf:type rdf:Property ;
    rdfs:label 'Uniform Number' ;
    rdfs:comment 'Numeric identifier displayed on the official\'s uniform during games, used for broadcast identification, fan-facing graphics, and post-game incident reporting (e.g., \'Official #54 issued the penalty\').' ;
    rdfs:domain ind:Official ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:varCertified rdf:type rdf:Property ;
    rdfs:label 'Var Certified' ;
    rdfs:comment 'Indicates whether the official holds a current VAR (Video Assistant Referee) certification, qualifying them for VAR room assignments in applicable competitions. Governed by FIFA VAR certification protocols and equivalent league standards.' ;
    rdfs:domain ind:Official ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:yearsOfExperience rdf:type rdf:Property ;
    rdfs:label 'Years Of Experience' ;
    rdfs:comment 'Total number of years the official has been actively officiating at any professional or sanctioned level. Used for certification tier assessments, playoff eligibility criteria, and performance benchmarking.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actionReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Action Reference Number' ;
    rdfs:comment 'Externally-known, human-readable reference number assigned by the league office to uniquely identify this disciplinary action (e.g., NFL-DISC-2024-00412). Used in official correspondence, press releases, and CBA compliance reporting.' ;
    rdfs:domain ind:DisciplinaryAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actionStatus rdf:type rdf:Property ;
    rdfs:label 'Action Status' ;
    rdfs:comment 'Current lifecycle state of the disciplinary action. Tracks the workflow from initial issuance through appeal resolution and final ruling. Drives CBA compliance dashboards and competitive integrity reporting. [ENUM-REF-CANDIDATE: pending|active|appealed|upheld|overturned|reduced|withdrawn — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:DisciplinaryAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appealDeadlineDate rdf:type rdf:Property ;
    rdfs:label 'Appeal Deadline Date' ;
    rdfs:comment 'The last calendar date by which the subject entity must file a formal appeal under the applicable CBA or league rules. Nullable when appeal_eligible is false.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:appealEligible rdf:type rdf:Property ;
    rdfs:label 'Appeal Eligible' ;
    rdfs:comment 'Indicates whether the subject entity is eligible to appeal the disciplinary ruling under the applicable CBA or league rules. Drives appeal workflow initiation in Salesforce CRM case management.' ;
    rdfs:domain ind:DisciplinaryAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:appealRulingDate rdf:type rdf:Property ;
    rdfs:label 'Appeal Ruling Date' ;
    rdfs:comment 'The calendar date on which the appeal body (league arbitrator, CAS, or independent panel) issued its final ruling on the appeal. Nullable until appeal is resolved.' ;
    rdfs:domain ind:DisciplinaryAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cbaArticleReference rdf:type rdf:Property ;
    rdfs:label 'Cba Article Reference' ;
    rdfs:comment 'Specific CBA (Collective Bargaining Agreement) article or section under which the disciplinary action was issued or the appeal is governed. Critical for labor relations compliance and arbitration proceedings.' ;
    rdfs:domain ind:League ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:draftPickLossRound rdf:type rdf:Property ;
    rdfs:label 'Draft Pick Loss Round' ;
    rdfs:comment 'The draft round of the pick forfeited as part of the disciplinary penalty. Nullable for non-draft-pick-loss penalty types. Supports draft governance and franchise asset tracking.' ;
    rdfs:domain ind:DisciplinaryAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:draftPickLossYear rdf:type rdf:Property ;
    rdfs:label 'Draft Pick Loss Year' ;
    rdfs:comment 'The draft year in which the forfeited pick applies. Nullable for non-draft-pick-loss penalty types. Used in conjunction with draft_pick_loss_round for franchise asset management.' ;
    rdfs:domain ind:DisciplinaryAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:finalRulingDescription rdf:type rdf:Property ;
    rdfs:label 'Final Ruling Description' ;
    rdfs:comment 'Narrative summary of the final ruling outcome after all appeal processes are exhausted. Documents any modifications to the original penalty (e.g., reduced from 4 games to 2 games). Used for legal records and CBA compliance audit.' ;
    rdfs:domain ind:DisciplinaryAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fineAmount rdf:type rdf:Property ;
    rdfs:label 'Fine Amount' ;
    rdfs:comment 'Gross monetary fine levied against the subject entity as part of the disciplinary action, expressed in the base currency. Nullable when the penalty type does not include a financial component.' ;
    rdfs:domain ind:DisciplinaryAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fineCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Fine Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the fine amount (e.g., USD, EUR, GBP). Required for multi-league international operations (FIFA, MLS international competitions).' ;
    rdfs:domain ind:DisciplinaryAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:finePaidAmount rdf:type rdf:Property ;
    rdfs:label 'Fine Paid Amount' ;
    rdfs:comment 'Actual monetary amount paid by the subject entity against the assessed fine. Supports accounts receivable tracking in SAP S/4HANA and outstanding balance reporting for league finance.' ;
    rdfs:domain ind:DisciplinaryAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:finePaymentDate rdf:type rdf:Property ;
    rdfs:label 'Fine Payment Date' ;
    rdfs:comment 'Date on which the fine was paid in full or the most recent partial payment was received. Used for financial reconciliation and delinquency tracking.' ;
    rdfs:domain ind:DisciplinaryAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:incidentDate rdf:type rdf:Property ;
    rdfs:label 'Incident Date' ;
    rdfs:comment 'The calendar date on which the disciplinary incident or infraction occurred. Distinct from the ruling date; used for timeline analysis and statute-of-limitations compliance.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:incidentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Incident Timestamp' ;
    rdfs:comment 'Precise date and time at which the disciplinary incident occurred, including timezone offset. Used for in-game incident correlation (e.g., ejection time, VAR/TMO review timestamp).' ;
    rdfs:domain ind:DisciplinaryAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:infractionCategory rdf:type rdf:Property ;
    rdfs:label 'Infraction Category' ;
    rdfs:comment 'Broader category grouping the nature of the infraction (e.g., on-field conduct, PED violation, gambling, domestic violence, financial misconduct, game integrity). Supports regulatory reporting to WADA, CAS, and league governing bodies. [ENUM-REF-CANDIDATE: on_field_conduct|ped_violation|gambling|domestic_violence|financial_misconduct|game_integrity|social_conduct|equipment_violation — promote to reference product]' ;
    rdfs:domain ind:DisciplinaryAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:infractionDescription rdf:type rdf:Property ;
    rdfs:label 'Infraction Description' ;
    rdfs:comment 'Detailed narrative description of the specific rule violation or conduct that triggered the disciplinary action, as documented by the league office. Supports legal review, CBA arbitration, and CAS proceedings.' ;
    rdfs:domain ind:DisciplinaryAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:infractionType rdf:type rdf:Property ;
    rdfs:label 'Infraction Type' ;
    rdfs:comment 'Primary classification of the disciplinary penalty imposed. Drives downstream CBA compliance tracking, salary cap impact assessment, and competitive integrity reporting. [ENUM-REF-CANDIDATE: suspension|fine|ejection|probation|draft_pick_loss|warning|roster_restriction|conditional_reinstatement — promote to reference product if additional types are needed]' ;
    rdfs:domain ind:DisciplinaryAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isGameIntegrityRelated rdf:type rdf:Property ;
    rdfs:label 'Is Game Integrity Related' ;
    rdfs:comment 'Indicates whether the disciplinary action involves a game integrity violation (e.g., match-fixing, gambling, sign-stealing). Triggers enhanced regulatory reporting to league governing bodies and law enforcement liaisons.' ;
    rdfs:domain ind:DisciplinaryAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPedRelated rdf:type rdf:Property ;
    rdfs:label 'Is Ped Related' ;
    rdfs:comment 'Indicates whether the disciplinary action is related to a Performance Enhancing Drug (PED) violation. Triggers mandatory WADA reporting obligations and anti-doping compliance workflows.' ;
    rdfs:domain ind:DisciplinaryAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPubliclyDisclosed rdf:type rdf:Property ;
    rdfs:label 'Is Publicly Disclosed' ;
    rdfs:comment 'Indicates whether the disciplinary action has been publicly disclosed by the league. Some actions (e.g., private reprimands) are not publicly announced. Governs data access and GDPR/CCPA disclosure controls.' ;
    rdfs:domain ind:DisciplinaryAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priorOffenseCount rdf:type rdf:Property ;
    rdfs:label 'Prior Offense Count' ;
    rdfs:comment 'Number of prior disciplinary actions of the same infraction category recorded against the subject entity. Supports escalating penalty calculation per CBA and league disciplinary schedules.' ;
    rdfs:domain ind:DisciplinaryAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:publicAnnouncementDate rdf:type rdf:Property ;
    rdfs:label 'Public Announcement Date' ;
    rdfs:comment 'The date on which the league publicly announced the disciplinary action. Used for media relations tracking, fan communications, and compliance with league transparency requirements.' ;
    rdfs:domain ind:DisciplinaryAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:repeatOffender rdf:type rdf:Property ;
    rdfs:label 'Repeat Offender' ;
    rdfs:comment 'Indicates whether the subject entity has a prior disciplinary history for the same or similar infraction category. Used to apply escalating penalty schedules per CBA provisions and league rules.' ;
    rdfs:domain ind:DisciplinaryAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ruleCodeViolated rdf:type rdf:Property ;
    rdfs:label 'Rule Code Violated' ;
    rdfs:comment 'The specific league rulebook article, section, or CBA provision code that was violated (e.g., NFL Rule 12, Section 2, Article 8; NBA CBA Article XXXV). Enables precise regulatory and compliance cross-referencing.' ;
    rdfs:domain ind:DisciplinaryAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rulingDate rdf:type rdf:Property ;
    rdfs:label 'Ruling Date' ;
    rdfs:comment 'The calendar date on which the league office issued the formal disciplinary ruling. Used for CBA compliance timelines, appeal window calculation, and regulatory reporting.' ;
    rdfs:domain ind:DisciplinaryAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:subjectEntityType rdf:type rdf:Property ;
    rdfs:label 'Subject Entity Type' ;
    rdfs:comment 'Classifies the type of entity against whom the disciplinary action was issued. Determines which reference table the subject_entity_id resolves to (player, coach, franchise, official, or staff member).' ;
    rdfs:domain ind:DisciplinaryAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:suspensionEndDate rdf:type rdf:Property ;
    rdfs:label 'Suspension End Date' ;
    rdfs:comment 'Calendar date on which the suspension period ends and the subject entity becomes eligible to return. Nullable for indefinite suspensions pending reinstatement review.' ;
    rdfs:domain ind:DisciplinaryAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:suspensionGames rdf:type rdf:Property ;
    rdfs:label 'Suspension Games' ;
    rdfs:comment 'Number of games for which the subject entity is suspended as part of the disciplinary action. Nullable for non-suspension penalty types. Used for roster planning, salary cap impact, and CBA compliance.' ;
    rdfs:domain ind:DisciplinaryAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:suspensionStartDate rdf:type rdf:Property ;
    rdfs:label 'Suspension Start Date' ;
    rdfs:comment 'Calendar date on which the suspension period begins. Used for roster eligibility management and salary cap entry adjustments.' ;
    rdfs:domain ind:DisciplinaryAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:suspensionWithPay rdf:type rdf:Property ;
    rdfs:label 'Suspension With Pay' ;
    rdfs:comment 'Indicates whether the subject entity continues to receive salary compensation during the suspension period. Directly impacts salary cap accounting and CBA compliance reporting.' ;
    rdfs:domain ind:DisciplinaryAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:varTmoReviewed rdf:type rdf:Property ;
    rdfs:label 'Var Tmo Reviewed' ;
    rdfs:comment 'Indicates whether the incident that triggered this disciplinary action was reviewed by VAR (Video Assistant Referee) or TMO (Television Match Official) technology during the game. Supports officiating quality analytics.' ;
    rdfs:domain ind:DisciplinaryAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:activePayrollAmount rdf:type rdf:Property ;
    rdfs:label 'Active Payroll Amount' ;
    rdfs:comment 'The total current payroll charged against the franchise\'s salary cap for all active roster contracts in the cap year. Updated on each roster transaction or contract signing. Expressed in USD.' ;
    rdfs:domain ind:SalaryCap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:apronAmount rdf:type rdf:Property ;
    rdfs:label 'Apron Amount' ;
    rdfs:comment 'The second apron threshold above the luxury tax line, above which franchises face additional CBA restrictions on roster moves (e.g., no trade aggregation, no MLE use). Expressed in USD. Introduced in NBA CBA 2023.' ;
    rdfs:domain ind:SalaryCap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:biAnnualExceptionAmount rdf:type rdf:Property ;
    rdfs:label 'Bi Annual Exception Amount' ;
    rdfs:comment 'The dollar value of the bi-annual exception available to franchises for the cap year, usable once every two years to sign players above the soft cap. Expressed in USD.' ;
    rdfs:domain ind:SalaryCap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capCalculationMethodology rdf:type rdf:Property ;
    rdfs:label 'Cap Calculation Methodology' ;
    rdfs:comment 'Narrative description of the formula or methodology used to derive the hard cap and soft cap amounts from total league revenue, as specified in the CBA. For example, \'BRI (Basketball Related Income) split at 51% player share\' or \'All Revenue multiplied by player cost percentage\'.' ;
    rdfs:domain ind:SalaryCap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Cap Effective Date' ;
    rdfs:comment 'The date on which the salary cap rules for this cap year become legally binding and enforceable for all franchises, as defined in the CBA.' ;
    rdfs:domain ind:SalaryCap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:capExceptionNotes rdf:type rdf:Property ;
    rdfs:label 'Cap Exception Notes' ;
    rdfs:comment 'Free-text notes documenting any special cap exceptions, waivers, or league-approved adjustments applied to this franchise\'s cap calculation for the cap year (e.g., COVID-19 cap smoothing, hardship exceptions).' ;
    rdfs:domain ind:SalaryCap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Cap Expiry Date' ;
    rdfs:comment 'The date on which the salary cap period ends and the cap year closes. After this date, final compliance determinations are made and luxury tax bills are issued.' ;
    rdfs:domain ind:SalaryCap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:capFloorAmount rdf:type rdf:Property ;
    rdfs:label 'Cap Floor Amount' ;
    rdfs:comment 'The minimum total payroll a franchise must commit to active player contracts for the cap year. Franchises below the floor may be subject to CBA penalties or required to distribute the shortfall to players. Expressed in USD.' ;
    rdfs:domain ind:SalaryCap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capHoldsAmount rdf:type rdf:Property ;
    rdfs:label 'Cap Holds Amount' ;
    rdfs:comment 'Total cap holds charged against the franchise for unsigned draft picks, restricted free agents, and qualifying offers outstanding. Cap holds reserve space until contracts are signed or rights are renounced. Expressed in USD.' ;
    rdfs:domain ind:SalaryCap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capSpaceRemaining rdf:type rdf:Property ;
    rdfs:label 'Cap Space Remaining' ;
    rdfs:comment 'The amount of salary cap space available to the franchise for additional player signings, calculated as the applicable cap ceiling minus total cap charges. Expressed in USD. Updated in real time on roster transactions.' ;
    rdfs:domain ind:SalaryCap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capType rdf:type rdf:Property ;
    rdfs:label 'Cap Type' ;
    rdfs:comment 'Classification of the cap structure applicable to this league and season. Hard cap enforces an absolute ceiling; soft cap allows exceptions; luxury tax imposes financial penalties above threshold; no_cap indicates an uncapped league.' ;
    rdfs:domain ind:SalaryCap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cbaVersion rdf:type rdf:Property ;
    rdfs:label 'Cba Version' ;
    rdfs:comment 'The version or effective date identifier of the Collective Bargaining Agreement governing the salary cap rules for this cap year (e.g., \'NFL CBA 2020-2030\', \'NBA CBA 2023\'). Ensures traceability to the correct CBA provisions.' ;
    rdfs:domain ind:League ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:draftPickPenaltyFlag rdf:type rdf:Property ;
    rdfs:label 'Draft Pick Penalty Flag' ;
    rdfs:comment 'Indicates whether the franchise has been assessed a draft pick forfeiture as a penalty for a salary cap violation in this cap year.' ;
    rdfs:domain ind:SalaryCap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:escrowPercentage rdf:type rdf:Property ;
    rdfs:label 'Escrow Percentage' ;
    rdfs:comment 'The percentage of player salaries withheld in escrow during the season to ensure the players\' share of revenue does not exceed the CBA-defined threshold. Expressed as a decimal (e.g., 0.1000 = 10%). Reconciled at season end.' ;
    rdfs:domain ind:SalaryCap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:firstApronAmount rdf:type rdf:Property ;
    rdfs:label 'First Apron Amount' ;
    rdfs:comment 'The first apron threshold above the luxury tax line, above which franchises face initial CBA restrictions on roster moves (e.g., reduced MLE, no sign-and-trade as acquiring team). Expressed in USD.' ;
    rdfs:domain ind:SalaryCap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hardCapAmount rdf:type rdf:Property ;
    rdfs:label 'Hard Cap Amount' ;
    rdfs:comment 'The absolute maximum total player payroll permitted under the league\'s hard cap rule for the cap year. Franchises may not exceed this amount under any circumstance. Expressed in USD.' ;
    rdfs:domain ind:SalaryCap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:injuredReserveCredit rdf:type rdf:Property ;
    rdfs:label 'Injured Reserve Credit' ;
    rdfs:comment 'Cap relief credit granted to a franchise when a player is placed on the injured reserve list, allowing a replacement signing above the normal cap threshold. Expressed in USD. Governed by CBA injured reserve rules.' ;
    rdfs:domain ind:SalaryCap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastTransactionDate rdf:type rdf:Property ;
    rdfs:label 'Last Transaction Date' ;
    rdfs:comment 'The date of the most recent roster transaction (signing, release, trade, IR placement) that triggered an update to this franchise\'s cap compliance snapshot.' ;
    rdfs:domain ind:SalaryCap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:luxuryTaxLiability rdf:type rdf:Property ;
    rdfs:label 'Luxury Tax Liability' ;
    rdfs:comment 'The calculated luxury tax dollar amount owed by the franchise based on the amount by which total payroll exceeds the luxury tax threshold, multiplied by the applicable CBA tax rate. Expressed in USD. Zero if payroll is below threshold.' ;
    rdfs:domain ind:SalaryCap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:luxuryTaxRepeaterFlag rdf:type rdf:Property ;
    rdfs:label 'Luxury Tax Repeater Flag' ;
    rdfs:comment 'Indicates whether the franchise qualifies as a luxury tax repeater under CBA rules, triggering higher incremental tax rates for franchises that have been taxpayers in multiple seasons within a defined lookback window.' ;
    rdfs:domain ind:SalaryCap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:midLevelExceptionAmount rdf:type rdf:Property ;
    rdfs:label 'Mid Level Exception Amount' ;
    rdfs:comment 'The dollar value of the mid-level exception available to franchises for the cap year, allowing teams over the soft cap to sign players up to this amount. Expressed in USD. Applicable in NBA-style soft cap leagues.' ;
    rdfs:domain ind:SalaryCap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:penaltyAmount rdf:type rdf:Property ;
    rdfs:label 'Penalty Amount' ;
    rdfs:comment 'The financial penalty assessed against the franchise for a salary cap violation, as determined by the league office. Expressed in USD. Zero if no violation exists.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:playerSharePercentage rdf:type rdf:Property ;
    rdfs:label 'Player Share Percentage' ;
    rdfs:comment 'The CBA-defined percentage of total league revenue allocated to player salaries and benefits for the cap year. Expressed as a decimal (e.g., 0.5100 = 51%). Drives cap calculation methodology.' ;
    rdfs:domain ind:SalaryCap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:practiceSquadCharges rdf:type rdf:Property ;
    rdfs:label 'Practice Squad Charges' ;
    rdfs:comment 'Total salary cap charges attributable to players on the practice squad roster for the cap year. Expressed in USD. Governed by CBA practice squad rules.' ;
    rdfs:domain ind:SalaryCap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recordType rdf:type rdf:Property ;
    rdfs:label 'Record Type' ;
    rdfs:comment 'Discriminator indicating whether this record is a league-wide cap rule definition or a per-franchise compliance snapshot. Drives downstream processing logic.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:snapshotTimestamp rdf:type rdf:Property ;
    rdfs:label 'Snapshot Timestamp' ;
    rdfs:comment 'The exact date and time at which the franchise-level compliance snapshot was captured. Enables point-in-time cap analysis and audit trail for roster transactions.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:softCapAmount rdf:type rdf:Property ;
    rdfs:label 'Soft Cap Amount' ;
    rdfs:comment 'The baseline salary cap ceiling above which teams may still sign players using defined CBA exceptions (e.g., mid-level exception, Bird rights). Expressed in USD. Applicable primarily in NBA-style cap structures.' ;
    rdfs:domain ind:SalaryCap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalLeagueRevenueBasis rdf:type rdf:Property ;
    rdfs:label 'Total League Revenue Basis' ;
    rdfs:comment 'The total league-wide revenue figure used as the basis for calculating the salary cap for the cap year, as defined in the CBA. Typically derived from broadcast rights, gate receipts, and other shared revenue streams. Expressed in USD.' ;
    rdfs:domain ind:SalaryCap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:violationDescription rdf:type rdf:Property ;
    rdfs:label 'Violation Description' ;
    rdfs:comment 'Narrative description of the nature of any salary cap violation identified for this franchise in the cap year. Populated only when compliance_status is \'violation\' or \'under_review\'.' ;
    rdfs:domain ind:SalaryCap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compensatoryPicksAuthorized rdf:type rdf:Property ;
    rdfs:label 'Compensatory Picks Authorized' ;
    rdfs:comment 'Indicates whether compensatory picks have been authorized for this draft event by the league office, awarded to franchises that lost qualifying free agents in the prior season.' ;
    rdfs:domain ind:Draft ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:draftCode rdf:type rdf:Property ;
    rdfs:label 'Draft Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying this draft event across league systems and partner integrations (e.g., \'NFL-DRAFT-2025\', \'NBA-DRAFT-2025-SUPP\').' ;
    rdfs:domain ind:Draft ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:draftName rdf:type rdf:Property ;
    rdfs:label 'Draft Name' ;
    rdfs:comment 'Official human-readable name of the draft event as published by the governing league (e.g., \'2025 NFL Draft\', \'2025 NBA Draft\').' ;
    rdfs:domain ind:Draft ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:draftStatus rdf:type rdf:Property ;
    rdfs:label 'Draft Status' ;
    rdfs:comment 'Current lifecycle state of the draft event, governing downstream processing of pick selections, trade executions, and athlete eligibility confirmations.' ;
    rdfs:domain ind:Draft ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eligibilityClass rdf:type rdf:Property ;
    rdfs:label 'Eligibility Class' ;
    rdfs:comment 'Classification of the athlete pool eligible for this draft, determining applicable eligibility rules, age requirements, and CBA provisions (e.g., college seniors, international prospects, supplemental class). [ENUM-REF-CANDIDATE: college|international|supplemental|developmental|undrafted_free_agent — promote to reference product]' ;
    rdfs:domain ind:Draft ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedAttendance rdf:type rdf:Property ;
    rdfs:label 'Expected Attendance' ;
    rdfs:comment 'Projected number of fans expected to attend the live draft event in person, used for venue capacity planning, security staffing, and sponsorship activation sizing.' ;
    rdfs:domain ind:Draft ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fanAttendanceAllowed rdf:type rdf:Property ;
    rdfs:label 'Fan Attendance Allowed' ;
    rdfs:comment 'Indicates whether public fan attendance is permitted at the live draft venue, affecting ticketing operations, venue capacity planning, and fan engagement activations.' ;
    rdfs:domain ind:Draft ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:forfeitedPicks rdf:type rdf:Property ;
    rdfs:label 'Forfeited Picks' ;
    rdfs:comment 'Number of pick slots forfeited during this draft event due to disciplinary actions, salary cap violations, or clock expiration, as ruled by the league office.' ;
    rdfs:domain ind:Draft ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:format rdf:type rdf:Property ;
    rdfs:label 'Format' ;
    rdfs:comment 'Operational format of the draft event indicating whether selections are made in-person at a live venue, fully virtual via remote broadcast, or a hybrid combination of both.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hostCity rdf:type rdf:Property ;
    rdfs:label 'Host City' ;
    rdfs:comment 'Name of the city hosting the live draft event, used for event planning, fan engagement, sponsorship activation, and broadcast production logistics.' ;
    rdfs:domain ind:Draft ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:integrityReviewNotes rdf:type rdf:Property ;
    rdfs:label 'Integrity Review Notes' ;
    rdfs:comment 'Free-text notes documenting the nature and outcome of any competitive integrity review associated with this draft event, maintained by the league compliance office.' ;
    rdfs:domain ind:Draft ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:integrityReviewRequired rdf:type rdf:Property ;
    rdfs:label 'Integrity Review Required' ;
    rdfs:comment 'Indicates whether this draft event or any of its picks are subject to a competitive integrity review by the league office, triggered by suspected rule violations or tanking investigations.' ;
    rdfs:domain ind:Draft ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lotteryConducted rdf:type rdf:Property ;
    rdfs:label 'Lottery Conducted' ;
    rdfs:comment 'Indicates whether a draft lottery was conducted to determine the order of top picks for this draft event (True = lottery held; False = order determined by standings or other method).' ;
    rdfs:domain ind:Draft ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lotteryDate rdf:type rdf:Property ;
    rdfs:label 'Lottery Date' ;
    rdfs:comment 'Calendar date on which the draft lottery was conducted to determine pick order, applicable when lottery_conducted is True.' ;
    rdfs:domain ind:Draft ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:orderMethod rdf:type rdf:Property ;
    rdfs:label 'Order Method' ;
    rdfs:comment 'Method used to determine the order in which franchises make their selections (e.g., lottery for top picks, inverse regular-season standings, coin flip for tied records, or predetermined compensatory formula). [ENUM-REF-CANDIDATE: lottery|inverse_standings|coin_flip|predetermined|compensatory — promote to reference product]' ;
    rdfs:domain ind:Draft ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ottStreamingEnabled rdf:type rdf:Property ;
    rdfs:label 'Ott Streaming Enabled' ;
    rdfs:comment 'Indicates whether the draft event is available for live streaming via OTT/DTC digital platforms in addition to or instead of traditional broadcast, supporting digital fan engagement.' ;
    rdfs:domain ind:Draft ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pickClockSeconds rdf:type rdf:Property ;
    rdfs:label 'Pick Clock Seconds' ;
    rdfs:comment 'Allotted time in seconds each franchise has to submit a pick selection before the clock expires and the pick may be forfeited or auto-submitted, as defined by league rules.' ;
    rdfs:domain ind:Draft ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:picksCompleted rdf:type rdf:Property ;
    rdfs:label 'Picks Completed' ;
    rdfs:comment 'Running count of pick selections that have been exercised and confirmed during the draft event, used for real-time progress tracking and broadcast production.' ;
    rdfs:domain ind:Draft ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:salaryCapYear rdf:type rdf:Property ;
    rdfs:label 'Salary Cap Year' ;
    rdfs:comment 'The salary cap fiscal year applicable to rookie contracts signed by athletes selected in this draft, governing rookie wage scale calculations and cap hit projections.' ;
    rdfs:domain ind:Draft ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sport rdf:type rdf:Property ;
    rdfs:label 'Sport' ;
    rdfs:comment 'The professional sport discipline governed by this draft event, used to apply sport-specific eligibility rules, CBA provisions, and draft format configurations.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:startTimestamp rdf:type rdf:Property ;
    rdfs:label 'Start Timestamp' ;
    rdfs:comment 'Precise date and time at which the draft event officially begins (first pick clock starts), used for broadcast scheduling, OTT streaming activation, and real-time pick tracking.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:supplementalDraft rdf:type rdf:Property ;
    rdfs:label 'Supplemental Draft' ;
    rdfs:comment 'Indicates whether this draft event is a supplemental draft (True) rather than the primary annual draft (False), used for athletes who became eligible after the standard draft deadline.' ;
    rdfs:domain ind:Draft ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:totalPicks rdf:type rdf:Property ;
    rdfs:label 'Total Picks' ;
    rdfs:comment 'Total number of pick slots in this draft event, including standard picks, compensatory picks, and supplemental picks as authorized by the governing league.' ;
    rdfs:domain ind:Draft ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tradesExecuted rdf:type rdf:Property ;
    rdfs:label 'Trades Executed' ;
    rdfs:comment 'Total number of pick trade transactions executed during this draft event, used for trade analysis, draft asset management reporting, and competitive intelligence.' ;
    rdfs:domain ind:Draft ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:wadaComplianceConfirmed rdf:type rdf:Property ;
    rdfs:label 'Wada Compliance Confirmed' ;
    rdfs:comment 'Indicates whether all athletes in the eligible draft class have been confirmed compliant with WADA anti-doping regulations prior to the draft event commencing.' ;
    rdfs:domain ind:Draft ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastTradeTransactionId rdf:type rdf:Property ;
    rdfs:label 'Last Trade Transaction Id' ;
    rdfs:comment 'Reference to the most recent trade transaction record in which this pick was transferred. Enables full trade audit trail linkage.' ;
    rdfs:domain ind:DraftPick ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TradeTransaction .

ind:primaryDraftAthleteProfileId rdf:type rdf:Property ;
    rdfs:label 'Primary Draft Athlete Profile Id' ;
    rdfs:comment 'Reference to the athlete selected with this pick upon exercise. Null until the pick is exercised. Links to the athlete profile for post-draft roster and contract management.' ;
    rdfs:domain ind:DraftPick ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AthleteProfile .

ind:primaryDraftCurrentOwnerFranchiseId rdf:type rdf:Property ;
    rdfs:label 'Primary Draft Current Owner Franchise Id' ;
    rdfs:comment 'Reference to the franchise that currently holds the rights to exercise this draft pick. May differ from the original owning franchise if the pick has been traded.' ;
    rdfs:domain ind:DraftPick ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Franchise .

ind:conditionDescription rdf:type rdf:Property ;
    rdfs:label 'Condition Description' ;
    rdfs:comment 'Free-text description of the conditions governing a conditional pick (e.g., \'Converts to 1st round if franchise wins division; otherwise 2nd round\'). Populated only when is_conditional is true.' ;
    rdfs:domain ind:DraftPick ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:draftPositionTier rdf:type rdf:Property ;
    rdfs:label 'Draft Position Tier' ;
    rdfs:comment 'Categorical tier classification of this pick\'s position within the draft (e.g., \'lottery\' for NBA lottery picks, \'top_10\', \'first_round\', \'second_round\', \'later_round\'). Used for pick valuation segmentation and trade analysis.' ;
    rdfs:domain ind:DraftPick ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exerciseDate rdf:type rdf:Property ;
    rdfs:label 'Exercise Date' ;
    rdfs:comment 'The date on which this pick was exercised (i.e., used to select an athlete during the draft event). Null until the pick is exercised.' ;
    rdfs:domain ind:DraftPick ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:exerciseTimestamp rdf:type rdf:Property ;
    rdfs:label 'Exercise Timestamp' ;
    rdfs:comment 'The precise date and time at which this pick was exercised during the draft event, including timezone offset. Supports real-time draft broadcast and pick clock compliance tracking.' ;
    rdfs:domain ind:DraftPick ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:externalRef rdf:type rdf:Property ;
    rdfs:label 'External Ref' ;
    rdfs:comment 'The externally-known identifier for this pick as published by the league office or official transaction systems (e.g., league transaction ID, official pick number code). Supports system-of-record reconciliation.' ;
    rdfs:domain ind:DraftPick ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forfeitureReason rdf:type rdf:Property ;
    rdfs:label 'Forfeiture Reason' ;
    rdfs:comment 'Description of the reason this pick was forfeited, if applicable (e.g., salary cap violation, tampering penalty, CBA non-compliance). Populated only when pick_status is \'forfeited\'.' ;
    rdfs:domain ind:DraftPick ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forfeitureRulingDate rdf:type rdf:Property ;
    rdfs:label 'Forfeiture Ruling Date' ;
    rdfs:comment 'The date on which the league office issued the ruling to forfeit this pick. Populated only when pick_status is \'forfeited\'.' ;
    rdfs:domain ind:DraftPick ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isConditional rdf:type rdf:Property ;
    rdfs:label 'Is Conditional' ;
    rdfs:comment 'Indicates whether this pick is subject to conditions that may alter its round, year, or validity (e.g., \'becomes a 1st round pick if team makes playoffs\'). When true, condition_description provides the governing terms.' ;
    rdfs:domain ind:DraftPick ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isLotteryEligible rdf:type rdf:Property ;
    rdfs:label 'Is Lottery Eligible' ;
    rdfs:comment 'Indicates whether this pick is eligible to be determined by a lottery mechanism (e.g., NBA Draft Lottery). Relevant for protected pick valuation and conditional pick resolution.' ;
    rdfs:domain ind:DraftPick ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isTradeable rdf:type rdf:Property ;
    rdfs:label 'Is Tradeable' ;
    rdfs:comment 'Indicates whether this pick is currently eligible to be traded under league rules. Some picks (e.g., compensatory picks in certain leagues, picks under CBA restrictions) may be non-tradeable.' ;
    rdfs:domain ind:DraftPick ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastTradeDate rdf:type rdf:Property ;
    rdfs:label 'Last Trade Date' ;
    rdfs:comment 'The date on which this pick was most recently traded to its current owning franchise. Null if the pick has never been traded.' ;
    rdfs:domain ind:DraftPick ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pickAnnouncementName rdf:type rdf:Property ;
    rdfs:label 'Pick Announcement Name' ;
    rdfs:comment 'The official name announced for this pick during the draft broadcast (e.g., \'The Dallas Cowboys select...\'). Used for broadcast production, content, and DAM (Digital Asset Management) workflows.' ;
    rdfs:domain ind:DraftPick ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pickClockSecondsRemaining rdf:type rdf:Property ;
    rdfs:label 'Pick Clock Seconds Remaining' ;
    rdfs:comment 'The number of seconds remaining on the pick clock when the pick was submitted. Used for draft broadcast analytics and compliance with league pick clock rules.' ;
    rdfs:domain ind:DraftPick ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pickNumber rdf:type rdf:Property ;
    rdfs:label 'Pick Number' ;
    rdfs:comment 'The sequential overall pick number within the entire draft event (e.g., pick #1 through #259 in the NFL Draft). Used for pick valuation models and historical analysis.' ;
    rdfs:domain ind:DraftPick ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pickSourceLeagueRule rdf:type rdf:Property ;
    rdfs:label 'Pick Source League Rule' ;
    rdfs:comment 'The specific league rule, CBA article, or governing provision under which this pick was created or awarded (e.g., \'CBA Article 5, Section 3 - Compensatory Pick Formula\', \'Expansion Draft Rule 12\'). Supports compliance and audit.' ;
    rdfs:domain ind:DraftPick ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pickStatus rdf:type rdf:Property ;
    rdfs:label 'Pick Status' ;
    rdfs:comment 'Current lifecycle status of the draft pick. \'available\' = held and ready to use; \'traded\' = transferred to another franchise; \'exercised\' = used to select an athlete; \'forfeited\' = surrendered as penalty; \'voided\' = invalidated by league ruling.' ;
    rdfs:domain ind:DraftPick ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pickValuationScore rdf:type rdf:Property ;
    rdfs:label 'Pick Valuation Score' ;
    rdfs:comment 'Quantitative valuation score assigned to this pick based on the league\'s or franchise\'s draft pick value chart (e.g., NFL Jimmy Johnson Chart, Chase Stuart Chart). Used for trade analysis and asset management. Not a calculated aggregate — represents the chart-assigned value for this pick position.' ;
    rdfs:domain ind:DraftPick ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pickWithinRound rdf:type rdf:Property ;
    rdfs:label 'Pick Within Round' ;
    rdfs:comment 'The sequential pick number within the specific round (e.g., 3rd pick in Round 2). Combined with round_number provides the full pick address (e.g., Round 2, Pick 3).' ;
    rdfs:domain ind:DraftPick ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:protectionLevel rdf:type rdf:Property ;
    rdfs:label 'Protection Level' ;
    rdfs:comment 'The top-N protection threshold for this pick (e.g., 3 = top-3 protected, meaning if the pick falls in the top 3 overall, it does not convey to the trading partner and rolls over). Null if unprotected.' ;
    rdfs:domain ind:DraftPick ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:protectionRolloverYearLimit rdf:type rdf:Property ;
    rdfs:label 'Protection Rollover Year Limit' ;
    rdfs:comment 'The maximum number of years a protected pick can roll over before it must convey regardless of protection status. Governs the expiry of pick protection in multi-year trade agreements.' ;
    rdfs:domain ind:DraftPick ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:salaryCapSlotValue rdf:type rdf:Property ;
    rdfs:label 'Salary Cap Slot Value' ;
    rdfs:comment 'The CBA-mandated salary cap slot value associated with this pick position, expressed in the league\'s designated currency. Governs the rookie contract value for the selected athlete. Critical for salary cap compliance reporting.' ;
    rdfs:domain ind:DraftPick ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tradeCount rdf:type rdf:Property ;
    rdfs:label 'Trade Count' ;
    rdfs:comment 'Total number of times this pick has been traded between franchises. Used for trade complexity analysis and pick valuation models.' ;
    rdfs:domain ind:DraftPick ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tradeHistory rdf:type rdf:Property ;
    rdfs:label 'Trade History' ;
    rdfs:comment 'Serialized summary of the full trade chain for this pick, recording each franchise that has held the pick in sequence (e.g., \'FranchiseA → FranchiseB → FranchiseC\'). Supports trade analysis and pick provenance auditing.' ;
    rdfs:domain ind:DraftPick ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryTradeAcquiringFranchiseId rdf:type rdf:Property ;
    rdfs:label 'Primary Trade Acquiring Franchise Id' ;
    rdfs:comment 'Reference to the franchise receiving the primary asset (player, draft pick, or cash consideration) in this transaction. In waiver claims, this is the claiming franchise.' ;
    rdfs:domain ind:TradeTransaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Franchise .

ind:primaryTradeAthleteAthleteProfileId rdf:type rdf:Property ;
    rdfs:label 'Primary Trade Athlete Athlete Profile Id' ;
    rdfs:comment 'Reference to the primary athlete (player) being transferred in this transaction. For multi-player trades, this represents the headline player; additional players are captured in associated transaction line records. Null for cash-only or draft-pick-only transactions.' ;
    rdfs:domain ind:TradeTransaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AthleteProfile .

ind:tertiaryTradeThirdFranchiseId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Trade Third Franchise Id' ;
    rdfs:comment 'Reference to the third franchise involved in a three-way trade transaction. Null for bilateral trades, waiver claims, and all other non-three-way transaction types.' ;
    rdfs:domain ind:TradeTransaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Franchise .

ind:cashConsiderationAmount rdf:type rdf:Property ;
    rdfs:label 'Cash Consideration Amount' ;
    rdfs:comment 'The gross monetary value of cash included in this transaction (e.g., player-for-cash trade, cash balancing payment). Subject to league-mandated cash consideration limits per CBA. Zero if no cash is exchanged.' ;
    rdfs:domain ind:TradeTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cashConsiderationCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Cash Consideration Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the cash consideration amount (e.g., USD, CAD, EUR). Required when cash_consideration_amount is non-zero.' ;
    rdfs:domain ind:TradeTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clearingDate rdf:type rdf:Property ;
    rdfs:label 'Clearing Date' ;
    rdfs:comment 'For waiver transactions, the date on which the player clears the waiver wire without being claimed, making them eligible for outright assignment or free agency. Null for non-waiver transaction types.' ;
    rdfs:domain ind:TradeTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:competitiveIntegrityReviewFlag rdf:type rdf:Property ;
    rdfs:label 'Competitive Integrity Review Flag' ;
    rdfs:comment 'Indicates whether this transaction was flagged for competitive integrity review by the league office (e.g., suspected tanking, collusion between franchises, or circumvention of salary cap rules). True = flagged for review.' ;
    rdfs:domain ind:TradeTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:conditionResolutionDate rdf:type rdf:Property ;
    rdfs:label 'Condition Resolution Date' ;
    rdfs:comment 'The date by which all conditional terms of this transaction must be resolved or triggered. Null for unconditional transactions. Used to monitor outstanding conditional trade obligations.' ;
    rdfs:domain ind:TradeTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:conditionalTermsDescription rdf:type rdf:Property ;
    rdfs:label 'Conditional Terms Description' ;
    rdfs:comment 'Free-text description of any conditions attached to this transaction (e.g., \'Draft pick converts to 1st round if team makes playoffs\', \'Player option triggers salary escalation\'). Null for unconditional transactions.' ;
    rdfs:domain ind:TradeTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:noTradeClauseWaived rdf:type rdf:Property ;
    rdfs:label 'No Trade Clause Waived' ;
    rdfs:comment 'Indicates whether the player involved in this transaction had a contractual no-trade clause that was formally waived by the player to allow the transaction to proceed. True = player waived their no-trade clause.' ;
    rdfs:domain ind:TradeTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:noTradeClauseWaiverDate rdf:type rdf:Property ;
    rdfs:label 'No Trade Clause Waiver Date' ;
    rdfs:comment 'The date on which the player formally waived their no-trade clause to permit this transaction. Null if no no-trade clause existed or was not applicable.' ;
    rdfs:domain ind:TradeTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:physicalExamRequired rdf:type rdf:Property ;
    rdfs:label 'Physical Exam Required' ;
    rdfs:comment 'Indicates whether the transaction is contingent upon the acquired player passing a physical examination by the acquiring franchise\'s medical staff. True = physical required before transaction is fully ratified.' ;
    rdfs:domain ind:League ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:physicalExamStatus rdf:type rdf:Property ;
    rdfs:label 'Physical Exam Status' ;
    rdfs:comment 'Current status of the required physical examination for the acquired player: not_required, pending (scheduled but not completed), passed (cleared), failed (transaction may be voided), waived (franchise waived physical requirement).' ;
    rdfs:domain ind:TradeTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salaryCapImpactAcquiring rdf:type rdf:Property ;
    rdfs:label 'Salary Cap Impact Acquiring' ;
    rdfs:comment 'The net change to the acquiring franchise\'s salary cap space resulting from this transaction (positive = cap charge added). Used for real-time cap compliance monitoring per CBA salary cap rules.' ;
    rdfs:domain ind:TradeTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:salaryCapImpactTrading rdf:type rdf:Property ;
    rdfs:label 'Salary Cap Impact Trading' ;
    rdfs:comment 'The net change to the trading franchise\'s salary cap space resulting from this transaction (negative = cap relief received). Used for real-time cap compliance monitoring per CBA salary cap rules.' ;
    rdfs:domain ind:TradeTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:salaryObligationCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Salary Obligation Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the salary obligation transferred amount (e.g., USD, CAD).' ;
    rdfs:domain ind:TradeTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salaryObligationTransferredAmount rdf:type rdf:Property ;
    rdfs:label 'Salary Obligation Transferred Amount' ;
    rdfs:comment 'The total remaining salary obligation (base salary plus guaranteed money) transferred from the trading franchise to the acquiring franchise as part of this transaction. Critical for salary cap compliance tracking per CBA.' ;
    rdfs:domain ind:TradeTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sourceSystemTransactionCode rdf:type rdf:Property ;
    rdfs:label 'Source System Transaction Code' ;
    rdfs:comment 'The native transaction identifier from the originating operational system of record (e.g., SAP S/4HANA SD document number, Salesforce CRM opportunity ID) used for lineage tracing and reconciliation with upstream systems.' ;
    rdfs:domain ind:TradeTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradeDeadlineExceptionFlag rdf:type rdf:Property ;
    rdfs:label 'Trade Deadline Exception Flag' ;
    rdfs:comment 'Indicates whether this transaction required and received a formal league exception to proceed after the official trade deadline. True = exception granted; False = standard transaction within deadline.' ;
    rdfs:domain ind:TradeTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:transactionReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Transaction Reference Number' ;
    rdfs:comment 'Externally-known league-assigned alphanumeric reference number for this transaction, used in official league communications, press releases, and regulatory filings. Format: LEAGUE_CODE-TXN-YEAR-SEQUENCE.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionStatus rdf:type rdf:Property ;
    rdfs:label 'Transaction Status' ;
    rdfs:comment 'Current lifecycle state of the transaction in the league approval workflow: pending_approval (submitted, awaiting league review), approved (league has ratified), rejected (league denied), voided (approved but subsequently nullified), conditional_pending (approved subject to future conditions being met), rescinded (mutually withdrawn by franchises prior to approval).' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:voidDate rdf:type rdf:Property ;
    rdfs:label 'Void Date' ;
    rdfs:comment 'The date on which this transaction was officially voided or rescinded by the league. Null for non-voided transactions.' ;
    rdfs:domain ind:TradeTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:voidReason rdf:type rdf:Property ;
    rdfs:label 'Void Reason' ;
    rdfs:comment 'Explanation of why this transaction was voided or rescinded (e.g., failed physical examination, player refusal of trade, salary cap violation discovered post-approval). Null for non-voided transactions.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waiverClaimFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Waiver Claim Fee Amount' ;
    rdfs:comment 'The standard waiver claim fee charged to the acquiring franchise by the league upon a successful waiver claim. Amount is defined by the applicable CBA. Zero or null for non-waiver transactions.' ;
    rdfs:domain ind:TradeTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:waiverPriorityOrder rdf:type rdf:Property ;
    rdfs:label 'Waiver Priority Order' ;
    rdfs:comment 'The league-assigned waiver priority rank of the claiming franchise at the time of the waiver transaction. Lower number indicates higher priority (e.g., 1 = first priority). Null for non-waiver transaction types.' ;
    rdfs:domain ind:TradeTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:brandCompliancePolicyId rdf:type rdf:Property ;
    rdfs:label 'Brand Compliance Policy Id' ;
    rdfs:comment 'Foreign key linking to compliance.policy. Business justification: Brand compliance policy governs which IP/licensed content is permitted on each SKU. Compliance teams enforce brand usage policies at SKU level during product approval. sku_catalog.brand_compliance_app' ;
    rdfs:domain ind:Merchandise ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Policy .

ind:licensingAgreementId rdf:type rdf:Property ;
    rdfs:label 'Licensing Agreement Id' ;
    rdfs:comment 'Foreign key linking to merchandise.licensing_agreement. Business justification: sku_catalog has license_required (BOOLEAN) and license_type (STRING) fields indicating that many SKUs are governed by a specific licensing agreement (e.g., an athlete NIL deal, a franchise IP license,' ;
    rdfs:domain ind:Merchandise ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LicensingAgreement .

ind:supplierId rdf:type rdf:Property ;
    rdfs:label 'Supplier Id' ;
    rdfs:comment 'Foreign key linking to merchandise.supplier. Business justification: A SKU in the merchandise catalog is manufactured or supplied by a specific supplier. This 1:N relationship (many SKUs per supplier) is essential for procurement, quality tracking, and brand compliance' ;
    rdfs:domain ind:Merchandise ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Supplier .

ind:targetSegmentId rdf:type rdf:Property ;
    rdfs:label 'Target Segment Id' ;
    rdfs:comment 'Foreign key linking to fan.segment. Business justification: SKUs are targeted at specific fan segments for personalized catalog display and availability (e.g., youth jerseys shown only to youth segment, VIP exclusives to VIP segment). Sports retailers use segm' ;
    rdfs:domain ind:Merchandise ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Segment .

ind:ageRestriction rdf:type rdf:Property ;
    rdfs:label 'Age Restriction' ;
    rdfs:comment 'Age restriction classification for the SKU. Applies to products such as alcohol-branded merchandise or items with content restrictions. Drives age-gate enforcement on e-commerce and POS channels.' ;
    rdfs:domain ind:SkuCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brandComplianceApproved rdf:type rdf:Property ;
    rdfs:label 'Brand Compliance Approved' ;
    rdfs:comment 'Indicates whether the SKU has received formal brand compliance approval from the relevant league or team IP owner. Must be True before the SKU can be activated for sale. Supports IP protection and brand integrity workflows.' ;
    rdfs:domain ind:Merchandise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:colorHexCode rdf:type rdf:Property ;
    rdfs:label 'Color Hex Code' ;
    rdfs:comment 'Hexadecimal color code representing the primary color of the SKU for digital display consistency across e-commerce platforms, digital asset management (DAM), and brand compliance validation.' ;
    rdfs:domain ind:SkuCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:colorName rdf:type rdf:Property ;
    rdfs:label 'Color Name' ;
    rdfs:comment 'Primary color name or color combination of the SKU variant as displayed to consumers (e.g., \'Lakers Gold\', \'Midnight Navy\', \'Heather Grey\'). Aligns with Shopify Plus variant option for color and supports visual merchandising.' ;
    rdfs:domain ind:SkuCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceApprovedDate rdf:type rdf:Property ;
    rdfs:label 'Compliance Approved Date' ;
    rdfs:comment 'Date on which brand compliance approval was granted by the league or team IP owner for this SKU. Used for audit trails, licensing compliance reporting, and SOX financial controls.' ;
    rdfs:domain ind:SkuCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:costPrice rdf:type rdf:Property ;
    rdfs:label 'Cost Price' ;
    rdfs:comment 'Standard cost of goods for this SKU representing the landed cost per unit including manufacturing, materials, and inbound freight. Used for gross margin calculation, inventory valuation, and EBITDA reporting.' ;
    rdfs:domain ind:SkuCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:countryOfOrigin rdf:type rdf:Property ;
    rdfs:label 'Country Of Origin' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code indicating where the product was manufactured (e.g., USA, CHN, BGD, VNM). Required for customs declarations, import duty calculation, and consumer labeling compliance.' ;
    rdfs:domain ind:SkuCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discontinuationDate rdf:type rdf:Property ;
    rdfs:label 'Discontinuation Date' ;
    rdfs:comment 'Date on which the SKU was or is scheduled to be discontinued and removed from active sales channels. Null for currently active SKUs. Supports end-of-life inventory planning and catalog archival.' ;
    rdfs:domain ind:SkuCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:editionSize rdf:type rdf:Property ;
    rdfs:label 'Edition Size' ;
    rdfs:comment 'Total number of units in the limited edition production run. Applicable only when is_limited_edition is True. Used for scarcity marketing, collector value assessment, and inventory allocation.' ;
    rdfs:domain ind:SkuCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:genderTarget rdf:type rdf:Property ;
    rdfs:label 'Gender Target' ;
    rdfs:comment 'Target gender or age demographic for the SKU used for product classification, catalog filtering, and merchandising segmentation across sales channels.' ;
    rdfs:domain ind:SkuCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:harmonizedTariffCode rdf:type rdf:Property ;
    rdfs:label 'Harmonized Tariff Code' ;
    rdfs:comment 'Harmonized System (HS) tariff classification code used for international trade, customs clearance, and import duty determination. Required for cross-border merchandise distribution and third-party retail export compliance.' ;
    rdfs:domain ind:SkuCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isAutographed rdf:type rdf:Property ;
    rdfs:label 'Is Autographed' ;
    rdfs:comment 'Indicates whether the SKU is an autographed memorabilia item. True triggers certificate of authenticity (COA) requirements, premium pricing tiers, and specialized inventory handling protocols.' ;
    rdfs:domain ind:SkuCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isGameUsed rdf:type rdf:Property ;
    rdfs:label 'Is Game Used' ;
    rdfs:comment 'Indicates whether the SKU is a game-used item (equipment or apparel actually used during an official game or event). True requires provenance documentation, chain-of-custody tracking, and premium authentication certification.' ;
    rdfs:domain ind:SkuCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isLimitedEdition rdf:type rdf:Property ;
    rdfs:label 'Is Limited Edition' ;
    rdfs:comment 'Indicates whether the SKU is a limited edition release with a defined production run cap. True triggers limited edition pricing strategy, scarcity marketing, and edition size tracking.' ;
    rdfs:domain ind:SkuCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:licenseRequired rdf:type rdf:Property ;
    rdfs:label 'License Required' ;
    rdfs:comment 'Indicates whether this SKU requires an active licensing agreement to manufacture, distribute, or sell. True for all officially licensed league, team, or athlete-branded merchandise. Drives compliance checks in the licensing workflow.' ;
    rdfs:domain ind:SkuCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:materialComposition rdf:type rdf:Property ;
    rdfs:label 'Material Composition' ;
    rdfs:comment 'Fabric or material composition of the product (e.g., \'100% Polyester\', \'60% Cotton 40% Polyester\', \'Genuine Leather\'). Required for product labeling compliance, customs declarations, and consumer transparency regulations.' ;
    rdfs:domain ind:SkuCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:msrp rdf:type rdf:Property ;
    rdfs:label 'Msrp' ;
    rdfs:comment 'Manufacturer\'s Suggested Retail Price in the base currency (USD) for this SKU. Serves as the reference price point for all sales channels including Shopify Plus e-commerce, venue POS, and third-party retail. Does not represent actual transaction price.' ;
    rdfs:domain ind:Merchandise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:productDescription rdf:type rdf:Property ;
    rdfs:label 'Product Description' ;
    rdfs:comment 'Detailed marketing and operational description of the product including materials, features, fit, and intended use. Used for e-commerce listings, catalog publishing, and digital asset management.' ;
    rdfs:domain ind:SkuCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productName rdf:type rdf:Property ;
    rdfs:label 'Product Name' ;
    rdfs:comment 'Human-readable commercial name of the merchandise product as displayed on sales channels, e-commerce storefronts, and POS systems (e.g., \'Los Angeles Lakers City Edition Jersey – LeBron James #23\').' ;
    rdfs:domain ind:Merchandise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productType rdf:type rdf:Property ;
    rdfs:label 'Product Type' ;
    rdfs:comment 'Indicates whether the SKU represents a physical tangible good, a digital product (e.g., digital collectible, downloadable content), or a bundle of multiple items. Drives fulfillment routing and revenue recognition treatment.' ;
    rdfs:domain ind:SkuCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiresAuthentication rdf:type rdf:Property ;
    rdfs:label 'Requires Authentication' ;
    rdfs:comment 'Indicates whether this SKU requires a certificate of authenticity (COA) or third-party authentication (e.g., PSA/DNA, JSA) before sale. Applies to autographed memorabilia, game-used items, and high-value collectibles.' ;
    rdfs:domain ind:SkuCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:salesChannelAvailability rdf:type rdf:Property ;
    rdfs:label 'Sales Channel Availability' ;
    rdfs:comment 'Pipe-delimited list of sales channels where this SKU is authorized for sale (e.g., \'shopify_online|venue_pos|third_party_retail|dtc_app\'). Drives omnichannel availability logic and channel-specific pricing rules. [ENUM-REF-CANDIDATE: shopify_online|venue_pos|third_party_retail|dtc_app|wholesale|international — promote to reference product]' ;
    rdfs:domain ind:SkuCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shopifyVariantCode rdf:type rdf:Property ;
    rdfs:label 'Shopify Variant Code' ;
    rdfs:comment 'Native variant identifier from the Shopify Plus e-commerce platform used for system-of-record reconciliation, API integration, and omnichannel order management. Enables traceability between the Silver Layer catalog and the Shopify Plus source system.' ;
    rdfs:domain ind:SkuCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sizeCode rdf:type rdf:Property ;
    rdfs:label 'Size Code' ;
    rdfs:comment 'Standardized size designation for the SKU variant (e.g., XS, S, M, L, XL, XXL, 3XL, 7, 7.5, 32x30). Null for non-sized items such as collectibles or accessories. Aligns with Shopify Plus variant option for size.' ;
    rdfs:domain ind:SkuCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:skuCode rdf:type rdf:Property ;
    rdfs:label 'Sku Code' ;
    rdfs:comment 'Externally-known alphanumeric code that uniquely identifies a specific product variant (team, style, size, color combination) across all sales channels including Shopify Plus, POS, and third-party retail. Serves as the SSOT business identifier for omnichannel product lookup.' ;
    rdfs:domain ind:Merchandise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxable rdf:type rdf:Property ;
    rdfs:label 'Taxable' ;
    rdfs:comment 'Indicates whether this SKU is subject to sales tax. Drives tax calculation at POS and e-commerce checkout. Certain memorabilia or resale items may have different tax treatment depending on jurisdiction.' ;
    rdfs:domain ind:SkuCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:weightGrams rdf:type rdf:Property ;
    rdfs:label 'Weight Grams' ;
    rdfs:comment 'Physical weight of the SKU in grams used for shipping rate calculation, customs documentation, and carrier SLA compliance across e-commerce fulfillment and third-party retail distribution.' ;
    rdfs:domain ind:SkuCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inventoryPositionId rdf:type rdf:Property ;
    rdfs:label 'Inventory Position Id' ;
    rdfs:comment 'Unique surrogate identifier for each inventory position record representing a SKU-location snapshot in the merchandise domain.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryInventoryRetailLocationId rdf:type rdf:Property ;
    rdfs:label 'Primary Inventory Retail Location Id' ;
    rdfs:comment 'Reference to the storage location (venue store, warehouse fulfillment center, or third-party retail consignment site) where this inventory position is held.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RetailLocation .

ind:primaryInventorySkuCatalogId rdf:type rdf:Property ;
    rdfs:label 'Primary Inventory Sku Catalog Id' ;
    rdfs:comment 'Reference to the merchandise SKU catalog entry for which this inventory position is tracked. Links to the product master.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SkuCatalog .

ind:reservedSegmentId rdf:type rdf:Property ;
    rdfs:label 'Reserved Segment Id' ;
    rdfs:comment 'Foreign key linking to fan.segment. Business justification: Inventory is pre-allocated for specific fan segments during VIP pre-sales, member-exclusive drops, and season ticket holder windows. This FK enables inventory reservation management by segment, a stan' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Segment .

ind:tertiaryInventoryTransferDestinationLocationRetailLocationId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Inventory Transfer Destination Location Retail Location Id' ;
    rdfs:comment 'Reference to the destination storage location for the most recent or active stock transfer affecting this inventory position. Used for event-day venue stocking and warehouse rebalancing.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RetailLocation .

ind:availableToSellQty rdf:type rdf:Property ;
    rdfs:label 'Available To Sell Qty' ;
    rdfs:comment 'Net units of the SKU at this location that can be sold or allocated to new orders. Calculated as on_hand_qty minus reserved_qty minus blocked_qty. Drives omnichannel availability display and reorder triggers.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:blockedQty rdf:type rdf:Property ;
    rdfs:label 'Blocked Qty' ;
    rdfs:comment 'Units of the SKU held at this location that are blocked from sale due to quality inspection, compliance hold, damage assessment, or licensing dispute. Tracked separately from reserved stock.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:brandComplianceStatus rdf:type rdf:Property ;
    rdfs:label 'Brand Compliance Status' ;
    rdfs:comment 'Current brand compliance status of the SKU inventory at this location. Non-compliant or under-review stock may be blocked from sale pending IP or licensing verification.' ;
    rdfs:domain ind:Merchandise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countVarianceQty rdf:type rdf:Property ;
    rdfs:label 'Count Variance Qty' ;
    rdfs:comment 'Difference between last_physical_count_qty and system on_hand_qty at the time of the count. Positive values indicate system over-count; negative values indicate shrinkage or unrecorded losses.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inTransitQty rdf:type rdf:Property ;
    rdfs:label 'In Transit Qty' ;
    rdfs:comment 'Units of the SKU currently in transit to this location from another storage location (warehouse, venue, or third-party). Included in inventory planning but not yet physically received.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inventoryValue rdf:type rdf:Property ;
    rdfs:label 'Inventory Value' ;
    rdfs:comment 'Total financial value of on-hand stock for this SKU at this location (on_hand_qty × unit_cost). Used for balance sheet inventory reporting and EBITDA analysis. Confidential financial data.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isConsignment rdf:type rdf:Property ;
    rdfs:label 'Is Consignment' ;
    rdfs:comment 'Indicates whether the inventory at this location is held on consignment with a third-party retailer. Consignment stock requires separate royalty tracking and licensing compliance under IP agreements.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isEventAllocated rdf:type rdf:Property ;
    rdfs:label 'Is Event Allocated' ;
    rdfs:comment 'Indicates whether this inventory position has been specifically allocated for an upcoming event (e.g., game day, concert, championship). Event-allocated stock is excluded from general omnichannel availability.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastMovementTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Movement Timestamp' ;
    rdfs:comment 'Date and time of the most recent stock movement (sale, transfer, adjustment, receipt) that changed the on-hand quantity for this SKU-location combination. Critical for real-time inventory sync validation.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lastMovementType rdf:type rdf:Property ;
    rdfs:label 'Last Movement Type' ;
    rdfs:comment 'Type of the most recent stock movement that updated this inventory position. Used for audit trail and inventory reconciliation. [ENUM-REF-CANDIDATE: sale|return|transfer_in|transfer_out|adjustment|receipt|write_off|event_allocation — promote to reference product]' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastPhysicalCountDate rdf:type rdf:Property ;
    rdfs:label 'Last Physical Count Date' ;
    rdfs:comment 'Date on which the most recent physical inventory count was conducted for this SKU at this location. Used to assess count freshness and schedule cycle counts per SOX and internal audit requirements.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastPhysicalCountQty rdf:type rdf:Property ;
    rdfs:label 'Last Physical Count Qty' ;
    rdfs:comment 'Actual unit count recorded during the most recent physical inventory count for this SKU at this location. Compared against system on-hand quantity to identify shrinkage or discrepancies.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:locationCode rdf:type rdf:Property ;
    rdfs:label 'Location Code' ;
    rdfs:comment 'Alphanumeric code identifying the physical storage location (e.g., venue store bin, warehouse zone, consignment shelf). Used for warehouse management and event-day stocking operations.' ;
    rdfs:domain ind:Merchandise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:locationType rdf:type rdf:Property ;
    rdfs:label 'Location Type' ;
    rdfs:comment 'Classification of the storage location where inventory is held. Drives omnichannel fulfillment routing, event-day stocking logic, and consignment royalty tracking. [ENUM-REF-CANDIDATE: venue_store|warehouse|consignment|pop_up|online_fulfillment|third_party_retail — promote to reference product]' ;
    rdfs:domain ind:Merchandise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxStockQty rdf:type rdf:Property ;
    rdfs:label 'Max Stock Qty' ;
    rdfs:comment 'Upper capacity limit for this SKU at this storage location. Prevents over-stocking and supports space planning for venue stores and warehouse zones.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:onHandQty rdf:type rdf:Property ;
    rdfs:label 'On Hand Qty' ;
    rdfs:comment 'Total physical units of the SKU currently present at the storage location, including reserved and blocked stock. Sourced from Shopify Plus inventory sync or warehouse management system.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:posLocationCode rdf:type rdf:Property ;
    rdfs:label 'Pos Location Code' ;
    rdfs:comment 'Identifier for the POS terminal or venue store location as registered in the POS system. Used to reconcile POS transaction-driven inventory deductions with Shopify Plus and SAP inventory records.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:positionStatus rdf:type rdf:Property ;
    rdfs:label 'Position Status' ;
    rdfs:comment 'Current lifecycle status of the inventory position record. \'blocked\' indicates stock held for quality inspection or compliance review; \'pending_audit\' indicates a physical count discrepancy under investigation.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reorderPointQty rdf:type rdf:Property ;
    rdfs:label 'Reorder Point Qty' ;
    rdfs:comment 'Stock level threshold at which a replenishment order should be initiated for this SKU at this location. Accounts for lead time and safety stock. Used by merchandise operations for automated reorder triggers.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reorderQty rdf:type rdf:Property ;
    rdfs:label 'Reorder Qty' ;
    rdfs:comment 'Standard replenishment order quantity for this SKU at this location when the reorder point is reached. Reflects economic order quantity or vendor minimum order quantity.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reservedQty rdf:type rdf:Property ;
    rdfs:label 'Reserved Qty' ;
    rdfs:comment 'Units of the SKU at this location that are committed to open orders, event-day allocations, or transfer requests and are not available for new sales. Sourced from Shopify Plus committed inventory.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:safetyStockQty rdf:type rdf:Property ;
    rdfs:label 'Safety Stock Qty' ;
    rdfs:comment 'Minimum buffer stock level for the SKU at this location below which a replenishment alert is triggered. Set by merchandise planners to prevent stockouts during peak event periods.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:shopifyInventoryItemCode rdf:type rdf:Property ;
    rdfs:label 'Shopify Inventory Item Code' ;
    rdfs:comment 'External identifier assigned by Shopify Plus to the inventory item for this SKU. Used for real-time inventory sync between Shopify Plus and the lakehouse silver layer.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shopifyLocationCode rdf:type rdf:Property ;
    rdfs:label 'Shopify Location Code' ;
    rdfs:comment 'External identifier assigned by Shopify Plus to the fulfillment location. Used to reconcile Shopify inventory levels with SAP and POS system records across omnichannel operations.' ;
    rdfs:domain ind:Merchandise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shrinkageQty rdf:type rdf:Property ;
    rdfs:label 'Shrinkage Qty' ;
    rdfs:comment 'Cumulative units of the SKU lost at this location due to theft, damage, or unrecorded consumption since the last physical count. Used for loss prevention reporting and inventory reconciliation.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:transferCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Transfer Completion Date' ;
    rdfs:comment 'Date on which the most recent stock transfer to or from this inventory position was completed and receiving confirmation was recorded.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:transferQty rdf:type rdf:Property ;
    rdfs:label 'Transfer Qty' ;
    rdfs:comment 'Number of units involved in the most recent or active stock transfer for this SKU-location. Captured to support transfer reconciliation and event-day stocking verification.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:transferReason rdf:type rdf:Property ;
    rdfs:label 'Transfer Reason' ;
    rdfs:comment 'Business reason for the most recent stock transfer affecting this inventory position. Supports event-day logistics planning and omnichannel inventory optimization reporting.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferStatus rdf:type rdf:Property ;
    rdfs:label 'Transfer Status' ;
    rdfs:comment 'Current workflow status of the most recent stock transfer associated with this inventory position. Drives in-transit quantity calculations and fulfillment center receiving workflows.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitCost rdf:type rdf:Property ;
    rdfs:label 'Unit Cost' ;
    rdfs:comment 'Standard or moving average cost per unit of the SKU at this location used for inventory valuation. Sourced from SAP S/4HANA material ledger. Confidential as it reflects supplier pricing and margin data.' ;
    rdfs:domain ind:Merchandise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:valuationMethod rdf:type rdf:Property ;
    rdfs:label 'Valuation Method' ;
    rdfs:comment 'Accounting method used to value inventory for this SKU at this location. Determines how unit_cost is calculated and reported on financial statements. Must align with SAP material ledger configuration.' ;
    rdfs:domain ind:InventoryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retailLocationId rdf:type rdf:Property ;
    rdfs:label 'Retail Location Id' ;
    rdfs:comment 'Unique surrogate identifier for each retail point-of-presence record in the merchandise sales channel master. Primary key for the retail_location data product.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RetailLocation .

ind:addressLine1 rdf:type rdf:Property ;
    rdfs:label 'Address Line 1' ;
    rdfs:comment 'Primary street address of the physical retail location. Required for venue stores, kiosks, warehouse outlets, and pop-up shops. Null for pure e-commerce storefronts.' ;
    rdfs:domain ind:RetailLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressLine2 rdf:type rdf:Property ;
    rdfs:label 'Address Line 2' ;
    rdfs:comment 'Secondary address detail for the physical retail location (suite, unit, concourse level, gate reference). Supplements address_line_1 for precise wayfinding within large venue complexes.' ;
    rdfs:domain ind:RetailLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelSegment rdf:type rdf:Property ;
    rdfs:label 'Channel Segment' ;
    rdfs:comment 'Sales channel segment classification for the retail location. Distinguishes Direct-To-Consumer (DTC) owned channels from wholesale, marketplace, venue retail, and concession operations. Drives revenue attribution, royalty calculation, and licensing compliance reporting.' ;
    rdfs:domain ind:RetailLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactEmail rdf:type rdf:Property ;
    rdfs:label 'Contact Email' ;
    rdfs:comment 'Primary contact email address for the retail location. Used for operational notifications, inventory alerts, and inter-department communications. Organizational contact data classified as confidential.' ;
    rdfs:domain ind:RetailLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactPhone rdf:type rdf:Property ;
    rdfs:label 'Contact Phone' ;
    rdfs:comment 'Primary contact telephone number for the retail location. Used for operational communications, vendor deliveries, and fan-facing store locator directory.' ;
    rdfs:domain ind:RetailLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defaultCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Default Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code used as the default transaction currency for this retail location (e.g., USD, GBP, EUR). Drives POS configuration, Shopify Plus storefront currency, and SAP SD pricing procedures.' ;
    rdfs:domain ind:RetailLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventDayHours rdf:type rdf:Property ;
    rdfs:label 'Event Day Hours' ;
    rdfs:comment 'Extended or modified operating hours applied on event days (game days, concerts, PPV events). Overrides standard weekday/weekend hours when an event is scheduled at the associated venue. Format: HH:MM-HH:MM.' ;
    rdfs:domain ind:RetailLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:floorAreaSqft rdf:type rdf:Property ;
    rdfs:label 'Floor Area Sqft' ;
    rdfs:comment 'Total usable retail floor area of the location in square feet. Used for merchandise density planning, inventory capacity modeling, and lease/facility cost allocation. Serves as the MEASUREMENT_OR_VALUE for the MASTER_RESOURCE role.' ;
    rdfs:domain ind:RetailLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inventoryLocationCode rdf:type rdf:Property ;
    rdfs:label 'Inventory Location Code' ;
    rdfs:comment 'SAP S/4HANA MM storage location or warehouse code linked to this retail location for inventory management, stock replenishment, and goods movement tracking. Enables real-time inventory visibility across omnichannel merchandise operations.' ;
    rdfs:domain ind:RetailLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isFlagship rdf:type rdf:Property ;
    rdfs:label 'Is Flagship' ;
    rdfs:comment 'Indicates whether this retail location is designated as the flagship store for the associated venue or brand. Flagship stores receive priority inventory allocation, exclusive product launches, and premium visual merchandising standards.' ;
    rdfs:domain ind:RetailLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isOnline rdf:type rdf:Property ;
    rdfs:label 'Is Online' ;
    rdfs:comment 'Indicates whether this retail location is a virtual/online storefront (e.g., Shopify Plus e-commerce) rather than a physical location. Drives omnichannel routing logic, inventory fulfillment rules, and digital analytics tagging.' ;
    rdfs:domain ind:RetailLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastAuditDate rdf:type rdf:Property ;
    rdfs:label 'Last Audit Date' ;
    rdfs:comment 'Date of the most recent compliance or operational audit conducted at this retail location. Covers PCI-DSS POS terminal audits, ADA accessibility inspections, and merchandise licensing compliance reviews.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:licenseTerritory rdf:type rdf:Property ;
    rdfs:label 'License Territory' ;
    rdfs:comment 'Geographic territory designation under which this retail location is authorized to sell licensed merchandise (e.g., \'NFL_NFC_WEST\', \'FIFA_EUROPE\', \'NBA_EASTERN_CONFERENCE\'). Enforces IP licensing boundaries and royalty calculation scope per league governing body agreements.' ;
    rdfs:domain ind:RetailLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:locationName rdf:type rdf:Property ;
    rdfs:label 'Location Name' ;
    rdfs:comment 'Human-readable display name of the retail point-of-presence (e.g., \'Allegiant Stadium Flagship Store\', \'Gate 4 Kiosk\', \'Official Online Store\'). Serves as the IDENTITY_LABEL for the MASTER_RESOURCE role.' ;
    rdfs:domain ind:RetailLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:locationStatus rdf:type rdf:Property ;
    rdfs:label 'Location Status' ;
    rdfs:comment 'Current operational lifecycle state of the retail location. Controls whether the location is available for sales transactions, inventory replenishment, and POS terminal assignment. Serves as the LIFECYCLE_STATUS for the MASTER_RESOURCE role.' ;
    rdfs:domain ind:RetailLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:managerName rdf:type rdf:Property ;
    rdfs:label 'Manager Name' ;
    rdfs:comment 'Name of the store manager or location lead responsible for day-to-day operations of this retail location. Used for operational escalation, staffing accountability, and SAP SuccessFactors workforce assignment reference.' ;
    rdfs:domain ind:RetailLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Modified Timestamp' ;
    rdfs:comment 'Timestamp of the most recent update to this retail location record. Used for change data capture (CDC), data lineage tracking, and Silver layer incremental load processing in the Databricks Lakehouse.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:operatingHoursWeekday rdf:type rdf:Property ;
    rdfs:label 'Operating Hours Weekday' ;
    rdfs:comment 'Standard weekday operating hours for the retail location in HH:MM-HH:MM 24-hour format (e.g., \'09:00-21:00\'). Used for fan-facing store locator, staff scheduling, and omnichannel availability configuration.' ;
    rdfs:domain ind:RetailLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatingHoursWeekend rdf:type rdf:Property ;
    rdfs:label 'Operating Hours Weekend' ;
    rdfs:comment 'Standard weekend operating hours for the retail location in HH:MM-HH:MM 24-hour format (e.g., \'10:00-18:00\'). Distinct from weekday hours to support event-day extended trading and fan engagement scheduling.' ;
    rdfs:domain ind:RetailLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesOrgCode rdf:type rdf:Property ;
    rdfs:label 'Sales Org Code' ;
    rdfs:comment 'SAP S/4HANA SD sales organization code to which this retail location belongs. Determines pricing procedures, output determination, and revenue recognition rules applicable to merchandise transactions at this location.' ;
    rdfs:domain ind:RetailLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:merchOrderId rdf:type rdf:Property ;
    rdfs:label 'Merch Order Id' ;
    rdfs:comment 'Unique surrogate identifier for a merchandise order record in the Sports Entertainment lakehouse silver layer. Primary key for the merch_order data product.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MerchOrder .

ind:fanPaymentMethodId rdf:type rdf:Property ;
    rdfs:label 'Fan Payment Method Id' ;
    rdfs:comment 'Foreign key linking to fan.payment_method. Business justification: Merchandise orders must reference the fan\'s stored payment method for PCI audit trails, fraud detection, and auto-renewal/subscription merchandise billing. Sports entertainment operators require this ' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PaymentMethod .

ind:priceListId rdf:type rdf:Property ;
    rdfs:label 'Price List Id' ;
    rdfs:comment 'Foreign key linking to merchandise.price_list. Business justification: merch_order captures the gross_amount, discount_amount, and net_total but has no reference to which price_list configuration governed the transaction. Adding price_list_id creates an order-level audit' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PriceList .

ind:primaryMerchEventFixtureId rdf:type rdf:Property ;
    rdfs:label 'Primary Merch Event Fixture Id' ;
    rdfs:comment 'Reference to the sports or entertainment event associated with this merchandise order. Enables revenue attribution to specific events for sponsorship and performance reporting.' ;
    rdfs:domain ind:MerchOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Fixture .

ind:primaryMerchFanFanProfileId rdf:type rdf:Property ;
    rdfs:label 'Primary Merch Fan Fan Profile Id' ;
    rdfs:comment 'Reference to the fan or customer who placed this merchandise order. Links to the fan master record in the Fan domain. Null for anonymous or guest checkout transactions.' ;
    rdfs:domain ind:MerchOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FanProfile .

ind:primaryMerchFranchiseId rdf:type rdf:Property ;
    rdfs:label 'Primary Merch Franchise Id' ;
    rdfs:comment 'Reference to the sports team whose licensed merchandise was primarily purchased in this order. Enables team-level merchandise revenue attribution, licensing royalty calculation, and brand performance reporting across the league.' ;
    rdfs:domain ind:MerchOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Franchise .

ind:channelSubtype rdf:type rdf:Property ;
    rdfs:label 'Channel Subtype' ;
    rdfs:comment 'Granular classification of the sales channel within the primary channel type. Enables detailed omnichannel analytics distinguishing mobile app vs. online store within e-commerce, or kiosk vs. arena store within venue POS. [ENUM-REF-CANDIDATE: online_store|mobile_app|arena_store|kiosk|pop_up|third_party_retailer — promote to reference product]' ;
    rdfs:domain ind:MerchOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:giftOrderFlag rdf:type rdf:Property ;
    rdfs:label 'Gift Order Flag' ;
    rdfs:comment 'Indicates whether the merchandise order was designated as a gift by the purchaser. When true, triggers gift wrapping, suppresses price disclosure on packing slip, and enables gift receipt generation. Relevant for holiday and event-driven merchandise campaigns.' ;
    rdfs:domain ind:MerchOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ipAddress rdf:type rdf:Property ;
    rdfs:label 'Ip Address' ;
    rdfs:comment 'IP address of the device used to place the e-commerce order via Shopify Plus. Used for fraud detection, geographic analytics, and GDPR/CCPA compliance audit trails. Null for in-venue POS transactions. Classified as confidential per GDPR Article 4 as it may constitute personal data.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netTotal rdf:type rdf:Property ;
    rdfs:label 'Net Total' ;
    rdfs:comment 'Final amount charged to the customer: gross_amount minus discount_amount plus tax_amount plus shipping_amount. Represents the actual revenue collected for this order. Used as the primary revenue figure for financial reporting and reconciliation against payment records.' ;
    rdfs:domain ind:MerchOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:orderDate rdf:type rdf:Property ;
    rdfs:label 'Order Date' ;
    rdfs:comment 'The principal real-world timestamp when the merchandise order was placed by the customer or captured at the Point of Sale (POS) terminal. Represents the business event time, distinct from system audit timestamps. Stored in ISO 8601 format with timezone offset.' ;
    rdfs:domain ind:MerchOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:posTerminalCode rdf:type rdf:Property ;
    rdfs:label 'Pos Terminal Code' ;
    rdfs:comment 'Unique identifier of the Point of Sale (POS) terminal device that processed the in-venue transaction. Populated only for venue_pos channel orders. Used for reconciliation, audit trails, and PCI DSS compliance reporting.' ;
    rdfs:domain ind:MerchOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Return Eligible Flag' ;
    rdfs:comment 'Indicates whether the order is eligible for return or exchange under the current merchandise return policy. May be false for event-day clearance items, personalized/customized merchandise, or items past the return window. Drives customer service and reverse logistics workflows.' ;
    rdfs:domain ind:MerchOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:returnWindowExpiry rdf:type rdf:Property ;
    rdfs:label 'Return Window Expiry' ;
    rdfs:comment 'The last date on which a return or exchange can be initiated for this order, calculated from the order date based on the applicable return policy. Used by customer service to validate return eligibility and by operations to manage reverse logistics SLA (Service Level Agreement) compliance.' ;
    rdfs:domain ind:MerchOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:shippingAmount rdf:type rdf:Property ;
    rdfs:label 'Shipping Amount' ;
    rdfs:comment 'Shipping and handling charges applied to the order. Populated for e-commerce orders with physical delivery. Zero or null for in-venue POS transactions where goods are handed over at point of purchase.' ;
    rdfs:domain ind:MerchOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shippingCountryCode rdf:type rdf:Property ;
    rdfs:label 'Shipping Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the shipping destination for e-commerce orders (e.g., USA, GBR, CAN). Used for international shipping compliance, tax jurisdiction determination, and geographic sales reporting. Null for in-venue POS transactions.' ;
    rdfs:domain ind:Merchandise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shippingMethod rdf:type rdf:Property ;
    rdfs:label 'Shipping Method' ;
    rdfs:comment 'The delivery method selected for the order (e.g., Standard Ground, Express 2-Day, Overnight, In-Store Pickup, Will Call). Populated for e-commerce orders. Null for in-venue POS transactions. Used for logistics planning and shipping cost analysis. [ENUM-REF-CANDIDATE: standard_ground|express_2day|overnight|in_store_pickup|will_call|international — promote to reference product]' ;
    rdfs:domain ind:MerchOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shippingPostalCode rdf:type rdf:Property ;
    rdfs:label 'Shipping Postal Code' ;
    rdfs:comment 'Postal or ZIP code of the shipping destination for e-commerce orders. Used for geographic sales analysis, regional fan merchandise demand mapping, and shipping carrier zone determination. Classified as confidential address data per GDPR and CCPA.' ;
    rdfs:domain ind:Merchandise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceOrderReference rdf:type rdf:Property ;
    rdfs:label 'Source Order Reference' ;
    rdfs:comment 'The native order identifier from the originating operational system (e.g., Shopify Plus order ID, POS transaction ID, wholesale portal order number). Enables traceability back to the system of record for reconciliation, dispute resolution, and audit purposes.' ;
    rdfs:domain ind:MerchOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxExemptFlag rdf:type rdf:Property ;
    rdfs:label 'Tax Exempt Flag' ;
    rdfs:comment 'Indicates whether the order is exempt from sales tax, typically applicable to wholesale B2B orders with a valid tax exemption certificate or reseller permit. Drives tax calculation logic and financial reporting for SAP S/4HANA FI tax reconciliation.' ;
    rdfs:domain ind:MerchOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:taxExemptionRef rdf:type rdf:Property ;
    rdfs:label 'Tax Exemption Ref' ;
    rdfs:comment 'Tax exemption certificate number or reseller permit reference for tax-exempt orders. Populated only when tax_exempt_flag is true. Required for tax audit documentation and compliance with applicable sales tax regulations.' ;
    rdfs:domain ind:MerchOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderLineId rdf:type rdf:Property ;
    rdfs:label 'Order Line Id' ;
    rdfs:comment 'Unique surrogate identifier for each individual order line item within the merchandise domain. Primary key for this entity.' ;
    rdfs:domain ind:Merchandise ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrderLine .

ind:primaryOrderEventFixtureId rdf:type rdf:Property ;
    rdfs:label 'Primary Order Event Fixture Id' ;
    rdfs:comment 'Reference to the sports or entertainment event associated with this merchandise purchase (e.g., a game-day jersey purchase linked to a specific fixture). Enables event-level merchandise revenue attribution and post-event sales analysis.' ;
    rdfs:domain ind:OrderLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Fixture .

ind:primaryOrderFranchiseId rdf:type rdf:Property ;
    rdfs:label 'Primary Order Franchise Id' ;
    rdfs:comment 'Reference to the sports team or franchise whose branding, intellectual property (IP), or licensing rights are associated with the merchandise SKU on this line. Enables team-level revenue attribution and royalty calculation.' ;
    rdfs:domain ind:OrderLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Franchise .

ind:primaryOrderSkuCatalogId rdf:type rdf:Property ;
    rdfs:label 'Primary Order Sku Catalog Id' ;
    rdfs:comment 'Reference to the specific Stock Keeping Unit (SKU) purchased on this line. Enables SKU-level sales performance tracking, inventory reconciliation, and product-level revenue attribution across channels.' ;
    rdfs:domain ind:OrderLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SkuCatalog .

ind:brandComplianceVerified rdf:type rdf:Property ;
    rdfs:label 'Brand Compliance Verified' ;
    rdfs:comment 'Indicates whether the merchandise SKU on this line has been verified as compliant with the applicable league or team brand standards and licensing requirements prior to sale. Supports IP protection and brand governance.' ;
    rdfs:domain ind:OrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fulfillmentLocationType rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Location Type' ;
    rdfs:comment 'Classification of the fulfillment origin for this line item, distinguishing between central warehouse, venue retail store, third-party logistics (3PL) provider, or direct drop-ship from supplier. Supports omnichannel fulfillment analytics.' ;
    rdfs:domain ind:OrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isGift rdf:type rdf:Property ;
    rdfs:label 'Is Gift' ;
    rdfs:comment 'Indicates whether this line item was purchased as a gift, triggering gift wrapping, gift receipt generation, and suppression of price information on packing slips.' ;
    rdfs:domain ind:OrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPersonalized rdf:type rdf:Property ;
    rdfs:label 'Is Personalized' ;
    rdfs:comment 'Indicates whether this line item includes a personalization or customization (e.g., player name/number printing on a jersey). Personalized items typically have different return eligibility and production lead times.' ;
    rdfs:domain ind:OrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isReturnEligible rdf:type rdf:Property ;
    rdfs:label 'Is Return Eligible' ;
    rdfs:comment 'Indicates whether this line item is eligible for return based on product type, licensing restrictions, event-specific merchandise policies, or return window expiry. Drives customer-facing return eligibility checks.' ;
    rdfs:domain ind:OrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lineDiscountAmount rdf:type rdf:Property ;
    rdfs:label 'Line Discount Amount' ;
    rdfs:comment 'Total monetary discount applied to this specific line item, including promotional codes, loyalty discounts, and manual overrides. Expressed in the order currency.' ;
    rdfs:domain ind:OrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lineDiscountPct rdf:type rdf:Property ;
    rdfs:label 'Line Discount Pct' ;
    rdfs:comment 'Discount rate applied to this line item expressed as a percentage of the unit price multiplied by quantity. Supports promotional effectiveness analysis and margin impact reporting.' ;
    rdfs:domain ind:OrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lineSubtotal rdf:type rdf:Property ;
    rdfs:label 'Line Subtotal' ;
    rdfs:comment 'Pre-tax line total calculated as (unit_price × quantity_ordered) minus line_discount_amount. Represents the net merchandise value of this line before tax. Used for revenue attribution and financial reporting.' ;
    rdfs:domain ind:OrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lineTaxAmount rdf:type rdf:Property ;
    rdfs:label 'Line Tax Amount' ;
    rdfs:comment 'Total tax amount charged on this line item, aggregating all applicable tax lines (e.g., state, local, VAT). Required for tax remittance reporting and financial reconciliation.' ;
    rdfs:domain ind:OrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:personalizationDetail rdf:type rdf:Property ;
    rdfs:label 'Personalization Detail' ;
    rdfs:comment 'Free-text description of the personalization applied to this line item (e.g., \'Name: JOHNSON, Number: 23\'). Populated only when is_personalized is true. Drives production instructions for customization fulfillment.' ;
    rdfs:domain ind:OrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityFulfilled rdf:type rdf:Property ;
    rdfs:label 'Quantity Fulfilled' ;
    rdfs:comment 'Number of units of this line item that have been physically picked, packed, and shipped or handed over to the customer. Enables partial fulfillment tracking and backorder identification.' ;
    rdfs:domain ind:OrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:quantityOrdered rdf:type rdf:Property ;
    rdfs:label 'Quantity Ordered' ;
    rdfs:comment 'Number of units of the SKU ordered on this line item. Used for inventory reservation, fulfillment picking, and sales volume reporting.' ;
    rdfs:domain ind:OrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:quantityReturned rdf:type rdf:Property ;
    rdfs:label 'Quantity Returned' ;
    rdfs:comment 'Number of units of this line item that have been returned by the customer. Supports return rate analysis, refund processing, and net revenue calculation at the SKU level.' ;
    rdfs:domain ind:Merchandise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:requiresShipping rdf:type rdf:Property ;
    rdfs:label 'Requires Shipping' ;
    rdfs:comment 'Indicates whether this line item requires physical shipment to the customer, as opposed to in-venue pickup or digital delivery. Drives shipping cost allocation and logistics workflow routing.' ;
    rdfs:domain ind:OrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:returnStatus rdf:type rdf:Property ;
    rdfs:label 'Return Status' ;
    rdfs:comment 'Current status of any return or refund request associated with this line item. Supports returns management, refund authorization workflows, and customer service operations.' ;
    rdfs:domain ind:OrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnWindowExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Return Window Expiry Date' ;
    rdfs:comment 'The last date on which a return for this line item can be initiated, calculated from the fulfillment date based on the applicable return policy. Used to enforce return eligibility and automate policy expiry.' ;
    rdfs:domain ind:OrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:royaltyAmount rdf:type rdf:Property ;
    rdfs:label 'Royalty Amount' ;
    rdfs:comment 'Calculated royalty obligation for this line item (line_subtotal × royalty_rate). Supports licensor payment processing, royalty accrual accounting, and IP rights holder reporting.' ;
    rdfs:domain ind:OrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sourceSystemLineRef rdf:type rdf:Property ;
    rdfs:label 'Source System Line Ref' ;
    rdfs:comment 'The native line item identifier from the originating operational system (e.g., Shopify Plus line item ID or SAP S/4HANA SD item number). Enables traceability and reconciliation between the lakehouse silver layer and the system of record.' ;
    rdfs:domain ind:OrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxExempt rdf:type rdf:Property ;
    rdfs:label 'Tax Exempt' ;
    rdfs:comment 'Indicates whether this line item is exempt from sales tax, applicable for wholesale transactions, reseller purchases, or tax-exempt organizations. Supports tax compliance and audit reporting.' ;
    rdfs:domain ind:OrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:unitPrice rdf:type rdf:Property ;
    rdfs:label 'Unit Price' ;
    rdfs:comment 'Listed selling price per single unit of the SKU at the time of order placement, before any line-level discounts or promotions are applied. Expressed in the order currency.' ;
    rdfs:domain ind:Merchandise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:variantDescription rdf:type rdf:Property ;
    rdfs:label 'Variant Description' ;
    rdfs:comment 'Descriptive label for the specific product variant attributes such as size, color, and team affiliation (e.g., \'Red / XL / Chicago Bulls\'). Supports customer-facing order confirmations and returns processing.' ;
    rdfs:domain ind:OrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:warehouseCode rdf:type rdf:Property ;
    rdfs:label 'Warehouse Code' ;
    rdfs:comment 'Reference to the fulfillment warehouse or distribution center assigned to fulfill this line item. Used for inventory allocation, pick-pack-ship operations, and logistics cost attribution.' ;
    rdfs:domain ind:OrderLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryLicensingAthleteAthleteProfileId rdf:type rdf:Property ;
    rdfs:label 'Primary Licensing Athlete Athlete Profile Id' ;
    rdfs:comment 'Reference to the athlete whose NIL (Name Image and Likeness) rights are licensed under this agreement. Populated only when is_nil_agreement is True. Links to the athlete profile in the athlete domain.' ;
    rdfs:domain ind:LicensingAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AthleteProfile .

ind:primaryLicensingFranchiseId rdf:type rdf:Property ;
    rdfs:label 'Primary Licensing Franchise Id' ;
    rdfs:comment 'Reference to the party (league, team, athlete, or rights-holding entity) granting the IP license.' ;
    rdfs:domain ind:LicensingAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Franchise .

ind:advancePayment rdf:type rdf:Property ;
    rdfs:label 'Advance Payment' ;
    rdfs:comment 'Upfront payment made by the licensee to the licensor at agreement execution, typically applied against future royalty obligations (recoupable advance).' ;
    rdfs:domain ind:LicensingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:antiCounterfeitingClause rdf:type rdf:Property ;
    rdfs:label 'Anti Counterfeiting Clause' ;
    rdfs:comment 'Indicates whether the agreement includes specific anti-counterfeiting obligations requiring the licensee to actively monitor and report unauthorized use of licensed IP.' ;
    rdfs:domain ind:LicensingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:auditRequirement rdf:type rdf:Property ;
    rdfs:label 'Audit Requirement' ;
    rdfs:comment 'Specifies the contractually mandated frequency of compliance audits the licensor may conduct on the licensee\'s books and production records to verify royalty accuracy and brand compliance.' ;
    rdfs:domain ind:LicensingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brandComplianceRequired rdf:type rdf:Property ;
    rdfs:label 'Brand Compliance Required' ;
    rdfs:comment 'Indicates whether the licensee is required to submit product samples and artwork for brand compliance review and approval before production. Supports IP (Intellectual Property) protection and brand integrity.' ;
    rdfs:domain ind:Merchandise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:disputeResolution rdf:type rdf:Property ;
    rdfs:label 'Dispute Resolution' ;
    rdfs:comment 'The contractually agreed mechanism for resolving disputes arising under this licensing agreement.' ;
    rdfs:domain ind:LicensingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionChannel rdf:type rdf:Property ;
    rdfs:label 'Distribution Channel' ;
    rdfs:comment 'The sales and distribution channels through which the licensee is authorized to sell licensed merchandise. DTC (Direct-To-Consumer) includes brand-owned online and physical stores. Venue covers in-stadium and arena retail.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:governingLaw rdf:type rdf:Property ;
    rdfs:label 'Governing Law' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the jurisdiction whose laws govern the interpretation and enforcement of this licensing agreement.' ;
    rdfs:domain ind:LicensingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceRequiredAmount rdf:type rdf:Property ;
    rdfs:label 'Insurance Required Amount' ;
    rdfs:comment 'Minimum liability insurance coverage amount the licensee is contractually required to maintain and evidence throughout the agreement term.' ;
    rdfs:domain ind:LicensingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isExclusive rdf:type rdf:Property ;
    rdfs:label 'Is Exclusive' ;
    rdfs:comment 'Indicates whether this licensing agreement grants exclusive rights to the licensee within the defined territory and product category scope. True = exclusive; False = non-exclusive.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isNilAgreement rdf:type rdf:Property ;
    rdfs:label 'Is Nil Agreement' ;
    rdfs:comment 'Indicates whether this licensing agreement covers NIL (Name Image and Likeness) rights for an individual athlete, enabling athlete-branded merchandise production and sale.' ;
    rdfs:domain ind:LicensingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:licensedIpDescription rdf:type rdf:Property ;
    rdfs:label 'Licensed Ip Description' ;
    rdfs:comment 'Narrative description of the specific intellectual property rights granted under this agreement, including team names, logos, player NIL (Name Image and Likeness) rights, trademarks, and other brand assets authorized for use.' ;
    rdfs:domain ind:LicensingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumGuaranteedRoyalty rdf:type rdf:Property ;
    rdfs:label 'Minimum Guaranteed Royalty' ;
    rdfs:comment 'The minimum royalty amount the licensee is contractually obligated to pay the licensor over the agreement term, regardless of actual sales volume. Protects licensor revenue floor.' ;
    rdfs:domain ind:LicensingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nextAuditDate rdf:type rdf:Property ;
    rdfs:label 'Next Audit Date' ;
    rdfs:comment 'The scheduled date for the next compliance audit of the licensee under this agreement, based on the audit_requirement frequency.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:royaltyRatePct rdf:type rdf:Property ;
    rdfs:label 'Royalty Rate Pct' ;
    rdfs:comment 'The contractually agreed royalty rate expressed as a percentage of net sales that the licensee must remit to the licensor for each unit of licensed merchandise sold.' ;
    rdfs:domain ind:Merchandise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:royaltyReportingFrequency rdf:type rdf:Property ;
    rdfs:label 'Royalty Reporting Frequency' ;
    rdfs:comment 'The contractually required frequency at which the licensee must submit royalty statements and remit royalty payments to the licensor.' ;
    rdfs:domain ind:LicensingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sellOffPeriodDays rdf:type rdf:Property ;
    rdfs:label 'Sell Off Period Days' ;
    rdfs:comment 'Number of calendar days after agreement expiration or termination during which the licensee is permitted to sell existing inventory of licensed merchandise before all sales must cease.' ;
    rdfs:domain ind:LicensingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sublicensingPermitted rdf:type rdf:Property ;
    rdfs:label 'Sublicensing Permitted' ;
    rdfs:comment 'Indicates whether the licensee is contractually permitted to sublicense the IP rights to third-party manufacturers or distributors.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:terminationNoticeDays rdf:type rdf:Property ;
    rdfs:label 'Termination Notice Days' ;
    rdfs:comment 'Number of calendar days of advance written notice required by either party to terminate the agreement for convenience, as specified in the contract.' ;
    rdfs:domain ind:LicensingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:territoryDescription rdf:type rdf:Property ;
    rdfs:label 'Territory Description' ;
    rdfs:comment 'Narrative description of the authorized sales and distribution territory when the territory spans multiple countries or requires specific regional clarification beyond the primary territory code.' ;
    rdfs:domain ind:LicensingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:royaltyPaymentId rdf:type rdf:Property ;
    rdfs:label 'Royalty Payment Id' ;
    rdfs:comment 'Unique surrogate identifier for each royalty payment record in the merchandise licensing domain. Primary key for the royalty_payment data product.' ;
    rdfs:domain ind:RoyaltyPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:advanceOffsetAmount rdf:type rdf:Property ;
    rdfs:label 'Advance Offset Amount' ;
    rdfs:comment 'Amount of previously paid royalty advance applied as an offset against the current period royalty due. Reduces the net royalty payable when an advance has been recouped against earned royalties.' ;
    rdfs:domain ind:RoyaltyPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:auditFlag rdf:type rdf:Property ;
    rdfs:label 'Audit Flag' ;
    rdfs:comment 'Indicates whether this royalty payment record is currently subject to a licensor-initiated audit under contractual audit rights provisions. True = under audit; False = not under audit.' ;
    rdfs:domain ind:RoyaltyPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cbaComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Cba Compliance Flag' ;
    rdfs:comment 'Indicates whether this royalty payment satisfies all applicable CBA (Collective Bargaining Agreement) reporting and payment obligations for the period. True = compliant; False = non-compliant or pending review.' ;
    rdfs:domain ind:RoyaltyPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:disputeResolutionDate rdf:type rdf:Property ;
    rdfs:label 'Dispute Resolution Date' ;
    rdfs:comment 'Date on which a royalty dispute was formally resolved between the licensee and licensor. Null if no dispute exists or if dispute is still open. Used to track dispute lifecycle and SLA compliance.' ;
    rdfs:domain ind:RoyaltyPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:grossSalesAmount rdf:type rdf:Property ;
    rdfs:label 'Gross Sales Amount' ;
    rdfs:comment 'Total gross sales revenue from licensed merchandise for the reporting period, before any deductions, returns, or allowances. Serves as the royalty base for rate application. Sourced from Shopify Plus e-commerce and POS transaction data.' ;
    rdfs:domain ind:RoyaltyPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ipRightsType rdf:type rdf:Property ;
    rdfs:label 'Ip Rights Type' ;
    rdfs:comment 'Type of intellectual property rights being licensed and generating the royalty obligation. Distinguishes trademark (team/league marks), copyright (creative works), NIL (Name Image and Likeness for athletes), likeness rights, logo rights, or patent rights.' ;
    rdfs:domain ind:RoyaltyPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licensorAcceptanceDate rdf:type rdf:Property ;
    rdfs:label 'Licensor Acceptance Date' ;
    rdfs:comment 'Date on which the licensor formally accepted the royalty report and payment amount for the reporting period. Null if not yet accepted or if disputed.' ;
    rdfs:domain ind:RoyaltyPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:licensorType rdf:type rdf:Property ;
    rdfs:label 'Licensor Type' ;
    rdfs:comment 'Classification of the IP rights holder receiving the royalty payment. Distinguishes between league-level IP (e.g., NFL, NBA, FIFA), team IP, individual athlete NIL (Name Image and Likeness) rights, player association collective rights, or event-specific IP.' ;
    rdfs:domain ind:RoyaltyPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumGuaranteeAmount rdf:type rdf:Property ;
    rdfs:label 'Minimum Guarantee Amount' ;
    rdfs:comment 'Contractual minimum royalty amount guaranteed to the licensor for the reporting period, regardless of actual sales performance. If royalty_due_amount is less than this value, the minimum guarantee applies.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netRoyaltyPaidAmount rdf:type rdf:Property ;
    rdfs:label 'Net Royalty Paid Amount' ;
    rdfs:comment 'Final net amount actually disbursed to the licensor after applying minimum guarantees, advance offsets, and adjustments. This is the monetary triplet net total for the royalty payment transaction.' ;
    rdfs:domain ind:RoyaltyPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netSalesAmount rdf:type rdf:Property ;
    rdfs:label 'Net Sales Amount' ;
    rdfs:comment 'Net sales amount after deducting returns and allowances from gross sales. Represents the contractually defined royalty base upon which the royalty rate is applied to calculate royalty due.' ;
    rdfs:domain ind:RoyaltyPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reportSubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Report Submission Date' ;
    rdfs:comment 'Date on which the royalty report for the period was formally submitted to the licensor. Used to verify compliance with contractual reporting deadlines and to support licensor audit rights.' ;
    rdfs:domain ind:RoyaltyPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reportSubmissionStatus rdf:type rdf:Property ;
    rdfs:label 'Report Submission Status' ;
    rdfs:comment 'Status of the royalty report submitted to the licensor for the reporting period. Tracks whether the report is in draft, has been formally submitted, accepted by the licensor, disputed, or is overdue per contractual deadlines.' ;
    rdfs:domain ind:RoyaltyPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Reporting Period End Date' ;
    rdfs:comment 'Last day of the sales reporting period covered by this royalty calculation. Together with reporting_period_start_date defines the window of licensed merchandise sales subject to royalty.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reportingPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Reporting Period Start Date' ;
    rdfs:comment 'First day of the sales reporting period covered by this royalty calculation, typically aligned to a calendar quarter, fiscal period, or CBA-defined reporting cycle.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:returnsAllowancesAmount rdf:type rdf:Property ;
    rdfs:label 'Returns Allowances Amount' ;
    rdfs:comment 'Total value of merchandise returns and trade allowances deducted from gross sales to arrive at net royalty base. Includes customer returns, damaged goods credits, and promotional allowances per licensing agreement terms.' ;
    rdfs:domain ind:RoyaltyPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:royaltyDueAmount rdf:type rdf:Property ;
    rdfs:label 'Royalty Due Amount' ;
    rdfs:comment 'Calculated royalty amount due to the licensor, derived by applying the royalty rate to net sales. Represents the gross royalty obligation before adjustments, minimum guarantees, or advance offsets.' ;
    rdfs:domain ind:RoyaltyPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fulfillmentShipmentId rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Shipment Id' ;
    rdfs:comment 'Unique surrogate identifier for each outbound fulfillment shipment record in the merchandise domain. Primary key for the fulfillment_shipment data product.' ;
    rdfs:domain ind:Merchandise ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FulfillmentShipment .

ind:pickupFacilityId rdf:type rdf:Property ;
    rdfs:label 'Pickup Facility Id' ;
    rdfs:comment 'Foreign key linking to venue.facility. Business justification: Will-call and venue-pickup merchandise fulfillment requires recording the specific facility where fans collect orders on event day. Venue operations staff use this to manage will-call queues and recon' ;
    rdfs:domain ind:FulfillmentShipment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Facility .

ind:primaryFulfillmentFanFanProfileId rdf:type rdf:Property ;
    rdfs:label 'Primary Fulfillment Fan Fan Profile Id' ;
    rdfs:comment 'Reference to the fan or end customer who is the recipient of this shipment. Supports fan delivery experience management and CRM integration via Salesforce CRM.' ;
    rdfs:domain ind:FulfillmentShipment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FanProfile .

ind:carrierServiceLevel rdf:type rdf:Property ;
    rdfs:label 'Carrier Service Level' ;
    rdfs:comment 'Specific service tier selected for this shipment (e.g., Ground, 2-Day, Overnight, International Priority). Determines transit time commitment and cost. Used for SLA compliance analysis.' ;
    rdfs:domain ind:FulfillmentShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customsDeclarationNumber rdf:type rdf:Property ;
    rdfs:label 'Customs Declaration Number' ;
    rdfs:comment 'Official customs declaration or harmonized tariff reference number assigned for international shipments. Required for cross-border compliance and import/export regulatory reporting.' ;
    rdfs:domain ind:FulfillmentShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:declaredCustomsValue rdf:type rdf:Property ;
    rdfs:label 'Declared Customs Value' ;
    rdfs:comment 'The declared monetary value of the shipment contents for customs purposes on international orders. Used to determine applicable duties, taxes, and import thresholds.' ;
    rdfs:domain ind:FulfillmentShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Estimated Delivery Date' ;
    rdfs:comment 'The carrier-committed or system-calculated date by which the parcel is expected to arrive at the fan destination. Used for SLA compliance monitoring and fan communication.' ;
    rdfs:domain ind:FulfillmentShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fulfillmentType rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Type' ;
    rdfs:comment 'Indicates the operational model used to fulfill this shipment: warehouse pick-and-pack, venue store dispatch, drop-ship from supplier, or third-party logistics (3PL) provider.' ;
    rdfs:domain ind:FulfillmentShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isPartialFulfillment rdf:type rdf:Property ;
    rdfs:label 'Is Partial Fulfillment' ;
    rdfs:comment 'Indicates whether this shipment represents a partial fulfillment of the associated order (True) or a complete fulfillment (False). Relevant when orders contain multiple SKUs fulfilled in separate shipments.' ;
    rdfs:domain ind:FulfillmentShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:labelCreatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Label Created Timestamp' ;
    rdfs:comment 'The precise date and time when the shipping label was generated in the fulfillment system. Marks the start of the shipment lifecycle and is used for warehouse throughput analysis.' ;
    rdfs:domain ind:FulfillmentShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lengthCm rdf:type rdf:Property ;
    rdfs:label 'Length Cm' ;
    rdfs:comment 'Length dimension of the shipment package in centimetres. Combined with width and height for dimensional weight (DIM weight) calculation used in carrier billing.' ;
    rdfs:domain ind:FulfillmentShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lineSequence rdf:type rdf:Property ;
    rdfs:label 'Line Sequence' ;
    rdfs:comment 'Sequential position of this order line within the shipment packing manifest. Used by warehouse pick/pack operations to order items within a shipment for efficient picking. Belongs to the shipment-line intersection, not to the shipment or order line alone.' ;
    rdfs:domain ind:FulfillmentShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:packageCount rdf:type rdf:Property ;
    rdfs:label 'Package Count' ;
    rdfs:comment 'Number of individual packages or parcels included in this shipment. Supports multi-box shipment tracking and carrier billing reconciliation.' ;
    rdfs:domain ind:FulfillmentShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pickTimestamp rdf:type rdf:Property ;
    rdfs:label 'Pick Timestamp' ;
    rdfs:comment 'The precise date and time when this specific order line item was physically picked from inventory for inclusion in this shipment. Belongs to the pick event at the intersection of shipment and line — not to the shipment (which has a ship_date) nor to the order line (which has no pick timing).' ;
    rdfs:domain ind:FulfillmentShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:quantityShipped rdf:type rdf:Property ;
    rdfs:label 'Quantity Shipped' ;
    rdfs:comment 'Number of units of this order line packed into this specific shipment. Critical for partial fulfillment scenarios where an order line is split across multiple shipments — belongs to the shipment-line intersection, not to either entity alone.' ;
    rdfs:domain ind:FulfillmentShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recipientEmail rdf:type rdf:Property ;
    rdfs:label 'Recipient Email' ;
    rdfs:comment 'Email address of the shipment recipient used for carrier tracking notifications and delivery confirmation communications. Classified as PII per GDPR and CCPA.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recipientName rdf:type rdf:Property ;
    rdfs:label 'Recipient Name' ;
    rdfs:comment 'Full name of the individual designated to receive the shipment as captured at order time. Required for carrier label generation and delivery confirmation. Classified as PII per GDPR and CCPA.' ;
    rdfs:domain ind:FulfillmentShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recipientPhone rdf:type rdf:Property ;
    rdfs:label 'Recipient Phone' ;
    rdfs:comment 'Phone number of the shipment recipient used for carrier delivery notifications and failed delivery contact. Classified as PII per GDPR and CCPA.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiresSignature rdf:type rdf:Property ;
    rdfs:label 'Requires Signature' ;
    rdfs:comment 'Indicates whether a recipient signature is required upon delivery (True). Typically applied to high-value merchandise, limited-edition memorabilia, or VIP fan orders.' ;
    rdfs:domain ind:FulfillmentShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:returnTrackingNumber rdf:type rdf:Property ;
    rdfs:label 'Return Tracking Number' ;
    rdfs:comment 'Carrier tracking number assigned for the return shipment if the fan initiates a return or the delivery fails. Supports reverse logistics tracking and merchandise returns processing.' ;
    rdfs:domain ind:FulfillmentShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipDate rdf:type rdf:Property ;
    rdfs:label 'Ship Date' ;
    rdfs:comment 'The calendar date on which the shipment was physically handed off to the carrier. Used as the baseline for SLA delivery window calculations and carrier performance reporting.' ;
    rdfs:domain ind:FulfillmentShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:shipmentNumber rdf:type rdf:Property ;
    rdfs:label 'Shipment Number' ;
    rdfs:comment 'Externally visible business identifier for this shipment, used in customer-facing communications, packing slips, and carrier handoff documentation. Distinct from the internal surrogate key.' ;
    rdfs:domain ind:FulfillmentShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipmentStatus rdf:type rdf:Property ;
    rdfs:label 'Shipment Status' ;
    rdfs:comment 'Current lifecycle state of the shipment as reported by the carrier or fulfillment system. Drives fan-facing delivery notifications and DTC SLA tracking. [ENUM-REF-CANDIDATE: pending|label_created|in_transit|out_for_delivery|delivered|failed|returned|cancelled — promote to reference product]' ;
    rdfs:domain ind:FulfillmentShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shippedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Shipped Timestamp' ;
    rdfs:comment 'The precise date and time when the shipment was confirmed as dispatched and handed to the carrier. Used for SLA measurement and fulfillment lead time analytics.' ;
    rdfs:domain ind:FulfillmentShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:shippingAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Shipping Address Line1' ;
    rdfs:comment 'Primary street address line of the fan delivery destination. Required for carrier label generation. Classified as PII per GDPR and CCPA.' ;
    rdfs:domain ind:FulfillmentShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shippingAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Shipping Address Line2' ;
    rdfs:comment 'Secondary address line (apartment, suite, unit number) for the fan delivery destination. Classified as PII per GDPR and CCPA.' ;
    rdfs:domain ind:FulfillmentShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shippingCity rdf:type rdf:Property ;
    rdfs:label 'Shipping City' ;
    rdfs:comment 'City of the fan delivery destination. Used for geographic delivery analytics and carrier zone determination. Classified as PII per GDPR and CCPA.' ;
    rdfs:domain ind:FulfillmentShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shippingCost rdf:type rdf:Property ;
    rdfs:label 'Shipping Cost' ;
    rdfs:comment 'Actual cost charged by the carrier for transporting this shipment, in the operating currency. Used for fulfillment cost analysis, margin reporting, and carrier contract performance evaluation.' ;
    rdfs:domain ind:FulfillmentShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shippingCostChargedToFan rdf:type rdf:Property ;
    rdfs:label 'Shipping Cost Charged To Fan' ;
    rdfs:comment 'The shipping fee amount collected from the fan at checkout. May differ from the actual carrier cost due to flat-rate shipping promotions, free shipping thresholds, or subsidized DTC shipping programs.' ;
    rdfs:domain ind:FulfillmentShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shippingCostCurrency rdf:type rdf:Property ;
    rdfs:label 'Shipping Cost Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the shipping cost amount (e.g., USD, GBP, EUR). Required for multi-currency international fulfillment operations.' ;
    rdfs:domain ind:FulfillmentShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shippingStateProvince rdf:type rdf:Property ;
    rdfs:label 'Shipping State Province' ;
    rdfs:comment 'State or province of the fan delivery destination. Used for carrier zone pricing, tax jurisdiction determination, and regional fulfillment analytics.' ;
    rdfs:domain ind:FulfillmentShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shopifyFulfillmentCode rdf:type rdf:Property ;
    rdfs:label 'Shopify Fulfillment Code' ;
    rdfs:comment 'External fulfillment identifier assigned by Shopify Plus at the time the fulfillment record is created. Used to reconcile shipment records with the Shopify Plus e-commerce platform and DTC fulfillment workflows.' ;
    rdfs:domain ind:FulfillmentShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaBreach rdf:type rdf:Property ;
    rdfs:label 'Sla Breach' ;
    rdfs:comment 'Indicates whether this shipment breached the committed delivery SLA (True), meaning actual_delivery_date exceeded estimated_delivery_date. Used for DTC fulfillment SLA KPI reporting and carrier performance management.' ;
    rdfs:domain ind:FulfillmentShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:trackingNumber rdf:type rdf:Property ;
    rdfs:label 'Tracking Number' ;
    rdfs:comment 'Carrier-assigned tracking number provided at the time of shipment handoff. Used by fans and operations teams to monitor parcel transit status via the carrier portal. Supports DTC SLA tracking.' ;
    rdfs:domain ind:Merchandise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:widthCm rdf:type rdf:Property ;
    rdfs:label 'Width Cm' ;
    rdfs:comment 'Width dimension of the shipment package in centimetres. Used in dimensional weight calculation for carrier billing and packaging optimization.' ;
    rdfs:domain ind:FulfillmentShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:returnRequestId rdf:type rdf:Property ;
    rdfs:label 'Return Request Id' ;
    rdfs:comment 'Unique system-generated identifier for the merchandise return or exchange request record in the Silver Layer lakehouse.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ReturnRequest .

ind:primaryReturnCustomerFanProfileId rdf:type rdf:Property ;
    rdfs:label 'Primary Return Customer Fan Profile Id' ;
    rdfs:comment 'Identifier of the fan or customer who submitted the return request. Used for CRM tracking, return history analysis, and loyalty program impact assessment.' ;
    rdfs:domain ind:ReturnRequest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FanProfile .

ind:primaryReturnFranchiseId rdf:type rdf:Property ;
    rdfs:label 'Primary Return Franchise Id' ;
    rdfs:comment 'Reference to the sports team whose licensed merchandise is being returned. Used for royalty reversal tracking, licensing compliance, and team-level return rate analytics.' ;
    rdfs:domain ind:ReturnRequest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Franchise .

ind:primaryReturnOriginalOrderMerchOrderId rdf:type rdf:Property ;
    rdfs:label 'Primary Return Original Order Merch Order Id' ;
    rdfs:comment 'Reference to the original merchandise sales order from which the items being returned were purchased. Links the return to the originating transaction for refund calculation and inventory reconciliation.' ;
    rdfs:domain ind:ReturnRequest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MerchOrder .

ind:primaryReturnSkuCatalogId rdf:type rdf:Property ;
    rdfs:label 'Primary Return Sku Catalog Id' ;
    rdfs:comment 'Reference to the specific merchandise SKU being returned. Links to the product master catalog for item identification, inventory restock eligibility, and licensing compliance validation.' ;
    rdfs:domain ind:ReturnRequest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SkuCatalog .

ind:tertiaryReturnMerchOrderId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Return Merch Order Id' ;
    rdfs:comment 'Identifier of the original Point of Sale transaction from which the returned item was purchased. Populated for POS-channel returns; used for in-store reconciliation and receipt validation.' ;
    rdfs:domain ind:ReturnRequest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MerchOrder .

ind:carrierName rdf:type rdf:Property ;
    rdfs:label 'Carrier Name' ;
    rdfs:comment 'Name of the shipping carrier used for mail-in returns (e.g., UPS, FedEx, USPS, DHL). Populated for mail-in return method; used for reverse logistics tracking.' ;
    rdfs:domain ind:ReturnRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerEmail rdf:type rdf:Property ;
    rdfs:label 'Customer Email' ;
    rdfs:comment 'Email address of the customer associated with the return request, captured at the time of submission for communication and notification purposes. Subject to GDPR and CCPA data privacy regulations.' ;
    rdfs:domain ind:ReturnRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ipComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Ip Compliance Flag' ;
    rdfs:comment 'Indicates whether the returned item has been flagged for potential IP, counterfeit, or brand compliance concerns. Triggers escalation to the licensing and IP protection team for investigation.' ;
    rdfs:domain ind:ReturnRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:itemCondition rdf:type rdf:Property ;
    rdfs:label 'Item Condition' ;
    rdfs:comment 'Physical condition of the merchandise item as assessed upon receipt of the return. Determines restock eligibility, supplier chargeback applicability, and IP/brand compliance escalation.' ;
    rdfs:domain ind:ReturnRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyException rdf:type rdf:Property ;
    rdfs:label 'Policy Exception' ;
    rdfs:comment 'Indicates whether this return request was approved as an exception to the standard merchandise returns policy (e.g., outside return window, non-returnable item category). Requires manager authorization.' ;
    rdfs:domain ind:ReturnRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:policyExceptionReason rdf:type rdf:Property ;
    rdfs:label 'Policy Exception Reason' ;
    rdfs:comment 'Narrative explanation for why a policy exception was granted on this return request. Populated only when policy_exception is True. Required for audit and compliance review.' ;
    rdfs:domain ind:ReturnRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:posTransactionReference rdf:type rdf:Property ;
    rdfs:label 'Pos Transaction Reference' ;
    rdfs:comment 'Identifier of the original Point of Sale transaction from which the returned item was purchased. Populated for POS-channel returns; used for in-store reconciliation and receipt validation.' ;
    rdfs:domain ind:ReturnRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestDate rdf:type rdf:Property ;
    rdfs:label 'Request Date' ;
    rdfs:comment 'Calendar date on which the customer submitted the return or exchange request. Used for return window eligibility validation against the merchandise returns policy.' ;
    rdfs:domain ind:ReturnRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requestStatus rdf:type rdf:Property ;
    rdfs:label 'Request Status' ;
    rdfs:comment 'Current lifecycle state of the return request workflow. Drives omnichannel returns policy enforcement and reverse logistics tracking. [ENUM-REF-CANDIDATE: pending|approved|rejected|in_transit|received|resolved|cancelled — promote to reference product]' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestTimestamp rdf:type rdf:Property ;
    rdfs:label 'Request Timestamp' ;
    rdfs:comment 'Precise date and time (with timezone offset) when the return request was submitted by the customer. Serves as the principal business event timestamp for SLA measurement and omnichannel audit trails.' ;
    rdfs:domain ind:ReturnRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:resolutionDate rdf:type rdf:Property ;
    rdfs:label 'Resolution Date' ;
    rdfs:comment 'Date on which the return request was fully resolved (refund issued, exchange dispatched, or store credit applied). Used for SLA compliance measurement and customer satisfaction reporting.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionType rdf:type rdf:Property ;
    rdfs:label 'Resolution Type' ;
    rdfs:comment 'Customer-requested or business-approved resolution outcome for the return request. Drives downstream refund processing, exchange order creation, or store credit issuance workflows.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restockEligible rdf:type rdf:Property ;
    rdfs:label 'Restock Eligible' ;
    rdfs:comment 'Indicates whether the returned merchandise item is eligible to be restocked and resold. Determined by item condition assessment and licensing compliance check.' ;
    rdfs:domain ind:ReturnRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:restockingFee rdf:type rdf:Property ;
    rdfs:label 'Restocking Fee' ;
    rdfs:comment 'Fee deducted from the refund amount to cover handling and restocking costs, applied per the merchandise returns policy. May be zero for defective or mis-shipped items.' ;
    rdfs:domain ind:ReturnRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:returnChannel rdf:type rdf:Property ;
    rdfs:label 'Return Channel' ;
    rdfs:comment 'The omnichannel sales channel through which the original purchase was made and/or the return is being processed. Supports channel-specific returns policy enforcement and reverse logistics routing.' ;
    rdfs:domain ind:ReturnRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnMethod rdf:type rdf:Property ;
    rdfs:label 'Return Method' ;
    rdfs:comment 'Physical method by which the customer is returning the merchandise item(s). Determines reverse logistics workflow, carrier label generation, and processing location assignment.' ;
    rdfs:domain ind:ReturnRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnReasonCode rdf:type rdf:Property ;
    rdfs:label 'Return Reason Code' ;
    rdfs:comment 'Standardized reason code selected by the customer or agent explaining why the merchandise is being returned. Used for quality analytics, supplier chargebacks, and brand compliance reporting. [ENUM-REF-CANDIDATE: defective|wrong_item|wrong_size|not_as_described|damaged_in_transit|changed_mind|duplicate_order|counterfeit_suspected — promote to reference product]' ;
    rdfs:domain ind:ReturnRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnReasonNotes rdf:type rdf:Property ;
    rdfs:label 'Return Reason Notes' ;
    rdfs:comment 'Free-text narrative provided by the customer or customer service agent elaborating on the reason for return. Supplements the standardized return_reason_code with contextual detail for quality review.' ;
    rdfs:domain ind:ReturnRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnWindowEligible rdf:type rdf:Property ;
    rdfs:label 'Return Window Eligible' ;
    rdfs:comment 'Indicates whether the return request was submitted within the allowable return window defined by the merchandise returns policy. Drives automated approval or escalation routing.' ;
    rdfs:domain ind:ReturnRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rmaNumber rdf:type rdf:Property ;
    rdfs:label 'Rma Number' ;
    rdfs:comment 'Externally-visible Return Merchandise Authorization number issued to the customer as proof of approved return. Used across omnichannel touchpoints (Shopify Plus, POS, venue stores) to track the return through reverse logistics.' ;
    rdfs:domain ind:ReturnRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shopifyReturnCode rdf:type rdf:Property ;
    rdfs:label 'Shopify Return Code' ;
    rdfs:comment 'Native return identifier assigned by Shopify Plus for e-commerce channel returns. Used for system-of-record reconciliation between the lakehouse Silver Layer and the Shopify Plus operational platform.' ;
    rdfs:domain ind:ReturnRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryPriceEventFixtureId rdf:type rdf:Property ;
    rdfs:label 'Primary Price Event Fixture Id' ;
    rdfs:comment 'Reference to the specific sports or entertainment event (e.g., championship game, concert, playoff) that triggers event-day or championship launch pricing. Null for non-event-specific price lists.' ;
    rdfs:domain ind:PriceList ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Fixture .

ind:primaryPriceSkuCatalogId rdf:type rdf:Property ;
    rdfs:label 'Primary Price Sku Catalog Id' ;
    rdfs:comment 'Reference to the specific merchandise SKU to which this price list entry applies. Null when the price list applies to an entire product category or all SKUs within a campaign scope.' ;
    rdfs:domain ind:PriceList ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SkuCatalog .

ind:basePrice rdf:type rdf:Property ;
    rdfs:label 'Base Price' ;
    rdfs:comment 'The standard unit price (MSRP or list price) for merchandise SKUs under this price list, expressed in the designated currency. This is the principal quantitative pricing fact before any discounts or promotions are applied.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:discountType rdf:type rdf:Property ;
    rdfs:label 'Discount Type' ;
    rdfs:comment 'The mechanism by which the promotional discount is applied: percentage (% off base price), fixed_amount (flat dollar reduction), bogo (Buy One Get One), free_shipping (shipping waiver), bundle (multi-SKU deal price), loyalty_points (fan loyalty reward redemption). Null for non-promotional price lists.' ;
    rdfs:domain ind:PriceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discountValue rdf:type rdf:Property ;
    rdfs:label 'Discount Value' ;
    rdfs:comment 'The magnitude of the discount: a percentage (0–100) for percentage-type discounts, or a fixed monetary amount for fixed_amount-type discounts. Interpreted in conjunction with discount_type.' ;
    rdfs:domain ind:Merchandise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:geographicScope rdf:type rdf:Property ;
    rdfs:label 'Geographic Scope' ;
    rdfs:comment 'Pipe-delimited list of ISO 3166-1 alpha-3 country codes defining the geographic markets where this price list is valid (e.g., \'USA|CAN|GBR\'). Supports global merchandise operations and regional pricing compliance.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCombinable rdf:type rdf:Property ;
    rdfs:label 'Is Combinable' ;
    rdfs:comment 'Indicates whether this price list or promotional discount may be combined with other active promotions in the same transaction. False enforces exclusivity (e.g., championship launch pricing cannot stack with loyalty discounts).' ;
    rdfs:domain ind:Merchandise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isLoyaltyRedemption rdf:type rdf:Property ;
    rdfs:label 'Is Loyalty Redemption' ;
    rdfs:comment 'Indicates whether this price list entry is redeemable via fan loyalty reward points rather than direct monetary payment. Supports fan loyalty reward redemption tracking.' ;
    rdfs:domain ind:PriceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:listStatus rdf:type rdf:Property ;
    rdfs:label 'List Status' ;
    rdfs:comment 'Current lifecycle state of the price list: draft (under configuration), active (live and applicable), scheduled (approved but not yet effective), expired (past effective_end_date), suspended (temporarily disabled), archived (retired from use).' ;
    rdfs:domain ind:PriceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loyaltyPointsRequired rdf:type rdf:Property ;
    rdfs:label 'Loyalty Points Required' ;
    rdfs:comment 'Number of fan loyalty reward points required to redeem this price list offer. Applicable only when is_loyalty_redemption is True. Null for non-loyalty price lists.' ;
    rdfs:domain ind:PriceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minOrderQuantity rdf:type rdf:Property ;
    rdfs:label 'Min Order Quantity' ;
    rdfs:comment 'Minimum number of SKU units that must be included in a transaction for this price list to be applicable. Used for wholesale bulk pricing and bundle deal qualification.' ;
    rdfs:domain ind:PriceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minOrderValue rdf:type rdf:Property ;
    rdfs:label 'Min Order Value' ;
    rdfs:comment 'Minimum transaction value (in the price list currency) required to qualify for this price list or promotional discount. Used for free shipping thresholds and tiered promotional offers.' ;
    rdfs:domain ind:PriceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumAdvertisedPrice rdf:type rdf:Property ;
    rdfs:label 'Minimum Advertised Price' ;
    rdfs:comment 'The lowest price at which merchandise may be advertised per licensing and brand compliance agreements. Enforced across all channels to protect brand integrity and licensor relationships.' ;
    rdfs:domain ind:PriceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:perCustomerUsageLimit rdf:type rdf:Property ;
    rdfs:label 'Per Customer Usage Limit' ;
    rdfs:comment 'Maximum number of times a single customer may redeem this promotional price list or promo code. Prevents abuse of fan loyalty and event-day promotions.' ;
    rdfs:domain ind:PriceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:priceListCode rdf:type rdf:Property ;
    rdfs:label 'Price List Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying this price list across systems (Shopify Plus, SAP SD, POS). Used as the business key for cross-system reconciliation.' ;
    rdfs:domain ind:PriceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceListName rdf:type rdf:Property ;
    rdfs:label 'Price List Name' ;
    rdfs:comment 'Human-readable name of the price list (e.g., \'Championship Launch MSRP 2025\', \'VIP Member Wholesale Spring\', \'Event-Day GA Promo\'). Used in Shopify Plus and POS displays.' ;
    rdfs:domain ind:PriceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceListType rdf:type rdf:Property ;
    rdfs:label 'Price List Type' ;
    rdfs:comment 'Classification of the price list by its commercial purpose: base (standard MSRP), wholesale (B2B/retailer), vip_member (fan loyalty tier), promotional (campaign-driven discount), event_day (championship or game-day launch), clearance (end-of-season markdown). [ENUM-REF-CANDIDATE: base|wholesale|vip_member|promotional|event_day|clearance — promote to reference product if additional types emerge]' ;
    rdfs:domain ind:PriceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promoCodeRedemptionCount rdf:type rdf:Property ;
    rdfs:label 'Promo Code Redemption Count' ;
    rdfs:comment 'Running count of the number of times this promotional code has been successfully redeemed. Used for campaign performance tracking and budget burn monitoring.' ;
    rdfs:domain ind:PriceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:promoCodeUsageLimit rdf:type rdf:Property ;
    rdfs:label 'Promo Code Usage Limit' ;
    rdfs:comment 'Maximum total number of times this promotional code may be redeemed across all customers. Null indicates unlimited usage. Used to control promotional budget exposure.' ;
    rdfs:domain ind:PriceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sapConditionRecordCode rdf:type rdf:Property ;
    rdfs:label 'Sap Condition Record Code' ;
    rdfs:comment 'The condition record number (KNUMH) from SAP S/4HANA SD pricing configuration corresponding to this price list entry. Enables traceability back to the ERP pricing master.' ;
    rdfs:domain ind:PriceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shopifyPriceListCode rdf:type rdf:Property ;
    rdfs:label 'Shopify Price List Code' ;
    rdfs:comment 'The native price list identifier assigned by Shopify Plus for this record. Used for cross-system reconciliation between the lakehouse silver layer and the Shopify Plus e-commerce platform.' ;
    rdfs:domain ind:PriceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxClass rdf:type rdf:Property ;
    rdfs:label 'Tax Class' ;
    rdfs:comment 'Tax classification applicable to merchandise sold under this price list, determining the VAT/sales tax treatment at point of sale. Aligns with SAP SD tax condition types.' ;
    rdfs:domain ind:PriceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wholesalePrice rdf:type rdf:Property ;
    rdfs:label 'Wholesale Price' ;
    rdfs:comment 'The unit price offered to licensed wholesale partners and third-party retailers for bulk merchandise orders. Null when price list type is not wholesale or B2B.' ;
    rdfs:domain ind:PriceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:promotionAssociatedLeagueId rdf:type rdf:Property ;
    rdfs:label 'Promotion Associated League Id' ;
    rdfs:comment 'Reference to the professional league or competition (e.g., NFL, NBA, MLS) whose licensed merchandise is covered by this promotion. Supports league-specific licensing compliance and royalty tracking.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:League .

ind:promotionLeagueId rdf:type rdf:Property ;
    rdfs:label 'Promotion League Id' ;
    rdfs:comment 'Reference to the professional league or competition (e.g., NFL, NBA, MLS) whose licensed merchandise is covered by this promotion. Supports league-specific licensing compliance and royalty tracking.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:League .

ind:applicableScope rdf:type rdf:Property ;
    rdfs:label 'Applicable Scope' ;
    rdfs:comment 'Defines the breadth of merchandise to which the promotion applies: all_products (entire catalog), specific_skus (individual SKU-level targeting), specific_categories (e.g., apparel, headwear), specific_collections (e.g., championship collection), or entire_order (applied to the full cart value).' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedDate rdf:type rdf:Property ;
    rdfs:label 'Approved Date' ;
    rdfs:comment 'Calendar date on which the promotion received final business and brand compliance approval. Distinct from the promotion start_date. Required for SOX audit trails and promotional governance.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:bogoBuyQuantity rdf:type rdf:Property ;
    rdfs:label 'Bogo Buy Quantity' ;
    rdfs:comment 'For Buy One Get One (BOGO) promotion types, the number of items the customer must purchase to qualify for the free or discounted item(s). Null for non-BOGO promotion types.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bogoGetQuantity rdf:type rdf:Property ;
    rdfs:label 'Bogo Get Quantity' ;
    rdfs:comment 'For Buy One Get One (BOGO) promotion types, the number of items the customer receives free or at a discounted price after meeting the bogo_buy_quantity threshold. Null for non-BOGO promotion types.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:discountValueType rdf:type rdf:Property ;
    rdfs:label 'Discount Value Type' ;
    rdfs:comment 'Specifies the unit of measure for the discount_value field: percentage (proportion of item price), fixed_amount (absolute currency deduction), or free (item/shipping provided at no cost). Enables correct calculation logic in Shopify Plus and POS systems.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventTrigger rdf:type rdf:Property ;
    rdfs:label 'Event Trigger' ;
    rdfs:comment 'Business event that triggers or is associated with this promotion. Captures the sports-entertainment context: none (standard promotion), game_day (active on event day), championship_win (post-championship merchandise launch), playoff_entry, season_opener, concert_event, or anniversary. Enables event-driven promotion activation workflows. [ENUM-REF-CANDIDATE: none|game_day|championship_win|playoff_entry|season_opener|concert_event|anniversary — promote to reference product if additional triggers emerge]' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:freeShippingThreshold rdf:type rdf:Property ;
    rdfs:label 'Free Shipping Threshold' ;
    rdfs:comment 'Minimum order subtotal (in promotion currency) required to qualify for free shipping when promotion_type is \'free_shipping\'. Null for non-shipping promotions or promotions with no spend threshold for free shipping.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:geographicRestriction rdf:type rdf:Property ;
    rdfs:label 'Geographic Restriction' ;
    rdfs:comment 'Comma-delimited list of ISO 3166-1 alpha-3 country codes where this promotion is valid. Null indicates no geographic restriction (global). Required for international licensing compliance and GDPR/CCPA-compliant targeted promotions in EU and California markets.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ipLicenseRequired rdf:type rdf:Property ;
    rdfs:label 'Ip License Required' ;
    rdfs:comment 'Indicates whether the merchandise covered by this promotion requires a valid Intellectual Property (IP) licensing agreement (e.g., team logo, league trademark). True = IP license verification required before promotion activation; False = no IP licensing constraint. Supports brand compliance and IP protection obligations.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isAutoApply rdf:type rdf:Property ;
    rdfs:label 'Is Auto Apply' ;
    rdfs:comment 'Indicates whether the promotion is automatically applied to qualifying carts without requiring the customer to enter a promo code. True = automatic discount; False = requires promo_code entry. Supports seamless event-day fan experience promotions.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:loyaltyPointsCost rdf:type rdf:Property ;
    rdfs:label 'Loyalty Points Cost' ;
    rdfs:comment 'Number of fan loyalty points required to redeem this promotion when requires_loyalty_membership is True and promotion_type is \'loyalty_reward\'. Null for non-loyalty promotions. Managed through the fan loyalty program in Adobe Experience Platform and Salesforce CRM.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maxDiscountCapAmount rdf:type rdf:Property ;
    rdfs:label 'Max Discount Cap Amount' ;
    rdfs:comment 'Maximum absolute discount amount (in promotion currency) that can be applied per transaction, regardless of the calculated percentage discount. Prevents excessive margin erosion on high-value merchandise orders. Null indicates no cap.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minPurchaseAmount rdf:type rdf:Property ;
    rdfs:label 'Min Purchase Amount' ;
    rdfs:comment 'Minimum cart or order subtotal (in the promotion currency) that must be met before the promotion can be applied. Null indicates no minimum spend threshold. Used to drive higher basket values on event-day and championship merchandise campaigns.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minQuantity rdf:type rdf:Property ;
    rdfs:label 'Min Quantity' ;
    rdfs:comment 'Minimum number of qualifying items that must be in the cart before the promotion activates. Primarily used for bundle and BOGO promotion types. Null indicates no quantity threshold.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:promoCode rdf:type rdf:Property ;
    rdfs:label 'Promo Code' ;
    rdfs:comment 'Externally-known alphanumeric code that fans, customers, or loyalty members enter at checkout to redeem the promotion (e.g., CHAMP2024, BOGO_JERSEY). Serves as the business-facing identifier for the promotion across Shopify Plus, POS, and partner channels.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promotionDescription rdf:type rdf:Property ;
    rdfs:label 'Promotion Description' ;
    rdfs:comment 'Free-text marketing description of the promotion as communicated to fans and retail staff. Includes terms and conditions summary, eligible merchandise categories, and any event-specific context (e.g., \'Celebrate the championship with 20% off all official team jerseys this weekend only\').' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promotionName rdf:type rdf:Property ;
    rdfs:label 'Promotion Name' ;
    rdfs:comment 'Human-readable marketing name for the promotional campaign as displayed to fans and retail staff (e.g., \'Championship Day 20% Off\', \'Buy One Get One Jersey\', \'Fan Loyalty Free Shipping\').' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promotionStatus rdf:type rdf:Property ;
    rdfs:label 'Promotion Status' ;
    rdfs:comment 'Current lifecycle state of the promotional campaign: draft (being configured), scheduled (approved but not yet live), active (currently redeemable), paused (temporarily suspended), expired (past end date), or cancelled (terminated before expiry).' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promotionType rdf:type rdf:Property ;
    rdfs:label 'Promotion Type' ;
    rdfs:comment 'Classification of the promotional mechanism applied: percentage_discount (e.g., 20% off), fixed_amount (e.g., $10 off), bogo (Buy One Get One), free_shipping, bundle (multi-item deal), or loyalty_reward (fan loyalty point redemption). [ENUM-REF-CANDIDATE: percentage_discount|fixed_amount|bogo|free_shipping|bundle|loyalty_reward — promote to reference product if additional types emerge]' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:redemptionCount rdf:type rdf:Property ;
    rdfs:label 'Redemption Count' ;
    rdfs:comment 'Running total of the number of times this promotion has been successfully redeemed across all channels since activation. Updated in near-real-time from Shopify Plus and POS transaction feeds. Used to monitor usage against usage_limit_total.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:requiresLoyaltyMembership rdf:type rdf:Property ;
    rdfs:label 'Requires Loyalty Membership' ;
    rdfs:comment 'Indicates whether redemption of this promotion requires the customer to be an active member of the fan loyalty program. True = loyalty members only; False = available to all customers. Supports fan loyalty reward redemption campaigns managed via Adobe Experience Platform.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:termsAndConditions rdf:type rdf:Property ;
    rdfs:label 'Terms And Conditions' ;
    rdfs:comment 'Full legal terms and conditions text governing the promotion, including exclusions, geographic restrictions, and expiry terms. Required for consumer protection compliance and GDPR/CCPA transparency obligations when promotions are targeted to EU or California-based fans.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usageLimitPerCustomer rdf:type rdf:Property ;
    rdfs:label 'Usage Limit Per Customer' ;
    rdfs:comment 'Maximum number of times a single customer or fan account may redeem this promotion. Null indicates no per-customer restriction. Prevents abuse of fan loyalty reward promotions.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:usageLimitTotal rdf:type rdf:Property ;
    rdfs:label 'Usage Limit Total' ;
    rdfs:comment 'Maximum total number of times this promotion can be redeemed across all customers and channels combined. Null indicates unlimited redemptions. Critical for scarcity-driven championship and limited-edition merchandise promotions.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bankAccountRef rdf:type rdf:Property ;
    rdfs:label 'Bank Account Ref' ;
    rdfs:comment 'Masked or tokenized reference to the supplier\'s bank account used for electronic payment processing. Full account details are stored in the SAP S/4HANA FI payment configuration. PCI-DSS and SOX controls apply.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defectRate rdf:type rdf:Property ;
    rdfs:label 'Defect Rate' ;
    rdfs:comment 'Percentage (0.00–100.00) of units received from this supplier that failed quality inspection. Used to monitor merchandise quality compliance and trigger corrective action plans.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ethicalSourcingCertName rdf:type rdf:Property ;
    rdfs:label 'Ethical Sourcing Cert Name' ;
    rdfs:comment 'Name of the ethical sourcing certification held by the supplier (e.g., Fair Trade, SA8000, WRAP, B Corp). Supports ESG due diligence and brand compliance reporting.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ethicalSourcingCertified rdf:type rdf:Property ;
    rdfs:label 'Ethical Sourcing Certified' ;
    rdfs:comment 'Indicates whether the supplier holds a recognized ethical sourcing certification (e.g., Fair Trade, SA8000, WRAP). Required for brand compliance and ESG reporting.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:incotermsCode rdf:type rdf:Property ;
    rdfs:label 'Incoterms Code' ;
    rdfs:comment 'International Commercial Terms (Incoterms 2020) code defining the division of shipping costs, risk, and responsibilities between the supplier and Sports Entertainment. Critical for merchandise import logistics and customs compliance. [ENUM-REF-CANDIDATE: EXW|FCA|CPT|CIP|DAP|DPU|DDP|FAS|FOB|CFR|CIF — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isLicensedProducer rdf:type rdf:Property ;
    rdfs:label 'Is Licensed Producer' ;
    rdfs:comment 'Indicates whether the supplier holds an active official merchandise license from the relevant sports league or governing body (e.g., NFL, NBA, FIFA) to produce and distribute branded goods. Mandatory for IP protection and brand compliance.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isoCertExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Iso Cert Expiry Date' ;
    rdfs:comment 'Expiry date of the supplier\'s ISO certification. Procurement teams use this to schedule re-certification audits and ensure continuous compliance.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isoCertificationCode rdf:type rdf:Property ;
    rdfs:label 'Iso Certification Code' ;
    rdfs:comment 'ISO standard certification code held by the supplier (e.g., ISO 9001 for quality management, ISO 14001 for environmental management). Used in supplier qualification and audit processes.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Lead Time Days' ;
    rdfs:comment 'Standard number of calendar days from purchase order placement to goods receipt for this supplier. Used for merchandise replenishment planning, event inventory readiness, and Shopify Plus fulfillment SLA management.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minimumOrderQuantity rdf:type rdf:Property ;
    rdfs:label 'Minimum Order Quantity' ;
    rdfs:comment 'Minimum number of units the supplier requires per purchase order line. Used in procurement planning to ensure order quantities meet supplier thresholds and avoid penalties.' ;
    rdfs:domain ind:Merchandise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:onTimeDeliveryRate rdf:type rdf:Property ;
    rdfs:label 'On Time Delivery Rate' ;
    rdfs:comment 'Percentage (0.00–100.00) of purchase orders delivered by the supplier on or before the confirmed delivery date. Key performance indicator for supplier reliability and event merchandise readiness.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Payment Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code in which the supplier is paid (e.g., USD, EUR, GBP). Used for multi-currency procurement and financial settlement.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredSupplierFlag rdf:type rdf:Property ;
    rdfs:label 'Preferred Supplier Flag' ;
    rdfs:comment 'Indicates whether this supplier has been designated as a preferred vendor for merchandise procurement, qualifying them for priority purchase order allocation and strategic partnership benefits.' ;
    rdfs:domain ind:Merchandise ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:qualityRatingScore rdf:type rdf:Property ;
    rdfs:label 'Quality Rating Score' ;
    rdfs:comment 'Numeric quality performance score (0.00–100.00) assigned to the supplier based on defect rates, return rates, and compliance with merchandise quality standards. Used in supplier evaluation and sourcing decisions.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:region rdf:type rdf:Property ;
    rdfs:label 'Region' ;
    rdfs:comment 'Geographic region where the supplier primarily operates (e.g., North America, Europe, Asia-Pacific). Used for supply chain risk segmentation and regional sourcing strategy.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapVendorAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Vendor Account Number' ;
    rdfs:comment '10-digit vendor account number (LIFNR) assigned in SAP S/4HANA MM/FI for this supplier. Used as the cross-system reconciliation key between the merchandise supplier master and the ERP financial and procurement modules.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierCode rdf:type rdf:Property ;
    rdfs:label 'Supplier Code' ;
    rdfs:comment 'Externally-known alphanumeric code assigned to the supplier for use in purchase orders, invoices, and procurement communications. Aligns with SAP S/4HANA vendor account number (LIFNR) in the MM module.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierStatus rdf:type rdf:Property ;
    rdfs:label 'Supplier Status' ;
    rdfs:comment 'Current lifecycle status of the supplier in the merchandise procurement master. Active suppliers are eligible for purchase orders; suspended suppliers are under review; blacklisted suppliers are permanently excluded from procurement.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierType rdf:type rdf:Property ;
    rdfs:label 'Supplier Type' ;
    rdfs:comment 'Classification of the supplier\'s operational role in the merchandise supply chain. Manufacturer produces goods; distributor warehouses and ships; print-on-demand fulfills custom orders; licensee holds IP rights to produce; wholesaler sells in bulk; dropshipper ships directly to consumer. [ENUM-REF-CANDIDATE: manufacturer|distributor|print_on_demand|licensee|wholesaler|dropshipper — promote to reference product]' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxNumber rdf:type rdf:Property ;
    rdfs:label 'Tax Number' ;
    rdfs:comment 'Government-issued tax identification number (e.g., EIN in the USA, VAT number in the EU) for the supplier entity. Required for financial reporting, 1099/W-9 compliance, and royalty payment processing.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradeName rdf:type rdf:Property ;
    rdfs:label 'Trade Name' ;
    rdfs:comment 'Operating or brand name of the supplier, which may differ from the legal name. Used in day-to-day procurement communications and vendor-facing materials.' ;
    rdfs:domain ind:Supplier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenseeId rdf:type rdf:Property ;
    rdfs:label 'Licensee Id' ;
    rdfs:comment 'Foreign key linking to broadcast.licensee. Business justification: Media rights deals grant broadcast rights to licensees (the parties receiving the license). Every media rights deal must identify the licensee receiving the rights. This is essential for contract mana' ;
    rdfs:domain ind:Broadcast ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Licensee .

ind:rightsHolderId rdf:type rdf:Property ;
    rdfs:label 'Rights Holder Id' ;
    rdfs:comment 'Foreign key linking to broadcast.rights_holder. Business justification: Media rights deals are negotiated with rights holders who own the content rights being licensed. Every media rights deal must identify the rights holder granting the rights. This is a foundational rel' ;
    rdfs:domain ind:Broadcast ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RightsHolder .

ind:annualRightsFeeUsd rdf:type rdf:Property ;
    rdfs:label 'Annual Rights Fee Usd' ;
    rdfs:comment 'Annual rights fee payable by the licensee in US Dollars. Used for ARR (Annual Recurring Revenue) tracking, financial planning in Workday Adaptive Planning, and year-over-year revenue comparison.' ;
    rdfs:domain ind:MediaRightsDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:blackoutRulesApplicable rdf:type rdf:Property ;
    rdfs:label 'Blackout Rules Applicable' ;
    rdfs:comment 'Indicates whether geographic or platform-based blackout rules apply to content distributed under this deal. When true, the CDN and streaming platform must enforce territory-based content restrictions.' ;
    rdfs:domain ind:Broadcast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:blackoutTerritoryCodes rdf:type rdf:Property ;
    rdfs:label 'Blackout Territory Codes' ;
    rdfs:comment 'Comma-separated list of ISO 3166-1 alpha-3 country or market codes where content blackout restrictions apply under this deal. Used by CDN geo-restriction and OTT/IPTV platform access control engines.' ;
    rdfs:domain ind:MediaRightsDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cdnProviderName rdf:type rdf:Property ;
    rdfs:label 'Cdn Provider Name' ;
    rdfs:comment 'Name of the CDN provider responsible for delivering digital content under this deal (e.g., Akamai, Fastly, Cloudflare). Relevant for OTT/IPTV and DTC streaming deals. Supports SLA monitoring and CDN cost allocation.' ;
    rdfs:domain ind:MediaRightsDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:daletContractRef rdf:type rdf:Property ;
    rdfs:label 'Dalet Contract Ref' ;
    rdfs:comment 'External reference identifier from Dalet Galaxy Media Asset Management system linking this deal to the corresponding rights contract object in the broadcast workflow system. Supports data lineage from source system.' ;
    rdfs:domain ind:MediaRightsDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataPrivacyComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Data Privacy Compliance Flag' ;
    rdfs:comment 'Indicates whether the deal includes contractual data privacy compliance obligations (GDPR, CCPA) governing fan data collected through the licensee\'s broadcast and streaming platforms.' ;
    rdfs:domain ind:MediaRightsDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dealCreatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Deal Created Timestamp' ;
    rdfs:comment 'Timestamp when this media rights deal record was first created in the system. Audit trail field for data governance and SOX compliance. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:MediaRightsDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:dealNumber rdf:type rdf:Property ;
    rdfs:label 'Deal Number' ;
    rdfs:comment 'Externally-known alphanumeric contract reference number assigned by the rights management system (Dalet Galaxy or Salesforce CRM) and used in all correspondence with broadcast partners. Serves as the BUSINESS_IDENTIFIER for this agreement.' ;
    rdfs:domain ind:MediaRightsDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dealStatus rdf:type rdf:Property ;
    rdfs:label 'Deal Status' ;
    rdfs:comment 'Current lifecycle state of the media rights deal. Drives rights enforcement and blackout rule activation. Values: draft, pending_approval, active, suspended, expired, terminated.' ;
    rdfs:domain ind:MediaRightsDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dealUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Deal Updated Timestamp' ;
    rdfs:comment 'Timestamp when this media rights deal record was most recently modified. Supports change data capture (CDC) in the Databricks Silver Layer and audit trail requirements. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:MediaRightsDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:dealValueUsd rdf:type rdf:Property ;
    rdfs:label 'Deal Value Usd' ;
    rdfs:comment 'Total gross contract value of the media rights deal in US Dollars over the full contract term. Represents the headline financial commitment. Used for EBITDA reporting and ARR calculations.' ;
    rdfs:domain ind:MediaRightsDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:digitalStreamingRightsIncluded rdf:type rdf:Property ;
    rdfs:label 'Digital Streaming Rights Included' ;
    rdfs:comment 'Indicates whether OTT/IPTV digital streaming rights are included in this deal, permitting distribution via internet-based platforms (e.g., DTC apps, OTT services).' ;
    rdfs:domain ind:MediaRightsDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:exclusivityType rdf:type rdf:Property ;
    rdfs:label 'Exclusivity Type' ;
    rdfs:comment 'Defines whether the rights granted are exclusive to the licensee within the territory, non-exclusive (shared with other licensees), first-window (first broadcast rights before others), or co-exclusive (shared exclusivity with a limited number of partners).' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:governingLawCountryCode rdf:type rdf:Property ;
    rdfs:label 'Governing Law Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the jurisdiction whose laws govern this media rights agreement (e.g., USA, GBR, CHE). Determines applicable regulatory frameworks and dispute resolution venue.' ;
    rdfs:domain ind:MediaRightsDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:highlightsRightsIncluded rdf:type rdf:Property ;
    rdfs:label 'Highlights Rights Included' ;
    rdfs:comment 'Indicates whether rights to produce and distribute short-form highlight clips are included in this deal. Relevant for social media, news broadcasts, and digital platform distribution.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:liveRightsIncluded rdf:type rdf:Property ;
    rdfs:label 'Live Rights Included' ;
    rdfs:comment 'Indicates whether live broadcast rights for events are included in this deal. Drives live feed distribution scheduling and OB (Outside Broadcast) resource allocation.' ;
    rdfs:domain ind:MediaRightsDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maxEventsPerSeason rdf:type rdf:Property ;
    rdfs:label 'Max Events Per Season' ;
    rdfs:comment 'Maximum number of events the licensee may broadcast per season under this deal. Caps the licensee\'s broadcast entitlement and protects rights holder\'s ability to distribute remaining events to other partners.' ;
    rdfs:domain ind:MediaRightsDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minGuaranteedEvents rdf:type rdf:Property ;
    rdfs:label 'Min Guaranteed Events' ;
    rdfs:comment 'Contractually guaranteed minimum number of live events the licensee is entitled to broadcast under this deal per contract year. Triggers make-good provisions if not met.' ;
    rdfs:domain ind:MediaRightsDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ppvRightsIncluded rdf:type rdf:Property ;
    rdfs:label 'Ppv Rights Included' ;
    rdfs:comment 'Indicates whether Pay-Per-View event packaging rights are included in this deal, allowing the licensee to offer individual event purchases to consumers.' ;
    rdfs:domain ind:MediaRightsDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:renewalOptionType rdf:type rdf:Property ;
    rdfs:label 'Renewal Option Type' ;
    rdfs:comment 'Type of renewal option included in the deal. Automatic renewal triggers without action; mutual_agreement requires both parties to agree; right_of_first_refusal gives the licensee priority to match competing offers; none means no renewal option exists.' ;
    rdfs:domain ind:MediaRightsDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:replayRightsIncluded rdf:type rdf:Property ;
    rdfs:label 'Replay Rights Included' ;
    rdfs:comment 'Indicates whether replay/rebroadcast rights are included in this deal, allowing the licensee to air recorded versions of events after the live window closes.' ;
    rdfs:domain ind:MediaRightsDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rightsCategories rdf:type rdf:Property ;
    rdfs:label 'Rights Categories' ;
    rdfs:comment 'Comma-separated list of rights categories included in this deal. Typical values: live, replay, highlights, ppv, clip_licensing, archive, digital_streaming, radio. Captures the full scope of content rights granted. [ENUM-REF-CANDIDATE: live|replay|highlights|ppv|clip_licensing|archive|digital_streaming|radio — promote to reference product]' ;
    rdfs:domain ind:MediaRightsDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rightsWindowCount rdf:type rdf:Property ;
    rdfs:label 'Rights Window Count' ;
    rdfs:comment 'Total number of distinct rights windows (time-period/platform/territory entitlement combinations) defined under this deal. Supports rights window enforcement and deal complexity classification.' ;
    rdfs:domain ind:MediaRightsDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rsnAffiliateCode rdf:type rdf:Property ;
    rdfs:label 'Rsn Affiliate Code' ;
    rdfs:comment 'Reference to the RSN affiliate entity associated with this deal when the deal type is rsn. Identifies the specific regional network carrying the broadcast rights within a defined geographic footprint.' ;
    rdfs:domain ind:Broadcast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesforceOpportunityReference rdf:type rdf:Property ;
    rdfs:label 'Salesforce Opportunity Reference' ;
    rdfs:comment 'External reference identifier from Salesforce CRM linking this media rights deal record to the originating CRM opportunity or contract object. Supports data lineage and system-of-record traceability.' ;
    rdfs:domain ind:MediaRightsDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sportName rdf:type rdf:Property ;
    rdfs:label 'Sport Name' ;
    rdfs:comment 'Name of the sport covered by this media rights deal (e.g., American Football, Basketball, Soccer, Baseball, Hockey). Supports multi-sport deal classification and rights analytics.' ;
    rdfs:domain ind:MediaRightsDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminationForCausePermitted rdf:type rdf:Property ;
    rdfs:label 'Termination For Cause Permitted' ;
    rdfs:comment 'Indicates whether either party may terminate the deal early for cause (e.g., breach of contract, regulatory non-compliance, PED violations affecting league integrity). Relevant for compliance and legal risk management.' ;
    rdfs:domain ind:MediaRightsDeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:territoryScope rdf:type rdf:Property ;
    rdfs:label 'Territory Scope' ;
    rdfs:comment 'Categorical scope of the geographic territory covered by this deal. Distinguishes between national, regional (e.g., RSN footprint), local market, worldwide, or multi-territory agreements.' ;
    rdfs:domain ind:Broadcast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:homeFranchiseId rdf:type rdf:Property ;
    rdfs:label 'Home Franchise Id' ;
    rdfs:comment 'Foreign key linking to league.franchise. Business justification: RSN affiliate routing and local market blackout enforcement require knowing the home franchise for each scheduled broadcast. Role-prefix \'home_\' distinguishes this from a generic franchise reference a' ;
    rdfs:domain ind:BroadcastSchedule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Franchise .

ind:primaryBroadcastEventFixtureId rdf:type rdf:Property ;
    rdfs:label 'Primary Broadcast Event Fixture Id' ;
    rdfs:comment 'Reference to the sporting or entertainment event being broadcast in this schedule window. Links the broadcast schedule to the event domain for event-to-channel assignment tracking.' ;
    rdfs:domain ind:BroadcastSchedule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Fixture .

ind:adBreakCount rdf:type rdf:Property ;
    rdfs:label 'Ad Break Count' ;
    rdfs:comment 'Number of planned commercial advertisement breaks within this broadcast schedule entry. Used for sponsorship inventory management, ad sales planning, and revenue forecasting.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:adBreakDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Ad Break Duration Minutes' ;
    rdfs:comment 'Total planned duration of all commercial advertisement breaks in minutes for this broadcast schedule entry. Used for ad inventory capacity planning and sponsor commitment fulfillment tracking.' ;
    rdfs:domain ind:BroadcastSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:airDate rdf:type rdf:Property ;
    rdfs:label 'Air Date' ;
    rdfs:comment 'Calendar date on which the broadcast is scheduled to air. Used for day-level scheduling, program guide publication, and rights window validation.' ;
    rdfs:domain ind:BroadcastSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:audioDescriptionRequired rdf:type rdf:Property ;
    rdfs:label 'Audio Description Required' ;
    rdfs:comment 'Indicates whether audio description (video description for visually impaired viewers) is required for this broadcast. Driven by FCC accessibility mandates and ADA compliance requirements for broadcast content.' ;
    rdfs:domain ind:BroadcastSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:blackoutApplicable rdf:type rdf:Property ;
    rdfs:label 'Blackout Applicable' ;
    rdfs:comment 'Indicates whether broadcast blackout rules apply to this schedule entry. When True, the blackout_rule_id and blackout_region_code must be evaluated before distribution to enforce territorial rights restrictions.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:broadcastType rdf:type rdf:Property ;
    rdfs:label 'Broadcast Type' ;
    rdfs:comment 'Classification of the broadcast feed type indicating whether the content is transmitted live, on a tape-delay basis, as a replay, as a highlight package, or as a Pay-Per-View (PPV) event. Drives rights enforcement, DRM policy application, and CDN routing logic.' ;
    rdfs:domain ind:BroadcastSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cdnProfileCode rdf:type rdf:Property ;
    rdfs:label 'Cdn Profile Code' ;
    rdfs:comment 'Code identifying the Content Delivery Network (CDN) configuration profile used to distribute this broadcast. Determines routing, caching, and failover behavior for digital platform delivery.' ;
    rdfs:domain ind:BroadcastSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closedCaptionRequired rdf:type rdf:Property ;
    rdfs:label 'Closed Caption Required' ;
    rdfs:comment 'Indicates whether closed captioning is required for this broadcast schedule entry. Mandatory for FCC compliance under the Twenty-First Century Communications and Video Accessibility Act (CVAA) and ADA accessibility requirements.' ;
    rdfs:domain ind:BroadcastSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:commentaryLanguageCode rdf:type rdf:Property ;
    rdfs:label 'Commentary Language Code' ;
    rdfs:comment 'ISO 639-1/639-2 language code for the commentary/play-by-play audio track, which may differ from the primary broadcast language. Relevant for international feed distribution and multi-language OTT packaging.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feedFormat rdf:type rdf:Property ;
    rdfs:label 'Feed Format' ;
    rdfs:comment 'Technical broadcast feed format specifying the video quality standard for this schedule entry (e.g., HD, 4K, SD, HDR, VR). Used for CDN capacity planning, encoder assignment, and viewer experience reporting.' ;
    rdfs:domain ind:BroadcastSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:internationalFeed rdf:type rdf:Property ;
    rdfs:label 'International Feed' ;
    rdfs:comment 'Indicates whether this broadcast schedule entry uses an international feed (world feed) as opposed to a domestic production feed. Relevant for FIFA, IOC, and other international governing body rights distribution.' ;
    rdfs:domain ind:BroadcastSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:obUnitCode rdf:type rdf:Property ;
    rdfs:label 'Ob Unit Code' ;
    rdfs:comment 'Identifier for the Outside Broadcast (OB) truck or mobile production unit assigned to this broadcast schedule entry. Used for equipment scheduling, logistics coordination, and production cost allocation.' ;
    rdfs:domain ind:Broadcast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:platformType rdf:type rdf:Property ;
    rdfs:label 'Platform Type' ;
    rdfs:comment 'Category of the distribution platform for this broadcast schedule entry. Distinguishes linear TV, Over-The-Top (OTT) streaming, Internet Protocol Television (IPTV), Regional Sports Network (RSN), Direct-To-Consumer (DTC), and Pay-Per-View (PPV) platform delivery modes.' ;
    rdfs:domain ind:Broadcast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ppvEvent rdf:type rdf:Property ;
    rdfs:label 'Ppv Event' ;
    rdfs:comment 'Indicates whether this broadcast schedule entry is a Pay-Per-View (PPV) event requiring individual purchase or access authorization. When True, triggers PPV pricing, access control, and revenue tracking workflows.' ;
    rdfs:domain ind:BroadcastSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:programDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Program Duration Minutes' ;
    rdfs:comment 'Planned duration of the broadcast program in minutes as scheduled in the program guide. Used for slot allocation, ad break planning, and rights window compliance verification.' ;
    rdfs:domain ind:BroadcastSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ratingClassification rdf:type rdf:Property ;
    rdfs:label 'Rating Classification' ;
    rdfs:comment 'Content rating classification assigned to this broadcast as per the TV Parental Guidelines system (e.g., TV-G, TV-PG, TV-14, TV-MA). Required for FCC compliance, parental control enforcement, and OTT platform content filtering.' ;
    rdfs:domain ind:BroadcastSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referenceCode rdf:type rdf:Property ;
    rdfs:label 'Reference Code' ;
    rdfs:comment 'Externally-known alphanumeric code assigned by Dalet Galaxy to uniquely identify this broadcast schedule entry across systems. Used for cross-system reconciliation and operational communication with broadcast partners.' ;
    rdfs:domain ind:BroadcastSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledEndTime rdf:type rdf:Property ;
    rdfs:label 'Scheduled End Time' ;
    rdfs:comment 'Precise date and timestamp at which the broadcast window is scheduled to conclude, including timezone offset. Used for slot duration calculation, back-to-back scheduling, and CDN resource planning.' ;
    rdfs:domain ind:BroadcastSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:simulcastFlag rdf:type rdf:Property ;
    rdfs:label 'Simulcast Flag' ;
    rdfs:comment 'Indicates whether this broadcast schedule entry is a simultaneous multi-platform broadcast (simulcast) airing on multiple channels or platforms at the same time. Used for rights management and audience deduplication in ratings reporting.' ;
    rdfs:domain ind:BroadcastSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rsnFranchiseId rdf:type rdf:Property ;
    rdfs:label 'Rsn Franchise Id' ;
    rdfs:comment 'Foreign key linking to league.franchise. Business justification: RSN channels are franchise-specific (YES Network/Yankees, NESN/Red Sox). RSN channel-to-franchise assignment is a named business construct for local rights management. Role-prefix \'rsn_\' reflects the ' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Franchise .

ind:blackoutRuleCode rdf:type rdf:Property ;
    rdfs:label 'Blackout Rule Code' ;
    rdfs:comment 'Code identifying the blackout restriction rule set applied to this channel. Blackout rules restrict broadcast of specific events in defined geographic territories per league agreements (e.g., NFL, NBA, MLB local blackout policies). Enforced at the channel level for linear and OTT distribution.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:broadcastFormat rdf:type rdf:Property ;
    rdfs:label 'Broadcast Format' ;
    rdfs:comment 'Primary content delivery format of this channel. Live = real-time event broadcast; Replay = time-shifted full event replay; VOD (Video on Demand) = on-demand library content; Simulcast = simultaneous broadcast across multiple platforms; Highlights = short-form curated content.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelNumber rdf:type rdf:Property ;
    rdfs:label 'Channel Number' ;
    rdfs:comment 'Logical channel number assigned by the platform operator or cable/satellite provider for linear channel lineup placement (e.g., channel 720 on DirecTV). Used for EPG (Electronic Program Guide) integration and subscriber navigation.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:closedCaptionSupported rdf:type rdf:Property ;
    rdfs:label 'Closed Caption Supported' ;
    rdfs:comment 'Indicates whether this channel supports closed captioning for accessibility compliance. Required for ADA (Americans with Disabilities Act) and FCC closed captioning mandates for broadcast channels serving US audiences.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:distributionTerritory rdf:type rdf:Property ;
    rdfs:label 'Distribution Territory' ;
    rdfs:comment 'The geographic territory or market in which this vendor is authorized to distribute the channel under this agreement. A single channel may have different vendors authorized for different territories (e.g., US West, EMEA, APAC).' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:encodingStandard rdf:type rdf:Property ;
    rdfs:label 'Encoding Standard' ;
    rdfs:comment 'Video encoding/compression standard used for this channel\'s stream (e.g., H.264/AVC, H.265/HEVC, AV1). Determines device compatibility, CDN efficiency, and streaming quality at given bitrates.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:epgCode rdf:type rdf:Property ;
    rdfs:label 'Epg Code' ;
    rdfs:comment 'External identifier used by Electronic Program Guide (EPG) data providers (e.g., Tribune Media, Gracenote) to reference this channel in scheduling and guide data feeds. Enables automated schedule ingestion and viewer guide population.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicCoverage rdf:type rdf:Property ;
    rdfs:label 'Geographic Coverage' ;
    rdfs:comment 'Textual description or structured list of geographic markets, regions, or territories this channel is licensed to serve (e.g., \'Northeast USA\', \'Western Europe\', \'Global excluding China\'). Distinct from country_code which captures the registration country; this field captures the full distribution footprint for rights enforcement.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxConcurrentStreams rdf:type rdf:Property ;
    rdfs:label 'Max Concurrent Streams' ;
    rdfs:comment 'Maximum number of simultaneous viewer streams permitted on this channel as defined by rights agreements or platform capacity constraints. Used for CDN capacity planning and rights compliance enforcement during peak events.' ;
    rdfs:domain ind:Broadcast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:monthlyRightsFee rdf:type rdf:Property ;
    rdfs:label 'Monthly Rights Fee' ;
    rdfs:comment 'Monthly fee paid to or received from the platform operator or rights holder for distribution of this channel, expressed in the channel\'s billing currency. Confidential commercial term used for revenue management and EBITDA reporting.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:multiviewSupported rdf:type rdf:Property ;
    rdfs:label 'Multiview Supported' ;
    rdfs:comment 'Indicates whether this channel supports simultaneous multi-angle or multi-game viewing (multiview) for premium subscribers. A differentiating feature for OTT and DTC channels used in fan engagement and premium tier upsell strategies.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:obUnitRequired rdf:type rdf:Property ;
    rdfs:label 'Ob Unit Required' ;
    rdfs:comment 'Indicates whether this channel requires an OB (Outside Broadcast) unit for live event production. When True, triggers OB unit scheduling and resource allocation workflows in the broadcast operations team.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:parentalRating rdf:type rdf:Property ;
    rdfs:label 'Parental Rating' ;
    rdfs:comment 'Content parental advisory rating assigned to this channel per FCC and TV Parental Guidelines standards (e.g., TV-G, TV-PG, TV-14, TV-MA). Used for parental control enforcement, platform compliance, and audience targeting restrictions.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionTier rdf:type rdf:Property ;
    rdfs:label 'Resolution Tier' ;
    rdfs:comment 'Video resolution quality tier offered by this channel. SD (Standard Definition), HD (High Definition), 4K (Ultra High Definition), 8K (Super Hi-Vision). Drives CDN (Content Delivery Network) bandwidth planning, rights packaging, and subscriber pricing tiers.' ;
    rdfs:domain ind:Broadcast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signalType rdf:type rdf:Property ;
    rdfs:label 'Signal Type' ;
    rdfs:comment 'Technical signal delivery mechanism for this channel. Determines infrastructure requirements, regulatory classification, and distribution partner compatibility. [ENUM-REF-CANDIDATE: digital|analog|IP|satellite|cable|terrestrial|fiber|microwave — promote to reference product]' ;
    rdfs:domain ind:Broadcast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:streamUrl rdf:type rdf:Property ;
    rdfs:label 'Stream Url' ;
    rdfs:comment 'Primary ingest or origin stream URL for OTT, IPTV, or DTC channel types. Confidential as it represents a direct access endpoint to live feed infrastructure. Used by broadcast operations and CDN configuration teams.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subscriberCount rdf:type rdf:Property ;
    rdfs:label 'Subscriber Count' ;
    rdfs:comment 'Current number of active subscribers or authorized viewers for this channel. For OTT/DTC/IPTV channels, reflects platform subscription count. For linear channels, reflects reported household reach. Used for ARPU (Average Revenue Per User) calculation and rights fee negotiations.' ;
    rdfs:domain ind:Broadcast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:uptimeSlaPct rdf:type rdf:Property ;
    rdfs:label 'Uptime Sla Pct' ;
    rdfs:comment 'Contractually committed uptime percentage for this channel as defined in the SLA (Service Level Agreement) with the platform operator or CDN provider (e.g., 99.95). Used for operational performance monitoring and penalty clause management.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:blackoutRuleId rdf:type rdf:Property ;
    rdfs:label 'Blackout Rule Id' ;
    rdfs:comment 'Unique surrogate identifier for the blackout rule record in the broadcast rights management system.' ;
    rdfs:domain ind:BlackoutRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryBlackoutEventFixtureId rdf:type rdf:Property ;
    rdfs:label 'Primary Blackout Event Fixture Id' ;
    rdfs:comment 'Reference to the specific event (game, match, concert, PPV event) to which this blackout rule applies. Null if the rule applies to all events under a league or rights window.' ;
    rdfs:domain ind:BlackoutRule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Fixture .

ind:appliesToHighlights rdf:type rdf:Property ;
    rdfs:label 'Applies To Highlights' ;
    rdfs:comment 'Indicates whether this blackout rule also restricts distribution of highlight clips and short-form content derived from the blacked-out event.' ;
    rdfs:domain ind:BlackoutRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:appliesToReplay rdf:type rdf:Property ;
    rdfs:label 'Applies To Replay' ;
    rdfs:comment 'Indicates whether this blackout rule extends to replay, VOD (Video on Demand), and time-shifted viewing of the event content, in addition to the live broadcast.' ;
    rdfs:domain ind:BlackoutRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:blackoutLiftCondition rdf:type rdf:Property ;
    rdfs:label 'Blackout Lift Condition' ;
    rdfs:comment 'Narrative description of the condition(s) under which this blackout rule is automatically lifted or deactivated (e.g., \'Blackout lifted when 85% of venue capacity is sold 72 hours prior to event start\').' ;
    rdfs:domain ind:BlackoutRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blackoutType rdf:type rdf:Property ;
    rdfs:label 'Blackout Type' ;
    rdfs:comment 'Classification of the blackout scope: \'local\' (home market territory), \'national\' (entire country), \'international\' (cross-border), \'rsn_exclusivity\' (Regional Sports Network exclusive window), \'ppv\' (Pay-Per-View event blackout), \'ott\' (Over-The-Top streaming platform blackout).' ;
    rdfs:domain ind:BlackoutRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blackoutWindowHours rdf:type rdf:Property ;
    rdfs:label 'Blackout Window Hours' ;
    rdfs:comment 'Number of hours before and/or after the event start time during which the blackout is enforced. Defines the temporal scope of the blackout window around the event.' ;
    rdfs:domain ind:BlackoutRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:distributionPlatform rdf:type rdf:Property ;
    rdfs:label 'Distribution Platform' ;
    rdfs:comment 'The delivery platform type on which the blackout is enforced: \'linear_tv\' (traditional broadcast), \'ott\' (Over-The-Top streaming), \'iptv\' (Internet Protocol Television), \'rsn\' (Regional Sports Network), \'ppv\' (Pay-Per-View), \'dtc\' (Direct-To-Consumer), \'cable\', \'satellite\'. [ENUM-REF-CANDIDATE: linear_tv|ott|iptv|rsn|ppv|dtc|cable|satellite — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Broadcast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enforcementMechanism rdf:type rdf:Property ;
    rdfs:label 'Enforcement Mechanism' ;
    rdfs:comment 'Technical method used to enforce the blackout rule: \'geo_ip_block\' (IP geolocation blocking), \'drm_token\' (DRM token restriction), \'cdn_restriction\' (CDN-level content blocking), \'access_control\' (platform access control list), \'manual\' (manual operator action), \'api_enforcement\' (API-level enforcement).' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geoPrecisionLevel rdf:type rdf:Property ;
    rdfs:label 'Geo Precision Level' ;
    rdfs:comment 'Granularity of geographic enforcement for this blackout rule: \'country\', \'state\', \'dma\' (Designated Market Area), \'zip_code\', \'city\'. Determines how precisely the blackout territory is defined and enforced.' ;
    rdfs:domain ind:BlackoutRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastReviewedDate rdf:type rdf:Property ;
    rdfs:label 'Last Reviewed Date' ;
    rdfs:comment 'The most recent date on which this blackout rule was reviewed for accuracy, compliance alignment, and continued applicability by the rights management team.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mandateSource rdf:type rdf:Property ;
    rdfs:label 'Mandate Source' ;
    rdfs:comment 'The originating source of the blackout mandate: \'league_cba\' (Collective Bargaining Agreement), \'rights_contract\' (media rights deal terms), \'regulatory\' (FCC or government regulation), \'venue_agreement\' (venue exclusivity clause), \'network_policy\' (broadcaster internal policy).' ;
    rdfs:domain ind:BlackoutRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationLeadHours rdf:type rdf:Property ;
    rdfs:label 'Notification Lead Hours' ;
    rdfs:comment 'Number of hours in advance that notification must be submitted to the relevant authority before the blackout rule is activated or lifted. Applicable when notification_required is True.' ;
    rdfs:domain ind:BlackoutRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:notificationRequired rdf:type rdf:Property ;
    rdfs:label 'Notification Required' ;
    rdfs:comment 'Indicates whether advance notification to the league office, rights holder, or regulatory body is required before activating or lifting this blackout rule.' ;
    rdfs:domain ind:BlackoutRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:overrideAuthority rdf:type rdf:Property ;
    rdfs:label 'Override Authority' ;
    rdfs:comment 'The organizational role or body authorized to approve an override of this blackout rule: \'league_office\', \'rights_holder\', \'network_ops\' (Network Operations), \'legal\', \'executive\'. Applicable only when override_eligible is True.' ;
    rdfs:domain ind:BlackoutRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overrideEligible rdf:type rdf:Property ;
    rdfs:label 'Override Eligible' ;
    rdfs:comment 'Indicates whether this blackout rule can be overridden under specific conditions (e.g., emergency broadcast, league waiver, special event designation). True = override is permissible with authorization.' ;
    rdfs:domain ind:BlackoutRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:penaltyClause rdf:type rdf:Property ;
    rdfs:label 'Penalty Clause' ;
    rdfs:comment 'Description of contractual or regulatory penalties applicable if this blackout rule is violated or improperly enforced, as defined in the rights agreement or league mandate.' ;
    rdfs:domain ind:BlackoutRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postEventBlackoutHours rdf:type rdf:Property ;
    rdfs:label 'Post Event Blackout Hours' ;
    rdfs:comment 'Number of hours after event conclusion during which the blackout remains enforced. Protects replay and VOD rights windows for RSN and rights holders.' ;
    rdfs:domain ind:BlackoutRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:preEventBlackoutHours rdf:type rdf:Property ;
    rdfs:label 'Pre Event Blackout Hours' ;
    rdfs:comment 'Number of hours prior to event start time during which the blackout is enforced. Used to protect live gate attendance and RSN exclusivity windows.' ;
    rdfs:domain ind:BlackoutRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rsnExclusivity rdf:type rdf:Property ;
    rdfs:label 'Rsn Exclusivity' ;
    rdfs:comment 'Indicates whether this blackout rule is driven by RSN exclusivity rights. True = an RSN holds exclusive broadcast rights in the territory, triggering the blackout on competing platforms.' ;
    rdfs:domain ind:BlackoutRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rsnPartnerName rdf:type rdf:Property ;
    rdfs:label 'Rsn Partner Name' ;
    rdfs:comment 'Name of the RSN partner holding exclusive broadcast rights that trigger this blackout (e.g., \'Bally Sports\', \'MSG Network\', \'ROOT Sports\'). Populated when rsn_exclusivity is True.' ;
    rdfs:domain ind:BlackoutRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleCode rdf:type rdf:Property ;
    rdfs:label 'Rule Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying this blackout rule, used in league governance documents, RSN contracts, and broadcast operations systems.' ;
    rdfs:domain ind:BlackoutRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleDescription rdf:type rdf:Property ;
    rdfs:label 'Rule Description' ;
    rdfs:comment 'Detailed narrative description of the blackout rule, including its business rationale, contractual basis, and operational scope.' ;
    rdfs:domain ind:BlackoutRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleName rdf:type rdf:Property ;
    rdfs:label 'Rule Name' ;
    rdfs:comment 'Human-readable name describing the blackout rule (e.g., \'NFL Home Market Local Blackout\', \'RSN Exclusivity Window - Pacific Northwest\').' ;
    rdfs:domain ind:BlackoutRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleStatus rdf:type rdf:Property ;
    rdfs:label 'Rule Status' ;
    rdfs:comment 'Current lifecycle state of the blackout rule: \'active\' (currently enforced), \'inactive\' (not enforced), \'pending\' (awaiting activation), \'suspended\' (temporarily halted), \'expired\' (past effective period), \'draft\' (under review).' ;
    rdfs:domain ind:BlackoutRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:territoryRegion rdf:type rdf:Property ;
    rdfs:label 'Territory Region' ;
    rdfs:comment 'Sub-national region, DMA (Designated Market Area), or RSN coverage zone within the territory where the blackout applies (e.g., \'New York DMA\', \'Pacific Northwest RSN Zone\'). Complements territory_code for granular geographic enforcement.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ticketSalesThresholdPct rdf:type rdf:Property ;
    rdfs:label 'Ticket Sales Threshold Pct' ;
    rdfs:comment 'The minimum percentage of venue capacity that must be sold for the blackout to be lifted (e.g., 85.00 means 85% of tickets must be sold). Applicable when trigger_condition is \'ticket_sales_threshold\' or \'sellout_rule\'.' ;
    rdfs:domain ind:BlackoutRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:triggerCondition rdf:type rdf:Property ;
    rdfs:label 'Trigger Condition' ;
    rdfs:comment 'The business condition that activates this blackout rule: \'ticket_sales_threshold\' (blackout lifted when ticket sales meet threshold), \'rsn_exclusivity\' (RSN holds exclusive rights), \'league_mandate\' (governing body requirement), \'rights_agreement\' (contractual obligation), \'ppv_purchase\' (PPV event requiring purchase), \'sellout_rule\' (event sold out). [ENUM-REF-CANDIDATE: ticket_sales_threshold|rsn_exclusivity|league_mandate|rights_agreement|ppv_purchase|sellout_rule|capacity_threshold|broadcast_window — promote to reference product]' ;
    rdfs:domain ind:BlackoutRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:backupFeedId rdf:type rdf:Property ;
    rdfs:label 'Backup Feed Id' ;
    rdfs:comment 'Reference to the designated backup or failover live feed that will be activated if this primary feed fails. Enables automated failover management and redundancy tracking in broadcast operations.' ;
    rdfs:domain ind:LiveFeed ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LiveFeed .

ind:daletAssetId rdf:type rdf:Property ;
    rdfs:label 'Dalet Asset Id' ;
    rdfs:comment 'Identifier of the corresponding media asset record in the Dalet Galaxy Media Asset Management (MAM) system. Enables traceability between the operational live feed record and the media asset management workflow for ingest, archiving, and content repurposing.' ;
    rdfs:domain ind:Broadcast ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Asset .

ind:primaryLiveEventFixtureId rdf:type rdf:Property ;
    rdfs:label 'Primary Live Event Fixture Id' ;
    rdfs:comment 'Reference to the scheduled sporting or entertainment event for which this live feed is being produced and distributed.' ;
    rdfs:domain ind:LiveFeed ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Fixture .

ind:audioTrackCount rdf:type rdf:Property ;
    rdfs:label 'Audio Track Count' ;
    rdfs:comment 'Total number of discrete audio tracks embedded in the live feed. Multiple tracks support stereo, 5.1 surround, and separate commentary language channels. Relevant for multi-language broadcast distribution and accessibility compliance.' ;
    rdfs:domain ind:LiveFeed ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cdnOriginEndpoint rdf:type rdf:Property ;
    rdfs:label 'Cdn Origin Endpoint' ;
    rdfs:comment 'Primary CDN (Content Delivery Network) origin ingest URL or endpoint address from which the live feed is distributed to downstream delivery nodes and OTT (Over-The-Top) platforms. Core operational field for live distribution monitoring.' ;
    rdfs:domain ind:Broadcast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commentaryLanguage rdf:type rdf:Property ;
    rdfs:label 'Commentary Language' ;
    rdfs:comment 'ISO 639-1 or ISO 639-2 language code for the primary commentary audio track on this live feed (e.g., \'en\' for English, \'es\' for Spanish, \'fr\' for French). Drives regional distribution routing and RSN (Regional Sports Network) assignment.' ;
    rdfs:domain ind:LiveFeed ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionTier rdf:type rdf:Property ;
    rdfs:label 'Distribution Tier' ;
    rdfs:comment 'Geographic scope of distribution authorized for this live feed under the applicable media rights agreement. Global feeds are distributed worldwide; regional feeds are limited to a geographic zone; national feeds are country-specific; local feeds are limited to a designated market area (DMA).' ;
    rdfs:domain ind:LiveFeed ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:encodingFormat rdf:type rdf:Property ;
    rdfs:label 'Encoding Format' ;
    rdfs:comment 'Video codec standard used to compress and encode the live feed signal. H.264 (AVC) and H.265 (HEVC) are the dominant standards for broadcast and OTT (Over-The-Top) streaming delivery. Impacts bandwidth, quality, and platform compatibility.' ;
    rdfs:domain ind:LiveFeed ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failoverActivated rdf:type rdf:Property ;
    rdfs:label 'Failover Activated' ;
    rdfs:comment 'Indicates whether the backup or redundancy failover mechanism was triggered during this live feed\'s transmission. Used for post-event incident analysis, SLA (Service Level Agreement) reporting, and broadcast reliability KPI (Key Performance Indicator) tracking.' ;
    rdfs:domain ind:LiveFeed ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:failoverTimestamp rdf:type rdf:Property ;
    rdfs:label 'Failover Timestamp' ;
    rdfs:comment 'Date and time (UTC) when the failover mechanism was activated for this live feed. Null if failover_activated is false. Used for incident root cause analysis and SLA (Service Level Agreement) breach assessment.' ;
    rdfs:domain ind:LiveFeed ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:feedCode rdf:type rdf:Property ;
    rdfs:label 'Feed Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying this live feed within broadcast operations and Dalet Galaxy media asset management workflows. Used for signal routing, scheduling, and inter-system reference.' ;
    rdfs:domain ind:LiveFeed ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feedName rdf:type rdf:Property ;
    rdfs:label 'Feed Name' ;
    rdfs:comment 'Human-readable descriptive name for the live feed, typically including event name, feed type, and language (e.g., \'NFL Championship - World Feed - English\'). Used in operational dashboards and scheduling systems.' ;
    rdfs:domain ind:LiveFeed ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feedStatus rdf:type rdf:Property ;
    rdfs:label 'Feed Status' ;
    rdfs:comment 'Current operational lifecycle status of the live feed. Active indicates the feed is live and distributing; standby is ready but not transmitting; failed indicates a signal loss or error condition; backup indicates a redundancy feed has taken over; scheduled indicates pre-event readiness; terminated indicates the feed has ended.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feedType rdf:type rdf:Property ;
    rdfs:label 'Feed Type' ;
    rdfs:comment 'Classification of the live feed by its production and distribution purpose. World feed is the primary international signal; clean feed has no graphics; ISO feed is an isolated camera angle; PPV (Pay-Per-View) and OTT (Over-The-Top) feeds are platform-specific variants. [ENUM-REF-CANDIDATE: world_feed|clean_feed|commentary_feed|iso_feed|backup_feed|ppv_feed|ott_feed — promote to reference product]' ;
    rdfs:domain ind:LiveFeed ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hdrFormat rdf:type rdf:Property ;
    rdfs:label 'Hdr Format' ;
    rdfs:comment 'High Dynamic Range (HDR) format applied to the live feed for enhanced color and brightness reproduction. HDR10 and HLG (Hybrid Log-Gamma) are the broadcast standards; Dolby Vision is a premium streaming format. None indicates standard dynamic range (SDR).' ;
    rdfs:domain ind:LiveFeed ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isIptvEnabled rdf:type rdf:Property ;
    rdfs:label 'Is Iptv Enabled' ;
    rdfs:comment 'Indicates whether this live feed is authorized and configured for distribution via IPTV (Internet Protocol Television) networks, including managed IPTV services provided by telecommunications operators.' ;
    rdfs:domain ind:LiveFeed ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isLinearTvEnabled rdf:type rdf:Property ;
    rdfs:label 'Is Linear Tv Enabled' ;
    rdfs:comment 'Indicates whether this live feed is authorized and configured for distribution via traditional linear television broadcast channels, including RSN (Regional Sports Network) and national broadcast network affiliates.' ;
    rdfs:domain ind:LiveFeed ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isOttEnabled rdf:type rdf:Property ;
    rdfs:label 'Is Ott Enabled' ;
    rdfs:comment 'Indicates whether this live feed is authorized and technically configured for distribution via OTT (Over-The-Top) streaming platforms, including DTC (Direct-To-Consumer) services and third-party streaming partners.' ;
    rdfs:domain ind:LiveFeed ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:latencyMode rdf:type rdf:Property ;
    rdfs:label 'Latency Mode' ;
    rdfs:comment 'Configured latency mode for this live feed delivery. Ultra-low latency (sub-3 seconds) is required for interactive and betting-adjacent use cases; low latency (3-10 seconds) for OTT (Over-The-Top) sports streaming; standard (10-30 seconds) for traditional broadcast; high for archive-quality delivery.' ;
    rdfs:domain ind:LiveFeed ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionRegion rdf:type rdf:Property ;
    rdfs:label 'Production Region' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the primary production region where this live feed is originated and managed. Used for regulatory compliance, rights territory management, and broadcast operations routing.' ;
    rdfs:domain ind:LiveFeed ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:redundancyConfig rdf:type rdf:Property ;
    rdfs:label 'Redundancy Config' ;
    rdfs:comment 'Redundancy architecture configured for this live feed to ensure continuity in case of primary signal failure. 1+1 means one active and one standby path; N+1 means N active feeds with one shared backup. Critical for broadcast SLA (Service Level Agreement) compliance.' ;
    rdfs:domain ind:LiveFeed ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:replayEnabled rdf:type rdf:Property ;
    rdfs:label 'Replay Enabled' ;
    rdfs:comment 'Indicates whether this live feed is authorized and configured to generate replay or catch-up content after the live event concludes. Drives post-event content ingest workflows in Dalet Galaxy and DRM (Digital Rights Management) policy application for replay windows.' ;
    rdfs:domain ind:LiveFeed ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:replayWindowHours rdf:type rdf:Property ;
    rdfs:label 'Replay Window Hours' ;
    rdfs:comment 'Number of hours after the live event ends during which replay content derived from this feed is available to authorized viewers. Defined by the media rights agreement and DRM (Digital Rights Management) policy. Null if replay_enabled is false.' ;
    rdfs:domain ind:LiveFeed ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:streamingSubscriptionId rdf:type rdf:Property ;
    rdfs:label 'Streaming Subscription Id' ;
    rdfs:comment 'Unique surrogate identifier for each streaming subscription record. Primary key for the streaming_subscription data product within the broadcast domain.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StreamingSubscription .

ind:primaryStreamingFanFanProfileId rdf:type rdf:Property ;
    rdfs:label 'Primary Streaming Fan Fan Profile Id' ;
    rdfs:comment 'Reference to the fan/subscriber identity record in the fan domain. Links the subscription to the individual consumer. Aligns with Adobe Experience Platform fan profile.' ;
    rdfs:domain ind:StreamingSubscription ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FanProfile .

ind:acquisitionChannel rdf:type rdf:Property ;
    rdfs:label 'Acquisition Channel' ;
    rdfs:comment 'The marketing or distribution channel through which the subscriber was acquired. Used for CAC (Customer Acquisition Cost) attribution, ROI (Return on Investment) analysis, and channel performance reporting in Adobe Experience Platform. [ENUM-REF-CANDIDATE: organic|paid_search|social_media|email|partner|in_app|referral — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:StreamingSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingCycle rdf:type rdf:Property ;
    rdfs:label 'Billing Cycle' ;
    rdfs:comment 'The recurring billing frequency for the subscription. Determines how often the subscriber is charged and when renewal events are triggered in the billing system.' ;
    rdfs:domain ind:StreamingSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingCycleDay rdf:type rdf:Property ;
    rdfs:label 'Billing Cycle Day' ;
    rdfs:comment 'The day of the month (1–28) on which the recurring billing charge is processed. Used by the billing engine to schedule charge attempts and generate invoices.' ;
    rdfs:domain ind:StreamingSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:blackoutRegionCode rdf:type rdf:Property ;
    rdfs:label 'Blackout Region Code' ;
    rdfs:comment 'ISO country or region code identifying the geographic blackout restriction applied to this subscription. Enforces broadcast rights agreements and RSN (Regional Sports Network) territorial exclusivity. Null if no blackout applies.' ;
    rdfs:domain ind:StreamingSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentDataSharingFlag rdf:type rdf:Property ;
    rdfs:label 'Consent Data Sharing Flag' ;
    rdfs:comment 'Indicates whether the subscriber has consented to their viewing and behavioral data being shared with third-party analytics partners, sponsors, or league data programs. Required for GDPR Article 6 lawful basis and CCPA opt-out compliance.' ;
    rdfs:domain ind:StreamingSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:consentMarketingFlag rdf:type rdf:Property ;
    rdfs:label 'Consent Marketing Flag' ;
    rdfs:comment 'Indicates whether the subscriber has provided explicit consent to receive marketing communications related to their subscription and associated sports/entertainment content. Mandatory for GDPR and CCPA compliance in fan engagement workflows.' ;
    rdfs:domain ind:StreamingSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:consentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Consent Timestamp' ;
    rdfs:comment 'The timestamp at which the subscriber\'s consent preferences (marketing and data sharing) were last captured or updated. Required for GDPR audit trail and proof-of-consent obligations.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:downloadEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Download Enabled Flag' ;
    rdfs:comment 'Indicates whether the subscriber\'s plan tier permits offline content downloads to their device. True = downloads permitted subject to DRM expiry rules; False = streaming only. Governed by content rights windows.' ;
    rdfs:domain ind:StreamingSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:drmProfileCode rdf:type rdf:Property ;
    rdfs:label 'Drm Profile Code' ;
    rdfs:comment 'Reference to the DRM (Digital Rights Management) policy profile assigned to this subscription tier. Governs content protection, concurrent stream limits, download rights, and device binding rules enforced by the CDN (Content Delivery Network) and streaming platform.' ;
    rdfs:domain ind:StreamingSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geoCountryCode rdf:type rdf:Property ;
    rdfs:label 'Geo Country Code' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code of the subscriber\'s registered billing address. Used for geo-based rights enforcement, tax jurisdiction determination, GDPR/CCPA applicability, and regional content licensing compliance.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxVideoQuality rdf:type rdf:Property ;
    rdfs:label 'Max Video Quality' ;
    rdfs:comment 'The highest video resolution quality tier permitted under this subscription plan. Governs CDN (Content Delivery Network) stream quality caps and is a key differentiator between subscription tiers.' ;
    rdfs:domain ind:StreamingSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextBillingDate rdf:type rdf:Property ;
    rdfs:label 'Next Billing Date' ;
    rdfs:comment 'The upcoming date on which the next recurring charge will be attempted for this subscription. Used for billing forecasting, dunning management, and subscriber communications.' ;
    rdfs:domain ind:StreamingSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:partnerBundleCode rdf:type rdf:Property ;
    rdfs:label 'Partner Bundle Code' ;
    rdfs:comment 'Identifier of the third-party partner bundle or distribution agreement through which this subscription was provisioned (e.g., IPTV carrier bundle, telco partnership, OTT aggregator). Null for direct DTC subscriptions. Used for partner revenue share reporting.' ;
    rdfs:domain ind:StreamingSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planTier rdf:type rdf:Property ;
    rdfs:label 'Plan Tier' ;
    rdfs:comment 'The commercial tier of the streaming subscription defining the level of content access and features available to the subscriber. Tiers range from basic (limited content) to all-access (full DTC/OTT catalog including PPV events).' ;
    rdfs:domain ind:StreamingSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ppvAccessFlag rdf:type rdf:Property ;
    rdfs:label 'Ppv Access Flag' ;
    rdfs:comment 'Indicates whether this subscription tier includes access to PPV (Pay-Per-View) events as part of the base plan entitlement. True = PPV events included; False = PPV requires separate purchase. Critical for revenue recognition and event packaging decisions.' ;
    rdfs:domain ind:StreamingSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:promotionalRate rdf:type rdf:Property ;
    rdfs:label 'Promotional Rate' ;
    rdfs:comment 'The discounted charge amount applied during a promotional period (e.g., introductory offer, bundle discount, loyalty reward). When populated, this rate overrides the standard subscription_charge for the promotional duration.' ;
    rdfs:domain ind:StreamingSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:promotionalRateEndDate rdf:type rdf:Property ;
    rdfs:label 'Promotional Rate End Date' ;
    rdfs:comment 'The date on which the promotional pricing expires and the subscriber reverts to the standard subscription_charge. Null if no promotion is active.' ;
    rdfs:domain ind:StreamingSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:serviceType rdf:type rdf:Property ;
    rdfs:label 'Service Type' ;
    rdfs:comment 'Classifies the streaming service model under which this subscription operates. DTC (Direct-To-Consumer) = owned platform; OTT (Over-The-Top Streaming) = third-party app distribution; IPTV (Internet Protocol Television) = carrier-delivered; RSN (Regional Sports Network) = regional broadcast bundle; PPV (Pay-Per-View) = single-event purchase.' ;
    rdfs:domain ind:StreamingSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subscriptionCharge rdf:type rdf:Property ;
    rdfs:label 'Subscription Charge' ;
    rdfs:comment 'The gross recurring charge amount billed to the subscriber per billing cycle before any discounts or promotional adjustments. Expressed in the subscription currency.' ;
    rdfs:domain ind:StreamingSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:subscriptionNumber rdf:type rdf:Property ;
    rdfs:label 'Subscription Number' ;
    rdfs:comment 'Externally-visible, human-readable subscription reference number used in customer communications, billing statements, and support interactions. Sourced from the DTC/OTT platform billing system.' ;
    rdfs:domain ind:StreamingSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subscriptionStatus rdf:type rdf:Property ;
    rdfs:label 'Subscription Status' ;
    rdfs:comment 'Current lifecycle state of the streaming subscription. Drives entitlement enforcement, billing actions, and fan engagement workflows. Active = currently billable and entitled; Trialing = within a free trial window; Suspended = temporarily paused; Cancelled = subscriber-initiated termination; Expired = end date passed without renewal.' ;
    rdfs:domain ind:StreamingSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:suspensionDate rdf:type rdf:Property ;
    rdfs:label 'Suspension Date' ;
    rdfs:comment 'The date on which the subscription was placed into a suspended state (e.g., due to payment failure, voluntary pause, or compliance hold). Null if subscription has never been suspended.' ;
    rdfs:domain ind:StreamingSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:suspensionReason rdf:type rdf:Property ;
    rdfs:label 'Suspension Reason' ;
    rdfs:comment 'The reason the subscription was placed into a suspended state. Used for operational triage, dunning management, and compliance reporting. Null if subscription has never been suspended.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trialEndDate rdf:type rdf:Property ;
    rdfs:label 'Trial End Date' ;
    rdfs:comment 'The date on which the free trial period ends and the first paid billing cycle commences. Null if trial_flag is False. Critical for churn prediction and trial-to-paid conversion tracking.' ;
    rdfs:domain ind:StreamingSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:trialFlag rdf:type rdf:Property ;
    rdfs:label 'Trial Flag' ;
    rdfs:comment 'Indicates whether the subscription is currently within a free trial period. True = subscriber has not yet been charged; False = paid subscription. Used to distinguish trial cohorts from paying subscribers in ARPU (Average Revenue Per User) and LTV (Lifetime Value) analytics.' ;
    rdfs:domain ind:StreamingSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:primaryMediaEventFixtureId rdf:type rdf:Property ;
    rdfs:label 'Primary Media Event Fixture Id' ;
    rdfs:comment 'Reference to the live sports or entertainment event that this media asset was captured from or is associated with. Links the broadcast asset to the event domain for scheduling, venue, and competition context.' ;
    rdfs:domain ind:MediaAsset ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Fixture .

ind:archiveLocation rdf:type rdf:Property ;
    rdfs:label 'Archive Location' ;
    rdfs:comment 'Physical or logical storage path/URI where the media asset master file is archived (e.g., cloud object storage bucket path, SAN mount point, tape library reference). Used by the Dalet Galaxy DAM for asset retrieval and restore operations.' ;
    rdfs:domain ind:MediaAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:archiveTier rdf:type rdf:Property ;
    rdfs:label 'Archive Tier' ;
    rdfs:comment 'Storage tier classification for the media asset based on access frequency and retention requirements. Hot: frequently accessed active assets; Warm: recent but less active; Cold: infrequently accessed; Deep Archive: long-term preservation. Drives storage cost allocation and retrieval SLA.' ;
    rdfs:domain ind:MediaAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:audioChannels rdf:type rdf:Property ;
    rdfs:label 'Audio Channels' ;
    rdfs:comment 'Number of audio channels in the media asset (e.g., 2 for stereo, 6 for 5.1 surround, 8 for 7.1 surround). Required for broadcast playout compatibility and OTT audio track configuration.' ;
    rdfs:domain ind:MediaAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:blackoutRuleApplicable rdf:type rdf:Property ;
    rdfs:label 'Blackout Rule Applicable' ;
    rdfs:comment 'Indicates whether broadcast blackout rules apply to this media asset. When True, the asset is subject to geographic blackout restrictions per league media rights agreements (e.g., NFL local market blackouts, RSN territorial restrictions). Drives CDN geo-blocking logic.' ;
    rdfs:domain ind:MediaAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:broadcastDate rdf:type rdf:Property ;
    rdfs:label 'Broadcast Date' ;
    rdfs:comment 'Date on which this media asset was first broadcast or made available to audiences. Used for rights window calculations, replay eligibility, and archive classification.' ;
    rdfs:domain ind:Broadcast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:checksum rdf:type rdf:Property ;
    rdfs:label 'Checksum' ;
    rdfs:comment 'SHA-256 cryptographic checksum of the media asset master file. Used to verify file integrity during ingest, transfer, and archive operations. Ensures no corruption or unauthorized modification of broadcast master content.' ;
    rdfs:domain ind:MediaAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fileSizeMb rdf:type rdf:Property ;
    rdfs:label 'File Size Mb' ;
    rdfs:comment 'Physical file size of the media asset in megabytes. Used for storage capacity planning, archive cost allocation, and CDN transfer cost estimation.' ;
    rdfs:domain ind:MediaAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isLiveRecording rdf:type rdf:Property ;
    rdfs:label 'Is Live Recording' ;
    rdfs:comment 'Indicates whether this media asset is a live or near-live recording captured during an active broadcast event, as opposed to a pre-produced or post-produced asset. Drives priority ingest workflows and real-time CDN distribution rules.' ;
    rdfs:domain ind:MediaAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:metadataTags rdf:type rdf:Property ;
    rdfs:label 'Metadata Tags' ;
    rdfs:comment 'Comma-separated free-text metadata tags applied to the media asset for search, discovery, and content classification purposes within the Dalet Galaxy DAM (e.g., \'playoffs,overtime,game-winner,fourth-quarter\'). Supports AI/ML content recommendation and editorial search.' ;
    rdfs:domain ind:MediaAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ppvEligible rdf:type rdf:Property ;
    rdfs:label 'Ppv Eligible' ;
    rdfs:comment 'Indicates whether this media asset is eligible for Pay-Per-View (PPV) packaging and monetization. When True, the asset may be included in PPV event bundles and premium access tiers.' ;
    rdfs:domain ind:MediaAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rightsExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Rights Expiry Date' ;
    rdfs:comment 'Date on which the media rights clearance for this asset expires. After this date, the asset must be withheld from distribution pending rights renewal. Critical for automated rights enforcement and compliance with media rights agreements.' ;
    rdfs:domain ind:MediaAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:subtitleAvailable rdf:type rdf:Property ;
    rdfs:label 'Subtitle Available' ;
    rdfs:comment 'Indicates whether closed captions or subtitles are available for this media asset. Required for ADA (Americans with Disabilities Act) compliance for broadcast content and OTT platform accessibility standards.' ;
    rdfs:domain ind:MediaAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:primaryRightsEventFixtureId rdf:type rdf:Property ;
    rdfs:label 'Primary Rights Event Fixture Id' ;
    rdfs:comment 'Reference to a specific sporting event or fixture covered by this rights window. Nullable for deal-level windows that cover a season or content category rather than a single event.' ;
    rdfs:domain ind:RightsWindow ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Fixture .

ind:advertisingRightsIncluded rdf:type rdf:Property ;
    rdfs:label 'Advertising Rights Included' ;
    rdfs:comment 'Indicates whether the licensee has the right to sell advertising inventory (e.g., CPM-based ad slots) within the broadcast under this rights window. Impacts revenue share calculations and sponsorship conflict management.' ;
    rdfs:domain ind:RightsWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:broadcastWindowType rdf:type rdf:Property ;
    rdfs:label 'Broadcast Window Type' ;
    rdfs:comment 'Classifies the role of this rights window within the overall broadcast schedule. Primary windows cover live or first-run broadcasts; secondary covers repeat broadcasts; catch-up covers time-shifted viewing; archive covers library content; preview covers promotional clips.' ;
    rdfs:domain ind:RightsWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:catchupWindowDays rdf:type rdf:Property ;
    rdfs:label 'Catchup Window Days' ;
    rdfs:comment 'Number of days after the original broadcast during which the licensee may make the content available for catch-up or time-shifted viewing. Zero or null indicates no catch-up rights are granted.' ;
    rdfs:domain ind:RightsWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:conflictResolutionStatus rdf:type rdf:Property ;
    rdfs:label 'Conflict Resolution Status' ;
    rdfs:comment 'Current status of any rights conflict resolution process for this window. Populated only when rights_conflict_flag is True. Tracks progression from detection through resolution or escalation to CAS arbitration.' ;
    rdfs:domain ind:RightsWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxBroadcastCount rdf:type rdf:Property ;
    rdfs:label 'Max Broadcast Count' ;
    rdfs:comment 'The maximum number of times the content may be broadcast under this rights window. Null indicates unlimited broadcasts within the window period. Enforced by the DRM and broadcast scheduling systems.' ;
    rdfs:domain ind:RightsWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minLeadTimeHours rdf:type rdf:Property ;
    rdfs:label 'Min Lead Time Hours' ;
    rdfs:comment 'The minimum number of hours before the scheduled broadcast that the licensee must notify the rights holder or activate the content feed. Supports SLA (Service Level Agreement) compliance and OB (Outside Broadcast) logistics.' ;
    rdfs:domain ind:RightsWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rightsCategory rdf:type rdf:Property ;
    rdfs:label 'Rights Category' ;
    rdfs:comment 'Broad classification of the rights type granted in this window. Distinguishes domestic broadcast rights from international, digital, mobile, radio, PPV (Pay-Per-View), and archive rights. [ENUM-REF-CANDIDATE: domestic|international|digital|mobile|radio|ppv|archive — promote to reference product]' ;
    rdfs:domain ind:RightsWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rightsConflictFlag rdf:type rdf:Property ;
    rdfs:label 'Rights Conflict Flag' ;
    rdfs:comment 'Indicates whether a rights conflict has been detected for this window (e.g., overlapping exclusivity with another window for the same content, platform, and territory). Triggers review workflow in the rights management system.' ;
    rdfs:domain ind:RightsWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rightsFeeAllocationPct rdf:type rdf:Property ;
    rdfs:label 'Rights Fee Allocation Pct' ;
    rdfs:comment 'The percentage of the total parent deal rights fee allocated to this specific window. Enables proportional revenue recognition and financial reporting across multiple windows derived from a single deal.' ;
    rdfs:domain ind:RightsWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rightsFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Rights Fee Amount' ;
    rdfs:comment 'The monetary value of the rights fee allocated to this specific window from the parent rights deal. Represents the portion of the total deal value attributable to this platform-territory-period combination. Used for revenue recognition and financial reporting.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rightsFeeCurrency rdf:type rdf:Property ;
    rdfs:label 'Rights Fee Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the rights fee amount (e.g., USD, GBP, EUR). Required for multi-currency rights deals across global markets.' ;
    rdfs:domain ind:RightsWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:windowEnd rdf:type rdf:Property ;
    rdfs:label 'Window End' ;
    rdfs:comment 'The precise date and time (exclusive) after which the licensee\'s broadcast rights under this window expire. Nullable for perpetual or open-ended windows. Critical for automated rights expiry enforcement.' ;
    rdfs:domain ind:RightsWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:windowReferenceCode rdf:type rdf:Property ;
    rdfs:label 'Window Reference Code' ;
    rdfs:comment 'Externally-known alphanumeric business identifier for this rights window, used in contracts, invoices, and rights management systems. Enables cross-system reconciliation with SAP S/4HANA and Dalet Galaxy.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:windowStart rdf:type rdf:Property ;
    rdfs:label 'Window Start' ;
    rdfs:comment 'The precise date and time (inclusive) from which the licensee is permitted to broadcast content under this rights window. Used for real-time rights enforcement at the CDN and DRM layer.' ;
    rdfs:domain ind:RightsWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:windowStatus rdf:type rdf:Property ;
    rdfs:label 'Window Status' ;
    rdfs:comment 'Current lifecycle state of the broadcast rights window. Drives rights enforcement logic: only \'active\' windows permit broadcast. Transitions follow deal negotiation and regulatory approval workflows.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionId rdf:type rdf:Property ;
    rdfs:label 'Production Id' ;
    rdfs:comment 'Primary key for production' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Production .

ind:featuredAthleteProfileId rdf:type rdf:Property ;
    rdfs:label 'Featured Athlete Profile Id' ;
    rdfs:comment 'Foreign key linking to athlete.athlete_profile. Business justification: Broadcast productions schedule specific athletes for on-air feature segments, player profiles, and pre/post-show appearances. Production teams must coordinate athlete availability, clearances, and NIL' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AthleteProfile .

ind:productionEventFixtureId rdf:type rdf:Property ;
    rdfs:label 'Production Event Fixture Id' ;
    rdfs:comment 'Reference to the sporting or entertainment event being produced and broadcast. Connects production execution to the event domain.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Fixture .

ind:productionFixtureId rdf:type rdf:Property ;
    rdfs:label 'Production Fixture Id' ;
    rdfs:comment 'Reference to the sporting or entertainment event being produced and broadcast. Connects production execution to the event domain.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Fixture .

ind:broadcastLanguage rdf:type rdf:Property ;
    rdfs:label 'Broadcast Language' ;
    rdfs:comment 'Primary language of the broadcast commentary and production, expressed as an IETF BCP 47 language tag (e.g., \'en\', \'es\', \'fr\', \'pt-BR\'). Drives market designation and rights distribution.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:colorAnalystName rdf:type rdf:Property ;
    rdfs:label 'Color Analyst Name' ;
    rdfs:comment 'Full name of the color analyst (expert commentator) assigned to this production\'s commentary team. Tracked for talent scheduling, contract compliance, and broadcast quality.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equipmentManifestReference rdf:type rdf:Property ;
    rdfs:label 'Equipment Manifest Reference' ;
    rdfs:comment 'Reference code or document identifier for the equipment manifest associated with this production, listing all cameras, audio rigs, transmission equipment, and OB unit inventory. Sourced from Dalet Galaxy asset tracking.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:graphicsPackageVersion rdf:type rdf:Property ;
    rdfs:label 'Graphics Package Version' ;
    rdfs:comment 'Version identifier of the on-screen graphics package (lower thirds, scoreboards, transitions, sponsor overlays) deployed for this production. Critical for brand consistency and sponsor compliance.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketDesignation rdf:type rdf:Property ;
    rdfs:label 'Market Designation' ;
    rdfs:comment 'Geographic market or territory for which this production is designated (e.g., \'US-National\', \'RSN-Northeast\', \'UK\', \'LATAM-Spanish\'). Governs blackout rules, rights windows, and distribution platform routing. [ENUM-REF-CANDIDATE: promote to reference product for standardized market codes]' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:obUnitIdentifier rdf:type rdf:Property ;
    rdfs:label 'Ob Unit Identifier' ;
    rdfs:comment 'Identifier of the Outside Broadcast (OB) truck or mobile production unit deployed for remote productions. Null for studio-based productions. Critical for equipment logistics and vendor billing.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:playByPlayAnnouncer rdf:type rdf:Property ;
    rdfs:label 'Play By Play Announcer' ;
    rdfs:comment 'Full name of the primary play-by-play announcer assigned to this production\'s commentary team. Key talent assignment tracked for scheduling, NIL compliance, and audience analytics.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postshowDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Postshow Duration Minutes' ;
    rdfs:comment 'Planned duration in minutes of the post-show segment following the main event broadcast. Used for crew scheduling, sponsor slot allocation, and runsheet planning.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:preshowDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Preshow Duration Minutes' ;
    rdfs:comment 'Planned duration in minutes of the pre-show segment preceding the main event broadcast. Used for crew scheduling, sponsor slot allocation, and runsheet planning.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:productionCode rdf:type rdf:Property ;
    rdfs:label 'Production Code' ;
    rdfs:comment 'Externally-known alphanumeric code assigned by Dalet Galaxy to uniquely identify this broadcast production instance across systems and workflows. Used in runsheets, crew calls, and equipment manifests.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionStatus rdf:type rdf:Property ;
    rdfs:label 'Production Status' ;
    rdfs:comment 'Current lifecycle state of the broadcast production instance within the Dalet Galaxy workflow. \'draft\' = initial planning; \'confirmed\' = crew and equipment locked; \'in_production\' = active pre-show or live execution; \'on_air\' = currently broadcasting; \'completed\' = post-production wrap; \'cancelled\' = production cancelled.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:replayAvailabilityTimestamp rdf:type rdf:Property ;
    rdfs:label 'Replay Availability Timestamp' ;
    rdfs:comment 'Date and time when replay or VOD content for this production becomes available to viewers on designated platforms. Null if replay_content_available is false. Governs rights window compliance.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:replayContentAvailable rdf:type rdf:Property ;
    rdfs:label 'Replay Content Available' ;
    rdfs:comment 'Indicates whether replay/VOD content will be made available following the live broadcast of this production. Drives post-production workflow initiation and rights window activation in the content domain.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sidelineReporterName rdf:type rdf:Property ;
    rdfs:label 'Sideline Reporter Name' ;
    rdfs:comment 'Full name of the sideline reporter assigned to this production. May be null for studio-only productions. Tracked for talent scheduling and credential management.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signalFormat rdf:type rdf:Property ;
    rdfs:label 'Signal Format' ;
    rdfs:comment 'Technical broadcast signal format used for this production (e.g., HD, 4K, 8K, SD, HDR). Determines equipment requirements, CDN bandwidth allocation, and platform delivery specifications.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sponsorBillboardCount rdf:type rdf:Property ;
    rdfs:label 'Sponsor Billboard Count' ;
    rdfs:comment 'Number of sponsor billboard/branding slots allocated within this production\'s broadcast runsheet. Used for sponsorship fulfillment tracking and CPM reporting.' ;
    rdfs:domain ind:Production ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryAudienceAssetId rdf:type rdf:Property ;
    rdfs:label 'Primary Audience Asset Id' ;
    rdfs:comment 'Reference to the content asset or media item that was broadcast during the measured window, enabling rights valuation and scheduling optimization.' ;
    rdfs:domain ind:AudienceRating ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Asset .

ind:amaViewers rdf:type rdf:Property ;
    rdfs:label 'Ama Viewers' ;
    rdfs:comment 'Average Minute Audience — the average number of viewers watching at any given minute during the broadcast window. The industry-standard linear TV metric used for GRP (Gross Rating Point) calculation and advertiser CPM (Cost Per Mille) pricing.' ;
    rdfs:domain ind:AudienceRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:audienceGuaranteeTarget rdf:type rdf:Property ;
    rdfs:label 'Audience Guarantee Target' ;
    rdfs:comment 'Contractually committed minimum audience size (total viewers) for this broadcast window as specified in the media rights or advertising agreement. Used for contractual audience guarantee reconciliation against actual total_viewers. Confidential as it reflects negotiated contract terms.' ;
    rdfs:domain ind:AudienceRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:avgViewingDurationMins rdf:type rdf:Property ;
    rdfs:label 'Avg Viewing Duration Mins' ;
    rdfs:comment 'Average number of minutes each viewer spent watching the broadcast during the measurement window. Used for audience engagement analysis, content scheduling optimization, and streaming platform retention reporting.' ;
    rdfs:domain ind:AudienceRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:blackoutApplied rdf:type rdf:Property ;
    rdfs:label 'Blackout Applied' ;
    rdfs:comment 'Indicates whether a broadcast blackout rule was in effect for this territory during the measurement window. Blackout rules are contractual restrictions in media rights agreements that limit broadcast in specific markets. Affects audience measurement scope.' ;
    rdfs:domain ind:AudienceRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contentGenre rdf:type rdf:Property ;
    rdfs:label 'Content Genre' ;
    rdfs:comment 'Genre classification of the broadcast content (e.g., Live Sport, Sports News, Sports Documentary, Concert, Esports, Magazine Show). Used for scheduling optimization and audience segmentation analysis. [ENUM-REF-CANDIDATE: Live Sport|Sports News|Sports Documentary|Concert|Esports|Magazine Show|Highlights|Other — promote to reference product]' ;
    rdfs:domain ind:AudienceRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:demoAgeBand rdf:type rdf:Property ;
    rdfs:label 'Demo Age Band' ;
    rdfs:comment 'Age band of the primary target demographic for this audience measurement record. Standard age groupings used by Nielsen and BARB for advertiser targeting and rate card segmentation (e.g., Adults 18-49 is the primary US broadcast demographic).' ;
    rdfs:domain ind:AudienceRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:demoGender rdf:type rdf:Property ;
    rdfs:label 'Demo Gender' ;
    rdfs:comment 'Gender segment of the audience demographic breakdown for this measurement record. Used for targeted advertising rate card differentiation and sponsor demographic guarantee reporting.' ;
    rdfs:domain ind:AudienceRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:demoIncomeBand rdf:type rdf:Property ;
    rdfs:label 'Demo Income Band' ;
    rdfs:comment 'Household income band of the measured audience segment (e.g., Under $50K, $50K-$100K, $100K-$150K, $150K+). Used for premium advertiser targeting and sponsorship package valuation. [ENUM-REF-CANDIDATE: Under $50K|$50K-$100K|$100K-$150K|$150K-$200K|$200K+ — promote to reference product]' ;
    rdfs:domain ind:AudienceRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:demoViewersCount rdf:type rdf:Property ;
    rdfs:label 'Demo Viewers Count' ;
    rdfs:comment 'Number of viewers within the specific demographic segment (age band, gender, income band) defined for this record. Enables granular demographic reporting for advertiser guarantee reconciliation.' ;
    rdfs:domain ind:AudienceRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:drmProtected rdf:type rdf:Property ;
    rdfs:label 'Drm Protected' ;
    rdfs:comment 'Indicates whether the broadcast content was delivered with DRM (Digital Rights Management) protection active during the measurement window. Relevant for OTT and IPTV platform compliance and piracy impact assessment on audience figures.' ;
    rdfs:domain ind:AudienceRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:grpValue rdf:type rdf:Property ;
    rdfs:label 'Grp Value' ;
    rdfs:comment 'Gross Rating Point value for this broadcast window, representing the sum of ratings across the target audience. Calculated as rating_pct multiplied by frequency. Primary currency for advertising inventory pricing and sponsorship valuation.' ;
    rdfs:domain ind:AudienceRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:guaranteeMet rdf:type rdf:Property ;
    rdfs:label 'Guarantee Met' ;
    rdfs:comment 'Indicates whether the actual audience (total_viewers) met or exceeded the contractual audience guarantee target for this broadcast window. Drives make-good advertising inventory decisions and rights agreement penalty calculations.' ;
    rdfs:domain ind:AudienceRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:liveViewers rdf:type rdf:Property ;
    rdfs:label 'Live Viewers' ;
    rdfs:comment 'Number of viewers who watched the broadcast in real-time (live) as opposed to time-shifted. Distinguishes live audience from time-shifted for PPV event reporting and live sports rights valuation.' ;
    rdfs:domain ind:AudienceRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:marketName rdf:type rdf:Property ;
    rdfs:label 'Market Name' ;
    rdfs:comment 'Name of the designated market area (DMA) or broadcast market within the territory (e.g., New York DMA, London ITV Region, Sydney Metro). Used for sub-national audience reporting and RSN rate card justification.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementReferenceCode rdf:type rdf:Property ;
    rdfs:label 'Measurement Reference Code' ;
    rdfs:comment 'Externally-known unique identifier assigned by the measurement provider (e.g., Nielsen panel ID, BARB survey code, OzTAM report reference, Comscore stream ID) for cross-system reconciliation.' ;
    rdfs:domain ind:AudienceRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementSource rdf:type rdf:Property ;
    rdfs:label 'Measurement Source' ;
    rdfs:comment 'The third-party or internal system that provided the audience measurement data. Determines methodology, panel composition, and credibility for advertiser and rights negotiations. [ENUM-REF-CANDIDATE: Nielsen|BARB|OzTAM|Comscore|Internal Streaming Analytics|Other — promote to reference product if additional sources are onboarded]' ;
    rdfs:domain ind:AudienceRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:peakConcurrentViewers rdf:type rdf:Property ;
    rdfs:label 'Peak Concurrent Viewers' ;
    rdfs:comment 'Maximum number of viewers simultaneously watching the broadcast at any single minute during the window. Key metric for streaming platform capacity planning, CDN (Content Delivery Network) provisioning, and PPV event valuation.' ;
    rdfs:domain ind:AudienceRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ratingPct rdf:type rdf:Property ;
    rdfs:label 'Rating Pct' ;
    rdfs:comment 'Percentage of the total universe of TV households or individuals that watched the broadcast, regardless of whether their TV was on. Distinct from share_pct which is based only on those actively viewing. Used for GRP (Gross Rating Point) calculation.' ;
    rdfs:domain ind:AudienceRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ratingType rdf:type rdf:Property ;
    rdfs:label 'Rating Type' ;
    rdfs:comment 'Classification of the audience measurement metric captured in this record. GRP (Gross Rating Point) represents total delivery; CPM (Cost Per Mille) supports advertiser rate card justification; Reach measures unique audience; Frequency measures average exposures; AMA (Average Minute Audience) is the standard linear TV metric; Share is the percentage of viewing universe. [ENUM-REF-CANDIDATE: GRP|CPM|Reach|Frequency|Viewership|AMA|Share — promote to reference product]' ;
    rdfs:domain ind:AudienceRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reach rdf:type rdf:Property ;
    rdfs:label 'Reach' ;
    rdfs:comment 'Total number of unique individuals who viewed at least one minute of the broadcast during the measured window. Distinct from total_viewers which may count repeat viewing. Used for unduplicated audience reporting to sponsors and rights holders.' ;
    rdfs:domain ind:AudienceRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sharePct rdf:type rdf:Property ;
    rdfs:label 'Share Pct' ;
    rdfs:comment 'Percentage of the total viewing universe (all households/individuals with TV/streaming access) that watched this broadcast during the window. Expressed as a decimal percentage (e.g., 12.500 = 12.5%). Core metric for competitive scheduling analysis.' ;
    rdfs:domain ind:AudienceRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:timeShiftedViewers rdf:type rdf:Property ;
    rdfs:label 'Time Shifted Viewers' ;
    rdfs:comment 'Number of viewers who watched the broadcast on a time-shifted basis (DVR, catch-up, VOD replay) within the measurement window. Reported separately per Nielsen Live+3 and Live+7 standards for contractual audience guarantee reconciliation.' ;
    rdfs:domain ind:AudienceRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalViewers rdf:type rdf:Property ;
    rdfs:label 'Total Viewers' ;
    rdfs:comment 'Total number of individual viewers who watched the broadcast during the measured window. The primary headline metric used in media rights negotiations, advertiser rate cards, and contractual audience guarantees.' ;
    rdfs:domain ind:AudienceRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:universeSize rdf:type rdf:Property ;
    rdfs:label 'Universe Size' ;
    rdfs:comment 'Total size of the viewing universe (total TV households or individuals) used as the denominator for rating_pct and share_pct calculations in the given territory and demographic. Provided by the measurement source.' ;
    rdfs:domain ind:AudienceRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:windowEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Window End Timestamp' ;
    rdfs:comment 'The precise date and time when the measured broadcast window ended. Combined with window_start_timestamp to define the exact measurement interval for AMA and share calculations.' ;
    rdfs:domain ind:AudienceRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:windowStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Window Start Timestamp' ;
    rdfs:comment 'The precise date and time when the measured broadcast window began, in ISO 8601 format with timezone offset. Used as the principal business event timestamp for scheduling optimization and rights valuation.' ;
    rdfs:domain ind:AudienceRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:preferredFranchiseId rdf:type rdf:Property ;
    rdfs:label 'Preferred Franchise Id' ;
    rdfs:comment 'Foreign key linking to league.franchise. Business justification: Fan CRM segmentation, personalization engines, and targeted marketing campaigns depend on knowing a fan\'s preferred franchise. Sports-entertainment CRM systems universally store preferred team as a FK' ;
    rdfs:domain ind:FanProfile ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Franchise .

ind:preferredVenueId rdf:type rdf:Property ;
    rdfs:label 'Preferred Venue Id' ;
    rdfs:comment 'Foreign key linking to venue.venue. Business justification: CRM personalization and fan segmentation reports require a proper FK to the preferred venue. fan_profile.preferred_venue is a denormalized plain-text field; replacing it with preferred_venue_id enforc' ;
    rdfs:domain ind:Fan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Venue .

ind:accessibilityRequirements rdf:type rdf:Property ;
    rdfs:label 'Accessibility Requirements' ;
    rdfs:comment 'Free-text description of any accessibility needs or disability accommodations required by the fan for venue attendance (e.g., wheelchair access, hearing loop, visual impairment assistance). Used by venue operations to fulfill Americans with Disabilities Act (ADA) obligations.' ;
    rdfs:domain ind:FanProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:aepProfileReference rdf:type rdf:Property ;
    rdfs:label 'Aep Profile Reference' ;
    rdfs:comment 'Unified profile identifier assigned by Adobe Experience Platform for fan engagement, personalization, and analytics. Enables cross-channel identity resolution.' ;
    rdfs:domain ind:FanProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:birthDate rdf:type rdf:Property ;
    rdfs:label 'Birth Date' ;
    rdfs:comment 'Fan\'s date of birth in ISO 8601 format (yyyy-MM-dd). Used for age verification, age-gated content access, birthday promotions, and demographic segmentation.' ;
    rdfs:domain ind:FanProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ccpaApplicable rdf:type rdf:Property ;
    rdfs:label 'Ccpa Applicable' ;
    rdfs:comment 'Indicates whether the fan is subject to California Consumer Privacy Act (CCPA) requirements based on their state of residence. Drives opt-out of sale rights and California-specific data handling procedures.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:communicationOptInEmail rdf:type rdf:Property ;
    rdfs:label 'Communication Opt In Email' ;
    rdfs:comment 'Indicates whether the fan has provided explicit consent to receive marketing and promotional communications via email. Must be True before any commercial email is sent. Governed by GDPR Article 6 and CAN-SPAM Act.' ;
    rdfs:domain ind:FanProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:communicationOptInPush rdf:type rdf:Property ;
    rdfs:label 'Communication Opt In Push' ;
    rdfs:comment 'Indicates whether the fan has consented to receive push notifications via the mobile application. Controls delivery of real-time event alerts, score updates, and personalized offers.' ;
    rdfs:domain ind:FanProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:communicationOptInSms rdf:type rdf:Property ;
    rdfs:label 'Communication Opt In Sms' ;
    rdfs:comment 'Indicates whether the fan has provided explicit consent to receive marketing and transactional communications via SMS/text message. Governed by GDPR Article 6 and TCPA regulations.' ;
    rdfs:domain ind:FanProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:consentCaptureDate rdf:type rdf:Property ;
    rdfs:label 'Consent Capture Date' ;
    rdfs:comment 'Date on which the fan\'s most recent privacy consent preferences were recorded. Required for GDPR and CCPA audit trails to demonstrate lawful basis for data processing.' ;
    rdfs:domain ind:FanProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:consentVersion rdf:type rdf:Property ;
    rdfs:label 'Consent Version' ;
    rdfs:comment 'Version identifier of the privacy policy and consent notice that the fan agreed to at the time of consent capture. Enables compliance teams to identify fans who need re-consent when policies are updated.' ;
    rdfs:domain ind:Fan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countryOfResidenceCode rdf:type rdf:Property ;
    rdfs:label 'Country Of Residence Code' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code for the fan\'s current country of residence. Determines applicable privacy regulations (GDPR for EU residents, CCPA for California residents) and geo-targeted content.' ;
    rdfs:domain ind:FanProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crmSegmentCode rdf:type rdf:Property ;
    rdfs:label 'Crm Segment Code' ;
    rdfs:comment 'CRM segmentation code assigned to the fan based on behavioral, demographic, and transactional attributes. Used for targeted marketing campaigns, personalized offers, and Lifetime Value (LTV) optimization. Managed in Salesforce CRM.' ;
    rdfs:domain ind:FanProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSharingConsent rdf:type rdf:Property ;
    rdfs:label 'Data Sharing Consent' ;
    rdfs:comment 'Indicates whether the fan has consented to sharing their personal data with third-party partners, sponsors, and advertisers. Required for sponsor activation and targeted advertising programs.' ;
    rdfs:domain ind:FanProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:displayName rdf:type rdf:Property ;
    rdfs:label 'Display Name' ;
    rdfs:comment 'Preferred public-facing name or username chosen by the fan for use on digital platforms, fan clubs, and engagement channels. May differ from legal name.' ;
    rdfs:domain ind:FanProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:email rdf:type rdf:Property ;
    rdfs:label 'Email' ;
    rdfs:comment 'Primary email address used for all fan communications, account authentication, ticketing confirmations, and CRM outreach. Subject to GDPR and CCPA consent requirements.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fanType rdf:type rdf:Property ;
    rdfs:label 'Fan Type' ;
    rdfs:comment 'Classification of the fan account type. Determines applicable business rules, pricing tiers, and service levels. \'family_account\' indicates a parent account with linked sub-profiles. \'vip\' denotes Very Important Person (VIP) status with premium service entitlements.' ;
    rdfs:domain ind:FanProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gender rdf:type rdf:Property ;
    rdfs:label 'Gender' ;
    rdfs:comment 'Self-reported gender identity of the fan. Used for demographic analytics, personalization, and inclusive marketing. Collected with explicit consent per GDPR and CCPA.' ;
    rdfs:domain ind:FanProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isSeasonTicketHolder rdf:type rdf:Property ;
    rdfs:label 'Is Season Ticket Holder' ;
    rdfs:comment 'Indicates whether the fan currently holds an active season ticket for any league or team. Season ticket holders receive priority access, dedicated account management, and exclusive benefits.' ;
    rdfs:domain ind:FanProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isVipMember rdf:type rdf:Property ;
    rdfs:label 'Is Vip Member' ;
    rdfs:comment 'Indicates whether the fan holds active Very Important Person (VIP) membership status, entitling them to premium hospitality, backstage access, and dedicated concierge services.' ;
    rdfs:domain ind:FanProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastEngagementDate rdf:type rdf:Property ;
    rdfs:label 'Last Engagement Date' ;
    rdfs:comment 'Date of the fan\'s most recent engagement activity across any channel (ticket purchase, content view, merchandise order, event attendance, app interaction). Used for recency scoring in CRM segmentation and churn risk models.' ;
    rdfs:domain ind:FanProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastLoginTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Login Timestamp' ;
    rdfs:comment 'Timestamp of the fan\'s most recent authenticated login to any digital platform (web, mobile app, OTT). Used for engagement recency scoring, dormancy detection, and re-engagement campaign targeting.' ;
    rdfs:domain ind:Fan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:loyaltyEnrollmentDate rdf:type rdf:Property ;
    rdfs:label 'Loyalty Enrollment Date' ;
    rdfs:comment 'Date on which the fan enrolled in the loyalty program. Used to calculate program tenure, anniversary rewards, and cohort-based retention analytics.' ;
    rdfs:domain ind:FanProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:loyaltyPointsBalance rdf:type rdf:Property ;
    rdfs:label 'Loyalty Points Balance' ;
    rdfs:comment 'Current unredeemed loyalty points balance for the fan. Points are earned through ticket purchases, merchandise, event attendance, and digital engagement. Used to determine redemption eligibility.' ;
    rdfs:domain ind:Fan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:loyaltyTier rdf:type rdf:Property ;
    rdfs:label 'Loyalty Tier' ;
    rdfs:comment 'Current tier level within the fan loyalty program. Determines reward multipliers, exclusive access privileges, and personalized offers. Tier is recalculated periodically based on engagement and spend activity.' ;
    rdfs:domain ind:Fan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:npsSurveyDate rdf:type rdf:Property ;
    rdfs:label 'Nps Survey Date' ;
    rdfs:comment 'Date on which the most recent Net Promoter Score (NPS) survey response was captured. Used to determine recency of sentiment data and schedule follow-up surveys.' ;
    rdfs:domain ind:Fan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:phone rdf:type rdf:Property ;
    rdfs:label 'Phone' ;
    rdfs:comment 'Primary mobile or landline phone number for the fan in E.164 international format. Used for SMS notifications, two-factor authentication, and event alerts.' ;
    rdfs:domain ind:FanProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredLanguageCode rdf:type rdf:Property ;
    rdfs:label 'Preferred Language Code' ;
    rdfs:comment 'IETF BCP 47 language tag representing the fan\'s preferred language for communications, digital platform content, and customer service interactions (e.g., \'en-US\', \'es-MX\', \'fr-FR\').' ;
    rdfs:domain ind:Fan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredSport rdf:type rdf:Property ;
    rdfs:label 'Preferred Sport' ;
    rdfs:comment 'The sport or sports property the fan most closely identifies with (e.g., \'NFL Football\', \'NBA Basketball\', \'MLS Soccer\', \'UFC\'). Used for content personalization, targeted promotions, and event recommendations. Free-text to accommodate multi-sport organizations.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationChannel rdf:type rdf:Property ;
    rdfs:label 'Registration Channel' ;
    rdfs:comment 'The channel through which the fan originally registered their account. Used for acquisition analytics, channel attribution, and Direct-To-Consumer (DTC) strategy reporting.' ;
    rdfs:domain ind:Fan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredTeamId rdf:type rdf:Property ;
    rdfs:label 'Preferred Team Id' ;
    rdfs:comment 'Reference to the fan\'s primary supported team or franchise. Used for personalized content delivery, targeted marketing, and team-specific loyalty benefit routing. Sourced from fan registration preference or CRM profile.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Team .

ind:cardBrand rdf:type rdf:Property ;
    rdfs:label 'Card Brand' ;
    rdfs:comment 'Brand of the default payment card on file (e.g., Visa, Mastercard, Amex). Non-sensitive card metadata retained for display and routing purposes. Does not constitute PAN or sensitive authentication data under PCI-DSS.' ;
    rdfs:domain ind:Fan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cardExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Card Expiry Date' ;
    rdfs:comment 'Expiration date of the default payment card on file. Used to proactively notify fans of upcoming card expiry and prompt payment method updates before renewal or purchase failures occur.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cardLastFour rdf:type rdf:Property ;
    rdfs:label 'Card Last Four' ;
    rdfs:comment 'Last four digits of the default payment card on file. Retained as permitted truncated PAN under PCI-DSS for fan-facing display and customer service verification. Does not constitute full PAN.' ;
    rdfs:domain ind:Fan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ccpaOptOutFlag rdf:type rdf:Property ;
    rdfs:label 'Ccpa Opt Out Flag' ;
    rdfs:comment 'Indicates whether the fan has exercised their CCPA right to opt out of the sale or sharing of personal information. True when the fan has submitted a Do Not Sell or Share request. Drives data sharing suppression for California-resident accounts.' ;
    rdfs:domain ind:Fan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:consentRecordedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Consent Recorded Timestamp' ;
    rdfs:comment 'Timestamp at which the fan\'s most recent consent preferences were recorded or last updated. Used as the audit timestamp for GDPR and CCPA consent records. Required for demonstrating lawful basis of processing under GDPR Article 7.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:crmAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Crm Account Number' ;
    rdfs:comment 'Externally-known alphanumeric account number assigned by Salesforce CRM. Used as the business-facing identifier on correspondence, ticketing portals, and fan-facing digital platforms. Serves as the BUSINESS_IDENTIFIER for this MASTER_AGREEMENT entity.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currency rdf:type rdf:Property ;
    rdfs:label 'Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code representing the fan\'s preferred transaction currency (e.g., USD, GBP, EUR, AUD). Used for pricing display, ticketing transactions, and merchandise purchases on the fan\'s account.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataResidencyCountry rdf:type rdf:Property ;
    rdfs:label 'Data Residency Country' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code indicating the jurisdiction in which the fan\'s personal data must be stored and processed. Drives data residency enforcement, GDPR adequacy decisions, and cross-border transfer controls.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defaultPaymentFlag rdf:type rdf:Property ;
    rdfs:label 'Default Payment Flag' ;
    rdfs:comment 'Indicates whether the stored payment instrument is designated as the default payment method for this account. True when this is the primary instrument used for automated renewals, loyalty redemptions, and one-click purchases.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:language rdf:type rdf:Property ;
    rdfs:label 'Language' ;
    rdfs:comment 'BCP 47 language tag representing the fan\'s preferred language for communications and digital platform content (e.g., en-US, es-MX, fr-FR, pt-BR). Used for localized content delivery, email template selection, and multilingual customer service routing.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loginFailureCount rdf:type rdf:Property ;
    rdfs:label 'Login Failure Count' ;
    rdfs:comment 'Number of consecutive failed login attempts since the last successful authentication. Used to trigger account lockout policies per security standards. Resets to zero upon successful login. Sourced from Salesforce CRM identity management.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:loyaltyPointsYtdEarned rdf:type rdf:Property ;
    rdfs:label 'Loyalty Points Ytd Earned' ;
    rdfs:comment 'Total loyalty points earned by the fan account in the current calendar or fiscal year. Used for annual tier qualification thresholds and year-end loyalty reporting. Resets at the start of each program year.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:marketingEmailOptInFlag rdf:type rdf:Property ;
    rdfs:label 'Marketing Email Opt In Flag' ;
    rdfs:comment 'Indicates whether the fan has opted in to receive marketing and promotional email communications. True when explicit opt-in consent has been recorded. Used by CRM to control email campaign eligibility and suppression lists.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:membershipNumber rdf:type rdf:Property ;
    rdfs:label 'Membership Number' ;
    rdfs:comment 'Unique alphanumeric membership identifier printed on physical or digital membership cards. Used for in-venue access control, loyalty redemption at Point of Sale (POS), and fan-facing account lookup. Distinct from crm_account_number — this is the fan-visible card number.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mfaEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Mfa Enabled Flag' ;
    rdfs:comment 'Indicates whether Multi-Factor Authentication (MFA) is currently enabled on the fan account. True when the fan has enrolled a second authentication factor (e.g., SMS OTP, authenticator app). Used for security compliance reporting and risk-based access control.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:passwordLastChangedDate rdf:type rdf:Property ;
    rdfs:label 'Password Last Changed Date' ;
    rdfs:comment 'Date on which the fan last changed their account password. Used for security policy enforcement, forced password rotation reminders, and breach response workflows. Does not store the password itself — credential metadata only.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pciPaymentToken rdf:type rdf:Property ;
    rdfs:label 'Pci Payment Token' ;
    rdfs:comment 'PCI-DSS compliant tokenized representation of the fan\'s default payment instrument on file. The token is issued by the payment processor and replaces the actual card number (PAN). Never stores raw card data. Used for recurring purchases, loyalty redemptions, and ticketing transactions.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryEmail rdf:type rdf:Property ;
    rdfs:label 'Primary Email' ;
    rdfs:comment 'Primary email address associated with the fan account, used for login authentication, transactional notifications, and marketing communications. Subject to GDPR and CCPA consent requirements. Sourced from Salesforce CRM Account email field.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryPhone rdf:type rdf:Property ;
    rdfs:label 'Primary Phone' ;
    rdfs:comment 'Primary contact phone number for the fan account in E.164 international format. Used for two-factor authentication (2FA), SMS notifications, and customer service outreach. Subject to GDPR and CCPA consent requirements.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pushNotificationOptInFlag rdf:type rdf:Property ;
    rdfs:label 'Push Notification Opt In Flag' ;
    rdfs:comment 'Indicates whether the fan has enabled push notifications on the mobile app. True when the fan has granted notification permissions. Used for real-time event alerts, score updates, and personalized offers via Adobe Experience Platform.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:seasonTicketHolderFlag rdf:type rdf:Property ;
    rdfs:label 'Season Ticket Holder Flag' ;
    rdfs:comment 'Indicates whether the fan account holds at least one active season ticket package for the current season. True when one or more season ticket entitlements are linked to this account. Used for priority access, renewal campaigns, and season ticket holder benefit eligibility.' ;
    rdfs:domain ind:Fan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:smsOptInFlag rdf:type rdf:Property ;
    rdfs:label 'Sms Opt In Flag' ;
    rdfs:comment 'Indicates whether the fan has opted in to receive SMS/text message marketing communications. True when explicit opt-in consent has been recorded. Required for TCPA compliance in the US and equivalent regulations in other jurisdictions.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:username rdf:type rdf:Property ;
    rdfs:label 'Username' ;
    rdfs:comment 'Unique login username chosen by the fan for digital platform authentication. Used across web, mobile app, and OTT (Over-The-Top Streaming) platforms. Must be unique across all active accounts. Sourced from Salesforce CRM identity management.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vipFlag rdf:type rdf:Property ;
    rdfs:label 'Vip Flag' ;
    rdfs:comment 'Indicates whether the fan account is designated as a Very Important Person (VIP), qualifying for premium hospitality, dedicated concierge services, and exclusive event access. Set by CRM administrators based on spend thresholds or manual designation.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:accessTierRequired rdf:type rdf:Property ;
    rdfs:label 'Access Tier Required' ;
    rdfs:comment 'The minimum membership tier within the loyalty program that a fan must hold in order to access this content asset. Belongs to the entitlement, not to the program or asset alone, because the same asset may require different tiers under different programs.' ;
    rdfs:domain ind:LoyaltyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crmProgramReference rdf:type rdf:Property ;
    rdfs:label 'Crm Program Reference' ;
    rdfs:comment 'External identifier for this loyalty program as recorded in Salesforce CRM. Used for cross-system reconciliation between the lakehouse Silver layer and the Salesforce CRM operational system of record. Enables audit traceability back to the source system.' ;
    rdfs:domain ind:LoyaltyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currencyName rdf:type rdf:Property ;
    rdfs:label 'Currency Name' ;
    rdfs:comment 'Branded name of the loyalty currency unit used within this program (e.g., \'Fan Points\', \'Arena Credits\', \'Court Cash\', \'Ice Coins\'). Displayed to fans in all engagement touchpoints and digital wallet interfaces.' ;
    rdfs:domain ind:LoyaltyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currencySymbol rdf:type rdf:Property ;
    rdfs:label 'Currency Symbol' ;
    rdfs:comment 'Short symbol or abbreviation representing the loyalty currency in UI displays and statements (e.g., \'FP\', \'AC\', \'pts\'). Used in fan-facing digital platforms and printed membership materials.' ;
    rdfs:domain ind:LoyaltyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:digitalWalletEnabled rdf:type rdf:Property ;
    rdfs:label 'Digital Wallet Enabled' ;
    rdfs:comment 'Indicates whether loyalty currency balances for this program are accessible via a digital wallet interface in the fan mobile app or OTT platform. Drives integration with Adobe Experience Platform digital wallet features and DTC fan engagement flows.' ;
    rdfs:domain ind:LoyaltyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:earningPeriodType rdf:type rdf:Property ;
    rdfs:label 'Earning Period Type' ;
    rdfs:comment 'Defines the time window used for the max_earning_per_period cap. Season aligns with the sports league calendar; calendar_year resets on January 1; rolling_12_months is a continuous window; monthly resets each calendar month.' ;
    rdfs:domain ind:LoyaltyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:earningRulesSummary rdf:type rdf:Property ;
    rdfs:label 'Earning Rules Summary' ;
    rdfs:comment 'Human-readable summary of the rules governing how fans earn loyalty currency (e.g., \'1 point per $1 spent on tickets; 2x points on merchandise; 5x points on PPV purchases\'). Operational detail is managed in the loyalty_earning_rule reference product; this field provides a concise program-level description for reporting and fan communications.' ;
    rdfs:domain ind:LoyaltyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentChannel rdf:type rdf:Property ;
    rdfs:label 'Enrollment Channel' ;
    rdfs:comment 'Primary channel through which fans enroll in this loyalty program. Web and mobile_app channels are DTC digital; venue_kiosk and POS (Point of Sale) are in-venue; crm_agent enrollments are processed by Salesforce CRM agents; partner enrollments originate from co-branded or coalition partners.' ;
    rdfs:domain ind:Fan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exclusiveWindowEnd rdf:type rdf:Property ;
    rdfs:label 'Exclusive Window End' ;
    rdfs:comment 'Calendar date on which the exclusivity period for this content asset under this loyalty program ends. After this date the asset may become available more broadly or under other programs.' ;
    rdfs:domain ind:LoyaltyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:exclusiveWindowStart rdf:type rdf:Property ;
    rdfs:label 'Exclusive Window Start' ;
    rdfs:comment 'Calendar date on which this content asset becomes exclusively available to members of this loyalty program. Defines the start of the exclusivity period during which the asset is gated to this program\'s members only.' ;
    rdfs:domain ind:LoyaltyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isAutoEnroll rdf:type rdf:Property ;
    rdfs:label 'Is Auto Enroll' ;
    rdfs:comment 'Indicates whether fans are automatically enrolled in this program upon meeting eligibility criteria (e.g., purchasing a season ticket or subscribing to an OTT streaming service) without requiring an explicit opt-in action. True = automatic enrollment; False = explicit opt-in required.' ;
    rdfs:domain ind:LoyaltyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPaidMembership rdf:type rdf:Property ;
    rdfs:label 'Is Paid Membership' ;
    rdfs:comment 'Indicates whether enrollment in this loyalty program requires a recurring or one-time membership fee. True = fee-based program (e.g., premium fan club subscription); False = free-to-join program. Drives billing integration with SAP S/4HANA SD module.' ;
    rdfs:domain ind:LoyaltyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:launchMarket rdf:type rdf:Property ;
    rdfs:label 'Launch Market' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the primary market in which this loyalty program was launched (e.g., \'USA\', \'GBR\', \'CAN\', \'AUS\'). Used for regulatory compliance scoping, market performance reporting, and multi-market program governance.' ;
    rdfs:domain ind:LoyaltyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loyaltyProgramStatus rdf:type rdf:Property ;
    rdfs:label 'Loyalty Program Status' ;
    rdfs:comment 'Current lifecycle state of the loyalty program. Active programs accept new enrollments and transactions; draft programs are in design/approval; suspended programs are temporarily halted; retired programs are closed to new activity but historical records are preserved.' ;
    rdfs:domain ind:LoyaltyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxEarningPerPeriod rdf:type rdf:Property ;
    rdfs:label 'Max Earning Per Period' ;
    rdfs:comment 'Cap on the total loyalty currency units a fan can earn within a defined period (e.g., per season, per calendar year). Controls program financial liability and prevents gaming. Null if no periodic earning cap is defined.' ;
    rdfs:domain ind:LoyaltyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxEarningPerTransaction rdf:type rdf:Property ;
    rdfs:label 'Max Earning Per Transaction' ;
    rdfs:comment 'Cap on the number of loyalty currency units a fan can earn from a single transaction (e.g., ticket purchase, merchandise order, PPV event). Prevents abuse and controls program liability. Null if no per-transaction cap is defined.' ;
    rdfs:domain ind:LoyaltyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:membershipFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Membership Fee Amount' ;
    rdfs:comment 'Annual or periodic membership fee charged to fans for enrollment in paid loyalty programs. Expressed in the program\'s operating currency. Null for free-to-join programs where is_paid_membership = False. Used in SAP S/4HANA FI/CO revenue recognition.' ;
    rdfs:domain ind:Fan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:membershipFeeCurrency rdf:type rdf:Property ;
    rdfs:label 'Membership Fee Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the membership fee amount (e.g., \'USD\', \'GBP\', \'EUR\', \'CAD\'). Required for multi-market programs operating across global leagues and venues.' ;
    rdfs:domain ind:Fan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:membershipFeeFrequency rdf:type rdf:Property ;
    rdfs:label 'Membership Fee Frequency' ;
    rdfs:comment 'Billing frequency for the loyalty program membership fee. Annual and seasonal fees align with sports league calendars; monthly fees support subscription-style DTC programs; one_time fees apply to lifetime memberships. Null for free programs.' ;
    rdfs:domain ind:Fan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:merchandiseRedemptionEnabled rdf:type rdf:Property ;
    rdfs:label 'Merchandise Redemption Enabled' ;
    rdfs:comment 'Indicates whether fans can redeem loyalty currency for merchandise purchases through the Shopify Plus e-commerce platform. When True, the program is integrated with Shopify Plus SKU catalog for redemption workflows.' ;
    rdfs:domain ind:LoyaltyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:minRedemptionThreshold rdf:type rdf:Property ;
    rdfs:label 'Min Redemption Threshold' ;
    rdfs:comment 'Minimum accumulated loyalty currency balance required before a fan is eligible to redeem points or credits. Prevents micro-redemptions and controls operational overhead (e.g., minimum 500 Fan Points before redemption is permitted).' ;
    rdfs:domain ind:LoyaltyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:npsTrackingEnabled rdf:type rdf:Property ;
    rdfs:label 'Nps Tracking Enabled' ;
    rdfs:comment 'Indicates whether Net Promoter Score (NPS) surveys are triggered for fans enrolled in this loyalty program. When True, NPS survey workflows are activated in Adobe Experience Platform following key engagement events such as event attendance or redemption.' ;
    rdfs:domain ind:LoyaltyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:partnerProgramFlag rdf:type rdf:Property ;
    rdfs:label 'Partner Program Flag' ;
    rdfs:comment 'Indicates whether this loyalty program is operated in partnership with an external sponsor or coalition partner (e.g., co-branded credit card loyalty, airline miles partner, retail partner). True = partner-operated or co-branded; False = wholly owned by Sports Entertainment.' ;
    rdfs:domain ind:LoyaltyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pointsCost rdf:type rdf:Property ;
    rdfs:label 'Points Cost' ;
    rdfs:comment 'Number of loyalty currency units a fan must spend to unlock access to this content asset under this specific loyalty program. Belongs to the entitlement because the same asset may carry different points costs across different programs.' ;
    rdfs:domain ind:LoyaltyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pointsExpiryPolicy rdf:type rdf:Property ;
    rdfs:label 'Points Expiry Policy' ;
    rdfs:comment 'Policy governing when accumulated loyalty currency expires for enrolled fans. Rolling policies expire points a fixed period after earning; annual_reset clears balances at a calendar year boundary; event_based expiry ties to specific events such as season end; no_expiry means points never expire.' ;
    rdfs:domain ind:LoyaltyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ppvEarningEnabled rdf:type rdf:Property ;
    rdfs:label 'Ppv Earning Enabled' ;
    rdfs:comment 'Indicates whether fans earn loyalty currency on Pay-Per-View (PPV) broadcast purchases. When True, PPV transactions from the broadcast platform are eligible for loyalty point accrual, driving cross-domain fan engagement between broadcast and loyalty.' ;
    rdfs:domain ind:LoyaltyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:programCode rdf:type rdf:Property ;
    rdfs:label 'Program Code' ;
    rdfs:comment 'Externally-known alphanumeric business identifier for the loyalty program used in CRM, ticketing, and digital platform integrations (e.g., \'NBA_FANPTS_2024\', \'ARENA_CREDITS_VIP\'). Sourced from Salesforce CRM program catalog.' ;
    rdfs:domain ind:LoyaltyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programDescription rdf:type rdf:Property ;
    rdfs:label 'Program Description' ;
    rdfs:comment 'Full marketing and operational description of the loyalty program including its value proposition, target fan segment, and key benefits. Used in Adobe Experience Platform content personalization, CRM campaign materials, and fan-facing digital platforms.' ;
    rdfs:domain ind:LoyaltyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programName rdf:type rdf:Property ;
    rdfs:label 'Program Name' ;
    rdfs:comment 'Human-readable marketing name of the loyalty program as displayed to fans across all channels (e.g., \'Fan Points Rewards\', \'Arena Credits Club\', \'Season Ticket Holder Elite\'). Used in Adobe Experience Platform personalization and fan-facing communications.' ;
    rdfs:domain ind:LoyaltyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programType rdf:type rdf:Property ;
    rdfs:label 'Program Type' ;
    rdfs:comment 'Classification of the loyalty program structure. Points-based programs award redeemable points per transaction; tier-based programs unlock benefits at spend thresholds; hybrid combines both; subscription requires recurring fee; coalition programs span multiple partner brands.' ;
    rdfs:domain ind:LoyaltyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programVersion rdf:type rdf:Property ;
    rdfs:label 'Program Version' ;
    rdfs:comment 'Integer version number tracking major structural changes to the loyalty program rules, tier definitions, or earning/redemption rates. Incremented when program terms materially change. Supports historical analysis of program evolution and fan communication of rule changes.' ;
    rdfs:domain ind:LoyaltyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:redemptionRate rdf:type rdf:Property ;
    rdfs:label 'Redemption Rate' ;
    rdfs:comment 'Monetary value of one loyalty currency unit when redeemed (e.g., 0.01 means 1 Fan Point = $0.01 USD). Used to calculate redemption value in fan-facing statements and in SAP S/4HANA FI liability accounting for outstanding points balances.' ;
    rdfs:domain ind:LoyaltyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:redemptionRulesSummary rdf:type rdf:Property ;
    rdfs:label 'Redemption Rules Summary' ;
    rdfs:comment 'Human-readable summary of the rules governing how fans redeem accumulated loyalty currency (e.g., \'100 points = $1 off ticket purchase; minimum 500 points to redeem; valid on GA and VIP tickets\'). Operational detail is managed in the loyalty_redemption_rule reference product.' ;
    rdfs:domain ind:LoyaltyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scopeType rdf:type rdf:Property ;
    rdfs:label 'Scope Type' ;
    rdfs:comment 'Defines the organizational scope at which the loyalty program operates. League-scoped programs apply across all teams in a league; venue-scoped programs are specific to a single arena or stadium; team-scoped programs are tied to a single franchise; digital_platform programs operate exclusively on OTT or DTC channels; multi-property programs span multiple business units.' ;
    rdfs:domain ind:LoyaltyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetFanSegment rdf:type rdf:Property ;
    rdfs:label 'Target Fan Segment' ;
    rdfs:comment 'CRM-defined fan segment or audience profile that this loyalty program is designed to serve (e.g., \'Season Ticket Holders\', \'VIP Members\', \'Casual Fans\', \'Family Accounts\', \'Digital-Only Subscribers\'). Drives Adobe Experience Platform audience targeting and Salesforce CRM campaign segmentation.' ;
    rdfs:domain ind:LoyaltyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ticketRedemptionEnabled rdf:type rdf:Property ;
    rdfs:label 'Ticket Redemption Enabled' ;
    rdfs:comment 'Indicates whether fans can redeem loyalty currency toward ticket purchases or upgrades through Ticketmaster/AXS or Archtics. When True, the program is integrated with the ticketing platform redemption API.' ;
    rdfs:domain ind:LoyaltyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tierCount rdf:type rdf:Property ;
    rdfs:label 'Tier Count' ;
    rdfs:comment 'Number of distinct membership tiers defined within this loyalty program (e.g., 3 for Bronze/Silver/Gold; 4 for Standard/Plus/Elite/VIP). Applicable for tier_based and hybrid program types. Zero or null for pure points-based programs with no tier structure.' ;
    rdfs:domain ind:LoyaltyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:homeTeamId rdf:type rdf:Property ;
    rdfs:label 'Home Team Id' ;
    rdfs:comment 'Reference to the fan\'s primary affiliated team within the loyalty program context. Used to route team-specific rewards, communications, and event access offers.' ;
    rdfs:domain ind:LoyaltyEnrollment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Team .

ind:primaryLoyaltyFanProfileId rdf:type rdf:Property ;
    rdfs:label 'Primary Loyalty Fan Profile Id' ;
    rdfs:comment 'Reference to the fan profile record representing the individual enrolled in the loyalty program. Sourced from Salesforce CRM fan master.' ;
    rdfs:domain ind:Fan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FanProfile .

ind:tertiaryLoyaltyReferredByFanFanProfileId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Loyalty Referred By Fan Fan Profile Id' ;
    rdfs:comment 'The fan ID of the existing loyalty member who referred this fan to the program. Used to credit referral bonuses and track viral growth of the loyalty program.' ;
    rdfs:domain ind:LoyaltyEnrollment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FanProfile .

ind:autoRenewalEnabled rdf:type rdf:Property ;
    rdfs:label 'Auto Renewal Enabled' ;
    rdfs:comment 'Indicates whether the fan has opted in to automatic renewal of their loyalty membership at the end of the current enrollment period. Drives renewal billing and communication workflows.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ccpaOptOut rdf:type rdf:Property ;
    rdfs:label 'Ccpa Opt Out' ;
    rdfs:comment 'Indicates whether the fan has exercised their California Consumer Privacy Act (CCPA) right to opt out of the sale or sharing of their personal data associated with this loyalty enrollment.' ;
    rdfs:domain ind:Fan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:currentPointsBalance rdf:type rdf:Property ;
    rdfs:label 'Current Points Balance' ;
    rdfs:comment 'The fan\'s current redeemable points balance available for redemption against rewards, merchandise, tickets, or experiences. Reflects earned points minus redeemed and expired points.' ;
    rdfs:domain ind:LoyaltyEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:currentTier rdf:type rdf:Property ;
    rdfs:label 'Current Tier' ;
    rdfs:comment 'The fan\'s current membership tier within the loyalty program (e.g., Bronze, Silver, Gold, Platinum, Diamond). Tier determines reward multipliers, exclusive access rights, and benefit eligibility. [ENUM-REF-CANDIDATE: Bronze|Silver|Gold|Platinum|Diamond — promote to reference product if tiers vary by program]' ;
    rdfs:domain ind:LoyaltyEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentNumber rdf:type rdf:Property ;
    rdfs:label 'Enrollment Number' ;
    rdfs:comment 'Externally visible alphanumeric reference code assigned to this enrollment at the time of registration. Used on fan-facing communications, membership cards, and CRM lookups. Format: LYL- followed by 8–16 alphanumeric characters.' ;
    rdfs:domain ind:LoyaltyEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentStatus rdf:type rdf:Property ;
    rdfs:label 'Enrollment Status' ;
    rdfs:comment 'Current lifecycle state of the fan\'s enrollment in the loyalty program. \'active\' indicates the fan is in good standing and accruing/redeeming points; \'suspended\' indicates a temporary hold; \'terminated\' indicates the enrollment has been permanently closed; \'pending\' indicates awaiting verification; \'expired\' indicates the enrollment lapsed due to inactivity or tier expiry.' ;
    rdfs:domain ind:LoyaltyEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Enrollment Timestamp' ;
    rdfs:comment 'Precise date and time (with timezone offset) at which the fan\'s enrollment was recorded in the source system. Supports intraday analytics and audit trail requirements.' ;
    rdfs:domain ind:Fan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:fanClubMember rdf:type rdf:Property ;
    rdfs:label 'Fan Club Member' ;
    rdfs:comment 'Indicates whether the fan is also a registered fan club member in conjunction with this loyalty enrollment. Fan club membership may confer additional points multipliers or exclusive content access.' ;
    rdfs:domain ind:LoyaltyEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gdprConsentGiven rdf:type rdf:Property ;
    rdfs:label 'Gdpr Consent Given' ;
    rdfs:comment 'Indicates whether the fan has provided explicit GDPR-compliant consent for the processing of their personal data in connection with this loyalty enrollment. Mandatory for fans in EU jurisdictions.' ;
    rdfs:domain ind:LoyaltyEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPrimaryEnrollment rdf:type rdf:Property ;
    rdfs:label 'Is Primary Enrollment' ;
    rdfs:comment 'Indicates whether this enrollment is the fan\'s primary or preferred loyalty program when the fan holds multiple enrollments. Used for default display, primary benefit application, and CRM segmentation.' ;
    rdfs:domain ind:LoyaltyEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lifetimePointsEarned rdf:type rdf:Property ;
    rdfs:label 'Lifetime Points Earned' ;
    rdfs:comment 'Cumulative total of all loyalty points earned by the fan since enrollment inception, regardless of redemptions or expirations. Used as a long-term engagement metric and for Lifetime Value (LTV) analysis.' ;
    rdfs:domain ind:LoyaltyEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:membershipCardIssuedDate rdf:type rdf:Property ;
    rdfs:label 'Membership Card Issued Date' ;
    rdfs:comment 'The date on which the loyalty membership card (physical or digital) was issued to the fan. Used for card lifecycle management and replacement tracking.' ;
    rdfs:domain ind:LoyaltyEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:membershipCardNumber rdf:type rdf:Property ;
    rdfs:label 'Membership Card Number' ;
    rdfs:comment 'The physical or digital membership card number issued to the fan for this loyalty enrollment. Used for venue access, Point of Sale (POS) identification, and reward redemption. Classified as confidential PII as it uniquely identifies the fan.' ;
    rdfs:domain ind:LoyaltyEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextTierPointsRequired rdf:type rdf:Property ;
    rdfs:label 'Next Tier Points Required' ;
    rdfs:comment 'Number of additional qualifying points the fan needs to earn to reach the next loyalty tier. Supports personalized upgrade progress communications and fan engagement nudges.' ;
    rdfs:domain ind:LoyaltyEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pointsCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Points Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code representing the monetary currency associated with points valuation for programs that peg points to a currency equivalent (e.g., USD, GBP, EUR). Null for pure point-based programs with no currency peg.' ;
    rdfs:domain ind:LoyaltyEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pointsExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Points Expiry Date' ;
    rdfs:comment 'The date on which the fan\'s current redeemable points balance will expire if not redeemed. Used to trigger expiry warning communications and drive redemption activity.' ;
    rdfs:domain ind:Fan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:preferredRewardCategory rdf:type rdf:Property ;
    rdfs:label 'Preferred Reward Category' ;
    rdfs:comment 'The fan\'s stated or inferred preferred category for loyalty reward redemption (e.g., tickets, merchandise, experiences). Used for personalized reward recommendations and program design analytics.' ;
    rdfs:domain ind:LoyaltyEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:previousTier rdf:type rdf:Property ;
    rdfs:label 'Previous Tier' ;
    rdfs:comment 'The fan\'s loyalty tier immediately prior to the most recent tier change. Used for win-back campaigns, downgrade communications, and tier transition analytics.' ;
    rdfs:domain ind:LoyaltyEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referralSourceCode rdf:type rdf:Property ;
    rdfs:label 'Referral Source Code' ;
    rdfs:comment 'Campaign or referral code used at the time of enrollment to attribute the fan\'s sign-up to a specific marketing campaign, partner promotion, or referral event. Supports Customer Acquisition Cost (CAC) and Return on Investment (ROI) analysis.' ;
    rdfs:domain ind:LoyaltyEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalDate rdf:type rdf:Property ;
    rdfs:label 'Renewal Date' ;
    rdfs:comment 'The date on which the fan\'s loyalty enrollment is scheduled for renewal. Used to trigger renewal reminders, billing events, and lapse prevention campaigns.' ;
    rdfs:domain ind:Fan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:seasonTicketHolder rdf:type rdf:Property ;
    rdfs:label 'Season Ticket Holder' ;
    rdfs:comment 'Indicates whether the fan enrolled in this loyalty program is also a season ticket holder. Season ticket holders typically receive enhanced tier benefits and accelerated points earning rates.' ;
    rdfs:domain ind:LoyaltyEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tierChangeReason rdf:type rdf:Property ;
    rdfs:label 'Tier Change Reason' ;
    rdfs:comment 'The business reason for the most recent change to the fan\'s loyalty tier. Supports audit trails, fan communications, and program governance reporting.' ;
    rdfs:domain ind:LoyaltyEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tierExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Tier Expiry Date' ;
    rdfs:comment 'The date on which the fan\'s current tier status expires if qualifying activity thresholds are not maintained. After this date, the fan may be downgraded to a lower tier per program rules.' ;
    rdfs:domain ind:LoyaltyEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:tierQualificationDate rdf:type rdf:Property ;
    rdfs:label 'Tier Qualification Date' ;
    rdfs:comment 'The date on which the fan qualified for their current loyalty tier. Used to determine tier anniversary, tier protection windows, and downgrade eligibility assessments.' ;
    rdfs:domain ind:LoyaltyEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:tierQualifyingPointsYtd rdf:type rdf:Property ;
    rdfs:label 'Tier Qualifying Points Ytd' ;
    rdfs:comment 'Points accumulated within the current qualification period (typically a rolling 12-month or calendar year window) that count toward tier maintenance or upgrade thresholds. Distinct from redeemable balance.' ;
    rdfs:domain ind:LoyaltyEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:vipStatus rdf:type rdf:Property ;
    rdfs:label 'Vip Status' ;
    rdfs:comment 'Indicates whether the fan holds Very Important Person (VIP) designation within this loyalty enrollment, granting access to premium experiences, hospitality suites, and exclusive events.' ;
    rdfs:domain ind:LoyaltyEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:loyaltyTransactionId rdf:type rdf:Property ;
    rdfs:label 'Loyalty Transaction Id' ;
    rdfs:comment 'Unique surrogate identifier for each loyalty point transaction record in the ledger. Primary key for the loyalty_transaction data product.' ;
    rdfs:domain ind:LoyaltyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:engagementEventId rdf:type rdf:Property ;
    rdfs:label 'Engagement Event Id' ;
    rdfs:comment 'Reference to the sports or entertainment event associated with this loyalty transaction (e.g., the game or concert at which a check-in was recorded or a ticket was purchased). Enables event-level loyalty analytics and attendance-based point attribution.' ;
    rdfs:domain ind:Fan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EngagementEvent .

ind:reversalOfTransactionLoyaltyTransactionId rdf:type rdf:Property ;
    rdfs:label 'Reversal Of Transaction Loyalty Transaction Id' ;
    rdfs:comment 'Self-referencing identifier pointing to the original loyalty transaction that this record reverses or corrects. Null for original transactions. Enables full audit chain reconstruction for reversed or adjusted point movements.' ;
    rdfs:domain ind:LoyaltyTransaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LoyaltyTransaction .

ind:tertiaryLoyaltyTransferTargetFanFanProfileId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Loyalty Transfer Target Fan Fan Profile Id' ;
    rdfs:comment 'For transfer-type transactions, the fan profile ID of the recipient who receives the transferred points. Null for all non-transfer transaction types. Supports family account and fan-to-fan transfer tracking.' ;
    rdfs:domain ind:LoyaltyTransaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FanProfile .

ind:wagerId rdf:type rdf:Property ;
    rdfs:label 'Wager Id' ;
    rdfs:comment 'Foreign key linking to gaming.wager. Business justification: Loyalty points earned on wagers: when a bettor earns loyalty points for placing a wager, the loyalty transaction must reference the originating wager for points calculation audit, dispute resolution, ' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Wager .

ind:activityChannel rdf:type rdf:Property ;
    rdfs:label 'Activity Channel' ;
    rdfs:comment 'The engagement channel through which the triggering activity was performed. Distinguishes between mobile app, web portal, venue Point of Sale (POS) terminal, call center, or partner system. Supports omnichannel loyalty analytics and channel attribution.' ;
    rdfs:domain ind:LoyaltyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:activityType rdf:type rdf:Property ;
    rdfs:label 'Activity Type' ;
    rdfs:comment 'The specific fan activity that triggered this loyalty transaction. Identifies the business action that caused the point movement, enabling activity-level analytics and program ROI measurement. [ENUM-REF-CANDIDATE: ticket_purchase|merchandise_purchase|event_check_in|content_view|referral|social_share|survey_completion|app_login|ppv_purchase|subscription_renewal — promote to reference product]' ;
    rdfs:domain ind:LoyaltyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:basePointsAmount rdf:type rdf:Property ;
    rdfs:label 'Base Points Amount' ;
    rdfs:comment 'The raw points amount calculated before any multiplier, bonus, or promotional adjustment is applied. Together with points_multiplier and points_amount, provides a full audit trail of the points calculation logic.' ;
    rdfs:domain ind:LoyaltyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isBonusTransaction rdf:type rdf:Property ;
    rdfs:label 'Is Bonus Transaction' ;
    rdfs:comment 'Indicates whether this transaction represents a bonus points award outside of the standard earn rate (e.g., birthday bonus, milestone bonus, welcome bonus, special event bonus). True = bonus transaction; False = standard transaction. Supports bonus program analytics and cost tracking.' ;
    rdfs:domain ind:LoyaltyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isTierQualifying rdf:type rdf:Property ;
    rdfs:label 'Is Tier Qualifying' ;
    rdfs:comment 'Indicates whether the points from this transaction count toward the fan\'s tier qualification threshold (some programs separate qualifying points from total points). True = counts toward tier qualification; False = does not count (e.g., bonus or promotional points). Supports tier progression analytics.' ;
    rdfs:domain ind:LoyaltyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:monetaryValue rdf:type rdf:Property ;
    rdfs:label 'Monetary Value' ;
    rdfs:comment 'The monetary spend amount (in the operating currency) associated with the triggering activity for this transaction. Used to calculate earn rates (points per dollar spent) and to measure the financial value of loyalty-driving purchases. Applicable for purchase-triggered transactions.' ;
    rdfs:domain ind:LoyaltyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pointsAmount rdf:type rdf:Property ;
    rdfs:label 'Points Amount' ;
    rdfs:comment 'The number of loyalty points earned, redeemed, adjusted, expired, or transferred in this transaction. Positive values represent points added to the balance; negative values represent points deducted. Decimal precision supports fractional point awards from multiplier promotions.' ;
    rdfs:domain ind:LoyaltyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pointsBalanceAfter rdf:type rdf:Property ;
    rdfs:label 'Points Balance After' ;
    rdfs:comment 'The fan\'s total loyalty point balance immediately after this transaction was applied. Provides a running ledger balance for audit trail purposes and enables point balance reconstruction at any point in time without aggregation.' ;
    rdfs:domain ind:LoyaltyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pointsMultiplier rdf:type rdf:Property ;
    rdfs:label 'Points Multiplier' ;
    rdfs:comment 'The multiplier factor applied to the base points calculation for this transaction, driven by membership tier, active promotions, or special event bonuses. A value of 1.00 indicates no multiplier; 2.00 indicates double points. Supports audit of why a fan received a specific points amount.' ;
    rdfs:domain ind:LoyaltyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:processingDate rdf:type rdf:Property ;
    rdfs:label 'Processing Date' ;
    rdfs:comment 'The calendar date on which the loyalty transaction was processed and applied to the fan\'s balance by the loyalty management system. May differ from transaction_timestamp for batch-processed or delayed-confirmation transactions (e.g., post-event check-in reconciliation).' ;
    rdfs:domain ind:LoyaltyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:redemptionValue rdf:type rdf:Property ;
    rdfs:label 'Redemption Value' ;
    rdfs:comment 'The monetary equivalent value of the points redeemed in this transaction, expressed in the operating currency. Populated only for redemption-type transactions. Used for loyalty liability accounting, reward cost tracking, and EBITDA impact analysis.' ;
    rdfs:domain ind:LoyaltyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reversalReason rdf:type rdf:Property ;
    rdfs:label 'Reversal Reason' ;
    rdfs:comment 'Free-text or coded explanation for why a transaction was reversed or adjusted. Populated only when transaction_status is \'reversed\' or transaction_type is \'adjust\'. Supports audit compliance and customer service resolution tracking.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceTransactionReference rdf:type rdf:Property ;
    rdfs:label 'Source Transaction Reference' ;
    rdfs:comment 'The native transaction identifier from the originating source system (e.g., Ticketmaster order number, Shopify order ID, SAP document number). Enables cross-system reconciliation and traceability back to the system of record.' ;
    rdfs:domain ind:LoyaltyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tierQualifyingPoints rdf:type rdf:Property ;
    rdfs:label 'Tier Qualifying Points' ;
    rdfs:comment 'The number of points from this transaction that count specifically toward the fan\'s tier qualification balance, which may differ from the total points_amount when bonus or promotional points are excluded from tier calculations.' ;
    rdfs:domain ind:LoyaltyTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:acquisitionPromotionId rdf:type rdf:Property ;
    rdfs:label 'Acquisition Promotion Id' ;
    rdfs:comment 'Foreign key linking to merchandise.promotion. Business justification: Membership acquisition promotions (e.g., \'buy membership, get merch discount\') must be tracked for retention analytics and promotion ROI reporting. Sports operators need to know which promotional offe' ;
    rdfs:domain ind:Membership ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Promotion .

ind:assignedSeatId rdf:type rdf:Property ;
    rdfs:label 'Assigned Seat Id' ;
    rdfs:comment 'Foreign key linking to venue.seat. Business justification: Season ticket membership management requires tracking the specific assigned seat for each member — core to seat manifest reconciliation, ADA compliance reporting, and renewal/relocation workflows. Rol' ;
    rdfs:domain ind:Membership ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Seat .

ind:exclusiveContentCollectionId rdf:type rdf:Property ;
    rdfs:label 'Exclusive Content Collection Id' ;
    rdfs:comment 'Foreign key linking to content.collection. Business justification: Membership content entitlement: sports entertainment memberships (VIP, season ticket holder) include access to exclusive content collections (behind-the-scenes, member-only video vaults). This FK supp' ;
    rdfs:domain ind:Membership ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Collection .

ind:membershipCorporateAccountId rdf:type rdf:Property ;
    rdfs:label 'Membership Corporate Account Id' ;
    rdfs:comment 'Reference to the corporate account record in Salesforce CRM when is_corporate is True. Links individual membership seats to the parent corporate purchaser for consolidated billing and reporting.' ;
    rdfs:domain ind:Membership ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Account .

ind:membershipFamilyAccountId rdf:type rdf:Property ;
    rdfs:label 'Membership Family Account Id' ;
    rdfs:comment 'Reference to the family account grouping record when this membership is part of a family plan. Enables consolidated family membership management, shared benefit pools, and family-level reporting.' ;
    rdfs:domain ind:Membership ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Account .

ind:membershipFanFanProfileId rdf:type rdf:Property ;
    rdfs:label 'Membership Fan Fan Profile Id' ;
    rdfs:comment 'Reference to the fan profile record that holds this membership. Links the membership contractual record to the fan identity master in the Salesforce CRM fan domain.' ;
    rdfs:domain ind:Membership ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FanProfile .

ind:membershipFanProfileId rdf:type rdf:Property ;
    rdfs:label 'Membership Fan Profile Id' ;
    rdfs:comment 'Reference to the fan profile record that holds this membership. Links the membership contractual record to the fan identity master in the Salesforce CRM fan domain.' ;
    rdfs:domain ind:Membership ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FanProfile .

ind:accessTier rdf:type rdf:Property ;
    rdfs:label 'Access Tier' ;
    rdfs:comment 'The tier level at which this membership is permitted to access the zone. Determines the scope of privileges within the zone (e.g., a VIP membership may have a higher access tier than a standard season ticket in the same zone). Belongs to the grant, not to the membership or zone alone.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:autoRenewFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Renew Flag' ;
    rdfs:comment 'Indicates whether the membership is configured to automatically renew at the end of the current term without requiring explicit fan action. Drives automated billing cycles in SAP S/4HANA FI and renewal notifications in Adobe Experience Platform.' ;
    rdfs:domain ind:Membership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:credentialType rdf:type rdf:Property ;
    rdfs:label 'Credential Type' ;
    rdfs:comment 'The credential format required to exercise this specific zone access grant for this membership. May differ from the zone\'s default credential_type_required when a membership tier is granted an override credential method. Belongs to the grant, not to the zone alone.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exclusiveContentFlag rdf:type rdf:Property ;
    rdfs:label 'Exclusive Content Flag' ;
    rdfs:comment 'Indicates whether this membership grants access to exclusive digital content (behind-the-scenes footage, member-only streams, editorial content) via OTT (Over-The-Top Streaming) or DTC (Direct-To-Consumer) platforms.' ;
    rdfs:domain ind:Membership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fee rdf:type rdf:Property ;
    rdfs:label 'Fee' ;
    rdfs:comment 'Gross fee amount charged to the fan for the membership per payment frequency cycle, in the operating currency. Represents the contractual price before any discounts or waivers. Used in revenue recognition and EBITDA reporting.' ;
    rdfs:domain ind:Membership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:grantStatus rdf:type rdf:Property ;
    rdfs:label 'Grant Status' ;
    rdfs:comment 'Current lifecycle status of this zone access grant. Allows individual membership-zone permissions to be suspended or revoked independently of the membership status or zone status — e.g., revoking field-level access for a member under investigation without cancelling their full membership.' ;
    rdfs:domain ind:Membership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCorporate rdf:type rdf:Property ;
    rdfs:label 'Is Corporate' ;
    rdfs:comment 'Indicates whether this membership is held under a corporate account (B2B) rather than an individual fan (B2C). Corporate memberships may have different billing, benefit allocation, and compliance requirements.' ;
    rdfs:domain ind:Membership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isVip rdf:type rdf:Property ;
    rdfs:label 'Is Vip' ;
    rdfs:comment 'Indicates whether this membership grants VIP (Very Important Person) status, entitling the fan to premium hospitality, lounge access, and priority services. Distinct from membership_tier — a flag used operationally for real-time access control at venues.' ;
    rdfs:domain ind:Membership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:loungeAccessFlag rdf:type rdf:Property ;
    rdfs:label 'Lounge Access Flag' ;
    rdfs:comment 'Indicates whether this membership grants access to VIP (Very Important Person) lounge facilities at the venue. Operationally consumed by Ticketmaster/AXS access control and venue operations teams.' ;
    rdfs:domain ind:Membership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:marketingOptInFlag rdf:type rdf:Property ;
    rdfs:label 'Marketing Opt In Flag' ;
    rdfs:comment 'Indicates whether the member has opted in to receive marketing communications (email, SMS, push notifications) from the organization. Distinct from GDPR consent — this governs direct marketing specifically. Consumed by Adobe Experience Platform campaign orchestration.' ;
    rdfs:domain ind:Membership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:meetGreetAllotment rdf:type rdf:Property ;
    rdfs:label 'Meet Greet Allotment' ;
    rdfs:comment 'Number of meet-and-greet experiences allocated to this membership per season or membership term. Zero indicates no meet-and-greet benefit. Used for experience inventory management and fan engagement reporting.' ;
    rdfs:domain ind:Membership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:membershipStatus rdf:type rdf:Property ;
    rdfs:label 'Membership Status' ;
    rdfs:comment 'Current lifecycle state of the membership agreement. Drives access control decisions in Ticketmaster/AXS, benefit eligibility checks, and CRM segmentation in Salesforce. Serves as the LIFECYCLE_STATUS for this MASTER_AGREEMENT entity.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:membershipTier rdf:type rdf:Property ;
    rdfs:label 'Membership Tier' ;
    rdfs:comment 'Benefit tier level within a membership type, defining the package of perks and privileges available to the fan (e.g., Bronze through Diamond for VIP club memberships). Drives benefit entitlement rules and pricing.' ;
    rdfs:domain ind:Fan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:membershipType rdf:type rdf:Property ;
    rdfs:label 'Membership Type' ;
    rdfs:comment 'Classification of the membership product tier. Distinguishes paid contractual relationships (season ticket holder, VIP club, fan club, OTT subscription, corporate) from complimentary grants. Drives benefit package assignment and revenue reporting. Serves as the CLASSIFICATION_OR_TYPE for this MASTER_AGREEMENT entity.' ;
    rdfs:domain ind:Membership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:merchandiseDiscountPct rdf:type rdf:Property ;
    rdfs:label 'Merchandise Discount Pct' ;
    rdfs:comment 'Percentage discount on merchandise purchases granted to the member as part of their benefit package. Applied at point of sale in Shopify Plus e-commerce and venue POS (Point of Sale) systems.' ;
    rdfs:domain ind:Fan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netFee rdf:type rdf:Property ;
    rdfs:label 'Net Fee' ;
    rdfs:comment 'Actual fee payable by the fan after applying discounts and waivers (membership_fee minus discount_amount). Used for revenue recognition, accounts receivable, and fan-facing billing statements.' ;
    rdfs:domain ind:Membership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:parkingPassFlag rdf:type rdf:Property ;
    rdfs:label 'Parking Pass Flag' ;
    rdfs:comment 'Indicates whether a parking pass benefit is included in this membership. Drives parking inventory allocation in venue operations and access control at parking facilities.' ;
    rdfs:domain ind:Membership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:paymentPlanFlag rdf:type rdf:Property ;
    rdfs:label 'Payment Plan Flag' ;
    rdfs:comment 'Indicates whether the fan is on an installment payment plan rather than paying the full membership fee upfront. Drives installment schedule management in SAP S/4HANA FI and Ticketmaster/AXS.' ;
    rdfs:domain ind:Membership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priorityTicketingFlag rdf:type rdf:Property ;
    rdfs:label 'Priority Ticketing Flag' ;
    rdfs:comment 'Indicates whether this membership grants priority access to ticket purchases before general public on-sale dates. Operationally consumed by Ticketmaster/AXS pre-sale access control.' ;
    rdfs:domain ind:Membership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:seatBlockReference rdf:type rdf:Property ;
    rdfs:label 'Seat Block Reference' ;
    rdfs:comment 'Reference to the assigned seat block or seating inventory allocation associated with this membership (e.g., season ticket seat section/row/seat range). Sourced from Archtics venue seating and inventory management system.' ;
    rdfs:domain ind:Membership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:validUntil rdf:type rdf:Property ;
    rdfs:label 'Valid Until' ;
    rdfs:comment 'Calendar date on which this zone access grant expires. Enables time-bounded access permissions independent of the membership end date (e.g., field-level access only during playoffs). Belongs to the grant, not to the membership or zone alone.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waitlistFlag rdf:type rdf:Property ;
    rdfs:label 'Waitlist Flag' ;
    rdfs:comment 'Indicates whether this membership record represents a fan on the waitlist for a sold-out membership tier (e.g., season ticket waitlist). Waitlisted records have membership_status of pending_activation until inventory becomes available.' ;
    rdfs:domain ind:Membership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:waitlistPosition rdf:type rdf:Property ;
    rdfs:label 'Waitlist Position' ;
    rdfs:comment 'Numeric position of the fan on the membership waitlist when waitlist_flag is True. Lower numbers indicate higher priority for membership offer. Null when not on waitlist.' ;
    rdfs:domain ind:Membership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:zoneAccessLevel rdf:type rdf:Property ;
    rdfs:label 'Zone Access Level' ;
    rdfs:comment 'The specific level of access within the zone granted to this membership — e.g., entry-only vs. full access vs. escorted access only. Varies per membership-zone combination and belongs to the grant record.' ;
    rdfs:domain ind:Membership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSegmentId rdf:type rdf:Property ;
    rdfs:label 'Source Segment Id' ;
    rdfs:comment 'Native identifier of this segment in the originating source system (e.g., Adobe Experience Platform audience GUID or Salesforce CRM campaign segment ID). Enables traceability and reconciliation between the lakehouse Silver Layer and the operational CRM/CDP systems.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Segment .

ind:targetTeamId rdf:type rdf:Property ;
    rdfs:label 'Target Team Id' ;
    rdfs:comment 'Identifier of the specific team or franchise associated with this segment. Enables team-level fan segmentation for localized marketing, merchandise promotions, and event-specific campaigns.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Team .

ind:ageBandMax rdf:type rdf:Property ;
    rdfs:label 'Age Band Max' ;
    rdfs:comment 'Maximum age (in years) of fans included in this segment. Used in conjunction with age_band_min to define a demographic age range for targeted campaigns. Nullable if no upper age bound is defined.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ageBandMin rdf:type rdf:Property ;
    rdfs:label 'Age Band Min' ;
    rdfs:comment 'Minimum age (in years) of fans included in this segment when demographic segmentation is applied. Used for age-gated content, alcohol sponsorship campaigns, and youth-specific engagement programs. Supports ADA and child privacy compliance.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:channelApplicability rdf:type rdf:Property ;
    rdfs:label 'Channel Applicability' ;
    rdfs:comment 'Comma-separated list of marketing and engagement channels for which this segment is activated (e.g., \'email, push_notification, sms, in_app, paid_social, display\'). Guides campaign execution teams on appropriate activation channels. [ENUM-REF-CANDIDATE: email|push_notification|sms|in_app|paid_social|display|direct_mail — promote to reference product]' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentRequirement rdf:type rdf:Property ;
    rdfs:label 'Consent Requirement' ;
    rdfs:comment 'Specifies the consent basis required for fans to be included in this segment and activated for marketing. Explicit consent is required for GDPR-regulated EU fans; legitimate interest may apply for certain analytics use cases. Ensures compliance with GDPR and CCPA.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:definitionCriteria rdf:type rdf:Property ;
    rdfs:label 'Definition Criteria' ;
    rdfs:comment 'Structured or semi-structured expression of the business rules and logic used to qualify fans into this segment (e.g., SQL predicate, JSON rule set, or natural-language description of inclusion/exclusion criteria). Sourced from Adobe Experience Platform segment builder or Salesforce CRM campaign filter logic.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:definitionFormat rdf:type rdf:Property ;
    rdfs:label 'Definition Format' ;
    rdfs:comment 'Format of the definition_criteria field, indicating how the segment logic is expressed. PQL refers to Adobe Experience Platform Profile Query Language. Enables downstream systems to parse and execute the segment definition correctly.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engagementScoreMax rdf:type rdf:Property ;
    rdfs:label 'Engagement Score Max' ;
    rdfs:comment 'Maximum fan engagement score for inclusion in this segment. Used in conjunction with engagement_score_min to define a score band for precise audience targeting. Nullable if no upper bound is defined.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:engagementScoreMin rdf:type rdf:Property ;
    rdfs:label 'Engagement Score Min' ;
    rdfs:comment 'Minimum fan engagement score required for inclusion in this segment, as calculated by Adobe Experience Platform. Engagement scores reflect fan interaction frequency, recency, and depth across digital and physical touchpoints.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fanCount rdf:type rdf:Property ;
    rdfs:label 'Fan Count' ;
    rdfs:comment 'Number of fan profiles qualifying for this segment as of the last refresh date. Represents the segment size used for campaign reach estimation, budget planning, and audience reporting. Not a real-time count — reflects the most recent batch evaluation.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isDtcEligible rdf:type rdf:Property ;
    rdfs:label 'Is Dtc Eligible' ;
    rdfs:comment 'Indicates whether this segment is approved for Direct-To-Consumer (DTC) marketing activation, including OTT streaming promotions, DTC merchandise offers, and subscription upsell campaigns. Supports DTC revenue strategy.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSuppressionList rdf:type rdf:Property ;
    rdfs:label 'Is Suppression List' ;
    rdfs:comment 'Indicates whether this segment functions as a suppression or exclusion list, identifying fans who should be excluded from specific campaigns (e.g., opted-out fans, recent purchasers, VIP do-not-contact lists). Critical for GDPR and CCPA compliance.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastRefreshTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Refresh Timestamp' ;
    rdfs:comment 'Date and time when the segment membership was most recently evaluated and the fan_count was last updated. Formatted as yyyy-MM-ddTHH:mm:ss.SSSXXX. Critical for assessing data freshness before campaign activation.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:ltvBand rdf:type rdf:Property ;
    rdfs:label 'Ltv Band' ;
    rdfs:comment 'Lifetime Value (LTV) classification band for fans in this segment, indicating their predicted or historical revenue contribution over their relationship with the organization. High-LTV segments receive premium personalization and VIP treatment. Supports ARPU and LTV analytics.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:membershipTierFilter rdf:type rdf:Property ;
    rdfs:label 'Membership Tier Filter' ;
    rdfs:comment 'Fan loyalty membership tier(s) included in this segment (e.g., \'bronze\', \'silver\', \'gold\', \'platinum\', \'vip\'). Enables tier-specific personalization, exclusive offers, and loyalty program communications. [ENUM-REF-CANDIDATE: bronze|silver|gold|platinum|vip|season_ticket_holder|fan_club — promote to reference product]' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modelScoreThreshold rdf:type rdf:Property ;
    rdfs:label 'Model Score Threshold' ;
    rdfs:comment 'Minimum propensity or confidence score from the predictive model required for fan inclusion in this segment. Expressed as a decimal between 0 and 1 (e.g., 0.7500 = 75% confidence). Applicable only when segment_type is \'predictive\'.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nextRefreshTimestamp rdf:type rdf:Property ;
    rdfs:label 'Next Refresh Timestamp' ;
    rdfs:comment 'Scheduled date and time for the next segment membership evaluation run. Used by campaign operations teams to plan activation timing and ensure segment data is current before campaign launch.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:npsBand rdf:type rdf:Property ;
    rdfs:label 'Nps Band' ;
    rdfs:comment 'Net Promoter Score (NPS) classification band associated with fans in this segment: promoters (score 9-10), passives (score 7-8), detractors (score 0-6), or unknown if NPS data is unavailable. Enables NPS-driven personalization and retention campaigns.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:owningBusinessUnit rdf:type rdf:Property ;
    rdfs:label 'Owning Business Unit' ;
    rdfs:comment 'Name of the business unit or department responsible for this segment (e.g., \'Fan Engagement\', \'Ticket Sales\', \'Sponsorship Marketing\', \'Merchandise\', \'Broadcast DTC\'). Determines accountability for segment maintenance and campaign activation.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refreshFrequency rdf:type rdf:Property ;
    rdfs:label 'Refresh Frequency' ;
    rdfs:comment 'How frequently the segment membership is re-evaluated and updated. Real-time segments use Adobe Experience Platform streaming segmentation; batch segments are evaluated on a scheduled cadence. Impacts campaign freshness and system resource planning.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rfmTier rdf:type rdf:Property ;
    rdfs:label 'Rfm Tier' ;
    rdfs:comment 'RFM (Recency, Frequency, Monetary) tier classification assigned to fans in this segment, applicable when segment_type is \'rfm\'. Champions are high-value frequent buyers; lost fans have not engaged recently. Drives targeted retention and reactivation campaigns.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentDescription rdf:type rdf:Property ;
    rdfs:label 'Segment Description' ;
    rdfs:comment 'Free-text business description of the segment\'s purpose, intended use case, and strategic rationale. Authored by the campaign or analytics team to provide context for downstream users and stakeholders.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentName rdf:type rdf:Property ;
    rdfs:label 'Segment Name' ;
    rdfs:comment 'Human-readable business name of the fan segment (e.g., \'High-Value Season Ticket Holders\', \'Lapsed Casual Fans\', \'Gen-Z Digital Natives\'). Used in campaign targeting, reporting dashboards, and personalization workflows.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentStatus rdf:type rdf:Property ;
    rdfs:label 'Segment Status' ;
    rdfs:comment 'Current lifecycle state of the segment definition. Active segments are available for campaign targeting; draft segments are under construction; archived segments are retained for historical reference but not used in live campaigns.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentType rdf:type rdf:Property ;
    rdfs:label 'Segment Type' ;
    rdfs:comment 'Classification of the segmentation methodology applied: RFM (Recency, Frequency, Monetary), behavioral (engagement actions), demographic (age, gender, location), psychographic (interests, values), predictive (ML-model-driven), or geographic. Drives which analytics model and personalization engine is applied.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tags rdf:type rdf:Property ;
    rdfs:label 'Tags' ;
    rdfs:comment 'Comma-separated business tags or labels applied to the segment for discoverability, governance, and categorization (e.g., \'retention, q4_campaign, nfl_season, vip, churn_prevention\'). Supports segment catalog search and filtering in Adobe Experience Platform and Salesforce CRM.' ;
    rdfs:domain ind:Fan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Segment Assignment Id' ;
    rdfs:comment 'Primary key for segment_assignment' ;
    rdfs:domain ind:SegmentAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:abTestVariant rdf:type rdf:Property ;
    rdfs:label 'Ab Test Variant' ;
    rdfs:comment 'The A/B or multivariate test variant assigned to this fan within the segment for campaign experimentation. Supports controlled testing of personalization strategies, messaging, and offer effectiveness across fan cohorts.' ;
    rdfs:domain ind:Fan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:activationDestination rdf:type rdf:Property ;
    rdfs:label 'Activation Destination' ;
    rdfs:comment 'The downstream system or platform to which this segment membership was activated (e.g., \'Adobe Target\', \'Google Ads\', \'Salesforce Marketing Cloud\', \'Meta Ads\'). Supports multi-channel activation tracking and attribution.' ;
    rdfs:domain ind:SegmentAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:activationStatus rdf:type rdf:Property ;
    rdfs:label 'Activation Status' ;
    rdfs:comment 'Indicates whether this segment membership has been activated for downstream use in a campaign, personalization engine, or ad platform. \'activated\' means the membership has been pushed to an activation destination such as Adobe Target or a paid media platform.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:activationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Activation Timestamp' ;
    rdfs:comment 'The date and time when this segment membership was activated and pushed to the downstream destination system. Distinct from assignment_timestamp; supports latency measurement between assignment and activation.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:assignmentChannel rdf:type rdf:Property ;
    rdfs:label 'Assignment Channel' ;
    rdfs:comment 'The system or interface channel through which the assignment was executed. \'crm\' = Salesforce CRM automation; \'aep\' = Adobe Experience Platform (AEP) audience activation; \'api\' = external API call; \'batch\' = scheduled batch job; \'manual_ui\' = CRM analyst via user interface.' ;
    rdfs:domain ind:SegmentAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentScore rdf:type rdf:Property ;
    rdfs:label 'Assignment Score' ;
    rdfs:comment 'Numeric score or confidence value associated with this assignment, typically produced by an ML model or rule engine. For ML-predicted assignments, this represents the model\'s probability or propensity score (0.0–1.0). For rule-based assignments, this may represent a weighted rule match score.' ;
    rdfs:domain ind:SegmentAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assignmentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Assignment Timestamp' ;
    rdfs:comment 'Precise date and time (with timezone) when the fan was assigned to this segment. Supports real-time campaign triggering and audit trail requirements.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:consentBasis rdf:type rdf:Property ;
    rdfs:label 'Consent Basis' ;
    rdfs:comment 'The legal basis under which the fan\'s data is processed for this segment assignment. Required for GDPR Article 6 compliance documentation. \'explicit_consent\' = fan actively opted in; \'legitimate_interest\' = business interest assessment conducted; \'contract\' = necessary for service delivery; \'legal_obligation\' = required by law; \'opt_out_not_exercised\' = CCPA default.' ;
    rdfs:domain ind:Fan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentVerified rdf:type rdf:Property ;
    rdfs:label 'Consent Verified' ;
    rdfs:comment 'Indicates whether the fan\'s data processing consent has been verified as valid and current at the time of this segment assignment. Ensures GDPR and CCPA compliance for targeted marketing use of this membership record.' ;
    rdfs:domain ind:SegmentAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dataSuppressionFlag rdf:type rdf:Property ;
    rdfs:label 'Data Suppression Flag' ;
    rdfs:comment 'Indicates whether this fan has exercised a right-to-suppress or opt-out request that should prevent this segment assignment from being used in outbound marketing or data sharing. Supports GDPR right to erasure and CCPA opt-out compliance.' ;
    rdfs:domain ind:SegmentAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:engagementScoreAtAssignment rdf:type rdf:Property ;
    rdfs:label 'Engagement Score At Assignment' ;
    rdfs:comment 'The fan\'s overall engagement score at the time of this segment assignment, as calculated by the CRM or Adobe Experience Platform. Captured as a point-in-time snapshot to support longitudinal analysis of how engagement drives segment membership.' ;
    rdfs:domain ind:SegmentAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fanTypeAtAssignment rdf:type rdf:Property ;
    rdfs:label 'Fan Type At Assignment' ;
    rdfs:comment 'The fan\'s account classification at the time of this segment assignment. Captured as a point-in-time snapshot to support historical cohort analysis. Values: individual consumer, family account, season ticket holder, VIP member, or fan club member.' ;
    rdfs:domain ind:SegmentAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isPrimarySegment rdf:type rdf:Property ;
    rdfs:label 'Is Primary Segment' ;
    rdfs:comment 'Indicates whether this segment is the fan\'s primary or highest-priority segment assignment when a fan belongs to multiple segments simultaneously. Used for personalization and communication preference resolution.' ;
    rdfs:domain ind:SegmentAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastEvaluatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Evaluated Timestamp' ;
    rdfs:comment 'The most recent date and time when the segment rule engine or ML model re-evaluated this fan\'s eligibility for the segment. Supports freshness monitoring and identifies stale assignments that may need re-evaluation.' ;
    rdfs:domain ind:SegmentAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:loyaltyTierAtAssignment rdf:type rdf:Property ;
    rdfs:label 'Loyalty Tier At Assignment' ;
    rdfs:comment 'The fan\'s loyalty program membership tier at the time of this segment assignment. Captured as a point-in-time snapshot to support time-variant analysis of how loyalty tier influences segment membership and campaign response.' ;
    rdfs:domain ind:SegmentAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:membershipDurationDays rdf:type rdf:Property ;
    rdfs:label 'Membership Duration Days' ;
    rdfs:comment 'The number of days the fan has been (or was) a member of this segment, calculated as the difference between assignment_date and either the current date (for active memberships) or revocation_date/expiry_date. Stored as a business-meaningful snapshot for reporting without requiring real-time calculation.' ;
    rdfs:domain ind:SegmentAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nextEvaluationDate rdf:type rdf:Property ;
    rdfs:label 'Next Evaluation Date' ;
    rdfs:comment 'The scheduled date for the next automated re-evaluation of this fan\'s segment eligibility. Supports segment refresh scheduling and ensures time-sensitive segments (e.g., event-proximity segments) are kept current.' ;
    rdfs:domain ind:SegmentAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:npsCohortFlag rdf:type rdf:Property ;
    rdfs:label 'Nps Cohort Flag' ;
    rdfs:comment 'Indicates whether this segment assignment is specifically designated for NPS (Net Promoter Score) survey cohort analysis. When true, the fan is included in NPS measurement campaigns for fan satisfaction tracking.' ;
    rdfs:domain ind:SegmentAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priorityRank rdf:type rdf:Property ;
    rdfs:label 'Priority Rank' ;
    rdfs:comment 'Numeric rank indicating the priority of this segment assignment relative to other active segment memberships for the same fan. Lower values indicate higher priority. Used for conflict resolution when a fan belongs to multiple segments with competing campaign rules.' ;
    rdfs:domain ind:SegmentAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:revocationDate rdf:type rdf:Property ;
    rdfs:label 'Revocation Date' ;
    rdfs:comment 'The date on which this fan\'s segment membership was revoked or removed, either by automated rule exit, manual override, or consent withdrawal. Null if the membership has not been revoked.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:revocationReason rdf:type rdf:Property ;
    rdfs:label 'Revocation Reason' ;
    rdfs:comment 'The reason code explaining why this fan\'s segment membership was revoked. \'rule_exit\' = fan no longer meets segment criteria; \'consent_withdrawn\' = GDPR/CCPA consent revoked; \'manual_removal\' = analyst override; \'data_quality\' = data integrity issue; \'segment_deprecated\' = segment definition retired; \'opt_out\' = fan opted out of communications.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scoreModelVersion rdf:type rdf:Property ;
    rdfs:label 'Score Model Version' ;
    rdfs:comment 'Version identifier of the ML model or rule engine that produced the assignment_score. Enables model governance, reproducibility, and performance tracking over time. Applicable when assignment_method is \'ml_predicted\'.' ;
    rdfs:domain ind:SegmentAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scorePercentile rdf:type rdf:Property ;
    rdfs:label 'Score Percentile' ;
    rdfs:comment 'The percentile rank of the fan\'s assignment score within the segment population at the time of assignment (0.00–100.00). Used for tiered targeting and prioritization within a segment cohort.' ;
    rdfs:domain ind:SegmentAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:segmentCategory rdf:type rdf:Property ;
    rdfs:label 'Segment Category' ;
    rdfs:comment 'The analytical category of the segment to which the fan is assigned. Denormalized from the segment definition for query performance. Supports filtering and reporting by segment type without joining to the segment master.' ;
    rdfs:domain ind:SegmentAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentVersion rdf:type rdf:Property ;
    rdfs:label 'Segment Version' ;
    rdfs:comment 'Version label of the segment definition that was active at the time of this assignment. Enables historical analysis of how segment criteria evolved and ensures reproducibility of cohort membership.' ;
    rdfs:domain ind:SegmentAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceRecordReference rdf:type rdf:Property ;
    rdfs:label 'Source Record Reference' ;
    rdfs:comment 'The native record identifier from the originating source system (e.g., Salesforce CRM Campaign Member ID, Adobe AEP Segment Membership ID). Supports data lineage, reconciliation, and cross-system traceability.' ;
    rdfs:domain ind:Fan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentPreferenceId rdf:type rdf:Property ;
    rdfs:label 'Consent Preference Id' ;
    rdfs:comment 'Unique surrogate identifier for each consent preference record. Primary key for the consent_preference data product in the fan domain.' ;
    rdfs:domain ind:ConsentPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryConsentFanProfileId rdf:type rdf:Property ;
    rdfs:label 'Primary Consent Fan Profile Id' ;
    rdfs:comment 'Identifier of the fan whose consent preference this record captures. Links to the fan master profile as the primary party reference.' ;
    rdfs:domain ind:ConsentPreference ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FanProfile .

ind:tertiaryConsentParentalGuardianFanProfileId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Consent Parental Guardian Fan Profile Id' ;
    rdfs:comment 'Fan ID of the parent or legal guardian who provided consent on behalf of a minor fan. Null for adult fans. Links to the guardian\'s fan profile for family account management.' ;
    rdfs:domain ind:ConsentPreference ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FanProfile .

ind:aepConsentReference rdf:type rdf:Property ;
    rdfs:label 'Aep Consent Reference' ;
    rdfs:comment 'External identifier of the corresponding consent record in Adobe Experience Platform. Supports synchronisation of consent signals to the fan engagement and personalisation platform.' ;
    rdfs:domain ind:ConsentPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentCategory rdf:type rdf:Property ;
    rdfs:label 'Consent Category' ;
    rdfs:comment 'High-level category grouping for this consent type, aligned with IAB TCF (Transparency and Consent Framework) and cookie consent banner classifications. Supports consent management platform (CMP) integration and reporting.' ;
    rdfs:domain ind:ConsentPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentDate rdf:type rdf:Property ;
    rdfs:label 'Consent Date' ;
    rdfs:comment 'Timestamp at which the fan actively granted this consent. Represents the principal business event timestamp for the consent lifecycle. Stored in ISO 8601 format with timezone offset.' ;
    rdfs:domain ind:ConsentPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:consentLanguageCode rdf:type rdf:Property ;
    rdfs:label 'Consent Language Code' ;
    rdfs:comment 'ISO 639-1 language code (optionally with ISO 3166-1 country subtag) of the language in which the consent notice was presented to the fan. Ensures consent was given in the fan\'s understood language, a GDPR requirement.' ;
    rdfs:domain ind:ConsentPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentNoticeUrl rdf:type rdf:Property ;
    rdfs:label 'Consent Notice Url' ;
    rdfs:comment 'URL of the specific privacy notice or consent form presented to the fan at the time of consent capture. Provides an auditable link to the exact disclosure document the fan reviewed.' ;
    rdfs:domain ind:ConsentPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentProofReference rdf:type rdf:Property ;
    rdfs:label 'Consent Proof Reference' ;
    rdfs:comment 'Reference identifier or URL pointing to the stored evidence of consent (e.g., a screenshot, form submission log, call recording reference, or digital audit token). Required for demonstrating consent under GDPR Article 7(1).' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Consent Reference Number' ;
    rdfs:comment 'Externally-known alphanumeric reference number assigned to this consent record, used for audit trails, regulatory inquiries, and fan-facing acknowledgement receipts. Generated at point of consent capture.' ;
    rdfs:domain ind:ConsentPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentRenewalReminderDate rdf:type rdf:Property ;
    rdfs:label 'Consent Renewal Reminder Date' ;
    rdfs:comment 'Date on which a consent renewal reminder should be sent to the fan, typically triggered before the effective_until date. Supports proactive consent lifecycle management to avoid consent lapse.' ;
    rdfs:domain ind:ConsentPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:consentSource rdf:type rdf:Property ;
    rdfs:label 'Consent Source' ;
    rdfs:comment 'The channel or touchpoint through which the fan provided or updated their consent. Used for audit purposes and to validate that consent was obtained through an appropriate mechanism. Values: web_form, mobile_app, in_venue_kiosk, call_center, paper_form, third_party.' ;
    rdfs:domain ind:ConsentPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentStatus rdf:type rdf:Property ;
    rdfs:label 'Consent Status' ;
    rdfs:comment 'Current lifecycle state of this consent record. \'granted\' indicates active consent; \'withdrawn\' indicates the fan has revoked consent; \'pending\' indicates consent request issued but not yet confirmed; \'expired\' indicates consent has lapsed past its validity period.' ;
    rdfs:domain ind:ConsentPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentType rdf:type rdf:Property ;
    rdfs:label 'Consent Type' ;
    rdfs:comment 'Classification of the specific data processing activity for which consent is being captured. Covers marketing email, SMS, push notification, data sharing with partners, profiling/personalization, and cookie consent. [ENUM-REF-CANDIDATE: marketing_email|sms|push_notification|data_sharing_partner|profiling_personalization|cookie — promote to reference product if additional types are required]' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crmConsentRecordReference rdf:type rdf:Property ;
    rdfs:label 'Crm Consent Record Reference' ;
    rdfs:comment 'External identifier of the corresponding consent record in Salesforce CRM. Enables bi-directional reconciliation between the lakehouse silver layer and the operational CRM system of record.' ;
    rdfs:domain ind:ConsentPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataPortabilityRequested rdf:type rdf:Property ;
    rdfs:label 'Data Portability Requested' ;
    rdfs:comment 'Indicates whether the fan has submitted a Data Portability request under GDPR Article 20, requesting their personal data in a machine-readable format. Triggers data export workflows.' ;
    rdfs:domain ind:ConsentPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:doubleOptInDate rdf:type rdf:Property ;
    rdfs:label 'Double Opt In Date' ;
    rdfs:comment 'Timestamp at which the fan completed the double opt-in confirmation step. Null if double opt-in was not required or not completed. Supports audit evidence for email marketing consent.' ;
    rdfs:domain ind:ConsentPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:doubleOptInFlag rdf:type rdf:Property ;
    rdfs:label 'Double Opt In Flag' ;
    rdfs:comment 'Indicates whether the fan completed a double opt-in confirmation process (True) for this consent, such as clicking a confirmation link in an email. Provides stronger evidence of consent for email marketing under GDPR.' ;
    rdfs:domain ind:ConsentPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:erasureRequestDate rdf:type rdf:Property ;
    rdfs:label 'Erasure Request Date' ;
    rdfs:comment 'Timestamp at which the fan submitted their Right to Erasure or CCPA deletion request. Null if no erasure request has been made. Starts the regulatory response clock (30 days under GDPR, 45 days under CCPA).' ;
    rdfs:domain ind:ConsentPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:iabTcfPurposeCode rdf:type rdf:Property ;
    rdfs:label 'Iab Tcf Purpose Code' ;
    rdfs:comment 'Numeric identifier of the IAB TCF v2.2 purpose associated with this consent record. Enables interoperability with programmatic advertising and digital media ecosystems for broadcast and OTT platforms.' ;
    rdfs:domain ind:ConsentPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:jurisdiction rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction' ;
    rdfs:comment 'The regulatory framework and geographic jurisdiction under which this consent record is governed. Determines which privacy law obligations apply. Values: EU_GDPR, CA_CCPA, UK_GDPR, BR_LGPD, AU_PRIVACY. [ENUM-REF-CANDIDATE: EU_GDPR|CA_CCPA|UK_GDPR|BR_LGPD|AU_PRIVACY|other — promote to reference product for full global coverage]' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalBasis rdf:type rdf:Property ;
    rdfs:label 'Legal Basis' ;
    rdfs:comment 'The GDPR Article 6 lawful basis under which personal data is processed for this consent record. While this product primarily captures consent, the legal basis field supports cases where processing may shift to another basis (e.g., contract fulfilment). Values: consent, legitimate_interest, contract, legal_obligation, vital_interest, public_task.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minorFlag rdf:type rdf:Property ;
    rdfs:label 'Minor Flag' ;
    rdfs:comment 'Indicates whether the fan is a minor (under 16 in EU, under 13 in US) at the time of consent. Triggers parental consent verification workflows and restricts certain processing activities under GDPR Article 8 and COPPA.' ;
    rdfs:domain ind:ConsentPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:optInFlag rdf:type rdf:Property ;
    rdfs:label 'Opt In Flag' ;
    rdfs:comment 'Indicates whether the fan has actively opted in (True) or opted out (False) for this consent type. Provides a direct boolean signal for downstream marketing suppression lists and personalisation engines.' ;
    rdfs:domain ind:ConsentPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:parentalConsentFlag rdf:type rdf:Property ;
    rdfs:label 'Parental Consent Flag' ;
    rdfs:comment 'Indicates whether verifiable parental consent has been obtained for a minor fan (True) or not (False). Required for fans identified as minors under GDPR Article 8 and COPPA.' ;
    rdfs:domain ind:ConsentPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:processingPurpose rdf:type rdf:Property ;
    rdfs:label 'Processing Purpose' ;
    rdfs:comment 'Detailed description of the specific data processing purpose for which consent is granted, as disclosed to the fan. Examples include \'personalised match recommendations\', \'third-party sponsor marketing\', \'fan behaviour analytics\'. Supports GDPR purpose limitation principle.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rightToErasureRequested rdf:type rdf:Property ;
    rdfs:label 'Right To Erasure Requested' ;
    rdfs:comment 'Indicates whether the fan has submitted a Right to Erasure (Right to be Forgotten) request under GDPR Article 17 or CCPA deletion request. Triggers downstream data deletion workflows across all processing systems.' ;
    rdfs:domain ind:ConsentPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:suppressionFlag rdf:type rdf:Property ;
    rdfs:label 'Suppression Flag' ;
    rdfs:comment 'Indicates whether this fan is on a global marketing suppression list (True), overriding all consent grants for outbound marketing communications. Used by Salesforce CRM and Adobe Experience Platform to enforce hard suppression.' ;
    rdfs:domain ind:Fan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:withdrawalDate rdf:type rdf:Property ;
    rdfs:label 'Withdrawal Date' ;
    rdfs:comment 'Timestamp at which the fan withdrew or revoked this consent. Null if consent has not been withdrawn. Required for GDPR and CCPA audit trails demonstrating timely cessation of processing.' ;
    rdfs:domain ind:ConsentPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:withdrawalMethod rdf:type rdf:Property ;
    rdfs:label 'Withdrawal Method' ;
    rdfs:comment 'The channel or mechanism through which the fan withdrew their consent. Null if consent has not been withdrawn. Supports audit trails and ensures withdrawal was as easy as granting consent per GDPR Article 7(3).' ;
    rdfs:domain ind:ConsentPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryEngagementBroadcastStreamLiveFeedId rdf:type rdf:Property ;
    rdfs:label 'Primary Engagement Broadcast Stream Live Feed Id' ;
    rdfs:comment 'Reference to the live broadcast or OTT (Over-The-Top) stream being watched during a live stream watch engagement event. Nullable for non-broadcast engagement types. Links to broadcast schedule and rights data.' ;
    rdfs:domain ind:EngagementEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LiveFeed .

ind:primaryEngagementFixtureId rdf:type rdf:Property ;
    rdfs:label 'Primary Engagement Fixture Id' ;
    rdfs:comment 'Reference to the sports or entertainment event associated with this engagement interaction (e.g., game, concert, match). Nullable for non-event-specific engagements such as app browsing or content views.' ;
    rdfs:domain ind:EngagementEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Fixture .

ind:aepExperienceEventReference rdf:type rdf:Property ;
    rdfs:label 'Aep Experience Event Reference' ;
    rdfs:comment 'The source system event identifier assigned by Adobe Experience Platform at the point of behavioral data capture. Used for lineage tracing and deduplication against the AEP raw event stream.' ;
    rdfs:domain ind:EngagementEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:aepSegmentIds rdf:type rdf:Property ;
    rdfs:label 'Aep Segment Ids' ;
    rdfs:comment 'Pipe-delimited list of Adobe Experience Platform (AEP) audience segment identifiers that the fan belonged to at the time of this engagement event. Captures the real-time segmentation state for personalization attribution and segment performance analysis. Stored as a delimited string per Silver layer no-complex-type convention.' ;
    rdfs:domain ind:EngagementEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appVersion rdf:type rdf:Property ;
    rdfs:label 'App Version' ;
    rdfs:comment 'Version number of the mobile or web application from which the engagement event was generated. Used for feature adoption tracking, bug correlation, and release impact analysis.' ;
    rdfs:domain ind:EngagementEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentAnalytics rdf:type rdf:Property ;
    rdfs:label 'Consent Analytics' ;
    rdfs:comment 'Indicates whether the fan had active analytics and behavioral tracking consent at the time of this engagement event. Governs whether this event can be used in behavioral analytics models and personalization under GDPR and CCPA.' ;
    rdfs:domain ind:EngagementEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:consentMarketing rdf:type rdf:Property ;
    rdfs:label 'Consent Marketing' ;
    rdfs:comment 'Indicates whether the fan had active marketing communications consent at the time of this engagement event, as recorded in the consent management platform. Governs whether this event can be used for personalized marketing activation under GDPR and CCPA.' ;
    rdfs:domain ind:EngagementEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contentProgressPct rdf:type rdf:Property ;
    rdfs:label 'Content Progress Pct' ;
    rdfs:comment 'Percentage of a content asset (video, podcast, article) consumed by the fan during a content view or live stream watch engagement event. Ranges from 0.00 to 100.00. Used for content completion rate analytics and personalization model features.' ;
    rdfs:domain ind:EngagementEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:crmInteractionReference rdf:type rdf:Property ;
    rdfs:label 'Crm Interaction Reference' ;
    rdfs:comment 'The corresponding interaction or activity record identifier in Salesforce CRM, if this engagement event was surfaced or actioned through the CRM platform. Used for cross-system reconciliation between AEP behavioral data and Salesforce CRM fan interaction history.' ;
    rdfs:domain ind:EngagementEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviceOs rdf:type rdf:Property ;
    rdfs:label 'Device Os' ;
    rdfs:comment 'Operating system of the device used during the engagement event. Used for platform-specific analytics, app version targeting, and technical performance monitoring. [ENUM-REF-CANDIDATE: ios|android|windows|macos|tvos|roku|fire_os|unknown — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:EngagementEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engagementChannel rdf:type rdf:Property ;
    rdfs:label 'Engagement Channel' ;
    rdfs:comment 'The interface or platform through which the fan engagement occurred. Distinguishes mobile app, web, in-venue, broadcast, social, Over-The-Top (OTT) streaming, email, and kiosk interactions for omnichannel analytics. [ENUM-REF-CANDIDATE: mobile_app|web|in_venue|broadcast|social|ott|email|kiosk — promote to reference product]' ;
    rdfs:domain ind:EngagementEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engagementDate rdf:type rdf:Property ;
    rdfs:label 'Engagement Date' ;
    rdfs:comment 'Calendar date of the fan engagement interaction, derived from engagement_timestamp. Used as a partition key and for day-level aggregation in reporting, event-day analysis, and fan attendance correlation. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:EngagementEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:engagementStatus rdf:type rdf:Property ;
    rdfs:label 'Engagement Status' ;
    rdfs:comment 'Current processing lifecycle state of the engagement event record within the Silver layer pipeline. Indicates whether the event has been captured from AEP, validated, enriched with fan profile data, rejected due to quality issues, or flagged as a duplicate.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engagementTimestamp rdf:type rdf:Property ;
    rdfs:label 'Engagement Timestamp' ;
    rdfs:comment 'The precise real-world date and time when the fan engagement interaction occurred, as recorded by the source system. Principal business event time used for time-series analysis, session stitching, and RFM recency scoring. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:EngagementEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:engagementType rdf:type rdf:Property ;
    rdfs:label 'Engagement Type' ;
    rdfs:comment 'Categorical discriminator identifying the kind of fan engagement interaction captured. Drives segmentation, RFM scoring, and personalization model feature engineering. [ENUM-REF-CANDIDATE: attendance_checkin|app_session|content_view|social_share|merchandise_browse|loyalty_redemption|live_stream_watch|beacon_detection|contest_entry|watchlist_action — promote to reference product]' ;
    rdfs:domain ind:EngagementEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engagementValueScore rdf:type rdf:Property ;
    rdfs:label 'Engagement Value Score' ;
    rdfs:comment 'Weighted numeric score representing the business value of this individual engagement interaction, assigned by the AEP scoring model based on engagement type, duration, and channel. Primary input to RFM (Recency, Frequency, Monetary) scoring and fan LTV (Lifetime Value) calculation.' ;
    rdfs:domain ind:EngagementEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:geoRegionCode rdf:type rdf:Property ;
    rdfs:label 'Geo Region Code' ;
    rdfs:comment 'ISO 3166-2 subdivision code (state, province, or region) of the fan\'s location at the time of engagement. Used for Regional Sports Network (RSN) blackout rule enforcement, regional sponsorship attribution, and market-level reporting.' ;
    rdfs:domain ind:EngagementEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isAuthenticated rdf:type rdf:Property ;
    rdfs:label 'Is Authenticated' ;
    rdfs:comment 'Indicates whether the fan was authenticated (logged in) at the time of the engagement event. Authenticated events can be linked to a known fan profile; unauthenticated events are anonymous. Critical for identity resolution and GDPR/CCPA consent enforcement.' ;
    rdfs:domain ind:EngagementEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:referralSource rdf:type rdf:Property ;
    rdfs:label 'Referral Source' ;
    rdfs:comment 'The originating source or campaign that drove the fan to this engagement event (e.g., push notification, email campaign, paid social ad, organic search, direct). Used for Customer Acquisition Cost (CAC) attribution and campaign Return on Investment (ROI) analysis.' ;
    rdfs:domain ind:EngagementEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:socialPlatform rdf:type rdf:Property ;
    rdfs:label 'Social Platform' ;
    rdfs:comment 'The social media platform on which a social share engagement event occurred. Nullable for non-social engagement types. Used for social channel performance analytics and influencer attribution. [ENUM-REF-CANDIDATE: twitter|instagram|facebook|tiktok|youtube|snapchat|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:EngagementEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:communicationId rdf:type rdf:Property ;
    rdfs:label 'Communication Id' ;
    rdfs:comment 'Primary key for communication' ;
    rdfs:domain ind:Communication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bettorAccountId rdf:type rdf:Property ;
    rdfs:label 'Bettor Account Id' ;
    rdfs:comment 'Foreign key linking to gaming.bettor_account. Business justification: Responsible gaming communications (self-exclusion confirmations, deposit limit notifications, bonus offer emails) must be tracked against the specific bettor account for regulatory audit trails. Regul' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BettorAccount .

ind:communicationFanFanProfileId rdf:type rdf:Property ;
    rdfs:label 'Communication Fan Fan Profile Id' ;
    rdfs:comment 'Reference to the fan profile who is the recipient of this communication. Links to the fan master profile record in the fan domain.' ;
    rdfs:domain ind:Communication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FanProfile .

ind:communicationFanProfileId rdf:type rdf:Property ;
    rdfs:label 'Communication Fan Profile Id' ;
    rdfs:comment 'Reference to the fan profile who is the recipient of this communication. Links to the fan master profile record in the fan domain.' ;
    rdfs:domain ind:Communication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FanProfile .

ind:bounceType rdf:type rdf:Property ;
    rdfs:label 'Bounce Type' ;
    rdfs:comment 'Classification of the delivery bounce when delivery_status is \'bounced\'. Hard bounce = permanent delivery failure (invalid address); Soft bounce = temporary failure (mailbox full, server unavailable); Block = rejected by receiving server due to spam or policy rules.' ;
    rdfs:domain ind:Communication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clickTimestamp rdf:type rdf:Property ;
    rdfs:label 'Click Timestamp' ;
    rdfs:comment 'The date and time (UTC) at which the fan first clicked a link or call-to-action within the communication. Null if no click was recorded. Used for click-through rate (CTR) and conversion analysis.' ;
    rdfs:domain ind:Communication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:clickUrl rdf:type rdf:Property ;
    rdfs:label 'Click Url' ;
    rdfs:comment 'The specific URL or deep link that the fan clicked within the communication. Captures the primary or first-click URL for conversion attribution and content performance analysis.' ;
    rdfs:domain ind:Communication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:communicationType rdf:type rdf:Property ;
    rdfs:label 'Communication Type' ;
    rdfs:comment 'Classification of the communication by business purpose. Transactional messages are triggered by fan actions (e.g., ticket purchase confirmation); marketing messages are campaign-driven; loyalty messages relate to loyalty program activity; service messages are operational; alerts are time-sensitive notifications.' ;
    rdfs:domain ind:Communication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conversionFlag rdf:type rdf:Property ;
    rdfs:label 'Conversion Flag' ;
    rdfs:comment 'Indicates whether the fan completed the intended conversion action (e.g., ticket purchase, merchandise order, loyalty enrolment) within the attribution window following this communication. True = conversion attributed to this communication.' ;
    rdfs:domain ind:Communication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:conversionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Conversion Timestamp' ;
    rdfs:comment 'The date and time (UTC) at which the fan completed the attributed conversion action following this communication. Null if no conversion was recorded. Used for attribution window analysis.' ;
    rdfs:domain ind:Communication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:deliveryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Delivery Timestamp' ;
    rdfs:comment 'The date and time (UTC) at which delivery of the communication was confirmed by the receiving server or device. Null if delivery has not been confirmed or if the message bounced.' ;
    rdfs:domain ind:Communication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:externalMessageReference rdf:type rdf:Property ;
    rdfs:label 'External Message Reference' ;
    rdfs:comment 'The unique message identifier assigned by the originating system of record (Salesforce CRM, Adobe Experience Platform, or third-party ESP/SMS gateway). Used for deduplication and cross-system traceability.' ;
    rdfs:domain ind:Communication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fatigueScore rdf:type rdf:Property ;
    rdfs:label 'Fatigue Score' ;
    rdfs:comment 'Numeric score representing the fan\'s communication fatigue level at the time this message was sent, calculated from recent communication frequency. Used to enforce fatigue caps and optimise send cadence. Higher values indicate greater fatigue risk.' ;
    rdfs:domain ind:Communication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:npsSurveyFlag rdf:type rdf:Property ;
    rdfs:label 'Nps Survey Flag' ;
    rdfs:comment 'Indicates whether this communication included or was a Net Promoter Score (NPS) survey request. True = NPS survey was embedded or linked in this message. Supports fan satisfaction tracking and NPS programme management.' ;
    rdfs:domain ind:Communication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:openTimestamp rdf:type rdf:Property ;
    rdfs:label 'Open Timestamp' ;
    rdfs:comment 'The date and time (UTC) at which the fan first opened or viewed the communication. Applicable to email (pixel tracking) and in-app messages. Null if the communication was not opened.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:optOutFlag rdf:type rdf:Property ;
    rdfs:label 'Opt Out Flag' ;
    rdfs:comment 'Indicates whether the fan unsubscribed or opted out of future communications as a result of receiving this specific message. True = opt-out action was triggered by this communication. Critical for GDPR suppression compliance and CAN-SPAM adherence.' ;
    rdfs:domain ind:Communication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:optOutTimestamp rdf:type rdf:Property ;
    rdfs:label 'Opt Out Timestamp' ;
    rdfs:comment 'The date and time (UTC) at which the fan submitted an opt-out or unsubscribe request linked to this communication. Null if no opt-out was recorded. Required for GDPR and CCPA suppression audit trails.' ;
    rdfs:domain ind:Communication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:personalizationFlag rdf:type rdf:Property ;
    rdfs:label 'Personalization Flag' ;
    rdfs:comment 'Indicates whether this communication was dynamically personalized using fan profile data (e.g., name, favourite team, loyalty tier, purchase history). True = personalized content was applied; False = generic broadcast content.' ;
    rdfs:domain ind:Communication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scheduledSendTimestamp rdf:type rdf:Property ;
    rdfs:label 'Scheduled Send Timestamp' ;
    rdfs:comment 'The date and time (UTC) at which the communication was originally scheduled to be sent. May differ from send_timestamp if the send was delayed or rescheduled. Used for send-time optimisation analysis.' ;
    rdfs:domain ind:Communication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sendTimestamp rdf:type rdf:Property ;
    rdfs:label 'Send Timestamp' ;
    rdfs:comment 'The date and time (UTC) at which the communication was dispatched from the sending platform to the delivery provider (ESP, SMS gateway, push service). This is the principal business event timestamp for this transaction.' ;
    rdfs:domain ind:Communication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:subjectLine rdf:type rdf:Property ;
    rdfs:label 'Subject Line' ;
    rdfs:comment 'The subject line or headline of the communication as delivered to the fan. Applicable primarily to email and push notifications. Used for A/B test analysis and engagement reporting.' ;
    rdfs:domain ind:Communication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:suppressionReason rdf:type rdf:Property ;
    rdfs:label 'Suppression Reason' ;
    rdfs:comment 'The reason this communication was suppressed and not sent to the fan. Used for compliance audit and communication fatigue management reporting. Populated only when suppression_flag is True.' ;
    rdfs:domain ind:Communication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:triggerType rdf:type rdf:Property ;
    rdfs:label 'Trigger Type' ;
    rdfs:comment 'Indicates how this communication was initiated — whether by a scheduled campaign, an automated journey step, a real-time event trigger (e.g., ticket purchase, game day), an API call, or a manual send by a CRM operator.' ;
    rdfs:domain ind:Communication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceCaseId rdf:type rdf:Property ;
    rdfs:label 'Service Case Id' ;
    rdfs:comment 'Primary key for service_case' ;
    rdfs:domain ind:ServiceCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryServiceEventFixtureId rdf:type rdf:Property ;
    rdfs:label 'Primary Service Event Fixture Id' ;
    rdfs:comment 'Reference to the sports or entertainment event associated with this service case, if applicable (e.g., a ticketing dispute or lost-and-found case linked to a specific game or concert). Null for cases not tied to a specific event.' ;
    rdfs:domain ind:ServiceCase ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Fixture .

ind:primaryServiceFanFanProfileId rdf:type rdf:Property ;
    rdfs:label 'Primary Service Fan Fan Profile Id' ;
    rdfs:comment 'Reference to the fan account associated with this service case. Links the case to the fan\'s identity, demographic, and CRM profile in the fan domain.' ;
    rdfs:domain ind:ServiceCase ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FanProfile .

ind:accessibilityAccommodationType rdf:type rdf:Property ;
    rdfs:label 'Accessibility Accommodation Type' ;
    rdfs:comment 'Specific type of accessibility accommodation requested or arranged for the fan (e.g., wheelchair seating, hearing loop, visual impairment assistance, companion seating). Populated for cases of type accessibility_accommodation. Supports ADA compliance reporting.' ;
    rdfs:domain ind:ServiceCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignedTeam rdf:type rdf:Property ;
    rdfs:label 'Assigned Team' ;
    rdfs:comment 'Name of the support team or queue to which the case is currently assigned (e.g., Ticketing Support, VIP Concierge, Membership Services, Accessibility Team). Supports team-level workload and performance reporting.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseCategory rdf:type rdf:Property ;
    rdfs:label 'Case Category' ;
    rdfs:comment 'Secondary classification grouping cases into operational categories for routing and reporting. Complements case_type with a broader operational lens. Corresponds to the Reason field on the Salesforce CRM Case object. [ENUM-REF-CANDIDATE: billing|access_control|fan_experience|safety_security|content_access|merchandise|general — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ServiceCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseDescription rdf:type rdf:Property ;
    rdfs:label 'Case Description' ;
    rdfs:comment 'Full narrative description of the fan\'s issue, request, or complaint as submitted. Captures the complete context of the case including relevant event details, ticket information, or membership concerns. Corresponds to the Description field on the Salesforce CRM Case object.' ;
    rdfs:domain ind:ServiceCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseReopenCount rdf:type rdf:Property ;
    rdfs:label 'Case Reopen Count' ;
    rdfs:comment 'Number of times this service case has been reopened after a prior resolution or closure. A high reopen count indicates unresolved fan issues and is a key quality metric for support operations.' ;
    rdfs:domain ind:ServiceCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:caseStatus rdf:type rdf:Property ;
    rdfs:label 'Case Status' ;
    rdfs:comment 'Current lifecycle state of the service case within the support workflow. Drives SLA tracking, agent workload management, and fan communication triggers. Corresponds to the Status field on the Salesforce CRM Case object. [ENUM-REF-CANDIDATE: new|open|pending_fan|pending_internal|escalated|resolved|closed — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseSubCategory rdf:type rdf:Property ;
    rdfs:label 'Case Sub Category' ;
    rdfs:comment 'Granular sub-classification within the case_category, providing detailed routing and root-cause analysis capability (e.g., within billing: duplicate_charge, incorrect_tier, failed_payment). Corresponds to a custom sub-reason field in Salesforce CRM.' ;
    rdfs:domain ind:ServiceCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseSubject rdf:type rdf:Property ;
    rdfs:label 'Case Subject' ;
    rdfs:comment 'Short, one-line summary of the fan\'s issue or request as entered by the fan or agent. Corresponds to the Subject field on the Salesforce CRM Case object. Used in case list views, dashboards, and agent queues.' ;
    rdfs:domain ind:ServiceCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseType rdf:type rdf:Property ;
    rdfs:label 'Case Type' ;
    rdfs:comment 'High-level classification of the service case category. Drives routing rules, SLA targets, and reporting segmentation. [ENUM-REF-CANDIDATE: ticketing_dispute|membership_billing|lost_and_found|accessibility_accommodation|complaint_escalation|vip_concierge|general_inquiry|refund_request|merchandise_issue|broadcast_access — promote to reference product]' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crmCaseSourceReference rdf:type rdf:Property ;
    rdfs:label 'Crm Case Source Reference' ;
    rdfs:comment 'The native Salesforce CRM Case record ID (18-character Salesforce ID) from the source system. Enables traceability and reconciliation between the Silver Layer lakehouse record and the originating Salesforce CRM Case object.' ;
    rdfs:domain ind:ServiceCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationFlag rdf:type rdf:Property ;
    rdfs:label 'Escalation Flag' ;
    rdfs:comment 'Indicates whether this service case has been formally escalated to a senior agent, supervisor, or management tier. True when the case has been escalated at any point in its lifecycle. Corresponds to the IsEscalated field on the Salesforce CRM Case object.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:escalationReason rdf:type rdf:Property ;
    rdfs:label 'Escalation Reason' ;
    rdfs:comment 'Narrative or coded reason explaining why the case was escalated (e.g., unresolved after SLA breach, fan dissatisfaction, legal threat, media risk, VIP status). Populated when escalation_flag is True.' ;
    rdfs:domain ind:ServiceCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Escalation Timestamp' ;
    rdfs:comment 'Date and time when the case was first escalated. Used to measure escalation response time and track escalation lifecycle duration.' ;
    rdfs:domain ind:ServiceCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:fanSentiment rdf:type rdf:Property ;
    rdfs:label 'Fan Sentiment' ;
    rdfs:comment 'Agent-assessed or AI-derived sentiment classification of the fan\'s tone and emotional state during the case interaction. Used for NPS (Net Promoter Score) correlation analysis and fan experience improvement programs.' ;
    rdfs:domain ind:ServiceCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:firstResponseTimestamp rdf:type rdf:Property ;
    rdfs:label 'First Response Timestamp' ;
    rdfs:comment 'Date and time when the assigned agent first responded to the fan on this case. Used to measure first-response SLA compliance and agent responsiveness KPIs.' ;
    rdfs:domain ind:ServiceCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:gdprDataRequestFlag rdf:type rdf:Property ;
    rdfs:label 'Gdpr Data Request Flag' ;
    rdfs:comment 'Indicates whether this service case involves a GDPR data subject request (e.g., right to access, right to erasure, data portability). True when the case is classified as a GDPR-related request. Supports GDPR compliance reporting and regulatory response tracking.' ;
    rdfs:domain ind:ServiceCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:npsSurveySentFlag rdf:type rdf:Property ;
    rdfs:label 'Nps Survey Sent Flag' ;
    rdfs:comment 'Indicates whether a post-case NPS satisfaction survey was sent to the fan upon case closure. True when the survey has been dispatched. Supports NPS tracking and fan experience measurement programs.' ;
    rdfs:domain ind:ServiceCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:originChannel rdf:type rdf:Property ;
    rdfs:label 'Origin Channel' ;
    rdfs:comment 'The channel through which the fan initiated the service case. Used for channel mix analysis, staffing optimization, and omnichannel CRM reporting. Corresponds to the Origin field on the Salesforce CRM Case object. [ENUM-REF-CANDIDATE: phone|email|chat|social|in_venue|web_form|mobile_app — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ServiceCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:avsResponseCode rdf:type rdf:Property ;
    rdfs:label 'Avs Response Code' ;
    rdfs:comment 'Response code returned by the card issuer\'s Address Verification Service (AVS) during the enrollment authorization. Indicates the degree of match between the billing address provided by the fan and the address on file with the issuer. Used in fraud scoring and risk decisioning.' ;
    rdfs:domain ind:PaymentMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankAccountLastFour rdf:type rdf:Property ;
    rdfs:label 'Bank Account Last Four' ;
    rdfs:comment 'Last four digits of the bank account number for direct debit payment methods. Displayed to the fan for identification purposes. Applicable only when payment_method_type is \'direct_debit\'. Null for card-based instruments.' ;
    rdfs:domain ind:PaymentMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankRoutingCode rdf:type rdf:Property ;
    rdfs:label 'Bank Routing Code' ;
    rdfs:comment 'Bank routing number (US ACH) or sort code (UK/EU) associated with a direct debit payment method. Used for ACH or SEPA payment processing. Stored in truncated or tokenized form. Null for non-direct-debit instruments.' ;
    rdfs:domain ind:PaymentMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Billing Address Line1' ;
    rdfs:comment 'Primary street address line of the billing address associated with this payment instrument. Used for Address Verification Service (AVS) checks during card-not-present transactions on ticketing and merchandise platforms.' ;
    rdfs:domain ind:PaymentMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Billing Address Line2' ;
    rdfs:comment 'Secondary street address line (apartment, suite, unit number) of the billing address. Optional supplementary address detail for Address Verification Service (AVS) processing.' ;
    rdfs:domain ind:PaymentMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingCity rdf:type rdf:Property ;
    rdfs:label 'Billing City' ;
    rdfs:comment 'City component of the billing address associated with this payment instrument. Used for AVS verification, fraud scoring, and geographic revenue reporting.' ;
    rdfs:domain ind:PaymentMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingCountryCode rdf:type rdf:Property ;
    rdfs:label 'Billing Country Code' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code of the billing address (e.g., USA, GBR, DEU). Determines applicable privacy regulation (GDPR for EU/EEA, CCPA for California), currency routing, and cross-border payment processing rules.' ;
    rdfs:domain ind:PaymentMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingPostalCode rdf:type rdf:Property ;
    rdfs:label 'Billing Postal Code' ;
    rdfs:comment 'Postal or ZIP code of the billing address. Critical input for Address Verification Service (AVS) checks on card-not-present transactions. Also used for geographic segmentation and tax jurisdiction mapping.' ;
    rdfs:domain ind:PaymentMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingStateProvince rdf:type rdf:Property ;
    rdfs:label 'Billing State Province' ;
    rdfs:comment 'State or province component of the billing address. Used for AVS verification, tax jurisdiction determination, and CCPA/GDPR applicability assessment for fan data privacy compliance.' ;
    rdfs:domain ind:PaymentMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:binNumber rdf:type rdf:Property ;
    rdfs:label 'Bin Number' ;
    rdfs:comment 'First 6–8 digits of the payment card number identifying the issuing institution and card product type. Used for routing decisions, interchange category determination, and fraud analysis. Stored as a non-sensitive BIN (not the full PAN) per PCI-DSS truncation rules.' ;
    rdfs:domain ind:PaymentMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cardFundingType rdf:type rdf:Property ;
    rdfs:label 'Card Funding Type' ;
    rdfs:comment 'Funding classification of the payment card as determined from BIN lookup. Distinguishes credit, debit, prepaid, and charge cards. Impacts interchange fee rates, refund processing timelines, and eligibility for certain promotional financing offers on season tickets.' ;
    rdfs:domain ind:PaymentMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cardholderName rdf:type rdf:Property ;
    rdfs:label 'Cardholder Name' ;
    rdfs:comment 'Name of the individual as it appears on the payment card or as registered with the payment instrument. Used for display in account management screens and for AVS/identity verification during high-value transactions. Stored only where operationally required per PCI-DSS data minimization principles.' ;
    rdfs:domain ind:PaymentMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentCaptureTimestamp rdf:type rdf:Property ;
    rdfs:label 'Consent Capture Timestamp' ;
    rdfs:comment 'Date and time when the fan explicitly consented to storing this payment instrument and authorizing recurring charges. Recorded in ISO 8601 format with timezone offset. Required for GDPR Article 6 lawful basis documentation and CCPA compliance audit trails.' ;
    rdfs:domain ind:PaymentMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:directDebitMandateRef rdf:type rdf:Property ;
    rdfs:label 'Direct Debit Mandate Ref' ;
    rdfs:comment 'Unique mandate reference number assigned for SEPA Direct Debit or ACH authorization agreements. Required for recurring direct debit collections such as installment-based season ticket payment plans. Null for non-direct-debit instruments.' ;
    rdfs:domain ind:PaymentMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expiryMonth rdf:type rdf:Property ;
    rdfs:label 'Expiry Month' ;
    rdfs:comment 'Two-digit calendar month (1–12) in which the payment card expires. Used in conjunction with expiry_year to determine card validity and trigger pre-expiry notification workflows for membership auto-renewal continuity.' ;
    rdfs:domain ind:PaymentMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:expiryNotificationSent rdf:type rdf:Property ;
    rdfs:label 'Expiry Notification Sent' ;
    rdfs:comment 'Indicates whether a pre-expiry notification has been dispatched to the fan via their preferred communication channel (email, SMS, push) to prompt card update before membership or season ticket auto-renewal fails. Managed by Adobe Experience Platform journey automation.' ;
    rdfs:domain ind:PaymentMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:expiryYear rdf:type rdf:Property ;
    rdfs:label 'Expiry Year' ;
    rdfs:comment 'Four-digit calendar year in which the payment card expires. Combined with expiry_month to assess card validity. Triggers automated pre-expiry fan communications to update payment details and prevent lapsed season ticket or membership renewals.' ;
    rdfs:domain ind:PaymentMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fraudRiskScore rdf:type rdf:Property ;
    rdfs:label 'Fraud Risk Score' ;
    rdfs:comment 'Numeric risk score (0.00–100.00) assigned to this payment instrument by the fraud detection engine at enrollment or last transaction. Higher scores indicate elevated fraud risk. Used to trigger step-up authentication, manual review, or instrument suspension. Not a calculated KPI — raw score from fraud provider.' ;
    rdfs:domain ind:PaymentMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:giftCardBalance rdf:type rdf:Property ;
    rdfs:label 'Gift Card Balance' ;
    rdfs:comment 'Current monetary balance remaining on a stored-value gift card payment instrument. Applicable only when payment_method_type is \'gift_card\'. Updated after each redemption transaction. Null for non-gift-card instruments. Denominated in the currency indicated by currency_code.' ;
    rdfs:domain ind:PaymentMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isDefault rdf:type rdf:Property ;
    rdfs:label 'Is Default' ;
    rdfs:comment 'Indicates whether this payment instrument is the fan\'s designated default method for one-click purchases, membership auto-renewals, and express checkout. Only one payment method per fan account should have this flag set to True at any time.' ;
    rdfs:domain ind:PaymentMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:issuerCountryCode rdf:type rdf:Property ;
    rdfs:label 'Issuer Country Code' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code of the financial institution that issued the payment card. Derived from the card BIN (Bank Identification Number). Used for cross-border transaction fee assessment, currency mismatch detection, and regulatory reporting.' ;
    rdfs:domain ind:PaymentMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastUsedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Used Timestamp' ;
    rdfs:comment 'Date and time of the most recent successful transaction processed against this payment instrument. Used to identify dormant payment methods for cleanup workflows and to assess instrument activity for fraud monitoring.' ;
    rdfs:domain ind:PaymentMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:methodStatus rdf:type rdf:Property ;
    rdfs:label 'Method Status' ;
    rdfs:comment 'Current lifecycle status of the payment instrument. \'active\' — valid and available for transactions; \'expired\' — card expiry date has passed; \'suspended\' — temporarily blocked due to fraud or dispute; \'removed\' — fan has deleted the instrument; \'pending_verification\' — awaiting micro-deposit or 3DS verification.' ;
    rdfs:domain ind:PaymentMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:networkTransactionReference rdf:type rdf:Property ;
    rdfs:label 'Network Transaction Reference' ;
    rdfs:comment 'Unique identifier assigned by the card network (Visa, Mastercard) during the initial card-on-file enrollment authorization. Required for subsequent MIT (Merchant-Initiated Transaction) recurring charges such as season ticket auto-renewals, ensuring compliance with card network stored credential mandates.' ;
    rdfs:domain ind:PaymentMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pciComplianceStatus rdf:type rdf:Property ;
    rdfs:label 'Pci Compliance Status' ;
    rdfs:comment 'Indicates the PCI-DSS compliance posture of this payment instrument record. \'compliant\' — token and data handling meet PCI-DSS v4.0 requirements; \'non_compliant\' — a compliance gap has been identified requiring remediation; \'pending_review\' — under compliance assessment. Supports PCI SSC audit reporting.' ;
    rdfs:domain ind:PaymentMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemTokenRef rdf:type rdf:Property ;
    rdfs:label 'Source System Token Ref' ;
    rdfs:comment 'External reference identifier for this payment token as recorded in the originating operational system (e.g., Ticketmaster/AXS vault ID, Shopify Plus payment method ID, Salesforce CRM payment record ID). Enables cross-system reconciliation and lineage tracing in the Silver Layer.' ;
    rdfs:domain ind:PaymentMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tokenValue rdf:type rdf:Property ;
    rdfs:label 'Token Value' ;
    rdfs:comment 'Opaque tokenized representation of the underlying payment instrument issued by the tokenization provider (e.g., Braintree, Stripe, Adyen). Replaces the raw PAN in all downstream systems. Never stores the actual card number. Compliant with PCI-DSS tokenization standards.' ;
    rdfs:domain ind:PaymentMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tokenizationProvider rdf:type rdf:Property ;
    rdfs:label 'Tokenization Provider' ;
    rdfs:comment 'Name of the third-party PCI-DSS compliant tokenization service provider that issued and manages the payment token. Used for routing, reconciliation, and vendor management. [ENUM-REF-CANDIDATE: Braintree|Adyen|Stripe|CyberSource|Worldpay|Checkout.com|Spreedly — promote to reference product if provider list grows beyond 6]' ;
    rdfs:domain ind:PaymentMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationMethod rdf:type rdf:Property ;
    rdfs:label 'Verification Method' ;
    rdfs:comment 'Method used to verify the payment instrument at enrollment. \'3ds\' — 3-D Secure authentication (Visa Secure / Mastercard Identity Check); \'avs\' — Address Verification Service; \'micro_deposit\' — two small deposits for bank account verification; \'cvv_check\' — card security code validation; \'none\' — no additional verification performed.' ;
    rdfs:domain ind:PaymentMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationStatus rdf:type rdf:Property ;
    rdfs:label 'Verification Status' ;
    rdfs:comment 'Outcome of the payment instrument verification process. \'verified\' — successfully authenticated; \'unverified\' — verification not yet completed; \'failed\' — verification attempt was unsuccessful; \'pending\' — verification in progress. Determines eligibility for high-value transactions such as season ticket purchases.' ;
    rdfs:domain ind:PaymentMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affiliatedTeamId rdf:type rdf:Property ;
    rdfs:label 'Affiliated Team Id' ;
    rdfs:comment 'Reference to the team or franchise this fan club is primarily associated with. Enables fan club segmentation by team for engagement programs and event access privileges.' ;
    rdfs:domain ind:Club ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Team .

ind:clubAffiliatedAthleteAthleteProfileId rdf:type rdf:Property ;
    rdfs:label 'Club Affiliated Athlete Athlete Profile Id' ;
    rdfs:comment 'Reference to the individual athlete this fan club is dedicated to, where the club is athlete-specific rather than team-specific (e.g., a player fan club). Nullable for team-based clubs.' ;
    rdfs:domain ind:Club ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AthleteProfile .

ind:clubAthleteProfileId rdf:type rdf:Property ;
    rdfs:label 'Club Athlete Profile Id' ;
    rdfs:comment 'Reference to the individual athlete this fan club is dedicated to, where the club is athlete-specific rather than team-specific (e.g., a player fan club). Nullable for team-based clubs.' ;
    rdfs:domain ind:Club ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AthleteProfile .

ind:clubSponsorId rdf:type rdf:Property ;
    rdfs:label 'Club Sponsor Id' ;
    rdfs:comment 'Reference to the primary commercial sponsor or brand partner associated with the fan club, enabling co-branded engagement programs and sponsorship ROI (Return on Investment) tracking.' ;
    rdfs:domain ind:Club ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Sponsor .

ind:clubSponsorshipPartnerSponsorId rdf:type rdf:Property ;
    rdfs:label 'Club Sponsorship Partner Sponsor Id' ;
    rdfs:comment 'Reference to the primary commercial sponsor or brand partner associated with the fan club, enabling co-branded engagement programs and sponsorship ROI (Return on Investment) tracking.' ;
    rdfs:domain ind:Club ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Sponsor .

ind:featuredContentAssetId rdf:type rdf:Property ;
    rdfs:label 'Featured Content Asset Id' ;
    rdfs:comment 'Foreign key linking to content.asset. Business justification: Fan club content management: official fan clubs in sports entertainment have a primary featured content asset (club promo video, intro reel). This FK supports club profile pages, CRM-driven club marke' ;
    rdfs:domain ind:Club ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Asset .

ind:parentClubId rdf:type rdf:Property ;
    rdfs:label 'Parent Club Id' ;
    rdfs:comment 'Self-referencing identifier for the parent fan club when this record represents a regional chapter or sub-chapter of a larger national or international fan club organization. Null for top-level clubs.' ;
    rdfs:domain ind:Club ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Club .

ind:annualRevenueUsd rdf:type rdf:Property ;
    rdfs:label 'Annual Revenue Usd' ;
    rdfs:comment 'Total annual revenue generated by the fan club from membership dues, merchandise sales, and events in USD. Used for financial planning, EBITDA contribution analysis, and sponsorship valuation. Sourced from SAP S/4HANA FI/CO.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:charterDocumentRef rdf:type rdf:Property ;
    rdfs:label 'Charter Document Ref' ;
    rdfs:comment 'Reference identifier or URL to the fan club\'s official charter, constitution, or founding document stored in the Digital Asset Management (DAM) system. Used for governance and compliance audits.' ;
    rdfs:domain ind:Club ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clubCode rdf:type rdf:Property ;
    rdfs:label 'Club Code' ;
    rdfs:comment 'Externally-known alphanumeric business identifier for the fan club, used in CRM systems, ticketing platforms, and member communications (e.g., \'MAN-UTD-OSC-NYC\'). Sourced from Salesforce CRM.' ;
    rdfs:domain ind:Club ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clubName rdf:type rdf:Property ;
    rdfs:label 'Club Name' ;
    rdfs:comment 'Official full name of the fan club as registered with the league or governing body (e.g., \'Manchester United Official Supporters Club – New York Chapter\').' ;
    rdfs:domain ind:Club ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clubStatus rdf:type rdf:Property ;
    rdfs:label 'Club Status' ;
    rdfs:comment 'Current lifecycle status of the fan club. \'active\' = fully operational; \'inactive\' = dormant but not dissolved; \'suspended\' = temporarily restricted by governing body; \'pending_approval\' = awaiting official recognition; \'dissolved\' = permanently closed.' ;
    rdfs:domain ind:Club ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clubType rdf:type rdf:Property ;
    rdfs:label 'Club Type' ;
    rdfs:comment 'Classification of the fan club by its organizational structure and affiliation level. \'official\' = league/team-sanctioned club; \'supporters_trust\' = member-owned democratic body; \'regional_chapter\' = geographic sub-chapter of a parent club; \'booster_club\' = fundraising-oriented; \'fan_society\' = informal affinity group.' ;
    rdfs:domain ind:Club ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crmAccountReference rdf:type rdf:Property ;
    rdfs:label 'Crm Account Reference' ;
    rdfs:comment 'External identifier for the fan club record in Salesforce CRM, enabling bi-directional synchronization between the lakehouse silver layer and the CRM system of record for fan and sponsor relationship management.' ;
    rdfs:domain ind:Club ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentMemberCount rdf:type rdf:Property ;
    rdfs:label 'Current Member Count' ;
    rdfs:comment 'Current total number of active enrolled members in the fan club as of the last refresh. Used for capacity monitoring, reporting, and engagement benchmarking. Not a calculated aggregate — sourced directly from the CRM enrollment system.' ;
    rdfs:domain ind:Club ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dissolutionDate rdf:type rdf:Property ;
    rdfs:label 'Dissolution Date' ;
    rdfs:comment 'The date on which the fan club was officially dissolved or deregistered. Null for active clubs. Used for lifecycle reporting and historical record retention.' ;
    rdfs:domain ind:Club ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:eventTicketAllocation rdf:type rdf:Property ;
    rdfs:label 'Event Ticket Allocation' ;
    rdfs:comment 'Number of event tickets allocated to the fan club per event or season by the team or venue, enabling priority access for members. Managed in coordination with Ticketmaster/AXS and Archtics inventory systems.' ;
    rdfs:domain ind:Club ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:foundingDate rdf:type rdf:Property ;
    rdfs:label 'Founding Date' ;
    rdfs:comment 'The official date on which the fan club was formally established or chartered. Used for anniversary recognition, eligibility calculations, and historical reporting.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:geographicTerritory rdf:type rdf:Property ;
    rdfs:label 'Geographic Territory' ;
    rdfs:comment 'The defined geographic territory or region in which the fan club operates and recruits members (e.g., \'Northeast USA\', \'Greater London\', \'Southeast Asia\'). Used for regional segmentation and chapter management.' ;
    rdfs:domain ind:Club ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hasVotingRights rdf:type rdf:Property ;
    rdfs:label 'Has Voting Rights' ;
    rdfs:comment 'Indicates whether the fan club grants members voting rights on club governance matters (e.g., election of club officers, rule changes). True for supporters trusts and democratic fan organizations.' ;
    rdfs:domain ind:Club ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isOfficialPartner rdf:type rdf:Property ;
    rdfs:label 'Is Official Partner' ;
    rdfs:comment 'Indicates whether the fan club holds an official partnership or affiliation agreement with the team, league, or governing body, granting access to official branding, event allocations, and co-marketing programs.' ;
    rdfs:domain ind:Club ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maxMembershipCapacity rdf:type rdf:Property ;
    rdfs:label 'Max Membership Capacity' ;
    rdfs:comment 'Maximum number of members the fan club is authorized or operationally designed to accommodate. Null indicates no cap. Used for waitlist management and capacity planning.' ;
    rdfs:domain ind:Club ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:membershipTierStructure rdf:type rdf:Property ;
    rdfs:label 'Membership Tier Structure' ;
    rdfs:comment 'Describes whether the fan club operates a single uniform membership level or a multi-tier structure with differentiated benefits (e.g., standard, premium, VIP). Drives benefit entitlement logic and dues pricing.' ;
    rdfs:domain ind:Club ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primarySport rdf:type rdf:Property ;
    rdfs:label 'Primary Sport' ;
    rdfs:comment 'The sport that the fan club is primarily associated with (e.g., \'Football\', \'Basketball\', \'Baseball\', \'Soccer\'). Used for cross-sport segmentation and content targeting.' ;
    rdfs:domain ind:Club ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recognitionDate rdf:type rdf:Property ;
    rdfs:label 'Recognition Date' ;
    rdfs:comment 'The date on which the fan club received official recognition or accreditation from the league, team, or governing body. May differ from founding_date for clubs that operated informally before formal recognition.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:originalFilingRegulatoryFilingId rdf:type rdf:Property ;
    rdfs:label 'Original Filing Regulatory Filing Id' ;
    rdfs:comment 'Reference to the original regulatory filing record that this filing amends or supersedes. Populated only when is_amendment is True.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RegulatoryFiling .

ind:acknowledgmentDate rdf:type rdf:Property ;
    rdfs:label 'Acknowledgment Date' ;
    rdfs:comment 'The date on which the governing body formally acknowledged receipt of the regulatory filing.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:acknowledgmentReference rdf:type rdf:Property ;
    rdfs:label 'Acknowledgment Reference' ;
    rdfs:comment 'Official reference number or confirmation code issued by the governing body upon receipt and acknowledgment of the filing.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confidentialityLevel rdf:type rdf:Property ;
    rdfs:label 'Confidentiality Level' ;
    rdfs:comment 'Data classification level of the filing content, governing internal access controls and disclosure obligations.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalPortalUrl rdf:type rdf:Property ;
    rdfs:label 'External Portal Url' ;
    rdfs:comment 'URL of the governing body\'s electronic filing portal where this submission was made or can be accessed (e.g., SEC EDGAR, WADA ADAMS, FCC Electronic Filing System).' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filingCategory rdf:type rdf:Property ;
    rdfs:label 'Filing Category' ;
    rdfs:comment 'High-level business domain category of the filing, enabling cross-domain compliance reporting and portfolio management across WADA, GDPR/CCPA, PCI-DSS, ADA, CAS, and financial regulators. [ENUM-REF-CANDIDATE: anti_doping|data_privacy|financial|broadcast|safety|accessibility|arbitration — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filingDescription rdf:type rdf:Property ;
    rdfs:label 'Filing Description' ;
    rdfs:comment 'Detailed narrative description of the regulatory filing\'s scope, content, and purpose, providing context for compliance officers and auditors.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filingPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Filing Period End Date' ;
    rdfs:comment 'The end date of the reporting or compliance period covered by this regulatory filing (e.g., fiscal year end, season end).' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:filingPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Filing Period Start Date' ;
    rdfs:comment 'The start date of the reporting or compliance period covered by this regulatory filing (e.g., fiscal year start, season start).' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:filingReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Filing Reference Number' ;
    rdfs:comment 'Externally-known unique reference number assigned to this regulatory filing, used for tracking and correspondence with the governing body.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filingStatus rdf:type rdf:Property ;
    rdfs:label 'Filing Status' ;
    rdfs:comment 'Current lifecycle state of the regulatory filing, from initial draft through governing body acknowledgment and final disposition. [ENUM-REF-CANDIDATE: draft|submitted|acknowledged|under_review|accepted|rejected|overdue — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filingTitle rdf:type rdf:Property ;
    rdfs:label 'Filing Title' ;
    rdfs:comment 'Descriptive title or name of the regulatory filing as it appears on the submission document (e.g., \'Annual Anti-Doping Declaration FY2024\', \'GDPR Article 30 Records of Processing\').' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filingType rdf:type rdf:Property ;
    rdfs:label 'Filing Type' ;
    rdfs:comment 'Classification of the regulatory filing by its purpose or mandate. [ENUM-REF-CANDIDATE: annual_report|incident_report|eligibility_certification|anti_doping_declaration|broadcast_license_renewal|financial_disclosure|privacy_impact_assessment|arbitration_submission|waiver_request|audit_response — promote to reference product]' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:governingBodyContact rdf:type rdf:Property ;
    rdfs:label 'Governing Body Contact' ;
    rdfs:comment 'Name or identifier of the primary contact person or department at the governing body responsible for receiving and processing this filing.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:internalCaseReference rdf:type rdf:Property ;
    rdfs:label 'Internal Case Reference' ;
    rdfs:comment 'Internal tracking number or case reference assigned by Sports Entertainment\'s compliance or legal team to this filing for cross-referencing with internal case management systems.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isAmendment rdf:type rdf:Property ;
    rdfs:label 'Is Amendment' ;
    rdfs:comment 'Indicates whether this filing is an amendment or correction to a previously submitted filing. True if this is an amended submission.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:penaltyRiskFlag rdf:type rdf:Property ;
    rdfs:label 'Penalty Risk Flag' ;
    rdfs:comment 'Indicates whether this filing carries a risk of regulatory penalty or sanction if not submitted on time or if rejected. Used for prioritization in compliance workflows.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recurrenceFrequency rdf:type rdf:Property ;
    rdfs:label 'Recurrence Frequency' ;
    rdfs:comment 'Frequency at which this type of regulatory filing recurs (e.g., annual for SEC annual reports, quarterly for financial disclosures). Populated when is_recurring is True.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryFramework rdf:type rdf:Property ;
    rdfs:label 'Regulatory Framework' ;
    rdfs:comment 'The primary regulatory or compliance framework under which this filing is made. [ENUM-REF-CANDIDATE: GDPR|CCPA|PCI_DSS|WADA|SOX|ADA|OSHA|ISO_20121|CAS|FCC|SEC|FIFA|IOC|NFL|NBA|MLB|NHL — promote to reference product]' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resubmissionDueDate rdf:type rdf:Property ;
    rdfs:label 'Resubmission Due Date' ;
    rdfs:comment 'Deadline by which a corrected or amended filing must be resubmitted following a rejection or request for additional information from the governing body.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reviewDeadlineDate rdf:type rdf:Property ;
    rdfs:label 'Review Deadline Date' ;
    rdfs:comment 'Internal deadline by which the filing must be reviewed and approved before submission to the governing body, supporting pre-submission quality control.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:submissionMethod rdf:type rdf:Property ;
    rdfs:label 'Submission Method' ;
    rdfs:comment 'The channel or method used to submit the filing to the governing body (e.g., electronic portal such as SEC EDGAR or WADA ADAMS, email, postal mail).' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Submission Timestamp' ;
    rdfs:comment 'The exact date and time the filing was formally submitted to the governing body. This is the principal business event timestamp for the filing transaction.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:submittedBy rdf:type rdf:Property ;
    rdfs:label 'Submitted By' ;
    rdfs:comment 'Full name or employee identifier of the internal staff member or authorized representative who submitted the filing on behalf of Sports Entertainment.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submitterTitle rdf:type rdf:Property ;
    rdfs:label 'Submitter Title' ;
    rdfs:comment 'Official job title of the individual who submitted the filing (e.g., Chief Compliance Officer, Legal Counsel, Data Protection Officer).' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportingDocumentCount rdf:type rdf:Property ;
    rdfs:label 'Supporting Document Count' ;
    rdfs:comment 'Number of supporting documents, attachments, or exhibits included with this regulatory filing submission.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:annualMembershipFee rdf:type rdf:Property ;
    rdfs:label 'Annual Membership Fee' ;
    rdfs:comment 'Annual fee or dues payable by Sports Entertainment to this governing body for membership, certification, or regulatory registration (in the denomination of penalty_currency_code).' ;
    rdfs:domain ind:GoverningBody ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:antiDopingAuthority rdf:type rdf:Property ;
    rdfs:label 'Anti Doping Authority' ;
    rdfs:comment 'Indicates whether this governing body has anti-doping testing, adjudication, or enforcement authority over Sports Entertainment\'s athletes (e.g., True for WADA, sport-specific anti-doping organizations).' ;
    rdfs:domain ind:GoverningBody ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:applicableBusinessDomains rdf:type rdf:Property ;
    rdfs:label 'Applicable Business Domains' ;
    rdfs:comment 'Comma-separated list of Sports Entertainment business domains subject to this governing body\'s authority (e.g., \'Athlete,Broadcast,Fan,Finance\' for GDPR; \'Athlete\' for WADA; \'Broadcast\' for FCC). Drives compliance scope mapping.' ;
    rdfs:domain ind:GoverningBody ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableFramework rdf:type rdf:Property ;
    rdfs:label 'Applicable Framework' ;
    rdfs:comment 'Primary regulatory framework, statute, or standard enforced by this body (e.g., GDPR, CCPA, PCI-DSS, SOX, WADA Code, ADA Title III, ISO 20121, CBA). Used to map compliance obligations to the correct authority.' ;
    rdfs:domain ind:GoverningBody ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:arbitrationAuthority rdf:type rdf:Property ;
    rdfs:label 'Arbitration Authority' ;
    rdfs:comment 'Indicates whether this body serves as a dispute resolution or arbitration authority for Sports Entertainment\'s legal and regulatory disputes (e.g., True for CAS — Court of Arbitration for Sport).' ;
    rdfs:domain ind:GoverningBody ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:auditCycle rdf:type rdf:Property ;
    rdfs:label 'Audit Cycle' ;
    rdfs:comment 'Frequency at which this governing body conducts or requires compliance audits, inspections, or assessments of Sports Entertainment\'s operations (e.g., annual for SOX/PCI-DSS, event_triggered for WADA testing, continuous for GDPR supervisory monitoring).' ;
    rdfs:domain ind:GoverningBody ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bodyType rdf:type rdf:Property ;
    rdfs:label 'Body Type' ;
    rdfs:comment 'Classification of the governing body by its organizational nature: sports_federation (FIFA, IOC, NFL, NBA, MLB, NHL, MLS), regulatory_agency (FCC, SEC, OSHA, ADA), standards_body (PCI SSC, ISO, WADA), arbitration_body (CAS), government_agency, or certification_body.' ;
    rdfs:domain ind:GoverningBody ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:broadcastRegulatoryAuthority rdf:type rdf:Property ;
    rdfs:label 'Broadcast Regulatory Authority' ;
    rdfs:comment 'Indicates whether this governing body regulates Sports Entertainment\'s broadcast, OTT streaming, or media rights distribution activities (e.g., True for FCC which governs broadcast licensing and content standards).' ;
    rdfs:domain ind:GoverningBody ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dataPrivacyAuthority rdf:type rdf:Property ;
    rdfs:label 'Data Privacy Authority' ;
    rdfs:comment 'Indicates whether this governing body is a data protection supervisory authority with jurisdiction over Sports Entertainment\'s fan data processing activities (e.g., True for GDPR supervisory authorities, CCPA enforcement via California AG).' ;
    rdfs:domain ind:GoverningBody ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:derecognitionDate rdf:type rdf:Property ;
    rdfs:label 'Derecognition Date' ;
    rdfs:comment 'Date on which Sports Entertainment\'s obligation to or recognition of this governing body ceased. Null if the relationship is still active.' ;
    rdfs:domain ind:GoverningBody ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:enforcementAuthorityLevel rdf:type rdf:Property ;
    rdfs:label 'Enforcement Authority Level' ;
    rdfs:comment 'Indicates the legal enforceability of this body\'s directives on Sports Entertainment: binding (mandatory legal compliance), advisory (recommended best practice), voluntary (opt-in participation), or conditional (binding only under specific circumstances such as event hosting).' ;
    rdfs:domain ind:GoverningBody ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filingDeadlineMonth rdf:type rdf:Property ;
    rdfs:label 'Filing Deadline Month' ;
    rdfs:comment 'Calendar month (1–12) by which annual regulatory filings, reports, or certifications must be submitted to this governing body (e.g., month 3 for SEC annual 10-K, month 12 for PCI-DSS Report on Compliance).' ;
    rdfs:domain ind:GoverningBody ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:frameworkEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Framework Effective Date' ;
    rdfs:comment 'Date on which the current version of the regulatory framework or standard became effective and binding on Sports Entertainment.' ;
    rdfs:domain ind:GoverningBody ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:frameworkVersion rdf:type rdf:Property ;
    rdfs:label 'Framework Version' ;
    rdfs:comment 'Current version or edition of the regulatory framework, code, or standard enforced by this body that Sports Entertainment is obligated to comply with (e.g., WADA Code 2021, PCI-DSS v4.0, ISO 20121:2012, GDPR 2016/679).' ;
    rdfs:domain ind:GoverningBody ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:governingBodyName rdf:type rdf:Property ;
    rdfs:label 'Governing Body Name' ;
    rdfs:comment 'Full official name of the governing body or regulatory authority (e.g., Fédération Internationale de Football Association, World Anti-Doping Agency).' ;
    rdfs:domain ind:GoverningBody ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:governingBodyStatus rdf:type rdf:Property ;
    rdfs:label 'Governing Body Status' ;
    rdfs:comment 'Current lifecycle status of the governing body record indicating whether Sports Entertainment is actively subject to its authority: active (current compliance obligation), inactive (no current obligation), suspended, dissolved, or under_review.' ;
    rdfs:domain ind:GoverningBody ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hqCity rdf:type rdf:Property ;
    rdfs:label 'Hq City' ;
    rdfs:comment 'City where the governing body\'s principal headquarters is located (e.g., Zurich for FIFA, Montreal for WADA, Lausanne for CAS/IOC, Washington D.C. for FCC).' ;
    rdfs:domain ind:GoverningBody ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hqCountry rdf:type rdf:Property ;
    rdfs:label 'Hq Country' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the country where the governing body\'s principal headquarters is physically located (e.g., CHE for FIFA/WADA/CAS in Switzerland, USA for FCC/SEC/OSHA).' ;
    rdfs:domain ind:GoverningBody ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:internalComplianceOwner rdf:type rdf:Property ;
    rdfs:label 'Internal Compliance Owner' ;
    rdfs:comment 'Name or employee identifier of the Sports Entertainment compliance officer or team lead responsible for managing the relationship and obligations with this governing body.' ;
    rdfs:domain ind:GoverningBody ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:internalLegalOwner rdf:type rdf:Property ;
    rdfs:label 'Internal Legal Owner' ;
    rdfs:comment 'Name or employee identifier of the Sports Entertainment legal counsel responsible for regulatory correspondence, filings, and dispute management with this governing body.' ;
    rdfs:domain ind:GoverningBody ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jurisdictionRegion rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Region' ;
    rdfs:comment 'Named geographic region or multi-country jurisdiction where the body\'s authority applies (e.g., European Union for GDPR supervisory authorities, North America for NHL Board of Governors). Complements primary_jurisdiction_country for supra-national bodies.' ;
    rdfs:domain ind:GoverningBody ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jurisdictionScope rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Scope' ;
    rdfs:comment 'Geographic scope of the governing body\'s authority: global (FIFA, IOC, WADA, CAS, PCI SSC), regional (GDPR supervisory authorities), national (FCC, SEC, OSHA, ADA, CCPA), state_provincial, or local.' ;
    rdfs:domain ind:GoverningBody ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastAuditOutcome rdf:type rdf:Property ;
    rdfs:label 'Last Audit Outcome' ;
    rdfs:comment 'Result of the most recently completed compliance audit by this governing body: pass (fully compliant), pass_with_findings (compliant with minor remediation required), fail (non-compliant), in_progress, or not_applicable.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxPenaltyAmount rdf:type rdf:Property ;
    rdfs:label 'Max Penalty Amount' ;
    rdfs:comment 'Maximum financial penalty (in the currency specified by penalty_currency_code) that this governing body can impose on Sports Entertainment per violation or incident (e.g., GDPR Article 83 up to €20M or 4% of global turnover).' ;
    rdfs:domain ind:GoverningBody ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:penaltyAuthority rdf:type rdf:Property ;
    rdfs:label 'Penalty Authority' ;
    rdfs:comment 'Indicates whether this governing body has the authority to impose financial penalties, sanctions, suspensions, or other punitive measures directly on Sports Entertainment or its athletes/operations.' ;
    rdfs:domain ind:GoverningBody ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:primaryContactTitle rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Title' ;
    rdfs:comment 'Official job title of the primary contact at the governing body (e.g., Director of Compliance, Chief Regulatory Officer, Enforcement Counsel).' ;
    rdfs:domain ind:GoverningBody ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryJurisdictionCountry rdf:type rdf:Property ;
    rdfs:label 'Primary Jurisdiction Country' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the primary jurisdiction where the governing body is headquartered or holds primary legal authority (e.g., CHE for Switzerland-based FIFA/WADA/CAS, USA for FCC/SEC/OSHA).' ;
    rdfs:domain ind:GoverningBody ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryDomain rdf:type rdf:Property ;
    rdfs:label 'Regulatory Domain' ;
    rdfs:comment 'Primary compliance or regulatory domain this body governs (e.g., anti-doping, data_privacy, broadcast_regulation, financial_reporting, venue_safety, payment_security, sport_governance, labor_relations, accessibility, event_sustainability). [ENUM-REF-CANDIDATE: anti_doping|data_privacy|broadcast_regulation|financial_reporting|venue_safety|payment_security|sport_governance|labor_relations|accessibility|event_sustainability — promote to reference product]' ;
    rdfs:domain ind:GoverningBody ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingObligation rdf:type rdf:Property ;
    rdfs:label 'Reporting Obligation' ;
    rdfs:comment 'Indicates whether Sports Entertainment has a mandatory periodic reporting or filing obligation to this governing body (e.g., True for SEC, SOX, FCC license renewals; False for advisory bodies).' ;
    rdfs:domain ind:GoverningBody ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:obligationGoverningBodyId rdf:type rdf:Property ;
    rdfs:label 'Obligation Governing Body Id' ;
    rdfs:comment 'The official identifier or article/section reference assigned by the governing body to this obligation (e.g., GDPR Article 17, WADA Code Article 2.1, PCI-DSS Requirement 6.3). Enables precise cross-referencing with official regulatory documentation.' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GoverningBody .

ind:obligationGoverningBodyReferenceGoverningBodyId rdf:type rdf:Property ;
    rdfs:label 'Obligation Governing Body Reference Governing Body Id' ;
    rdfs:comment 'FK to compliance.governing_body' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GoverningBody .

ind:applicabilityScope rdf:type rdf:Property ;
    rdfs:label 'Applicability Scope' ;
    rdfs:comment 'The operational scope within Sports Entertainment to which this obligation applies (e.g., global for GDPR, athlete for WADA anti-doping, venue for ADA accessibility, broadcast for FCC regulations, digital for CCPA). Determines which business units and systems are in scope. [ENUM-REF-CANDIDATE: global|regional|national|league|venue|event|athlete|broadcast|digital — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceCategory rdf:type rdf:Property ;
    rdfs:label 'Compliance Category' ;
    rdfs:comment 'High-level thematic category grouping obligations by compliance domain (e.g., data-privacy for GDPR/CCPA, anti-doping for WADA, payment-security for PCI-DSS, accessibility for ADA, financial-reporting for SOX). Enables portfolio-level compliance reporting. [ENUM-REF-CANDIDATE: data-privacy|anti-doping|payment-security|accessibility|financial-reporting|workplace-safety|broadcast-regulation|athlete-eligibility|arbitration|licensing|event-safety — promote to reference product]' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlFrameworkMapping rdf:type rdf:Property ;
    rdfs:label 'Control Framework Mapping' ;
    rdfs:comment 'Reference to the internal or industry control framework control identifier that addresses this obligation (e.g., ISO 27001 control A.18.1, NIST CSF PR.DS-1, COSO control activity). Enables integrated compliance and risk management reporting.' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enforcementConsequence rdf:type rdf:Property ;
    rdfs:label 'Enforcement Consequence' ;
    rdfs:comment 'Description of the regulatory, legal, or financial consequences of non-compliance with this obligation (e.g., \'GDPR fine up to 4% of global annual turnover\', \'WADA athlete suspension up to 4 years\', \'PCI-DSS card processing suspension\'). Critical for risk prioritization.' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationThresholdDays rdf:type rdf:Property ;
    rdfs:label 'Escalation Threshold Days' ;
    rdfs:comment 'Number of days before the next_review_date or reporting deadline at which an automated escalation alert is triggered to senior compliance leadership. Ensures timely intervention before regulatory deadlines are missed.' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:evidenceRequired rdf:type rdf:Property ;
    rdfs:label 'Evidence Required' ;
    rdfs:comment 'Indicates whether formal documentary evidence (audit logs, test results, certifications, filings) must be collected and retained to demonstrate compliance with this obligation. Drives evidence management workflows in the compliance program.' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:evidenceRetentionYears rdf:type rdf:Property ;
    rdfs:label 'Evidence Retention Years' ;
    rdfs:comment 'Number of years that compliance evidence and documentation for this obligation must be retained per regulatory or legal requirements. Drives records management policies and data lifecycle governance.' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isMandatory rdf:type rdf:Property ;
    rdfs:label 'Is Mandatory' ;
    rdfs:comment 'Indicates whether this obligation is legally or contractually mandatory (True) versus voluntary or best-practice (False). Mandatory obligations trigger formal compliance tracking, audit evidence collection, and regulatory reporting workflows.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nextReviewDate rdf:type rdf:Property ;
    rdfs:label 'Next Review Date' ;
    rdfs:comment 'Scheduled date for the next formal review of this obligation to assess continued applicability, regulatory changes, and compliance posture. Drives the compliance calendar and review task scheduling.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:obligationCode rdf:type rdf:Property ;
    rdfs:label 'Obligation Code' ;
    rdfs:comment 'Externally-known, human-readable unique code assigned to this compliance obligation (e.g., OBL-GDPR-20240001). Used as the business identifier across regulatory filings, audit reports, and cross-system references.' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:obligationDescription rdf:type rdf:Property ;
    rdfs:label 'Obligation Description' ;
    rdfs:comment 'Detailed narrative describing the full scope, requirements, and expectations of the compliance obligation as imposed by the governing body or regulation. Provides context for compliance officers and legal counsel.' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:obligationStatus rdf:type rdf:Property ;
    rdfs:label 'Obligation Status' ;
    rdfs:comment 'Current lifecycle state of the compliance obligation within the organization\'s compliance program. Active obligations are currently enforceable; expired obligations have passed their end date; waived obligations have been formally exempted by the governing body.' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:obligationType rdf:type rdf:Property ;
    rdfs:label 'Obligation Type' ;
    rdfs:comment 'Categorical classification of the obligation by its nature of required action (e.g., reporting, testing, audit, certification, training, disclosure, filing, monitoring). Drives workflow routing and task assignment. [ENUM-REF-CANDIDATE: reporting|testing|audit|certification|training|disclosure|filing|monitoring|policy-enforcement|eligibility-review — promote to reference product]' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:penaltyMaxAmount rdf:type rdf:Property ;
    rdfs:label 'Penalty Max Amount' ;
    rdfs:comment 'Maximum monetary penalty that can be imposed for non-compliance with this obligation, expressed in the currency specified by penalty_currency_code. Used for risk quantification, insurance coverage assessment, and executive risk reporting.' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatoryArticleReference rdf:type rdf:Property ;
    rdfs:label 'Regulatory Article Reference' ;
    rdfs:comment 'Specific article, section, clause, or requirement number within the regulatory framework that mandates this obligation (e.g., \'GDPR Article 17 - Right to Erasure\', \'PCI-DSS Requirement 3.4\', \'WADA Code Article 2.1\'). Enables precise legal cross-referencing.' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remediationDueDate rdf:type rdf:Property ;
    rdfs:label 'Remediation Due Date' ;
    rdfs:comment 'Target date by which any identified compliance gaps or non-conformances related to this obligation must be remediated. Populated when last_audit_outcome is non-compliant or partially-compliant.' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reportingDeadlineDay rdf:type rdf:Property ;
    rdfs:label 'Reporting Deadline Day' ;
    rdfs:comment 'Day of the month (1-31) by which periodic compliance reports or filings must be submitted to the governing body. Combined with reporting_deadline_month to define the annual filing deadline for obligations with fixed calendar deadlines.' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reportingDeadlineMonth rdf:type rdf:Property ;
    rdfs:label 'Reporting Deadline Month' ;
    rdfs:comment 'Month of the year (1-12) by which periodic compliance reports or filings must be submitted to the governing body. Combined with reporting_deadline_day to define the annual filing deadline.' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:responsibleBusinessUnit rdf:type rdf:Property ;
    rdfs:label 'Responsible Business Unit' ;
    rdfs:comment 'The internal business unit, department, or division that is the primary owner accountable for fulfilling this compliance obligation (e.g., Legal, Finance, IT Security, Athlete Management, Venue Operations). Drives accountability assignment and escalation paths.' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewFrequency rdf:type rdf:Property ;
    rdfs:label 'Review Frequency' ;
    rdfs:comment 'How often this compliance obligation must be formally reviewed and assessed for continued compliance (e.g., annual for SOX controls, quarterly for PCI-DSS, ad-hoc for CAS arbitration cases). Drives the compliance calendar. [ENUM-REF-CANDIDATE: daily|weekly|monthly|quarterly|semi-annual|annual|ad-hoc — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskLevel rdf:type rdf:Property ;
    rdfs:label 'Risk Level' ;
    rdfs:comment 'Assessed risk severity of non-compliance with this obligation, based on likelihood of breach and magnitude of consequence. Drives prioritization of compliance resources, audit scheduling, and executive escalation thresholds.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thirdPartyInvolved rdf:type rdf:Property ;
    rdfs:label 'Third Party Involved' ;
    rdfs:comment 'Indicates whether fulfillment of this obligation involves or requires oversight of a third-party vendor, partner, or service provider (True). Triggers third-party risk management workflows and vendor compliance assessment requirements.' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:thirdPartyName rdf:type rdf:Property ;
    rdfs:label 'Third Party Name' ;
    rdfs:comment 'Name of the primary third-party vendor, partner, or service provider involved in fulfilling this obligation (e.g., WADA-accredited testing laboratory, PCI-DSS Qualified Security Assessor, GDPR data processor). Populated only when third_party_involved is True.' ;
    rdfs:domain ind:Obligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentPolicyId rdf:type rdf:Property ;
    rdfs:label 'Parent Policy Id' ;
    rdfs:comment 'Self-referencing identifier pointing to a parent policy when this policy is a sub-policy or addendum of a higher-level framework policy (e.g., a regional GDPR addendum referencing the master Data Privacy Policy).' ;
    rdfs:domain ind:Policy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Policy .

ind:primarySupersededByPolicyId rdf:type rdf:Property ;
    rdfs:label 'Primary Superseded By Policy Id' ;
    rdfs:comment 'Identifier of the newer policy version that replaces this record when status is \'superseded\'. Enables version chain traceability for regulatory audit purposes.' ;
    rdfs:domain ind:Policy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Policy .

ind:adaSectionRef rdf:type rdf:Property ;
    rdfs:label 'Ada Section Ref' ;
    rdfs:comment 'Specific ADA title and section referenced by this accessibility policy (e.g., \'Title III Section 302 — Public Accommodations\'). Populated only for venue accessibility policies.' ;
    rdfs:domain ind:Policy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicabilityDomain rdf:type rdf:Property ;
    rdfs:label 'Applicability Domain' ;
    rdfs:comment 'Primary data or business domain to which this policy applies, aligned to Sports Entertainment\'s defined data domains. [ENUM-REF-CANDIDATE: event|athlete|venue|broadcast|ticketing|fan|sponsorship|merchandise|league|content|finance|workforce|digital_platform|all — promote to reference product]' ;
    rdfs:domain ind:Policy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalAuthority rdf:type rdf:Property ;
    rdfs:label 'Approval Authority' ;
    rdfs:comment 'Name or title of the individual, committee, or governing body that has authority to approve this policy (e.g., \'Board of Directors\', \'Chief Legal Officer\', \'Compliance Committee\').' ;
    rdfs:domain ind:Policy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attestationFrequencyMonths rdf:type rdf:Property ;
    rdfs:label 'Attestation Frequency Months' ;
    rdfs:comment 'Frequency in months at which in-scope personnel must re-attest compliance with this policy (e.g., 12 for annual attestation). Null if requires_attestation is False.' ;
    rdfs:domain ind:Policy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dataClassification rdf:type rdf:Property ;
    rdfs:label 'Data Classification' ;
    rdfs:comment 'Data classification level of the policy document itself, governing who may access and distribute it. Aligned to Sports Entertainment\'s data classification framework.' ;
    rdfs:domain ind:Policy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentUrl rdf:type rdf:Property ;
    rdfs:label 'Document Url' ;
    rdfs:comment 'Secure URL pointing to the authoritative policy document stored in the enterprise document management system or intranet (e.g., SharePoint, Dalet Galaxy DAM). Provides direct access to the full policy text.' ;
    rdfs:domain ind:Policy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionProcessDescription rdf:type rdf:Property ;
    rdfs:label 'Exception Process Description' ;
    rdfs:comment 'Description of the formal process by which an exception or waiver to this policy may be requested and approved, including the approving authority and required documentation.' ;
    rdfs:domain ind:Policy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fccRuleRef rdf:type rdf:Property ;
    rdfs:label 'Fcc Rule Ref' ;
    rdfs:comment 'Specific FCC regulation or rule number referenced by this broadcast content policy (e.g., \'47 CFR Part 73 — Broadcast Content Standards\'). Populated only for broadcast content policies.' ;
    rdfs:domain ind:Policy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gdprLawfulBasis rdf:type rdf:Property ;
    rdfs:label 'Gdpr Lawful Basis' ;
    rdfs:comment 'GDPR Article 6 lawful basis for processing personal data under this policy. Populated only for data privacy policies applicable to EU residents.' ;
    rdfs:domain ind:Policy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownerDepartment rdf:type rdf:Property ;
    rdfs:label 'Owner Department' ;
    rdfs:comment 'Organizational department or business unit responsible for policy ownership (e.g., \'Legal & Compliance\', \'Data Privacy Office\', \'Finance\', \'Venue Operations\').' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pciDssRequirementRef rdf:type rdf:Property ;
    rdfs:label 'Pci Dss Requirement Ref' ;
    rdfs:comment 'Specific PCI-DSS requirement number(s) addressed by this policy (e.g., \'Requirement 3.4 — Protect Stored Cardholder Data\'). Populated only for payment security policies.' ;
    rdfs:domain ind:Policy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:penaltyDescription rdf:type rdf:Property ;
    rdfs:label 'Penalty Description' ;
    rdfs:comment 'Description of sanctions, fines, or disciplinary consequences for non-compliance with this policy (e.g., \'GDPR fines up to 4% of global annual turnover\', \'WADA 4-year ban\', \'PCI-DSS card brand fines\').' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyCategory rdf:type rdf:Property ;
    rdfs:label 'Policy Category' ;
    rdfs:comment 'Secondary classification indicating whether the policy is driven by external regulatory mandate, internal governance decision, contractual obligation (e.g., CBA), or voluntary industry standard adoption.' ;
    rdfs:domain ind:Policy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyCode rdf:type rdf:Property ;
    rdfs:label 'Policy Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying the policy across all governing systems (e.g., POL-GDPR-20240001). Used in regulatory filings, audit trails, and cross-system references.' ;
    rdfs:domain ind:Policy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyName rdf:type rdf:Property ;
    rdfs:label 'Policy Name' ;
    rdfs:comment 'Official human-readable title of the compliance policy (e.g., \'GDPR Data Subject Rights Policy\', \'WADA Anti-Doping Program Policy\', \'PCI-DSS Cardholder Data Protection Policy\').' ;
    rdfs:domain ind:Policy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyStatus rdf:type rdf:Property ;
    rdfs:label 'Policy Status' ;
    rdfs:comment 'Current lifecycle state of the policy. \'draft\' indicates the policy is being authored; \'active\' means it is currently enforced; \'under_review\' means it is being revised; \'superseded\' means a newer version has replaced it; \'retired\' means it is no longer applicable; \'suspended\' means enforcement is temporarily paused.' ;
    rdfs:domain ind:Policy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyType rdf:type rdf:Property ;
    rdfs:label 'Policy Type' ;
    rdfs:comment 'High-level classification of the policy by compliance domain. [ENUM-REF-CANDIDATE: data_privacy|anti_doping|payment_security|venue_accessibility|broadcast_content|anti_corruption|conduct_and_ethics|labor_relations — promote to reference product]' ;
    rdfs:domain ind:Policy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryObligationRef rdf:type rdf:Property ;
    rdfs:label 'Regulatory Obligation Ref' ;
    rdfs:comment 'Specific regulatory article, section, or requirement that mandates this policy (e.g., \'GDPR Article 5\', \'PCI-DSS Requirement 12.1\', \'WADA Code Article 2.1\', \'ADA Title III Section 302\'). Links the policy to its external legal obligation.' ;
    rdfs:domain ind:Policy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiresAttestation rdf:type rdf:Property ;
    rdfs:label 'Requires Attestation' ;
    rdfs:comment 'Indicates whether in-scope employees, athletes, or contractors must formally attest (sign off) that they have read and understood this policy. Drives attestation workflow in SAP SuccessFactors.' ;
    rdfs:domain ind:Policy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reviewCycleMonths rdf:type rdf:Property ;
    rdfs:label 'Review Cycle Months' ;
    rdfs:comment 'Mandatory review frequency expressed in months (e.g., 12 for annual, 6 for semi-annual). Drives automated review scheduling and compliance calendar entries.' ;
    rdfs:domain ind:Policy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:scopeDescription rdf:type rdf:Property ;
    rdfs:label 'Scope Description' ;
    rdfs:comment 'Narrative description of the organizational scope of the policy — which business units, geographies, employee populations, systems, or operations are covered (e.g., \'Applies to all fan-facing digital platforms processing EU resident data\').' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingRequired rdf:type rdf:Property ;
    rdfs:label 'Training Required' ;
    rdfs:comment 'Indicates whether mandatory training must be completed by in-scope personnel as a condition of policy compliance. Drives training assignment in SAP SuccessFactors.' ;
    rdfs:domain ind:Policy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:wadaArticleRef rdf:type rdf:Property ;
    rdfs:label 'Wada Article Ref' ;
    rdfs:comment 'Specific WADA Code article number referenced by this anti-doping policy (e.g., \'Article 2.1 — Presence of Prohibited Substance\'). Populated only for anti-doping policies.' ;
    rdfs:domain ind:Policy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorEngagementAuditEngagementId rdf:type rdf:Property ;
    rdfs:label 'Prior Engagement Audit Engagement Id' ;
    rdfs:comment 'Reference to the immediately preceding audit engagement of the same type and scope, enabling year-over-year comparison, trend analysis, and tracking of repeat findings across audit cycles.' ;
    rdfs:domain ind:AuditEngagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AuditEngagement .

ind:attestationOfComplianceIssued rdf:type rdf:Property ;
    rdfs:label 'Attestation Of Compliance Issued' ;
    rdfs:comment 'Indicates whether a formal Attestation of Compliance (AOC) or equivalent compliance certificate has been issued as an output of this audit engagement. Particularly relevant for PCI-DSS QSA audits and ISO certification audits.' ;
    rdfs:domain ind:AuditEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:auditFirm rdf:type rdf:Property ;
    rdfs:label 'Audit Firm' ;
    rdfs:comment 'Name of the external audit firm, Qualified Security Assessor (QSA) organisation, or internal audit function conducting the engagement (e.g., Deloitte, KPMG, PCI-certified QSA firm). Null for purely internal audits.' ;
    rdfs:domain ind:AuditEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditReportReference rdf:type rdf:Property ;
    rdfs:label 'Audit Report Reference' ;
    rdfs:comment 'Document reference number or DAM (Digital Asset Management) identifier for the formal audit report stored in the content management system. Enables retrieval of the full report for regulatory review, legal proceedings, or CAS arbitration.' ;
    rdfs:domain ind:AuditEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditSubtype rdf:type rdf:Property ;
    rdfs:label 'Audit Subtype' ;
    rdfs:comment 'Further classification within the audit type (e.g., for PCI-DSS: QSA on-site, SAQ-D self-assessment; for SOX: internal controls over financial reporting, IT general controls; for OSHA: routine inspection, incident-triggered). Provides granular categorisation for analytics and benchmarking.' ;
    rdfs:domain ind:AuditEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditType rdf:type rdf:Property ;
    rdfs:label 'Audit Type' ;
    rdfs:comment 'Classification of the audit engagement by governing framework or regulatory program. Determines the applicable standards, scope templates, and reporting obligations. [ENUM-REF-CANDIDATE: PCI_DSS|SOX|OSHA|ADA|GDPR|WADA|ISO_20121|CCPA|internal — promote to reference product]' ;
    rdfs:domain ind:AuditEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditorType rdf:type rdf:Property ;
    rdfs:label 'Auditor Type' ;
    rdfs:comment 'Classification of the auditing party as internal (in-house audit team), external (independent audit firm or QSA), regulatory (government or governing body inspector), or third_party (vendor/partner audit). Affects independence requirements and report distribution.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cycleFrequency rdf:type rdf:Property ;
    rdfs:label 'Cycle Frequency' ;
    rdfs:comment 'Recurrence cadence of this audit engagement type as mandated by the governing framework or internal policy (e.g., PCI-DSS QSA annual, OSHA routine quarterly, WADA ad_hoc). Drives scheduling and forward pipeline planning.' ;
    rdfs:domain ind:AuditEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataPrivacyInScope rdf:type rdf:Property ;
    rdfs:label 'Data Privacy In Scope' ;
    rdfs:comment 'Indicates whether personal data processing activities (fan data, athlete data, employee data) are within the scope of this audit engagement, triggering GDPR/CCPA-specific audit procedures and data protection officer involvement.' ;
    rdfs:domain ind:AuditEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:engagementReference rdf:type rdf:Property ;
    rdfs:label 'Engagement Reference' ;
    rdfs:comment 'Externally-known alphanumeric reference code assigned to the audit engagement at initiation (e.g., AUD-2024-00123). Used in correspondence with auditors, regulators, and management. Aligns with the BUSINESS_IDENTIFIER canonical category for TRANSACTION_HEADER role.' ;
    rdfs:domain ind:AuditEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engagementRiskRating rdf:type rdf:Property ;
    rdfs:label 'Engagement Risk Rating' ;
    rdfs:comment 'Pre-audit risk rating assigned during planning to prioritise audit resources and determine scope depth. Based on inherent risk of the business unit, regulatory exposure, and prior audit history. Aligns with risk-based audit planning methodology.' ;
    rdfs:domain ind:AuditEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedRemediationCost rdf:type rdf:Property ;
    rdfs:label 'Estimated Remediation Cost' ;
    rdfs:comment 'Estimated financial cost in USD to remediate all open findings identified during the audit engagement. Used for budgeting, EBITDA impact assessment, and prioritisation of remediation investments. Populated post-report issuance.' ;
    rdfs:domain ind:AuditEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:finalDisposition rdf:type rdf:Property ;
    rdfs:label 'Final Disposition' ;
    rdfs:comment 'Ultimate resolution outcome of the audit engagement after all findings have been addressed. Indicates whether the engagement was fully closed with remediation, risk accepted by management, escalated to senior leadership, or referred to a regulatory body.' ;
    rdfs:domain ind:AuditEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:internalAuditOwner rdf:type rdf:Property ;
    rdfs:label 'Internal Audit Owner' ;
    rdfs:comment 'Name or identifier of the internal audit manager or compliance officer responsible for coordinating and owning this audit engagement on behalf of Sports Entertainment. Accountable for scheduling, evidence collection, and management response coordination.' ;
    rdfs:domain ind:AuditEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leadAuditorName rdf:type rdf:Property ;
    rdfs:label 'Lead Auditor Name' ;
    rdfs:comment 'Full name of the lead auditor responsible for conducting and signing off the audit engagement. May be an internal audit manager or an external QSA/firm representative. Retained for accountability and regulatory record-keeping.' ;
    rdfs:domain ind:AuditEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:managementResponseDueDate rdf:type rdf:Property ;
    rdfs:label 'Management Response Due Date' ;
    rdfs:comment 'Deadline by which management must submit formal responses to audit findings, including remediation plans and corrective action commitments. Tracked for SLA compliance and escalation management.' ;
    rdfs:domain ind:AuditEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:managementResponseReceived rdf:type rdf:Property ;
    rdfs:label 'Management Response Received' ;
    rdfs:comment 'Indicates whether management has submitted their formal response to audit findings within the required timeframe. Tracks SLA adherence for the management response process and triggers escalation when overdue.' ;
    rdfs:domain ind:AuditEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:openFindingsCount rdf:type rdf:Property ;
    rdfs:label 'Open Findings Count' ;
    rdfs:comment 'Number of audit findings that remain open and unresolved at the time of record update. Tracks remediation progress and supports KPI reporting on compliance posture.' ;
    rdfs:domain ind:AuditEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:overallOpinion rdf:type rdf:Property ;
    rdfs:label 'Overall Opinion' ;
    rdfs:comment 'The auditor\'s formal overall opinion or conclusion on the subject matter of the audit engagement. For PCI-DSS: compliant/non_compliant; for SOX: unqualified/qualified/adverse/disclaimer; for OSHA/ADA: pass/fail mapped to compliant/non_compliant. Null until report is issued.' ;
    rdfs:domain ind:AuditEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentSystemsInScope rdf:type rdf:Property ;
    rdfs:label 'Payment Systems In Scope' ;
    rdfs:comment 'Indicates whether payment card processing systems (POS terminals, e-commerce platforms, ticketing payment flows) are within the scope of this audit, triggering PCI-DSS specific audit procedures and QSA involvement.' ;
    rdfs:domain ind:AuditEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatorySubmissionRequired rdf:type rdf:Property ;
    rdfs:label 'Regulatory Submission Required' ;
    rdfs:comment 'Indicates whether the audit report or findings must be formally submitted to a regulatory authority or governing body (e.g., SEC filing for SOX, FCC for broadcast compliance, WADA for anti-doping program results). Drives submission workflow and deadline tracking.' ;
    rdfs:domain ind:AuditEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reportIssuanceDate rdf:type rdf:Property ;
    rdfs:label 'Report Issuance Date' ;
    rdfs:comment 'Date on which the formal audit report was issued to management and relevant stakeholders. Triggers the management response clock and regulatory submission deadlines.' ;
    rdfs:domain ind:AuditEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:targetBusinessUnit rdf:type rdf:Property ;
    rdfs:label 'Target Business Unit' ;
    rdfs:comment 'The organisational business unit, division, or department that is the primary subject of this audit engagement (e.g., Venue Operations, Broadcast & Media Rights, Ticketing, Fan Engagement, Finance). Enables domain-level compliance reporting and resource planning.' ;
    rdfs:domain ind:AuditEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalFindingsCount rdf:type rdf:Property ;
    rdfs:label 'Total Findings Count' ;
    rdfs:comment 'Total number of audit findings, observations, or deficiencies identified during the engagement across all severity levels. Provides a headline metric for management reporting and trend analysis.' ;
    rdfs:domain ind:AuditEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:wadaProgramInScope rdf:type rdf:Property ;
    rdfs:label 'Wada Program In Scope' ;
    rdfs:comment 'Indicates whether the WADA anti-doping program, including testing pools, whereabouts compliance, and Therapeutic Use Exemption (TUE) administration, is within the scope of this audit engagement.' ;
    rdfs:domain ind:AuditEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:acceptedRiskApprovedBy rdf:type rdf:Property ;
    rdfs:label 'Accepted Risk Approved By' ;
    rdfs:comment 'Name or identifier of the senior executive or risk committee member who formally approved the risk acceptance decision. Required for audit trail integrity under SOX and PCI-DSS.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acceptedRiskExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Accepted Risk Expiry Date' ;
    rdfs:comment 'Date on which the risk acceptance decision expires and must be reviewed and re-approved. Ensures time-bounded risk acceptance in line with PCI-DSS and SOX governance requirements.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:acceptedRiskRationale rdf:type rdf:Property ;
    rdfs:label 'Accepted Risk Rationale' ;
    rdfs:comment 'Documented management rationale for formally accepting the residual risk associated with this finding rather than remediating it. Required when finding_status is \'accepted-risk\'. Must be approved by an authorised risk owner per governance policy.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualRemediationDate rdf:type rdf:Property ;
    rdfs:label 'Actual Remediation Date' ;
    rdfs:comment 'Date on which remediation was actually completed and confirmed by the finding owner. Null if remediation is not yet complete. Used to calculate remediation cycle time and SLA adherence.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:affectedBusinessProcess rdf:type rdf:Property ;
    rdfs:label 'Affected Business Process' ;
    rdfs:comment 'Core business process impacted by the finding (e.g., Ticket Sales and Revenue Management, Fan Engagement, Broadcast Rights Distribution, Venue Operations). Aligns findings to the business process taxonomy for operational risk reporting.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedSystem rdf:type rdf:Property ;
    rdfs:label 'Affected System' ;
    rdfs:comment 'Name of the operational system, application, or platform where the non-conformance was identified (e.g., SAP S/4HANA FI, Ticketmaster, Salesforce CRM, Shopify Plus POS). Enables system-level risk aggregation.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignedOwner rdf:type rdf:Property ;
    rdfs:label 'Assigned Owner' ;
    rdfs:comment 'Name or identifier of the individual or team accountable for remediating this finding. Typically a business unit leader or compliance officer responsible for the affected control area.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditPeriodEnd rdf:type rdf:Property ;
    rdfs:label 'Audit Period End' ;
    rdfs:comment 'End date of the audit period during which this finding was identified. Together with audit_period_start, defines the scope window for the audit engagement.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:auditPeriodStart rdf:type rdf:Property ;
    rdfs:label 'Audit Period Start' ;
    rdfs:comment 'Start date of the audit period during which this finding was identified. Enables temporal scoping of findings to specific fiscal or compliance review periods.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:auditorName rdf:type rdf:Property ;
    rdfs:label 'Auditor Name' ;
    rdfs:comment 'Name of the lead auditor (internal or external) who identified and documented this finding. Required for audit trail accountability and regulatory reporting.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlDomain rdf:type rdf:Property ;
    rdfs:label 'Control Domain' ;
    rdfs:comment 'Functional control area to which the finding belongs (e.g., Access Control, Data Privacy, Financial Reporting, Venue Safety, Anti-Doping, Payment Processing). Enables domain-level aggregation of findings for risk reporting. [ENUM-REF-CANDIDATE: Access Control|Data Privacy|Financial Reporting|Venue Safety|Anti-Doping|Payment Processing|Broadcast Compliance|Athlete Eligibility — promote to reference product]' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlReference rdf:type rdf:Property ;
    rdfs:label 'Control Reference' ;
    rdfs:comment 'Specific control identifier from the applicable regulatory framework or internal control catalogue that was found to be non-conformant (e.g., PCI-DSS Req 8.2.1, SOX ITGC-04, GDPR Art.32). Enables traceability to the control library.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationDate rdf:type rdf:Property ;
    rdfs:label 'Escalation Date' ;
    rdfs:comment 'Date on which the finding was formally escalated to senior management, the audit committee, or a regulatory authority. Null if no escalation has occurred.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:escalationRequired rdf:type rdf:Property ;
    rdfs:label 'Escalation Required' ;
    rdfs:comment 'Indicates whether this finding requires escalation to senior management, the audit committee, or a regulatory body due to its severity, regulatory implications, or overdue remediation status.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:evidenceReference rdf:type rdf:Property ;
    rdfs:label 'Evidence Reference' ;
    rdfs:comment 'Reference identifier or location of the supporting audit evidence (e.g., document ID, DAM asset reference, screenshot log path) that substantiates the finding. Supports audit trail completeness and regulatory defensibility.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:findingCategory rdf:type rdf:Property ;
    rdfs:label 'Finding Category' ;
    rdfs:comment 'Severity classification of the finding per standard audit grading: critical (immediate risk/breach), major (significant non-conformance), minor (limited non-conformance), or observation (improvement opportunity with no current non-conformance).' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:findingReference rdf:type rdf:Property ;
    rdfs:label 'Finding Reference' ;
    rdfs:comment 'Externally-known alphanumeric reference code assigned to this finding for cross-system tracking and regulatory correspondence (e.g., PCI-2024-F0012). Serves as the business identifier communicated to auditors and regulators.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:findingStatus rdf:type rdf:Property ;
    rdfs:label 'Finding Status' ;
    rdfs:comment 'Current lifecycle state of the finding: open (identified, not yet actioned), in-remediation (remediation underway), closed (remediation verified complete), or accepted-risk (risk formally accepted by management with documented rationale).' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:findingTitle rdf:type rdf:Property ;
    rdfs:label 'Finding Title' ;
    rdfs:comment 'Short, human-readable title summarising the nature of the audit finding (e.g., \'Inadequate access control review for POS terminals\'). Used in executive dashboards and regulatory reports.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:identifiedDate rdf:type rdf:Property ;
    rdfs:label 'Identified Date' ;
    rdfs:comment 'Calendar date on which the finding was formally identified and documented during the audit fieldwork. Represents the principal business event date for this finding.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:managementResponse rdf:type rdf:Property ;
    rdfs:label 'Management Response' ;
    rdfs:comment 'Formal written response from management acknowledging the finding and committing to a remediation approach. Captured as part of the audit report finalisation process and required for SOX and PCI-DSS audit documentation.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nonConformanceDescription rdf:type rdf:Property ;
    rdfs:label 'Non Conformance Description' ;
    rdfs:comment 'Detailed narrative describing the specific non-conformance or gap identified during the audit. Includes what was observed, what was expected per the control requirement, and the evidence reviewed.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorFindingReference rdf:type rdf:Property ;
    rdfs:label 'Prior Finding Reference' ;
    rdfs:comment 'Reference number of the original finding from a prior audit cycle if this is a repeat finding. Enables lineage tracking of recurring control deficiencies across audit periods.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recommendedRemediation rdf:type rdf:Property ;
    rdfs:label 'Recommended Remediation' ;
    rdfs:comment 'Auditor-recommended corrective or preventive action to address the non-conformance and prevent recurrence. Forms the basis of the remediation plan agreed with the finding owner.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Regulatory Notification Date' ;
    rdfs:comment 'Date on which the mandatory regulatory notification was submitted to the relevant governing body. Null if notification is not required or not yet submitted. Critical for GDPR 72-hour deadline compliance tracking.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:remediationPlan rdf:type rdf:Property ;
    rdfs:label 'Remediation Plan' ;
    rdfs:comment 'Management\'s documented plan for addressing the finding, including specific actions, milestones, and resources committed. May differ from the auditor\'s recommendation where management has chosen an alternative approach.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:repeatFinding rdf:type rdf:Property ;
    rdfs:label 'Repeat Finding' ;
    rdfs:comment 'Indicates whether this finding is a recurrence of a previously identified finding from a prior audit cycle. Repeat findings signal systemic control failures and trigger escalated remediation requirements under PCI-DSS and SOX.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:riskImpactDescription rdf:type rdf:Property ;
    rdfs:label 'Risk Impact Description' ;
    rdfs:comment 'Narrative description of the potential business, financial, legal, or reputational impact if this finding is not remediated. Supports risk-based prioritisation and executive reporting.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetRemediationDate rdf:type rdf:Property ;
    rdfs:label 'Target Remediation Date' ;
    rdfs:comment 'Agreed target date by which the remediation action must be completed and verified. Used for SLA tracking and regulatory deadline management.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:verifiedBy rdf:type rdf:Property ;
    rdfs:label 'Verified By' ;
    rdfs:comment 'Name or identifier of the auditor or compliance officer who independently verified the effectiveness of the remediation action and authorised closure of the finding.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dopingTestId rdf:type rdf:Property ;
    rdfs:label 'Doping Test Id' ;
    rdfs:comment 'Primary key for doping_test' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DopingTest .

ind:primaryDopingAthleteAthleteProfileId rdf:type rdf:Property ;
    rdfs:label 'Primary Doping Athlete Athlete Profile Id' ;
    rdfs:comment 'Reference to the athlete subject to the doping test or whereabouts filing obligation.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AthleteProfile .

ind:primaryDopingCompetitionEventFixtureId rdf:type rdf:Property ;
    rdfs:label 'Primary Doping Competition Event Fixture Id' ;
    rdfs:comment 'Reference to the sanctioned competition event during which an in-competition test was conducted. Null for out-of-competition tests and whereabouts records.' ;
    rdfs:domain ind:DopingTest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Fixture .

ind:whereaboutsFilingId rdf:type rdf:Property ;
    rdfs:label 'Whereabouts Filing Id' ;
    rdfs:comment 'Foreign key linking to compliance.whereabouts_filing. Business justification: A doping test (particularly out-of-competition testing) is conducted against a specific whereabouts filing period. The doping_test has whereabouts_filing_period as a string field. Replacing this with ' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WhereaboutsFiling .

ind:adamsReference rdf:type rdf:Property ;
    rdfs:label 'Adams Reference' ;
    rdfs:comment 'Unique reference number assigned within the WADA Anti-Doping Administration and Management System (ADAMS) for cross-system traceability of the test or whereabouts filing.' ;
    rdfs:domain ind:DopingTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bSampleAnalysisRequested rdf:type rdf:Property ;
    rdfs:label 'B Sample Analysis Requested' ;
    rdfs:comment 'Indicates whether the athlete has formally requested analysis of the B-sample to contest an Adverse Analytical Finding (AAF) on the A-sample.' ;
    rdfs:domain ind:DopingTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:bSampleResultStatus rdf:type rdf:Property ;
    rdfs:label 'B Sample Result Status' ;
    rdfs:comment 'Outcome of the B-sample confirmatory analysis. A confirmed result corroborates the A-sample AAF; a not-confirmed result may lead to case withdrawal.' ;
    rdfs:domain ind:DopingTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:casCaseReference rdf:type rdf:Property ;
    rdfs:label 'Cas Case Reference' ;
    rdfs:comment 'Reference number of any Court of Arbitration for Sport (CAS) appeal or arbitration proceeding arising from this doping test result.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chainOfCustodyStatus rdf:type rdf:Property ;
    rdfs:label 'Chain Of Custody Status' ;
    rdfs:comment 'Current integrity status of the sample chain of custody from collection through laboratory receipt. A broken chain may invalidate the test result.' ;
    rdfs:domain ind:DopingTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectionCountryCode rdf:type rdf:Property ;
    rdfs:label 'Collection Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the jurisdiction where the sample was collected, used for jurisdictional reporting and WADA regional authority assignment.' ;
    rdfs:domain ind:DopingTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectionDate rdf:type rdf:Property ;
    rdfs:label 'Collection Date' ;
    rdfs:comment 'Calendar date on which the biological sample was collected from the athlete by the Doping Control Officer (DCO). Null for whereabouts-only records.' ;
    rdfs:domain ind:DopingTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:collectionLocation rdf:type rdf:Property ;
    rdfs:label 'Collection Location' ;
    rdfs:comment 'Descriptive name or address of the facility or venue where the sample was collected (e.g., doping control station at stadium, athlete hotel, training facility).' ;
    rdfs:domain ind:DopingTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Collection Timestamp' ;
    rdfs:comment 'Precise date and time at which the biological sample was collected, used for chain-of-custody sequencing and time-sensitive analysis windows.' ;
    rdfs:domain ind:DopingTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:dcoIdentifier rdf:type rdf:Property ;
    rdfs:label 'Dco Identifier' ;
    rdfs:comment 'Unique identifier of the certified Doping Control Officer (DCO) who conducted the sample collection, used for chain-of-custody accountability and DCO performance auditing.' ;
    rdfs:domain ind:DopingTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:laboratoryAccreditationNumber rdf:type rdf:Property ;
    rdfs:label 'Laboratory Accreditation Number' ;
    rdfs:comment 'WADA-issued accreditation number of the testing laboratory, confirming its authorization to conduct anti-doping analyses.' ;
    rdfs:domain ind:DopingTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:laboratoryReference rdf:type rdf:Property ;
    rdfs:label 'Laboratory Reference' ;
    rdfs:comment 'Identifier or name of the WADA-accredited laboratory to which the sample was dispatched for analysis.' ;
    rdfs:domain ind:DopingTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:missedFilingCount rdf:type rdf:Property ;
    rdfs:label 'Missed Filing Count' ;
    rdfs:comment 'Cumulative count of missed or incomplete whereabouts filings within the rolling 12-month window. Three strikes within 12 months constitutes an anti-doping rule violation under WADA Code Article 2.4.' ;
    rdfs:domain ind:DopingTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:missedTestCount rdf:type rdf:Property ;
    rdfs:label 'Missed Test Count' ;
    rdfs:comment 'Cumulative count of missed doping tests (failure to be present at declared whereabouts location) within the rolling 12-month window, contributing to the Article 2.4 violation threshold.' ;
    rdfs:domain ind:DopingTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:overnightLocation rdf:type rdf:Property ;
    rdfs:label 'Overnight Location' ;
    rdfs:comment 'Address or description of the athlete\'s regular overnight accommodation as declared in the whereabouts filing, used by DCOs to locate the athlete for unannounced testing.' ;
    rdfs:domain ind:DopingTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prohibitedSubstance rdf:type rdf:Property ;
    rdfs:label 'Prohibited Substance' ;
    rdfs:comment 'Name of the prohibited substance or method detected in the sample, as listed on the WADA Prohibited List. Null for negative results or whereabouts records.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prohibitedSubstanceCategory rdf:type rdf:Property ;
    rdfs:label 'Prohibited Substance Category' ;
    rdfs:comment 'WADA Prohibited List category of the detected substance or method (e.g., S1 Anabolic Agents, S2 Peptide Hormones, M1 Blood Manipulation). [ENUM-REF-CANDIDATE: S0|S1|S2|S3|S4|S5|S6|S7|S8|S9|P1|M1|M2|M3 — promote to reference product]' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registeredTestingPool rdf:type rdf:Property ;
    rdfs:label 'Registered Testing Pool' ;
    rdfs:comment 'Indicates the Registered Testing Pool (RTP) tier to which the athlete belongs at the time of the test or filing, determining the applicable whereabouts and testing obligations.' ;
    rdfs:domain ind:DopingTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resultNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Result Notification Date' ;
    rdfs:comment 'Date on which the test result was formally communicated to the athlete and relevant Anti-Doping Organization (ADO), triggering any applicable provisional suspension timelines.' ;
    rdfs:domain ind:DopingTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sampleCodeA rdf:type rdf:Property ;
    rdfs:label 'Sample Code A' ;
    rdfs:comment 'Unique barcode or identifier assigned to the primary (A) sample container at the point of collection, used for laboratory tracking and chain-of-custody verification.' ;
    rdfs:domain ind:DopingTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleCodeB rdf:type rdf:Property ;
    rdfs:label 'Sample Code B' ;
    rdfs:comment 'Unique barcode or identifier assigned to the reserve (B) sample container, retained for confirmatory analysis if the A-sample returns an Adverse Analytical Finding (AAF).' ;
    rdfs:domain ind:DopingTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleType rdf:type rdf:Property ;
    rdfs:label 'Sample Type' ;
    rdfs:comment 'Biological matrix collected during the test. Values include urine, blood, Athlete Biological Passport (ABP) longitudinal blood sample, or dried blood spot. Null for whereabouts-only records.' ;
    rdfs:domain ind:DopingTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sanctionEndDate rdf:type rdf:Property ;
    rdfs:label 'Sanction End Date' ;
    rdfs:comment 'Date on which the period of ineligibility or sanction is scheduled to end, after which the athlete may apply for reinstatement of eligibility.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sanctionStartDate rdf:type rdf:Property ;
    rdfs:label 'Sanction Start Date' ;
    rdfs:comment 'Date on which the formal period of ineligibility or sanction commenced, used to calculate eligibility reinstatement dates.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sanctionStatus rdf:type rdf:Property ;
    rdfs:label 'Sanction Status' ;
    rdfs:comment 'Current disciplinary sanction status resulting from this test record. Tracks progression from provisional suspension through formal sanction or appeal outcome.' ;
    rdfs:domain ind:DopingTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Test Reference Number' ;
    rdfs:comment 'Externally assigned unique identifier for the doping test event, issued by the Doping Control Officer (DCO) or testing authority at the point of sample collection. Null for whereabouts-only records.' ;
    rdfs:domain ind:DopingTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testType rdf:type rdf:Property ;
    rdfs:label 'Test Type' ;
    rdfs:comment 'Classification of the doping test as in-competition (conducted during or around a sanctioned event) or out-of-competition (conducted outside of event periods), per WADA definitions.' ;
    rdfs:domain ind:DopingTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:therapeuticUseExemptionGranted rdf:type rdf:Property ;
    rdfs:label 'Therapeutic Use Exemption Granted' ;
    rdfs:comment 'Indicates whether a valid Therapeutic Use Exemption (TUE) was in place for the athlete at the time of the test, which may negate an Adverse Analytical Finding (AAF) for an otherwise prohibited substance.' ;
    rdfs:domain ind:DopingTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:trainingLocation rdf:type rdf:Property ;
    rdfs:label 'Training Location' ;
    rdfs:comment 'Address or name of the primary training facility declared in the whereabouts filing, including scheduled training hours for the filing period.' ;
    rdfs:domain ind:DopingTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:whereaboutsComplianceStatus rdf:type rdf:Property ;
    rdfs:label 'Whereabouts Compliance Status' ;
    rdfs:comment 'Compliance classification for the whereabouts filing submission. A missed or incomplete filing may count toward the three-strike threshold for an Article 2.4 anti-doping rule violation.' ;
    rdfs:domain ind:DopingTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:whereaboutsSubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Whereabouts Submission Date' ;
    rdfs:comment 'Date on which the athlete submitted their whereabouts filing for the applicable quarter. Used to determine compliance with the quarterly submission deadline.' ;
    rdfs:domain ind:DopingTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:aSampleResult rdf:type rdf:Property ;
    rdfs:label 'A Sample Result' ;
    rdfs:comment 'Result of the analysis of the A-sample (primary sample) by the WADA-accredited laboratory. An Adverse Analytical Finding (AAF) triggers the ADRV process; an Atypical Finding (ATF) requires further investigation.' ;
    rdfs:domain ind:DopingViolation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bSampleRequestedFlag rdf:type rdf:Property ;
    rdfs:label 'B Sample Requested Flag' ;
    rdfs:comment 'Indicates whether the athlete exercised their right to request analysis of the B-sample (confirmation sample) to verify the A-sample result. True if B-sample analysis was requested.' ;
    rdfs:domain ind:DopingViolation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:bSampleResult rdf:type rdf:Property ;
    rdfs:label 'B Sample Result' ;
    rdfs:comment 'Result of the B-sample analysis confirming or refuting the A-sample Adverse Analytical Finding (AAF). Confirmed means the ADRV is substantiated; not_confirmed may lead to case withdrawal. Null if B-sample was not requested.' ;
    rdfs:domain ind:DopingViolation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:banDurationMonths rdf:type rdf:Property ;
    rdfs:label 'Ban Duration Months' ;
    rdfs:comment 'Length of the period of ineligibility (ban) imposed on the athlete, expressed in months. Standard WADA Code sanctions are 12, 24, or 48 months depending on substance category and aggravating/mitigating factors. Zero if no ineligibility was imposed.' ;
    rdfs:domain ind:DopingViolation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:banEndDate rdf:type rdf:Property ;
    rdfs:label 'Ban End Date' ;
    rdfs:comment 'Date on which the period of ineligibility (ban) is scheduled to expire, calculated from ban_start_date plus ban_duration_months. Null if the ban is indefinite or pending final determination.' ;
    rdfs:domain ind:DopingViolation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:banStartDate rdf:type rdf:Property ;
    rdfs:label 'Ban Start Date' ;
    rdfs:comment 'Date on which the period of ineligibility (ban) officially commenced. May be backdated to the date of provisional suspension or sample collection per WADA Code Article 10.11.' ;
    rdfs:domain ind:DopingViolation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:casDecisionDate rdf:type rdf:Property ;
    rdfs:label 'Cas Decision Date' ;
    rdfs:comment 'Date on which the Court of Arbitration for Sport (CAS) issued its final arbitral award on the appeal. Null if CAS proceedings are ongoing or no appeal was filed.' ;
    rdfs:domain ind:DopingViolation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:casOutcome rdf:type rdf:Property ;
    rdfs:label 'Cas Outcome' ;
    rdfs:comment 'Outcome of the Court of Arbitration for Sport (CAS) arbitral award: whether the original sanction was upheld, reduced, increased, overturned, remanded for rehearing, or the appeal was withdrawn. Null if no CAS appeal was filed.' ;
    rdfs:domain ind:DopingViolation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:casReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Cas Reference Number' ;
    rdfs:comment 'Official Court of Arbitration for Sport (CAS) case reference number assigned when the violation decision is appealed to CAS arbitration (e.g., CAS 2023/A/9876). Null if no CAS appeal has been filed.' ;
    rdfs:domain ind:DopingViolation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseNotes rdf:type rdf:Property ;
    rdfs:label 'Case Notes' ;
    rdfs:comment 'Free-text field for compliance officers to record case-specific notes, mitigating or aggravating circumstances, legal observations, or procedural annotations relevant to the Anti-Doping Rule Violation (ADRV) case management.' ;
    rdfs:domain ind:DopingViolation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disqualificationEndDate rdf:type rdf:Property ;
    rdfs:label 'Disqualification End Date' ;
    rdfs:comment 'End date of the period for which competition results are disqualified. Null if disqualification is open-ended or covers all results from the start date forward.' ;
    rdfs:domain ind:DopingViolation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:disqualificationStartDate rdf:type rdf:Property ;
    rdfs:label 'Disqualification Start Date' ;
    rdfs:comment 'Start date of the period for which competition results are disqualified. Typically the date of the sample collection or the date of the non-analytical violation.' ;
    rdfs:domain ind:DopingViolation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:hearingBody rdf:type rdf:Property ;
    rdfs:label 'Hearing Body' ;
    rdfs:comment 'Name of the tribunal, panel, or disciplinary body that conducted the hearing (e.g., FIFA Disciplinary Committee, NFL Anti-Doping Program Panel, WADA Independent Hearing Panel).' ;
    rdfs:domain ind:DopingViolation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inCompetitionFlag rdf:type rdf:Property ;
    rdfs:label 'In Competition Flag' ;
    rdfs:comment 'Indicates whether the sample or violation occurred during an in-competition period (True) or out-of-competition (False). Relevant for determining which prohibited substances apply under the WADA Prohibited List.' ;
    rdfs:domain ind:DopingViolation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:laboratoryName rdf:type rdf:Property ;
    rdfs:label 'Laboratory Name' ;
    rdfs:comment 'Name of the WADA-accredited laboratory that performed the analysis of the biological sample and issued the Adverse Analytical Finding (AAF) or Atypical Finding (ATF). Null for non-analytical violations.' ;
    rdfs:domain ind:DopingViolation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationDate rdf:type rdf:Property ;
    rdfs:label 'Notification Date' ;
    rdfs:comment 'Date on which the athlete was formally notified of the Anti-Doping Rule Violation (ADRV) by the anti-doping organisation (ADO) or governing body. Triggers the provisional suspension clock under WADA Code.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:prohibitedMethod rdf:type rdf:Property ;
    rdfs:label 'Prohibited Method' ;
    rdfs:comment 'Description of the prohibited method used (e.g., blood doping, gene doping, manipulation of samples), where the violation involves a prohibited method rather than a substance. Null when not applicable.' ;
    rdfs:domain ind:DopingViolation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:provisionalSuspensionDate rdf:type rdf:Property ;
    rdfs:label 'Provisional Suspension Date' ;
    rdfs:comment 'Date on which the provisional suspension of the athlete took effect, pending the outcome of the hearing process. Null if no provisional suspension was imposed.' ;
    rdfs:domain ind:DopingViolation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:publicDisclosureDate rdf:type rdf:Property ;
    rdfs:label 'Public Disclosure Date' ;
    rdfs:comment 'Date on which the Anti-Doping Rule Violation (ADRV) and sanction were publicly disclosed on the governing body\'s or WADA\'s official website per mandatory publication requirements. Null if not yet disclosed or exempt from disclosure.' ;
    rdfs:domain ind:DopingViolation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:publicDisclosureFlag rdf:type rdf:Property ;
    rdfs:label 'Public Disclosure Flag' ;
    rdfs:comment 'Indicates whether the Anti-Doping Rule Violation (ADRV) and sanction have been publicly disclosed per WADA Code Article 14.3 mandatory publication requirements. False if the case involves a minor athlete or is subject to confidentiality provisions.' ;
    rdfs:domain ind:DopingViolation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reinstatementEligibilityDate rdf:type rdf:Property ;
    rdfs:label 'Reinstatement Eligibility Date' ;
    rdfs:comment 'Date from which the athlete is eligible to apply for reinstatement and return to competition following completion of the period of ineligibility and satisfaction of all reinstatement conditions (e.g., whereabouts compliance, return-to-competition testing).' ;
    rdfs:domain ind:DopingViolation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:resultsDisqualifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Results Disqualified Flag' ;
    rdfs:comment 'Indicates whether the athlete\'s competition results from the relevant period have been automatically disqualified as a consequence of the Anti-Doping Rule Violation (ADRV), including forfeiture of medals, points, and prizes.' ;
    rdfs:domain ind:DopingViolation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:revisedBanDurationMonths rdf:type rdf:Property ;
    rdfs:label 'Revised Ban Duration Months' ;
    rdfs:comment 'Revised period of ineligibility in months as determined by the appellate body (CAS or other). Populated only when the appeal resulted in a modification of the original sanction. Null if no revision occurred.' ;
    rdfs:domain ind:DopingViolation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sanctionType rdf:type rdf:Property ;
    rdfs:label 'Sanction Type' ;
    rdfs:comment 'Type of sanction imposed following the hearing decision. Ineligibility (ban) is the primary sanction; others include reprimand, disqualification of results, financial fine, warning, or conditional suspension.' ;
    rdfs:domain ind:DopingViolation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:therapeuticUseExemptionFlag rdf:type rdf:Property ;
    rdfs:label 'Therapeutic Use Exemption Flag' ;
    rdfs:comment 'Indicates whether the athlete held a valid Therapeutic Use Exemption (TUE) for the detected substance at the time of the sample collection. A valid TUE may result in the ADRV charge being withdrawn.' ;
    rdfs:domain ind:DopingViolation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:violationReferenceCode rdf:type rdf:Property ;
    rdfs:label 'Violation Reference Code' ;
    rdfs:comment 'Externally-known unique alphanumeric reference code assigned to this Anti-Doping Rule Violation (ADRV) by the governing body or anti-doping organisation (ADO) for case tracking and correspondence.' ;
    rdfs:domain ind:DopingViolation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:violationStatus rdf:type rdf:Property ;
    rdfs:label 'Violation Status' ;
    rdfs:comment 'Current lifecycle status of the Anti-Doping Rule Violation (ADRV) case, tracking progression from initial notification through provisional suspension, hearing, sanction, appeal, and final resolution. [ENUM-REF-CANDIDATE: pending|provisional_suspension|hearing_scheduled|sanctioned|appealed|overturned|closed — promote to reference product]' ;
    rdfs:domain ind:DopingViolation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:violationType rdf:type rdf:Property ;
    rdfs:label 'Violation Type' ;
    rdfs:comment 'Classification of the Anti-Doping Rule Violation (ADRV) per WADA Code Article 2. Distinguishes between analytical findings (positive test results) and non-analytical violations such as whereabouts failures, tampering, refusal to submit to sample collection, possession, trafficking, administration, complicity, or prohibited association. [ENUM-REF-CANDIDATE: adverse_analytical_finding|atypical_analytical_finding|whereabouts_failure|tampering|refusal|possession|trafficking|administration|complicity|prohibited_association — promote to reference product]' ;
    rdfs:domain ind:DopingViolation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wadaAdamsCaseReference rdf:type rdf:Property ;
    rdfs:label 'Wada Adams Case Reference' ;
    rdfs:comment 'Case identifier assigned within the WADA Anti-Doping Administration and Management System (ADAMS), the global platform for managing doping control information. Used for cross-organisational case tracking and mandatory WADA reporting.' ;
    rdfs:domain ind:DopingViolation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryWhereaboutsAthleteAthleteProfileId rdf:type rdf:Property ;
    rdfs:label 'Primary Whereabouts Athlete Athlete Profile Id' ;
    rdfs:comment 'Identifier of the registered testing pool athlete who submitted this whereabouts filing. Links to the athlete master record in the athlete domain.' ;
    rdfs:domain ind:WhereaboutsFiling ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AthleteProfile .

ind:adamsReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Adams Reference Number' ;
    rdfs:comment 'Unique reference number assigned by the WADA ADAMS portal upon submission of the whereabouts filing. Used as the externally-known business identifier for cross-referencing with WADA and national anti-doping organisations.' ;
    rdfs:domain ind:WhereaboutsFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:athleteResponseDeadline rdf:type rdf:Property ;
    rdfs:label 'Athlete Response Deadline' ;
    rdfs:comment 'Deadline by which the athlete must respond to a missed or incomplete filing notification. Typically 14 days from notification_date per WADA ISTI. Failure to respond within this window may result in the missed filing being confirmed.' ;
    rdfs:domain ind:WhereaboutsFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:authorisedRepresentativeName rdf:type rdf:Property ;
    rdfs:label 'Authorised Representative Name' ;
    rdfs:comment 'Full name of the authorised representative (agent, coach, or team official) who submitted the filing on behalf of the athlete, where applicable. Null if the athlete submitted directly.' ;
    rdfs:domain ind:WhereaboutsFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competitionEndDate rdf:type rdf:Property ;
    rdfs:label 'Competition End Date' ;
    rdfs:comment 'End date of the scheduled competition or event during the filing period. Defines the in-competition period boundary for testing jurisdiction and sample classification purposes.' ;
    rdfs:domain ind:WhereaboutsFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:competitionStartDate rdf:type rdf:Property ;
    rdfs:label 'Competition Start Date' ;
    rdfs:comment 'Start date of the scheduled competition or event during the filing period. Used to plan in-competition doping control and to validate athlete availability windows.' ;
    rdfs:domain ind:WhereaboutsFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:filingDeadline rdf:type rdf:Property ;
    rdfs:label 'Filing Deadline' ;
    rdfs:comment 'Regulatory deadline by which the athlete must submit their whereabouts filing for the applicable quarter. Typically the last day of the preceding quarter per WADA ISTI requirements.' ;
    rdfs:domain ind:WhereaboutsFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:filingNotes rdf:type rdf:Property ;
    rdfs:label 'Filing Notes' ;
    rdfs:comment 'Free-text notes or comments recorded by the compliance officer or anti-doping administrator regarding this whereabouts filing. May include exceptional circumstances, force majeure events, or administrative observations relevant to compliance adjudication.' ;
    rdfs:domain ind:WhereaboutsFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filingPeriodQuarter rdf:type rdf:Property ;
    rdfs:label 'Filing Period Quarter' ;
    rdfs:comment 'Calendar quarter (1=Q1 Jan-Mar, 2=Q2 Apr-Jun, 3=Q3 Jul-Sep, 4=Q4 Oct-Dec) to which this whereabouts filing applies. Under WADA Code Article 2.4, three missed filings within 12 months constitute a whereabouts failure violation.' ;
    rdfs:domain ind:WhereaboutsFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:filingPeriodYear rdf:type rdf:Property ;
    rdfs:label 'Filing Period Year' ;
    rdfs:comment 'Calendar year (e.g., 2024) to which this whereabouts filing applies. Combined with filing_period_quarter to uniquely identify the quarterly filing obligation period.' ;
    rdfs:domain ind:WhereaboutsFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isLateSubmission rdf:type rdf:Property ;
    rdfs:label 'Is Late Submission' ;
    rdfs:comment 'Flag indicating whether the filing was submitted after the regulatory deadline (submission_date > filing_deadline). Late submissions may be treated as incomplete or missed filings depending on the anti-doping organisation\'s rules.' ;
    rdfs:domain ind:WhereaboutsFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:missedFilingCountRolling12m rdf:type rdf:Property ;
    rdfs:label 'Missed Filing Count Rolling 12m' ;
    rdfs:comment 'Running count of missed or non-compliant whereabouts filings by this athlete within the preceding 12-month rolling window at the time of this filing. When this value reaches 3, a WADA Code Article 2.4 whereabouts failure violation is triggered. Stored as a point-in-time snapshot for audit and adjudication purposes.' ;
    rdfs:domain ind:WhereaboutsFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:notificationSent rdf:type rdf:Property ;
    rdfs:label 'Notification Sent' ;
    rdfs:comment 'Flag indicating whether the athlete has been formally notified of a missed or incomplete filing determination as required by WADA ISTI. Notification is a prerequisite before a missed filing can be counted toward the Article 2.4 violation threshold.' ;
    rdfs:domain ind:WhereaboutsFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:overnightLocationAddress rdf:type rdf:Property ;
    rdfs:label 'Overnight Location Address' ;
    rdfs:comment 'Full street address where the athlete will be sleeping each night during the filing period. Required field under WADA ISTI for out-of-competition testing. Classified as restricted PII as it reveals the athlete\'s residential or accommodation location.' ;
    rdfs:domain ind:WhereaboutsFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overnightLocationCity rdf:type rdf:Property ;
    rdfs:label 'Overnight Location City' ;
    rdfs:comment 'City component of the athlete\'s overnight location for the filing period. Supports geographic analysis of testing pool distribution and logistics planning for out-of-competition testing.' ;
    rdfs:domain ind:WhereaboutsFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overnightLocationCountry rdf:type rdf:Property ;
    rdfs:label 'Overnight Location Country' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code for the athlete\'s overnight location during the filing period. Used to coordinate testing jurisdiction between national and international anti-doping organisations.' ;
    rdfs:domain ind:WhereaboutsFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsibleOrganisation rdf:type rdf:Property ;
    rdfs:label 'Responsible Organisation' ;
    rdfs:comment 'Name of the Anti-Doping Organisation (ADO) responsible for managing this athlete\'s whereabouts filing obligation for the period (e.g., WADA, USADA, UKAD, or the relevant International Federation). Determines which body adjudicates missed filing violations.' ;
    rdfs:domain ind:WhereaboutsFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewStatus rdf:type rdf:Property ;
    rdfs:label 'Review Status' ;
    rdfs:comment 'Current status of the compliance review process for this filing. PENDING = awaiting review; IN_REVIEW = under active compliance review; ACCEPTED = compliance determination finalised; DISPUTED = athlete or representative has contested the compliance determination; ESCALATED = referred to CAS or governing body for adjudication.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sixtyMinuteSlotTime rdf:type rdf:Property ;
    rdfs:label 'Sixty Minute Slot Time' ;
    rdfs:comment 'Specific 60-minute daily time window (HH:MM in 24-hour format, representing start of slot) during which the athlete guarantees availability for out-of-competition testing at the declared training venue. This is a mandatory WADA ISTI requirement for Registered Testing Pool athletes.' ;
    rdfs:domain ind:WhereaboutsFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:testingPoolType rdf:type rdf:Property ;
    rdfs:label 'Testing Pool Type' ;
    rdfs:comment 'Classification of the registered testing pool to which the athlete belongs. RTP = Registered Testing Pool (international-level, managed by International Federation or WADA); NRTP = National Registered Testing Pool (managed by National Anti-Doping Organisation); TP = Testing Pool (lower-tier, no whereabouts filing obligation but tracked for completeness).' ;
    rdfs:domain ind:WhereaboutsFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingScheduleEndTime rdf:type rdf:Property ;
    rdfs:label 'Training Schedule End Time' ;
    rdfs:comment 'Scheduled end time of the athlete\'s regular training sessions during the filing period. Together with training_schedule_start_time, defines the daily availability window for doping control officers.' ;
    rdfs:domain ind:WhereaboutsFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:trainingScheduleStartTime rdf:type rdf:Property ;
    rdfs:label 'Training Schedule Start Time' ;
    rdfs:comment 'Scheduled start time of the athlete\'s regular training sessions during the filing period. Combined with training_schedule_end_time, defines the 60-minute testing slot window required by WADA ISTI.' ;
    rdfs:domain ind:WhereaboutsFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:trainingVenueAddress rdf:type rdf:Property ;
    rdfs:label 'Training Venue Address' ;
    rdfs:comment 'Full street address of the primary training venue for the filing period. Enables doping control officers to locate the athlete for unannounced out-of-competition testing.' ;
    rdfs:domain ind:WhereaboutsFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingVenueName rdf:type rdf:Property ;
    rdfs:label 'Training Venue Name' ;
    rdfs:comment 'Name of the primary training facility or venue where the athlete trains during the filing period. Required for out-of-competition testing planning and sample collection logistics.' ;
    rdfs:domain ind:WhereaboutsFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:updateCount rdf:type rdf:Property ;
    rdfs:label 'Update Count' ;
    rdfs:comment 'Number of times this whereabouts filing has been updated or amended after initial submission. Athletes may update filings up to the deadline without penalty; updates after the deadline may be flagged for review.' ;
    rdfs:domain ind:WhereaboutsFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:violationThresholdReached rdf:type rdf:Property ;
    rdfs:label 'Violation Threshold Reached' ;
    rdfs:comment 'Flag indicating whether this filing caused the athlete\'s missed filing count to reach or exceed the WADA Code Article 2.4 threshold of three missed/incomplete filings within 12 months, triggering a formal whereabouts failure violation.' ;
    rdfs:domain ind:WhereaboutsFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:arbitrationCaseId rdf:type rdf:Property ;
    rdfs:label 'Arbitration Case Id' ;
    rdfs:comment 'Foreign key linking to compliance.arbitration_case. Business justification: An eligibility certification may be subject to a CAS arbitration case (e.g., eligibility appeal). The eligibility_certification has cas_case_reference as a string field. Replacing this with a FK to ar' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ArbitrationCase .

ind:primaryEligibilityEventFixtureId rdf:type rdf:Property ;
    rdfs:label 'Primary Eligibility Event Fixture Id' ;
    rdfs:comment 'Reference to the specific event or fixture for which this certification or exemption applies. Null when the record is entity-level rather than event-specific.' ;
    rdfs:domain ind:EligibilityCertification ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Fixture .

ind:adaAccommodationRequirements rdf:type rdf:Property ;
    rdfs:label 'Ada Accommodation Requirements' ;
    rdfs:comment 'Detailed description of specific accessibility accommodations required or certified under ADA Title III for venue certifications or ADA undue hardship exemptions. Includes wheelchair access, assistive listening systems, accessible seating, and service animal provisions. Null for non-ADA certification types.' ;
    rdfs:domain ind:EligibilityCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicationDate rdf:type rdf:Property ;
    rdfs:label 'Application Date' ;
    rdfs:comment 'Date on which the certification or exemption application was formally submitted to the issuing authority. Used for SLA tracking, regulatory deadline compliance, and audit trail.' ;
    rdfs:domain ind:EligibilityCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:approvedSubstance rdf:type rdf:Property ;
    rdfs:label 'Approved Substance' ;
    rdfs:comment 'Name of the specific prohibited substance or method for which a Therapeutic Use Exemption (TUE) has been granted under WADA Code Article 4.4. Null for non-TUE certification types. Must reference the WADA Prohibited List substance name.' ;
    rdfs:domain ind:EligibilityCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:broadcastTerritoryCode rdf:type rdf:Property ;
    rdfs:label 'Broadcast Territory Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country or territory code for which a broadcast territorial exemption applies. Used for FCC content exemptions and RSN blackout rule overrides. Null for non-broadcast exemption types.' ;
    rdfs:domain ind:EligibilityCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cbaProvisionReference rdf:type rdf:Property ;
    rdfs:label 'Cba Provision Reference' ;
    rdfs:comment 'Reference to the specific Collective Bargaining Agreement (CBA) article or provision that governs this eligibility certification (e.g., drug testing protocols, medical clearance requirements, grievance procedures). Null when CBA is not applicable.' ;
    rdfs:domain ind:EligibilityCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationStatus rdf:type rdf:Property ;
    rdfs:label 'Certification Status' ;
    rdfs:comment 'Current lifecycle state of the certification or exemption record. Drives competition gating for athletes and operational permit status for venues. \'Pending\' indicates under review; \'Approved\' confirms active compliance; \'Denied\' records rejection; \'Suspended\' indicates temporary hold; \'Revoked\' indicates withdrawal; \'Expired\' indicates lapse past effective period.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationType rdf:type rdf:Property ;
    rdfs:label 'Certification Type' ;
    rdfs:comment 'Specific category of certification or exemption. Examples include: league_eligibility, amateur_status, age_nationality_eligibility, anti_doping_clearance, medical_clearance, ada_venue_accessibility, event_safety, therapeutic_use_exemption (TUE), broadcast_territorial_exemption, ada_undue_hardship, fcc_content_exemption. [ENUM-REF-CANDIDATE: league_eligibility|amateur_status|age_nationality_eligibility|anti_doping_clearance|medical_clearance|ada_venue_accessibility|event_safety|therapeutic_use_exemption|broadcast_territorial_exemption|ada_undue_hardship|fcc_content_exemption — promote to reference product]' ;
    rdfs:domain ind:EligibilityCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certifiedEntityName rdf:type rdf:Property ;
    rdfs:label 'Certified Entity Name' ;
    rdfs:comment 'Human-readable name of the certified or exempt entity (athlete full name, venue name, event name, or organization name) at the time of certification issuance. Preserved for audit and historical reporting independent of master record changes.' ;
    rdfs:domain ind:EligibilityCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certifiedEntityType rdf:type rdf:Property ;
    rdfs:label 'Certified Entity Type' ;
    rdfs:comment 'Classification of the entity to which this certification or exemption applies. Determines which domain FK (athlete_id, venue_id, event_id) is populated and governs applicable regulatory framework.' ;
    rdfs:domain ind:EligibilityCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competitionEligibilityFlag rdf:type rdf:Property ;
    rdfs:label 'Competition Eligibility Flag' ;
    rdfs:comment 'Derived operational flag indicating whether the certified entity is currently cleared for competition or operational use based on the current certification status and effective/expiry dates. True = eligible; False = ineligible. Used as the primary gate in athlete rostering and event participation systems.' ;
    rdfs:domain ind:EligibilityCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:complianceFramework rdf:type rdf:Property ;
    rdfs:label 'Compliance Framework' ;
    rdfs:comment 'Primary regulatory or governance framework under which this certification or exemption is issued. Enables framework-specific reporting, audit scheduling, and policy enforcement. [ENUM-REF-CANDIDATE: WADA|ADA|FCC|GDPR|CCPA|PCI_DSS|OSHA|FIFA|IOC|CBA|SOX|ISO_20121 — promote to reference product]' ;
    rdfs:domain ind:EligibilityCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionsRestrictions rdf:type rdf:Property ;
    rdfs:label 'Conditions Restrictions' ;
    rdfs:comment 'Free-text description of any conditions, limitations, or restrictions attached to this certification or exemption (e.g., \'valid only for regular season competition\', \'subject to quarterly medical review\', \'restricted to home venue only\'). Null if unconditional.' ;
    rdfs:domain ind:EligibilityCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:denialReason rdf:type rdf:Property ;
    rdfs:label 'Denial Reason' ;
    rdfs:comment 'Structured reason code or free-text explanation provided by the issuing authority when a certification or exemption application is denied or revoked. Required for appeal processes and regulatory audit trails. Null when status is not denied or revoked.' ;
    rdfs:domain ind:EligibilityCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isRetroactive rdf:type rdf:Property ;
    rdfs:label 'Is Retroactive' ;
    rdfs:comment 'Indicates whether this certification or exemption was granted retroactively (True) or prospectively (False). Particularly relevant for WADA Therapeutic Use Exemptions (TUEs) where retroactive approval is permitted under specific circumstances per WADA Code Article 4.4.' ;
    rdfs:domain ind:EligibilityCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:issuingAuthorityReference rdf:type rdf:Property ;
    rdfs:label 'Issuing Authority Reference' ;
    rdfs:comment 'Official reference number, case number, or docket identifier assigned by the issuing authority for this certification or exemption (e.g., WADA ADAMS TUE reference ID, CAS case number, FCC docket number). Enables direct cross-referencing with external regulatory systems.' ;
    rdfs:domain ind:EligibilityCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:medicalJustification rdf:type rdf:Property ;
    rdfs:label 'Medical Justification' ;
    rdfs:comment 'Clinical rationale and medical necessity statement supporting a Therapeutic Use Exemption (TUE) or medical clearance certification. Documents the diagnosed condition, treatment necessity, and absence of performance-enhancing effect. Classified confidential due to sensitive health information context at the organizational compliance level.' ;
    rdfs:domain ind:EligibilityCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prohibitedListVersion rdf:type rdf:Property ;
    rdfs:label 'Prohibited List Version' ;
    rdfs:comment 'Version identifier of the WADA Prohibited List in effect at the time of TUE application or anti-doping clearance certification (format: YYYY-MM, e.g., 2024-01). Ensures traceability to the correct annual prohibited substance list. Null for non-anti-doping certification types.' ;
    rdfs:domain ind:EligibilityCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalDueDate rdf:type rdf:Property ;
    rdfs:label 'Renewal Due Date' ;
    rdfs:comment 'Date by which a renewal application must be submitted to maintain continuous certification or exemption coverage. Typically set prior to expiry_date to allow processing time. Null when renewal_required is False.' ;
    rdfs:domain ind:EligibilityCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:renewalRequired rdf:type rdf:Property ;
    rdfs:label 'Renewal Required' ;
    rdfs:comment 'Indicates whether this certification or exemption requires periodic renewal (True) or is granted on a permanent basis (False). Drives automated renewal reminder workflows and compliance calendar scheduling.' ;
    rdfs:domain ind:EligibilityCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reviewingOfficer rdf:type rdf:Property ;
    rdfs:label 'Reviewing Officer' ;
    rdfs:comment 'Name or identifier of the compliance officer, medical officer, or regulatory representative responsible for reviewing and processing this certification or exemption application within the organization. Used for internal accountability and audit trail.' ;
    rdfs:domain ind:EligibilityCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportingDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Supporting Document Reference' ;
    rdfs:comment 'Reference identifier or URL pointing to supporting documentation stored in the DAM or document management system (e.g., medical certificates, physician letters, venue inspection reports, legal opinions). Enables audit trail linkage without embedding documents in the data product.' ;
    rdfs:domain ind:EligibilityCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wadaAdamsTueReference rdf:type rdf:Property ;
    rdfs:label 'Wada Adams Tue Reference' ;
    rdfs:comment 'Unique reference identifier assigned by the WADA Anti-Doping Administration and Management System (ADAMS) for this Therapeutic Use Exemption (TUE) record. Enables direct cross-referencing with WADA\'s global anti-doping database. Null for non-TUE records.' ;
    rdfs:domain ind:EligibilityCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryArbitrationPolicyId rdf:type rdf:Property ;
    rdfs:label 'Primary Arbitration Policy Id' ;
    rdfs:comment 'Reference to the internal compliance policy, code of conduct, or regulatory framework that was allegedly violated or is at issue in this case. Links to the compliance policy master for policy enforcement tracking.' ;
    rdfs:domain ind:ArbitrationCase ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Policy .

ind:appealFiled rdf:type rdf:Property ;
    rdfs:label 'Appeal Filed' ;
    rdfs:comment 'Indicates whether an appeal has been filed against the initial award or judgment. Triggers escalation workflow and updated financial provisioning.' ;
    rdfs:domain ind:ArbitrationCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:awardAmount rdf:type rdf:Property ;
    rdfs:label 'Award Amount' ;
    rdfs:comment 'Monetary amount awarded or ordered by the arbitral tribunal or court in the final award or judgment. Positive value indicates amount payable by Sports Entertainment; negative indicates amount receivable. Null if case is not yet resolved or resolved without monetary award.' ;
    rdfs:domain ind:ArbitrationCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:awardSummary rdf:type rdf:Property ;
    rdfs:label 'Award Summary' ;
    rdfs:comment 'Concise narrative summary of the final award, judgment, or decision rendered by the tribunal or court, including key findings, relief granted, and any conditions or obligations imposed.' ;
    rdfs:domain ind:ArbitrationCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:casePriority rdf:type rdf:Property ;
    rdfs:label 'Case Priority' ;
    rdfs:comment 'Internal priority classification assigned by the legal and compliance team based on financial exposure, reputational risk, and regulatory significance. Drives resource allocation and executive escalation thresholds.' ;
    rdfs:domain ind:ArbitrationCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimantName rdf:type rdf:Property ;
    rdfs:label 'Claimant Name' ;
    rdfs:comment 'Full legal name of the claimant (arbitration) or plaintiff (litigation) initiating the dispute. May be an individual athlete, organization, league, or regulatory body. Classified confidential as it is a party to active legal proceedings.' ;
    rdfs:domain ind:ArbitrationCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimantType rdf:type rdf:Property ;
    rdfs:label 'Claimant Type' ;
    rdfs:comment 'Categorical classification of the claimant party. Enables segmentation of dispute proceedings by party type for governance reporting and trend analysis. [ENUM-REF-CANDIDATE: athlete|club|league|broadcaster|sponsor|employee|regulatory_body|third_party — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ArbitrationCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discoveryStatus rdf:type rdf:Property ;
    rdfs:label 'Discovery Status' ;
    rdfs:comment 'Current status of the evidence discovery or document production phase of the proceedings. Tracks compliance with discovery obligations and deadlines.' ;
    rdfs:domain ind:ArbitrationCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enforcementStatus rdf:type rdf:Property ;
    rdfs:label 'Enforcement Status' ;
    rdfs:comment 'Current status of enforcement of the award, judgment, or settlement terms. Tracks whether obligations have been satisfied, are being contested, or are pending enforcement action.' ;
    rdfs:domain ind:ArbitrationCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedLiabilityAmount rdf:type rdf:Property ;
    rdfs:label 'Estimated Liability Amount' ;
    rdfs:comment 'Internal legal team estimate of the maximum financial exposure or liability associated with this case, expressed in the base currency. Used for financial provisioning, SOX contingent liability disclosures, and executive risk reporting.' ;
    rdfs:domain ind:ArbitrationCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:expectedResolutionDate rdf:type rdf:Property ;
    rdfs:label 'Expected Resolution Date' ;
    rdfs:comment 'Projected date by which a final award, judgment, or settlement is expected. Used for financial provisioning, regulatory reporting timelines, and executive risk dashboards.' ;
    rdfs:domain ind:ArbitrationCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:filingDate rdf:type rdf:Property ;
    rdfs:label 'Filing Date' ;
    rdfs:comment 'The date on which the case, claim, or complaint was formally filed with the adjudicating forum. Serves as the principal business event date for statute of limitations tracking and SLA measurement.' ;
    rdfs:domain ind:ArbitrationCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:firstHearingDate rdf:type rdf:Property ;
    rdfs:label 'First Hearing Date' ;
    rdfs:comment 'Scheduled or actual date of the first formal hearing, oral argument, or trial session. Used for calendar management, counsel preparation tracking, and SLA compliance.' ;
    rdfs:domain ind:ArbitrationCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:forum rdf:type rdf:Property ;
    rdfs:label 'Forum' ;
    rdfs:comment 'The adjudicating forum or tribunal where the case is being heard. CAS (Court of Arbitration for Sport) is the primary sports arbitration body; other forums include civil courts, regulatory agencies, and labor boards.' ;
    rdfs:domain ind:ArbitrationCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interimMeasuresDescription rdf:type rdf:Property ;
    rdfs:label 'Interim Measures Description' ;
    rdfs:comment 'Narrative description of any interim or provisional measures ordered, including scope, duration, and conditions. Populated only when interim_measures_granted is True.' ;
    rdfs:domain ind:ArbitrationCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interimMeasuresGranted rdf:type rdf:Property ;
    rdfs:label 'Interim Measures Granted' ;
    rdfs:comment 'Indicates whether interim or provisional measures (e.g., injunctions, stay of eligibility suspension, asset freezes) have been granted by the tribunal or court during the pendency of the case.' ;
    rdfs:domain ind:ArbitrationCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:latestHearingDate rdf:type rdf:Property ;
    rdfs:label 'Latest Hearing Date' ;
    rdfs:comment 'Date of the most recent hearing, session, or proceeding. Tracks case progression and supports scheduling of subsequent hearings.' ;
    rdfs:domain ind:ArbitrationCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:leadExternalCounsel rdf:type rdf:Property ;
    rdfs:label 'Lead External Counsel' ;
    rdfs:comment 'Name of the primary external law firm or lead attorney representing Sports Entertainment in the proceedings. Used for matter management, conflict-of-interest checks, and outside counsel spend tracking.' ;
    rdfs:domain ind:ArbitrationCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:matterManagementRef rdf:type rdf:Property ;
    rdfs:label 'Matter Management Ref' ;
    rdfs:comment 'Reference identifier from the enterprise legal matter management system (e.g., SAP S/4HANA legal module or external e-billing platform) linking this case record to the full matter file, billing records, and document repository.' ;
    rdfs:domain ind:ArbitrationCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outsideCounselSpend rdf:type rdf:Property ;
    rdfs:label 'Outside Counsel Spend' ;
    rdfs:comment 'Cumulative legal fees and disbursements paid to external counsel for this case to date. Used for matter budget management, ROI (Return on Investment) analysis of legal spend, and EBITDA (Earnings Before Interest Taxes Depreciation and Amortization) impact reporting.' ;
    rdfs:domain ind:ArbitrationCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:panelComposition rdf:type rdf:Property ;
    rdfs:label 'Panel Composition' ;
    rdfs:comment 'Names and roles of arbitrators, panel members, or presiding judge(s) assigned to the case. Stored as a structured text description (e.g., \'Sole Arbitrator: J. Smith; Appointed by CAS\'). Classified confidential due to sensitivity of judicial assignment information.' ;
    rdfs:domain ind:ArbitrationCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:respondentName rdf:type rdf:Property ;
    rdfs:label 'Respondent Name' ;
    rdfs:comment 'Full legal name of the respondent (arbitration) or defendant (litigation) against whom the dispute is brought. May be Sports Entertainment entity, an athlete, club, or third party. Classified confidential as it is a party to active legal proceedings.' ;
    rdfs:domain ind:ArbitrationCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:respondentType rdf:type rdf:Property ;
    rdfs:label 'Respondent Type' ;
    rdfs:comment 'Categorical classification of the respondent or defendant party. Enables segmentation of dispute proceedings by party type for governance reporting and trend analysis. [ENUM-REF-CANDIDATE: athlete|club|league|broadcaster|sponsor|employee|regulatory_body|third_party — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ArbitrationCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementAmount rdf:type rdf:Property ;
    rdfs:label 'Settlement Amount' ;
    rdfs:comment 'Agreed monetary settlement amount if the case was resolved through negotiated settlement rather than a formal award or judgment. Null if no settlement was reached.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:settlementTerms rdf:type rdf:Property ;
    rdfs:label 'Settlement Terms' ;
    rdfs:comment 'Summary of the key terms and conditions of any negotiated settlement agreement, including confidentiality obligations, non-disparagement clauses, and performance requirements. Distinct from award_summary which covers tribunal-rendered decisions.' ;
    rdfs:domain ind:ArbitrationCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sportOrLeague rdf:type rdf:Property ;
    rdfs:label 'Sport Or League' ;
    rdfs:comment 'The specific sport, league, or competition context to which this case relates (e.g., NFL, NBA, FIFA, UFC, ATP). Enables domain-specific reporting and governing body alignment for multi-sport enterprises.' ;
    rdfs:domain ind:ArbitrationCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subjectMatter rdf:type rdf:Property ;
    rdfs:label 'Subject Matter' ;
    rdfs:comment 'Concise description of the primary legal or regulatory subject matter at issue (e.g., PED (Performance Enhancing Drug) violation, NIL (Name Image and Likeness) contract breach, broadcast IP (Intellectual Property) infringement, GDPR data privacy violation, ADA accessibility non-compliance, CBA grievance).' ;
    rdfs:domain ind:ArbitrationCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:privacyRequestId rdf:type rdf:Property ;
    rdfs:label 'Privacy Request Id' ;
    rdfs:comment 'Unique surrogate identifier for each privacy request or consent record within the unified data subject interaction system. Serves as the primary key for all GDPR, CCPA, and applicable privacy regulation interactions.' ;
    rdfs:domain ind:PrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryPrivacyFanFanProfileId rdf:type rdf:Property ;
    rdfs:label 'Primary Privacy Fan Fan Profile Id' ;
    rdfs:comment 'Identifier of the fan or data subject who submitted the privacy request or whose consent is being recorded. Links to the fan master record in Salesforce CRM and Adobe Experience Platform.' ;
    rdfs:domain ind:PrivacyRequest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FanProfile .

ind:aepConsentProfileReference rdf:type rdf:Property ;
    rdfs:label 'Aep Consent Profile Reference' ;
    rdfs:comment 'Identifier of the corresponding consent profile record in Adobe Experience Platform (AEP). Enables bidirectional synchronization between the compliance SSOT and the AEP consent management layer for real-time personalization suppression and marketing activation controls.' ;
    rdfs:domain ind:PrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agentAuthorizationReference rdf:type rdf:Property ;
    rdfs:label 'Agent Authorization Reference' ;
    rdfs:comment 'Reference identifier or document locator for the power of attorney, signed authorization form, or other legal instrument authorizing an agent to act on behalf of the data subject. Populated only when is_authorized_agent = True. Links to the compliance document management system.' ;
    rdfs:domain ind:PrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableRegulation rdf:type rdf:Property ;
    rdfs:label 'Applicable Regulation' ;
    rdfs:comment 'Primary privacy regulation governing this request or consent record. Determines the applicable deadline, response format, and legal basis requirements. \'BOTH\' applies when the data subject qualifies under both GDPR (EU resident) and CCPA (California resident). \'OTHER\' covers emerging state-level privacy laws (e.g., VCDPA, CPA).' ;
    rdfs:domain ind:PrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentAction rdf:type rdf:Property ;
    rdfs:label 'Consent Action' ;
    rdfs:comment 'Specific action taken on the consent record. Applicable when interaction_type = \'consent\'. \'granted\' = affirmative consent given; \'withdrawn\' = previously granted consent revoked; \'updated\' = consent scope modified; \'expired\' = consent lapsed per policy version expiry. Null for rights requests.' ;
    rdfs:domain ind:PrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentGrantedAt rdf:type rdf:Property ;
    rdfs:label 'Consent Granted At' ;
    rdfs:comment 'Date and time when the data subject affirmatively granted consent. Serves as the legal basis timestamp for processing activities relying on consent under GDPR Article 6(1)(a). Null for rights requests or consent withdrawal records.' ;
    rdfs:domain ind:PrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:consentPolicyVersion rdf:type rdf:Property ;
    rdfs:label 'Consent Policy Version' ;
    rdfs:comment 'Version identifier of the privacy policy or consent notice that was presented to the data subject at the time of consent capture. Enables tracking of consent validity across policy updates and supports re-consent workflows when material policy changes occur. Format: v{major}.{minor}.' ;
    rdfs:domain ind:PrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentWithdrawnAt rdf:type rdf:Property ;
    rdfs:label 'Consent Withdrawn At' ;
    rdfs:comment 'Date and time when the data subject withdrew previously granted consent. Upon withdrawal, downstream processing activities relying on this consent must cease. Integrated with Adobe Experience Platform consent management to suppress marketing and analytics processing.' ;
    rdfs:domain ind:PrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:dataCategoriesInScope rdf:type rdf:Property ;
    rdfs:label 'Data Categories In Scope' ;
    rdfs:comment 'Comma-separated list of personal data categories covered by this request or consent record (e.g., \'ticketing_history, fan_profile, payment_data, location_data, biometric_data\'). Derived from the data subject\'s request or the consent scope definition. Used for scoping the fulfillment workflow and data inventory mapping.' ;
    rdfs:domain ind:PrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSubjectJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Data Subject Jurisdiction' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code representing the jurisdiction of the data subject\'s residence, used to determine the applicable privacy regulation (GDPR for EU/EEA residents, CCPA for California residents, etc.) and the corresponding response obligations. Examples: GBR, DEU, USA, CAN.' ;
    rdfs:domain ind:PrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dpoReviewRequired rdf:type rdf:Property ;
    rdfs:label 'Dpo Review Required' ;
    rdfs:comment 'Indicates whether this request requires review by the Data Protection Officer (DPO) before fulfillment. Set to True for high-risk erasure requests, requests involving special category data (biometric, health), or requests that may conflict with legal retention obligations.' ;
    rdfs:domain ind:PrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dpoReviewedAt rdf:type rdf:Property ;
    rdfs:label 'Dpo Reviewed At' ;
    rdfs:comment 'Date and time when the Data Protection Officer (DPO) completed their review of the privacy request. Populated only when dpo_review_required = True. Supports audit trail for high-risk processing decisions.' ;
    rdfs:domain ind:PrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:extendedDeadline rdf:type rdf:Property ;
    rdfs:label 'Extended Deadline' ;
    rdfs:comment 'Revised response deadline after a formal extension has been granted and the data subject notified. Replaces regulatory_deadline as the operative SLA date when an extension is invoked. Null if no extension was applied.' ;
    rdfs:domain ind:PrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:extensionNotifiedAt rdf:type rdf:Property ;
    rdfs:label 'Extension Notified At' ;
    rdfs:comment 'Date and time when the data subject was notified of a response deadline extension. Under GDPR, organizations may extend the 30-day deadline by a further 60 days for complex requests, but must notify the data subject within the initial 30-day window. Under CCPA, a 45-day extension is permitted with notice.' ;
    rdfs:domain ind:PrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:identityVerificationMethod rdf:type rdf:Property ;
    rdfs:label 'Identity Verification Method' ;
    rdfs:comment 'Method used to verify the identity of the requestor. Supports audit trail requirements and helps assess verification strength. Values: email_confirmation (link-based), account_login (authenticated session), knowledge_based (security questions), document_upload (ID document), two_factor (MFA challenge).' ;
    rdfs:domain ind:PrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:identityVerificationStatus rdf:type rdf:Property ;
    rdfs:label 'Identity Verification Status' ;
    rdfs:comment 'Status of the identity verification process for the requestor. \'pending\' = verification initiated but not complete; \'verified\' = identity confirmed; \'failed\' = verification unsuccessful (request cannot proceed); \'waived\' = verification not required per policy (e.g., consent withdrawal). Mandatory step before fulfilling access or erasure requests.' ;
    rdfs:domain ind:PrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interactionType rdf:type rdf:Property ;
    rdfs:label 'Interaction Type' ;
    rdfs:comment 'Top-level discriminator indicating whether this record represents a data subject rights request (access, erasure, portability, etc.) or a consent management event (grant, withdrawal, update). Drives downstream processing workflow and regulatory deadline calculation.' ;
    rdfs:domain ind:PrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isAuthorizedAgent rdf:type rdf:Property ;
    rdfs:label 'Is Authorized Agent' ;
    rdfs:comment 'Indicates whether the request was submitted by an authorized agent acting on behalf of the data subject rather than the data subject themselves. When True, agent authorization documentation must be collected and linked via agent_authorization_reference. Required for CCPA compliance.' ;
    rdfs:domain ind:PrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:legalHoldFlag rdf:type rdf:Property ;
    rdfs:label 'Legal Hold Flag' ;
    rdfs:comment 'Indicates whether the data subject\'s records are subject to a legal hold that prevents erasure or restriction fulfillment. When True, the erasure or restriction request must be suspended pending resolution of the legal matter. Coordinated with the legal case management system.' ;
    rdfs:domain ind:PrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:processingNotes rdf:type rdf:Property ;
    rdfs:label 'Processing Notes' ;
    rdfs:comment 'Free-text field capturing internal notes, decisions, and observations recorded by the processing team during fulfillment. Includes documentation of exemptions applied, systems searched, and any complexities encountered. Confidential — not shared with the data subject.' ;
    rdfs:domain ind:PrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryDeadline rdf:type rdf:Property ;
    rdfs:label 'Regulatory Deadline' ;
    rdfs:comment 'Calculated deadline by which the organization must fulfill or respond to the privacy request. Derived from submitted_at plus the applicable regulatory window: 30 calendar days under GDPR (extendable to 90 with notice) or 45 calendar days under CCPA (extendable to 90). Stored as a business date for SLA monitoring and escalation triggers.' ;
    rdfs:domain ind:PrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requestType rdf:type rdf:Property ;
    rdfs:label 'Request Type' ;
    rdfs:comment 'Specific type of data subject rights request submitted. Applicable when interaction_type = \'rights_request\'. Values: access_sar (Subject Access Request), erasure (Right to be Forgotten), portability (Data Portability), rectification (Correction), restriction (Processing Restriction), opt_out_of_sale (CCPA Opt-Out of Sale/Sharing). Null for consent records.' ;
    rdfs:domain ind:PrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestorEmail rdf:type rdf:Property ;
    rdfs:label 'Requestor Email' ;
    rdfs:comment 'Email address provided by the requestor at submission. Used for identity verification correspondence and delivery of the privacy request response. Stored as PII under GDPR Article 4 and CCPA.' ;
    rdfs:domain ind:PrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestorFullName rdf:type rdf:Property ;
    rdfs:label 'Requestor Full Name' ;
    rdfs:comment 'Full legal name of the individual submitting the privacy request. May differ from the fan record name when submitted by an authorized agent or legal representative on behalf of the data subject.' ;
    rdfs:domain ind:PrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseDeliveryMethod rdf:type rdf:Property ;
    rdfs:label 'Response Delivery Method' ;
    rdfs:comment 'Method used to deliver the privacy request response or consent confirmation to the data subject. Must align with the data subject\'s preferred contact channel and regulatory requirements for secure delivery of personal data.' ;
    rdfs:domain ind:PrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseOutcome rdf:type rdf:Property ;
    rdfs:label 'Response Outcome' ;
    rdfs:comment 'Final outcome of the privacy request fulfillment. \'fulfilled\' = request fully completed; \'partially_fulfilled\' = some data categories actioned, others exempted; \'rejected\' = request denied with legal basis; \'no_data_found\' = no personal data located for the subject; \'extended\' = response period extended per regulatory allowance with notice sent.' ;
    rdfs:domain ind:PrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionChannel rdf:type rdf:Property ;
    rdfs:label 'Submission Channel' ;
    rdfs:comment 'Channel through which the data subject submitted the privacy request or provided/withdrew consent. Supports channel analytics and compliance audit trails. Values align with Adobe Experience Platform touchpoint taxonomy.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submittedAt rdf:type rdf:Property ;
    rdfs:label 'Submitted At' ;
    rdfs:comment 'Exact date and time (with timezone) when the privacy request was submitted or the consent event was recorded. This is the principal business event timestamp and the anchor for all regulatory deadline calculations (GDPR 30-day, CCPA 45-day).' ;
    rdfs:domain ind:PrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:thirdPartyDisclosures rdf:type rdf:Property ;
    rdfs:label 'Third Party Disclosures' ;
    rdfs:comment 'Comma-separated list of third-party organizations to whom the data subject\'s personal data has been disclosed and who must be notified of erasure, restriction, or opt-out requests. Includes sponsors, broadcast partners, and analytics vendors. Required for GDPR Article 17(2) and CCPA opt-out propagation.' ;
    rdfs:domain ind:PrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usStateCode rdf:type rdf:Property ;
    rdfs:label 'Us State Code' ;
    rdfs:comment 'Two-letter US state code for data subjects residing in the United States. Used to determine applicability of state-level privacy laws beyond CCPA (e.g., VCDPA for Virginia, CPA for Colorado, CTDPA for Connecticut). Populated only when data_subject_jurisdiction = \'USA\'.' ;
    rdfs:domain ind:PrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verifiedAt rdf:type rdf:Property ;
    rdfs:label 'Verified At' ;
    rdfs:comment 'Date and time when the requestor\'s identity was successfully verified. Marks the start of the regulatory response clock in jurisdictions where the deadline begins upon verification rather than submission.' ;
    rdfs:domain ind:PrivacyRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:assessmentOutcome rdf:type rdf:Property ;
    rdfs:label 'Assessment Outcome' ;
    rdfs:comment 'Final outcome of the DPIA/PIA review process. \'Approved\' indicates processing may proceed; \'Approved with conditions\' requires specific mitigations before go-live; \'Rejected\' prohibits processing; \'Not required\' indicates no formal assessment was needed.' ;
    rdfs:domain ind:DataProcessingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentType rdf:type rdf:Property ;
    rdfs:label 'Assessment Type' ;
    rdfs:comment 'Type of privacy impact assessment conducted for this processing activity. \'dpia\' = Data Protection Impact Assessment (mandatory under GDPR Article 35 for high-risk processing); \'pia\' = Privacy Impact Assessment (broader scope); \'screening\' = pre-DPIA threshold assessment; \'none\' = no assessment required.' ;
    rdfs:domain ind:DataProcessingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controllerProcessorRole rdf:type rdf:Property ;
    rdfs:label 'Controller Processor Role' ;
    rdfs:comment 'Designates whether Sports Entertainment acts as a Data Controller, Data Processor, Joint Controller, or Sub-Processor for this processing activity, as defined under GDPR Article 4. Determines the applicable compliance obligations.' ;
    rdfs:domain ind:DataProcessingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crossBorderTransferFlag rdf:type rdf:Property ;
    rdfs:label 'Cross Border Transfer Flag' ;
    rdfs:comment 'Indicates whether personal data is transferred to a country outside the European Economic Area (EEA) or to an international organisation. Triggers mandatory documentation of transfer mechanisms under GDPR Chapter V.' ;
    rdfs:domain ind:DataProcessingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dataDomain rdf:type rdf:Property ;
    rdfs:label 'Data Domain' ;
    rdfs:comment 'Business data domain to which this processing activity belongs (e.g., Fan, Athlete, Ticketing). Aligns with Sports Entertainment\'s enterprise data domain taxonomy for governance and ownership assignment. [ENUM-REF-CANDIDATE: fan|athlete|broadcast|ticketing|sponsorship|finance|workforce|digital_platform|content|venue — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:DataProcessingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSubjectCategories rdf:type rdf:Property ;
    rdfs:label 'Data Subject Categories' ;
    rdfs:comment 'Categories of individuals whose personal data is processed (e.g., \'Fans/Ticket Holders\', \'Athletes\', \'Employees\', \'Minors under 16\'). Pipe-delimited list. Mandatory field under GDPR Article 30(1)(c). [ENUM-REF-CANDIDATE: fans|athletes|employees|minors|sponsors|media_partners|venue_staff|contractors — promote to reference product]' ;
    rdfs:domain ind:DataProcessingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dpiaRequired rdf:type rdf:Property ;
    rdfs:label 'Dpia Required' ;
    rdfs:comment 'Indicates whether a formal Data Protection Impact Assessment (DPIA) is mandatory for this processing activity under GDPR Article 35 (e.g., large-scale processing of special category data, systematic monitoring, biometric identification for ticketing).' ;
    rdfs:domain ind:DataProcessingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dpoConsultationDate rdf:type rdf:Property ;
    rdfs:label 'Dpo Consultation Date' ;
    rdfs:comment 'Date on which the Data Protection Officer (DPO) was formally consulted regarding this processing activity or DPIA. Provides an audit trail for GDPR Article 35(2) compliance.' ;
    rdfs:domain ind:DataProcessingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dpoConsulted rdf:type rdf:Property ;
    rdfs:label 'Dpo Consulted' ;
    rdfs:comment 'Indicates whether the Data Protection Officer (DPO) was formally consulted during the DPIA/PIA process, as required under GDPR Article 35(2). Mandatory for all high-risk processing activities.' ;
    rdfs:domain ind:DataProcessingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:identifiedRisks rdf:type rdf:Property ;
    rdfs:label 'Identified Risks' ;
    rdfs:comment 'Narrative description of privacy risks identified during the DPIA/PIA assessment (e.g., \'Unauthorised access to fan biometric data\', \'Re-identification of pseudonymised athlete health records\', \'Cross-border transfer of minors\' data without adequate safeguards\').' ;
    rdfs:domain ind:DataProcessingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:includesSpecialCategoryData rdf:type rdf:Property ;
    rdfs:label 'Includes Special Category Data' ;
    rdfs:comment 'Indicates whether this processing activity involves special category personal data as defined under GDPR Article 9 (e.g., health data, biometric data, racial/ethnic origin). Triggers additional safeguards and explicit consent requirements.' ;
    rdfs:domain ind:DataProcessingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:legitimateInterestDescription rdf:type rdf:Property ;
    rdfs:label 'Legitimate Interest Description' ;
    rdfs:comment 'Where legal basis is \'legitimate_interests\', documents the specific legitimate interest pursued and the balancing test outcome. Required to demonstrate compliance with GDPR Article 6(1)(f) and to evidence the three-part test (purpose, necessity, balancing).' ;
    rdfs:domain ind:DataProcessingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pciDssApplicable rdf:type rdf:Property ;
    rdfs:label 'Pci Dss Applicable' ;
    rdfs:comment 'Indicates whether this processing activity involves payment card data and is therefore subject to PCI-DSS requirements. Applicable to ticketing (Ticketmaster/AXS), merchandise (Shopify Plus), and POS transactions at venues.' ;
    rdfs:domain ind:DataProcessingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:personalDataCategories rdf:type rdf:Property ;
    rdfs:label 'Personal Data Categories' ;
    rdfs:comment 'Categories of personal data processed, including special category data under GDPR Article 9 (e.g., \'Fan PII: name, email, purchase history\', \'Athlete health data: injury records, biometrics\', \'Payment data: PCI-DSS card data\', \'Biometric data: facial recognition for ticketing\'). Mandatory under GDPR Article 30(1)(c).' ;
    rdfs:domain ind:DataProcessingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processingActivityName rdf:type rdf:Property ;
    rdfs:label 'Processing Activity Name' ;
    rdfs:comment 'Human-readable name of the personal data processing activity (e.g., \'Biometric Ticketing Enrollment\', \'Fan CRM Profiling\', \'Athlete Health Monitoring\'). Serves as the primary identity label for the record in the RoPA register.' ;
    rdfs:domain ind:DataProcessingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processingActivityReference rdf:type rdf:Property ;
    rdfs:label 'Processing Activity Reference' ;
    rdfs:comment 'Externally-known unique reference code assigned to this processing activity in the official RoPA register (e.g., \'RoPA-FAN-20240001\'). Used for cross-referencing in regulatory filings and supervisory authority correspondence.' ;
    rdfs:domain ind:DataProcessingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processingEndDate rdf:type rdf:Property ;
    rdfs:label 'Processing End Date' ;
    rdfs:comment 'Date on which this personal data processing activity ceased or is scheduled to cease. Null for ongoing processing activities. Represents the effective-until date for the processing activity\'s lifecycle.' ;
    rdfs:domain ind:DataProcessingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:processingOwner rdf:type rdf:Property ;
    rdfs:label 'Processing Owner' ;
    rdfs:comment 'Business owner responsible for this processing activity (e.g., \'VP Fan Engagement\', \'Head of Athlete Performance\', \'Director of Ticketing Operations\'). Accountable for ensuring ongoing compliance with the documented controls and review schedule.' ;
    rdfs:domain ind:DataProcessingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processingStartDate rdf:type rdf:Property ;
    rdfs:label 'Processing Start Date' ;
    rdfs:comment 'Date on which this personal data processing activity commenced or is scheduled to commence. Represents the effective-from date for the processing activity\'s lifecycle.' ;
    rdfs:domain ind:DataProcessingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:processingStatus rdf:type rdf:Property ;
    rdfs:label 'Processing Status' ;
    rdfs:comment 'Current lifecycle state of the processing activity record within the RoPA register. \'Active\' indicates live processing; \'Suspended\' indicates temporarily halted; \'Retired\' indicates decommissioned processing.' ;
    rdfs:domain ind:DataProcessingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordLastUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Record Last Updated Timestamp' ;
    rdfs:comment 'Timestamp when this RoPA/DPIA record was most recently modified. Supports audit trail requirements and change management tracking for GDPR Article 30 register maintenance.' ;
    rdfs:domain ind:DataProcessingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:retentionBasis rdf:type rdf:Property ;
    rdfs:label 'Retention Basis' ;
    rdfs:comment 'Legal or business justification for the defined retention period (e.g., \'SOX 7-year financial record requirement\', \'WADA anti-doping sample retention 10 years\', \'PCI-DSS transaction log 1 year\', \'GDPR consent withdrawal\'). Documents the regulatory driver for the retention schedule.' ;
    rdfs:domain ind:DataProcessingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retentionPeriodDays rdf:type rdf:Property ;
    rdfs:label 'Retention Period Days' ;
    rdfs:comment 'Maximum number of days personal data is retained for this processing activity before deletion or anonymisation, in accordance with GDPR Article 5(1)(e) storage limitation principle. Derived from the applicable retention schedule.' ;
    rdfs:domain ind:DataProcessingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:riskMitigationMeasures rdf:type rdf:Property ;
    rdfs:label 'Risk Mitigation Measures' ;
    rdfs:comment 'Specific technical and organisational measures implemented or planned to mitigate identified privacy risks (e.g., \'Biometric data encrypted with hardware security module\', \'Athlete health data access restricted to medical staff via SAP SuccessFactors role-based controls\', \'DRM applied to broadcast content containing athlete biometrics\').' ;
    rdfs:domain ind:DataProcessingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:securityMeasures rdf:type rdf:Property ;
    rdfs:label 'Security Measures' ;
    rdfs:comment 'Description of technical and organisational measures implemented to protect personal data (e.g., \'AES-256 encryption at rest, TLS 1.3 in transit, role-based access control, PCI-DSS tokenisation for payment data, pseudonymisation of fan analytics data\'). Mandatory under GDPR Article 32 and Article 30(1)(g).' ;
    rdfs:domain ind:DataProcessingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialCategoryDataType rdf:type rdf:Property ;
    rdfs:label 'Special Category Data Type' ;
    rdfs:comment 'Specific type of special category data processed under GDPR Article 9, where applicable. For Sports Entertainment, common types include \'health\' (athlete injury/medical records), \'biometric\' (facial recognition ticketing), and \'genetic\' (anti-doping testing under WADA). [ENUM-REF-CANDIDATE: health|biometric|genetic|racial_ethnic|religious|political|trade_union|sexual_orientation|criminal_offence|none — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:DataProcessingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supervisoryAuthorityConsultationDate rdf:type rdf:Property ;
    rdfs:label 'Supervisory Authority Consultation Date' ;
    rdfs:comment 'Date on which the supervisory authority was formally consulted under GDPR Article 36. Null if consultation was not required or has not yet occurred.' ;
    rdfs:domain ind:DataProcessingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:supervisoryAuthorityConsultationRequired rdf:type rdf:Property ;
    rdfs:label 'Supervisory Authority Consultation Required' ;
    rdfs:comment 'Indicates whether prior consultation with the relevant supervisory authority (e.g., ICO, CNIL) is required before commencing this processing activity, as mandated by GDPR Article 36 when residual risk remains high after mitigation.' ;
    rdfs:domain ind:DataProcessingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:thirdPartyRecipients rdf:type rdf:Property ;
    rdfs:label 'Third Party Recipients' ;
    rdfs:comment 'Names and categories of third parties to whom personal data is disclosed (e.g., \'Ticketmaster/AXS — ticketing processor\', \'Salesforce CRM — fan relationship management\', \'WADA — anti-doping authority\', \'Adobe Experience Platform — fan analytics\'). Mandatory under GDPR Article 30(1)(d).' ;
    rdfs:domain ind:DataProcessingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferDestinationCountries rdf:type rdf:Property ;
    rdfs:label 'Transfer Destination Countries' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country codes of countries to which personal data is transferred outside the EEA (e.g., \'USA|CAN|AUS\'). Pipe-delimited. Required for GDPR Article 30 RoPA documentation and supervisory authority reporting.' ;
    rdfs:domain ind:DataProcessingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferMechanism rdf:type rdf:Property ;
    rdfs:label 'Transfer Mechanism' ;
    rdfs:comment 'Legal mechanism used to legitimise cross-border personal data transfers where applicable (e.g., \'standard_contractual_clauses\' for transfers to US-based Salesforce CRM or Adobe Experience Platform, \'adequacy_decision\' for transfers to UK post-Brexit). Mandatory under GDPR Article 46.' ;
    rdfs:domain ind:DataProcessingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wadaApplicable rdf:type rdf:Property ;
    rdfs:label 'Wada Applicable' ;
    rdfs:comment 'Indicates whether this processing activity involves athlete anti-doping data subject to WADA Code requirements, including whereabouts data, biological passport data, and anti-doping test results. Triggers specific data sharing obligations with WADA and national anti-doping organisations.' ;
    rdfs:domain ind:DataProcessingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:primaryStaffEventFixtureId rdf:type rdf:Property ;
    rdfs:label 'Primary Staff Event Fixture Id' ;
    rdfs:comment 'Reference to the specific event for which this staffing plan is created. Links the labor demand plan to the scheduled live event.' ;
    rdfs:domain ind:StaffPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Fixture .

ind:revisedStaffPlanId rdf:type rdf:Property ;
    rdfs:label 'Revised Staff Plan Id' ;
    rdfs:comment 'Self-referencing FK on staff_plan (revised_staff_plan_id)' ;
    rdfs:domain ind:StaffPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffPlan .

ind:actualCostUsd rdf:type rdf:Property ;
    rdfs:label 'Actual Cost Usd' ;
    rdfs:comment 'Actual labor cost in US dollars incurred for this role category after the event, as recorded in the financial system. Compared against estimated_cost_usd for variance analysis.' ;
    rdfs:domain ind:StaffPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualHeadcount rdf:type rdf:Property ;
    rdfs:label 'Actual Headcount' ;
    rdfs:comment 'Actual number of staff who reported and worked for this role category on event day. Captured post-event for variance analysis against required and confirmed headcount.' ;
    rdfs:domain ind:StaffPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:agencyPurchaseOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Agency Purchase Order Number' ;
    rdfs:comment 'SAP purchase order number issued to the staffing agency for this role category. Required for accounts payable processing and agency invoice matching.' ;
    rdfs:domain ind:StaffPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:briefingLocation rdf:type rdf:Property ;
    rdfs:label 'Briefing Location' ;
    rdfs:comment 'Physical location within or near the venue where staff in this role category are required to report for pre-event briefing and credential check-in.' ;
    rdfs:domain ind:StaffPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:briefingTimestamp rdf:type rdf:Property ;
    rdfs:label 'Briefing Timestamp' ;
    rdfs:comment 'Scheduled date and time for the pre-event staff briefing for this role category. Must occur before shift_start_timestamp.' ;
    rdfs:domain ind:StaffPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:confirmedHeadcount rdf:type rdf:Property ;
    rdfs:label 'Confirmed Headcount' ;
    rdfs:comment 'Number of staff positions confirmed and scheduled for this role category as of the latest plan update. Compared against required_headcount to identify fulfillment gaps.' ;
    rdfs:domain ind:StaffPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contingencyHeadcount rdf:type rdf:Property ;
    rdfs:label 'Contingency Headcount' ;
    rdfs:comment 'Number of additional staff positions held in reserve for this role category to cover no-shows, emergencies, or unexpected demand surges on event day.' ;
    rdfs:domain ind:StaffPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:credentialRequirements rdf:type rdf:Property ;
    rdfs:label 'Credential Requirements' ;
    rdfs:comment 'Description of required certifications, licenses, or credentials that staff in this role category must hold (e.g., CPR certification, security guard license, food handler permit, AV technician certification).' ;
    rdfs:domain ind:StaffPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deploymentZone rdf:type rdf:Property ;
    rdfs:label 'Deployment Zone' ;
    rdfs:comment 'Venue zone or area where staff in this role category are assigned to operate (e.g., Gate A, Concourse Level 2, Parking Lot C, Field Level). Supports event-day logistics coordination.' ;
    rdfs:domain ind:StaffPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employmentType rdf:type rdf:Property ;
    rdfs:label 'Employment Type' ;
    rdfs:comment 'Classification of the employment arrangement for staff in this role category. Determines payroll processing, CBA applicability, and agency billing procedures.' ;
    rdfs:domain ind:StaffPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedCostUsd rdf:type rdf:Property ;
    rdfs:label 'Estimated Cost Usd' ;
    rdfs:comment 'Total estimated labor cost in US dollars for this role category for the event, calculated from required headcount, shift duration, and pay rate. Used for event budget planning.' ;
    rdfs:domain ind:StaffPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:eventTypeCategory rdf:type rdf:Property ;
    rdfs:label 'Event Type Category' ;
    rdfs:comment 'Broad classification of the event type driving this staffing plan. Used to apply standard staffing templates and benchmarks appropriate to the event category.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fulfillmentSource rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Source' ;
    rdfs:comment 'Indicates whether the staffing demand for this role category is fulfilled by in-house employees, an external staffing agency, a combination of both, or volunteers.' ;
    rdfs:domain ind:StaffPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isAdaRole rdf:type rdf:Property ;
    rdfs:label 'Is Ada Role' ;
    rdfs:comment 'Indicates whether this role category is specifically designated to support ADA accessibility services for guests with disabilities (e.g., wheelchair escorts, hearing loop operators).' ;
    rdfs:domain ind:StaffPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isOshaSafetyCritical rdf:type rdf:Property ;
    rdfs:label 'Is Osha Safety Critical' ;
    rdfs:comment 'Indicates whether this role category is classified as safety-critical under OSHA standards, requiring mandatory minimum staffing levels and specific credential verification before event approval.' ;
    rdfs:domain ind:StaffPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:minimumHeadcount rdf:type rdf:Property ;
    rdfs:label 'Minimum Headcount' ;
    rdfs:comment 'Minimum number of staff for this role category below which the event cannot safely proceed. Used as the go/no-go threshold for operational readiness approval.' ;
    rdfs:domain ind:StaffPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:payRateUsd rdf:type rdf:Property ;
    rdfs:label 'Pay Rate Usd' ;
    rdfs:comment 'Planned hourly pay rate in US dollars for staff in this role category. Used for cost estimation and budget reconciliation. Classified as confidential business data.' ;
    rdfs:domain ind:StaffPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:planName rdf:type rdf:Property ;
    rdfs:label 'Plan Name' ;
    rdfs:comment 'Human-readable name identifying this staffing plan, typically including event name, date, and role category (e.g., \'NBA Finals 2025 – Security Plan\').' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planNotes rdf:type rdf:Property ;
    rdfs:label 'Plan Notes' ;
    rdfs:comment 'Free-text operational notes or special instructions for this staffing plan record, such as event-specific requirements, weather contingencies, or VIP security protocols.' ;
    rdfs:domain ind:StaffPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Plan Reference Number' ;
    rdfs:comment 'Externally-known alphanumeric reference number assigned to this staffing plan for cross-system tracking and vendor communication (e.g., VSP-2025-0042).' ;
    rdfs:domain ind:StaffPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planStatus rdf:type rdf:Property ;
    rdfs:label 'Plan Status' ;
    rdfs:comment 'Current lifecycle status of the staffing plan. Tracks progression from initial draft through approval and execution to completion or cancellation.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planVersion rdf:type rdf:Property ;
    rdfs:label 'Plan Version' ;
    rdfs:comment 'Incremental version number of the staffing plan. Incremented each time the plan is revised and resubmitted for approval, enabling audit trail of changes.' ;
    rdfs:domain ind:StaffPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:requiredHeadcount rdf:type rdf:Property ;
    rdfs:label 'Required Headcount' ;
    rdfs:comment 'Total number of staff positions required for this role category to safely and operationally execute the event. Represents the labor demand target.' ;
    rdfs:domain ind:StaffPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:roleCategory rdf:type rdf:Property ;
    rdfs:label 'Role Category' ;
    rdfs:comment 'Operational role category for which this staffing plan row specifies headcount requirements. Each plan record covers one role category per event. [ENUM-REF-CANDIDATE: security|medical|usher|concessions|parking|cleaning|av_production|guest_services|other — promote to reference product]' ;
    rdfs:domain ind:StaffPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shiftDurationHours rdf:type rdf:Property ;
    rdfs:label 'Shift Duration Hours' ;
    rdfs:comment 'Total planned shift duration in hours for this role category, derived from shift start and end timestamps. Used for cost estimation and CBA compliance checks.' ;
    rdfs:domain ind:StaffPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shiftEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Shift End Timestamp' ;
    rdfs:comment 'Planned date and time when staff in this role category are scheduled to end their shift, including post-event teardown and debrief time.' ;
    rdfs:domain ind:StaffPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:shiftStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Shift Start Timestamp' ;
    rdfs:comment 'Planned date and time when staff in this role category are scheduled to begin their shift, including pre-event setup and briefing time.' ;
    rdfs:domain ind:StaffPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:supervisorName rdf:type rdf:Property ;
    rdfs:label 'Supervisor Name' ;
    rdfs:comment 'Name of the designated supervisor or team lead responsible for managing staff in this role category on event day. Business reference field, not direct PII in operational context.' ;
    rdfs:domain ind:StaffPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:uniformCode rdf:type rdf:Property ;
    rdfs:label 'Uniform Code' ;
    rdfs:comment 'Code identifying the required uniform or dress code for staff in this role category. Used for procurement planning and event-day identification of staff.' ;
    rdfs:domain ind:StaffPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:extendedTransactionWindowId rdf:type rdf:Property ;
    rdfs:label 'Extended Transaction Window Id' ;
    rdfs:comment 'Self-referencing FK on transaction_window (extended_transaction_window_id)' ;
    rdfs:domain ind:TransactionWindow ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TransactionWindow .

ind:approvalTurnaroundHours rdf:type rdf:Property ;
    rdfs:label 'Approval Turnaround Hours' ;
    rdfs:comment 'Maximum number of hours within which the league office must approve or reject a transaction submitted during this window. Defines the Service Level Agreement (SLA) for transaction processing.' ;
    rdfs:domain ind:TransactionWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:closeTimestamp rdf:type rdf:Property ;
    rdfs:label 'Close Timestamp' ;
    rdfs:comment 'Precise date and time (with timezone) at which the transaction window officially closes. Critical for trade deadline compliance — transactions submitted after this timestamp are invalid.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:competitiveIntegrityReviewRequired rdf:type rdf:Property ;
    rdfs:label 'Competitive Integrity Review Required' ;
    rdfs:comment 'Indicates whether transactions executed during this window are subject to a competitive integrity review by the league office to prevent collusion, tanking, or other violations of fair competition standards.' ;
    rdfs:domain ind:TransactionWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:eligibleTransactionTypes rdf:type rdf:Property ;
    rdfs:label 'Eligible Transaction Types' ;
    rdfs:comment 'Comma-separated list of transaction types authorized during this window (e.g., \'trade,waiver_claim,free_agent_signing,dfa,option_exercise\'). Defines the scope of permissible roster movements for compliance validation of league_trade_transaction and waiver_claim records.' ;
    rdfs:domain ind:TransactionWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:franchiseParticipationScope rdf:type rdf:Property ;
    rdfs:label 'Franchise Participation Scope' ;
    rdfs:comment 'Defines which franchises are eligible to participate in this transaction window. \'all_franchises\' applies league-wide; other values restrict participation to a subset of franchises.' ;
    rdfs:domain ind:TransactionWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:internationalTransferRulesApply rdf:type rdf:Property ;
    rdfs:label 'International Transfer Rules Apply' ;
    rdfs:comment 'Indicates whether FIFA Transfer Regulations or equivalent international governing body transfer rules apply to transactions within this window. Relevant for MLS, international soccer, and cross-border athlete movements.' ;
    rdfs:domain ind:TransactionWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isFreeAgencyEligible rdf:type rdf:Property ;
    rdfs:label 'Is Free Agency Eligible' ;
    rdfs:comment 'Indicates whether free agent signings are permitted during this transaction window. Governs whether franchises may negotiate and execute contracts with unrestricted or restricted free agents.' ;
    rdfs:domain ind:TransactionWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isInternationalSigningEligible rdf:type rdf:Property ;
    rdfs:label 'Is International Signing Eligible' ;
    rdfs:comment 'Indicates whether international player signings are authorized during this window. Relevant for MLB International Signing Period, FIFA transfer windows, and MLS international roster slots.' ;
    rdfs:domain ind:TransactionWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isTradeEligible rdf:type rdf:Property ;
    rdfs:label 'Is Trade Eligible' ;
    rdfs:comment 'Indicates whether player-for-player or player-for-pick trades are permitted during this transaction window. False for windows restricted to free agency or waiver activity only.' ;
    rdfs:domain ind:TransactionWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isWaiverEligible rdf:type rdf:Property ;
    rdfs:label 'Is Waiver Eligible' ;
    rdfs:comment 'Indicates whether waiver claims and waiver wire transactions are permitted during this transaction window. Determines whether waiver_claim records may be anchored to this window.' ;
    rdfs:domain ind:TransactionWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:leagueApprovalRequired rdf:type rdf:Property ;
    rdfs:label 'League Approval Required' ;
    rdfs:comment 'Indicates whether transactions executed during this window require explicit league office approval before becoming effective. When true, transactions remain pending until the league approves.' ;
    rdfs:domain ind:TransactionWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maxCashConsiderationUsd rdf:type rdf:Property ;
    rdfs:label 'Max Cash Consideration Usd' ;
    rdfs:comment 'Maximum cash consideration in US dollars permitted in a single transaction during this window, as governed by CBA provisions. Null if no cash limit applies. Used for compliance validation of league_trade_transaction records.' ;
    rdfs:domain ind:TransactionWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxTransactionsPerFranchise rdf:type rdf:Property ;
    rdfs:label 'Max Transactions Per Franchise' ;
    rdfs:comment 'Maximum number of transactions a single franchise may execute during this window, as defined by league rules or CBA provisions. Null indicates no per-franchise limit.' ;
    rdfs:domain ind:TransactionWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:penaltyDraftPickLoss rdf:type rdf:Property ;
    rdfs:label 'Penalty Draft Pick Loss' ;
    rdfs:comment 'Indicates whether violation of this transaction window\'s rules may result in forfeiture of draft picks as a disciplinary penalty, per CBA or league governance provisions.' ;
    rdfs:domain ind:TransactionWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:penaltyFineAmount rdf:type rdf:Property ;
    rdfs:label 'Penalty Fine Amount' ;
    rdfs:comment 'Monetary fine amount imposed on a franchise for executing a transaction outside the authorized window or in violation of window rules. Expressed in the currency defined by currency_code.' ;
    rdfs:domain ind:TransactionWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:penaltySuspensionEligible rdf:type rdf:Property ;
    rdfs:label 'Penalty Suspension Eligible' ;
    rdfs:comment 'Indicates whether franchise personnel (e.g., general managers, coaches) may be suspended for violations of this transaction window\'s rules.' ;
    rdfs:domain ind:TransactionWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rosterFreezeApplies rdf:type rdf:Property ;
    rdfs:label 'Roster Freeze Applies' ;
    rdfs:comment 'Indicates whether a roster freeze is in effect during this transaction window, prohibiting certain roster moves. Common during playoff periods or immediately preceding the trade deadline.' ;
    rdfs:domain ind:TransactionWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:salaryCapApplies rdf:type rdf:Property ;
    rdfs:label 'Salary Cap Applies' ;
    rdfs:comment 'Indicates whether salary cap compliance checks are required for transactions executed during this window. When true, all transactions must be validated against the franchise\'s cap space before league approval.' ;
    rdfs:domain ind:TransactionWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:wadaClearanceRequired rdf:type rdf:Property ;
    rdfs:label 'Wada Clearance Required' ;
    rdfs:comment 'Indicates whether World Anti-Doping Agency (WADA) clearance is required for athletes involved in transactions during this window. Applicable for international transfers and leagues with mandatory anti-doping compliance.' ;
    rdfs:domain ind:TransactionWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:windowName rdf:type rdf:Property ;
    rdfs:label 'Window Name' ;
    rdfs:comment 'Official human-readable name of the transaction window as published by the league (e.g., \'NFL Trade Deadline 2024\', \'NBA Free Agency Window 2024-25\', \'MLB International Signing Period 2024\').' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:windowNotes rdf:type rdf:Property ;
    rdfs:label 'Window Notes' ;
    rdfs:comment 'Free-text field for league operations staff to record supplementary information about this transaction window, including special conditions, amendments, or exceptions not captured in structured fields.' ;
    rdfs:domain ind:TransactionWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:windowReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Window Reference Number' ;
    rdfs:comment 'Externally-known alphanumeric reference code assigned by the league office to uniquely identify this transaction window for official communications, compliance filings, and franchise notifications.' ;
    rdfs:domain ind:TransactionWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:windowType rdf:type rdf:Property ;
    rdfs:label 'Window Type' ;
    rdfs:comment 'Classification of the transaction window by its primary business purpose. Determines which roster movement and trade activity types are authorized. DFA = Designated for Assignment. [ENUM-REF-CANDIDATE: trade_deadline|free_agency|waiver_period|dfa_window|international_signing|supplemental_draft — promote to reference product if additional types emerge]' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:splitFromBroadcastWindowId rdf:type rdf:Property ;
    rdfs:label 'Split From Broadcast Window Id' ;
    rdfs:comment 'Self-referencing FK on broadcast_window (split_from_broadcast_window_id)' ;
    rdfs:domain ind:BroadcastWindow ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BroadcastWindow .

ind:adInventorySeconds rdf:type rdf:Property ;
    rdfs:label 'Ad Inventory Seconds' ;
    rdfs:comment 'Total available advertising inventory in seconds within this broadcast window. Used for ad sales, CPM revenue forecasting, and sponsor fulfillment tracking.' ;
    rdfs:domain ind:BroadcastWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:alternateCommentaryLanguageCode rdf:type rdf:Property ;
    rdfs:label 'Alternate Commentary Language Code' ;
    rdfs:comment 'ISO 639-1/639-2 language code for a secondary or alternate commentary track (e.g., Spanish-language feed on an English-primary broadcast). Supports multi-language broadcast packages.' ;
    rdfs:domain ind:BroadcastWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:broadcastEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Broadcast End Timestamp' ;
    rdfs:comment 'Expected end time of the broadcast window, including post-match coverage, analysis segments, and sign-off. Used for scheduling adjacent programming and managing broadcast slot duration.' ;
    rdfs:domain ind:BroadcastWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:broadcastKickoffTimestamp rdf:type rdf:Property ;
    rdfs:label 'Broadcast Kickoff Timestamp' ;
    rdfs:comment 'The contractually mandated or broadcaster-driven start time for the fixture as required by the broadcast window. May differ from the venue-local scheduled start time due to broadcast scheduling constraints (e.g., network prime-time requirements).' ;
    rdfs:domain ind:BroadcastWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:broadcastRightsRegion rdf:type rdf:Property ;
    rdfs:label 'Broadcast Rights Region' ;
    rdfs:comment 'The geographic market or territory in which this digital touchpoint is licensed to distribute this fixture. Belongs to the distribution record because the same fixture may have different licensed regions per touchpoint.' ;
    rdfs:domain ind:BroadcastWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coverageStatus rdf:type rdf:Property ;
    rdfs:label 'Coverage Status' ;
    rdfs:comment 'Operational lifecycle status of this fixture\'s coverage under this deal. Tracks whether the rights coverage is scheduled, confirmed by both parties, currently live, completed post-broadcast, or under dispute.' ;
    rdfs:domain ind:BroadcastWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:daletScheduleReference rdf:type rdf:Property ;
    rdfs:label 'Dalet Schedule Reference' ;
    rdfs:comment 'Source system identifier from Dalet Galaxy Media Asset Management and Broadcast Workflow platform for this broadcast window schedule entry. Enables bi-directional reconciliation between the lakehouse and the operational broadcast scheduling system.' ;
    rdfs:domain ind:BroadcastWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:digitalStreamingIncluded rdf:type rdf:Property ;
    rdfs:label 'Digital Streaming Included' ;
    rdfs:comment 'Indicates whether the broadcast window rights package includes simultaneous or catch-up digital/OTT streaming rights in addition to linear broadcast. Drives DTC and OTT platform activation.' ;
    rdfs:domain ind:BroadcastWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:drmPolicyCode rdf:type rdf:Property ;
    rdfs:label 'Drm Policy Code' ;
    rdfs:comment 'Code referencing the Digital Rights Management (DRM) policy applied to this broadcast window for digital and OTT distribution. Governs content protection, geo-restriction enforcement, and stream encryption requirements.' ;
    rdfs:domain ind:BroadcastWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedViewership rdf:type rdf:Property ;
    rdfs:label 'Expected Viewership' ;
    rdfs:comment 'Projected audience size (number of viewers) for this broadcast window in the specified territory. Used for CPM pricing, sponsor valuation, and rights fee benchmarking. Sourced from historical ratings and audience research.' ;
    rdfs:domain ind:BroadcastWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:geoRestrictionApplicable rdf:type rdf:Property ;
    rdfs:label 'Geo Restriction Applicable' ;
    rdfs:comment 'Indicates whether geographic blackout or content restriction rules are enforced for this specific fixture-touchpoint combination. Distinct from the touchpoint-level geo_restriction_enabled flag, which is a capability indicator rather than a per-fixture enforcement decision.' ;
    rdfs:domain ind:BroadcastWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isFreeToAir rdf:type rdf:Property ;
    rdfs:label 'Is Free To Air' ;
    rdfs:comment 'Indicates whether this broadcast window is distributed on a free-to-air (FTA) basis, accessible to all viewers without subscription or pay-per-view purchase. Relevant for regulatory compliance in markets with FTA obligations for major sporting events.' ;
    rdfs:domain ind:BroadcastWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:kickoffConstraintReason rdf:type rdf:Property ;
    rdfs:label 'Kickoff Constraint Reason' ;
    rdfs:comment 'Reason code explaining why the broadcast-driven kickoff time was set, particularly when it differs from the venue-preferred or league-default time. Supports scheduling governance and CBA compliance review. [ENUM-REF-CANDIDATE: broadcaster_prime_time|network_scheduling|rights_agreement|league_mandate|venue_curfew|international_window|other — promote to reference product]' ;
    rdfs:domain ind:BroadcastWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:localKickoffTimestamp rdf:type rdf:Property ;
    rdfs:label 'Local Kickoff Timestamp' ;
    rdfs:comment 'Territory-specific local start time for the broadcast, accounting for the time zone of the target broadcast market. Distinct from the venue-local kickoff and the broadcaster-mandated kickoff timestamp.' ;
    rdfs:domain ind:BroadcastWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:platformRights rdf:type rdf:Property ;
    rdfs:label 'Platform Rights' ;
    rdfs:comment 'Comma-separated list of platforms (e.g., linear_tv, ott, mobile, ppv) entitled to carry this specific fixture under this deal. Captures the intersection of deal-level platform rights and fixture-level eligibility (e.g., a PPV-eligible fixture activates ppv rights; a non-PPV fixture does not).' ;
    rdfs:domain ind:BroadcastWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postShowEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Post Show End Timestamp' ;
    rdfs:comment 'Scheduled end time for post-match broadcast coverage (interviews, analysis, highlights recap). Defines the full broadcast slot duration for rights and scheduling purposes.' ;
    rdfs:domain ind:BroadcastWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:preShowStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Pre Show Start Timestamp' ;
    rdfs:comment 'Scheduled start time for pre-match broadcast coverage (warm-up shows, analyst panels, player arrivals). Determines when the broadcast feed must be live ahead of kickoff.' ;
    rdfs:domain ind:BroadcastWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:primaryBroadcasterName rdf:type rdf:Property ;
    rdfs:label 'Primary Broadcaster Name' ;
    rdfs:comment 'Name of the primary broadcaster or network holding the rights to air this fixture in the assigned territory (e.g., \'ESPN\', \'Sky Sports\', \'beIN Sports\'). Operational reference for production coordination and rights management.' ;
    rdfs:domain ind:BroadcastWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rightsFeeAllocation rdf:type rdf:Property ;
    rdfs:label 'Rights Fee Allocation' ;
    rdfs:comment 'The portion of the total deal value (in USD) allocated to this specific fixture under this media rights deal. Used for per-fixture revenue recognition, reporting, and rights accounting. Belongs to the fixture-deal combination, not to either entity alone.' ;
    rdfs:domain ind:BroadcastWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rightsFeeCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Rights Fee Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the broadcast rights fee amount (e.g., \'USD\', \'GBP\', \'EUR\'). Required for multi-currency financial reporting and SAP S/4HANA FI integration.' ;
    rdfs:domain ind:BroadcastWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleConflictFlag rdf:type rdf:Property ;
    rdfs:label 'Schedule Conflict Flag' ;
    rdfs:comment 'Indicates whether this broadcast window has a detected scheduling conflict with another fixture or broadcast slot on the same channel or in the same territory. Triggers scheduling review workflow.' ;
    rdfs:domain ind:BroadcastWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:slotDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Slot Duration Minutes' ;
    rdfs:comment 'Total allocated broadcast slot duration in minutes, including pre-show, match/event, and post-show coverage. Used for EPG scheduling, ad inventory planning, and broadcaster contractual slot compliance.' ;
    rdfs:domain ind:BroadcastWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:territoryCountryCode rdf:type rdf:Property ;
    rdfs:label 'Territory Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code identifying the primary broadcast territory for this window. Governs rights enforcement, blackout rules, and geo-targeted distribution. Use \'WLD\' for worldwide rights.' ;
    rdfs:domain ind:BroadcastWindow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ticketTransferId rdf:type rdf:Property ;
    rdfs:label 'Ticket Transfer Id' ;
    rdfs:comment 'Unique system-generated identifier for each peer-to-peer ticket transfer record. Primary key for the ticket_transfer data product.' ;
    rdfs:domain ind:TicketTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryPriorTransferTicketTransferId rdf:type rdf:Property ;
    rdfs:label 'Primary Prior Transfer Ticket Transfer Id' ;
    rdfs:comment 'Reference to the immediately preceding transfer record for this ticket, enabling chain-of-custody tracking across multiple transfers. Null for the first transfer of a ticket.' ;
    rdfs:domain ind:TicketTransfer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TicketTransfer .

ind:primaryTicketFanProfileId rdf:type rdf:Property ;
    rdfs:label 'Primary Ticket Fan Profile Id' ;
    rdfs:comment 'Fan account identifier of the ticket holder initiating the transfer (the sender). Used for CRM tracking, season ticket holder (STH) loyalty attribution, and transfer eligibility validation.' ;
    rdfs:domain ind:TicketTransfer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FanProfile .

ind:primaryTicketInventoryId rdf:type rdf:Property ;
    rdfs:label 'Primary Ticket Inventory Id' ;
    rdfs:comment 'Reference to the specific ticket inventory record being transferred between fan accounts. Links to the originating ticket entitlement.' ;
    rdfs:domain ind:TicketTransfer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TicketInventory .

ind:tertiaryTicketRecipientFanFanProfileId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Ticket Recipient Fan Fan Profile Id' ;
    rdfs:comment 'Fan account identifier of the fan receiving the transferred ticket. Populated upon successful transfer acceptance. Null if the recipient has not yet accepted or does not have an existing fan account.' ;
    rdfs:domain ind:TicketTransfer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FanProfile .

ind:acceptedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Accepted Timestamp' ;
    rdfs:comment 'Date and time when the recipient accepted the ticket transfer. Null if the transfer has not yet been accepted. Triggers entitlement re-issuance to the recipient fan account.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:expiryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Expiry Timestamp' ;
    rdfs:comment 'Date and time after which the transfer invitation is no longer valid for acceptance. If the recipient does not accept before this timestamp, the transfer status transitions to \'expired\' and the entitlement reverts to the sender.' ;
    rdfs:domain ind:TicketTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:fraudRiskFlag rdf:type rdf:Property ;
    rdfs:label 'Fraud Risk Flag' ;
    rdfs:comment 'Indicates whether this transfer was flagged by the fraud detection system as potentially suspicious (e.g., rapid successive transfers, transfers to unknown accounts, high-value event tickets). Triggers manual review workflow.' ;
    rdfs:domain ind:TicketTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:initiatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Initiated Timestamp' ;
    rdfs:comment 'Date and time when the sender initiated the ticket transfer request. This is the principal business event timestamp for the transfer lifecycle. Stored in ISO 8601 format with timezone offset.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:isReturnTransfer rdf:type rdf:Property ;
    rdfs:label 'Is Return Transfer' ;
    rdfs:comment 'Indicates whether this transfer represents a ticket being returned to the original sender after a prior outbound transfer. Supports STH account reconciliation and loyalty point reversal workflows.' ;
    rdfs:domain ind:TicketTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recipientDisplayName rdf:type rdf:Property ;
    rdfs:label 'Recipient Display Name' ;
    rdfs:comment 'Display name or full name of the recipient as entered by the sender or resolved from the recipient fan account. Used for sender confirmation UI and customer service. Classified as restricted PII per GDPR Article 4.' ;
    rdfs:domain ind:TicketTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recipientTermsAcceptedFlag rdf:type rdf:Property ;
    rdfs:label 'Recipient Terms Accepted Flag' ;
    rdfs:comment 'Indicates whether the recipient explicitly accepted the transfer terms and conditions upon claiming the ticket. Required for entitlement issuance and compliance with consumer protection regulations.' ;
    rdfs:domain ind:TicketTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sourceSystemTransferCode rdf:type rdf:Property ;
    rdfs:label 'Source System Transfer Code' ;
    rdfs:comment 'Native transfer identifier from the originating operational system (Ticketmaster or AXS). Used for cross-system reconciliation, support case lookup, and data lineage tracing between the Silver layer and the source system of record.' ;
    rdfs:domain ind:TicketTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:termsAcceptedFlag rdf:type rdf:Property ;
    rdfs:label 'Terms Accepted Flag' ;
    rdfs:comment 'Indicates whether the sender explicitly accepted the transfer terms and conditions at the time of initiating the transfer. Required for compliance with Ticketmaster/AXS transfer policy and consumer protection regulations.' ;
    rdfs:domain ind:TicketTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:termsVersion rdf:type rdf:Property ;
    rdfs:label 'Terms Version' ;
    rdfs:comment 'Version identifier of the transfer terms and conditions accepted by the sender at the time of transfer initiation. Enables legal and compliance teams to audit which version of terms governed each transfer.' ;
    rdfs:domain ind:TicketTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferDirection rdf:type rdf:Property ;
    rdfs:label 'Transfer Direction' ;
    rdfs:comment 'Indicates the directional nature of the transfer relative to the originating account. \'outbound\' — sender is giving away the ticket; \'inbound\' — recipient is receiving; \'return\' — ticket returned to original holder after a prior transfer.' ;
    rdfs:domain ind:TicketTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferMethod rdf:type rdf:Property ;
    rdfs:label 'Transfer Method' ;
    rdfs:comment 'Channel or mechanism used to deliver the transfer invitation to the recipient. \'mobile_app\' — in-app transfer via Ticketmaster/AXS mobile; \'email\' — transfer link sent via email; \'sms\' — transfer link sent via SMS; \'platform_link\' — shareable URL generated for transfer.' ;
    rdfs:domain ind:TicketTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Transfer Reference Number' ;
    rdfs:comment 'Externally-visible alphanumeric reference number assigned to the transfer transaction, used for fan-facing communication, customer service lookup, and audit trail. Sourced from Ticketmaster/AXS transfer workflow.' ;
    rdfs:domain ind:TicketTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferRestrictionReason rdf:type rdf:Property ;
    rdfs:label 'Transfer Restriction Reason' ;
    rdfs:comment 'Reason code explaining why a transfer was restricted or blocked. \'none\' — no restriction; \'price_tier_restricted\' — price tier does not permit transfer; \'event_restricted\' — event-level transfer lockout; \'package_restricted\' — season ticket package terms prohibit transfer; \'compliance_hold\' — regulatory or compliance hold; \'fraud_hold\' — fraud risk flag applied.' ;
    rdfs:domain ind:TicketTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferType rdf:type rdf:Property ;
    rdfs:label 'Transfer Type' ;
    rdfs:comment 'Classification of the transfer by business context. \'standard\' — ad hoc peer-to-peer transfer; \'season_ticket_forward\' — STH forwarding a game ticket; \'group_forward\' — group sale ticket forwarded to individual attendee; \'comp_forward\' — complimentary ticket forwarded by recipient.' ;
    rdfs:domain ind:TicketTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentBettingMarketId rdf:type rdf:Property ;
    rdfs:label 'Parent Betting Market Id' ;
    rdfs:comment 'Self-referencing FK on betting_market (parent_betting_market_id)' ;
    rdfs:domain ind:BettingMarket ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BettingMarket .

ind:primaryBettingEventFixtureId rdf:type rdf:Property ;
    rdfs:label 'Primary Betting Event Fixture Id' ;
    rdfs:comment 'Reference to the specific sports or entertainment event this market is associated with. Links the market definition to the event scheduling and planning domain for settlement and reporting.' ;
    rdfs:domain ind:BettingMarket ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Fixture .

ind:ageVerificationRequired rdf:type rdf:Property ;
    rdfs:label 'Age Verification Required' ;
    rdfs:comment 'Indicates whether bettors must complete age verification before placing wagers on this market. True = age verification mandatory; False = standard KYC suffices. Driven by jurisdiction-specific regulatory requirements.' ;
    rdfs:domain ind:BettingMarket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:displayOrder rdf:type rdf:Property ;
    rdfs:label 'Display Order' ;
    rdfs:comment 'Numeric ordering value controlling the sequence in which this market is presented within its market category on betting interfaces and odds feeds. Lower values appear first. Supports merchandising and fan engagement optimization.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isFuturesMarket rdf:type rdf:Property ;
    rdfs:label 'Is Futures Market' ;
    rdfs:comment 'Indicates whether this market is a futures wagering product where the outcome is determined at a future date (e.g., season champion, award winner). True = futures market; False = event-specific market. Affects settlement timeline and liability reporting.' ;
    rdfs:domain ind:BettingMarket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isLiveInplay rdf:type rdf:Property ;
    rdfs:label 'Is Live Inplay' ;
    rdfs:comment 'Indicates whether this market is offered as a live in-play (in-game) wagering product where odds update in real time during the event. True = live in-play market; False = pre-game market. Drives real-time odds feed routing and latency SLA requirements.' ;
    rdfs:domain ind:BettingMarket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isParlayEligible rdf:type rdf:Property ;
    rdfs:label 'Is Parlay Eligible' ;
    rdfs:comment 'Indicates whether this market can be combined into a parlay or teaser multi-leg wager. True = eligible for parlay inclusion; False = must be wagered as a standalone market. Governs parlay construction rules in the betting platform.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:marginPercentage rdf:type rdf:Property ;
    rdfs:label 'Margin Percentage' ;
    rdfs:comment 'The operator\'s built-in margin (overround/vig) applied to this market, expressed as a decimal percentage (e.g., 0.0500 = 5%). Represents the house edge embedded in the odds. Confidential commercial data used for profitability analysis and pricing strategy.' ;
    rdfs:domain ind:BettingMarket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:marketCategory rdf:type rdf:Property ;
    rdfs:label 'Market Category' ;
    rdfs:comment 'High-level grouping of the market by scope: Game = single-game outcome; Season = full-season result (e.g., division winner); Tournament = multi-round competition outcome; Player = individual athlete performance; Team = team-level statistic; Entertainment = non-sport event (e.g., awards show outcome).' ;
    rdfs:domain ind:BettingMarket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketCloseTimestamp rdf:type rdf:Property ;
    rdfs:label 'Market Close Timestamp' ;
    rdfs:comment 'Date and time when this wagering market was closed and no further wagers were accepted. For pre-game markets this is typically event start time; for live markets it is the point of suspension or event conclusion.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:marketCode rdf:type rdf:Property ;
    rdfs:label 'Market Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying this market definition across odds feeds, prop bet catalogs, and regulatory reporting systems. Used as the business key in downstream integrations.' ;
    rdfs:domain ind:BettingMarket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketOpenTimestamp rdf:type rdf:Property ;
    rdfs:label 'Market Open Timestamp' ;
    rdfs:comment 'Date and time when this wagering market was first opened and made available for bet placement. Used for audit trails, regulatory reporting, and market lifecycle analytics.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:marketSourceFeed rdf:type rdf:Property ;
    rdfs:label 'Market Source Feed' ;
    rdfs:comment 'Identifier of the external odds feed provider or internal pricing engine that originates the market definition and odds for this market (e.g., \'SPORTRADAR\', \'GENIUS_SPORTS\', \'INTERNAL_TRADING\'). Supports feed reconciliation and SLA monitoring.' ;
    rdfs:domain ind:BettingMarket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketStatus rdf:type rdf:Property ;
    rdfs:label 'Market Status' ;
    rdfs:comment 'Current operational lifecycle state of the wagering market. Open = accepting wagers; Suspended = temporarily halted (e.g., injury news, VAR review); Closed = no longer accepting wagers; Settled = outcome determined and payouts processed; Voided = market cancelled with stakes returned; Pending = awaiting activation.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketTypeCode rdf:type rdf:Property ;
    rdfs:label 'Market Type Code' ;
    rdfs:comment 'Classification of the wagering market structure. Moneyline = straight win/loss; Spread = point spread handicap; Total = over/under aggregate score; Futures = outcome of future event; Parlay = multi-leg combined bet; Teaser = adjusted spread/total parlay; Prop = proposition/player-specific bet; Live In-Play = real-time in-game market. [ENUM-REF-CANDIDATE: moneyline|spread|total|futures|parlay|teaser|prop|live_inplay — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:BettingMarket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxLiabilityAmount rdf:type rdf:Property ;
    rdfs:label 'Max Liability Amount' ;
    rdfs:comment 'Maximum total financial exposure the operator accepts across all wagers on this market before triggering automatic suspension or odds adjustment. Expressed in the operating currency. Confidential risk management parameter.' ;
    rdfs:domain ind:BettingMarket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxPayoutAmount rdf:type rdf:Property ;
    rdfs:label 'Max Payout Amount' ;
    rdfs:comment 'Maximum total payout the operator will honor for a single winning wager on this market, expressed in the operating currency. Caps operator liability for high-odds outcomes.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxStakeAmount rdf:type rdf:Property ;
    rdfs:label 'Max Stake Amount' ;
    rdfs:comment 'Maximum wager amount permitted on this market per bet placement, expressed in the operating currency. Enforced to manage operator liability exposure and comply with responsible gaming limits.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minStakeAmount rdf:type rdf:Property ;
    rdfs:label 'Min Stake Amount' ;
    rdfs:comment 'Minimum wager amount permitted on this market per bet placement, expressed in the operating currency. Enforced at point-of-sale to comply with operator risk management and regulatory minimums.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:oddsFormat rdf:type rdf:Property ;
    rdfs:label 'Odds Format' ;
    rdfs:comment 'Default odds presentation format for this market. American = moneyline (+/-); Decimal = European multiplier; Fractional = UK traditional; Hong Kong/Indonesian/Malay = regional formats. Drives display logic in betting interfaces and odds feeds.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:propBetCategory rdf:type rdf:Property ;
    rdfs:label 'Prop Bet Category' ;
    rdfs:comment 'For proposition (prop) bet markets, classifies the type of proposition: Player Performance = individual athlete stat (e.g., passing yards, points scored); Team Statistic = team-level metric; Game Event = specific in-game occurrence (e.g., first score method); Entertainment = non-sport proposition; None = not a prop bet market.' ;
    rdfs:domain ind:BettingMarket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryMarketCode rdf:type rdf:Property ;
    rdfs:label 'Regulatory Market Code' ;
    rdfs:comment 'The market identifier assigned by the relevant gaming regulatory authority for official reporting and audit purposes. Required for regulatory filings in licensed jurisdictions. May differ from internal market_code.' ;
    rdfs:domain ind:BettingMarket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsibleGamingFlag rdf:type rdf:Property ;
    rdfs:label 'Responsible Gaming Flag' ;
    rdfs:comment 'Indicates whether this market has been flagged for enhanced responsible gaming controls (e.g., lower stake limits, mandatory cooling-off prompts, exclusion from promotional offers). True = enhanced controls active; False = standard controls apply.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:settlementOutcome rdf:type rdf:Property ;
    rdfs:label 'Settlement Outcome' ;
    rdfs:comment 'The official result used to settle this market (e.g., \'HOME_WIN\', \'OVER\', \'PLAYER_A\', \'PUSH\'). Populated after event conclusion and official score confirmation. Null until market is settled. [ENUM-REF-CANDIDATE: HOME_WIN|AWAY_WIN|DRAW|OVER|UNDER|PUSH|VOID|CANCELLED — promote to reference product]' ;
    rdfs:domain ind:BettingMarket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementRuleCode rdf:type rdf:Property ;
    rdfs:label 'Settlement Rule Code' ;
    rdfs:comment 'Code referencing the official settlement rule set applied to determine winning outcomes for this market (e.g., REGULATION_TIME_ONLY, INCLUDING_OT, OFFICIAL_SCORE_AT_CLOSE). Governs how and when the market is settled post-event.' ;
    rdfs:domain ind:BettingMarket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementRuleDescription rdf:type rdf:Property ;
    rdfs:label 'Settlement Rule Description' ;
    rdfs:comment 'Plain-language description of the settlement rules for this market, including conditions for void, push, or partial settlement. Displayed to bettors and referenced in regulatory filings.' ;
    rdfs:domain ind:BettingMarket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementTimestamp rdf:type rdf:Property ;
    rdfs:label 'Settlement Timestamp' ;
    rdfs:comment 'Date and time when the market outcome was officially determined and winning wagers were settled. Null if market is not yet settled. Critical for financial reconciliation and regulatory reporting.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:spreadValue rdf:type rdf:Property ;
    rdfs:label 'Spread Value' ;
    rdfs:comment 'The handicap value applied to the favored team or participant in a spread market (e.g., -3.5 means the favorite must win by more than 3.5 points). Null for non-spread market types.' ;
    rdfs:domain ind:BettingMarket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalLineValue rdf:type rdf:Property ;
    rdfs:label 'Total Line Value' ;
    rdfs:comment 'The aggregate score or statistical threshold set for an over/under (totals) market (e.g., 47.5 total points in an NFL game). Bettors wager on whether the actual result exceeds or falls below this value. Null for non-totals market types.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:oddsFeedId rdf:type rdf:Property ;
    rdfs:label 'Odds Feed Id' ;
    rdfs:comment 'Unique surrogate identifier for each odds feed record in the Silver layer lakehouse. Primary key for the odds_feed data product.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OddsFeed .

ind:primaryOddsEventFixtureId rdf:type rdf:Property ;
    rdfs:label 'Primary Odds Event Fixture Id' ;
    rdfs:comment 'Reference to the sporting event (fixture or competition) to which this odds feed record is associated.' ;
    rdfs:domain ind:OddsFeed ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Fixture .

ind:selectionId rdf:type rdf:Property ;
    rdfs:label 'Selection Id' ;
    rdfs:comment 'Reference to the specific selection (outcome) within the betting market for which odds are being updated (e.g., Team A to win, Over 2.5 goals).' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Selection .

ind:supersededOddsFeedId rdf:type rdf:Property ;
    rdfs:label 'Superseded Odds Feed Id' ;
    rdfs:comment 'Self-referencing FK on odds_feed (superseded_odds_feed_id)' ;
    rdfs:domain ind:OddsFeed ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OddsFeed .

ind:americanOdds rdf:type rdf:Property ;
    rdfs:label 'American Odds' ;
    rdfs:comment 'The odds expressed in American moneyline format. Positive values (e.g., +150) indicate profit on a $100 stake; negative values (e.g., -200) indicate the stake required to win $100. Standard format for US sports wagering markets.' ;
    rdfs:domain ind:OddsFeed ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:decimalOdds rdf:type rdf:Property ;
    rdfs:label 'Decimal Odds' ;
    rdfs:comment 'The odds expressed in decimal format (European format), representing the total payout per unit staked including the stake (e.g., 2.500000 means a $1 bet returns $2.50). Widely used in European and international markets.' ;
    rdfs:domain ind:OddsFeed ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:feedChannel rdf:type rdf:Property ;
    rdfs:label 'Feed Channel' ;
    rdfs:comment 'The technical delivery channel through which this odds update was received from the provider. Supports feed reliability monitoring and SLA compliance tracking.' ;
    rdfs:domain ind:OddsFeed ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feedLatencyMs rdf:type rdf:Property ;
    rdfs:label 'Feed Latency Ms' ;
    rdfs:comment 'The measured latency in milliseconds between the provider_published_timestamp and the received_timestamp for this odds update. Used for SLA monitoring, provider performance benchmarking, and real-time display quality assurance.' ;
    rdfs:domain ind:OddsFeed ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:feedReferenceCode rdf:type rdf:Property ;
    rdfs:label 'Feed Reference Code' ;
    rdfs:comment 'Externally-known unique identifier assigned by the odds provider for this specific odds update message. Used for deduplication, reconciliation, and audit trail against the provider\'s own records.' ;
    rdfs:domain ind:OddsFeed ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feedSourceName rdf:type rdf:Property ;
    rdfs:label 'Feed Source Name' ;
    rdfs:comment 'Human-readable name of the odds data provider or compiler that supplied this update (e.g., \'Sportradar\', \'Kambi\', \'Genius Sports\', \'SBTech\'). Used for provider performance monitoring and SLA tracking.' ;
    rdfs:domain ind:OddsFeed ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feedVersion rdf:type rdf:Property ;
    rdfs:label 'Feed Version' ;
    rdfs:comment 'Version identifier of the odds feed protocol or API specification used by the provider for this update. Supports backward compatibility management and feed migration tracking.' ;
    rdfs:domain ind:OddsFeed ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fractionalOddsDenominator rdf:type rdf:Property ;
    rdfs:label 'Fractional Odds Denominator' ;
    rdfs:comment 'The denominator component of fractional odds (UK format), representing the stake unit (e.g., denominator 1 in 3/1 means $1 staked). Combined with numerator to express the full fractional odds.' ;
    rdfs:domain ind:OddsFeed ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fractionalOddsNumerator rdf:type rdf:Property ;
    rdfs:label 'Fractional Odds Numerator' ;
    rdfs:comment 'The numerator component of fractional odds (UK format), representing the profit relative to the denominator stake (e.g., numerator 3 in 3/1 means $3 profit per $1 staked). Used in UK and Irish markets.' ;
    rdfs:domain ind:OddsFeed ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:handicapValue rdf:type rdf:Property ;
    rdfs:label 'Handicap Value' ;
    rdfs:comment 'The handicap or point spread value associated with this selection, where applicable (e.g., -1.5 goals, +3.5 points). Null for non-handicap markets. Essential for Asian handicap, European handicap, and point spread markets.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:impliedProbability rdf:type rdf:Property ;
    rdfs:label 'Implied Probability' ;
    rdfs:comment 'The probability of the selection winning as implied by the current odds, expressed as a decimal between 0 and 1 (e.g., 0.400000 = 40%). Derived from decimal odds as 1/decimal_odds before margin adjustment. Used for overround analysis and pricing analytics.' ;
    rdfs:domain ind:OddsFeed ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:integrityAlertFlag rdf:type rdf:Property ;
    rdfs:label 'Integrity Alert Flag' ;
    rdfs:comment 'Indicates whether this odds update has triggered a betting integrity alert (True), such as suspicious line movement that may indicate match-fixing or insider information. Supports regulatory reporting obligations to governing bodies (FIFA, NFL, NBA, etc.).' ;
    rdfs:domain ind:OddsFeed ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isInPlay rdf:type rdf:Property ;
    rdfs:label 'Is In Play' ;
    rdfs:comment 'Indicates whether this odds update relates to an in-play (live) betting market where the event is already in progress (True), or a pre-match market (False). In-play markets have different regulatory requirements and risk profiles.' ;
    rdfs:domain ind:OddsFeed ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isResulted rdf:type rdf:Property ;
    rdfs:label 'Is Resulted' ;
    rdfs:comment 'Indicates whether the betting market has been officially resulted/settled (True) or is still open/pending (False). A resulted market has a confirmed outcome and all bets have been settled.' ;
    rdfs:domain ind:OddsFeed ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSuspended rdf:type rdf:Property ;
    rdfs:label 'Is Suspended' ;
    rdfs:comment 'Indicates whether the betting market was suspended at the time of this odds update (True = suspended, False = tradeable). Suspension may be triggered by significant events (e.g., red card, injury, VAR review, TMO decision) or risk management actions.' ;
    rdfs:domain ind:OddsFeed ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jurisdictionCode rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Code' ;
    rdfs:comment 'ISO 3166-1 alpha-2 or alpha-3 country/state code identifying the regulatory jurisdiction under which this odds feed record is governed. Critical for jurisdiction-specific compliance, licensing, and regulatory reporting (e.g., US state-level gaming regulations, GDPR for EU).' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineMovementDirection rdf:type rdf:Property ;
    rdfs:label 'Line Movement Direction' ;
    rdfs:comment 'Indicates the direction of the odds movement relative to the previous update for this selection. \'up\' means odds lengthened (selection less favoured); \'down\' means odds shortened (selection more favoured); \'unchanged\' means no movement; \'open\' is the first price; \'close\' is the final price before event start.' ;
    rdfs:domain ind:OddsFeed ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketType rdf:type rdf:Property ;
    rdfs:label 'Market Type' ;
    rdfs:comment 'Classification of the betting market type for this odds update (e.g., match_result, over_under, handicap, first_goalscorer, prop_bet, futures, outright). Supports market-level analytics and regulatory reporting segmentation. [ENUM-REF-CANDIDATE: match_result|over_under|handicap|first_goalscorer|prop_bet|futures|outright — promote to reference product]' ;
    rdfs:domain ind:OddsFeed ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overroundPct rdf:type rdf:Property ;
    rdfs:label 'Overround Pct' ;
    rdfs:comment 'The bookmaker\'s margin (vigorish/vig) expressed as a percentage, calculated as the sum of all implied probabilities for a market minus 100%. Represents the theoretical profit margin built into the odds. Used for pricing analytics and margin monitoring.' ;
    rdfs:domain ind:OddsFeed ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:previousDecimalOdds rdf:type rdf:Property ;
    rdfs:label 'Previous Decimal Odds' ;
    rdfs:comment 'The decimal odds value from the immediately preceding odds update for this selection and market. Enables line movement magnitude calculation and trend analysis without requiring a self-join.' ;
    rdfs:domain ind:OddsFeed ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceBoostIndicator rdf:type rdf:Property ;
    rdfs:label 'Price Boost Indicator' ;
    rdfs:comment 'Indicates whether the odds for this selection have been artificially enhanced as part of a promotional price boost offer (True) or reflect standard market pricing (False). Price boosts are a common fan engagement and DTC acquisition tool.' ;
    rdfs:domain ind:OddsFeed ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:providerPublishedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Provider Published Timestamp' ;
    rdfs:comment 'The date and time at which the odds provider published or generated this odds update on their end. Used to calculate feed latency (received_timestamp minus provider_published_timestamp) and for regulatory audit trails.' ;
    rdfs:domain ind:OddsFeed ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:receivedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Received Timestamp' ;
    rdfs:comment 'The precise date and time (with millisecond precision and timezone offset) at which this odds update message was received from the provider feed. Principal business event timestamp for latency measurement and audit.' ;
    rdfs:domain ind:OddsFeed ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:regulatoryReportingFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reporting Flag' ;
    rdfs:comment 'Indicates whether this odds feed record must be included in regulatory filings or reports to gaming authorities in the applicable jurisdiction (True). Supports automated regulatory reporting workflows and SOX/CCPA/GDPR compliance.' ;
    rdfs:domain ind:OddsFeed ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:resultOutcome rdf:type rdf:Property ;
    rdfs:label 'Result Outcome' ;
    rdfs:comment 'The official result outcome for this selection once the market has been resulted. \'win\' = selection won; \'lose\' = selection lost; \'void\' = bet voided; \'push\' = stake returned (tie); \'half_win\'/\'half_lose\' = Asian handicap partial outcomes. Null until market is resulted.' ;
    rdfs:domain ind:OddsFeed ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceMarketReference rdf:type rdf:Property ;
    rdfs:label 'Source Market Reference' ;
    rdfs:comment 'The provider\'s own internal market identifier or reference code for this betting market, as supplied in the feed message. Enables direct reconciliation with the provider\'s system without requiring a reverse lookup.' ;
    rdfs:domain ind:OddsFeed ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cashoutOfWagerId rdf:type rdf:Property ;
    rdfs:label 'Cashout Of Wager Id' ;
    rdfs:comment 'Self-referencing FK on wager (cashout_of_wager_id)' ;
    rdfs:domain ind:Wager ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Wager .

ind:promotionCampaignId rdf:type rdf:Property ;
    rdfs:label 'Promotion Campaign Id' ;
    rdfs:comment 'Foreign key linking to fan.campaign. Business justification: Sportsbook operators track which promotional campaign drove a wager (free bet offers, deposit match promotions) for marketing ROI reporting and bonus liability accounting. wager.promotion_code is a de' ;
    rdfs:domain ind:Wager ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Campaign .

ind:regulatoryReportId rdf:type rdf:Property ;
    rdfs:label 'Regulatory Report Id' ;
    rdfs:comment 'The identifier of the regulatory filing or suspicious activity report (SAR) that this wager was included in, if applicable. Used for AML compliance tracking and regulatory audit trail. Null if no regulatory report has been filed for this wager.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RegulatoryReport .

ind:voidEmergencyActivationId rdf:type rdf:Property ;
    rdfs:label 'Void Emergency Activation Id' ;
    rdfs:comment 'Foreign key linking to security.emergency_activation. Business justification: Wager void due to emergency event cancellation: when an emergency activation cancels an event, open wagers must be voided and stakes refunded. This FK links each voided wager to the specific activatio' ;
    rdfs:domain ind:Wager ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EmergencyActivation .

ind:wagerEventFixtureId rdf:type rdf:Property ;
    rdfs:label 'Wager Event Fixture Id' ;
    rdfs:comment 'Identifier of the sporting or entertainment event that this wager is associated with (e.g., NFL game, UFC bout, NBA match). Used for event-level wagering aggregation and settlement.' ;
    rdfs:domain ind:Wager ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Fixture .

ind:wagerFixtureId rdf:type rdf:Property ;
    rdfs:label 'Wager Fixture Id' ;
    rdfs:comment 'Identifier of the sporting or entertainment event that this wager is associated with (e.g., NFL game, UFC bout, NBA match). Used for event-level wagering aggregation and settlement.' ;
    rdfs:domain ind:Wager ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Fixture .

ind:bonusAmount rdf:type rdf:Property ;
    rdfs:label 'Bonus Amount' ;
    rdfs:comment 'The monetary value of any bonus or promotional credit applied to this wager. Tracked separately from real-money stake for regulatory gross gaming revenue (GGR) reporting and bonus liability accounting.' ;
    rdfs:domain ind:Wager ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cashoutAmount rdf:type rdf:Property ;
    rdfs:label 'Cashout Amount' ;
    rdfs:comment 'The monetary amount offered and accepted by the bettor when exercising the early cash-out option. Null if the wager was not cashed out. Represents the sportsbook\'s real-time liability reduction value.' ;
    rdfs:domain ind:Wager ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cashoutTimestamp rdf:type rdf:Property ;
    rdfs:label 'Cashout Timestamp' ;
    rdfs:comment 'The date and time when the bettor exercised the early cash-out option, if applicable. Null if the wager was not cashed out early. Used for cash-out feature analytics and liability management.' ;
    rdfs:domain ind:Wager ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:deviceFingerprint rdf:type rdf:Property ;
    rdfs:label 'Device Fingerprint' ;
    rdfs:comment 'Anonymized or hashed identifier of the device used to place the wager. Used for fraud detection, multi-accounting prevention, and geolocation compliance verification. Not a direct personal identifier but may be used to identify individuals in combination with other data.' ;
    rdfs:domain ind:Wager ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geolocationCountry rdf:type rdf:Property ;
    rdfs:label 'Geolocation Country' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code where the bettor was physically located at time of wager placement. Used for international jurisdiction compliance and cross-border wagering restriction enforcement.' ;
    rdfs:domain ind:Wager ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geolocationState rdf:type rdf:Property ;
    rdfs:label 'Geolocation State' ;
    rdfs:comment 'Two-letter US state code (or equivalent jurisdiction code) where the bettor was physically located at time of wager placement, as verified by geolocation service. Critical for confirming the bettor is within a licensed wagering jurisdiction.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geolocationVerified rdf:type rdf:Property ;
    rdfs:label 'Geolocation Verified' ;
    rdfs:comment 'Indicates whether the bettor\'s physical location was successfully verified by the geolocation service at time of wager placement. False may indicate a geolocation failure or VPN/proxy detection, requiring compliance review.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:integrityFlag rdf:type rdf:Property ;
    rdfs:label 'Integrity Flag' ;
    rdfs:comment 'Indicates whether this wager has been flagged for sports integrity review due to suspicious betting patterns (e.g., unusual odds movement, match-fixing indicators). Flagged wagers are reported to relevant sports governing bodies (FIFA, NFL, NBA integrity units) and gaming regulators.' ;
    rdfs:domain ind:Wager ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isFreeBet rdf:type rdf:Property ;
    rdfs:label 'Is Free Bet' ;
    rdfs:comment 'Indicates whether this wager was funded by a promotional free bet credit rather than real money from the bettor\'s account. Free bets are excluded from certain regulatory gross gaming revenue calculations.' ;
    rdfs:domain ind:Wager ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isLiveBet rdf:type rdf:Property ;
    rdfs:label 'Is Live Bet' ;
    rdfs:comment 'Indicates whether this wager was placed as an in-play (live) bet after the event commenced, as opposed to a pre-game bet. Live bets carry different risk profiles and are subject to specific regulatory requirements in some jurisdictions.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:legCount rdf:type rdf:Property ;
    rdfs:label 'Leg Count' ;
    rdfs:comment 'The number of individual selections (legs) included in this wager. For straight bets this is 1; for parlays and teasers this is 2 or more. Used for parlay payout validation and risk management.' ;
    rdfs:domain ind:Wager ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:oddsAtPlacement rdf:type rdf:Property ;
    rdfs:label 'Odds At Placement' ;
    rdfs:comment 'The decimal odds offered to the bettor at the exact moment the wager was placed. Locked in at placement time and used for payout calculation. Stored in decimal format (e.g., 2.50 = evens +100 American odds) regardless of display format shown to bettor.' ;
    rdfs:domain ind:Wager ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:placementTimestamp rdf:type rdf:Property ;
    rdfs:label 'Placement Timestamp' ;
    rdfs:comment 'The exact date and time (with timezone) when the wager was accepted and confirmed by the sportsbook platform. This is the principal business event timestamp and is critical for in-play betting validation, regulatory reporting, and audit trails.' ;
    rdfs:domain ind:Wager ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:potentialPayout rdf:type rdf:Property ;
    rdfs:label 'Potential Payout' ;
    rdfs:comment 'The maximum gross payout amount the bettor would receive if the wager wins, calculated as stake_amount multiplied by odds_at_placement. Captured at placement time for liability management and bettor communication.' ;
    rdfs:domain ind:Wager ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:potentialProfit rdf:type rdf:Property ;
    rdfs:label 'Potential Profit' ;
    rdfs:comment 'The net profit the bettor would receive if the wager wins, calculated as potential_payout minus stake_amount. Represents the bettor\'s net gain and is used in responsible gaming exposure monitoring.' ;
    rdfs:domain ind:Wager ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:selectionDescription rdf:type rdf:Property ;
    rdfs:label 'Selection Description' ;
    rdfs:comment 'Human-readable description of the bettor\'s selection within the betting market (e.g., \'Kansas City Chiefs to win\', \'Over 48.5 total points\', \'LeBron James to score 30+ points\'). Captured at time of placement for audit and display purposes.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:selfExclusionOverride rdf:type rdf:Property ;
    rdfs:label 'Self Exclusion Override' ;
    rdfs:comment 'Indicates whether this wager was placed despite a self-exclusion or cooling-off period being active on the bettor\'s account. Should always be False for compliant operations; True values require immediate regulatory escalation.' ;
    rdfs:domain ind:Wager ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:stakeAmount rdf:type rdf:Property ;
    rdfs:label 'Stake Amount' ;
    rdfs:comment 'The monetary amount wagered by the bettor at time of placement, in the transaction currency. Represents the bettor\'s financial exposure and is the basis for hold calculations and regulatory reporting.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taxWithheldAmount rdf:type rdf:Property ;
    rdfs:label 'Tax Withheld Amount' ;
    rdfs:comment 'The amount of tax withheld from the settlement payout at source, as required by applicable jurisdiction tax laws (e.g., US federal withholding on large winnings per IRS Form W-2G thresholds). Zero if no withholding applies.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ticketTerminalCode rdf:type rdf:Property ;
    rdfs:label 'Ticket Terminal Code' ;
    rdfs:comment 'Identifier of the specific betting terminal, kiosk, or point-of-sale device used to place the wager. Used for terminal-level reconciliation, fraud detection, and equipment audit trails in retail and kiosk channels.' ;
    rdfs:domain ind:Wager ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wagerStatus rdf:type rdf:Property ;
    rdfs:label 'Wager Status' ;
    rdfs:comment 'Current lifecycle status of the wager. \'pending\' indicates the event has not yet concluded; \'won\'/\'lost\' reflect settled outcomes; \'void\' indicates cancellation (e.g., event postponed); \'cashed_out\' reflects early cash-out by bettor; \'pushed\' indicates a tie/refund outcome.' ;
    rdfs:domain ind:Wager ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wagerType rdf:type rdf:Property ;
    rdfs:label 'Wager Type' ;
    rdfs:comment 'Classification of the wager structure. \'straight\' is a single-selection bet; \'parlay\' combines multiple selections for higher payout; \'teaser\' adjusts point spreads; \'prop\' is a proposition bet on specific in-game events; \'futures\' bets on season-long outcomes; \'round_robin\' is a series of parlays. [ENUM-REF-CANDIDATE: straight|parlay|teaser|prop|futures|round_robin|if_bet|reverse — promote to reference product]' ;
    rdfs:domain ind:Wager ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acquisitionCampaignId rdf:type rdf:Property ;
    rdfs:label 'Acquisition Campaign Id' ;
    rdfs:comment 'Foreign key linking to fan.campaign. Business justification: Gaming operators track which marketing campaign drove bettor account registration for affiliate commission calculation and acquisition ROI reporting. bettor_account has denormalized affiliate_code and' ;
    rdfs:domain ind:BettorAccount ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Campaign .

ind:referredByBettorAccountId rdf:type rdf:Property ;
    rdfs:label 'Referred By Bettor Account Id' ;
    rdfs:comment 'Self-referencing FK on bettor_account (referred_by_bettor_account_id)' ;
    rdfs:domain ind:BettorAccount ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BettorAccount .

ind:affiliateCode rdf:type rdf:Property ;
    rdfs:label 'Affiliate Code' ;
    rdfs:comment 'Affiliate or partner referral code applied at account registration. Used to attribute the account acquisition to a specific affiliate partner for commission calculation and partnership performance reporting.' ;
    rdfs:domain ind:BettorAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ageVerified rdf:type rdf:Property ;
    rdfs:label 'Age Verified' ;
    rdfs:comment 'Indicates whether the bettor has passed mandatory age verification confirming they meet the minimum legal gambling age for their registration jurisdiction. Accounts with False status are restricted from wagering activity.' ;
    rdfs:domain ind:BettorAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ageVerifiedDate rdf:type rdf:Property ;
    rdfs:label 'Age Verified Date' ;
    rdfs:comment 'Date on which the bettor\'s age was successfully verified. Null if age verification has not been completed. Required for regulatory compliance reporting.' ;
    rdfs:domain ind:BettorAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:balance rdf:type rdf:Property ;
    rdfs:label 'Balance' ;
    rdfs:comment 'Current real-money balance available in the bettor\'s account for wagering, expressed in the account\'s base currency. Excludes bonus funds. Updated in real time following deposits, withdrawals, wager placements, and settlements.' ;
    rdfs:domain ind:BettorAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bonusBalance rdf:type rdf:Property ;
    rdfs:label 'Bonus Balance' ;
    rdfs:comment 'Current promotional or bonus credit balance in the bettor\'s account. Bonus funds are subject to wagering requirements before withdrawal and are tracked separately from real-money balance per regulatory requirements.' ;
    rdfs:domain ind:BettorAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:depositLimitDaily rdf:type rdf:Property ;
    rdfs:label 'Deposit Limit Daily' ;
    rdfs:comment 'Maximum amount the bettor is permitted to deposit within a rolling 24-hour period. Set by the bettor or operator as a responsible gaming control. Null indicates no limit is set. Enforced at the platform level.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:depositLimitMonthly rdf:type rdf:Property ;
    rdfs:label 'Deposit Limit Monthly' ;
    rdfs:comment 'Maximum amount the bettor is permitted to deposit within a rolling 30-day period. A responsible gaming control that can be set by the bettor or mandated by the operator or regulator. Null indicates no limit is set.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:depositLimitWeekly rdf:type rdf:Property ;
    rdfs:label 'Deposit Limit Weekly' ;
    rdfs:comment 'Maximum amount the bettor is permitted to deposit within a rolling 7-day period. A responsible gaming control that can be set by the bettor or mandated by the operator or regulator. Null indicates no limit is set.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:identityDocumentExpiry rdf:type rdf:Property ;
    rdfs:label 'Identity Document Expiry' ;
    rdfs:comment 'Expiry date of the identity document submitted for KYC. Used to trigger re-verification workflows when documents approach or pass expiry, ensuring ongoing KYC compliance.' ;
    rdfs:domain ind:BettorAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:identityDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Identity Document Reference' ;
    rdfs:comment 'Tokenized or masked reference to the government-issued identity document number used for KYC verification. The full document number is stored in the secure KYC vault; this field holds only the vault reference token to enable audit linkage without exposing raw PII.' ;
    rdfs:domain ind:BettorAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:identityDocumentType rdf:type rdf:Property ;
    rdfs:label 'Identity Document Type' ;
    rdfs:comment 'Type of government-issued identity document submitted for KYC verification. Determines the applicable document validation rules and expiry tracking requirements.' ;
    rdfs:domain ind:BettorAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:kycStatus rdf:type rdf:Property ;
    rdfs:label 'Kyc Status' ;
    rdfs:comment 'Current status of the Know Your Customer (KYC) identity verification process for this account. Accounts must achieve \'verified\' status before full wagering privileges are granted. \'expired\' indicates previously verified documents have lapsed and re-verification is required.' ;
    rdfs:domain ind:BettorAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:kycVerifiedDate rdf:type rdf:Property ;
    rdfs:label 'Kyc Verified Date' ;
    rdfs:comment 'Date on which the bettor\'s identity was successfully verified through the KYC process. Null if KYC has not been completed. Used for compliance audit trails and re-verification scheduling.' ;
    rdfs:domain ind:BettorAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lossLimitDaily rdf:type rdf:Property ;
    rdfs:label 'Loss Limit Daily' ;
    rdfs:comment 'Maximum net loss the bettor is permitted to incur within a rolling 24-hour period. A responsible gaming control that triggers account suspension when reached. Null indicates no limit is set.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:promoCodeUsed rdf:type rdf:Property ;
    rdfs:label 'Promo Code Used' ;
    rdfs:comment 'Promotional or welcome offer code entered by the bettor at account registration. Used to apply welcome bonuses, track promotional campaign effectiveness, and calculate bonus liability.' ;
    rdfs:domain ind:BettorAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Registration Jurisdiction' ;
    rdfs:comment 'ISO 3166-1 alpha-2 or alpha-3 code for the jurisdiction (state, province, or country) under which this account was registered and is licensed to operate. Determines applicable regulatory framework, tax obligations, and responsible gaming requirements.' ;
    rdfs:domain ind:BettorAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationStateCode rdf:type rdf:Property ;
    rdfs:label 'Registration State Code' ;
    rdfs:comment 'Two-letter US state or Canadian province code where the bettor account was registered. Used for state-level regulatory reporting, tax withholding, and geofencing compliance. Complements registration_jurisdiction for sub-national precision.' ;
    rdfs:domain ind:BettorAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsibleGamingFlagDate rdf:type rdf:Property ;
    rdfs:label 'Responsible Gaming Flag Date' ;
    rdfs:comment 'Date on which the responsible gaming flag was most recently set on this account. Used to track the duration of elevated monitoring and schedule periodic reviews.' ;
    rdfs:domain ind:BettorAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:selfExclusionEndDate rdf:type rdf:Property ;
    rdfs:label 'Self Exclusion End Date' ;
    rdfs:comment 'Date on which the bettor\'s self-exclusion period is scheduled to end. Null for indefinite exclusions or accounts with no exclusion. Used to trigger re-activation eligibility workflows.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:selfExclusionStartDate rdf:type rdf:Property ;
    rdfs:label 'Self Exclusion Start Date' ;
    rdfs:comment 'Date on which the bettor\'s self-exclusion period began. Null if no self-exclusion is active or has ever been applied. Required for regulatory compliance and re-activation eligibility calculations.' ;
    rdfs:domain ind:BettorAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:selfExclusionStatus rdf:type rdf:Property ;
    rdfs:label 'Self Exclusion Status' ;
    rdfs:comment 'Indicates whether the bettor has enrolled in a self-exclusion program. \'voluntary\' means bettor-initiated exclusion; \'mandatory\' means regulator or operator-imposed exclusion; \'expired\' means a prior exclusion period has ended. Accounts with active exclusion are blocked from wagering.' ;
    rdfs:domain ind:BettorAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceChannel rdf:type rdf:Property ;
    rdfs:label 'Source Channel' ;
    rdfs:comment 'Channel through which the bettor account was originally registered. Used for customer acquisition cost (CAC) attribution, affiliate commission calculations, and channel performance analytics.' ;
    rdfs:domain ind:BettorAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxIdReference rdf:type rdf:Property ;
    rdfs:label 'Tax Id Reference' ;
    rdfs:comment 'Tokenized reference to the bettor\'s tax identification number (e.g., SSN or ITIN in the US) stored in the secure KYC vault. Required for IRS W-2G tax reporting on winnings exceeding regulatory thresholds. The raw TIN is never stored in this field.' ;
    rdfs:domain ind:BettorAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:twoFactorAuthEnabled rdf:type rdf:Property ;
    rdfs:label 'Two Factor Auth Enabled' ;
    rdfs:comment 'Indicates whether the bettor has enabled two-factor authentication (2FA) on their account. Relevant for security posture reporting and may be mandated by certain jurisdictions for high-value accounts.' ;
    rdfs:domain ind:BettorAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:w2gThresholdMet rdf:type rdf:Property ;
    rdfs:label 'W2g Threshold Met' ;
    rdfs:comment 'Indicates whether the bettor has met the IRS W-2G reportable winnings threshold ($600 or more at 300:1 odds or greater, or $1,200+ for certain game types) within the current tax year. Triggers tax documentation workflows.' ;
    rdfs:domain ind:BettorAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:wagerLimitDaily rdf:type rdf:Property ;
    rdfs:label 'Wager Limit Daily' ;
    rdfs:comment 'Maximum total wager amount the bettor is permitted to place within a rolling 24-hour period. A responsible gaming control. Null indicates no limit is set.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:propBetId rdf:type rdf:Property ;
    rdfs:label 'Prop Bet Id' ;
    rdfs:comment 'Unique surrogate identifier for each proposition bet offering in the master catalog. Primary key for the prop_bet data product.' ;
    rdfs:domain ind:PropBet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:parentPropBetId rdf:type rdf:Property ;
    rdfs:label 'Parent Prop Bet Id' ;
    rdfs:comment 'Self-referencing FK on prop_bet (parent_prop_bet_id)' ;
    rdfs:domain ind:PropBet ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PropBet .

ind:primaryPropAthleteAthleteProfileId rdf:type rdf:Property ;
    rdfs:label 'Primary Prop Athlete Athlete Profile Id' ;
    rdfs:comment 'Reference to the athlete who is the subject of a player proposition bet (e.g., anytime touchdown scorer, first basket, strikeout totals). Null for game-level or novelty props.' ;
    rdfs:domain ind:PropBet ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AthleteProfile .

ind:primaryPropEventFixtureId rdf:type rdf:Property ;
    rdfs:label 'Primary Prop Event Fixture Id' ;
    rdfs:comment 'Reference to the sporting event or fixture to which this proposition bet is associated (e.g., NFL game, UFC bout, NBA match).' ;
    rdfs:domain ind:PropBet ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Fixture .

ind:ageRestrictionYears rdf:type rdf:Property ;
    rdfs:label 'Age Restriction Years' ;
    rdfs:comment 'Minimum legal age in years required to place a wager on this proposition bet in the applicable jurisdiction (typically 18 or 21 depending on jurisdiction). Enforced at account verification.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fantasySportType rdf:type rdf:Property ;
    rdfs:label 'Fantasy Sport Type' ;
    rdfs:comment 'Indicates whether this proposition bet is associated with a daily fantasy sports (DFS) contest, a season-long fantasy league, or is a standard sportsbook prop (not_applicable). Used for regulatory classification under UIGEA and state DFS laws.' ;
    rdfs:domain ind:PropBet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fixtureDate rdf:type rdf:Property ;
    rdfs:label 'Fixture Date' ;
    rdfs:comment 'The scheduled calendar date of the sporting event or fixture to which this proposition bet is tied. Used for scheduling, market management, and regulatory reporting.' ;
    rdfs:domain ind:PropBet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isSameGameParlayEligible rdf:type rdf:Property ;
    rdfs:label 'Is Same Game Parlay Eligible' ;
    rdfs:comment 'Indicates whether this proposition bet is eligible to be combined with other bets from the same game in a same-game parlay (SGP) product. Distinct from general parlay eligibility due to correlated outcome risk controls.' ;
    rdfs:domain ind:PropBet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jurisdictionCodes rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Codes' ;
    rdfs:comment 'Pipe-delimited list of jurisdiction codes (US state, country, or territory codes) where this proposition bet is legally available for wagering (e.g., \'NJ|NV|PA|CO|IL\'). Drives geo-restriction logic on the betting platform.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineUnit rdf:type rdf:Property ;
    rdfs:label 'Line Unit' ;
    rdfs:comment 'The unit of measurement for the proposition bet line value (e.g., touchdowns, points, yards, strikeouts, assists, rebounds, goals). Provides context for interpreting prop_line_value. [ENUM-REF-CANDIDATE: touchdowns|points|yards|strikeouts|assists|rebounds|goals|saves|aces|birdies|rounds|other — 12 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PropBet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxWagerAmount rdf:type rdf:Property ;
    rdfs:label 'Max Wager Amount' ;
    rdfs:comment 'The maximum single-bet stake amount (in the operating currency) permitted on this proposition bet, as set by the risk management team. Enforced at the platform level to control liability exposure.' ;
    rdfs:domain ind:PropBet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minWagerAmount rdf:type rdf:Property ;
    rdfs:label 'Min Wager Amount' ;
    rdfs:comment 'The minimum single-bet stake amount (in the operating currency) required to place a wager on this proposition bet. Set by the platform operator per regulatory and commercial requirements.' ;
    rdfs:domain ind:PropBet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:oddsProviderCode rdf:type rdf:Property ;
    rdfs:label 'Odds Provider Code' ;
    rdfs:comment 'Code identifying the external odds feed provider or trading desk that supplied the opening and current odds for this proposition bet (e.g., \'SPORTRADAR\', \'GENIUS_SPORTS\', \'INTERNAL\').' ;
    rdfs:domain ind:PropBet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overOdds rdf:type rdf:Property ;
    rdfs:label 'Over Odds' ;
    rdfs:comment 'The current decimal odds offered for the \'over\' or \'yes\' selection on this proposition bet. Expressed in decimal format per international sportsbook standards (e.g., 1.9091 for -110 American odds).' ;
    rdfs:domain ind:PropBet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:propCategory rdf:type rdf:Property ;
    rdfs:label 'Prop Category' ;
    rdfs:comment 'High-level classification of the proposition bet type: player_prop (individual athlete performance), game_prop (game-level outcome), team_prop (team performance), novelty_prop (non-standard entertainment wagers), entertainment_prop (non-sport entertainment events), series_prop (multi-game series outcome).' ;
    rdfs:domain ind:PropBet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:propCode rdf:type rdf:Property ;
    rdfs:label 'Prop Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying this proposition bet offering within the gaming platform and across partner sportsbook integrations (e.g., PROP-NFL-TD-ANYTIME-001).' ;
    rdfs:domain ind:PropBet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:propDescription rdf:type rdf:Property ;
    rdfs:label 'Prop Description' ;
    rdfs:comment 'Detailed narrative description of the proposition bet, including the specific outcome being wagered on, applicable rules, and any clarifying conditions for settlement.' ;
    rdfs:domain ind:PropBet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:propLineValue rdf:type rdf:Property ;
    rdfs:label 'Prop Line Value' ;
    rdfs:comment 'The numeric threshold or line associated with over/under or points-based proposition bets (e.g., 1.5 touchdowns, 24.5 points, 7.5 strikeouts). Null for yes/no or binary props.' ;
    rdfs:domain ind:PropBet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:propName rdf:type rdf:Property ;
    rdfs:label 'Prop Name' ;
    rdfs:comment 'Human-readable display name of the proposition bet as shown to bettors on the platform (e.g., \'Anytime Touchdown Scorer - Patrick Mahomes\', \'First Team to Score\').' ;
    rdfs:domain ind:PropBet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:propSubcategory rdf:type rdf:Property ;
    rdfs:label 'Prop Subcategory' ;
    rdfs:comment 'Granular classification within the prop category (e.g., \'touchdown_scorer\', \'passing_yards\', \'first_basket\', \'strikeout_total\', \'margin_of_victory\', \'first_team_to_score\'). [ENUM-REF-CANDIDATE: touchdown_scorer|passing_yards|first_basket|strikeout_total|margin_of_victory|first_team_to_score|rushing_yards|receiving_yards|assists|rebounds — promote to reference product]' ;
    rdfs:domain ind:PropBet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryCategory rdf:type rdf:Property ;
    rdfs:label 'Regulatory Category' ;
    rdfs:comment 'Regulatory classification of the proposition bet for licensing, reporting, and compliance purposes as defined by applicable gaming authorities (sports_wagering, daily_fantasy, novelty, entertainment, esports).' ;
    rdfs:domain ind:PropBet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementCriteria rdf:type rdf:Property ;
    rdfs:label 'Settlement Criteria' ;
    rdfs:comment 'Detailed rules and conditions used to determine the winning outcome of the proposition bet (e.g., \'Player must score a touchdown at any point during regulation and overtime\', \'Official league statistics used for settlement within 72 hours of game completion\').' ;
    rdfs:domain ind:PropBet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementResult rdf:type rdf:Property ;
    rdfs:label 'Settlement Result' ;
    rdfs:comment 'The official outcome of the proposition bet after settlement: win (winning selection), lose (losing selection), void (bet cancelled), push (tie/refund), pending (not yet settled).' ;
    rdfs:domain ind:PropBet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:underOdds rdf:type rdf:Property ;
    rdfs:label 'Under Odds' ;
    rdfs:comment 'The current decimal odds offered for the \'under\' or \'no\' selection on this proposition bet. Expressed in decimal format per international sportsbook standards.' ;
    rdfs:domain ind:PropBet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:winningSelection rdf:type rdf:Property ;
    rdfs:label 'Winning Selection' ;
    rdfs:comment 'The specific outcome or selection that was determined to be the winner upon settlement (e.g., \'Yes\', \'Over\', \'Team A\', player name). Populated after settlement.' ;
    rdfs:domain ind:PropBet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fantasyLeagueId rdf:type rdf:Property ;
    rdfs:label 'Fantasy League Id' ;
    rdfs:comment 'Unique surrogate identifier for each fantasy sports league instance. Primary key for the fantasy_league data product in the gaming domain.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FantasyLeague .

ind:predecessorFantasyLeagueId rdf:type rdf:Property ;
    rdfs:label 'Predecessor Fantasy League Id' ;
    rdfs:comment 'Self-referencing FK on fantasy_league (predecessor_fantasy_league_id)' ;
    rdfs:domain ind:FantasyLeague ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FantasyLeague .

ind:ageRestrictionMinimum rdf:type rdf:Property ;
    rdfs:label 'Age Restriction Minimum' ;
    rdfs:comment 'Minimum participant age (in years) required to join this league, as mandated by the applicable gaming jurisdiction. Typically 18 or 21 depending on state/country regulations.' ;
    rdfs:domain ind:FantasyLeague ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:auctionBudget rdf:type rdf:Property ;
    rdfs:label 'Auction Budget' ;
    rdfs:comment 'The total virtual currency budget allocated to each team manager for bidding during an auction draft. Applicable only when draft_type is auction. Null for snake or auto-pick drafts.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:benchSlots rdf:type rdf:Property ;
    rdfs:label 'Bench Slots' ;
    rdfs:comment 'Number of non-scoring reserve player slots on each team\'s roster. Bench players do not contribute to weekly scoring but are held for future use.' ;
    rdfs:domain ind:FantasyLeague ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:draftType rdf:type rdf:Property ;
    rdfs:label 'Draft Type' ;
    rdfs:comment 'The method by which team managers select players at the start of the season. Snake drafts reverse pick order each round; auction drafts allocate a budget for bidding; auto-pick uses algorithmic selection; linear maintains consistent pick order; third-round reversal is a hybrid variant. [ENUM-REF-CANDIDATE: snake|auction|auto_pick|linear|third_round_reversal — promote to reference product]' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entryFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Entry Fee Amount' ;
    rdfs:comment 'Monetary amount charged to each team manager to participate in the league. Zero for free-to-play leagues. Used for prize pool calculation, revenue recognition, and regulatory reporting to gaming authorities.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:entryFeeCurrency rdf:type rdf:Property ;
    rdfs:label 'Entry Fee Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the entry fee amount (e.g., USD, CAD, GBP). Required for multi-jurisdiction gaming operations and financial reporting.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:faabBudget rdf:type rdf:Property ;
    rdfs:label 'Faab Budget' ;
    rdfs:comment 'The total Free Agent Acquisition Budget (FAAB) allocated to each team at season start for bidding on waiver wire players. Applicable only when waiver_type is FAAB. Null for non-FAAB leagues.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inviteCode rdf:type rdf:Property ;
    rdfs:label 'Invite Code' ;
    rdfs:comment 'Alphanumeric code required to join a private or corporate league. Distributed by the commissioner to authorized participants. Null for public leagues.' ;
    rdfs:domain ind:FantasyLeague ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isKeeperLeague rdf:type rdf:Property ;
    rdfs:label 'Is Keeper League' ;
    rdfs:comment 'Indicates whether the league allows managers to retain (keep) a defined number of players from one season to the next. True for keeper and dynasty formats; False for redraft leagues.' ;
    rdfs:domain ind:FantasyLeague ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPublic rdf:type rdf:Property ;
    rdfs:label 'Is Public' ;
    rdfs:comment 'Indicates whether the league is publicly discoverable and joinable without an invitation code. True for open public leagues; False for private, corporate, or invite-only leagues.' ;
    rdfs:domain ind:FantasyLeague ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:keeperSlotCount rdf:type rdf:Property ;
    rdfs:label 'Keeper Slot Count' ;
    rdfs:comment 'Number of players each team manager is permitted to retain (keep) from the prior season\'s roster. Applicable only when is_keeper_league is True. Null for redraft leagues.' ;
    rdfs:domain ind:FantasyLeague ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:leagueExternalCode rdf:type rdf:Property ;
    rdfs:label 'League External Code' ;
    rdfs:comment 'Externally-known identifier assigned by the originating platform (e.g., DraftKings league ID, FanDuel league code, or proprietary platform reference). Used for cross-system reconciliation.' ;
    rdfs:domain ind:FantasyLeague ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:playoffStartWeek rdf:type rdf:Property ;
    rdfs:label 'Playoff Start Week' ;
    rdfs:comment 'The competition week number (within the sport\'s season) at which the fantasy playoff bracket begins. Determines the length of the regular season and playoff scheduling.' ;
    rdfs:domain ind:FantasyLeague ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:playoffTeamCount rdf:type rdf:Property ;
    rdfs:label 'Playoff Team Count' ;
    rdfs:comment 'Number of teams that qualify for the end-of-season playoff bracket. Determines playoff seeding logic and the number of regular-season weeks required.' ;
    rdfs:domain ind:FantasyLeague ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:prizePoolType rdf:type rdf:Property ;
    rdfs:label 'Prize Pool Type' ;
    rdfs:comment 'Classification of how the prize pool is funded and guaranteed. Guaranteed pools are pre-committed by the platform regardless of entry count; variable pools are derived from entry fees collected; hybrid combines both; no_prize applies to free leagues.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prizeStructure rdf:type rdf:Property ;
    rdfs:label 'Prize Structure' ;
    rdfs:comment 'Distribution model for prize pool payouts. Winner-take-all awards the full pool to first place; top_3 distributes across three places; top_half pays all teams finishing in the upper half; custom uses a commissioner-defined payout schedule.' ;
    rdfs:domain ind:FantasyLeague ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationCloseDate rdf:type rdf:Property ;
    rdfs:label 'Registration Close Date' ;
    rdfs:comment 'The last date on which new team managers may join the league. After this date, the league roster is locked and the draft is scheduled.' ;
    rdfs:domain ind:FantasyLeague ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:registrationOpenDate rdf:type rdf:Property ;
    rdfs:label 'Registration Open Date' ;
    rdfs:comment 'The date on which the league becomes open for new team manager registrations. Relevant for public leagues and marketing campaign alignment.' ;
    rdfs:domain ind:FantasyLeague ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rosterSize rdf:type rdf:Property ;
    rdfs:label 'Roster Size' ;
    rdfs:comment 'Total number of player slots on each team\'s active and bench roster combined. Governs the player pool depth required and waiver wire activity.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:scoringFormat rdf:type rdf:Property ;
    rdfs:label 'Scoring Format' ;
    rdfs:comment 'The scoring methodology applied to player statistics to calculate fantasy points. Standard awards points for touchdowns and yardage; PPR (Points Per Reception) adds per-catch bonuses; half-PPR applies a 0.5 per-reception bonus; dynasty retains players across seasons; DFS (Daily Fantasy Sports) uses single-contest scoring; keeper retains selected players; IDP (Individual Defensive Player) scores defensive players individually. [ENUM-REF-CANDIDATE: standard|PPR|half_PPR|dynasty|DFS|keeper|IDP — promote to reference product]' ;
    rdfs:domain ind:FantasyLeague ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scoringPeriodType rdf:type rdf:Property ;
    rdfs:label 'Scoring Period Type' ;
    rdfs:comment 'The frequency at which fantasy points are tallied and matchup results are determined. Weekly is standard for NFL; daily is common for NBA and MLB; season_long accumulates points across the full season.' ;
    rdfs:domain ind:FantasyLeague ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:starterCount rdf:type rdf:Property ;
    rdfs:label 'Starter Count' ;
    rdfs:comment 'Number of active (starting) roster slots that score points each week. Excludes bench slots. Critical for lineup optimization analytics.' ;
    rdfs:domain ind:FantasyLeague ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tradeReviewType rdf:type rdf:Property ;
    rdfs:label 'Trade Review Type' ;
    rdfs:comment 'The process by which proposed trades are reviewed and approved or vetoed. Commissioner review gives sole authority to the commissioner; league_vote requires a majority of managers to approve; auto_approve processes trades immediately; none disables trading.' ;
    rdfs:domain ind:FantasyLeague ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waiverType rdf:type rdf:Property ;
    rdfs:label 'Waiver Type' ;
    rdfs:comment 'The mechanism governing how unclaimed free-agent players are acquired during the season. FAAB (Free Agent Acquisition Budget) uses a blind bidding system; rolling assigns priority by last waiver claim; reverse_standings gives priority to lower-ranked teams; none allows immediate free-agent pickups.' ;
    rdfs:domain ind:FantasyLeague ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fantasyRosterId rdf:type rdf:Property ;
    rdfs:label 'Fantasy Roster Id' ;
    rdfs:comment 'Unique surrogate identifier for a fantasy roster record within the gaming domain. Serves as the primary key for this transactional entity capturing a fantasy team\'s active roster at a point in time.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FantasyRoster .

ind:fantasyTeamId rdf:type rdf:Property ;
    rdfs:label 'Fantasy Team Id' ;
    rdfs:comment 'Reference to the fantasy team that owns this roster. Links the roster record to the managing team entity within the fantasy league platform.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FantasyTeam .

ind:previousFantasyRosterId rdf:type rdf:Property ;
    rdfs:label 'Previous Fantasy Roster Id' ;
    rdfs:comment 'Self-referencing FK on fantasy_roster (previous_fantasy_roster_id)' ;
    rdfs:domain ind:FantasyRoster ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FantasyRoster .

ind:primaryFantasyAthleteAthleteProfileId rdf:type rdf:Property ;
    rdfs:label 'Primary Fantasy Athlete Athlete Profile Id' ;
    rdfs:comment 'Reference to the rostered athlete occupying this roster slot. Links to the athlete master record for performance statistics, injury status, and eligibility validation.' ;
    rdfs:domain ind:FantasyRoster ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AthleteProfile .

ind:acquisitionType rdf:type rdf:Property ;
    rdfs:label 'Acquisition Type' ;
    rdfs:comment 'The method by which the fantasy team acquired this athlete onto their roster. Supports waiver processing audits, trade history reporting, and draft analytics.' ;
    rdfs:domain ind:FantasyRoster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auctionDraftPrice rdf:type rdf:Property ;
    rdfs:label 'Auction Draft Price' ;
    rdfs:comment 'The winning bid amount paid for this athlete during an auction-style fantasy draft, applicable when acquisition_type is \'drafted\' in auction format leagues. Used for auction value analytics and budget management reporting.' ;
    rdfs:domain ind:FantasyRoster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:commissionerOverride rdf:type rdf:Property ;
    rdfs:label 'Commissioner Override' ;
    rdfs:comment 'Indicates whether a league commissioner manually overrode the standard roster rules to create or modify this roster record (e.g., reversing an invalid trade, correcting a system error). Supports audit trails for commissioner actions.' ;
    rdfs:domain ind:FantasyRoster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:commissionerOverrideNotes rdf:type rdf:Property ;
    rdfs:label 'Commissioner Override Notes' ;
    rdfs:comment 'Free-text notes entered by the league commissioner explaining the rationale for any manual roster override. Populated only when commissioner_override is true. Supports dispute resolution and audit documentation.' ;
    rdfs:domain ind:FantasyRoster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dropDate rdf:type rdf:Property ;
    rdfs:label 'Drop Date' ;
    rdfs:comment 'The calendar date on which this athlete was dropped from the fantasy team\'s roster, releasing them to the waiver wire or free agent pool. Null if the athlete is currently rostered. Supports roster history and waiver wire availability tracking.' ;
    rdfs:domain ind:FantasyRoster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dropReason rdf:type rdf:Property ;
    rdfs:label 'Drop Reason' ;
    rdfs:comment 'The reason code explaining why this athlete was removed from the fantasy roster. Supports waiver wire analytics, commissioner dispute resolution, and roster management pattern analysis.' ;
    rdfs:domain ind:FantasyRoster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isIrEligible rdf:type rdf:Property ;
    rdfs:label 'Is Ir Eligible' ;
    rdfs:comment 'Indicates whether this athlete currently qualifies for placement on the fantasy team\'s Injured Reserve (IR) slot based on their real-world injury designation (e.g., IR, PUP, Out). Enables roster management without dropping injured players.' ;
    rdfs:domain ind:FantasyRoster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isStartingLineup rdf:type rdf:Property ;
    rdfs:label 'Is Starting Lineup' ;
    rdfs:comment 'Indicates whether this athlete is designated in the active starting lineup (true) or on the bench (false) for the current scoring period. Determines whether the athlete\'s real-world performance scores points for the fantasy team.' ;
    rdfs:domain ind:FantasyRoster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:keeperCostRound rdf:type rdf:Property ;
    rdfs:label 'Keeper Cost Round' ;
    rdfs:comment 'The draft round cost assigned to retaining this athlete as a keeper in the subsequent season\'s draft. Applicable in keeper leagues; null for non-keeper acquisitions.' ;
    rdfs:domain ind:FantasyRoster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:keeperYear rdf:type rdf:Property ;
    rdfs:label 'Keeper Year' ;
    rdfs:comment 'The season year in which this athlete was designated as a keeper, applicable in keeper or dynasty league formats where acquisition_type is \'keeper\'. Tracks multi-year keeper eligibility and cost escalation rules.' ;
    rdfs:domain ind:FantasyRoster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:leagueFormat rdf:type rdf:Property ;
    rdfs:label 'League Format' ;
    rdfs:comment 'The format type of the fantasy league governing this roster record. Determines applicable roster rules, keeper eligibility, salary cap applicability, and scoring configurations.' ;
    rdfs:domain ind:FantasyRoster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineupChangeCount rdf:type rdf:Property ;
    rdfs:label 'Lineup Change Count' ;
    rdfs:comment 'The number of times this roster slot has been modified (athlete swapped in or out) during the current scoring period prior to roster lock. Used for engagement analytics and lineup activity monitoring.' ;
    rdfs:domain ind:FantasyRoster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rosterLockTimestamp rdf:type rdf:Property ;
    rdfs:label 'Roster Lock Timestamp' ;
    rdfs:comment 'The precise date and time at which this roster configuration was locked for the scoring period, preventing further lineup changes. Critical for dispute resolution and lineup integrity enforcement.' ;
    rdfs:domain ind:FantasyRoster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:rosterReferenceCode rdf:type rdf:Property ;
    rdfs:label 'Roster Reference Code' ;
    rdfs:comment 'Externally-known alphanumeric business identifier for this roster record, used in API responses, waiver processing confirmations, and fan-facing lineup management interfaces.' ;
    rdfs:domain ind:FantasyRoster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rosterSlotPosition rdf:type rdf:Property ;
    rdfs:label 'Roster Slot Position' ;
    rdfs:comment 'The designated roster slot position label assigned to this athlete entry (e.g., QB, RB, WR, TE, FLEX, K, DEF, SP, RP, C, PG, SG, SF, PF, G, F, UTIL). Governs lineup eligibility and scoring rules per slot. [ENUM-REF-CANDIDATE: QB|RB|WR|TE|FLEX|K|DEF|SP|RP|C|PG|SG|SF|PF|G|F|UTIL|BN|IR — promote to reference product]' ;
    rdfs:domain ind:FantasyRoster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salaryCapValue rdf:type rdf:Property ;
    rdfs:label 'Salary Cap Value' ;
    rdfs:comment 'The salary cap dollar amount assigned to this athlete on the fantasy team\'s roster, applicable in salary cap or auction draft league formats. Contributes to the team\'s total salary cap utilization tracking.' ;
    rdfs:domain ind:FantasyRoster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scoringPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Scoring Period End Date' ;
    rdfs:comment 'The end date of the fantasy scoring period to which this roster record applies. Together with scoring_period_start_date, defines the exact window for which this roster configuration is valid.' ;
    rdfs:domain ind:FantasyRoster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scoringPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Scoring Period Start Date' ;
    rdfs:comment 'The start date of the fantasy scoring period (week, day, or matchup period) to which this roster record applies. Used for period-based scoring calculations and historical roster snapshots.' ;
    rdfs:domain ind:FantasyRoster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sourcePlatform rdf:type rdf:Property ;
    rdfs:label 'Source Platform' ;
    rdfs:comment 'The platform or channel through which the roster action (acquisition, lineup change, drop) was initiated. Supports fan engagement analytics, platform adoption reporting, and Adobe Experience Platform personalization.' ;
    rdfs:domain ind:FantasyRoster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waiverClaimPriority rdf:type rdf:Property ;
    rdfs:label 'Waiver Claim Priority' ;
    rdfs:comment 'The waiver wire priority order of the fantasy team at the time this athlete was claimed via waiver, applicable when acquisition_type is \'waiver\'. Lower values indicate higher priority. Used for waiver dispute resolution and fairness auditing.' ;
    rdfs:domain ind:FantasyRoster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:waiverClaimTimestamp rdf:type rdf:Property ;
    rdfs:label 'Waiver Claim Timestamp' ;
    rdfs:comment 'The precise timestamp at which the waiver claim for this athlete was submitted by the fantasy team manager. Applicable when acquisition_type is \'waiver\'. Used for claim ordering and dispute resolution.' ;
    rdfs:domain ind:FantasyRoster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:predecessorFantasyTeamId rdf:type rdf:Property ;
    rdfs:label 'Predecessor Fantasy Team Id' ;
    rdfs:comment 'Self-referencing FK on fantasy_team (predecessor_fantasy_team_id)' ;
    rdfs:domain ind:FantasyTeam ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FantasyTeam .

ind:primaryFantasyBettorAccountId rdf:type rdf:Property ;
    rdfs:label 'Primary Fantasy Bettor Account Id' ;
    rdfs:comment 'Reference to the licensed bettor/player account that owns and manages this fantasy team. Links to the registered gaming account for responsible gaming monitoring, KYC compliance, and regulatory reporting.' ;
    rdfs:domain ind:FantasyTeam ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BettorAccount .

ind:auctionBudgetSpent rdf:type rdf:Property ;
    rdfs:label 'Auction Budget Spent' ;
    rdfs:comment 'The total virtual currency spent by this team during the auction draft. Used to calculate remaining budget and validate draft compliance. Applicable only when draft_type is \'auction\'.' ;
    rdfs:domain ind:FantasyTeam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:autopickEnabled rdf:type rdf:Property ;
    rdfs:label 'Autopick Enabled' ;
    rdfs:comment 'Indicates whether the platform\'s automated lineup optimization is enabled for this team. When true, the system sets the optimal starting lineup based on projected points if the manager does not manually set it before the deadline.' ;
    rdfs:domain ind:FantasyTeam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:draftPosition rdf:type rdf:Property ;
    rdfs:label 'Draft Position' ;
    rdfs:comment 'The pick order assigned to this team in the fantasy league\'s draft. Determines the sequence in which the team selects athletes during the draft event. Lower numbers indicate earlier selection priority.' ;
    rdfs:domain ind:FantasyTeam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:emailNotificationEnabled rdf:type rdf:Property ;
    rdfs:label 'Email Notification Enabled' ;
    rdfs:comment 'Indicates whether the team owner has opted in to receive email notifications for league events such as waiver results, trade proposals, and scoring updates. Supports GDPR and CCPA consent management.' ;
    rdfs:domain ind:FantasyTeam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:faabRemaining rdf:type rdf:Property ;
    rdfs:label 'Faab Remaining' ;
    rdfs:comment 'The remaining Free Agent Acquisition Budget (FAAB) balance available for future waiver claims. Decremented with each successful blind-bid claim. Applicable in FAAB waiver leagues.' ;
    rdfs:domain ind:FantasyTeam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastActivityTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Activity Timestamp' ;
    rdfs:comment 'The most recent timestamp at which the team owner performed any action (lineup change, waiver claim, trade, login). Used for inactive team detection, responsible gaming monitoring, and engagement analytics.' ;
    rdfs:domain ind:FantasyTeam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:logoUrl rdf:type rdf:Property ;
    rdfs:label 'Logo Url' ;
    rdfs:comment 'URL pointing to the team\'s custom logo image stored in the Digital Asset Management (DAM) system or Content Delivery Network (CDN). Used for display in league interfaces, mobile apps, and broadcast overlays.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:managerDisplayName rdf:type rdf:Property ;
    rdfs:label 'Manager Display Name' ;
    rdfs:comment 'The public-facing display name of the team owner/manager as shown to other league participants. Distinct from the bettor\'s legal name; may be a username or alias per platform privacy settings.' ;
    rdfs:domain ind:FantasyTeam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:playoffQualified rdf:type rdf:Property ;
    rdfs:label 'Playoff Qualified' ;
    rdfs:comment 'Indicates whether this team has clinched a playoff berth in the current season. True when the team meets the league\'s qualification criteria based on record and standings.' ;
    rdfs:domain ind:FantasyTeam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pointsAgainst rdf:type rdf:Property ;
    rdfs:label 'Points Against' ;
    rdfs:comment 'Cumulative fantasy points scored by opponents against this team across all completed scoring periods. Used as a secondary tiebreaker in standings and for strength-of-schedule analytics.' ;
    rdfs:domain ind:FantasyTeam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pushNotificationEnabled rdf:type rdf:Property ;
    rdfs:label 'Push Notification Enabled' ;
    rdfs:comment 'Indicates whether the team owner has opted in to receive mobile push notifications for real-time scoring updates, injury alerts, and waiver wire activity. Supports GDPR and CCPA consent management.' ;
    rdfs:domain ind:FantasyTeam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:standingRank rdf:type rdf:Property ;
    rdfs:label 'Standing Rank' ;
    rdfs:comment 'Current ordinal rank of this team within its division or league based on wins, losses, ties, and points scored. Updated after each scoring period. Used for playoff qualification determination.' ;
    rdfs:domain ind:FantasyTeam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:teamAbbreviation rdf:type rdf:Property ;
    rdfs:label 'Team Abbreviation' ;
    rdfs:comment 'Short alphanumeric code (2–6 characters) representing the team in compact displays such as scoreboards, mobile notifications, and broadcast overlays.' ;
    rdfs:domain ind:FantasyTeam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:teamName rdf:type rdf:Property ;
    rdfs:label 'Team Name' ;
    rdfs:comment 'User-defined display name for the fantasy team as shown in league standings, leaderboards, and fan engagement platforms. Subject to content moderation policies.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:teamSlogan rdf:type rdf:Property ;
    rdfs:label 'Team Slogan' ;
    rdfs:comment 'Optional user-defined tagline or motto for the fantasy team. Displayed on team profile pages and league communications. Subject to content moderation policies.' ;
    rdfs:domain ind:FantasyTeam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:teamStatus rdf:type rdf:Property ;
    rdfs:label 'Team Status' ;
    rdfs:comment 'Current lifecycle status of the fantasy team within its league. \'active\' indicates the team is in good standing and participating; \'suspended\' indicates a responsible gaming or compliance hold; \'withdrawn\' indicates the owner has exited the league.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradeBlockStatus rdf:type rdf:Property ;
    rdfs:label 'Trade Block Status' ;
    rdfs:comment 'Indicates whether the team owner has flagged this team\'s athletes as available for trade negotiations. True signals that the owner is actively seeking trade offers, enabling targeted trade proposals from other managers.' ;
    rdfs:domain ind:FantasyTeam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tradesAccepted rdf:type rdf:Property ;
    rdfs:label 'Trades Accepted' ;
    rdfs:comment 'Total number of trade transactions accepted by this team in the current season. Used for trade activity monitoring and collusion detection under responsible gaming compliance.' ;
    rdfs:domain ind:FantasyTeam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tradesVetoed rdf:type rdf:Property ;
    rdfs:label 'Trades Vetoed' ;
    rdfs:comment 'Total number of trade proposals involving this team that were vetoed by the league commissioner or league vote. Supports collusion investigation and league integrity monitoring.' ;
    rdfs:domain ind:FantasyTeam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:waiverClaimsUsed rdf:type rdf:Property ;
    rdfs:label 'Waiver Claims Used' ;
    rdfs:comment 'Total number of waiver wire claims exercised by this team in the current season. Used to enforce per-season claim limits where applicable under league rules.' ;
    rdfs:domain ind:FantasyTeam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:waiverPriority rdf:type rdf:Property ;
    rdfs:label 'Waiver Priority' ;
    rdfs:comment 'The team\'s current priority position in the waiver wire queue. Lower numbers indicate higher priority for claiming available athletes. Resets or adjusts based on league waiver rules after each claim.' ;
    rdfs:domain ind:FantasyTeam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:walletId rdf:type rdf:Property ;
    rdfs:label 'Wallet Id' ;
    rdfs:comment 'Unique surrogate identifier for the gaming wallet ledger record. Primary key for this entity.' ;
    rdfs:domain ind:Wallet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:consolidatedFromWalletId rdf:type rdf:Property ;
    rdfs:label 'Consolidated From Wallet Id' ;
    rdfs:comment 'Self-referencing FK on wallet (consolidated_from_wallet_id)' ;
    rdfs:domain ind:Wallet ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Wallet .

ind:amlRiskRating rdf:type rdf:Property ;
    rdfs:label 'Aml Risk Rating' ;
    rdfs:comment 'Anti-Money Laundering (AML) risk classification assigned to this wallet based on transaction patterns, deposit sources, and bettor profile. Drives enhanced due diligence (EDD) requirements and regulatory reporting thresholds.' ;
    rdfs:domain ind:Wallet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bonusCreditBalance rdf:type rdf:Property ;
    rdfs:label 'Bonus Credit Balance' ;
    rdfs:comment 'Current balance of promotional bonus credits awarded to the bettor (e.g., free-bet credits, deposit match bonuses, loyalty rewards). Bonus credits are subject to wagering requirements before conversion to withdrawable funds.' ;
    rdfs:domain ind:Wallet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bonusWageringProgressAmount rdf:type rdf:Property ;
    rdfs:label 'Bonus Wagering Progress Amount' ;
    rdfs:comment 'Cumulative wagering amount applied toward satisfying the current bonus wagering requirement. When this value reaches (bonus_credit_balance × bonus_wagering_requirement_multiplier), the bonus converts to withdrawable funds.' ;
    rdfs:domain ind:Wallet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bonusWageringRequirementMultiplier rdf:type rdf:Property ;
    rdfs:label 'Bonus Wagering Requirement Multiplier' ;
    rdfs:comment 'The rollover multiplier applied to bonus credits before they can be converted to withdrawable real-money funds (e.g., 5x means the bettor must wager 5 times the bonus amount). Drives bonus liability calculations.' ;
    rdfs:domain ind:Wallet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dormancyDate rdf:type rdf:Property ;
    rdfs:label 'Dormancy Date' ;
    rdfs:comment 'Date on which the wallet was classified as dormant. Used to calculate escheatment timelines and trigger unclaimed property reporting to state authorities.' ;
    rdfs:domain ind:Wallet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dormancyFlag rdf:type rdf:Property ;
    rdfs:label 'Dormancy Flag' ;
    rdfs:comment 'Indicates whether the wallet has been classified as dormant due to inactivity beyond the operator-defined dormancy threshold (typically 12 months with no transactions). Dormant wallets may be subject to inactivity fees or unclaimed property escheatment.' ;
    rdfs:domain ind:Wallet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:geolocationComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Geolocation Compliance Flag' ;
    rdfs:comment 'Indicates whether the bettor\'s most recent session passed geolocation verification confirming they were physically located within a licensed jurisdiction at the time of wagering. True = compliant; False = geolocation check failed or bypassed.' ;
    rdfs:domain ind:Wallet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:kycVerifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Kyc Verified Flag' ;
    rdfs:comment 'Indicates whether the bettor\'s identity has been fully verified through the Know Your Customer (KYC) process. True = verified; False = pending or failed. Unverified wallets may have restricted deposit and withdrawal capabilities.' ;
    rdfs:domain ind:Wallet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastDepositTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Deposit Timestamp' ;
    rdfs:comment 'Timestamp of the most recent real-money deposit credited to this wallet. Used for dormancy analysis, responsible gaming velocity checks, and AML monitoring.' ;
    rdfs:domain ind:Wallet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lastTransactionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Transaction Timestamp' ;
    rdfs:comment 'Timestamp of the most recent financial transaction (deposit, withdrawal, wager placement, wager settlement, bonus credit) recorded against this wallet. Used for dormancy detection and responsible gaming monitoring.' ;
    rdfs:domain ind:Wallet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lastWithdrawalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Withdrawal Timestamp' ;
    rdfs:comment 'Timestamp of the most recent withdrawal processed from this wallet. Used for dormancy analysis and AML monitoring.' ;
    rdfs:domain ind:Wallet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lifetimeBonusAwardedAmount rdf:type rdf:Property ;
    rdfs:label 'Lifetime Bonus Awarded Amount' ;
    rdfs:comment 'Cumulative total of all promotional bonus credits ever awarded to this wallet. Used for marketing ROI analysis, bonus liability reporting, and responsible gaming assessments.' ;
    rdfs:domain ind:Wallet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lifetimeDepositAmount rdf:type rdf:Property ;
    rdfs:label 'Lifetime Deposit Amount' ;
    rdfs:comment 'Cumulative total of all real-money deposits made into this wallet since account creation. Used for responsible gaming monitoring, AML thresholds, and regulatory reporting.' ;
    rdfs:domain ind:Wallet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lifetimeWithdrawalAmount rdf:type rdf:Property ;
    rdfs:label 'Lifetime Withdrawal Amount' ;
    rdfs:comment 'Cumulative total of all real-money withdrawals processed from this wallet since account creation. Used for AML monitoring, tax reporting (e.g., IRS Form W-2G), and responsible gaming analytics.' ;
    rdfs:domain ind:Wallet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:operatorFreezeReason rdf:type rdf:Property ;
    rdfs:label 'Operator Freeze Reason' ;
    rdfs:comment 'Reason code for an operator-initiated wallet freeze or suspension. Required for audit trail and regulatory reporting when wallet_status is \'frozen\' or \'suspended\'. [ENUM-REF-CANDIDATE: aml_investigation|fraud_review|regulatory_order|chargeback_dispute|responsible_gaming|other — promote to reference product]' ;
    rdfs:domain ind:Wallet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pendingHoldAmount rdf:type rdf:Property ;
    rdfs:label 'Pending Hold Amount' ;
    rdfs:comment 'Total amount currently reserved (held) against the real-money balance for open/unsettled wagers. Funds are released back to real_money_balance upon wager settlement or cancellation.' ;
    rdfs:domain ind:Wallet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:preferredOddsFormat rdf:type rdf:Property ;
    rdfs:label 'Preferred Odds Format' ;
    rdfs:comment 'Bettor\'s preferred display format for betting odds on this wallet\'s associated platform. Stored at wallet level to support personalized UX across jurisdictions.' ;
    rdfs:domain ind:Wallet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:realMoneyBalance rdf:type rdf:Property ;
    rdfs:label 'Real Money Balance' ;
    rdfs:comment 'Current spendable real-money balance in the wallet denominated in currency_code. Represents deposited funds net of withdrawals, settled wager losses, and fees. Excludes bonus credits and pending holds.' ;
    rdfs:domain ind:Wallet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reservedWithdrawalAmount rdf:type rdf:Property ;
    rdfs:label 'Reserved Withdrawal Amount' ;
    rdfs:comment 'Amount currently reserved for a pending withdrawal request that has been initiated but not yet processed or cleared by the payment processor. Reduces available withdrawable_balance.' ;
    rdfs:domain ind:Wallet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:selfExclusionFlag rdf:type rdf:Property ;
    rdfs:label 'Self Exclusion Flag' ;
    rdfs:comment 'Indicates whether the bettor has voluntarily enrolled in a self-exclusion program, prohibiting all wagering activity on this wallet. True = self-excluded; False = not self-excluded. Triggers immediate wallet suspension.' ;
    rdfs:domain ind:Wallet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sessionTimeLimitMinutes rdf:type rdf:Property ;
    rdfs:label 'Session Time Limit Minutes' ;
    rdfs:comment 'Maximum continuous gaming session duration in minutes before the bettor is prompted to take a break or is automatically logged out. Responsible gaming control set by bettor or operator.' ;
    rdfs:domain ind:Wallet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:taxWithholdingFlag rdf:type rdf:Property ;
    rdfs:label 'Tax Withholding Flag' ;
    rdfs:comment 'Indicates whether federal or state tax withholding is currently applied to winnings paid out from this wallet (e.g., IRS backup withholding for bettors who have not provided a valid TIN). True = withholding active.' ;
    rdfs:domain ind:Wallet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:walletStatus rdf:type rdf:Property ;
    rdfs:label 'Wallet Status' ;
    rdfs:comment 'Current operational lifecycle state of the gaming wallet. \'active\' = fully operational; \'suspended\' = temporarily restricted by operator or regulator; \'frozen\' = locked pending investigation or AML review; \'closed\' = permanently deactivated; \'pending_verification\' = KYC/AML checks incomplete.' ;
    rdfs:domain ind:Wallet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:walletType rdf:type rdf:Property ;
    rdfs:label 'Wallet Type' ;
    rdfs:comment 'Classification of the wallet by gaming product line. Determines which bet types, markets, and regulatory rules apply. [ENUM-REF-CANDIDATE: sports_wagering|fantasy_sports|casino|poker|combined — promote to reference product if additional types emerge]' ;
    rdfs:domain ind:Wallet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:withdrawableBalance rdf:type rdf:Property ;
    rdfs:label 'Withdrawable Balance' ;
    rdfs:comment 'Portion of the real-money balance that has met all wagering requirements and regulatory hold periods and is eligible for withdrawal to the bettor\'s registered payment method. May be less than or equal to real_money_balance.' ;
    rdfs:domain ind:Wallet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:parentJurisdictionId rdf:type rdf:Property ;
    rdfs:label 'Parent Jurisdiction Id' ;
    rdfs:comment 'Self-referencing FK on jurisdiction (parent_jurisdiction_id)' ;
    rdfs:domain ind:Jurisdiction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Jurisdiction .

ind:amlReportingThreshold rdf:type rdf:Property ;
    rdfs:label 'Aml Reporting Threshold' ;
    rdfs:comment 'Monetary threshold (in jurisdiction currency) above which a single wagering transaction or cumulative patron activity must be reported to the regulatory authority under Anti-Money Laundering (AML) requirements (e.g., USD 10,000 per FinCEN CTR rules). Null if no statutory threshold applies.' ;
    rdfs:domain ind:Jurisdiction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:applicationSubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Application Submission Date' ;
    rdfs:comment 'Date on which Sports Entertainment submitted the initial or renewal license application to the regulatory authority. Used to track application pipeline and regulatory processing timelines.' ;
    rdfs:domain ind:Jurisdiction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:collegeSportsWageringPermitted rdf:type rdf:Property ;
    rdfs:label 'College Sports Wagering Permitted' ;
    rdfs:comment 'Indicates whether wagering on college and university sporting events is permitted in this jurisdiction. Several jurisdictions prohibit wagering on in-state college teams or all college sports. True = college sports wagering authorized; False = prohibited.' ;
    rdfs:domain ind:Jurisdiction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dataLocalizationRequired rdf:type rdf:Property ;
    rdfs:label 'Data Localization Required' ;
    rdfs:comment 'Indicates whether the jurisdiction mandates that patron data and wagering transaction records must be stored within the geographic boundaries of the jurisdiction. True = data must remain in-jurisdiction; False = no localization requirement. Impacts cloud infrastructure and data residency architecture.' ;
    rdfs:domain ind:Jurisdiction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:depositLimitRequired rdf:type rdf:Property ;
    rdfs:label 'Deposit Limit Required' ;
    rdfs:comment 'Indicates whether the jurisdiction mandates that operators offer or enforce patron deposit limits as part of responsible gaming compliance. True = deposit limits are a regulatory requirement; False = not mandated.' ;
    rdfs:domain ind:Jurisdiction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dfsPermitted rdf:type rdf:Property ;
    rdfs:label 'Dfs Permitted' ;
    rdfs:comment 'Indicates whether Daily Fantasy Sports (DFS) contests are legally permitted in this jurisdiction. True = DFS authorized; False = not authorized. Drives DFS product availability and platform configuration.' ;
    rdfs:domain ind:Jurisdiction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:geolocationRequired rdf:type rdf:Property ;
    rdfs:label 'Geolocation Required' ;
    rdfs:comment 'Indicates whether real-time geolocation verification is required to confirm the patron is physically located within the jurisdiction at the time of wagering. True = geolocation check mandatory; False = not required.' ;
    rdfs:domain ind:Jurisdiction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ggrTaxRate rdf:type rdf:Property ;
    rdfs:label 'Ggr Tax Rate' ;
    rdfs:comment 'Statutory tax rate applied to Gross Gaming Revenue (GGR) in this jurisdiction, expressed as a decimal percentage (e.g., 0.1300 = 13%). GGR is defined as total wagers accepted minus winnings paid to players. Used in financial planning, P&L modeling, and tax remittance calculations.' ;
    rdfs:domain ind:Jurisdiction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inPlayWageringPermitted rdf:type rdf:Property ;
    rdfs:label 'In Play Wagering Permitted' ;
    rdfs:comment 'Indicates whether in-play (live) wagering on ongoing sporting events is permitted in this jurisdiction. Some jurisdictions restrict wagering to pre-game markets only. True = in-play wagering authorized; False = pre-game only.' ;
    rdfs:domain ind:Jurisdiction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:integrityFeeRate rdf:type rdf:Property ;
    rdfs:label 'Integrity Fee Rate' ;
    rdfs:comment 'Rate (expressed as a decimal percentage of handle or GGR) payable to sports leagues or governing bodies as a sports integrity fee or data royalty mandated by the jurisdiction (e.g., 0.0025 = 0.25%). Null if no integrity fee is required. Relevant for NFL, NBA, MLB, NHL, MLS league data agreements.' ;
    rdfs:domain ind:Jurisdiction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:jurisdictionName rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Name' ;
    rdfs:comment 'Full legal name of the gaming regulatory jurisdiction (e.g., State of New Jersey, Province of Ontario, United Kingdom). Used in regulatory filings, compliance reports, and operator-facing documentation.' ;
    rdfs:domain ind:Jurisdiction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:kycRequired rdf:type rdf:Property ;
    rdfs:label 'Kyc Required' ;
    rdfs:comment 'Indicates whether Know Your Customer (KYC) identity verification is mandated by the regulatory authority before a patron may place wagers in this jurisdiction. True = KYC mandatory; False = KYC not required.' ;
    rdfs:domain ind:Jurisdiction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maxSingleWagerLimit rdf:type rdf:Property ;
    rdfs:label 'Max Single Wager Limit' ;
    rdfs:comment 'Maximum monetary amount (in jurisdiction currency) permitted for a single wager as mandated by the regulatory authority. Null if no statutory cap exists. Used to configure wagering platform risk controls and patron-facing bet limits.' ;
    rdfs:domain ind:Jurisdiction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minAgeRequirement rdf:type rdf:Property ;
    rdfs:label 'Min Age Requirement' ;
    rdfs:comment 'Minimum legal age (in years) required for a patron to participate in sports wagering or fantasy sports in this jurisdiction (e.g., 18 or 21). Enforced at account registration and KYC verification.' ;
    rdfs:domain ind:Jurisdiction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:officialDataMandate rdf:type rdf:Property ;
    rdfs:label 'Official Data Mandate' ;
    rdfs:comment 'Indicates whether the jurisdiction requires operators to use official league-supplied data feeds for in-play wagering markets (as opposed to third-party data providers). True = official data required; False = no mandate. Impacts data vendor contracts and API integration requirements.' ;
    rdfs:domain ind:Jurisdiction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:onlineWageringPermitted rdf:type rdf:Property ;
    rdfs:label 'Online Wagering Permitted' ;
    rdfs:comment 'Indicates whether online and mobile sports wagering is permitted in this jurisdiction, as distinct from retail (in-person) wagering. True = online/mobile wagering authorized; False = retail only.' ;
    rdfs:domain ind:Jurisdiction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:promotionalDeductionAllowed rdf:type rdf:Property ;
    rdfs:label 'Promotional Deduction Allowed' ;
    rdfs:comment 'Indicates whether the jurisdiction permits deduction of promotional credits and free-play bonuses from gross gaming revenue before calculating the taxable GGR base. True = deductions permitted; False = gross revenue taxed without promotional deductions.' ;
    rdfs:domain ind:Jurisdiction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:propBetPermitted rdf:type rdf:Property ;
    rdfs:label 'Prop Bet Permitted' ;
    rdfs:comment 'Indicates whether proposition bets (prop bets) on individual player or game-specific outcomes are permitted in this jurisdiction. Some jurisdictions restrict prop bets on college athletes or specific leagues. True = prop bets authorized; False = restricted.' ;
    rdfs:domain ind:Jurisdiction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regionOrState rdf:type rdf:Property ;
    rdfs:label 'Region Or State' ;
    rdfs:comment 'Name of the sub-national administrative region, state, or province within the country (e.g., New Jersey, Nevada, Ontario, England). Null for country-level jurisdictions. Supports state-level regulatory mapping.' ;
    rdfs:domain ind:Jurisdiction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingFrequency rdf:type rdf:Property ;
    rdfs:label 'Reporting Frequency' ;
    rdfs:comment 'Frequency at which Sports Entertainment must submit regulatory compliance and financial reports to the governing authority in this jurisdiction. Drives automated report generation scheduling.' ;
    rdfs:domain ind:Jurisdiction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsibleGamingMandates rdf:type rdf:Property ;
    rdfs:label 'Responsible Gaming Mandates' ;
    rdfs:comment 'Free-text description of applicable responsible gaming compliance mandates imposed by the regulatory authority in this jurisdiction, including deposit limits, loss limits, session time limits, cooling-off periods, and problem gambling helpline display requirements.' ;
    rdfs:domain ind:Jurisdiction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retailWageringPermitted rdf:type rdf:Property ;
    rdfs:label 'Retail Wagering Permitted' ;
    rdfs:comment 'Indicates whether retail in-person sports wagering at licensed physical locations (e.g., sportsbooks at venues or casinos) is permitted in this jurisdiction. True = retail wagering authorized; False = not authorized.' ;
    rdfs:domain ind:Jurisdiction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:selfExclusionProgramName rdf:type rdf:Property ;
    rdfs:label 'Self Exclusion Program Name' ;
    rdfs:comment 'Name of the mandatory responsible gaming self-exclusion program administered by the regulatory authority in this jurisdiction (e.g., New Jersey Self-Exclusion Program, GamStop UK). Operators must integrate with this program as a condition of licensure.' ;
    rdfs:domain ind:Jurisdiction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sportsWageringPermitted rdf:type rdf:Property ;
    rdfs:label 'Sports Wagering Permitted' ;
    rdfs:comment 'Indicates whether fixed-odds sports wagering is legally permitted in this jurisdiction under the current license. True = sports wagering authorized; False = not authorized. Drives product availability configuration.' ;
    rdfs:domain ind:Jurisdiction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:taxRemittanceFrequency rdf:type rdf:Property ;
    rdfs:label 'Tax Remittance Frequency' ;
    rdfs:comment 'Frequency at which GGR tax payments must be remitted to the regulatory authority in this jurisdiction. Drives accounts payable scheduling and cash flow planning in SAP S/4HANA FI/CO.' ;
    rdfs:domain ind:Jurisdiction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsibleGamingLimitId rdf:type rdf:Property ;
    rdfs:label 'Responsible Gaming Limit Id' ;
    rdfs:comment 'Unique surrogate identifier for each responsible gaming limit record configured for a bettor account. Primary key for the responsible_gaming_limit data product in the Silver Layer lakehouse.' ;
    rdfs:domain ind:ResponsibleGamingLimit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primarySupersededByLimitResponsibleGamingLimitId rdf:type rdf:Property ;
    rdfs:label 'Primary Superseded By Limit Responsible Gaming Limit Id' ;
    rdfs:comment 'Self-referencing identifier pointing to the newer responsible_gaming_limit record that replaced this one when a limit was modified or updated. Null if this is the current active limit. Enables full limit history chain reconstruction for regulatory audit.' ;
    rdfs:domain ind:ResponsibleGamingLimit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ResponsibleGamingLimit .

ind:activatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Activated Timestamp' ;
    rdfs:comment 'The exact date and time when this responsible gaming limit transitioned to active status and began enforcement. May differ from requested_timestamp due to mandatory regulatory cooling-off periods before limit reductions take effect.' ;
    rdfs:domain ind:ResponsibleGamingLimit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:coolingOffEndDate rdf:type rdf:Property ;
    rdfs:label 'Cooling Off End Date' ;
    rdfs:comment 'The date on which a mandatory regulatory cooling-off period ends, after which a limit increase or self-exclusion reversal may take effect. Null for limit decreases and new limits that take effect immediately.' ;
    rdfs:domain ind:ResponsibleGamingLimit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:interactionChannel rdf:type rdf:Property ;
    rdfs:label 'Interaction Channel' ;
    rdfs:comment 'The platform or interface through which the bettor or operator submitted the responsible gaming limit request. Supports omnichannel analytics and regulatory channel-specific reporting requirements.' ;
    rdfs:domain ind:ResponsibleGamingLimit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isPermanent rdf:type rdf:Property ;
    rdfs:label 'Is Permanent' ;
    rdfs:comment 'Indicates whether this responsible gaming limit is designated as permanent with no expiry date. True for lifetime self-exclusions and permanent bans. False for time-bound limits. Drives expiry_date nullability logic and regulatory reporting classification.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:limitAmount rdf:type rdf:Property ;
    rdfs:label 'Limit Amount' ;
    rdfs:comment 'The monetary ceiling or numeric threshold set by the limit. For deposit, loss, and wager limit types this is a currency amount. For session_time limits this field is null and limit_duration_minutes is used instead. For self_exclusion and cooling_off this field is null.' ;
    rdfs:domain ind:ResponsibleGamingLimit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:limitChangeDirection rdf:type rdf:Property ;
    rdfs:label 'Limit Change Direction' ;
    rdfs:comment 'Indicates whether this limit record represents an increase, decrease, new establishment, or reinstatement of a previously revoked limit. Regulators typically require immediate enforcement of limit decreases but allow a cooling-off period before increases take effect.' ;
    rdfs:domain ind:ResponsibleGamingLimit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:limitDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Limit Duration Minutes' ;
    rdfs:comment 'Duration in minutes applicable to time-based limit types such as session_time, cooling_off, and self_exclusion. For monetary limit types (deposit, loss, wager) this field is null.' ;
    rdfs:domain ind:ResponsibleGamingLimit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:limitPeriod rdf:type rdf:Property ;
    rdfs:label 'Limit Period' ;
    rdfs:comment 'The rolling or fixed time window over which the limit amount or duration is measured and enforced. For example, a daily deposit limit resets every 24 hours, while a lifetime self-exclusion has no reset.' ;
    rdfs:domain ind:ResponsibleGamingLimit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:limitReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Limit Reference Number' ;
    rdfs:comment 'Externally-known alphanumeric reference code assigned to this responsible gaming limit record, used for regulatory reporting, audit trails, and customer-facing communications.' ;
    rdfs:domain ind:ResponsibleGamingLimit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:limitSource rdf:type rdf:Property ;
    rdfs:label 'Limit Source' ;
    rdfs:comment 'Identifies the originating party that established this responsible gaming limit. Player_initiated means the bettor voluntarily set the limit. Operator_imposed means the gaming operator applied the limit based on internal responsible gaming policies. Regulator_mandated means the applicable gaming regulatory authority required the limit.' ;
    rdfs:domain ind:ResponsibleGamingLimit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:limitStatus rdf:type rdf:Property ;
    rdfs:label 'Limit Status' ;
    rdfs:comment 'Current lifecycle state of the responsible gaming limit. Pending indicates the limit has been requested but not yet enforced (e.g., awaiting cooling-off period before reduction takes effect). Active means the limit is currently enforced. Suspended means temporarily paused by operator or regulator. Revoked means cancelled. Expired means the limit reached its end date.' ;
    rdfs:domain ind:ResponsibleGamingLimit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:limitType rdf:type rdf:Property ;
    rdfs:label 'Limit Type' ;
    rdfs:comment 'Classification of the responsible gaming control applied to the bettor account. Defines the nature of the restriction: deposit limits cap funds added, loss limits cap net losses, wager limits cap individual bet amounts, session_time limits cap continuous play duration, cooling_off imposes a temporary break, and self_exclusion is a voluntary or mandated ban from wagering activity.' ;
    rdfs:domain ind:ResponsibleGamingLimit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatorNotes rdf:type rdf:Property ;
    rdfs:label 'Operator Notes' ;
    rdfs:comment 'Free-text field for operator-entered notes or justification related to this responsible gaming limit, particularly for operator_imposed or regulator_mandated limits. Used for internal case management and regulatory audit documentation.' ;
    rdfs:domain ind:ResponsibleGamingLimit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:playerAcknowledgementFlag rdf:type rdf:Property ;
    rdfs:label 'Player Acknowledgement Flag' ;
    rdfs:comment 'Indicates whether the bettor has explicitly acknowledged and confirmed the responsible gaming limit through the platform interface. True means the player confirmed; False means acknowledgement is pending. Required for audit and GDPR consent documentation.' ;
    rdfs:domain ind:ResponsibleGamingLimit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:playerAcknowledgementTimestamp rdf:type rdf:Property ;
    rdfs:label 'Player Acknowledgement Timestamp' ;
    rdfs:comment 'The date and time when the bettor explicitly acknowledged and confirmed the responsible gaming limit. Null if player_acknowledgement_flag is False. Critical for GDPR consent audit trails.' ;
    rdfs:domain ind:ResponsibleGamingLimit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:previousLimitAmount rdf:type rdf:Property ;
    rdfs:label 'Previous Limit Amount' ;
    rdfs:comment 'The monetary limit amount that was in effect immediately before the current limit was set. Enables regulators and auditors to assess whether a limit change represents an increase or decrease, which has different cooling-off period implications.' ;
    rdfs:domain ind:ResponsibleGamingLimit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatoryNotificationSent rdf:type rdf:Property ;
    rdfs:label 'Regulatory Notification Sent' ;
    rdfs:comment 'Indicates whether the required regulatory notification for this limit event has been transmitted to the applicable gaming authority. True means notification has been sent; False means notification is pending or not yet required.' ;
    rdfs:domain ind:ResponsibleGamingLimit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryNotificationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Regulatory Notification Timestamp' ;
    rdfs:comment 'The date and time when the regulatory notification for this responsible gaming limit event was transmitted to the applicable gaming authority. Null if regulatory_notification_sent is False.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:reviewDate rdf:type rdf:Property ;
    rdfs:label 'Review Date' ;
    rdfs:comment 'The scheduled date on which this responsible gaming limit is due for review by the operator\'s responsible gaming team. Applicable primarily to operator_imposed and regulator_mandated limits to ensure ongoing appropriateness.' ;
    rdfs:domain ind:ResponsibleGamingLimit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:revocationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Revocation Timestamp' ;
    rdfs:comment 'The date and time when this responsible gaming limit was revoked or cancelled. Null for limits that are active, pending, or expired. Supports regulatory reporting on limit lifecycle events.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:riskTriggerCode rdf:type rdf:Property ;
    rdfs:label 'Risk Trigger Code' ;
    rdfs:comment 'Coded identifier of the responsible gaming risk indicator or algorithm trigger that prompted an operator_imposed or regulator_mandated limit. Examples include spend velocity alerts, session duration thresholds, or self-reported problem gambling indicators. Null for player_initiated limits. [ENUM-REF-CANDIDATE: spend_velocity|session_duration|self_reported|third_party_referral|regulatory_directive|behavioral_pattern — promote to reference product]' ;
    rdfs:domain ind:ResponsibleGamingLimit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:selfExclusionProgram rdf:type rdf:Property ;
    rdfs:label 'Self Exclusion Program' ;
    rdfs:comment 'Identifies the self-exclusion program under which a self_exclusion limit type was registered. Voluntary is operator-level, national_registry and state_registry refer to government-administered exclusion databases, and operator_program refers to multi-operator industry programs.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:selfExclusionId rdf:type rdf:Property ;
    rdfs:label 'Self Exclusion Id' ;
    rdfs:comment 'Unique surrogate identifier for each self-exclusion record in the gaming platform. Primary key for the self_exclusion data product.' ;
    rdfs:domain ind:SelfExclusion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:renewedSelfExclusionId rdf:type rdf:Property ;
    rdfs:label 'Renewed Self Exclusion Id' ;
    rdfs:comment 'Self-referencing FK on self_exclusion (renewed_self_exclusion_id)' ;
    rdfs:domain ind:SelfExclusion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SelfExclusion .

ind:accountSuspensionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Account Suspension Timestamp' ;
    rdfs:comment 'The precise date and time at which the bettor\'s account was technically suspended in the gaming platform following the exclusion election. May differ from exclusion_election_timestamp due to processing lag.' ;
    rdfs:domain ind:SelfExclusion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:acknowledgmentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Acknowledgment Timestamp' ;
    rdfs:comment 'The precise date and time at which the bettor provided formal acknowledgment of the exclusion terms. Provides an audit trail for consent management and regulatory compliance.' ;
    rdfs:domain ind:SelfExclusion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:balanceDispositionStatus rdf:type rdf:Property ;
    rdfs:label 'Balance Disposition Status' ;
    rdfs:comment 'Tracks the status of the pending account balance at time of exclusion. Pending indicates funds not yet processed; refunded indicates funds returned to bettor; forfeited indicates funds surrendered per regulatory rule; held_regulatory indicates funds held pending regulatory instruction; transferred indicates funds moved to a responsible gaming fund.' ;
    rdfs:domain ind:SelfExclusion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bonusClawbackFlag rdf:type rdf:Property ;
    rdfs:label 'Bonus Clawback Flag' ;
    rdfs:comment 'Indicates whether outstanding bonus balances or promotional credits on the bettor\'s account were clawed back (forfeited) at the time of exclusion, per operator terms and conditions.' ;
    rdfs:domain ind:SelfExclusion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:counselingCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Counseling Completion Date' ;
    rdfs:comment 'The date on which the bettor completed the required responsible gaming counseling or assessment program. Null if counseling is not required or not yet completed.' ;
    rdfs:domain ind:SelfExclusion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:electionChannel rdf:type rdf:Property ;
    rdfs:label 'Election Channel' ;
    rdfs:comment 'The channel through which the exclusion was initiated or submitted. Online indicates self-service via web or mobile app; in_person indicates submission at a physical venue or gaming facility; phone indicates call center submission; mail indicates written submission; regulatory_portal indicates submission via a state gaming authority portal; third_party indicates submission by a guardian or legal representative.' ;
    rdfs:domain ind:SelfExclusion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exclusionAcknowledgmentFlag rdf:type rdf:Property ;
    rdfs:label 'Exclusion Acknowledgment Flag' ;
    rdfs:comment 'Indicates whether the bettor formally acknowledged the terms and consequences of the self-exclusion (e.g., via digital signature, checkbox confirmation, or in-person signature). Required for voluntary self-exclusions to establish informed consent.' ;
    rdfs:domain ind:SelfExclusion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:exclusionDurationMonths rdf:type rdf:Property ;
    rdfs:label 'Exclusion Duration Months' ;
    rdfs:comment 'The elected or imposed duration of the exclusion in whole months, as selected at the time of enrollment. Common regulatory options include 6, 12, 24, 60 months, or lifetime. Null for permanent exclusions.' ;
    rdfs:domain ind:SelfExclusion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:exclusionElectionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Exclusion Election Timestamp' ;
    rdfs:comment 'The precise date and time at which the exclusion was formally elected or imposed, representing the principal real-world business event time. Used for regulatory audit trails and compliance reporting.' ;
    rdfs:domain ind:SelfExclusion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:exclusionEndDate rdf:type rdf:Property ;
    rdfs:label 'Exclusion End Date' ;
    rdfs:comment 'The calendar date on which the exclusion period is scheduled to expire. Null if the exclusion is permanent. Must be evaluated in conjunction with is_permanent flag.' ;
    rdfs:domain ind:SelfExclusion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:exclusionReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Exclusion Reference Number' ;
    rdfs:comment 'Externally-known alphanumeric reference number assigned to this exclusion record, used for regulatory reporting, correspondence with the bettor, and cross-platform reconciliation. Format: SE-{JURISDICTION}-{SEQUENCE}.' ;
    rdfs:domain ind:SelfExclusion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exclusionScope rdf:type rdf:Property ;
    rdfs:label 'Exclusion Scope' ;
    rdfs:comment 'Defines the breadth of the exclusion: single_platform restricts the bettor from one specific gaming platform; all_platforms restricts across all operator-owned platforms; statewide applies to all licensed operators in a jurisdiction; nationwide applies across all US jurisdictions; global applies internationally.' ;
    rdfs:domain ind:SelfExclusion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exclusionStartDate rdf:type rdf:Property ;
    rdfs:label 'Exclusion Start Date' ;
    rdfs:comment 'The calendar date on which the exclusion becomes effective and the bettor\'s account is suspended from all gaming activities within the defined scope.' ;
    rdfs:domain ind:SelfExclusion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:exclusionStatus rdf:type rdf:Property ;
    rdfs:label 'Exclusion Status' ;
    rdfs:comment 'Current lifecycle state of the self-exclusion record. Active indicates the exclusion is in force; expired indicates the exclusion period has lapsed without reinstatement; reinstated indicates the bettor has been approved to resume gaming; pending_review indicates a reinstatement request is under evaluation; revoked indicates the exclusion was cancelled by regulatory authority.' ;
    rdfs:domain ind:SelfExclusion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exclusionType rdf:type rdf:Property ;
    rdfs:label 'Exclusion Type' ;
    rdfs:comment 'Categorical classification of the exclusion\'s origin. Voluntary self-exclusion is bettor-initiated; operator exclusion is imposed by the platform; state-mandated exclusion is driven by a state gaming authority or NCPG list; court-ordered exclusion is legally mandated; guardian exclusion is filed on behalf of a minor or incapacitated person. [ENUM-REF-CANDIDATE: voluntary_self_exclusion|operator_exclusion|state_mandated_exclusion|ncpg_exclusion|court_ordered_exclusion|guardian_exclusion — promote to reference product]' ;
    rdfs:domain ind:SelfExclusion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalExclusionListCode rdf:type rdf:Property ;
    rdfs:label 'External Exclusion List Code' ;
    rdfs:comment 'The identifier assigned to this bettor by an external exclusion registry such as the NCPG national list or a state gaming authority exclusion database. Used for cross-referencing and deduplication against external lists.' ;
    rdfs:domain ind:SelfExclusion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initiatedBy rdf:type rdf:Property ;
    rdfs:label 'Initiated By' ;
    rdfs:comment 'Identifies the party that initiated the exclusion action. Bettor indicates voluntary self-exclusion; operator indicates platform-imposed exclusion; state_authority indicates a state gaming commission mandate; court indicates a judicial order; guardian indicates a legal guardian acting on behalf of the bettor; ncpg indicates the National Council on Problem Gambling list submission.' ;
    rdfs:domain ind:SelfExclusion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketingSuppressionFlag rdf:type rdf:Property ;
    rdfs:label 'Marketing Suppression Flag' ;
    rdfs:comment 'Indicates whether the bettor\'s account has been suppressed from all marketing communications (email, SMS, push notifications, direct mail) as required during the exclusion period. Must be True for all active exclusions per responsible gaming regulations.' ;
    rdfs:domain ind:SelfExclusion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ncpgListMatchFlag rdf:type rdf:Property ;
    rdfs:label 'Ncpg List Match Flag' ;
    rdfs:comment 'Indicates whether this bettor\'s account was matched against the National Council on Problem Gambling (NCPG) national self-exclusion list during onboarding or periodic screening. True indicates a confirmed match requiring mandatory exclusion.' ;
    rdfs:domain ind:SelfExclusion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:openWagerCount rdf:type rdf:Property ;
    rdfs:label 'Open Wager Count' ;
    rdfs:comment 'The number of open or unsettled wagers on the bettor\'s account at the time the exclusion was applied. Used to manage wager settlement obligations and regulatory reporting.' ;
    rdfs:domain ind:SelfExclusion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:openWagerDisposition rdf:type rdf:Property ;
    rdfs:label 'Open Wager Disposition' ;
    rdfs:comment 'Defines how open wagers are handled upon exclusion activation. void_all cancels all open bets and refunds stakes; settle_then_suspend allows existing bets to settle before account suspension; held_pending holds wagers for regulatory review; regulatory_directed follows specific authority instruction.' ;
    rdfs:domain ind:SelfExclusion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatorExclusionReason rdf:type rdf:Property ;
    rdfs:label 'Operator Exclusion Reason' ;
    rdfs:comment 'Free-text or coded reason provided by the operator when imposing an operator-initiated exclusion. Examples include suspected problem gambling behavior, bonus abuse, fraud, or regulatory directive. Null for voluntary self-exclusions.' ;
    rdfs:domain ind:SelfExclusion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pendingBalanceAmount rdf:type rdf:Property ;
    rdfs:label 'Pending Balance Amount' ;
    rdfs:comment 'The bettor\'s account balance at the time of exclusion that is pending disposition. Regulatory requirements in many jurisdictions mandate return of remaining funds to the excluded bettor. Expressed in the jurisdiction\'s base currency.' ;
    rdfs:domain ind:SelfExclusion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:platformCode rdf:type rdf:Property ;
    rdfs:label 'Platform Code' ;
    rdfs:comment 'Identifier of the specific gaming platform or product (e.g., sports wagering app, fantasy sports platform, online casino) from which the bettor is excluded. Relevant when exclusion_scope is single_platform.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryNotificationStatus rdf:type rdf:Property ;
    rdfs:label 'Regulatory Notification Status' ;
    rdfs:comment 'Tracks the status of the mandatory regulatory notification submission to the governing gaming authority. Pending indicates not yet submitted; submitted indicates sent but not confirmed; acknowledged indicates confirmed receipt by authority; failed indicates submission error requiring retry.' ;
    rdfs:domain ind:SelfExclusion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reinstatementApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Reinstatement Approval Status' ;
    rdfs:comment 'Current status of the bettor\'s reinstatement request. not_requested indicates no request has been filed; pending indicates under review; approved indicates reinstatement granted; denied indicates request rejected; withdrawn indicates bettor withdrew the request.' ;
    rdfs:domain ind:SelfExclusion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reinstatementApprovedDate rdf:type rdf:Property ;
    rdfs:label 'Reinstatement Approved Date' ;
    rdfs:comment 'The date on which the reinstatement request was formally approved by the operator and/or regulatory authority, allowing the bettor to resume gaming activities. Null if reinstatement has not been approved.' ;
    rdfs:domain ind:SelfExclusion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reinstatementCoolingOffDays rdf:type rdf:Property ;
    rdfs:label 'Reinstatement Cooling Off Days' ;
    rdfs:comment 'The mandatory cooling-off period in days that must elapse after a reinstatement request before the bettor can be reinstated. Defined by jurisdictional regulation or operator policy.' ;
    rdfs:domain ind:SelfExclusion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reinstatementRequestDate rdf:type rdf:Property ;
    rdfs:label 'Reinstatement Request Date' ;
    rdfs:comment 'The date on which the excluded bettor formally submitted a request to be reinstated to gaming activities. Null if no reinstatement has been requested. Triggers the reinstatement review workflow.' ;
    rdfs:domain ind:SelfExclusion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:responsibleGamingCounselingRequired rdf:type rdf:Property ;
    rdfs:label 'Responsible Gaming Counseling Required' ;
    rdfs:comment 'Indicates whether the bettor is required to complete a responsible gaming counseling or assessment program as a condition of reinstatement. Driven by operator policy or regulatory mandate.' ;
    rdfs:domain ind:SelfExclusion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:stateExclusionListMatchFlag rdf:type rdf:Property ;
    rdfs:label 'State Exclusion List Match Flag' ;
    rdfs:comment 'Indicates whether this bettor was identified via a state-level exclusion list (distinct from NCPG national list). True indicates the exclusion was triggered by a state gaming authority\'s exclusion registry match.' ;
    rdfs:domain ind:SelfExclusion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:amendedRegulatoryReportId rdf:type rdf:Property ;
    rdfs:label 'Amended Regulatory Report Id' ;
    rdfs:comment 'Self-referencing FK on regulatory_report (amended_regulatory_report_id)' ;
    rdfs:domain ind:RegulatoryReport ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RegulatoryReport .

ind:acknowledgementTimestamp rdf:type rdf:Property ;
    rdfs:label 'Acknowledgement Timestamp' ;
    rdfs:comment 'The date and time when the regulatory authority formally acknowledged receipt of the submitted report. Distinct from submission_timestamp; marks the start of the regulatory review clock.' ;
    rdfs:domain ind:RegulatoryReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:activePlayerCount rdf:type rdf:Property ;
    rdfs:label 'Active Player Count' ;
    rdfs:comment 'Number of unique active registered players who placed at least one wager during the reporting period. Required for responsible gaming program and player activity regulatory disclosures.' ;
    rdfs:domain ind:RegulatoryReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:amlFlaggedTransactionCount rdf:type rdf:Property ;
    rdfs:label 'Aml Flagged Transaction Count' ;
    rdfs:comment 'Number of transactions flagged for potential Anti-Money Laundering (AML) activity during the reporting period and disclosed in this regulatory filing.' ;
    rdfs:domain ind:RegulatoryReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:filingDeadlineDate rdf:type rdf:Property ;
    rdfs:label 'Filing Deadline Date' ;
    rdfs:comment 'The regulatory-mandated deadline by which this report must be submitted to the governing authority. Used to monitor compliance with filing timeliness requirements and flag late submissions.' ;
    rdfs:domain ind:RegulatoryReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ggrAmount rdf:type rdf:Property ;
    rdfs:label 'Ggr Amount' ;
    rdfs:comment 'Total Gross Gaming Revenue (GGR) reported for the filing period, representing total wagers accepted minus total winnings paid out. Applicable for GGR report type filings. Expressed in the reporting currency.' ;
    rdfs:domain ind:RegulatoryReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:internalReviewNotes rdf:type rdf:Property ;
    rdfs:label 'Internal Review Notes' ;
    rdfs:comment 'Free-text field capturing internal compliance team notes, review comments, or escalation details associated with the preparation or review of this regulatory report. Not shared externally.' ;
    rdfs:domain ind:RegulatoryReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isAmended rdf:type rdf:Property ;
    rdfs:label 'Is Amended' ;
    rdfs:comment 'Indicates whether this report is an amendment to a previously submitted filing. True = amended/corrected report; False = original submission. Amended reports must reference the original report number.' ;
    rdfs:domain ind:RegulatoryReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isLateFiling rdf:type rdf:Property ;
    rdfs:label 'Is Late Filing' ;
    rdfs:comment 'Indicates whether this report was submitted after the regulatory filing deadline. True = filed late; False = filed on time. Used for compliance monitoring and penalty risk assessment.' ;
    rdfs:domain ind:RegulatoryReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:kycVerifiedPlayerCount rdf:type rdf:Property ;
    rdfs:label 'Kyc Verified Player Count' ;
    rdfs:comment 'Number of players who completed Know Your Customer (KYC) identity verification during the reporting period. Required for AML/KYC compliance filings with gaming regulators.' ;
    rdfs:domain ind:RegulatoryReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:originalReportNumber rdf:type rdf:Property ;
    rdfs:label 'Original Report Number' ;
    rdfs:comment 'The report_number of the original filing that this amended report supersedes. Populated only when is_amended = True. Enables audit trail linkage between original and amended submissions.' ;
    rdfs:domain ind:RegulatoryReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryBodyReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Regulatory Body Reference Number' ;
    rdfs:comment 'Acknowledgement or reference number assigned by the regulatory authority upon receipt or processing of the submitted report. Used for official correspondence and audit trail.' ;
    rdfs:domain ind:RegulatoryReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportFrequency rdf:type rdf:Property ;
    rdfs:label 'Report Frequency' ;
    rdfs:comment 'The required cadence at which this type of regulatory report must be submitted to the governing authority (e.g., monthly GGR reports, annual responsible gaming program reports, ad hoc SARs).' ;
    rdfs:domain ind:RegulatoryReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportNumber rdf:type rdf:Property ;
    rdfs:label 'Report Number' ;
    rdfs:comment 'Externally-known unique business identifier assigned to this report at the time of generation, used for tracking and cross-referencing with regulatory bodies (e.g., RPT-2024-NV-00123).' ;
    rdfs:domain ind:RegulatoryReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportStatus rdf:type rdf:Property ;
    rdfs:label 'Report Status' ;
    rdfs:comment 'Current lifecycle state of the regulatory report in its submission workflow. Tracks progression from internal drafting through regulatory authority acceptance or rejection.' ;
    rdfs:domain ind:RegulatoryReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportType rdf:type rdf:Property ;
    rdfs:label 'Report Type' ;
    rdfs:comment 'Classification of the regulatory report by its required filing category. GGR = Gross Gaming Revenue report; SAR = Suspicious Activity Report; self_exclusion_compliance = self-exclusion program adherence; responsible_gaming_program = responsible gaming program status; AML_KYC = Anti-Money Laundering / Know Your Customer compliance filing. [ENUM-REF-CANDIDATE: GGR|SAR|self_exclusion_compliance|responsible_gaming_program|AML_KYC|other — promote to reference product]' ;
    rdfs:domain ind:RegulatoryReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportVersion rdf:type rdf:Property ;
    rdfs:label 'Report Version' ;
    rdfs:comment 'Sequential version number of this regulatory report, incremented each time an amendment or resubmission is made. Version 1 = original filing; higher values indicate amended filings.' ;
    rdfs:domain ind:RegulatoryReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:responsibleGamingInterventionCount rdf:type rdf:Property ;
    rdfs:label 'Responsible Gaming Intervention Count' ;
    rdfs:comment 'Number of responsible gaming interventions (e.g., deposit limit alerts, cooling-off period activations, problem gambling referrals) executed during the reporting period. Required for responsible gaming program reports.' ;
    rdfs:domain ind:RegulatoryReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sarCount rdf:type rdf:Property ;
    rdfs:label 'Sar Count' ;
    rdfs:comment 'Number of individual Suspicious Activity Reports (SARs) included or referenced in this regulatory filing. Applicable for SAR batch or summary filings to FINCEN or state gaming authorities.' ;
    rdfs:domain ind:RegulatoryReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:selfExclusionBreachCount rdf:type rdf:Property ;
    rdfs:label 'Self Exclusion Breach Count' ;
    rdfs:comment 'Number of instances where a self-excluded player was identified as having accessed or attempted to access gaming services during the reporting period. Critical compliance metric for regulatory filings.' ;
    rdfs:domain ind:RegulatoryReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:selfExclusionCount rdf:type rdf:Property ;
    rdfs:label 'Self Exclusion Count' ;
    rdfs:comment 'Number of players enrolled in the self-exclusion program during the reporting period. Required for self-exclusion compliance reports submitted to gaming regulators.' ;
    rdfs:domain ind:RegulatoryReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sportCategory rdf:type rdf:Property ;
    rdfs:label 'Sport Category' ;
    rdfs:comment 'The sport or event category covered by this regulatory report (e.g., NFL, NBA, MLB, NHL, MLS, UFC, FIFA, horse racing, esports). Used for sport-specific regulatory breakdowns required by some jurisdictions.' ;
    rdfs:domain ind:RegulatoryReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalWagersAmount rdf:type rdf:Property ;
    rdfs:label 'Total Wagers Amount' ;
    rdfs:comment 'Aggregate value of all wagers accepted during the reporting period, as reported to the regulatory authority. Used as a component of GGR calculation and regulatory financial disclosure.' ;
    rdfs:domain ind:RegulatoryReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalWinningsPaidAmount rdf:type rdf:Property ;
    rdfs:label 'Total Winnings Paid Amount' ;
    rdfs:comment 'Aggregate value of all winnings paid out to bettors during the reporting period, as reported to the regulatory authority. Used as a component of GGR calculation.' ;
    rdfs:domain ind:RegulatoryReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:eligibleSeasonTicketPackageId rdf:type rdf:Property ;
    rdfs:label 'Eligible Season Ticket Package Id' ;
    rdfs:comment 'Foreign key linking to ticketing.season_ticket_package. Business justification: STH-exclusive contest eligibility: sports operators run contests restricted to holders of specific season ticket packages (e.g., premium tier STH-only prediction contests). The contest must reference ' ;
    rdfs:domain ind:Contest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SeasonTicketPackage .

ind:featuredCollectionId rdf:type rdf:Property ;
    rdfs:label 'Featured Collection Id' ;
    rdfs:comment 'Foreign key linking to content.collection. Business justification: DFS and bracket contests feature curated content collections (player highlight reels, slate previews) on contest lobby pages. Contest operations teams link a content collection to each contest for fan' ;
    rdfs:domain ind:Contest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Collection .

ind:prizeSkuCatalogId rdf:type rdf:Property ;
    rdfs:label 'Prize Sku Catalog Id' ;
    rdfs:comment 'Foreign key linking to merchandise.sku_catalog. Business justification: Gaming contest merchandise prize fulfillment: DFS and gaming contests award merchandise SKUs as prizes. Operations require linking the contest to the specific merchandise SKU for prize inventory reser' ;
    rdfs:domain ind:Contest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SkuCatalog .

ind:prizeTicketInventoryId rdf:type rdf:Property ;
    rdfs:label 'Prize Ticket Inventory Id' ;
    rdfs:comment 'Foreign key linking to ticketing.ticket_inventory. Business justification: Contest prize ticket allocation: sports entertainment operators configure contests where the prize pool includes specific ticket inventory (e.g., playoff seats). The contest must reference the allocat' ;
    rdfs:domain ind:Contest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TicketInventory .

ind:promotionalAssetId rdf:type rdf:Property ;
    rdfs:label 'Promotional Asset Id' ;
    rdfs:comment 'Foreign key linking to content.asset. Business justification: DFS contest display operations: each contest references a specific promotional content asset (banner image, preview video) for rendering on platform pages. Role prefix \'promotional_\' distinguishes fro' ;
    rdfs:domain ind:Contest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Asset .

ind:qualifierContestId rdf:type rdf:Property ;
    rdfs:label 'Qualifier Contest Id' ;
    rdfs:comment 'Self-referencing FK on contest (qualifier_contest_id)' ;
    rdfs:domain ind:Contest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Contest .

ind:ageRestrictionOverride rdf:type rdf:Property ;
    rdfs:label 'Age Restriction Override' ;
    rdfs:comment 'Jurisdiction-specific minimum age requirement that overrides the platform default for this contest in this jurisdiction. Populated only when the jurisdiction mandates a higher age threshold than the platform standard (e.g., 21 instead of 18). NULL indicates no override — platform default applies.' ;
    rdfs:domain ind:Contest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:completionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Completion Timestamp' ;
    rdfs:comment 'Date and time when all games in the slate concluded, final scores were confirmed, and the contest was officially completed. Triggers prize payout processing.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:contestName rdf:type rdf:Property ;
    rdfs:label 'Contest Name' ;
    rdfs:comment 'Human-readable display name of the contest as shown to players on the platform (e.g., \'Sunday Million GPP\', \'NFL Week 12 50/50\').' ;
    rdfs:domain ind:Contest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contestStatus rdf:type rdf:Property ;
    rdfs:label 'Contest Status' ;
    rdfs:comment 'Current lifecycle state of the contest. \'open\' accepts entries; \'locked\' is past entry deadline; \'live\' is in-progress scoring; \'completed\' is final; \'cancelled\' is voided with refunds; \'postponed\' is delayed.' ;
    rdfs:domain ind:Contest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contestType rdf:type rdf:Property ;
    rdfs:label 'Contest Type' ;
    rdfs:comment 'Classification of the contest format. GPP (Guaranteed Prize Pool) tournaments are top-heavy; 50/50 and double-up pay the top half; head-to-head is one-on-one; satellite/qualifier awards entries to larger contests. [ENUM-REF-CANDIDATE: GPP|50_50|HEAD_TO_HEAD|SATELLITE|DOUBLE_UP|QUALIFIER — promote to reference product]' ;
    rdfs:domain ind:Contest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entriesFilled rdf:type rdf:Property ;
    rdfs:label 'Entries Filled' ;
    rdfs:comment 'Current count of entries submitted to this contest at the time of last update. Used to monitor fill rate and determine overlay exposure for guaranteed prize pools.' ;
    rdfs:domain ind:Contest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isBeginnerOnly rdf:type rdf:Property ;
    rdfs:label 'Is Beginner Only' ;
    rdfs:comment 'Indicates whether this contest is restricted to new or inexperienced players. Beginner contests are a responsible gaming and player acquisition tool that limits exposure to highly experienced players.' ;
    rdfs:domain ind:Contest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isFreeToPlay rdf:type rdf:Property ;
    rdfs:label 'Is Free To Play' ;
    rdfs:comment 'Indicates whether this is a free-to-play (no entry fee) contest. Free contests may offer prizes funded by the operator for promotional or responsible gaming purposes.' ;
    rdfs:domain ind:Contest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isGuaranteed rdf:type rdf:Property ;
    rdfs:label 'Is Guaranteed' ;
    rdfs:comment 'Indicates whether the prize pool is guaranteed by the operator regardless of the number of entries received. True for GPP contests; False for non-guaranteed contests that may be cancelled if underfilled.' ;
    rdfs:domain ind:Contest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jurisdictionExclusionCodes rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Exclusion Codes' ;
    rdfs:comment 'Pipe-delimited list of jurisdiction or state codes where this contest is explicitly prohibited (e.g., \'US-WA|US-ID\'). Complements jurisdiction_codes for regulatory compliance.' ;
    rdfs:domain ind:Contest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lockTimestamp rdf:type rdf:Property ;
    rdfs:label 'Lock Timestamp' ;
    rdfs:comment 'Date and time after which no new entries or lineup edits are accepted. Typically set to the first game\'s scheduled start time. Regulatory requirement to prevent late entry based on real-world information.' ;
    rdfs:domain ind:Contest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:maxEntriesPerPlayer rdf:type rdf:Property ;
    rdfs:label 'Max Entries Per Player' ;
    rdfs:comment 'Maximum number of lineup entries a single player account may submit to this contest. Limits multi-entry advantage and supports responsible gaming controls. Typically 1 for head-to-head; higher for large GPPs.' ;
    rdfs:domain ind:Contest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minEntriesRequired rdf:type rdf:Property ;
    rdfs:label 'Min Entries Required' ;
    rdfs:comment 'Minimum number of entries required for the contest to run. If not met by lock time, the contest may be cancelled and entry fees refunded. Relevant for head-to-head and small-field contests.' ;
    rdfs:domain ind:Contest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:paidPlacesCount rdf:type rdf:Property ;
    rdfs:label 'Paid Places Count' ;
    rdfs:comment 'Number of finishing positions that receive a cash prize payout. Determines the percentage of the field that cashes. Key metric for contest attractiveness and responsible gaming disclosures.' ;
    rdfs:domain ind:Contest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:prizeReportingThreshold rdf:type rdf:Property ;
    rdfs:label 'Prize Reporting Threshold' ;
    rdfs:comment 'Jurisdiction-specific monetary threshold above which a prize payout from this contest must be reported to the regulatory authority or tax body. This value is contest-jurisdiction specific because it may vary based on contest type (DFS vs. wagering) and jurisdiction rules. Expressed in the jurisdiction\'s currency_code.' ;
    rdfs:domain ind:Contest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:prizeStructureType rdf:type rdf:Property ;
    rdfs:label 'Prize Structure Type' ;
    rdfs:comment 'Describes how prizes are distributed across finishing positions. \'top_heavy\' concentrates prizes at the top; \'flat\' pays equal amounts across a wide range; \'winner_take_all\' awards the full pool to first place; \'tiered\' uses defined payout brackets.' ;
    rdfs:domain ind:Contest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rakePercentage rdf:type rdf:Property ;
    rdfs:label 'Rake Percentage' ;
    rdfs:comment 'Operator\'s take rate expressed as a percentage of total entry fees collected. Represents the platform\'s revenue margin on the contest. Used for financial reporting and EBITDA analysis.' ;
    rdfs:domain ind:Contest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:registrationOpenTimestamp rdf:type rdf:Property ;
    rdfs:label 'Registration Open Timestamp' ;
    rdfs:comment 'Date and time when the contest becomes available for player entry registration. Defines the entry acceptance window start.' ;
    rdfs:domain ind:Contest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:regulatoryContestCode rdf:type rdf:Property ;
    rdfs:label 'Regulatory Contest Code' ;
    rdfs:comment 'Identifier assigned by the relevant state or national gaming regulatory authority for this contest. Required for regulatory reporting and audit submissions.' ;
    rdfs:domain ind:Contest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restrictionType rdf:type rdf:Property ;
    rdfs:label 'Restriction Type' ;
    rdfs:comment 'Classification of the type of restriction applied to this contest in this jurisdiction. A full_block means the contest is entirely unavailable; age_gated means players must meet a jurisdiction-specific age threshold; prize_capped means the prize pool is limited by jurisdictional rules.' ;
    rdfs:domain ind:Contest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scoringSystemCode rdf:type rdf:Property ;
    rdfs:label 'Scoring System Code' ;
    rdfs:comment 'Code identifying the fantasy scoring ruleset applied to this contest (e.g., STANDARD, PPR, HALF_PPR for NFL; CLASSIC for NBA). Determines how real-world player statistics translate to fantasy points.' ;
    rdfs:domain ind:Contest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalEntriesCap rdf:type rdf:Property ;
    rdfs:label 'Total Entries Cap' ;
    rdfs:comment 'Maximum total number of entries allowed across all players in this contest. Defines the contest capacity. When reached, the contest is closed to new entries.' ;
    rdfs:domain ind:Contest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contestEntryId rdf:type rdf:Property ;
    rdfs:label 'Contest Entry Id' ;
    rdfs:comment 'Unique surrogate identifier for each DFS contest entry record in the Silver layer. Primary key for this transactional entity.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ContestEntry .

ind:prizeAccessEntitlementId rdf:type rdf:Property ;
    rdfs:label 'Prize Access Entitlement Id' ;
    rdfs:comment 'Foreign key linking to ticketing.access_entitlement. Business justification: Contest prize fulfillment: when a gaming contest awards a game ticket as a prize, the contest_entry must reference the issued access_entitlement for prize tracking, compliance reporting, and gate-scan' ;
    rdfs:domain ind:ContestEntry ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AccessEntitlement .

ind:prizeMerchOrderId rdf:type rdf:Property ;
    rdfs:label 'Prize Merch Order Id' ;
    rdfs:comment 'Foreign key linking to merchandise.merch_order. Business justification: When a contest winner receives a physical merchandise prize, the fulfillment is processed as a merch_order. This prize fulfillment tracking link enables finance reconciliation, royalty reporting, and ' ;
    rdfs:domain ind:ContestEntry ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MerchOrder .

ind:rebuyOfContestEntryId rdf:type rdf:Property ;
    rdfs:label 'Rebuy Of Contest Entry Id' ;
    rdfs:comment 'Self-referencing FK on contest_entry (rebuy_of_contest_entry_id)' ;
    rdfs:domain ind:ContestEntry ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ContestEntry .

ind:actualPoints rdf:type rdf:Property ;
    rdfs:label 'Actual Points' ;
    rdfs:comment 'Total actual fantasy points scored by the submitted lineup after all real-world games in the slate have concluded and scores are finalized. Principal quantitative outcome for settlement and ranking.' ;
    rdfs:domain ind:ContestEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bonusAmountApplied rdf:type rdf:Property ;
    rdfs:label 'Bonus Amount Applied' ;
    rdfs:comment 'Promotional or bonus credit amount applied toward the entry fee for this contest entry. Reduces the net cash charged to the bettor. Used for promotion reconciliation and regulatory reporting.' ;
    rdfs:domain ind:ContestEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contestSlateDate rdf:type rdf:Property ;
    rdfs:label 'Contest Slate Date' ;
    rdfs:comment 'The primary game-day date of the contest slate this entry is associated with. Used for scheduling, settlement timing, and regulatory reporting period alignment.' ;
    rdfs:domain ind:ContestEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:entryNumberInContest rdf:type rdf:Property ;
    rdfs:label 'Entry Number In Contest' ;
    rdfs:comment 'Sequential entry number for this bettor within the same contest (e.g., 1 = first entry, 2 = second entry). Supports multi-entry tracking and regulatory caps on entries per bettor per contest.' ;
    rdfs:domain ind:ContestEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:entryReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Entry Reference Number' ;
    rdfs:comment 'Externally visible alphanumeric reference code assigned to this contest entry at submission time. Used for customer support, regulatory reporting, and settlement reconciliation.' ;
    rdfs:domain ind:ContestEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:finalRank rdf:type rdf:Property ;
    rdfs:label 'Final Rank' ;
    rdfs:comment 'Final standing rank of this entry within the contest after all scores are settled. Rank 1 = highest scoring entry. Determines prize eligibility and payout tier.' ;
    rdfs:domain ind:ContestEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isAutopick rdf:type rdf:Property ;
    rdfs:label 'Is Autopick' ;
    rdfs:comment 'Indicates whether the lineup for this entry was generated automatically by the platform\'s autopick algorithm rather than manually selected by the bettor. Relevant for contest integrity and bettor experience analytics.' ;
    rdfs:domain ind:ContestEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isLateSwap rdf:type rdf:Property ;
    rdfs:label 'Is Late Swap' ;
    rdfs:comment 'Indicates whether the bettor utilized a late swap to substitute an injured or scratched athlete in the lineup after the initial contest lock but before that athlete\'s game started. Applicable only in contests that permit late swaps.' ;
    rdfs:domain ind:ContestEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lineupEditCount rdf:type rdf:Property ;
    rdfs:label 'Lineup Edit Count' ;
    rdfs:comment 'Number of times the bettor modified the submitted lineup between initial entry and lineup lock. Supports contest integrity monitoring and late-swap tracking.' ;
    rdfs:domain ind:ContestEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lineupLockTimestamp rdf:type rdf:Property ;
    rdfs:label 'Lineup Lock Timestamp' ;
    rdfs:comment 'The date and time at which the submitted lineup was locked and no further edits were permitted. Marks the transition from \'active\' to \'locked\' entry status.' ;
    rdfs:domain ind:ContestEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:netEntryFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Net Entry Fee Amount' ;
    rdfs:comment 'Actual cash amount charged to the bettor after applying bonus credits (entry_fee_amount minus bonus_amount_applied). Represents the real monetary outlay for regulatory and financial reporting.' ;
    rdfs:domain ind:ContestEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:payoutStatus rdf:type rdf:Property ;
    rdfs:label 'Payout Status' ;
    rdfs:comment 'Current status of the prize payout for this entry. \'pending\' = prize calculated but not yet disbursed; \'processed\' = funds credited to bettor account; \'failed\' = disbursement error; \'withheld\' = held for tax or compliance review; \'cancelled\' = prize voided.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payoutTimestamp rdf:type rdf:Property ;
    rdfs:label 'Payout Timestamp' ;
    rdfs:comment 'Date and time when the prize payout was successfully credited to the bettor account. Null if payout has not yet been processed.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:percentileRank rdf:type rdf:Property ;
    rdfs:label 'Percentile Rank' ;
    rdfs:comment 'This entry\'s final rank expressed as a percentile within the contest field (e.g., 95.00 = top 5%). Supports bettor performance analytics and DFS platform reporting.' ;
    rdfs:domain ind:ContestEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:prizeAmount rdf:type rdf:Property ;
    rdfs:label 'Prize Amount' ;
    rdfs:comment 'Gross prize amount won by this entry based on final rank and contest prize structure. Zero if entry did not finish in a paying position. Used for prize distribution and IRS W-2G tax reporting.' ;
    rdfs:domain ind:ContestEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:prizeTier rdf:type rdf:Property ;
    rdfs:label 'Prize Tier' ;
    rdfs:comment 'Prize tier or payout band this entry qualified for based on final rank (e.g., \'1st Place\', \'Top 10\', \'Top 20%\', \'No Prize\'). Derived from the contest prize structure at settlement. [ENUM-REF-CANDIDATE: 1st_place|2nd_place|3rd_place|top_10|top_20_pct|top_50_pct|no_prize — promote to reference product]' ;
    rdfs:domain ind:ContestEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectedPoints rdf:type rdf:Property ;
    rdfs:label 'Projected Points' ;
    rdfs:comment 'Total projected fantasy points for the submitted lineup at the time of entry lock, based on pre-game statistical projections. Used for contest analytics and bettor decision support.' ;
    rdfs:domain ind:ContestEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:promotionCode rdf:type rdf:Property ;
    rdfs:label 'Promotion Code' ;
    rdfs:comment 'Promotional or referral code applied at the time of entry submission. Used for marketing attribution, bonus reconciliation, and campaign performance reporting.' ;
    rdfs:domain ind:ContestEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salaryCapUsed rdf:type rdf:Property ;
    rdfs:label 'Salary Cap Used' ;
    rdfs:comment 'Total salary cap value consumed by the submitted lineup. Must not exceed the contest\'s maximum salary cap limit. Used for lineup validation and contest integrity checks.' ;
    rdfs:domain ind:ContestEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:w2gReportable rdf:type rdf:Property ;
    rdfs:label 'W2g Reportable' ;
    rdfs:comment 'Indicates whether this contest entry\'s prize winnings meet or exceed the IRS W-2G reporting threshold, requiring issuance of a W-2G tax form to the bettor and reporting to the IRS.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:payoutId rdf:type rdf:Property ;
    rdfs:label 'Payout Id' ;
    rdfs:comment 'Unique surrogate identifier for each gaming payout disbursement record in the silver layer lakehouse.' ;
    rdfs:domain ind:Payout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reversedPayoutId rdf:type rdf:Property ;
    rdfs:label 'Reversed Payout Id' ;
    rdfs:comment 'Self-referencing FK on payout (reversed_payout_id)' ;
    rdfs:domain ind:Payout ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Payout .

ind:amlReviewFlag rdf:type rdf:Property ;
    rdfs:label 'Aml Review Flag' ;
    rdfs:comment 'Indicates whether this payout has been flagged for Anti-Money Laundering review due to threshold triggers (e.g., cash equivalent payouts exceeding $10,000 CTR threshold) or suspicious activity patterns. When true, payout may be held pending compliance review.' ;
    rdfs:domain ind:Payout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:approvalRequired rdf:type rdf:Property ;
    rdfs:label 'Approval Required' ;
    rdfs:comment 'Indicates whether this payout requires manual review and approval before disbursement, triggered by large payout thresholds, AML flags, first-time large payout rules, or operator risk controls.' ;
    rdfs:domain ind:Payout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:bonusAmountIncluded rdf:type rdf:Property ;
    rdfs:label 'Bonus Amount Included' ;
    rdfs:comment 'Portion of the gross payout amount attributable to bonus funds or promotional credits rather than real-money wagering. Used to separate real-money GGR from bonus-funded activity in regulatory reporting and financial reconciliation.' ;
    rdfs:domain ind:Payout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ctrReportable rdf:type rdf:Property ;
    rdfs:label 'Ctr Reportable' ;
    rdfs:comment 'Indicates whether this payout triggers a FinCEN Currency Transaction Report (CTR) requirement, applicable when cash-equivalent payouts to a single bettor exceed $10,000 in a single gaming day. Drives CTR filing workflow.' ;
    rdfs:domain ind:Payout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:federalWithholdingRate rdf:type rdf:Property ;
    rdfs:label 'Federal Withholding Rate' ;
    rdfs:comment 'Federal income tax withholding rate applied to this payout, expressed as a decimal (e.g., 0.2400 for 24%). Determined by IRS backup withholding rules or regular gambling withholding rates based on payout type and bettor tax status.' ;
    rdfs:domain ind:Payout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ggrPeriod rdf:type rdf:Property ;
    rdfs:label 'Ggr Period' ;
    rdfs:comment 'YYYY-MM formatted reporting period to which this payout is attributed for Gross Gaming Revenue (GGR) calculations and regulatory financial reporting. GGR = Total Wagers - Total Payouts within the period. Supports monthly regulatory submissions.' ;
    rdfs:domain ind:Payout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grossPayoutAmount rdf:type rdf:Property ;
    rdfs:label 'Gross Payout Amount' ;
    rdfs:comment 'Total payout amount before any tax withholding deductions, representing the full winning amount owed to the bettor. Used as the basis for W-2G threshold evaluation and Gross Gaming Revenue (GGR) calculations.' ;
    rdfs:domain ind:Payout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isFreeBetPayout rdf:type rdf:Property ;
    rdfs:label 'Is Free Bet Payout' ;
    rdfs:comment 'Indicates whether this payout originated from a free bet promotion where the stake was operator-funded. When true, the stake amount is excluded from the net payout per standard free bet payout rules (profit only, stake not returned). Affects GGR and bonus cost accounting.' ;
    rdfs:domain ind:Payout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:netPayoutAmount rdf:type rdf:Property ;
    rdfs:label 'Net Payout Amount' ;
    rdfs:comment 'Final amount disbursed to the bettor after deducting tax_withheld_amount from gross_payout_amount. This is the actual funds received by the bettor and the amount recorded in the payment processor instruction.' ;
    rdfs:domain ind:Payout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:oddsAtSettlement rdf:type rdf:Property ;
    rdfs:label 'Odds At Settlement' ;
    rdfs:comment 'Decimal odds value at which the winning wager was settled. Used for W-2G threshold ratio verification (300:1 requirement for sports betting) and audit trail of payout calculation basis.' ;
    rdfs:domain ind:Payout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:operatorCode rdf:type rdf:Property ;
    rdfs:label 'Operator Code' ;
    rdfs:comment 'Identifier of the licensed gaming operator or skin under whose license this payout was processed. Relevant for B2B platform operators managing multiple licensed brands or white-label operations across jurisdictions.' ;
    rdfs:domain ind:Gaming ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payoutMethod rdf:type rdf:Property ;
    rdfs:label 'Payout Method' ;
    rdfs:comment 'Disbursement channel used to deliver funds to the bettor. Wallet credit: instant credit to in-app gaming wallet; ACH: Automated Clearing House bank transfer; Check: physical check mailed to bettor; Wire transfer: bank wire for large payouts; PayPal/Venmo: third-party digital wallet. [ENUM-REF-CANDIDATE: wallet_credit|ach|check|wire_transfer|paypal|venmo|prepaid_card — promote to reference product]' ;
    rdfs:domain ind:Payout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payoutType rdf:type rdf:Property ;
    rdfs:label 'Payout Type' ;
    rdfs:comment 'Classification of the payout by its originating business event. Wager settlement covers standard sportsbook wins; DFS contest prize covers daily fantasy sports contest payouts; fantasy league prize covers season-long league prize distributions; bonus conversion covers wagering requirement completions; promotional credit covers operator-funded promotional payouts; free bet winnings covers winnings from free bet stakes. [ENUM-REF-CANDIDATE: wager_settlement|dfs_contest_prize|fantasy_league_prize|bonus_conversion|promotional_credit|free_bet_winnings — promote to reference product]' ;
    rdfs:domain ind:Payout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prizeRank rdf:type rdf:Property ;
    rdfs:label 'Prize Rank' ;
    rdfs:comment 'Finishing rank or placement position of the bettor\'s DFS contest entry or fantasy league team that determined the prize payout amount. Null for sportsbook wager payouts. Used for prize structure validation and contest result reconciliation.' ;
    rdfs:domain ind:Payout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:processorName rdf:type rdf:Property ;
    rdfs:label 'Processor Name' ;
    rdfs:comment 'Name of the third-party payment processor or banking network used to execute this payout disbursement (e.g., Worldpay, FIS, PayPal, Venmo, NACHA ACH network). Supports processor performance monitoring and reconciliation routing.' ;
    rdfs:domain ind:Payout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processorReference rdf:type rdf:Property ;
    rdfs:label 'Processor Reference' ;
    rdfs:comment 'Transaction reference number returned by the external payment processor (ACH network, wire transfer system, check issuer, or digital wallet provider) upon submission of the payout instruction. Used for payment reconciliation and dispute resolution.' ;
    rdfs:domain ind:Payout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stateWithholdingAmount rdf:type rdf:Property ;
    rdfs:label 'State Withholding Amount' ;
    rdfs:comment 'State income tax withheld from the gross payout amount per the applicable state gaming jurisdiction\'s withholding requirements. Separate from federal withholding. Zero if the jurisdiction does not require state withholding.' ;
    rdfs:domain ind:Payout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:w2gFormReference rdf:type rdf:Property ;
    rdfs:label 'W2g Form Reference' ;
    rdfs:comment 'Reference number of the IRS W-2G tax form issued to the bettor for this payout. Populated only when w2g_reportable is true. Used for tax compliance tracking, bettor tax document retrieval, and IRS filing reconciliation.' ;
    rdfs:domain ind:Payout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:credentialEventFixtureId rdf:type rdf:Property ;
    rdfs:label 'Credential Event Fixture Id' ;
    rdfs:comment 'Reference to the specific event for which this credential is valid, if the credential is event-scoped rather than season- or venue-scoped. Null for standing/permanent credentials valid across all events at a venue.' ;
    rdfs:domain ind:Credential ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Fixture .

ind:credentialFixtureId rdf:type rdf:Property ;
    rdfs:label 'Credential Fixture Id' ;
    rdfs:comment 'Reference to the specific event for which this credential is valid, if the credential is event-scoped rather than season- or venue-scoped. Null for standing/permanent credentials valid across all events at a venue.' ;
    rdfs:domain ind:Credential ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Fixture .

ind:reissuedFromCredentialId rdf:type rdf:Property ;
    rdfs:label 'Reissued From Credential Id' ;
    rdfs:comment 'Self-referencing FK on credential (reissued_from_credential_id)' ;
    rdfs:domain ind:Credential ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Credential .

ind:accessZoneList rdf:type rdf:Property ;
    rdfs:label 'Access Zone List' ;
    rdfs:comment 'Comma-delimited list of specific zone codes within the venue that this credential authorizes entry to (e.g., \'Z01,Z04,Z07,Z12\'). Complements access_tier with granular zone-level control as configured in the access control system.' ;
    rdfs:domain ind:Credential ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accreditationBody rdf:type rdf:Property ;
    rdfs:label 'Accreditation Body' ;
    rdfs:comment 'Name of the external governing body or league office that accredited this credential (e.g., \'FIFA Accreditation Centre\', \'NFL League Office\', \'IOC Media Accreditation\'). Relevant for media passes and law enforcement credentials requiring external validation.' ;
    rdfs:domain ind:Credential ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accreditationReference rdf:type rdf:Property ;
    rdfs:label 'Accreditation Reference' ;
    rdfs:comment 'External reference number or accreditation ID assigned by the governing body or league office (e.g., FIFA accreditation number, IOC media pass number). Used for cross-referencing with external accreditation systems.' ;
    rdfs:domain ind:Credential ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:backgroundCheckStatus rdf:type rdf:Property ;
    rdfs:label 'Background Check Status' ;
    rdfs:comment 'Status of the background screening conducted on the credential holder prior to issuance. Classified as confidential business-sensitive data. Values: cleared (passed), pending (in progress), failed (did not pass), waived (exempted by policy), not_required (credential type exempt).' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:barcodeValue rdf:type rdf:Property ;
    rdfs:label 'Barcode Value' ;
    rdfs:comment 'Encoded barcode string (1D or 2D/QR) printed on or embedded in the credential, scanned at access control checkpoints. Classified as confidential as it is the operational key for physical access. Managed in alignment with Ticketmaster/AXS access control systems.' ;
    rdfs:domain ind:Credential ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:biometricLinked rdf:type rdf:Property ;
    rdfs:label 'Biometric Linked' ;
    rdfs:comment 'Indicates whether this credential has been linked to a biometric profile (e.g., fingerprint, facial recognition) for enhanced identity verification at high-security access points. True = biometric data is enrolled and active for this credential.' ;
    rdfs:domain ind:Credential ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:biometricType rdf:type rdf:Property ;
    rdfs:label 'Biometric Type' ;
    rdfs:comment 'Type of biometric modality enrolled for this credential when biometric_linked is True. Classified as restricted PII/biometric per GDPR Article 9 and CCPA. Values: fingerprint, facial_recognition, iris_scan, palm_vein, none.' ;
    rdfs:domain ind:Credential ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:credentialNumber rdf:type rdf:Property ;
    rdfs:label 'Credential Number' ;
    rdfs:comment 'Externally visible, human-readable credential identifier printed on the physical badge or encoded in the digital pass (e.g., CRED-STAFF-000123). Used by security personnel and access control systems to reference a specific credential without exposing the internal surrogate key.' ;
    rdfs:domain ind:Credential ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:credentialStatus rdf:type rdf:Property ;
    rdfs:label 'Credential Status' ;
    rdfs:comment 'Current lifecycle state of the credential. active: valid and in use; suspended: temporarily deactivated (e.g., investigation); revoked: permanently cancelled; expired: past validity end date; pending_activation: issued but not yet activated; lost_stolen: reported missing and deactivated for security.' ;
    rdfs:domain ind:Credential ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emergencyContactName rdf:type rdf:Property ;
    rdfs:label 'Emergency Contact Name' ;
    rdfs:comment 'Full name of the emergency contact person for the credential holder, used by venue medical and security staff in the event of an incident. Classified as restricted PII per GDPR and CCPA.' ;
    rdfs:domain ind:Credential ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emergencyContactPhone rdf:type rdf:Property ;
    rdfs:label 'Emergency Contact Phone' ;
    rdfs:comment 'Phone number of the emergency contact person for the credential holder. Classified as restricted PII per GDPR and CCPA. Used by venue medical and security staff in emergency situations.' ;
    rdfs:domain ind:Credential ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escortRequired rdf:type rdf:Property ;
    rdfs:label 'Escort Required' ;
    rdfs:comment 'Indicates whether the credential holder must be accompanied by an authorized escort when accessing certain zones. True = escort is mandatory. Used for contractor and visitor credentials in high-security areas.' ;
    rdfs:domain ind:Security ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:holderOrganization rdf:type rdf:Property ;
    rdfs:label 'Holder Organization' ;
    rdfs:comment 'Name of the organization, team, media outlet, agency, or employer that the credential holder represents (e.g., \'ESPN\', \'Dallas Cowboys\', \'ABC Security Services\'). Used for affiliation-based access grouping and sponsor/partner credential management.' ;
    rdfs:domain ind:Security ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holderRole rdf:type rdf:Property ;
    rdfs:label 'Holder Role' ;
    rdfs:comment 'Functional role or job title of the credential holder within the event or venue context (e.g., \'Head Coach\', \'Camera Operator\', \'Paramedic\', \'Venue Director\'). Informs access tier assignment and is displayed on the physical credential.' ;
    rdfs:domain ind:Credential ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingAuthorityCode rdf:type rdf:Property ;
    rdfs:label 'Issuing Authority Code' ;
    rdfs:comment 'Standardized short code identifying the issuing authority (e.g., \'NFL_SEC\', \'FIFA_ACC\', \'VENUE_MGR\'). Used for system-level filtering and reporting across multi-league or multi-event deployments.' ;
    rdfs:domain ind:Credential ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lawEnforcementAgency rdf:type rdf:Property ;
    rdfs:label 'Law Enforcement Agency' ;
    rdfs:comment 'Name of the law enforcement agency represented by the credential holder (e.g., \'NYPD\', \'FBI\', \'US Secret Service\'). Populated only for credential_type = law_enforcement. Used for coordination with venue security command.' ;
    rdfs:domain ind:Security ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lawEnforcementBadgeNumber rdf:type rdf:Property ;
    rdfs:label 'Law Enforcement Badge Number' ;
    rdfs:comment 'Official badge or shield number of the law enforcement officer, used to verify identity against agency records. Classified as confidential. Populated only for credential_type = law_enforcement.' ;
    rdfs:domain ind:Credential ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:multiEventFlag rdf:type rdf:Property ;
    rdfs:label 'Multi Event Flag' ;
    rdfs:comment 'Indicates whether this credential is valid across multiple events (e.g., a season-long staff badge or a tournament-wide media pass) rather than a single event. True = valid for multiple events within the validity period.' ;
    rdfs:domain ind:Credential ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:photoUrl rdf:type rdf:Property ;
    rdfs:label 'Photo Url' ;
    rdfs:comment 'Secure URL pointing to the credential holder\'s photograph stored in the Digital Asset Management (DAM) system, used for visual identity verification by security personnel. Classified as restricted biometric PII per GDPR Article 9.' ;
    rdfs:domain ind:Credential ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:printTemplateCode rdf:type rdf:Property ;
    rdfs:label 'Print Template Code' ;
    rdfs:comment 'Code referencing the physical credential print template used for this credential type (e.g., \'TMPL-MEDIA-2024\', \'TMPL-STAFF-VIP\'). Determines layout, branding, and security features printed on the badge.' ;
    rdfs:domain ind:Credential ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rfidTagCode rdf:type rdf:Property ;
    rdfs:label 'Rfid Tag Code' ;
    rdfs:comment 'Unique identifier of the RFID chip embedded in the credential card or wristband, used for contactless access control scanning. Classified as confidential as it is a physical access key. Null if the credential does not use RFID technology.' ;
    rdfs:domain ind:Credential ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vehicleAccessFlag rdf:type rdf:Property ;
    rdfs:label 'Vehicle Access Flag' ;
    rdfs:comment 'Indicates whether this credential also grants vehicle access to restricted parking or loading dock areas at the venue. True = vehicle access is authorized in addition to pedestrian access.' ;
    rdfs:domain ind:Credential ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:vehiclePlateNumber rdf:type rdf:Property ;
    rdfs:label 'Vehicle Plate Number' ;
    rdfs:comment 'License plate number of the vehicle authorized for venue access under this credential when vehicle_access_flag is True. Classified as confidential. Null if vehicle access is not granted.' ;
    rdfs:domain ind:Credential ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentAccessZoneId rdf:type rdf:Property ;
    rdfs:label 'Parent Access Zone Id' ;
    rdfs:comment 'Self-referencing FK on access_zone (parent_access_zone_id)' ;
    rdfs:domain ind:AccessZone ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AccessZone .

ind:accessCloseTime rdf:type rdf:Property ;
    rdfs:label 'Access Close Time' ;
    rdfs:comment 'Standard time of day (HH:MM, 24-hour format) at which access to this zone closes relative to event day operations (e.g., \'23:59\' for post-event lockdown). Used for access control system scheduling and security staffing deployment.' ;
    rdfs:domain ind:AccessZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:accessControlSystem rdf:type rdf:Property ;
    rdfs:label 'Access Control System' ;
    rdfs:comment 'Name or type of the electronic access control system managing entry/exit to this zone (e.g., Ticketmaster/AXS turnstile, Lenel, C-Cure, Genetec, Honeywell, manual staffed checkpoint, or none). Determines integration points for real-time access event logging. [ENUM-REF-CANDIDATE: ticketmaster_axs|lenel|ccure|genetec|honeywell|manual|none — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:AccessZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accessOpenTime rdf:type rdf:Property ;
    rdfs:label 'Access Open Time' ;
    rdfs:comment 'Standard time of day (HH:MM, 24-hour format) at which access to this zone opens relative to event day operations (e.g., \'06:00\' for early crew access). Used for access control system scheduling and security staffing deployment.' ;
    rdfs:domain ind:AccessZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:adaAccessibleFlag rdf:type rdf:Property ;
    rdfs:label 'Ada Accessible Flag' ;
    rdfs:comment 'Indicates whether the access zone meets ADA accessibility requirements including wheelchair access, accessible entry/exit points, and compliant pathways (True = ADA compliant, False = not compliant or not assessed). Required for ADA regulatory reporting.' ;
    rdfs:domain ind:AccessZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:adjacentZoneCodes rdf:type rdf:Property ;
    rdfs:label 'Adjacent Zone Codes' ;
    rdfs:comment 'Comma-separated list of zone_codes for physically adjacent access zones sharing a boundary or transition point with this zone. Used for crowd flow modeling, spillover risk assessment, and emergency egress path analysis. Note: a dedicated zone_adjacency junction product should be used for full relational modeling.' ;
    rdfs:domain ind:AccessZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alcoholPermittedFlag rdf:type rdf:Property ;
    rdfs:label 'Alcohol Permitted Flag' ;
    rdfs:comment 'Indicates whether alcohol consumption and/or service is permitted within this zone (True = permitted, False = not permitted). Used for concession operations planning, liquor licensing compliance, and fan experience management.' ;
    rdfs:domain ind:AccessZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:broadcastZoneFlag rdf:type rdf:Property ;
    rdfs:label 'Broadcast Zone Flag' ;
    rdfs:comment 'Indicates whether this zone is designated as a broadcast or media production area (True = broadcast zone, False = non-broadcast). Triggers media credential requirements and coordination with broadcast operations teams and OB (Outside Broadcast) units.' ;
    rdfs:domain ind:AccessZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cameraCount rdf:type rdf:Property ;
    rdfs:label 'Camera Count' ;
    rdfs:comment 'Number of surveillance cameras installed and actively monitoring the access zone. Used for security audit compliance, coverage gap analysis, and incident response planning.' ;
    rdfs:domain ind:AccessZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:credentialTypeRequired rdf:type rdf:Property ;
    rdfs:label 'Credential Type Required' ;
    rdfs:comment 'Type of credential required for access to this zone (e.g., event_ticket, staff_badge, media_credential, vip_wristband, law_enforcement_id, biometric, all_access_pass). Drives credentialing issuance rules in Ticketmaster/AXS and physical security systems. [ENUM-REF-CANDIDATE: event_ticket|staff_badge|media_credential|vip_wristband|law_enforcement_id|biometric|all_access_pass|none — promote to reference product]' ;
    rdfs:domain ind:AccessZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emergencyAssemblyPointFlag rdf:type rdf:Property ;
    rdfs:label 'Emergency Assembly Point Flag' ;
    rdfs:comment 'Indicates whether this zone serves as a designated emergency assembly or muster point during evacuation scenarios (True = designated assembly point, False = not designated). Used in emergency response plans and evacuation drills.' ;
    rdfs:domain ind:AccessZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:entryPointCount rdf:type rdf:Property ;
    rdfs:label 'Entry Point Count' ;
    rdfs:comment 'Number of physical entry points (gates, turnstiles, doors, checkpoints) providing access into this zone. Used for crowd flow throughput modeling, staffing calculations, and emergency egress planning.' ;
    rdfs:domain ind:AccessZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:evacuationRouteCode rdf:type rdf:Property ;
    rdfs:label 'Evacuation Route Code' ;
    rdfs:comment 'Code identifying the primary designated evacuation route assigned to this zone in the venue emergency response plan. Used by security command center and first responders during emergency scenarios.' ;
    rdfs:domain ind:AccessZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exitPointCount rdf:type rdf:Property ;
    rdfs:label 'Exit Point Count' ;
    rdfs:comment 'Number of physical exit points from this zone. Used for emergency evacuation planning, egress compliance with fire safety codes, and crowd flow modeling.' ;
    rdfs:domain ind:AccessZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:floorAreaSqm rdf:type rdf:Property ;
    rdfs:label 'Floor Area Sqm' ;
    rdfs:comment 'Physical floor area of the access zone measured in square metres. Used to calculate occupancy density ratios, crowd flow modeling, and compliance with safety regulations requiring minimum space per person.' ;
    rdfs:domain ind:AccessZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hvacZoneReference rdf:type rdf:Property ;
    rdfs:label 'Hvac Zone Reference' ;
    rdfs:comment 'Reference code linking this access zone to the corresponding HVAC zone in the Building Management System (BMS). Used for environmental control coordination during events and emergency ventilation management.' ;
    rdfs:domain ind:AccessZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lawEnforcementRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Law Enforcement Required Flag' ;
    rdfs:comment 'Indicates whether sworn law enforcement officers are required to be stationed at or within this zone during events (True = required, False = not required). Used for event security planning, law enforcement coordination, and regulatory compliance.' ;
    rdfs:domain ind:AccessZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:levelNumber rdf:type rdf:Property ;
    rdfs:label 'Level Number' ;
    rdfs:comment 'Numeric floor or level within the venue where the zone is located (e.g., 0 = ground/field level, 1 = concourse level, 2 = upper deck, -1 = sub-ground). Used for wayfinding, evacuation routing, and zone adjacency mapping.' ;
    rdfs:domain ind:AccessZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:mapCoordinates rdf:type rdf:Property ;
    rdfs:label 'Map Coordinates' ;
    rdfs:comment 'Geographic or venue-relative coordinate string (e.g., GeoJSON polygon or venue grid reference) defining the physical boundary of the zone on the venue floor plan. Used for digital venue mapping, crowd flow modeling, and real-time occupancy visualization.' ;
    rdfs:domain ind:AccessZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxOccupancy rdf:type rdf:Property ;
    rdfs:label 'Max Occupancy' ;
    rdfs:comment 'Maximum number of persons permitted within the zone simultaneously as defined by fire safety codes, venue engineering assessments, and regulatory approvals. Used for crowd flow modeling, real-time occupancy monitoring, and ADA compliance reporting.' ;
    rdfs:domain ind:AccessZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minSecurityStaffCount rdf:type rdf:Property ;
    rdfs:label 'Min Security Staff Count' ;
    rdfs:comment 'Minimum number of security personnel required to be deployed in this zone during an active event. Used for event staffing plans, security contractor scheduling, and compliance with venue safety regulations.' ;
    rdfs:domain ind:AccessZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nextSafetyInspectionDate rdf:type rdf:Property ;
    rdfs:label 'Next Safety Inspection Date' ;
    rdfs:comment 'Scheduled date for the next mandatory safety inspection of this access zone. Used for compliance calendar management and proactive safety governance.' ;
    rdfs:domain ind:AccessZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reEntryPermittedFlag rdf:type rdf:Property ;
    rdfs:label 'Re Entry Permitted Flag' ;
    rdfs:comment 'Indicates whether credential holders who have exited this zone are permitted to re-enter during the same event (True = re-entry allowed, False = no re-entry). Drives access control system configuration in Ticketmaster/AXS.' ;
    rdfs:domain ind:AccessZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:screeningProtocol rdf:type rdf:Property ;
    rdfs:label 'Screening Protocol' ;
    rdfs:comment 'Security screening method applied at entry points to this zone: none, visual_check, metal_detector, magnetometer, pat_down, full_search, or biometric_scan. Determines staffing requirements and equipment deployment for event security operations. [ENUM-REF-CANDIDATE: none|visual_check|metal_detector|magnetometer|pat_down|full_search|biometric_scan — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:AccessZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sectionReference rdf:type rdf:Property ;
    rdfs:label 'Section Reference' ;
    rdfs:comment 'Venue section or block designation within which the access zone falls (e.g., \'North Stand\', \'Section 112\', \'East Wing\'). Aligns with Archtics seating inventory and venue map coordinates for operational cross-referencing.' ;
    rdfs:domain ind:AccessZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:smokingPermittedFlag rdf:type rdf:Property ;
    rdfs:label 'Smoking Permitted Flag' ;
    rdfs:comment 'Indicates whether smoking is permitted within this zone (True = permitted, False = not permitted). Used for venue policy enforcement, health and safety compliance, and fan experience communications.' ;
    rdfs:domain ind:AccessZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:surveillanceCoverageFlag rdf:type rdf:Property ;
    rdfs:label 'Surveillance Coverage Flag' ;
    rdfs:comment 'Indicates whether the access zone is covered by CCTV or other surveillance systems (True = covered, False = not covered). Critical for security planning, incident investigation, and compliance with venue safety regulations.' ;
    rdfs:domain ind:AccessZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:timeRestrictedFlag rdf:type rdf:Property ;
    rdfs:label 'Time Restricted Flag' ;
    rdfs:comment 'Indicates whether access to this zone is restricted to specific time windows during an event (True = time-restricted, False = open throughout event). When True, access_open_time and access_close_time define the permitted window.' ;
    rdfs:domain ind:AccessZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:zoneCode rdf:type rdf:Property ;
    rdfs:label 'Zone Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying the access zone within a venue (e.g., FIELD-01, PRESS-BOX-A, VIP-SUITE-N). Used on credentials, wristbands, and access control hardware programming.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:zoneColorCode rdf:type rdf:Property ;
    rdfs:label 'Zone Color Code' ;
    rdfs:comment 'Hexadecimal color code used to visually represent this zone on venue maps, security dashboards, and credentialing systems (e.g., #FF0000 for red restricted zones, #00FF00 for public green zones). Standardizes visual communication across security operations.' ;
    rdfs:domain ind:AccessZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:zoneDescription rdf:type rdf:Property ;
    rdfs:label 'Zone Description' ;
    rdfs:comment 'Free-text narrative description of the access zone including its physical characteristics, operational purpose, notable features, and any special access conditions not captured in structured fields. Used for security briefings and operational documentation.' ;
    rdfs:domain ind:AccessZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:zoneName rdf:type rdf:Property ;
    rdfs:label 'Zone Name' ;
    rdfs:comment 'Human-readable descriptive name of the access zone (e.g., \'Field Level / Pitch Side\', \'Home Team Locker Room\', \'Broadcast Compound\', \'VIP Hospitality Suite North\'). Used in operational reports and credentialing systems.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:zoneStatus rdf:type rdf:Property ;
    rdfs:label 'Zone Status' ;
    rdfs:comment 'Current operational lifecycle status of the access zone: active (in normal use), inactive (temporarily disabled), under_maintenance (physical works in progress), decommissioned (permanently retired), temporary (event-specific pop-up zone). Drives whether the zone is enforced in access control systems.' ;
    rdfs:domain ind:AccessZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:zoneTier rdf:type rdf:Property ;
    rdfs:label 'Zone Tier' ;
    rdfs:comment 'Security classification tier of the zone defining the baseline access control level: public (general admission concourse), restricted (credentialed staff/media), secured (law enforcement / command), sterile (field/pitch/locker room — highest protection). Drives credentialing rules and screening protocols.' ;
    rdfs:domain ind:AccessZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:zoneType rdf:type rdf:Property ;
    rdfs:label 'Zone Type' ;
    rdfs:comment 'Functional category of the zone describing its operational purpose: field_pitch, locker_room, press_box, broadcast_compound, vip_hospitality, back_of_house, command_center, parking_compound, public_concourse, medical, production_truck_bay, merchandise_storage. [ENUM-REF-CANDIDATE: field_pitch|locker_room|press_box|broadcast_compound|vip_hospitality|back_of_house|command_center|parking_compound|public_concourse|medical|production_truck_bay|merchandise_storage — promote to reference product]' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:credentialAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Credential Assignment Id' ;
    rdfs:comment 'Unique system-generated identifier for each credential assignment record. Primary key for the credential_assignment data product in the security domain.' ;
    rdfs:domain ind:Security ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CredentialAssignment .

ind:holderFanProfileId rdf:type rdf:Property ;
    rdfs:label 'Holder Fan Profile Id' ;
    rdfs:comment 'Foreign key linking to fan.fan_profile. Business justification: Credential assignments for fan holders (season ticket, VIP, fan club) must reference the fan profile to enable event-day access verification, ban enforcement checks, and post-event attendance reportin' ;
    rdfs:domain ind:CredentialAssignment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FanProfile .

ind:primaryCredentialEventFixtureId rdf:type rdf:Property ;
    rdfs:label 'Primary Credential Event Fixture Id' ;
    rdfs:comment 'Reference to the specific sports or entertainment event for which this credential assignment is valid. Null if the assignment is venue-wide or period-based rather than event-specific.' ;
    rdfs:domain ind:CredentialAssignment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Fixture .

ind:supersededCredentialAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Superseded Credential Assignment Id' ;
    rdfs:comment 'Self-referencing FK on credential_assignment (superseded_credential_assignment_id)' ;
    rdfs:domain ind:CredentialAssignment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CredentialAssignment .

ind:assignmentNumber rdf:type rdf:Property ;
    rdfs:label 'Assignment Number' ;
    rdfs:comment 'Externally-known human-readable business identifier for the credential assignment, used in credentialing workflows, printed on assignment receipts, and referenced in post-event reconciliation reports. Format: CA-{YYYY}-{NNNNNN}.' ;
    rdfs:domain ind:CredentialAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:credentialScope rdf:type rdf:Property ;
    rdfs:label 'Credential Scope' ;
    rdfs:comment 'Defines the temporal and event scope of the credential assignment — whether it is valid for a single event, multiple events, an entire season, or the venue broadly. Drives validity period enforcement and renewal workflows.' ;
    rdfs:domain ind:CredentialAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventDayNumber rdf:type rdf:Property ;
    rdfs:label 'Event Day Number' ;
    rdfs:comment 'For multi-day events (tournaments, festivals, conventions), the specific day number within the event for which this credential is valid. Null for single-day events or season-wide credentials.' ;
    rdfs:domain ind:CredentialAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:holderIdNumber rdf:type rdf:Property ;
    rdfs:label 'Holder Id Number' ;
    rdfs:comment 'Government-issued or organizational identification number (e.g., employee ID, press pass number, law enforcement badge number) used to verify the identity of the credential holder at time of issuance.' ;
    rdfs:domain ind:CredentialAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holderPhotoUrl rdf:type rdf:Property ;
    rdfs:label 'Holder Photo Url' ;
    rdfs:comment 'Secure URL reference to the credential holder\'s photo image stored in the Digital Asset Management (DAM) system. Used for visual identity verification at access control points. Subject to biometric data protection regulations.' ;
    rdfs:domain ind:CredentialAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holderType rdf:type rdf:Property ;
    rdfs:label 'Holder Type' ;
    rdfs:comment 'Classification of the individual receiving the credential, defining their role and relationship to the event or venue. Drives access zone eligibility and credentialing workflow routing. [ENUM-REF-CANDIDATE: staff|media|contractor|law_enforcement|athlete|sponsor|vip|volunteer|official|vendor — promote to reference product]' ;
    rdfs:domain ind:CredentialAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mealEntitlement rdf:type rdf:Property ;
    rdfs:label 'Meal Entitlement' ;
    rdfs:comment 'Indicates whether the credential assignment includes meal or catering entitlement in designated hospitality areas (e.g., press dining, staff cafeteria). Used for catering planning and cost allocation.' ;
    rdfs:domain ind:CredentialAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:multiZoneAccess rdf:type rdf:Property ;
    rdfs:label 'Multi Zone Access' ;
    rdfs:comment 'Indicates whether this credential assignment grants access to multiple zones beyond the primary access zone. True when the holder is authorized for more than one zone; False for single-zone access.' ;
    rdfs:domain ind:CredentialAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pickupConfirmed rdf:type rdf:Property ;
    rdfs:label 'Pickup Confirmed' ;
    rdfs:comment 'Indicates whether the credential holder has physically collected the credential from the credentialing desk. True when pickup has been confirmed; False when credential is still awaiting collection.' ;
    rdfs:domain ind:CredentialAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pickupLocation rdf:type rdf:Property ;
    rdfs:label 'Pickup Location' ;
    rdfs:comment 'Name or designation of the credentialing desk, gate, or location where the credential was or is to be collected by the holder (e.g., \'Media Gate North\', \'VIP Credentialing Desk Level 2\').' ;
    rdfs:domain ind:CredentialAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pickupTimestamp rdf:type rdf:Property ;
    rdfs:label 'Pickup Timestamp' ;
    rdfs:comment 'Date and time at which the credential holder physically collected the credential from the credentialing desk. Null if credential has not yet been picked up.' ;
    rdfs:domain ind:CredentialAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:returnConfirmed rdf:type rdf:Property ;
    rdfs:label 'Return Confirmed' ;
    rdfs:comment 'Indicates whether the credential has been returned to the credentialing authority after the event or assignment period. True when return is confirmed; False when credential is still outstanding. Critical for post-event reconciliation.' ;
    rdfs:domain ind:CredentialAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:returnTimestamp rdf:type rdf:Property ;
    rdfs:label 'Return Timestamp' ;
    rdfs:comment 'Date and time at which the credential was returned to the credentialing authority. Null if credential has not yet been returned. Used in post-event reconciliation to identify unreturned credentials.' ;
    rdfs:domain ind:CredentialAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:specialAccessNotes rdf:type rdf:Property ;
    rdfs:label 'Special Access Notes' ;
    rdfs:comment 'Free-text field capturing any special access permissions, restrictions, or annotations associated with this credential assignment (e.g., \'Authorized for post-game press conference only\', \'Escort required at all times\'). Supports non-standard credentialing scenarios.' ;
    rdfs:domain ind:CredentialAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vehicleAccess rdf:type rdf:Property ;
    rdfs:label 'Vehicle Access' ;
    rdfs:comment 'Indicates whether this credential assignment includes authorization for vehicle access to restricted venue areas such as loading docks, field-level parking, or broadcast compound. True when vehicle access is granted.' ;
    rdfs:domain ind:CredentialAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:accessEventId rdf:type rdf:Property ;
    rdfs:label 'Access Event Id' ;
    rdfs:comment 'Unique surrogate identifier for each physical access control scan event record in the Silver layer lakehouse. Primary key for this table.' ;
    rdfs:domain ind:AccessEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:overrideOfAccessEventId rdf:type rdf:Property ;
    rdfs:label 'Override Of Access Event Id' ;
    rdfs:comment 'Self-referencing FK on access_event (override_of_access_event_id)' ;
    rdfs:domain ind:AccessEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AccessEvent .

ind:primaryAccessFixtureId rdf:type rdf:Property ;
    rdfs:label 'Primary Access Fixture Id' ;
    rdfs:comment 'FK to event.fixture.fixture_id — Event-correlated access control — security operations must correlate access scans to specific events for crowd management, capacity monitoring, and incident investigation.' ;
    rdfs:domain ind:AccessEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Fixture .

ind:accessDirection rdf:type rdf:Property ;
    rdfs:label 'Access Direction' ;
    rdfs:comment 'Direction of movement at the checkpoint: \'entry\' = entering the zone or venue, \'exit\' = leaving the zone or venue, \'internal\' = movement between internal zones. Used for real-time occupancy tracking and crowd flow analysis.' ;
    rdfs:domain ind:AccessEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adaAccommodationFlag rdf:type rdf:Property ;
    rdfs:label 'Ada Accommodation Flag' ;
    rdfs:comment 'Indicates whether the credential holder required an ADA (Americans with Disabilities Act) accommodation at this access point (e.g., accessible gate routing). True = ADA accommodation applied; False = standard access.' ;
    rdfs:domain ind:AccessEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:antiPassbackZone rdf:type rdf:Property ;
    rdfs:label 'Anti Passback Zone' ;
    rdfs:comment 'Identifier of the anti-passback zone group assigned to this checkpoint. Anti-passback rules prevent a credential from being used to enter a zone it has not exited. Used for tailgating detection and occupancy integrity.' ;
    rdfs:domain ind:AccessEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:biometricVerifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Biometric Verified Flag' ;
    rdfs:comment 'Indicates whether biometric verification (e.g., facial recognition, fingerprint) was used as part of the credential authentication for this scan event. True = biometric match confirmed; False = biometric not used or not matched.' ;
    rdfs:domain ind:AccessEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:credentialHolderCategory rdf:type rdf:Property ;
    rdfs:label 'Credential Holder Category' ;
    rdfs:comment 'Broad category of the person holding the credential. Distinct from credential_type (which describes the credential itself); this describes the person\'s role. Used for access pattern analytics and compliance reporting. [ENUM-REF-CANDIDATE: athlete|staff|media|vip|vendor|law_enforcement|official — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:AccessEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:credentialToken rdf:type rdf:Property ;
    rdfs:label 'Credential Token' ;
    rdfs:comment 'Tokenized or masked representation of the physical credential identifier (e.g., RFID card number, barcode, NFC token) as presented to the reader. Stored in tokenized form to comply with PCI-DSS and GDPR. Not the raw credential number.' ;
    rdfs:domain ind:AccessEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataRetentionExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Data Retention Expiry Date' ;
    rdfs:comment 'Date on which this access event record is scheduled for deletion or anonymization per applicable data retention policies (GDPR, CCPA). Supports automated data lifecycle management in the lakehouse.' ;
    rdfs:domain ind:AccessEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:duplicateScanFlag rdf:type rdf:Property ;
    rdfs:label 'Duplicate Scan Flag' ;
    rdfs:comment 'Indicates whether this scan event was detected as a duplicate presentation of the same credential within a short time window (anti-passback detection). True = duplicate detected; False = unique scan.' ;
    rdfs:domain ind:AccessEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:emergencyEvacuationFlag rdf:type rdf:Property ;
    rdfs:label 'Emergency Evacuation Flag' ;
    rdfs:comment 'Indicates whether this scan event occurred during an active emergency evacuation protocol. True = evacuation mode active at time of scan; False = normal operations. Critical for post-incident headcount reconciliation.' ;
    rdfs:domain ind:AccessEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:eventPhase rdf:type rdf:Property ;
    rdfs:label 'Event Phase' ;
    rdfs:comment 'Operational phase of the event at the time of the scan. Used to segment access patterns by event lifecycle stage for crowd management analytics and post-event review.' ;
    rdfs:domain ind:AccessEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gdprDataSubjectFlag rdf:type rdf:Property ;
    rdfs:label 'Gdpr Data Subject Flag' ;
    rdfs:comment 'Indicates whether the credential holder associated with this scan event is a data subject under GDPR jurisdiction (e.g., EU resident). True = GDPR data subject protections apply; False = not subject to GDPR. Drives data retention and erasure workflows.' ;
    rdfs:domain ind:AccessEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lawEnforcementNotifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Law Enforcement Notified Flag' ;
    rdfs:comment 'Indicates whether law enforcement was notified as a result of this access event (e.g., blacklisted credential, flagged individual). True = law enforcement notification triggered; False = no notification.' ;
    rdfs:domain ind:Security ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:networkZone rdf:type rdf:Property ;
    rdfs:label 'Network Zone' ;
    rdfs:comment 'Network segment or VLAN identifier of the reader device that processed this scan. Used for cybersecurity segmentation audits and forensic network analysis in the event of a security breach.' ;
    rdfs:domain ind:AccessEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:occupancyCountAtScan rdf:type rdf:Property ;
    rdfs:label 'Occupancy Count At Scan' ;
    rdfs:comment 'Snapshot of the current occupancy count for the zone at the moment this scan event was processed. Captured at scan time to support real-time occupancy tracking and capacity compliance reporting.' ;
    rdfs:domain ind:AccessEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:officerOverrideFlag rdf:type rdf:Property ;
    rdfs:label 'Officer Override Flag' ;
    rdfs:comment 'Indicates whether a security officer manually overrode the system\'s access decision for this event. True = officer override applied; False = system decision was final. Critical for post-event forensic review and accountability audits.' ;
    rdfs:domain ind:AccessEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:overrideJustification rdf:type rdf:Property ;
    rdfs:label 'Override Justification' ;
    rdfs:comment 'Free-text or coded reason provided by the officer when performing a manual override. Required when officer_override_flag is True. Supports accountability and compliance audit trails.' ;
    rdfs:domain ind:AccessEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:readerDeviceCode rdf:type rdf:Property ;
    rdfs:label 'Reader Device Code' ;
    rdfs:comment 'Reference to the physical access control reader or scanner device that captured this scan event. Used for device-level diagnostics, tamper detection, and post-event forensic review.' ;
    rdfs:domain ind:AccessEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:readerFirmwareVersion rdf:type rdf:Property ;
    rdfs:label 'Reader Firmware Version' ;
    rdfs:comment 'Firmware version of the access control reader device at the time of the scan. Captured for forensic integrity, device audit trails, and vulnerability management compliance.' ;
    rdfs:domain ind:AccessEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:readerLocationCode rdf:type rdf:Property ;
    rdfs:label 'Reader Location Code' ;
    rdfs:comment 'Alphanumeric code identifying the physical location of the reader device within the venue (e.g., \'NE-G1-R04\'). Supports device-level forensic analysis and maintenance tracking.' ;
    rdfs:domain ind:AccessEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scanDurationMs rdf:type rdf:Property ;
    rdfs:label 'Scan Duration Ms' ;
    rdfs:comment 'Time in milliseconds taken for the reader to process the credential and return a result. Used for throughput analysis, reader performance monitoring, and identifying bottlenecks at high-traffic checkpoints.' ;
    rdfs:domain ind:AccessEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sourceEventReference rdf:type rdf:Property ;
    rdfs:label 'Source Event Reference' ;
    rdfs:comment 'The original event transaction ID or record key from the source access control system (e.g., Ticketmaster/AXS transaction ID). Enables traceability back to the operational system of record for audit and reconciliation.' ;
    rdfs:domain ind:AccessEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:watchlistMatchFlag rdf:type rdf:Property ;
    rdfs:label 'Watchlist Match Flag' ;
    rdfs:comment 'Indicates whether the credential or credential holder matched an entry on a security watchlist at the time of the scan. True = watchlist match detected; False = no match. Triggers escalation workflows.' ;
    rdfs:domain ind:AccessEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:zoneCapacity rdf:type rdf:Property ;
    rdfs:label 'Zone Capacity' ;
    rdfs:comment 'Maximum permitted occupancy for the zone at the time of the scan event, as configured in the access control system. Used alongside occupancy_count_at_scan to determine capacity compliance status.' ;
    rdfs:domain ind:AccessEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:zoneLevel rdf:type rdf:Property ;
    rdfs:label 'Zone Level' ;
    rdfs:comment 'Security classification level of the zone being accessed at the time of the scan. Captures the sensitivity of the zone for risk-tiered reporting and compliance. Values: public, restricted, highly_restricted, field_level, backstage.' ;
    rdfs:domain ind:AccessEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentScreeningCheckpointId rdf:type rdf:Property ;
    rdfs:label 'Parent Screening Checkpoint Id' ;
    rdfs:comment 'Self-referencing FK on screening_checkpoint (parent_screening_checkpoint_id)' ;
    rdfs:domain ind:ScreeningCheckpoint ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ScreeningCheckpoint .

ind:activationEndTime rdf:type rdf:Property ;
    rdfs:label 'Activation End Time' ;
    rdfs:comment 'Standard time of day (HH:MM, 24-hour format) at which this checkpoint ceases screening operations and is deactivated. Used for egress planning and post-event security stand-down scheduling.' ;
    rdfs:domain ind:ScreeningCheckpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:activationScheduleType rdf:type rdf:Property ;
    rdfs:label 'Activation Schedule Type' ;
    rdfs:comment 'Defines the operational activation pattern for this checkpoint — whether it is staffed only on event days, permanently active, activated seasonally, or deployed on-demand for high-security events. Drives resource planning and cost allocation.' ;
    rdfs:domain ind:ScreeningCheckpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:activationStartTime rdf:type rdf:Property ;
    rdfs:label 'Activation Start Time' ;
    rdfs:comment 'Standard time of day (HH:MM, 24-hour format) at which this checkpoint is activated and begins screening operations relative to event start. Used for gate opening schedules and ingress management planning.' ;
    rdfs:domain ind:ScreeningCheckpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:adaLaneCount rdf:type rdf:Property ;
    rdfs:label 'Ada Lane Count' ;
    rdfs:comment 'Number of ADA (Americans with Disabilities Act) compliant accessible screening lanes available at this checkpoint. Distinct from the total lane count — used for ADA compliance reporting and accessibility planning.' ;
    rdfs:domain ind:ScreeningCheckpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:checkpointCode rdf:type rdf:Property ;
    rdfs:label 'Checkpoint Code' ;
    rdfs:comment 'Externally-known alphanumeric business identifier for the screening checkpoint, used in operational communications, staffing assignments, and incident reporting (e.g., \'GATE-A-MAG-01\', \'VIP-BAG-03\'). Unique within a venue.' ;
    rdfs:domain ind:ScreeningCheckpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checkpointName rdf:type rdf:Property ;
    rdfs:label 'Checkpoint Name' ;
    rdfs:comment 'Human-readable descriptive name for the screening checkpoint as displayed on operational maps, staff briefings, and incident reports (e.g., \'North Gate Magnetometer Lane 2\', \'VIP Credentialing Desk East\').' ;
    rdfs:domain ind:ScreeningCheckpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checkpointStatus rdf:type rdf:Property ;
    rdfs:label 'Checkpoint Status' ;
    rdfs:comment 'Current operational lifecycle status of the screening checkpoint. Drives activation scheduling, staffing allocation, and security coverage gap analysis.' ;
    rdfs:domain ind:ScreeningCheckpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checkpointType rdf:type rdf:Property ;
    rdfs:label 'Checkpoint Type' ;
    rdfs:comment 'Classification of the physical security screening checkpoint by its primary function and method of screening. Drives staffing requirements, equipment deployment, and throughput planning. [ENUM-REF-CANDIDATE: magnetometer_lane|bag_check_station|pat_down_area|vehicle_inspection|credentialing_desk|explosive_trace_detection — promote to reference product if additional types are added]' ;
    rdfs:domain ind:ScreeningCheckpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:credentialTypeAccepted rdf:type rdf:Property ;
    rdfs:label 'Credential Type Accepted' ;
    rdfs:comment 'Type(s) of credentials or access passes accepted at this checkpoint for entry authorization (e.g., \'event_ticket\', \'media_credential\', \'staff_badge\', \'law_enforcement_id\'). Drives access control configuration in Ticketmaster/AXS. [ENUM-REF-CANDIDATE: event_ticket|media_credential|staff_badge|law_enforcement_id|vip_pass|vendor_pass|athlete_credential — promote to reference product]' ;
    rdfs:domain ind:ScreeningCheckpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emergencyResponseZone rdf:type rdf:Property ;
    rdfs:label 'Emergency Response Zone' ;
    rdfs:comment 'Designated emergency response zone code to which this checkpoint belongs for incident command and evacuation coordination. Aligns with the venue emergency response plan and law enforcement sector assignments.' ;
    rdfs:domain ind:ScreeningCheckpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equipmentAssetTag rdf:type rdf:Property ;
    rdfs:label 'Equipment Asset Tag' ;
    rdfs:comment 'Physical asset tag or serial number of the primary screening equipment unit deployed at this checkpoint. Used for maintenance tracking, calibration scheduling, and asset lifecycle management in the facilities management system.' ;
    rdfs:domain ind:ScreeningCheckpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equipmentLastCalibrationDate rdf:type rdf:Property ;
    rdfs:label 'Equipment Last Calibration Date' ;
    rdfs:comment 'Date on which the primary screening equipment at this checkpoint was most recently calibrated and certified for operational use. Required for regulatory compliance and safety audits.' ;
    rdfs:domain ind:ScreeningCheckpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:equipmentNextCalibrationDate rdf:type rdf:Property ;
    rdfs:label 'Equipment Next Calibration Date' ;
    rdfs:comment 'Scheduled date for the next mandatory calibration of the primary screening equipment at this checkpoint. Triggers maintenance work orders and ensures continuous compliance with security equipment standards.' ;
    rdfs:domain ind:ScreeningCheckpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:eventTypeApplicability rdf:type rdf:Property ;
    rdfs:label 'Event Type Applicability' ;
    rdfs:comment 'Specifies the category of events for which this checkpoint is activated (e.g., \'all_events\', \'sports_only\', \'concerts_only\', \'ppv_events\', \'high_profile_only\'). Supports dynamic checkpoint activation planning across the event calendar. [ENUM-REF-CANDIDATE: all_events|sports_only|concerts_only|ppv_events|high_profile_only|private_events — promote to reference product]' ;
    rdfs:domain ind:ScreeningCheckpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:floorLevel rdf:type rdf:Property ;
    rdfs:label 'Floor Level' ;
    rdfs:comment 'Floor or level designation within the venue where this checkpoint is located (e.g., \'Ground\', \'Level 1\', \'Concourse\', \'Basement\'). Used for emergency evacuation planning and facility management.' ;
    rdfs:domain ind:ScreeningCheckpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gateNumber rdf:type rdf:Property ;
    rdfs:label 'Gate Number' ;
    rdfs:comment 'Physical gate or entrance number associated with this screening checkpoint as labeled on venue maps and patron-facing signage (e.g., \'Gate 1\', \'Gate C\', \'Loading Dock 3\'). Used for wayfinding and incident location reporting.' ;
    rdfs:domain ind:Security ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isExpressLane rdf:type rdf:Property ;
    rdfs:label 'Is Express Lane' ;
    rdfs:comment 'Indicates whether this checkpoint operates as an expedited screening lane for credentialed personnel, season ticket holders, VIP (Very Important Person) guests, or pre-screened patrons with reduced wait times.' ;
    rdfs:domain ind:ScreeningCheckpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isVehicleCheckpoint rdf:type rdf:Property ;
    rdfs:label 'Is Vehicle Checkpoint' ;
    rdfs:comment 'Indicates whether this checkpoint is designated for vehicle inspection rather than pedestrian screening. Drives different equipment, staffing, and protocol requirements for parking lot and loading dock security.' ;
    rdfs:domain ind:ScreeningCheckpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:laneCount rdf:type rdf:Property ;
    rdfs:label 'Lane Count' ;
    rdfs:comment 'Number of parallel screening lanes available at this checkpoint. A single checkpoint may have multiple lanes operating simultaneously to increase throughput capacity during peak ingress periods.' ;
    rdfs:domain ind:ScreeningCheckpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lawEnforcementPost rdf:type rdf:Property ;
    rdfs:label 'Law Enforcement Post' ;
    rdfs:comment 'Indicates whether this checkpoint requires a dedicated law enforcement officer (LEO) post as part of the security deployment plan. Drives coordination with local police, sheriff, or federal law enforcement agencies.' ;
    rdfs:domain ind:ScreeningCheckpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maxQueueLengthMeters rdf:type rdf:Property ;
    rdfs:label 'Max Queue Length Meters' ;
    rdfs:comment 'Maximum physical queue length in meters that can be accommodated at this checkpoint before crowd management protocols are triggered. Used for ingress modeling and crowd density safety planning.' ;
    rdfs:domain ind:ScreeningCheckpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minStaffRequired rdf:type rdf:Property ;
    rdfs:label 'Min Staff Required' ;
    rdfs:comment 'Minimum number of security personnel required to operate this checkpoint at baseline capacity. Used for staffing plans, shift scheduling, and SLA (Service Level Agreement) compliance with law enforcement partners.' ;
    rdfs:domain ind:ScreeningCheckpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:operatingSopReference rdf:type rdf:Property ;
    rdfs:label 'Operating Sop Reference' ;
    rdfs:comment 'Document reference number or URL for the Standard Operating Procedure (SOP) governing operations at this checkpoint type. Ensures staff follow approved protocols and supports compliance audits.' ;
    rdfs:domain ind:ScreeningCheckpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:optimalStaffCount rdf:type rdf:Property ;
    rdfs:label 'Optimal Staff Count' ;
    rdfs:comment 'Recommended number of security personnel for this checkpoint to achieve rated throughput capacity. Distinct from minimum staffing — represents the target headcount for peak event operations.' ;
    rdfs:domain ind:ScreeningCheckpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:physicalLocationDescription rdf:type rdf:Property ;
    rdfs:label 'Physical Location Description' ;
    rdfs:comment 'Narrative description of the precise physical location of this checkpoint within the venue (e.g., \'North concourse, adjacent to Section 101 entrance, ground level\'). Supports emergency response coordination and incident reporting.' ;
    rdfs:domain ind:ScreeningCheckpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryEquipmentType rdf:type rdf:Property ;
    rdfs:label 'Primary Equipment Type' ;
    rdfs:comment 'Primary security screening equipment deployed at this checkpoint. WTMD (Walk-Through Metal Detector), X-ray (baggage X-ray scanner), ETD (Explosive Trace Detection). Drives maintenance scheduling, calibration records, and procurement planning. [ENUM-REF-CANDIDATE: WTMD|X-ray|ETD|handheld_wand|visual_inspection|CCTV|vehicle_barrier — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ScreeningCheckpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prohibitedItemsListVersion rdf:type rdf:Property ;
    rdfs:label 'Prohibited Items List Version' ;
    rdfs:comment 'Version identifier of the prohibited items policy document governing what items are screened and confiscated at this checkpoint (e.g., \'v2.3\'). Ensures staff are operating under the current approved policy and supports audit traceability.' ;
    rdfs:domain ind:ScreeningCheckpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:throughputCapacityPerHour rdf:type rdf:Property ;
    rdfs:label 'Throughput Capacity Per Hour' ;
    rdfs:comment 'Rated maximum number of persons that can be screened through this checkpoint per hour under normal operating conditions. Used for crowd management planning, staffing optimization, and event ingress modeling.' ;
    rdfs:domain ind:ScreeningCheckpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:venueZoneCode rdf:type rdf:Property ;
    rdfs:label 'Venue Zone Code' ;
    rdfs:comment 'Alphanumeric code identifying the specific security zone or sector within the venue where this checkpoint is located (e.g., \'ZONE-A\', \'CONCOURSE-2\', \'FIELD-LEVEL\'). Aligns with venue access control zone mapping.' ;
    rdfs:domain ind:Security ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screeningEventId rdf:type rdf:Property ;
    rdfs:label 'Screening Event Id' ;
    rdfs:comment 'Unique surrogate identifier for each individual screening interaction record at a security checkpoint. Primary key for the screening_event data product in the Databricks Silver Layer.' ;
    rdfs:domain ind:ScreeningEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryScreeningFanProfileId rdf:type rdf:Property ;
    rdfs:label 'Primary Screening Fan Profile Id' ;
    rdfs:comment 'Reference to the fan, staff member, or credentialed personnel who was screened. May be null for anonymous general admission screenings where identity is not captured.' ;
    rdfs:domain ind:ScreeningEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FanProfile .

ind:primaryScreeningFixtureId rdf:type rdf:Property ;
    rdfs:label 'Primary Screening Fixture Id' ;
    rdfs:comment 'Reference to the sports or entertainment event during which this screening interaction took place. Enables post-event security review and cross-event trend analysis.' ;
    rdfs:domain ind:ScreeningEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Fixture .

ind:screenedAthleteProfileId rdf:type rdf:Property ;
    rdfs:label 'Screened Athlete Profile Id' ;
    rdfs:comment 'Foreign key linking to athlete.athlete_profile. Business justification: Athletes pass through security screening checkpoints at venues. Linking screening events to athlete profiles supports WADA whereabouts compliance documentation, security audit trails, and incident inv' ;
    rdfs:domain ind:ScreeningEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AthleteProfile .

ind:adaAccommodationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Ada Accommodation Required Flag' ;
    rdfs:comment 'Indicates whether the screened individual required an ADA accommodation during the screening process (e.g., wheelchair user, medical device wearer). Supports ADA compliance reporting and accessibility audit requirements.' ;
    rdfs:domain ind:ScreeningEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:alarmResolution rdf:type rdf:Property ;
    rdfs:label 'Alarm Resolution' ;
    rdfs:comment 'The resolution or explanation for an equipment alarm triggered during screening. Null when no alarm was triggered. Supports false-positive rate analysis and equipment calibration review.' ;
    rdfs:domain ind:ScreeningEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confiscationReceiptNumber rdf:type rdf:Property ;
    rdfs:label 'Confiscation Receipt Number' ;
    rdfs:comment 'Reference number issued to the individual when a prohibited item is confiscated, enabling item retrieval after the event if applicable. Null when no item was confiscated. Supports chain-of-custody documentation.' ;
    rdfs:domain ind:ScreeningEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entryDeniedReason rdf:type rdf:Property ;
    rdfs:label 'Entry Denied Reason' ;
    rdfs:comment 'Free-text or coded reason why entry was denied to the screened individual. Null when entry was not denied. Supports denied-entry trend analysis and policy enforcement review.' ;
    rdfs:domain ind:ScreeningEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equipmentAlarmTriggeredFlag rdf:type rdf:Property ;
    rdfs:label 'Equipment Alarm Triggered Flag' ;
    rdfs:comment 'Indicates whether the screening equipment (e.g., magnetometer, X-ray) triggered an alarm during this interaction. Distinguishes equipment-initiated alerts from officer-initiated secondary screenings.' ;
    rdfs:domain ind:ScreeningEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:equipmentCode rdf:type rdf:Property ;
    rdfs:label 'Equipment Code' ;
    rdfs:comment 'Identifier of the specific screening equipment unit used (e.g., magnetometer unit serial number, X-ray machine ID). Supports equipment maintenance tracking, calibration compliance, and fault correlation analysis.' ;
    rdfs:domain ind:ScreeningEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationType rdf:type rdf:Property ;
    rdfs:label 'Escalation Type' ;
    rdfs:comment 'The type of escalation triggered by this screening interaction. Null or \'none\' when no escalation occurred. Used to categorize escalation patterns and resource deployment analysis.' ;
    rdfs:domain ind:ScreeningEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:itemConfiscatedFlag rdf:type rdf:Property ;
    rdfs:label 'Item Confiscated Flag' ;
    rdfs:comment 'Indicates whether the detected prohibited item was physically confiscated from the individual. Distinct from denied_entry outcome — an item may be confiscated while the individual is still permitted entry. Supports confiscation log and chain-of-custody tracking.' ;
    rdfs:domain ind:ScreeningEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:laneNumber rdf:type rdf:Property ;
    rdfs:label 'Lane Number' ;
    rdfs:comment 'The specific screening lane within a checkpoint where the interaction occurred. Multiple lanes may operate at a single gate or checkpoint. Used for lane-level throughput and staffing analysis.' ;
    rdfs:domain ind:ScreeningEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lawEnforcementCaseNumber rdf:type rdf:Property ;
    rdfs:label 'Law Enforcement Case Number' ;
    rdfs:comment 'The official case or incident number assigned by law enforcement when they were notified or took action related to this screening event. Null when law enforcement was not involved. Enables cross-referencing with law enforcement records.' ;
    rdfs:domain ind:Security ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prohibitedItemCategory rdf:type rdf:Property ;
    rdfs:label 'Prohibited Item Category' ;
    rdfs:comment 'High-level category of the prohibited item detected during screening. Null when no prohibited item was found. Supports trend analysis and policy review. [ENUM-REF-CANDIDATE: weapon_firearm|weapon_edged|weapon_blunt|explosive|controlled_substance|alcohol|oversized_bag|laser_device|other — promote to reference product]' ;
    rdfs:domain ind:ScreeningEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prohibitedItemDescription rdf:type rdf:Property ;
    rdfs:label 'Prohibited Item Description' ;
    rdfs:comment 'Free-text description of the specific prohibited item detected (e.g., \'folding knife, 3-inch blade\', \'half-pint whiskey flask\'). Null when no prohibited item was found. Used for detailed incident documentation and law enforcement reporting.' ;
    rdfs:domain ind:Security ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prohibitedItemFlag rdf:type rdf:Property ;
    rdfs:label 'Prohibited Item Flag' ;
    rdfs:comment 'Indicates whether a prohibited item was detected during this screening interaction. True when any prohibited item was found, regardless of whether it was confiscated or the individual was denied entry. Key driver for prohibited item trend analysis.' ;
    rdfs:domain ind:ScreeningEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:queueWaitTimeSeconds rdf:type rdf:Property ;
    rdfs:label 'Queue Wait Time Seconds' ;
    rdfs:comment 'The estimated or measured time in seconds the individual waited in the queue before reaching the screening checkpoint. Supports fan experience analysis, crowd management planning, and SLA reporting for entry operations.' ;
    rdfs:domain ind:ScreeningEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:screenedPersonType rdf:type rdf:Property ;
    rdfs:label 'Screened Person Type' ;
    rdfs:comment 'Classification of the individual being screened, distinguishing fans from credentialed personnel, VIP guests, media, athletes, and law enforcement. Supports segmented security analytics and credentialing compliance. [ENUM-REF-CANDIDATE: fan|staff|vendor|media|vip|athlete|law_enforcement — promote to reference product]' ;
    rdfs:domain ind:ScreeningEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screeningDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Screening Duration Seconds' ;
    rdfs:comment 'The elapsed time in seconds from the start to the completion of the screening interaction. Used for checkpoint throughput analysis, staffing optimization, and identifying bottlenecks in the fan entry process.' ;
    rdfs:domain ind:ScreeningEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:screeningMethod rdf:type rdf:Property ;
    rdfs:label 'Screening Method' ;
    rdfs:comment 'The physical or technological method used to conduct the screening. Supports equipment utilization analysis and compliance with venue security protocols. [ENUM-REF-CANDIDATE: walk_through_magnetometer|hand_wand|pat_down|bag_x_ray|visual_inspection|explosive_trace_detection — promote to reference product]' ;
    rdfs:domain ind:ScreeningEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screeningOutcome rdf:type rdf:Property ;
    rdfs:label 'Screening Outcome' ;
    rdfs:comment 'The result of the screening interaction indicating the disposition of the screened individual. Drives escalation workflows, prohibited item trend analysis, and checkpoint throughput reporting. [ENUM-REF-CANDIDATE: cleared|secondary_screening|denied_entry|prohibited_item_confiscated|medical_referral|law_enforcement_referral — promote to reference product]' ;
    rdfs:domain ind:ScreeningEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screeningReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Screening Reference Number' ;
    rdfs:comment 'Externally-visible alphanumeric reference code assigned to this screening interaction, used for incident reporting, law enforcement coordination, and audit trail purposes. Format: SCR-{YEAR}-{EVENTID}-{SEQUENCE}.' ;
    rdfs:domain ind:ScreeningEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screeningTimestamp rdf:type rdf:Property ;
    rdfs:label 'Screening Timestamp' ;
    rdfs:comment 'The precise date and time when the screening interaction occurred at the checkpoint. Principal business event timestamp used for throughput analysis, timeline reconstruction, and post-event security review.' ;
    rdfs:domain ind:ScreeningEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:escalatedFromSecurityIncidentId rdf:type rdf:Property ;
    rdfs:label 'Escalated From Security Incident Id' ;
    rdfs:comment 'Self-referencing FK on security_incident (escalated_from_security_incident_id)' ;
    rdfs:domain ind:SecurityIncident ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SecurityIncident .

ind:involvedAthleteProfileId rdf:type rdf:Property ;
    rdfs:label 'Involved Athlete Profile Id' ;
    rdfs:comment 'Foreign key linking to athlete.athlete_profile. Business justification: Security incident reports in sports venues must identify involved athletes (on-field altercations, locker room incidents, fan confrontations). League discipline, insurance claims, and broadcast disclo' ;
    rdfs:domain ind:SecurityIncident ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AthleteProfile .

ind:primarySecurityEventFixtureId rdf:type rdf:Property ;
    rdfs:label 'Primary Security Event Fixture Id' ;
    rdfs:comment 'Reference to the specific Sports Entertainment event (game, concert, match) during which the security incident occurred. Enables event-level incident density analysis and post-event security debriefs.' ;
    rdfs:domain ind:SecurityIncident ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Fixture .

ind:primarySecurityFanFanProfileId rdf:type rdf:Property ;
    rdfs:label 'Primary Security Fan Fan Profile Id' ;
    rdfs:comment 'Reference to the registered fan profile in the CRM system (Salesforce CRM / Adobe Experience Platform) if the involved party is an identified fan. Enables cross-referencing with ticketing history, ban records, and loyalty status.' ;
    rdfs:domain ind:SecurityIncident ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FanProfile .

ind:surveillanceAssetId rdf:type rdf:Property ;
    rdfs:label 'Surveillance Asset Id' ;
    rdfs:comment 'Foreign key linking to content.asset. Business justification: Security incident investigations require linking to the DAM asset containing the surveillance footage clip. Post-incident review, insurance claims, and law enforcement handoff processes all depend on ' ;
    rdfs:domain ind:Security ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Asset .

ind:banDurationDays rdf:type rdf:Property ;
    rdfs:label 'Ban Duration Days' ;
    rdfs:comment 'Duration in days of the venue ban issued to the involved party. A value of -1 or null indicates a permanent ban. Populated when ban_issued is True.' ;
    rdfs:domain ind:SecurityIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:banIssued rdf:type rdf:Property ;
    rdfs:label 'Ban Issued' ;
    rdfs:comment 'Indicates whether a venue ban or trespass notice was issued to the involved party as a result of this incident. Triggers downstream ban enforcement processes in Ticketmaster/AXS access control.' ;
    rdfs:domain ind:SecurityIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:closedAt rdf:type rdf:Property ;
    rdfs:label 'Closed At' ;
    rdfs:comment 'Date and time the security incident case was formally closed following completion of all required actions, investigations, and documentation. Null if the incident remains open or under review.' ;
    rdfs:domain ind:SecurityIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:closureNotes rdf:type rdf:Property ;
    rdfs:label 'Closure Notes' ;
    rdfs:comment 'Free-text notes recorded at the time of case closure, summarizing final outcomes, follow-up actions completed, and any lessons learned for security operations improvement.' ;
    rdfs:domain ind:SecurityIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:credentialTypeViolated rdf:type rdf:Property ;
    rdfs:label 'Credential Type Violated' ;
    rdfs:comment 'Type of access credential involved in a credentialing violation incident (e.g., forged media pass, unauthorized field access badge). Populated when incident_type is credentialing_violation. [ENUM-REF-CANDIDATE: media|staff|vip|field_access|broadcast|vendor|athlete — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SecurityIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disposition rdf:type rdf:Property ;
    rdfs:label 'Disposition' ;
    rdfs:comment 'Final outcome or action taken as a result of the security incident. Drives downstream processes including ban enforcement, medical referral, and law enforcement handoff. [ENUM-REF-CANDIDATE: ejected|arrested|warned|banned|referred_medical|no_action|trespass_notice|cited — promote to reference product]' ;
    rdfs:domain ind:SecurityIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emergencyResponsePlanActivated rdf:type rdf:Property ;
    rdfs:label 'Emergency Response Plan Activated' ;
    rdfs:comment 'Indicates whether the venue\'s formal Emergency Response Plan (ERP) was activated in response to this incident. Required for post-incident compliance review and insurance documentation.' ;
    rdfs:domain ind:SecurityIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:evacuationTriggered rdf:type rdf:Property ;
    rdfs:label 'Evacuation Triggered' ;
    rdfs:comment 'Indicates whether the incident triggered a partial or full venue evacuation protocol. Drives post-incident emergency response plan review and regulatory reporting obligations.' ;
    rdfs:domain ind:SecurityIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:insuranceClaimFiled rdf:type rdf:Property ;
    rdfs:label 'Insurance Claim Filed' ;
    rdfs:comment 'Indicates whether an insurance claim was filed in connection with this security incident. Triggers financial reporting obligations and coordination with the Finance domain.' ;
    rdfs:domain ind:Security ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:involvedPartyIdNumber rdf:type rdf:Property ;
    rdfs:label 'Involved Party Id Number' ;
    rdfs:comment 'Government-issued or venue-issued identification number (e.g., driver\'s license, passport, fan membership ID) for the primary involved party. Restricted PII used for law enforcement coordination and ban enforcement.' ;
    rdfs:domain ind:SecurityIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:involvedPartyName rdf:type rdf:Property ;
    rdfs:label 'Involved Party Name' ;
    rdfs:comment 'Full name of the primary individual involved in the security incident (subject, suspect, or victim). Classified as restricted PII under GDPR and CCPA. Required for law enforcement reporting and case management.' ;
    rdfs:domain ind:SecurityIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:involvedPartyType rdf:type rdf:Property ;
    rdfs:label 'Involved Party Type' ;
    rdfs:comment 'Classification of the primary party involved in or subject to the security incident. Determines applicable regulatory obligations (e.g., GDPR for fan data, CBA provisions for athlete incidents). [ENUM-REF-CANDIDATE: fan|athlete|staff|vendor|media|vip_guest|unknown — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SecurityIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lawEnforcementNotified rdf:type rdf:Property ;
    rdfs:label 'Law Enforcement Notified' ;
    rdfs:comment 'Indicates whether local law enforcement (police, FBI, or other agency) was notified of the security incident. Required for regulatory reporting and incident severity escalation tracking.' ;
    rdfs:domain ind:SecurityIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:leagueGoverningBodyReported rdf:type rdf:Property ;
    rdfs:label 'League Governing Body Reported' ;
    rdfs:comment 'Indicates whether the incident was reported to the relevant league governing body (e.g., NFL, NBA, FIFA, NHL) per league security reporting obligations. Required for compliance with league security protocols and CBA provisions.' ;
    rdfs:domain ind:SecurityIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:medicalReferralRequired rdf:type rdf:Property ;
    rdfs:label 'Medical Referral Required' ;
    rdfs:comment 'Indicates whether the incident required a medical referral or emergency medical services (EMS) response. Triggers coordination with venue.safety_incident domain for OSHA recordkeeping when True.' ;
    rdfs:domain ind:SecurityIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:narrative rdf:type rdf:Property ;
    rdfs:label 'Narrative' ;
    rdfs:comment 'Free-text detailed description of the security incident as recorded by the responding officer, including sequence of events, actions taken, and any relevant contextual observations. Primary source for legal and insurance documentation.' ;
    rdfs:domain ind:SecurityIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:numberOfPersonsInvolved rdf:type rdf:Property ;
    rdfs:label 'Number Of Persons Involved' ;
    rdfs:comment 'Total count of individuals directly involved in the security incident (subjects, victims, and witnesses). Used for incident severity assessment and resource deployment analysis.' ;
    rdfs:domain ind:SecurityIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:prohibitedItemType rdf:type rdf:Property ;
    rdfs:label 'Prohibited Item Type' ;
    rdfs:comment 'Classification of the prohibited item seized during the incident, applicable when incident_type is prohibited_item_seizure (e.g., weapon, alcohol, pyrotechnic, laser pointer, drone). [ENUM-REF-CANDIDATE: weapon|alcohol|pyrotechnic|laser_pointer|drone|controlled_substance|recording_device|other — promote to reference product]' ;
    rdfs:domain ind:SecurityIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportedAt rdf:type rdf:Property ;
    rdfs:label 'Reported At' ;
    rdfs:comment 'Date and time the incident was formally reported to the security operations center or duty manager, which may differ from the occurrence time. Used to measure reporting lag and response readiness.' ;
    rdfs:domain ind:SecurityIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:responseTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Response Time Minutes' ;
    rdfs:comment 'Elapsed time in minutes between the incident occurrence timestamp and the arrival of the first responding security officer. Key performance indicator (KPI) for security operations SLA compliance and staffing adequacy reviews.' ;
    rdfs:domain ind:SecurityIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sectionIdentifier rdf:type rdf:Property ;
    rdfs:label 'Section Identifier' ;
    rdfs:comment 'Specific section, block, or area designation within the venue zone where the incident took place (e.g., Section 112, Row G, Gate 4 Entry). Sourced from Archtics seating inventory for precise location mapping.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:severityTier rdf:type rdf:Property ;
    rdfs:label 'Severity Tier' ;
    rdfs:comment 'Standardized severity classification assigned to the incident at time of reporting, used to prioritize response resources and escalation protocols. Tier 1 Critical requires immediate law enforcement; Tier 4 Low is handled by venue security staff.' ;
    rdfs:domain ind:SecurityIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surveillanceFootageAvailable rdf:type rdf:Property ;
    rdfs:label 'Surveillance Footage Available' ;
    rdfs:comment 'Indicates whether CCTV or surveillance camera footage is available and has been preserved for this incident. Critical for evidence management, legal proceedings, and post-incident review.' ;
    rdfs:domain ind:SecurityIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ejectedAthleteProfileId rdf:type rdf:Property ;
    rdfs:label 'Ejected Athlete Profile Id' ;
    rdfs:comment 'Foreign key linking to athlete.athlete_profile. Business justification: Athletes are ejected from games for on-field conduct violations. Ejection records must reference the athlete profile to trigger league discipline reviews, suspension determinations, and broadcast repo' ;
    rdfs:domain ind:EjectionRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AthleteProfile .

ind:ejectingOfficialId rdf:type rdf:Property ;
    rdfs:label 'Ejecting Official Id' ;
    rdfs:comment 'Foreign key linking to league.official. Business justification: When a game official initiates an ejection, the ejection record must reference the specific official for officiating performance reviews and disciplinary accountability. ejecting_officer_badge is a de' ;
    rdfs:domain ind:EjectionRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Official .

ind:appealFiledFlag rdf:type rdf:Property ;
    rdfs:label 'Appeal Filed Flag' ;
    rdfs:comment 'Indicates whether the ejected individual has formally filed an appeal against the ejection decision. True = appeal filed; False = no appeal filed. Triggers the ejection review workflow and updates ejection_status to \'appealed\'.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:arrestMadeFlag rdf:type rdf:Property ;
    rdfs:label 'Arrest Made Flag' ;
    rdfs:comment 'Indicates whether the ejected individual was formally arrested by law enforcement at or following the ejection. True = arrest was made; False = no arrest. Relevant for legal proceedings, insurance claims, and ban severity determination.' ;
    rdfs:domain ind:EjectionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:banRecommendationFlag rdf:type rdf:Property ;
    rdfs:label 'Ban Recommendation Flag' ;
    rdfs:comment 'Indicates whether the ejecting officer or supervisor has recommended a venue ban for the ejected individual. True = ban recommended; False = no ban recommended. Feeds the venue ban registry workflow for formal ban issuance.' ;
    rdfs:domain ind:EjectionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:banRegistryReference rdf:type rdf:Property ;
    rdfs:label 'Ban Registry Reference' ;
    rdfs:comment 'Reference to the formal ban record created in the venue ban registry as a result of this ejection. Populated after the ban is formally issued following the recommendation workflow. Null if no ban was issued.' ;
    rdfs:domain ind:EjectionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:banType rdf:type rdf:Property ;
    rdfs:label 'Ban Type' ;
    rdfs:comment 'Classification of the recommended or issued ban scope. Populated when ban_recommendation_flag is True. Drives the ban registry entry type and enforcement duration. [ENUM-REF-CANDIDATE: single_event|season|multi_season|lifetime|league_wide — promote to reference product]' ;
    rdfs:domain ind:EjectionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ejectedPartyIdNumber rdf:type rdf:Property ;
    rdfs:label 'Ejected Party Id Number' ;
    rdfs:comment 'The identification document number (e.g., driver\'s license number, passport number) of the ejected individual as recorded for ban enforcement and law enforcement handoff. Stored in compliance with GDPR and CCPA data minimization principles.' ;
    rdfs:domain ind:EjectionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ejectedPartyIdType rdf:type rdf:Property ;
    rdfs:label 'Ejected Party Id Type' ;
    rdfs:comment 'Type of identification document presented or used to identify the ejected individual at the time of ejection. Supports identity verification for ban enforcement and law enforcement handoff.' ;
    rdfs:domain ind:EjectionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ejectedPartyName rdf:type rdf:Property ;
    rdfs:label 'Ejected Party Name' ;
    rdfs:comment 'Full name of the individual who was ejected, as recorded at the time of ejection from identification documents or ticketing records. Required for ban enforcement, law enforcement handoff documentation, and legal proceedings.' ;
    rdfs:domain ind:EjectionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ejectedPartyType rdf:type rdf:Property ;
    rdfs:label 'Ejected Party Type' ;
    rdfs:comment 'Classification of the type of individual who was ejected. Determines the applicable code of conduct, ban enforcement pathway, and reporting requirements. VIP (Very Important Person) guests and media personnel follow distinct escalation protocols.' ;
    rdfs:domain ind:EjectionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ejectionReasonCode rdf:type rdf:Property ;
    rdfs:label 'Ejection Reason Code' ;
    rdfs:comment 'Standardized reason code classifying the primary cause of the ejection. Drives ban recommendation logic, repeat offender scoring, and regulatory reporting. [ENUM-REF-CANDIDATE: intoxication|fighting|field_invasion|harassment|prohibited_item|threatening_behavior|racial_abuse|ticket_fraud — promote to reference product]' ;
    rdfs:domain ind:EjectionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ejectionReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Ejection Reason Description' ;
    rdfs:comment 'Free-text narrative description of the specific circumstances leading to the ejection, as recorded by the ejecting security officer. Supplements the standardized reason code with contextual detail for incident review and legal proceedings.' ;
    rdfs:domain ind:EjectionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ejectionReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Ejection Reference Number' ;
    rdfs:comment 'Externally-known alphanumeric reference number assigned to this ejection at the time of occurrence, used in law enforcement handoff documentation, ban notices, and fan appeals. Format: EJ-{YYYY}-{NNNNNN}.' ;
    rdfs:domain ind:EjectionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ejectionStatus rdf:type rdf:Property ;
    rdfs:label 'Ejection Status' ;
    rdfs:comment 'Current lifecycle state of the ejection record. \'pending\' indicates the ejection is being processed; \'confirmed\' means the ejection is finalized; \'appealed\' means the ejected party has filed a formal appeal; \'overturned\' means the ejection was reversed upon review; \'upheld\' means the ejection was sustained after appeal.' ;
    rdfs:domain ind:EjectionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ejectionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Ejection Timestamp' ;
    rdfs:comment 'The precise date and time at which the ejection was executed — i.e., when the individual physically exited or was removed from the venue. This is the principal real-world business event time, distinct from when the record was created in the system.' ;
    rdfs:domain ind:EjectionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lawEnforcementHandoffFlag rdf:type rdf:Property ;
    rdfs:label 'Law Enforcement Handoff Flag' ;
    rdfs:comment 'Indicates whether the ejected individual was handed off to law enforcement (police, stadium security authority) at the time of ejection. True = law enforcement was involved; False = internal security handled the ejection without law enforcement transfer.' ;
    rdfs:domain ind:EjectionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:medicalAssistanceRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Medical Assistance Required Flag' ;
    rdfs:comment 'Indicates whether medical assistance was required for the ejected individual or any other party involved in the incident (e.g., intoxication requiring EMT response, injury from altercation). True = medical assistance was provided or requested; False = no medical assistance needed.' ;
    rdfs:domain ind:EjectionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priorEjectionCount rdf:type rdf:Property ;
    rdfs:label 'Prior Ejection Count' ;
    rdfs:comment 'The number of prior ejections on record for this individual at the time of this ejection event. Used to determine escalation thresholds for ban recommendations and repeat offender classification. Sourced from the ejection history at time of record creation.' ;
    rdfs:domain ind:EjectionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:repeatOffenderFlag rdf:type rdf:Property ;
    rdfs:label 'Repeat Offender Flag' ;
    rdfs:comment 'Indicates whether the ejected individual has a prior ejection record within the Sports Entertainment system at the time of this ejection. True = prior ejection(s) on record; False = first-time ejection. Drives escalated ban recommendations and repeat offender tracking workflows.' ;
    rdfs:domain ind:EjectionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:surveillanceFootageAvailableFlag rdf:type rdf:Property ;
    rdfs:label 'Surveillance Footage Available Flag' ;
    rdfs:comment 'Indicates whether surveillance camera footage of the ejection incident is available and has been flagged for retention. True = footage available and retained; False = no footage available. Supports legal proceedings, appeals, and security system audits.' ;
    rdfs:domain ind:EjectionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:venueZoneType rdf:type rdf:Property ;
    rdfs:label 'Venue Zone Type' ;
    rdfs:comment 'Classification of the venue zone where the ejection occurred. Supports access control analysis and security resource allocation by zone category. [ENUM-REF-CANDIDATE: seating_bowl|field_level|concourse|vip_suite|media_zone|backstage|parking|entry_gate — promote to reference product]' ;
    rdfs:domain ind:EjectionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primarySupersededByPlanEmergencyResponsePlanId rdf:type rdf:Property ;
    rdfs:label 'Primary Superseded By Plan Emergency Response Plan Id' ;
    rdfs:comment 'Reference to the newer emergency response plan that has replaced this version. Null if this is the current active version. Enables version chain traceability for audit and regulatory review.' ;
    rdfs:domain ind:EmergencyResponsePlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EmergencyResponsePlan .

ind:activationTrigger rdf:type rdf:Property ;
    rdfs:label 'Activation Trigger' ;
    rdfs:comment 'Narrative description of the specific conditions or thresholds that trigger activation of this emergency response plan (e.g., \'Confirmed armed individual on premises\', \'NWS Tornado Warning issued within 10-mile radius\'). Critical for incident command decision-making.' ;
    rdfs:domain ind:EmergencyResponsePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adaAccommodationProvisions rdf:type rdf:Property ;
    rdfs:label 'Ada Accommodation Provisions' ;
    rdfs:comment 'Description of specific provisions within this plan for evacuating and sheltering guests and staff with disabilities, including wheelchair-accessible evacuation routes, Areas of Rescue Assistance (ARA), and mobility assistance protocols.' ;
    rdfs:domain ind:EmergencyResponsePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:communicationProtocol rdf:type rdf:Property ;
    rdfs:label 'Communication Protocol' ;
    rdfs:comment 'Description of the communication systems and protocols used during plan activation, including radio frequencies, PA system codes, mass notification system triggers, and social media blackout procedures.' ;
    rdfs:domain ind:EmergencyResponsePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crowdCapacityThreshold rdf:type rdf:Property ;
    rdfs:label 'Crowd Capacity Threshold' ;
    rdfs:comment 'Minimum crowd attendance count at which this plan\'s enhanced protocols are activated (e.g., plans may have tiered activation based on event size). Supports DHS Special Event Assessment Rating (SEAR) classification.' ;
    rdfs:domain ind:EmergencyResponsePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dhsApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Dhs Approval Date' ;
    rdfs:comment 'Date on which DHS formally approved this emergency response plan. Null if approval is pending, not required, or rejected.' ;
    rdfs:domain ind:EmergencyResponsePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dhsApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Dhs Approval Status' ;
    rdfs:comment 'Regulatory approval status of this plan with the U.S. Department of Homeland Security. Required for events classified under DHS Special Event Assessment Rating (SEAR) Tier I-III.' ;
    rdfs:domain ind:EmergencyResponsePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fireMarshalApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Fire Marshal Approval Date' ;
    rdfs:comment 'Date on which the local fire marshal formally approved this emergency response plan. Null if approval is pending, not required, or rejected.' ;
    rdfs:domain ind:EmergencyResponsePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fireMarshalApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Fire Marshal Approval Status' ;
    rdfs:comment 'Regulatory approval status of this plan with the local fire marshal authority. Required for all venue events under NFPA 101 and local fire codes. Drives event permit issuance.' ;
    rdfs:domain ind:EmergencyResponsePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fireMarshalContact rdf:type rdf:Property ;
    rdfs:label 'Fire Marshal Contact' ;
    rdfs:comment 'Primary contact phone number for the local fire marshal office responsible for approving and coordinating fire evacuation components of this plan. Required for regulatory compliance.' ;
    rdfs:domain ind:EmergencyResponsePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentCommandStructure rdf:type rdf:Property ;
    rdfs:label 'Incident Command Structure' ;
    rdfs:comment 'Description of the Incident Command System (ICS) hierarchy governing this plan, including Incident Commander role, Operations Section Chief, Safety Officer, and Public Information Officer designations per NIMS ICS standards.' ;
    rdfs:domain ind:EmergencyResponsePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentCommanderName rdf:type rdf:Property ;
    rdfs:label 'Incident Commander Name' ;
    rdfs:comment 'Full name of the designated Incident Commander responsible for directing emergency response operations under this plan. Confidential operational security information.' ;
    rdfs:domain ind:Security ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentCommanderTitle rdf:type rdf:Property ;
    rdfs:label 'Incident Commander Title' ;
    rdfs:comment 'Official job title of the designated Incident Commander (e.g., \'Director of Event Security\', \'VP Venue Operations\'). Used in regulatory filings and law enforcement coordination documents.' ;
    rdfs:domain ind:EmergencyResponsePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastDrillDate rdf:type rdf:Property ;
    rdfs:label 'Last Drill Date' ;
    rdfs:comment 'Date of the most recent tabletop exercise or full-scale drill conducted to validate this emergency response plan. Required for OSHA compliance and DHS preparedness certification.' ;
    rdfs:domain ind:EmergencyResponsePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lawEnforcementContact rdf:type rdf:Property ;
    rdfs:label 'Law Enforcement Contact' ;
    rdfs:comment 'Primary contact phone number or radio channel for law enforcement coordination during activation of this plan. Confidential operational security data restricted to authorized security personnel.' ;
    rdfs:domain ind:EmergencyResponsePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mediaBlackoutFlag rdf:type rdf:Property ;
    rdfs:label 'Media Blackout Flag' ;
    rdfs:comment 'Indicates whether this plan includes a media and social media blackout protocol during initial activation to prevent panic, protect operational security, and manage public communications through official channels only.' ;
    rdfs:domain ind:EmergencyResponsePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:medicalTriageZoneCount rdf:type rdf:Property ;
    rdfs:label 'Medical Triage Zone Count' ;
    rdfs:comment 'Number of designated medical triage zones established under this plan for mass casualty incident (MCI) response. Drives medical resource pre-positioning and EMS coordination planning.' ;
    rdfs:domain ind:EmergencyResponsePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:multiVenueFlag rdf:type rdf:Property ;
    rdfs:label 'Multi Venue Flag' ;
    rdfs:comment 'Indicates whether this emergency response plan applies to multiple venues simultaneously (e.g., a league-wide severe weather protocol). When True, venue_id represents the primary venue and additional venues are linked in a separate association table.' ;
    rdfs:domain ind:EmergencyResponsePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mutualAidAgreementRef rdf:type rdf:Property ;
    rdfs:label 'Mutual Aid Agreement Ref' ;
    rdfs:comment 'Reference number or name of the mutual aid agreement with external agencies (neighboring jurisdictions, hospitals, EMS providers) that supports this plan. Enables cross-agency resource sharing during large-scale incidents.' ;
    rdfs:domain ind:EmergencyResponsePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planCode rdf:type rdf:Property ;
    rdfs:label 'Plan Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying this emergency response plan across venues and regulatory submissions (e.g., ERP-FIRE-2024-001). Used in DHS filings, local fire marshal submissions, and law enforcement coordination documents.' ;
    rdfs:domain ind:EmergencyResponsePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planDocumentUrl rdf:type rdf:Property ;
    rdfs:label 'Plan Document Url' ;
    rdfs:comment 'Secure URL to the full emergency response plan document stored in the Sports Entertainment Digital Asset Management (DAM) system. Access restricted to authorized security and compliance personnel. Confidential operational security document.' ;
    rdfs:domain ind:EmergencyResponsePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planOwnerDepartment rdf:type rdf:Property ;
    rdfs:label 'Plan Owner Department' ;
    rdfs:comment 'Organizational department responsible for this emergency response plan (e.g., \'Venue Security Operations\', \'Event Safety and Compliance\', \'Facilities Management\').' ;
    rdfs:domain ind:EmergencyResponsePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planOwnerName rdf:type rdf:Property ;
    rdfs:label 'Plan Owner Name' ;
    rdfs:comment 'Full name of the Sports Entertainment staff member accountable for maintaining, updating, and submitting this emergency response plan. Confidential internal personnel data.' ;
    rdfs:domain ind:EmergencyResponsePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryTriageZoneLocation rdf:type rdf:Property ;
    rdfs:label 'Primary Triage Zone Location' ;
    rdfs:comment 'Physical location description of the primary medical triage zone within the venue (e.g., \'Gate A Concourse Level 1\', \'Field Level South End Zone\'). Used by EMS and medical staff during MCI activation.' ;
    rdfs:domain ind:EmergencyResponsePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publicAddressCode rdf:type rdf:Property ;
    rdfs:label 'Public Address Code' ;
    rdfs:comment 'Standardized code word or phrase used in venue public address announcements to signal activation of this plan without causing public panic (e.g., \'Code Alpha\' for medical emergency, \'Code Bravo\' for security threat).' ;
    rdfs:domain ind:EmergencyResponsePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Regulatory Jurisdiction' ;
    rdfs:comment 'Geographic and regulatory jurisdiction governing this plan (e.g., \'Clark County, Nevada\', \'City of New York, NY\', \'Federal – DHS Tier 1\'). Determines which regulatory bodies must approve the plan.' ;
    rdfs:domain ind:EmergencyResponsePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:searTier rdf:type rdf:Property ;
    rdfs:label 'Sear Tier' ;
    rdfs:comment 'DHS Special Event Assessment Rating tier assigned to events covered by this plan. Tier 1 represents the highest national significance (e.g., Super Bowl, Olympics); Tier 3 represents significant regional events. Determines federal resource allocation and coordination requirements.' ;
    rdfs:domain ind:EmergencyResponsePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shelterInPlaceZone rdf:type rdf:Property ;
    rdfs:label 'Shelter In Place Zone' ;
    rdfs:comment 'Designated venue area(s) for shelter-in-place protocols, applicable for severe weather, active threat, or hazmat scenarios. Includes interior hardened areas, concourse corridors, and below-grade spaces.' ;
    rdfs:domain ind:EmergencyResponsePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:threatLevel rdf:type rdf:Property ;
    rdfs:label 'Threat Level' ;
    rdfs:comment 'Severity classification of the emergency scenario addressed by this plan, aligned with DHS threat level taxonomy. Drives resource pre-positioning, law enforcement notification thresholds, and public communication protocols.' ;
    rdfs:domain ind:EmergencyResponsePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalatedEmergencyActivationId rdf:type rdf:Property ;
    rdfs:label 'Escalated Emergency Activation Id' ;
    rdfs:comment 'Self-referencing FK on emergency_activation (escalated_emergency_activation_id)' ;
    rdfs:domain ind:EmergencyActivation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EmergencyActivation .

ind:primaryEmergencyEventFixtureId rdf:type rdf:Property ;
    rdfs:label 'Primary Emergency Event Fixture Id' ;
    rdfs:comment 'Reference to the Sports Entertainment event (game, concert, match, etc.) during which this emergency activation occurred. Links activation to the event scheduling and ticketing context.' ;
    rdfs:domain ind:EmergencyActivation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Fixture .

ind:activationNumber rdf:type rdf:Property ;
    rdfs:label 'Activation Number' ;
    rdfs:comment 'Externally-known, human-readable business identifier for this emergency activation event (e.g., EMA-2024-000123). Used in after-action reports, law enforcement coordination, and regulatory filings. Serves as the BUSINESS_IDENTIFIER category for TRANSACTION_HEADER role.' ;
    rdfs:domain ind:EmergencyActivation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:activationSource rdf:type rdf:Property ;
    rdfs:label 'Activation Source' ;
    rdfs:comment 'Identifies how the emergency activation was triggered: manually by an authorized officer, automatically by an alarm or surveillance system, or reported by law enforcement, staff, or fans. Supports root cause analysis and system effectiveness evaluation.' ;
    rdfs:domain ind:EmergencyActivation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:afterActionReportReference rdf:type rdf:Property ;
    rdfs:label 'After Action Report Reference' ;
    rdfs:comment 'Document reference number or URL linking to the formal After-Action Report (AAR) completed following this emergency activation. The AAR documents lessons learned, response effectiveness, and corrective actions. Required for OSHA, ISO 20121, and league governance compliance.' ;
    rdfs:domain ind:EmergencyActivation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:afterActionReportStatus rdf:type rdf:Property ;
    rdfs:label 'After Action Report Status' ;
    rdfs:comment 'Current completion status of the After-Action Report (AAR) for this emergency activation. Tracks compliance with mandatory post-incident review requirements.' ;
    rdfs:domain ind:EmergencyActivation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allClearTimestamp rdf:type rdf:Property ;
    rdfs:label 'All Clear Timestamp' ;
    rdfs:comment 'The date and time when the all-clear signal was officially issued, indicating the emergency has been resolved and normal operations may resume. Null if the activation has not yet been resolved. Used to calculate response duration.' ;
    rdfs:domain ind:EmergencyActivation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:broadcastInterrupted rdf:type rdf:Property ;
    rdfs:label 'Broadcast Interrupted' ;
    rdfs:comment 'Indicates whether live broadcast operations (TV, OTT, radio) were interrupted or suspended as a result of this emergency activation. Relevant for media rights compliance, FCC reporting, and broadcast partner SLA management.' ;
    rdfs:domain ind:EmergencyActivation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:commandPostLocation rdf:type rdf:Property ;
    rdfs:label 'Command Post Location' ;
    rdfs:comment 'Physical location description of the Incident Command Post (ICP) established for this emergency activation (e.g., \'Gate C Security Office\', \'Parking Lot B Mobile Command Unit\'). Critical for coordinating multi-agency response and documenting ICS compliance.' ;
    rdfs:domain ind:EmergencyActivation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confirmedFatalitiesCount rdf:type rdf:Property ;
    rdfs:label 'Confirmed Fatalities Count' ;
    rdfs:comment 'Total number of confirmed fatalities recorded as a direct result of the emergency incident. Triggers mandatory OSHA fatality reporting within 8 hours, executive notification, and regulatory investigation protocols.' ;
    rdfs:domain ind:EmergencyActivation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:confirmedInjuriesCount rdf:type rdf:Property ;
    rdfs:label 'Confirmed Injuries Count' ;
    rdfs:comment 'Total number of confirmed injuries (non-fatal) recorded as a direct result of the emergency incident. Used for OSHA 300 log reporting, insurance claims, and after-action analysis.' ;
    rdfs:domain ind:EmergencyActivation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:drillExercise rdf:type rdf:Property ;
    rdfs:label 'Drill Exercise' ;
    rdfs:comment 'Indicates whether this activation record represents a planned emergency drill or tabletop exercise rather than an actual emergency event. Allows filtering of drill records from operational incident analytics and regulatory reporting.' ;
    rdfs:domain ind:EmergencyActivation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:emsNotified rdf:type rdf:Property ;
    rdfs:label 'Ems Notified' ;
    rdfs:comment 'Indicates whether Emergency Medical Services (EMS) was formally notified as part of this emergency activation. Mandatory documentation for mass casualty and medical emergency plan types.' ;
    rdfs:domain ind:EmergencyActivation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:estimatedOccupancyAtActivation rdf:type rdf:Property ;
    rdfs:label 'Estimated Occupancy At Activation' ;
    rdfs:comment 'Estimated number of persons (fans, staff, athletes, media) present in the venue at the time of emergency activation. Critical for resource allocation, casualty ratio calculations, and post-event safety analysis. Serves as the QUANTITATIVE_RESULT category for this non-monetary TRANSACTION_HEADER.' ;
    rdfs:domain ind:EmergencyActivation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:evacuationInitiated rdf:type rdf:Property ;
    rdfs:label 'Evacuation Initiated' ;
    rdfs:comment 'Indicates whether a full or partial venue evacuation was initiated as part of this emergency activation. Drives crowd management protocol tracking and post-event safety audit requirements.' ;
    rdfs:domain ind:EmergencyActivation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:evacuationType rdf:type rdf:Property ;
    rdfs:label 'Evacuation Type' ;
    rdfs:comment 'Specifies the scope of evacuation executed during this emergency activation: full venue, partial (specific sections), sector-specific (single zone), or none. Applicable only when evacuation_initiated is True.' ;
    rdfs:domain ind:EmergencyActivation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventCancelled rdf:type rdf:Property ;
    rdfs:label 'Event Cancelled' ;
    rdfs:comment 'Indicates whether the Sports Entertainment event was fully cancelled (not resumed) as a result of this emergency activation. Triggers ticketing refund workflows, force majeure clauses, and insurance claim processes.' ;
    rdfs:domain ind:EmergencyActivation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:eventSuspended rdf:type rdf:Property ;
    rdfs:label 'Event Suspended' ;
    rdfs:comment 'Indicates whether the Sports Entertainment event (game, concert, match) was formally suspended or halted as a result of this emergency activation. Impacts ticketing refund obligations, broadcast rights, and league governance reporting.' ;
    rdfs:domain ind:EmergencyActivation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:falseAlarm rdf:type rdf:Property ;
    rdfs:label 'False Alarm' ;
    rdfs:comment 'Indicates whether this emergency activation was subsequently determined to be a false alarm (no actual emergency existed). Critical for tracking false alarm rates, system calibration, and regulatory reporting to fire/police authorities.' ;
    rdfs:domain ind:EmergencyActivation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fbiNotified rdf:type rdf:Property ;
    rdfs:label 'Fbi Notified' ;
    rdfs:comment 'Indicates whether the Federal Bureau of Investigation (FBI) was formally notified as part of this emergency activation. Required for terrorism, active shooter, and bomb threat plan types per federal reporting obligations.' ;
    rdfs:domain ind:EmergencyActivation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fireDepartmentNotified rdf:type rdf:Property ;
    rdfs:label 'Fire Department Notified' ;
    rdfs:comment 'Indicates whether the fire department was formally notified as part of this emergency activation. Required for NFPA 101 and OSHA compliance documentation.' ;
    rdfs:domain ind:EmergencyActivation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:incidentSeverityLevel rdf:type rdf:Property ;
    rdfs:label 'Incident Severity Level' ;
    rdfs:comment 'Standardized severity classification of the emergency incident at time of activation (Level 1 = minor/localized to Level 5 = catastrophic/mass casualty). Drives resource mobilization, agency notification requirements, and executive escalation protocols.' ;
    rdfs:domain ind:EmergencyActivation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentTriggerDescription rdf:type rdf:Property ;
    rdfs:label 'Incident Trigger Description' ;
    rdfs:comment 'Narrative description of the specific incident, condition, or threat that triggered the emergency plan activation. Captures the initiating event details for after-action review and regulatory reporting.' ;
    rdfs:domain ind:EmergencyActivation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lockdownInitiated rdf:type rdf:Property ;
    rdfs:label 'Lockdown Initiated' ;
    rdfs:comment 'Indicates whether a venue lockdown (perimeter secured, no entry/exit permitted) was initiated as part of this emergency activation. Critical for active shooter and terrorism threat plan types.' ;
    rdfs:domain ind:EmergencyActivation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:medicalTransportsCount rdf:type rdf:Property ;
    rdfs:label 'Medical Transports Count' ;
    rdfs:comment 'Number of individuals transported by EMS or other medical transport to off-site medical facilities during or immediately following the emergency activation. Supports EMS coordination reporting and insurance documentation.' ;
    rdfs:domain ind:EmergencyActivation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:policeNotified rdf:type rdf:Property ;
    rdfs:label 'Police Notified' ;
    rdfs:comment 'Indicates whether law enforcement (police) was formally notified as part of this emergency activation. Required for regulatory compliance documentation and after-action reporting.' ;
    rdfs:domain ind:EmergencyActivation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryReportFiled rdf:type rdf:Property ;
    rdfs:label 'Regulatory Report Filed' ;
    rdfs:comment 'Indicates whether a mandatory regulatory report (e.g., OSHA fatality/hospitalization report, FCC emergency alert report, local authority notification) has been filed for this emergency activation.' ;
    rdfs:domain ind:EmergencyActivation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryReportReference rdf:type rdf:Property ;
    rdfs:label 'Regulatory Report Reference' ;
    rdfs:comment 'Reference number or tracking identifier for the regulatory report filed with the applicable authority (OSHA, FCC, local emergency management). Populated only when regulatory_report_filed is True.' ;
    rdfs:domain ind:EmergencyActivation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Response Duration Minutes' ;
    rdfs:comment 'Total elapsed time in minutes from activation_timestamp to all_clear_timestamp. Captured as a stored business metric (not derived at query time) to support SLA compliance reporting and benchmarking against emergency response KPI targets.' ;
    rdfs:domain ind:EmergencyActivation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:shelterInPlaceInitiated rdf:type rdf:Property ;
    rdfs:label 'Shelter In Place Initiated' ;
    rdfs:comment 'Indicates whether a shelter-in-place directive was issued to venue occupants as part of this emergency activation. Mutually exclusive with full evacuation in most scenarios.' ;
    rdfs:domain ind:EmergencyActivation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:threatCategory rdf:type rdf:Property ;
    rdfs:label 'Threat Category' ;
    rdfs:comment 'Broad category of the threat or hazard that prompted the emergency activation. Used for trend analysis, risk modeling, and compliance reporting across venue and event portfolios. [ENUM-REF-CANDIDATE: physical|medical|environmental|structural|cyber|crowd|weather|terrorism — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:EmergencyActivation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentVenueId rdf:type rdf:Property ;
    rdfs:label 'Parent Venue Id' ;
    rdfs:comment 'Self-referencing FK on venue (parent_venue_id)' ;
    rdfs:domain ind:Venue ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Venue .

ind:iso20121CertExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Iso 20121 Cert Expiry Date' ;
    rdfs:comment 'Expiry date of the venue\'s ISO 20121 Event Sustainability Management System certification. Triggers recertification workflows and may affect eligibility for international event bids.' ;
    rdfs:domain ind:Venue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:namingRightsExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Naming Rights Expiry Date' ;
    rdfs:comment 'Date on which the current naming-rights sponsorship agreement expires. Triggers renewal pipeline activity in Salesforce CRM and venue_name update workflows. Commercially sensitive contract data.' ;
    rdfs:domain ind:Venue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:namingRightsHolder rdf:type rdf:Property ;
    rdfs:label 'Naming Rights Holder' ;
    rdfs:comment 'Name of the corporate sponsor that has purchased naming rights for the venue. Commercially sensitive sponsorship data managed in Salesforce CRM. Impacts venue_name display and brand compliance obligations.' ;
    rdfs:domain ind:Venue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oshaSafetyRating rdf:type rdf:Property ;
    rdfs:label 'Osha Safety Rating' ;
    rdfs:comment 'Current OSHA occupational safety and health compliance rating for the venue as determined by the most recent regulatory inspection. Drives event hosting eligibility and insurance premium calculations.' ;
    rdfs:domain ind:Venue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:venueCode rdf:type rdf:Property ;
    rdfs:label 'Venue Code' ;
    rdfs:comment 'Short, externally-known alphanumeric code uniquely identifying the venue across operational systems (Archtics, Ticketmaster, SAP). Used as the BUSINESS_IDENTIFIER for cross-system reconciliation and manifest references.' ;
    rdfs:domain ind:Venue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:venueName rdf:type rdf:Property ;
    rdfs:label 'Venue Name' ;
    rdfs:comment 'Official public-facing name of the venue as marketed to fans and broadcast partners. Reflects current naming-rights branding. Serves as the IDENTITY_LABEL for the venue master resource.' ;
    rdfs:domain ind:Venue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentFiscalPeriodId rdf:type rdf:Property ;
    rdfs:label 'Parent Fiscal Period Id' ;
    rdfs:comment 'Reference to the parent fiscal period for hierarchical period structures (e.g., a monthly period rolling up to a quarterly period). Null for top-level periods.' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FiscalPeriod .

ind:primaryPriorFiscalPeriodId rdf:type rdf:Property ;
    rdfs:label 'Primary Prior Fiscal Period Id' ;
    rdfs:comment 'Self-referencing FK on fiscal_period (prior_fiscal_period_id)' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FiscalPeriod .

ind:budgetVersion rdf:type rdf:Property ;
    rdfs:label 'Budget Version' ;
    rdfs:comment 'The budget version or scenario applicable to this fiscal period (e.g., Original Budget, Revised Budget, Forecast).' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calendarMonth rdf:type rdf:Property ;
    rdfs:label 'Calendar Month' ;
    rdfs:comment 'The calendar month (1-12) in which this fiscal period starts, used for calendar-to-fiscal mapping.' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:calendarQuarter rdf:type rdf:Property ;
    rdfs:label 'Calendar Quarter' ;
    rdfs:comment 'The calendar quarter (1-4) in which this fiscal period starts, used for calendar-to-fiscal mapping.' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:calendarYear rdf:type rdf:Property ;
    rdfs:label 'Calendar Year' ;
    rdfs:comment 'The calendar year in which this fiscal period starts, used for calendar-to-fiscal mapping.' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:closedDate rdf:type rdf:Property ;
    rdfs:label 'Closed Date' ;
    rdfs:comment 'The date when this fiscal period was officially closed for transaction entry (yyyy-MM-dd). Null if not yet closed.' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:daysInPeriod rdf:type rdf:Property ;
    rdfs:label 'Days In Period' ;
    rdfs:comment 'Total number of calendar days in this fiscal period, used for pro-rata calculations and variance analysis.' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fiscalMonth rdf:type rdf:Property ;
    rdfs:label 'Fiscal Month' ;
    rdfs:comment 'The fiscal month number within the fiscal year (1-12). Null for non-monthly periods.' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fiscalPeriodDescription rdf:type rdf:Property ;
    rdfs:label 'Fiscal Period Description' ;
    rdfs:comment 'Additional descriptive information about the fiscal period, including special characteristics or notes.' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fiscalQuarter rdf:type rdf:Property ;
    rdfs:label 'Fiscal Quarter' ;
    rdfs:comment 'The fiscal quarter number within the fiscal year (1-4). Null for non-quarterly periods.' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fiscalWeek rdf:type rdf:Property ;
    rdfs:label 'Fiscal Week' ;
    rdfs:comment 'The fiscal week number within the fiscal year (1-52 or 1-53). Null for non-weekly periods.' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isAdjustmentPeriod rdf:type rdf:Property ;
    rdfs:label 'Is Adjustment Period' ;
    rdfs:comment 'Indicates whether this is a special adjustment period (e.g., Period 13) used for year-end adjustments and accruals (True/False).' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isCurrentPeriod rdf:type rdf:Property ;
    rdfs:label 'Is Current Period' ;
    rdfs:comment 'Indicates whether this is the current active fiscal period (True/False).' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isYearEndPeriod rdf:type rdf:Property ;
    rdfs:label 'Is Year End Period' ;
    rdfs:comment 'Indicates whether this period is the final period of the fiscal year, requiring year-end closing procedures (True/False).' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lockedDate rdf:type rdf:Property ;
    rdfs:label 'Locked Date' ;
    rdfs:comment 'The date when this fiscal period was locked for final reporting and audit (yyyy-MM-dd). Null if not yet locked.' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:periodCode rdf:type rdf:Property ;
    rdfs:label 'Period Code' ;
    rdfs:comment 'Business identifier code for the fiscal period, typically combining fiscal year and period number (e.g., FY2024-Q1, FY2024-P01).' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:periodName rdf:type rdf:Property ;
    rdfs:label 'Period Name' ;
    rdfs:comment 'Human-readable name of the fiscal period (e.g., Q1 2024, January 2024, FY2024 Period 1).' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:periodStatus rdf:type rdf:Property ;
    rdfs:label 'Period Status' ;
    rdfs:comment 'Current lifecycle status of the fiscal period. Future: not yet started; Open: active for transactions; Closed: no new transactions allowed; Locked: closed and finalized for reporting; Archived: historical record only.' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Reporting Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code used for financial reporting in this period (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:secFilingRequired rdf:type rdf:Property ;
    rdfs:label 'Sec Filing Required' ;
    rdfs:comment 'Indicates whether this fiscal period requires SEC financial reporting filings (10-Q, 10-K) for publicly traded entities (True/False).' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:soxAuditRequired rdf:type rdf:Property ;
    rdfs:label 'Sox Audit Required' ;
    rdfs:comment 'Indicates whether this fiscal period requires SOX compliance audit procedures (True/False).' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:workingDaysInPeriod rdf:type rdf:Property ;
    rdfs:label 'Working Days In Period' ;
    rdfs:comment 'Number of business working days in this fiscal period, excluding weekends and holidays, used for operational metrics.' ;
    rdfs:domain ind:FiscalPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:supervisingAgentId rdf:type rdf:Property ;
    rdfs:label 'Supervising Agent Id' ;
    rdfs:comment 'Self-referencing FK on agent (supervising_agent_id)' ;
    rdfs:domain ind:Agent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Agent .

ind:activeClientCount rdf:type rdf:Property ;
    rdfs:label 'Active Client Count' ;
    rdfs:comment 'The current number of active athletes represented by this agent.' ;
    rdfs:domain ind:Agent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:agentType rdf:type rdf:Property ;
    rdfs:label 'Agent Type' ;
    rdfs:comment 'The classification of agent services provided: player contract negotiation, marketing and endorsements, financial planning, legal services, or full-service representation.' ;
    rdfs:domain ind:Agent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:barAdmissionState rdf:type rdf:Property ;
    rdfs:label 'Bar Admission State' ;
    rdfs:comment 'The state(s) where the agent is admitted to practice law, if applicable for legal representation services.' ;
    rdfs:domain ind:Agent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:barNumber rdf:type rdf:Property ;
    rdfs:label 'Bar Number' ;
    rdfs:comment 'The attorney license number issued by the state bar association, if the agent is a licensed attorney.' ;
    rdfs:domain ind:Agent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationDate rdf:type rdf:Property ;
    rdfs:label 'Certification Date' ;
    rdfs:comment 'The date when the agent was first certified by the league or players association to represent athletes.' ;
    rdfs:domain ind:Agent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:certificationExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Certification Expiration Date' ;
    rdfs:comment 'The date when the agent\'s current certification expires and requires renewal.' ;
    rdfs:domain ind:Athlete ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:commissionRatePercentage rdf:type rdf:Property ;
    rdfs:label 'Commission Rate Percentage' ;
    rdfs:comment 'The standard commission percentage the agent charges on athlete contracts and endorsement deals, typically regulated by collective bargaining agreements.' ;
    rdfs:domain ind:Athlete ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:complianceTrainingDate rdf:type rdf:Property ;
    rdfs:label 'Compliance Training Date' ;
    rdfs:comment 'The date when the agent last completed mandatory compliance and ethics training required by the governing body.' ;
    rdfs:domain ind:Agent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:disciplinaryActionSummary rdf:type rdf:Property ;
    rdfs:label 'Disciplinary Action Summary' ;
    rdfs:comment 'A summary description of any disciplinary actions, sanctions, or violations recorded against the agent.' ;
    rdfs:domain ind:Agent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastRenewalDate rdf:type rdf:Property ;
    rdfs:label 'Last Renewal Date' ;
    rdfs:comment 'The most recent date when the agent renewed their certification with the governing body.' ;
    rdfs:domain ind:Agent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:linkedinProfileUrl rdf:type rdf:Property ;
    rdfs:label 'Linkedin Profile Url' ;
    rdfs:comment 'The LinkedIn profile URL for the agent\'s professional networking presence.' ;
    rdfs:domain ind:Agent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:officeAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Office Address Line1' ;
    rdfs:comment 'The first line of the agent\'s primary business office street address.' ;
    rdfs:domain ind:Agent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:officeAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Office Address Line2' ;
    rdfs:comment 'The second line of the agent\'s primary business office street address (suite, floor, building).' ;
    rdfs:domain ind:Agent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:officeCity rdf:type rdf:Property ;
    rdfs:label 'Office City' ;
    rdfs:comment 'The city where the agent\'s primary business office is located.' ;
    rdfs:domain ind:Agent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:officeCountryCode rdf:type rdf:Property ;
    rdfs:label 'Office Country Code' ;
    rdfs:comment 'The three-letter ISO country code for the agent\'s primary business office location.' ;
    rdfs:domain ind:Agent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:officePostalCode rdf:type rdf:Property ;
    rdfs:label 'Office Postal Code' ;
    rdfs:comment 'The postal or ZIP code for the agent\'s primary business office location.' ;
    rdfs:domain ind:Agent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:officeStateProvince rdf:type rdf:Property ;
    rdfs:label 'Office State Province' ;
    rdfs:comment 'The state or province where the agent\'s primary business office is located.' ;
    rdfs:domain ind:Agent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredContactMethod rdf:type rdf:Property ;
    rdfs:label 'Preferred Contact Method' ;
    rdfs:comment 'The agent\'s preferred method of communication for business matters and athlete representation discussions.' ;
    rdfs:domain ind:Agent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:professionalLiabilityCoverageAmount rdf:type rdf:Property ;
    rdfs:label 'Professional Liability Coverage Amount' ;
    rdfs:comment 'The total coverage amount in USD for the agent\'s professional liability insurance policy.' ;
    rdfs:domain ind:Agent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:professionalLiabilityExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Professional Liability Expiration Date' ;
    rdfs:comment 'The expiration date of the agent\'s current professional liability insurance policy.' ;
    rdfs:domain ind:Agent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:professionalLiabilityInsuranceCarrier rdf:type rdf:Property ;
    rdfs:label 'Professional Liability Insurance Carrier' ;
    rdfs:comment 'The name of the insurance company providing professional liability (errors and omissions) coverage for the agent.' ;
    rdfs:domain ind:Agent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:professionalLiabilityPolicyNumber rdf:type rdf:Property ;
    rdfs:label 'Professional Liability Policy Number' ;
    rdfs:comment 'The policy number for the agent\'s professional liability insurance coverage.' ;
    rdfs:domain ind:Agent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specializationSports rdf:type rdf:Property ;
    rdfs:label 'Specialization Sports' ;
    rdfs:comment 'Comma-separated list of sports or leagues in which the agent specializes (e.g., NFL, NBA, MLB, NHL, MLS, international soccer).' ;
    rdfs:domain ind:Athlete ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxIdentificationNumber rdf:type rdf:Property ;
    rdfs:label 'Tax Identification Number' ;
    rdfs:comment 'The federal tax identification number (EIN or SSN) for the agent or agency used for IRS reporting and contract payments.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentAgencyId rdf:type rdf:Property ;
    rdfs:label 'Parent Agency Id' ;
    rdfs:comment 'Self-referencing FK on agency (parent_agency_id)' ;
    rdfs:domain ind:Agency ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Agency .

ind:agencyCode rdf:type rdf:Property ;
    rdfs:label 'Agency Code' ;
    rdfs:comment 'Unique business identifier or registration code assigned to the agency by league or governing body.' ;
    rdfs:domain ind:Agency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agencyStatus rdf:type rdf:Property ;
    rdfs:label 'Agency Status' ;
    rdfs:comment 'Current operational status of the agency.' ;
    rdfs:domain ind:Agency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agencyType rdf:type rdf:Property ;
    rdfs:label 'Agency Type' ;
    rdfs:comment 'Classification of the agency based on the scope of services provided to athletes.' ;
    rdfs:domain ind:Agency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditOutcome rdf:type rdf:Property ;
    rdfs:label 'Audit Outcome' ;
    rdfs:comment 'Result of the most recent compliance audit or regulatory review.' ;
    rdfs:domain ind:Agency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessRegistrationNumber rdf:type rdf:Property ;
    rdfs:label 'Business Registration Number' ;
    rdfs:comment 'Official business registration or incorporation number issued by government authority.' ;
    rdfs:domain ind:SportsEntertainment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certifiedAgentCount rdf:type rdf:Property ;
    rdfs:label 'Certified Agent Count' ;
    rdfs:comment 'Number of certified sports agents employed by the agency.' ;
    rdfs:domain ind:Agency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:complianceOfficerEmail rdf:type rdf:Property ;
    rdfs:label 'Compliance Officer Email' ;
    rdfs:comment 'Email address of the compliance officer for regulatory inquiries and reporting.' ;
    rdfs:domain ind:Agency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceOfficerName rdf:type rdf:Property ;
    rdfs:label 'Compliance Officer Name' ;
    rdfs:comment 'Full name of the designated compliance officer responsible for regulatory adherence and ethical standards.' ;
    rdfs:domain ind:Agency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeResolutionMethod rdf:type rdf:Property ;
    rdfs:label 'Dispute Resolution Method' ;
    rdfs:comment 'Primary method used by the agency for resolving disputes with clients or third parties.' ;
    rdfs:domain ind:Agency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employeeCount rdf:type rdf:Property ;
