    rdfs:domain ind:InventoryUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inventoryUnitStatus rdf:type rdf:Property ;
    rdfs:label 'Inventory Unit Status' ;
    rdfs:comment 'Current lifecycle status of the inventory unit indicating availability for sale.' ;
    rdfs:domain ind:InventoryUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumAvailabilityQuantity rdf:type rdf:Property ;
    rdfs:label 'Maximum Availability Quantity' ;
    rdfs:comment 'Maximum number of units available for sale per time period to maintain inventory scarcity and value.' ;
    rdfs:domain ind:InventoryUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:measurementMethod rdf:type rdf:Property ;
    rdfs:label 'Measurement Method' ;
    rdfs:comment 'Methodology used to measure and report performance of this inventory unit (e.g., \'Nielsen Ratings\', \'Google Analytics\', \'Manual Count\').' ;
    rdfs:domain ind:InventoryUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumCommitmentQuantity rdf:type rdf:Property ;
    rdfs:label 'Minimum Commitment Quantity' ;
    rdfs:comment 'Minimum number of units or activations required for purchase of this inventory unit.' ;
    rdfs:domain ind:InventoryUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:packageEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Package Eligible Flag' ;
    rdfs:comment 'Indicates whether this inventory unit can be included in bundled sponsorship packages (true) or must be sold standalone (false).' ;
    rdfs:domain ind:InventoryUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:productionRequirements rdf:type rdf:Property ;
    rdfs:label 'Production Requirements' ;
    rdfs:comment 'Technical specifications and production requirements for sponsor creative assets (file formats, dimensions, lead times).' ;
    rdfs:domain ind:InventoryUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Rate Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the base rate amount.' ;
    rdfs:domain ind:InventoryUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateUnit rdf:type rdf:Property ;
    rdfs:label 'Rate Unit' ;
    rdfs:comment 'Unit of measure for the base rate pricing (e.g., per event, per season, per thousand impressions).' ;
    rdfs:domain ind:InventoryUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reachEstimate rdf:type rdf:Property ;
    rdfs:label 'Reach Estimate' ;
    rdfs:comment 'Estimated unique audience reach for this inventory unit across all distribution channels.' ;
    rdfs:domain ind:InventoryUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:seasonalityFlag rdf:type rdf:Property ;
    rdfs:label 'Seasonality Flag' ;
    rdfs:comment 'Indicates whether this inventory unit is available year-round (false) or only during specific seasons or events (true).' ;
    rdfs:domain ind:InventoryUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:unitCode rdf:type rdf:Property ;
    rdfs:label 'Unit Code' ;
    rdfs:comment 'Business identifier code for the inventory unit used in sponsor proposals and contracts.' ;
    rdfs:domain ind:InventoryUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitName rdf:type rdf:Property ;
    rdfs:label 'Unit Name' ;
    rdfs:comment 'Human-readable name of the sponsorship inventory unit (e.g., \'Ring Apron Logo\', \'Broadcast Lower Third\', \'Jersey Patch\').' ;
    rdfs:domain ind:InventoryUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitType rdf:type rdf:Property ;
    rdfs:label 'Unit Type' ;
    rdfs:comment 'Classification of the inventory unit by media channel or activation type.' ;
    rdfs:domain ind:InventoryUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:visibilityRating rdf:type rdf:Property ;
    rdfs:label 'Visibility Rating' ;
    rdfs:comment 'Qualitative rating of the inventory unit\'s prominence and visibility to audiences.' ;
    rdfs:domain ind:InventoryUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentEventTypeId rdf:type rdf:Property ;
    rdfs:label 'Parent Event Type Id' ;
    rdfs:comment 'Self-referencing FK on event_type (parent_event_type_id)' ;
    rdfs:domain ind:Type ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Type .

ind:eventTypeCode rdf:type rdf:Property ;
    rdfs:label 'Event Type Code' ;
    rdfs:comment 'Short alphanumeric code uniquely identifying the event type (e.g., WWE_RAW, SMACKDOWN, WRESTLEMANIA, CONCERT, LIVE_EVENT). Used as a business key for integration and reporting.' ;
    rdfs:domain ind:Type ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventTypeDescription rdf:type rdf:Property ;
    rdfs:label 'Event Type Description' ;
    rdfs:comment 'Detailed description of the event type, including its purpose, format, and distinguishing characteristics.' ;
    rdfs:domain ind:Type ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventTypeName rdf:type rdf:Property ;
    rdfs:label 'Event Type Name' ;
    rdfs:comment 'Full human-readable name of the event type (e.g., Monday Night Raw, SmackDown, WrestleMania, Concert, Live Event).' ;
    rdfs:domain ind:Type ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventTypeStatus rdf:type rdf:Property ;
    rdfs:label 'Event Type Status' ;
    rdfs:comment 'Current lifecycle status of the event type. Active types are currently in use; inactive types are temporarily suspended; retired types are no longer used; planned types are under development.' ;
    rdfs:domain ind:Type ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:internationalDistribution rdf:type rdf:Property ;
    rdfs:label 'International Distribution' ;
    rdfs:comment 'Indicates whether events of this type are distributed internationally (true) or are domestic-only (false).' ;
    rdfs:domain ind:Type ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isBroadcast rdf:type rdf:Property ;
    rdfs:label 'Is Broadcast' ;
    rdfs:comment 'Indicates whether events of this type are broadcast on television or streaming platforms (true) or are live-only (false).' ;
    rdfs:domain ind:Type ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPayPerView rdf:type rdf:Property ;
    rdfs:label 'Is Pay Per View' ;
    rdfs:comment 'Indicates whether events of this type are premium pay-per-view offerings (true) or standard programming (false).' ;
    rdfs:domain ind:Type ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isTicketed rdf:type rdf:Property ;
    rdfs:label 'Is Ticketed' ;
    rdfs:comment 'Indicates whether events of this type require ticket sales (true) or are non-ticketed (false, e.g., free digital events).' ;
    rdfs:domain ind:Type ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:leagueAffiliation rdf:type rdf:Property ;
    rdfs:label 'League Affiliation' ;
    rdfs:comment 'Name of the professional league or brand associated with this event type (e.g., WWE, NXT, AEW). Null for non-league events like concerts.' ;
    rdfs:domain ind:Type ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:merchandiseApplicable rdf:type rdf:Property ;
    rdfs:label 'Merchandise Applicable' ;
    rdfs:comment 'Indicates whether events of this type typically include merchandise sales opportunities (true) or not (false).' ;
    rdfs:domain ind:Type ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:productionComplexity rdf:type rdf:Property ;
    rdfs:label 'Production Complexity' ;
    rdfs:comment 'Relative complexity of production logistics for events of this type: low (minimal setup), medium (standard production), high (advanced staging/effects), premium (flagship events with maximum production value).' ;
    rdfs:domain ind:Type ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordingRequired rdf:type rdf:Property ;
    rdfs:label 'Recording Required' ;
    rdfs:comment 'Indicates whether events of this type must be recorded for archive, replay, or content library purposes (true) or are ephemeral live-only experiences (false).' ;
    rdfs:domain ind:Type ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiresVenue rdf:type rdf:Property ;
    rdfs:label 'Requires Venue' ;
    rdfs:comment 'Indicates whether events of this type require a physical venue (true) or can be virtual/digital-only (false).' ;
    rdfs:domain ind:Type ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:revenueModel rdf:type rdf:Property ;
    rdfs:label 'Revenue Model' ;
    rdfs:comment 'Primary revenue generation model for events of this type: ticket sales, sponsorship, broadcast rights, merchandise, or hybrid (multiple streams).' ;
    rdfs:domain ind:Type ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seasonApplicable rdf:type rdf:Property ;
    rdfs:label 'Season Applicable' ;
    rdfs:comment 'Indicates whether events of this type are organized into seasons (true) or are standalone/ad-hoc (false).' ;
    rdfs:domain ind:Type ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sponsorshipTier rdf:type rdf:Property ;
    rdfs:label 'Sponsorship Tier' ;
    rdfs:comment 'Standard sponsorship tier classification for events of this type, indicating the level of sponsor engagement and investment opportunity.' ;
    rdfs:domain ind:Type ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tournamentApplicable rdf:type rdf:Property ;
    rdfs:label 'Tournament Applicable' ;
    rdfs:comment 'Indicates whether events of this type can be part of tournament brackets or elimination structures (true) or are standalone matches/shows (false).' ;
    rdfs:domain ind:Type ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:typicalCapacityRange rdf:type rdf:Property ;
    rdfs:label 'Typical Capacity Range' ;
    rdfs:comment 'Expected audience capacity range for events of this type (e.g., 5000-10000, 15000-20000, 50000+). Used for venue selection and revenue forecasting.' ;
    rdfs:domain ind:Type ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:typicalDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Typical Duration Minutes' ;
    rdfs:comment 'Standard or expected duration of events of this type, measured in minutes. Used for scheduling and venue planning.' ;
    rdfs:domain ind:Type ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:parentPriceZoneId rdf:type rdf:Property ;
    rdfs:label 'Parent Price Zone Id' ;
    rdfs:comment 'Self-referencing FK on price_zone (parent_price_zone_id)' ;
    rdfs:domain ind:PriceZone ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PriceZone .

ind:accessibleSeating rdf:type rdf:Property ;
    rdfs:label 'Accessible Seating' ;
    rdfs:comment 'Indicates whether this zone includes ADA-compliant accessible seating for guests with disabilities.' ;
    rdfs:domain ind:PriceZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:amenitiesIncluded rdf:type rdf:Property ;
    rdfs:label 'Amenities Included' ;
    rdfs:comment 'Comma-separated list of amenities included with tickets in this zone (e.g., \'VIP Lounge Access\', \'Complimentary Beverage\', \'Meet and Greet\').' ;
    rdfs:domain ind:PriceZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:companionSeatsAvailable rdf:type rdf:Property ;
    rdfs:label 'Companion Seats Available' ;
    rdfs:comment 'Indicates whether companion seats adjacent to accessible seating are available in this zone.' ;
    rdfs:domain ind:PriceZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:externalZoneCode rdf:type rdf:Property ;
    rdfs:label 'External Zone Code' ;
    rdfs:comment 'Price zone identifier in the external ticketing system (Ticketmaster, AXS, Archtics). Used for integration and reconciliation.' ;
    rdfs:domain ind:PriceZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:groupSalesEligible rdf:type rdf:Property ;
    rdfs:label 'Group Sales Eligible' ;
    rdfs:comment 'Indicates whether this zone is available for group sales packages (typically 10+ tickets).' ;
    rdfs:domain ind:PriceZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:minimumGroupSize rdf:type rdf:Property ;
    rdfs:label 'Minimum Group Size' ;
    rdfs:comment 'Minimum number of tickets required for group sales eligibility in this zone. Null if group sales not applicable.' ;
    rdfs:domain ind:PriceZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:mobileEntryEnabled rdf:type rdf:Property ;
    rdfs:label 'Mobile Entry Enabled' ;
    rdfs:comment 'Indicates whether mobile/digital ticket delivery and entry is available for this zone.' ;
    rdfs:domain ind:PriceZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priceZoneDescription rdf:type rdf:Property ;
    rdfs:label 'Price Zone Description' ;
    rdfs:comment 'Detailed description of the price zone including location, view characteristics, and special features. Used for customer-facing marketing.' ;
    rdfs:domain ind:PriceZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceZoneStatus rdf:type rdf:Property ;
    rdfs:label 'Price Zone Status' ;
    rdfs:comment 'Current lifecycle status of the price zone. Controls availability for ticket sales and inventory allocation.' ;
    rdfs:domain ind:PriceZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:printAtHomeEnabled rdf:type rdf:Property ;
    rdfs:label 'Print At Home Enabled' ;
    rdfs:comment 'Indicates whether print-at-home ticket delivery is available for this zone.' ;
    rdfs:domain ind:PriceZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:resaleAllowed rdf:type rdf:Property ;
    rdfs:label 'Resale Allowed' ;
    rdfs:comment 'Indicates whether tickets from this zone can be resold on the secondary marketplace.' ;
    rdfs:domain ind:PriceZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rowRangeEnd rdf:type rdf:Property ;
    rdfs:label 'Row Range End' ;
    rdfs:comment 'Ending row identifier for this price zone (e.g., \'Z\', \'50\'). Used for seat mapping and access control.' ;
    rdfs:domain ind:PriceZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rowRangeStart rdf:type rdf:Property ;
    rdfs:label 'Row Range Start' ;
    rdfs:comment 'Starting row identifier for this price zone (e.g., \'A\', \'1\'). Used for seat mapping and access control.' ;
    rdfs:domain ind:PriceZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ticketingSystemCode rdf:type rdf:Property ;
    rdfs:label 'Ticketing System Code' ;
    rdfs:comment 'External ticketing platform that manages inventory for this zone.' ;
    rdfs:domain ind:PriceZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tier rdf:type rdf:Property ;
    rdfs:label 'Tier' ;
    rdfs:comment 'Pricing tier classification for revenue segmentation and dynamic pricing models.' ;
    rdfs:domain ind:PriceZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:viewQualityRating rdf:type rdf:Property ;
    rdfs:label 'View Quality Rating' ;
    rdfs:comment 'Subjective rating of sightline quality from this zone. Influences pricing and customer satisfaction.' ;
    rdfs:domain ind:PriceZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:willCallEnabled rdf:type rdf:Property ;
    rdfs:label 'Will Call Enabled' ;
    rdfs:comment 'Indicates whether will-call pickup is available for tickets in this zone.' ;
    rdfs:domain ind:PriceZone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:officialAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Official Assignment Id' ;
    rdfs:comment 'Primary key for the official_assignment association' ;
    rdfs:domain ind:OfficialAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:crewRole rdf:type rdf:Property ;
    rdfs:label 'Crew Role' ;
    rdfs:comment 'The specific officiating role this official performed in this game (e.g., Head Referee, Linesman, VAR Operator, TMO, Umpire). Distinct from official.primary_position which reflects career-level specialization; this captures the actual role performed on the day.' ;
    rdfs:domain ind:OfficialAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:performanceScore rdf:type rdf:Property ;
    rdfs:label 'Performance Score' ;
    rdfs:comment 'Numeric performance grade issued by the officiating bureau\'s evaluation team for this official\'s performance in this specific game. Distinct from official.performance_rating which is a rolling composite season score. Feeds into the composite rating calculation.' ;
    rdfs:domain ind:OfficialAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varTmoIntervened rdf:type rdf:Property ;
    rdfs:label 'Var Tmo Intervened' ;
    rdfs:comment 'Indicates whether this official exercised a VAR or TMO intervention decision during this specific game. Complements game_result.var_tmo_intervention_flag at the game level by attributing the intervention to the specific official responsible.' ;
    rdfs:domain ind:OfficialAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:collectionItemId rdf:type rdf:Property ;
    rdfs:label 'Collection Item Id' ;
    rdfs:comment 'Primary key for the collection_item association' ;
    rdfs:domain ind:CollectionItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:addedByUser rdf:type rdf:Property ;
    rdfs:label 'Added By User' ;
    rdfs:comment 'Identifier or username of the editorial staff member or system process that added this asset to the collection. Captures the operational provenance of the membership record.' ;
    rdfs:domain ind:CollectionItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Added Timestamp' ;
    rdfs:comment 'Date and time when this asset was added to the collection by an editorial user or automated curation process. Belongs to the membership event, not to the asset or collection independently.' ;
    rdfs:domain ind:CollectionItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:isFeaturedInCollection rdf:type rdf:Property ;
    rdfs:label 'Is Featured In Collection' ;
    rdfs:comment 'Indicates whether this asset is designated as a featured or promoted item within this specific collection. A single asset may be featured in one collection but not another, making this a relationship-level attribute.' ;
    rdfs:domain ind:CollectionItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:positionInCollection rdf:type rdf:Property ;
    rdfs:label 'Position In Collection' ;
    rdfs:comment 'Ordinal position of the asset within the collection sequence. Drives playback order for playlists and display order for galleries. Belongs to the membership relationship, not to the asset or collection independently.' ;
    rdfs:domain ind:CollectionItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assetTagId rdf:type rdf:Property ;
    rdfs:label 'Asset Tag Id' ;
    rdfs:comment 'Primary key for the asset_tag association' ;
    rdfs:domain ind:AssetTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:confidenceScore rdf:type rdf:Property ;
    rdfs:label 'Confidence Score' ;
    rdfs:comment 'AI/ML confidence score (0.0000–1.0000) for this specific asset-tag pairing when tagging_method is AUTO_AI. Null for manually applied tags. Belongs to the association because the same tag applied to different assets will have different confidence scores from the model.' ;
    rdfs:domain ind:AssetTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isPrimaryTag rdf:type rdf:Property ;
    rdfs:label 'Is Primary Tag' ;
    rdfs:comment 'Indicates whether this tag is designated as a primary/featured tag for the asset within its taxonomy category (e.g., the primary sport tag, the primary athlete tag). Supports ranked display and personalization prioritization. Belongs to the asset-tag relationship, not to either entity alone.' ;
    rdfs:domain ind:AssetTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:taggedByUser rdf:type rdf:Property ;
    rdfs:label 'Tagged By User' ;
    rdfs:comment 'Username or system identifier of the editorial user or automated process that applied this tag to this asset. Belongs to the tagging event, not to the asset or the tag. Used for editorial accountability, workflow auditing, and quality review.' ;
    rdfs:domain ind:AssetTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taggedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Tagged Timestamp' ;
    rdfs:comment 'Date and time when this specific metadata tag was applied to this specific asset. Belongs to the tagging event, not to the asset or the tag independently. Used for audit trails, editorial workflow tracking, and tag freshness analysis.' ;
    rdfs:domain ind:AssetTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:taggingMethod rdf:type rdf:Property ;
    rdfs:label 'Tagging Method' ;
    rdfs:comment 'Method by which this tag was applied to the asset. Distinguishes human editorial tagging from AI auto-tagging, bulk ingest tagging, or rules-engine-driven tagging. Critical for quality assurance workflows and confidence-based filtering.' ;
    rdfs:domain ind:AssetTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planZoneDesignationId rdf:type rdf:Property ;
    rdfs:label 'Plan Zone Designation Id' ;
    rdfs:comment 'Primary key for the plan_zone_designation association' ;
    rdfs:domain ind:PlanZoneDesignation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:activationSequenceOrder rdf:type rdf:Property ;
    rdfs:label 'Activation Sequence Order' ;
    rdfs:comment 'Numeric sequence indicating the order in which this zone is activated or engaged during plan execution. Lower numbers indicate earlier activation. Enables responders to follow a structured zone-by-zone activation protocol during an incident.' ;
    rdfs:domain ind:PlanZoneDesignation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:evacuationPriorityLevel rdf:type rdf:Property ;
    rdfs:label 'Evacuation Priority Level' ;
    rdfs:comment 'Numeric priority ranking (1 = highest priority) for evacuating this zone under this specific plan. Priority may differ across plans — a VIP hospitality zone may be priority 1 under an active shooter plan but priority 3 under a severe weather plan.' ;
    rdfs:domain ind:PlanZoneDesignation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:evacuationRouteDescription rdf:type rdf:Property ;
    rdfs:label 'Evacuation Route Description' ;
    rdfs:comment 'Narrative description of primary and secondary evacuation routes for this plan, including ADA-accessible routes, assembly points, and crowd flow management corridors. Aligned with venue floor plan and ADA compliance requirements. [Moved from emergency_response_plan: This STRING field in emergency_response_plan is a denormalized narrative that attempts to capture zone-level evacuation routing. The proper model is to designate specific access_zone records with evacuation_priority_level and zone_role_in_plan in the plan_zone_designation association, replacing this free-text field with structured, queryable zone designations. The narrative description, if needed, can be retained as a notes field on the designation record.]' ;
    rdfs:domain ind:PlanZoneDesignation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shelterInPlaceFlag rdf:type rdf:Property ;
    rdfs:label 'Shelter In Place Flag' ;
    rdfs:comment 'Indicates whether this access zone is designated as a shelter-in-place location under this specific emergency response plan. Belongs to the designation relationship because the same zone may be a shelter-in-place zone under a severe weather plan but an evacuation zone under a fire plan.' ;
    rdfs:domain ind:PlanZoneDesignation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:triageZoneFlag rdf:type rdf:Property ;
    rdfs:label 'Triage Zone Flag' ;
    rdfs:comment 'Indicates whether this access zone is designated as a medical triage area under this specific emergency response plan. A zone may be a triage zone under an MCI plan but not under a fire evacuation plan — hence this flag belongs to the designation, not the zone master record.' ;
    rdfs:domain ind:PlanZoneDesignation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:zoneRoleInPlan rdf:type rdf:Property ;
    rdfs:label 'Zone Role In Plan' ;
    rdfs:comment 'The specific operational role this access zone is designated to perform under this emergency response plan. A zone may serve as a triage area under one plan and an evacuation staging area under another. This attribute belongs to the designation relationship, not to either the plan or the zone alone.' ;
    rdfs:domain ind:PlanZoneDesignation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clubMembershipId rdf:type rdf:Property ;
    rdfs:label 'Club Membership Id' ;
    rdfs:comment 'Primary key for the club_membership association' ;
    rdfs:domain ind:ClubMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:feePaidFlag rdf:type rdf:Property ;
    rdfs:label 'Fee Paid Flag' ;
    rdfs:comment 'Indicates whether the fan has paid the current period\'s membership dues for this specific club enrollment. Drives access control for member-only benefits and event ticket allocations.' ;
    rdfs:domain ind:ClubMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isFanClubMember rdf:type rdf:Property ;
    rdfs:label 'Is Fan Club Member' ;
    rdfs:comment 'Indicates whether the fan is an active member of an official fan club. Fan club members receive exclusive content, early ticket access, and community engagement opportunities. [Moved from fan_profile: This boolean flag on fan_profile is a denormalized scalar that cannot represent which clubs a fan belongs to or the status of each membership. With the club_membership association table in place, this flag becomes derivable (EXISTS query on club_membership where membership_status = \'active\') and should be removed from fan_profile to avoid data inconsistency.]' ;
    rdfs:domain ind:ClubMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:joinDate rdf:type rdf:Property ;
    rdfs:label 'Join Date' ;
    rdfs:comment 'The date on which the fan formally enrolled in this fan club. Belongs to the enrollment record, not the fan profile or club, as a fan may have different join dates across multiple clubs.' ;
    rdfs:domain ind:ClubMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:supplierCategoryAuthorizationId rdf:type rdf:Property ;
    rdfs:label 'Supplier Category Authorization Id' ;
    rdfs:comment 'Primary key for the supplier_category_authorization association' ;
    rdfs:domain ind:SupplierCategoryAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:productCategories rdf:type rdf:Property ;
    rdfs:label 'Product Categories' ;
    rdfs:comment 'Comma-separated list of merchandise product categories supplied by this vendor (e.g., apparel, headwear, memorabilia, accessories, footwear). Used for category management and sourcing strategy. [Moved from supplier: This denormalized comma-separated STRING field on supplier is a workaround for the unmodeled M:N relationship. It must be removed and replaced by the supplier_category_authorization association table, which provides referential integrity, queryability, and per-authorization commercial terms.]' ;
    rdfs:domain ind:SupplierCategoryAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parkingActivationId rdf:type rdf:Property ;
    rdfs:label 'Parking Activation Id' ;
    rdfs:comment 'Primary key for the parking_activation association' ;
    rdfs:domain ind:ParkingActivation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:activeParkingLotCount rdf:type rdf:Property ;
    rdfs:label 'Active Parking Lot Count' ;
    rdfs:comment 'Number of parking lots or structures that were open and actively managed during the event. Used for parking revenue reconciliation and fan ingress/egress logistics analysis. [Moved from event_day_ops: This aggregate count on event_day_ops is a derived metric that can be computed from the parking_activation association (COUNT of records with activation_status = \'open\' for a given event_day_ops_id). Storing it as a denormalized count on event_day_ops creates a maintenance burden and risks inconsistency with the activation records. It should be removed from event_day_ops and derived via query from this association table.]' ;
    rdfs:domain ind:ParkingActivation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:shuttleActiveFlag rdf:type rdf:Property ;
    rdfs:label 'Shuttle Active Flag' ;
    rdfs:comment 'Indicates whether shuttle service between this parking lot and the venue entrance is active for this event. Relevant for remote and off-site lots. Sourced from detection phase relationship data.' ;
    rdfs:domain ind:ParkingActivation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:spacesAllocatedForEvent rdf:type rdf:Property ;
    rdfs:label 'Spaces Allocated For Event' ;
    rdfs:comment 'Number of parking spaces designated for use during this specific event. May differ from the lot\'s total capacity (parking_lot.accessible_spaces, total spaces) due to reserved sections, construction, or VIP holds. Sourced from detection phase relationship data.' ;
    rdfs:domain ind:ParkingActivation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:configSectionAllocationId rdf:type rdf:Property ;
    rdfs:label 'Config Section Allocation Id' ;
    rdfs:comment 'Primary key for the config_section_allocation association' ;
    rdfs:domain ind:ConfigSectionAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accessRestriction rdf:type rdf:Property ;
    rdfs:label 'Access Restriction' ;
    rdfs:comment 'Configuration-specific access restriction applied to this seating section under this capacity profile. Examples: \'credential_required\', \'vip_only\', \'staff_only\', \'no_public_access\'. Null if no restriction beyond standard ticketing applies. Belongs to the allocation, not the section or config independently.' ;
    rdfs:domain ind:ConfigSectionAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocatedCapacity rdf:type rdf:Property ;
    rdfs:label 'Allocated Capacity' ;
    rdfs:comment 'Number of seats or positions in this seating section that are active and available for sale or assignment under this specific capacity configuration. Differs from the section\'s total capacity when partial kills or restrictions apply.' ;
    rdfs:domain ind:ConfigSectionAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:killSeatCountForSection rdf:type rdf:Property ;
    rdfs:label 'Kill Seat Count For Section' ;
    rdfs:comment 'Number of seats within this specific seating section that are killed (removed from sellable inventory) under this capacity configuration. Section-level kill count, distinct from the config-level aggregate kill_seat_count on capacity_config.' ;
    rdfs:domain ind:ConfigSectionAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:priceZoneOverride rdf:type rdf:Property ;
    rdfs:label 'Price Zone Override' ;
    rdfs:comment 'Config-specific price zone code that overrides the seating section\'s default price_zone_code for this capacity configuration. Used when a concert layout reprices sections differently from the standard sports manifest. Null if the section\'s default price zone applies.' ;
    rdfs:domain ind:ConfigSectionAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sectionStatusInConfig rdf:type rdf:Property ;
    rdfs:label 'Section Status In Config' ;
    rdfs:comment 'Operational status of this seating section within the capacity configuration. \'open\' means fully active; \'partial\' means partially activated with kills; \'killed\' means all seats removed from inventory; \'closed\' means physically inaccessible; \'restricted\' means access-limited. This status belongs to neither the config nor the section alone — it is specific to their combination.' ;
    rdfs:domain ind:ConfigSectionAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .
