ind:clarificationNumber rdf:type rdf:Property ;
    rdfs:label 'Clarification Number' ;
    rdfs:comment 'External reference number assigned to the clarification by the tendering authority.' ;
    rdfs:domain ind:Clarification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clarificationStatus rdf:type rdf:Property ;
    rdfs:label 'Clarification Status' ;
    rdfs:comment 'Current lifecycle status of the clarification.' ;
    rdfs:domain ind:Bid ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:communicationType rdf:type rdf:Property ;
    rdfs:label 'Communication Type' ;
    rdfs:comment 'Category of the communication exchanged during the tender period.' ;
    rdfs:domain ind:Clarification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:content rdf:type rdf:Property ;
