    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:changeOrderType rdf:type rdf:Property ;
    rdfs:label 'Change Order Type' ;
    rdfs:comment 'Classification of the change order purpose, e.g., addition, omission, time extension, price adjustment, or scope change.' ;
