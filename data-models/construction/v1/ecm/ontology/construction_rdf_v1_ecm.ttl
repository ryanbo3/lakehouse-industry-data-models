ind:attachmentsFlag rdf:type rdf:Property ;
    rdfs:label 'Attachments Flag' ;
    rdfs:comment 'Indicates whether supporting documents are attached to the scope record.' ;
    rdfs:domain ind:ContractScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:changeOrderCount rdf:type rdf:Property ;
    rdfs:label 'Change Order Count' ;
    rdfs:comment 'Number of change orders that have been applied to this scope.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:eotEntitlementFlag rdf:type rdf:Property ;
    rdfs:label 'Eot Entitlement Flag' ;
    rdfs:comment 'Indicates whether the scope includes entitlement to extensions of time.' ;
    rdfs:domain ind:ContractScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:exclusions rdf:type rdf:Property ;
    rdfs:label 'Exclusions' ;
    rdfs:comment 'Text describing work items explicitly excluded from the scope.' ;
    rdfs:domain ind:ContractScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicArea rdf:type rdf:Property ;
    rdfs:label 'Geographic Area' ;
    rdfs:comment 'Textual description of the geographic boundaries covered by the scope.' ;
    rdfs:domain ind:ContractScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inclusions rdf:type rdf:Property ;
    rdfs:label 'Inclusions' ;
    rdfs:comment 'Text describing work items explicitly included in the scope.' ;
    rdfs:domain ind:ContractScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedEndDate rdf:type rdf:Property ;
    rdfs:label 'Planned End Date' ;
    rdfs:comment 'Planned completion date for the scope.' ;
