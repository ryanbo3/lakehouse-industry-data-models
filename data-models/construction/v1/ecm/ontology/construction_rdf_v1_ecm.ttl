    rdfs:range xsd:decimal .

ind:percentCompleteUnits rdf:type rdf:Property ;
    rdfs:label 'Percent Complete Units' ;
    rdfs:comment 'Percentage of work units completed (0-100).' ;
    rdfs:domain ind:ProgressUpdate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:periodNumber rdf:type rdf:Property ;
    rdfs:label 'Period Number' ;
    rdfs:comment 'Sequential number of the reporting period within the project schedule.' ;
