    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:criticalActivityCount rdf:type rdf:Property ;
    rdfs:label 'Critical Activity Count' ;
    rdfs:comment 'Number of activities currently on the critical path.' ;
