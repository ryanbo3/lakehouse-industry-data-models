    rdfs:comment 'Ratio of apprentices to journeymen required for prevailing-wage project compliance.' ;
    rdfs:domain ind:ApprenticeshipProgression ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:apprenticeshipEndDate rdf:type rdf:Property ;
