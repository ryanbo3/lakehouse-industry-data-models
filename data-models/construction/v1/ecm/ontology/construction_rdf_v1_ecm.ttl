ind:privacyObligationId rdf:type rdf:Property ;
    rdfs:label 'Privacy Obligation Id' ;
    rdfs:comment 'Foreign key linking to compliance.privacy_obligation. Business justification: Consent records are tied to a privacy obligation; adding privacy_obligation_id links consent to its governing obligation.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PrivacyObligation .

ind:consentCategory rdf:type rdf:Property ;
    rdfs:label 'Consent Category' ;
    rdfs:comment 'High-level classification of the consent (e.g., personal data, marketing, analytics).' ;
