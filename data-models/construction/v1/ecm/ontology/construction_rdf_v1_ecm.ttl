    rdfs:comment 'Quantity earmarked for pending work packages or purchase orders.' ;
    rdfs:domain ind:StockLevel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:safetyStock rdf:type rdf:Property ;
    rdfs:label 'Safety Stock' ;
    rdfs:comment 'Buffer quantity maintained to protect against demand variability or supply delays.' ;
    rdfs:domain ind:StockLevel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stockLevelStatus rdf:type rdf:Property ;
    rdfs:label 'Stock Level Status' ;
    rdfs:comment 'Current lifecycle status of the stock quantity.' ;
    rdfs:domain ind:StockLevel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stockMovementId rdf:type rdf:Property ;
    rdfs:label 'Stock Movement Id' ;
    rdfs:comment 'Primary key for stock_movement' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accountingEntryPosted rdf:type rdf:Property ;
    rdfs:label 'Accounting Entry Posted' ;
    rdfs:comment 'True when the financial posting for the receipt has been completed.' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:actualDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Actual Delivery Date' ;
    rdfs:comment 'Date on which the material physically arrived at the site.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:destinationWarehouseCode rdf:type rdf:Property ;
    rdfs:label 'Destination Warehouse Code' ;
    rdfs:comment 'Code of the warehouse or site where the material is being received.' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Expected Delivery Date' ;
    rdfs:comment 'Planned delivery date as per the purchase order.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:freightCost rdf:type rdf:Property ;
    rdfs:label 'Freight Cost' ;
    rdfs:comment 'Transportation cost associated with delivering the material.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:freightCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Freight Currency Code' ;
    rdfs:comment 'Currency of the freight cost.' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:goodsReceiptType rdf:type rdf:Property ;
    rdfs:label 'Goods Receipt Type' ;
    rdfs:comment 'Indicates whether the receipt is from a purchase, internal transfer, or return.' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCriticalMaterial rdf:type rdf:Property ;
    rdfs:label 'Is Critical Material' ;
    rdfs:comment 'Indicates whether the material is classified as critical for project execution.' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:qualityCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Quality Certificate Number' ;
    rdfs:comment 'Reference number of the quality certificate attached to the material batch.' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityReceived rdf:type rdf:Property ;
    rdfs:label 'Quantity Received' ;
    rdfs:comment 'Amount of material physically received, expressed in the unit of measure.' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:receiptNumber rdf:type rdf:Property ;
    rdfs:label 'Receipt Number' ;
    rdfs:comment 'Business-visible identifier assigned to the receipt (e.g., GR-2023-000123).' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receiptStatus rdf:type rdf:Property ;
    rdfs:label 'Receipt Status' ;
    rdfs:comment 'Overall processing status of the goods receipt.' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receiptTimestamp rdf:type rdf:Property ;
    rdfs:label 'Receipt Timestamp' ;
    rdfs:comment 'Exact date and time the goods receipt was posted in the system.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sourceWarehouseCode rdf:type rdf:Property ;
    rdfs:label 'Source Warehouse Code' ;
    rdfs:comment 'Code of the warehouse or location from which the material originated.' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageLocationCode rdf:type rdf:Property ;
    rdfs:label 'Storage Location Code' ;
    rdfs:comment 'Code of the warehouse or site location where the material is stored.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stockTransferId rdf:type rdf:Property ;
    rdfs:label 'Stock Transfer Id' ;
    rdfs:comment 'System-generated unique identifier for the stock transfer transaction.' ;
    rdfs:domain ind:StockTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:destinationWarehouseId rdf:type rdf:Property ;
    rdfs:label 'Destination Warehouse Id' ;
    rdfs:comment 'Identifier of the warehouse or storage location receiving the material.' ;
    rdfs:domain ind:StockTransfer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Warehouse .

ind:sourceWarehouseId rdf:type rdf:Property ;
    rdfs:label 'Source Warehouse Id' ;
    rdfs:comment 'Identifier of the warehouse or storage location from which the material is transferred.' ;
    rdfs:domain ind:StockTransfer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Warehouse .

ind:actualArrivalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Arrival Timestamp' ;
    rdfs:comment 'Timestamp when the material was actually received at the destination warehouse.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:carrierName rdf:type rdf:Property ;
    rdfs:label 'Carrier Name' ;
    rdfs:comment 'Name of the logistics provider or carrier responsible for moving the material.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedArrivalDate rdf:type rdf:Property ;
    rdfs:label 'Expected Arrival Date' ;
    rdfs:comment 'Planned date on which the material is expected to arrive at the destination.' ;
    rdfs:domain ind:StockTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:stockTransferStatus rdf:type rdf:Property ;
    rdfs:label 'Stock Transfer Status' ;
    rdfs:comment 'Current lifecycle state of the stock transfer (e.g., draft, planned, in-transit, completed, cancelled).' ;
    rdfs:domain ind:StockTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferNumber rdf:type rdf:Property ;
    rdfs:label 'Transfer Number' ;
    rdfs:comment 'Human-readable reference number assigned to the stock transfer for tracking and communication.' ;
    rdfs:domain ind:StockTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferReason rdf:type rdf:Property ;
    rdfs:label 'Transfer Reason' ;
    rdfs:comment 'Business reason for the material movement, such as site reallocation or surplus return.' ;
    rdfs:domain ind:Material ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferTimestamp rdf:type rdf:Property ;
    rdfs:label 'Transfer Timestamp' ;
    rdfs:comment 'Date and time when the material movement was initiated or recorded.' ;
    rdfs:domain ind:StockTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:transportMode rdf:type rdf:Property ;
    rdfs:label 'Transport Mode' ;
    rdfs:comment 'Mode of transportation used for the transfer.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accessControlMethod rdf:type rdf:Property ;
    rdfs:label 'Access Control Method' ;
    rdfs:comment 'Primary method used to control entry to the warehouse.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capacityAreaSqm rdf:type rdf:Property ;
    rdfs:label 'Capacity Area Sqm' ;
    rdfs:comment 'Maximum usable floor area in square metres.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capacityWeightTonnes rdf:type rdf:Property ;
    rdfs:label 'Capacity Weight Tonnes' ;
    rdfs:comment 'Maximum total weight the warehouse can safely store, expressed in metric tonnes.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:certificationExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Certification Expiry Date' ;
    rdfs:comment 'Date on which the hazardous-material certification expires.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:climateControlType rdf:type rdf:Property ;
    rdfs:label 'Climate Control Type' ;
    rdfs:comment 'Specific climate control method applied when temperature_controlled is true.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gpsAccuracyMeters rdf:type rdf:Property ;
    rdfs:label 'Gps Accuracy Meters' ;
    rdfs:comment 'Estimated positional accuracy of the GPS coordinates, in metres.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:gpsLatitude rdf:type rdf:Property ;
    rdfs:label 'Gps Latitude' ;
    rdfs:comment 'Latitude coordinate of the warehouse centre point.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gpsLongitude rdf:type rdf:Property ;
    rdfs:label 'Gps Longitude' ;
    rdfs:comment 'Longitude coordinate of the warehouse centre point.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hazardousMaterialCertificationType rdf:type rdf:Property ;
    rdfs:label 'Hazardous Material Certification Type' ;
    rdfs:comment 'Specific type of hazardous-material certification held, if any.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inventoryManagementSystem rdf:type rdf:Property ;
    rdfs:label 'Inventory Management System' ;
    rdfs:comment 'Name of the downstream system that tracks inventory within this warehouse (e.g., SAP WM, Procore).' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isHazardousMaterialCertified rdf:type rdf:Property ;
    rdfs:label 'Is Hazardous Material Certified' ;
    rdfs:comment 'Indicates whether the warehouse holds a valid hazardous-material storage certification.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:securityLevel rdf:type rdf:Property ;
    rdfs:label 'Security Level' ;
    rdfs:comment 'Overall security classification of the warehouse.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:state rdf:type rdf:Property ;
    rdfs:label 'State' ;
    rdfs:comment 'State or province of the warehouse location.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageZoneDetails rdf:type rdf:Property ;
    rdfs:label 'Storage Zone Details' ;
    rdfs:comment 'Free-form description of internal zones, racks, bins, or yard sections.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureControlled rdf:type rdf:Property ;
    rdfs:label 'Temperature Controlled' ;
    rdfs:comment 'True if the warehouse maintains a controlled temperature environment.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:warehouseDescription rdf:type rdf:Property ;
    rdfs:label 'Warehouse Description' ;
    rdfs:comment 'Narrative description of the warehouse, its purpose, and special characteristics.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:warehouseName rdf:type rdf:Property ;
    rdfs:label 'Warehouse Name' ;
    rdfs:comment 'Human-readable name of the warehouse or laydown yard.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:warehouseStatus rdf:type rdf:Property ;
    rdfs:label 'Warehouse Status' ;
    rdfs:comment 'Current operational status of the warehouse.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:warehouseType rdf:type rdf:Property ;
    rdfs:label 'Warehouse Type' ;
    rdfs:comment 'Classification of the warehouse based on construction and regulatory characteristics.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wastageId rdf:type rdf:Property ;
    rdfs:label 'Wastage Id' ;
    rdfs:comment 'Primary key for wastage' ;
    rdfs:domain ind:Wastage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:wastageCreatedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Wastage Created By User Employee Id' ;
    rdfs:comment 'Identifier of the user who initially created the record.' ;
    rdfs:domain ind:Wastage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:wastageEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Wastage Employee Id' ;
    rdfs:comment 'Identifier of the user who approved the waste record.' ;
    rdfs:domain ind:Wastage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualQuantityConsumed rdf:type rdf:Property ;
    rdfs:label 'Actual Quantity Consumed' ;
    rdfs:comment 'Quantity of material actually used in the activity.' ;
    rdfs:domain ind:Wastage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cause rdf:type rdf:Property ;
    rdfs:label 'Cause' ;
    rdfs:comment 'Root cause of the material wastage.' ;
    rdfs:domain ind:Wastage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disposalLocation rdf:type rdf:Property ;
    rdfs:label 'Disposal Location' ;
    rdfs:comment 'Physical location where the waste was disposed or processed.' ;
    rdfs:domain ind:Wastage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isRecyclable rdf:type rdf:Property ;
    rdfs:label 'Is Recyclable' ;
    rdfs:comment 'Flag indicating whether the waste material is recyclable.' ;
    rdfs:domain ind:Wastage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:plannedQuantity rdf:type rdf:Property ;
    rdfs:label 'Planned Quantity' ;
    rdfs:comment 'Quantity of material originally planned for the activity.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reportingPeriod rdf:type rdf:Property ;
    rdfs:label 'Reporting Period' ;
    rdfs:comment 'Period (e.g., YYYY-MM) for which the waste is reported.' ;
    rdfs:domain ind:Wastage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wastageDate rdf:type rdf:Property ;
    rdfs:label 'Wastage Date' ;
    rdfs:comment 'Date on which the material wastage event occurred.' ;
    rdfs:domain ind:Wastage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:wastageStatus rdf:type rdf:Property ;
    rdfs:label 'Wastage Status' ;
    rdfs:comment 'Current lifecycle status of the wastage record.' ;
    rdfs:domain ind:Wastage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wasteCostAdjustment rdf:type rdf:Property ;
    rdfs:label 'Waste Cost Adjustment' ;
    rdfs:comment 'Adjustments (e.g., rebates, penalties) applied to the gross waste cost.' ;
    rdfs:domain ind:Wastage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wasteCostGross rdf:type rdf:Property ;
    rdfs:label 'Waste Cost Gross' ;
    rdfs:comment 'Total cost associated with the waste before any adjustments.' ;
    rdfs:domain ind:Wastage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wasteCostNet rdf:type rdf:Property ;
    rdfs:label 'Waste Cost Net' ;
    rdfs:comment 'Net cost after adjustments, representing the financial impact of the waste.' ;
    rdfs:domain ind:Wastage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wasteRecordNumber rdf:type rdf:Property ;
    rdfs:label 'Waste Record Number' ;
    rdfs:comment 'Human-readable identifier assigned to the wastage entry for tracking and reference.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wasteType rdf:type rdf:Property ;
    rdfs:label 'Waste Type' ;
    rdfs:comment 'Category of material that was wasted.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workFront rdf:type rdf:Property ;
    rdfs:label 'Work Front' ;
    rdfs:comment 'Specific work front or location on site where waste occurred.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryScheduleId rdf:type rdf:Property ;
    rdfs:label 'Delivery Schedule Id' ;
    rdfs:comment 'Unique identifier for the delivery schedule record. Primary key for the delivery schedule entity.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualDeliveryTime rdf:type rdf:Property ;
    rdfs:label 'Actual Delivery Time' ;
    rdfs:comment 'Actual timestamp when the material delivery was received at the site gate or delivery point. Captured from site daily logs or gate entry system.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:criticalPathFlag rdf:type rdf:Property ;
    rdfs:label 'Critical Path Flag' ;
    rdfs:comment 'Indicates whether the associated activity is on the project critical path per CPM (Critical Path Method) analysis. True if on critical path, False otherwise. Drives prioritization of delivery tracking.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:delayReasonCode rdf:type rdf:Property ;
    rdfs:label 'Delay Reason Code' ;
    rdfs:comment 'Standardized code indicating the reason for delivery delay (e.g., vendor production delay, logistics issue, customs clearance, weather, site access restriction). Null if no delay.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:delayReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Delay Reason Description' ;
    rdfs:comment 'Detailed explanation of the delay reason, including root cause analysis and corrective actions taken.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryPointCode rdf:type rdf:Property ;
    rdfs:label 'Delivery Point Code' ;
    rdfs:comment 'Code identifying the specific delivery location on site (e.g., site gate, laydown area, warehouse, tower crane zone). References site location master data.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryPointDescription rdf:type rdf:Property ;
    rdfs:label 'Delivery Point Description' ;
    rdfs:comment 'Detailed description of the delivery point location, including access instructions and unloading requirements.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryQuantity rdf:type rdf:Property ;
    rdfs:label 'Delivery Quantity' ;
    rdfs:comment 'Quantity of material scheduled for delivery in this schedule line. Must align with PO line item quantity and unit of measure.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deliveryStatus rdf:type rdf:Property ;
    rdfs:label 'Delivery Status' ;
    rdfs:comment 'Current status of the delivery schedule indicating whether the delivery is progressing as planned or experiencing issues. Updated based on vendor updates and schedule variance analysis.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expediteFlag rdf:type rdf:Property ;
    rdfs:label 'Expedite Flag' ;
    rdfs:comment 'Indicates whether this delivery has been flagged for expedited processing due to critical path impact or schedule risk. True if expedited, False otherwise.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:goodsReceiptNumber rdf:type rdf:Property ;
    rdfs:label 'Goods Receipt Number' ;
    rdfs:comment 'SAP MM goods receipt document number generated upon physical receipt and acceptance of the material. Null if goods receipt has not been posted.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:goodsReceiptQuantity rdf:type rdf:Property ;
    rdfs:label 'Goods Receipt Quantity' ;
    rdfs:comment 'Actual quantity received and accepted during goods receipt. May differ from delivery quantity due to shortages, damages, or over-delivery.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:incoterm rdf:type rdf:Property ;
    rdfs:label 'Incoterm' ;
    rdfs:comment 'International Commercial Terms code defining the delivery terms and transfer of risk between vendor and buyer (e.g., EXW, FOB, CIF, DDP).' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Inspection Required Flag' ;
    rdfs:comment 'Indicates whether the material requires QA/QC (Quality Assurance/Quality Control) inspection upon delivery before acceptance. True if inspection required, False otherwise.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:plannedDeliveryTime rdf:type rdf:Property ;
    rdfs:label 'Planned Delivery Time' ;
    rdfs:comment 'Specific time window planned for material delivery, including hour and minute. Critical for coordinating site logistics and crane availability.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:projectCode rdf:type rdf:Property ;
    rdfs:label 'Project Code' ;
    rdfs:comment 'Unique identifier for the construction project to which this material delivery is assigned. Links delivery to project schedule and WBS (Work Breakdown Structure).' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiredOnSiteDate rdf:type rdf:Property ;
    rdfs:label 'Required On Site Date' ;
    rdfs:comment 'Date by which the material must be available on the construction site to support the project schedule. Derived from Primavera P6 activity start dates and material lead times.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scheduleLineNumber rdf:type rdf:Property ;
    rdfs:label 'Schedule Line Number' ;
    rdfs:comment 'Sequential line number within the purchase order identifying this specific delivery schedule. Allows multiple delivery schedules per PO line item.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:shipmentTrackingNumber rdf:type rdf:Property ;
    rdfs:label 'Shipment Tracking Number' ;
    rdfs:comment 'Carrier tracking number or bill of lading number for the shipment. Used for real-time logistics tracking and delivery confirmation.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteContactName rdf:type rdf:Property ;
    rdfs:label 'Site Contact Name' ;
    rdfs:comment 'Name of the site personnel responsible for coordinating and accepting the delivery. Typically site engineer or materials coordinator.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteContactPhone rdf:type rdf:Property ;
    rdfs:label 'Site Contact Phone' ;
    rdfs:comment 'Phone number of the site contact person for delivery coordination and issue resolution.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialHandlingInstructions rdf:type rdf:Property ;
    rdfs:label 'Special Handling Instructions' ;
    rdfs:comment 'Specific instructions for handling, unloading, or storing the material upon delivery (e.g., crane required, temperature-sensitive, hazardous material, fragile).' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorCode rdf:type rdf:Property ;
    rdfs:label 'Vendor Code' ;
    rdfs:comment 'Unique identifier for the supplier or vendor responsible for delivering the material. References vendor master data.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorCommittedDate rdf:type rdf:Property ;
    rdfs:label 'Vendor Committed Date' ;
    rdfs:comment 'Date on which the vendor has committed to deliver the material to the designated delivery point. Captured from PO acknowledgment or vendor confirmation.' ;
    rdfs:domain ind:DeliverySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:goodsReceiptId rdf:type rdf:Property ;
    rdfs:label 'Goods Receipt Id' ;
    rdfs:comment 'Primary key for goods_receipt' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GoodsReceipt .

ind:materialCatalogId rdf:type rdf:Property ;
    rdfs:label 'Material Catalog Id' ;
    rdfs:comment 'Foreign key linking to procurement.material_catalog. Business justification: Link goods receipt material to master catalog for normalization and remove redundant material_id column.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MaterialCatalog .

ind:siteLocationId rdf:type rdf:Property ;
    rdfs:label 'Site Location Id' ;
    rdfs:comment 'Reference to the construction site or warehouse location where the materials were physically received and stored.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SiteLocation .

ind:deliveryCompletedFlag rdf:type rdf:Property ;
    rdfs:label 'Delivery Completed Flag' ;
    rdfs:comment 'Indicates whether this goods receipt completes the delivery for the purchase order line item (True=complete, False=partial delivery expected).' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:grDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Gr Document Number' ;
    rdfs:comment 'Unique business document number assigned to this goods receipt transaction. Used for audit trail and cross-system reconciliation.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceVerificationStatus rdf:type rdf:Property ;
    rdfs:label 'Invoice Verification Status' ;
    rdfs:comment 'Status of three-way match process comparing PO, goods receipt, and vendor invoice. Determines whether invoice can be paid.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Material Document Number' ;
    rdfs:comment 'SAP material document number generated upon goods receipt posting. Used for inventory movement tracking and financial integration.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:movementType rdf:type rdf:Property ;
    rdfs:label 'Movement Type' ;
    rdfs:comment 'SAP movement type code indicating the type of inventory transaction (e.g., 101=GR for PO, 122=Return Delivery). Determines financial and inventory impact.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderedQuantity rdf:type rdf:Property ;
    rdfs:label 'Ordered Quantity' ;
    rdfs:comment 'Quantity of material originally ordered on the purchase order line item. Used for variance analysis against received quantity.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:poLineItemNumber rdf:type rdf:Property ;
    rdfs:label 'Po Line Item Number' ;
    rdfs:comment 'Line item number on the purchase order to which this goods receipt applies. Enables line-level three-way match.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:receivedQuantity rdf:type rdf:Property ;
    rdfs:label 'Received Quantity' ;
    rdfs:comment 'Actual quantity of material physically received and accepted. This is the quantity that updates inventory and triggers invoice verification.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:receivingInspectorName rdf:type rdf:Property ;
    rdfs:label 'Receiving Inspector Name' ;
    rdfs:comment 'Full name of the receiving inspector who verified and accepted the delivery. Provides human-readable reference for audit and accountability.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rejectedQuantity rdf:type rdf:Property ;
    rdfs:label 'Rejected Quantity' ;
    rdfs:comment 'Quantity of material rejected due to quality issues, damage, or non-conformance. Triggers vendor return or credit memo process.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reversalDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Reversal Document Number' ;
    rdfs:comment 'Document number of the reversal transaction if this goods receipt was cancelled. Used for audit trail and reconciliation.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversalReason rdf:type rdf:Property ;
    rdfs:label 'Reversal Reason' ;
    rdfs:comment 'Reason code or description explaining why the goods receipt was reversed (e.g., incorrect posting, return to vendor, data entry error).' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trackingNumber rdf:type rdf:Property ;
    rdfs:label 'Tracking Number' ;
    rdfs:comment 'Shipment tracking number provided by the carrier. Enables real-time delivery status monitoring and proof of delivery.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transportationMode rdf:type rdf:Property ;
    rdfs:label 'Transportation Mode' ;
    rdfs:comment 'Method of transportation used to deliver the materials (truck, rail, air, sea, courier, pickup). Used for logistics analysis and lead time optimization.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unloadingPoint rdf:type rdf:Property ;
    rdfs:label 'Unloading Point' ;
    rdfs:comment 'Specific unloading dock, gate, or receiving area where the materials were delivered at the construction site.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valuationType rdf:type rdf:Property ;
    rdfs:label 'Valuation Type' ;
    rdfs:comment 'Material valuation category used for inventory accounting (e.g., standard cost, moving average price). Determines how the receipt is valued financially.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:varianceNotes rdf:type rdf:Property ;
    rdfs:label 'Variance Notes' ;
    rdfs:comment 'Free-text notes explaining any discrepancies, damages, or special conditions observed during goods receipt. Used for dispute resolution and vendor performance tracking.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:varianceReasonCode rdf:type rdf:Property ;
    rdfs:label 'Variance Reason Code' ;
    rdfs:comment 'Code indicating the reason for any variance between ordered and received quantities (e.g., short shipment, over delivery, damaged goods).' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionReleaseId rdf:type rdf:Property ;
    rdfs:label 'Inspection Release Id' ;
    rdfs:comment 'Unique identifier for the inspection release record. Primary key for vendor quality compliance and documentation tracking.' ;
    rdfs:domain ind:InspectionRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:aconexTransmittalReference rdf:type rdf:Property ;
    rdfs:label 'Aconex Transmittal Reference' ;
    rdfs:comment 'Reference number for the Aconex document transmittal through which the inspection documents were formally submitted and distributed.' ;
    rdfs:domain ind:InspectionRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:asBuiltDrawingDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'As Built Drawing Document Number' ;
    rdfs:comment 'Document control number for as-built drawings submitted by vendor showing final fabricated dimensions and configurations.' ;
    rdfs:domain ind:InspectionRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentReviewDate rdf:type rdf:Property ;
    rdfs:label 'Document Review Date' ;
    rdfs:comment 'Date when the document review was completed and approval status was assigned.' ;
    rdfs:domain ind:InspectionRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:documentReviewStatus rdf:type rdf:Property ;
    rdfs:label 'Document Review Status' ;
    rdfs:comment 'Current review status of the vendor-submitted inspection and technical documents. Tracks document approval workflow.' ;
    rdfs:domain ind:InspectionRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentReviewerName rdf:type rdf:Property ;
    rdfs:label 'Document Reviewer Name' ;
    rdfs:comment 'Name of the engineer or QA/QC specialist who reviewed and approved the inspection documentation.' ;
    rdfs:domain ind:InspectionRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentRevisionNumber rdf:type rdf:Property ;
    rdfs:label 'Document Revision Number' ;
    rdfs:comment 'Revision identifier for the inspection documentation package. Tracks version control for resubmissions and updates.' ;
    rdfs:domain ind:InspectionRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentSubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Document Submission Date' ;
    rdfs:comment 'Date when the vendor submitted the inspection documentation package for review.' ;
    rdfs:domain ind:InspectionRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:equipmentTagNumber rdf:type rdf:Property ;
    rdfs:label 'Equipment Tag Number' ;
    rdfs:comment 'Unique tag identifier for the specific equipment unit being inspected. Used for traceability in MEP and major equipment installations.' ;
    rdfs:domain ind:InspectionRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Inspection Order Number' ;
    rdfs:comment 'Business identifier for the inspection order issued to vendor or third-party inspector. Format: IO-YYYYNNNN.' ;
    rdfs:domain ind:InspectionRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionRemarks rdf:type rdf:Property ;
    rdfs:label 'Inspection Remarks' ;
    rdfs:comment 'Free-text field for inspector comments, observations, special conditions, or additional notes regarding the inspection findings.' ;
    rdfs:domain ind:InspectionRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionReportDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Inspection Report Document Number' ;
    rdfs:comment 'Document control number for the formal inspection report. Links to document management system for full report retrieval.' ;
    rdfs:domain ind:InspectionRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionResult rdf:type rdf:Property ;
    rdfs:label 'Inspection Result' ;
    rdfs:comment 'Overall outcome of the inspection. Pass indicates full compliance, conditional pass indicates minor non-conformances with agreed remediation, fail indicates rejection, pending retest indicates awaiting re-inspection.' ;
    rdfs:domain ind:InspectionRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionWitnessRequired rdf:type rdf:Property ;
    rdfs:label 'Inspection Witness Required' ;
    rdfs:comment 'Flag indicating whether client or third-party witness is contractually required to be present during inspection. True if witness hold point is specified in ITP.' ;
    rdfs:domain ind:InspectionRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inspectorName rdf:type rdf:Property ;
    rdfs:label 'Inspector Name' ;
    rdfs:comment 'Full name of the inspector or inspection agency representative who performed the inspection. May be internal QA/QC staff, third-party inspector, or client representative.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectorOrganization rdf:type rdf:Property ;
    rdfs:label 'Inspector Organization' ;
    rdfs:comment 'Name of the organization or agency that performed the inspection (e.g., internal QA/QC team, third-party inspection agency, client representative).' ;
    rdfs:domain ind:InspectionRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:itpReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Itp Reference Number' ;
    rdfs:comment 'Reference to the approved Inspection and Test Plan document that defines the inspection requirements and hold points for this material or equipment.' ;
    rdfs:domain ind:InspectionRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialDataSheetDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Material Data Sheet Document Number' ;
    rdfs:comment 'Document control number for the vendor-submitted material data sheet. Contains material properties, composition, and technical characteristics.' ;
    rdfs:domain ind:InspectionRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:millCertificateDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Mill Certificate Document Number' ;
    rdfs:comment 'Document control number for the mill test certificate (MTC) or material test report (MTR) provided by the manufacturer. Critical for material traceability.' ;
    rdfs:domain ind:InspectionRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ncrCount rdf:type rdf:Property ;
    rdfs:label 'Ncr Count' ;
    rdfs:comment 'Number of Non-Conformance Reports raised during this inspection. Zero indicates full compliance with specifications.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:omManualDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Om Manual Document Number' ;
    rdfs:comment 'Document control number for the vendor-submitted Operations and Maintenance manual. Required for equipment handover and commissioning.' ;
    rdfs:domain ind:InspectionRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:punchListItems rdf:type rdf:Property ;
    rdfs:label 'Punch List Items' ;
    rdfs:comment 'Comma-separated list or detailed description of outstanding punch list items, deficiencies, or minor non-conformances identified during inspection that require remediation before final release.' ;
    rdfs:domain ind:InspectionRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:releaseCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Release Certificate Number' ;
    rdfs:comment 'Unique certificate number issued upon successful inspection, authorizing shipment or installation. Format: RC-YYYYNNNN. Required before goods can be shipped to site.' ;
    rdfs:domain ind:InspectionRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipmentAuthorizationDate rdf:type rdf:Property ;
    rdfs:label 'Shipment Authorization Date' ;
    rdfs:comment 'Date when the vendor was formally authorized to ship the inspected materials to the construction site following successful inspection release.' ;
    rdfs:domain ind:InspectionRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:technicalSpecificationReference rdf:type rdf:Property ;
    rdfs:label 'Technical Specification Reference' ;
    rdfs:comment 'Reference to the technical specification document or drawing number against which the inspection was performed.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testReportDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Test Report Document Number' ;
    rdfs:comment 'Document control number for laboratory or field test reports (e.g., NDT reports, hydrostatic test reports, performance test reports).' ;
    rdfs:domain ind:InspectionRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:witnessOrganization rdf:type rdf:Property ;
    rdfs:label 'Witness Organization' ;
    rdfs:comment 'Name of the client organization or third-party entity that witnessed the inspection, if witness was required.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:witnessRepresentativeName rdf:type rdf:Property ;
    rdfs:label 'Witness Representative Name' ;
    rdfs:comment 'Name of the individual representative from the witness organization who attended the inspection.' ;
    rdfs:domain ind:InspectionRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:procurementMaterialMasterId rdf:type rdf:Property ;
    rdfs:label 'Procurement Material Master Id' ;
    rdfs:comment 'Unique identifier for the material master record in the procurement catalog. Primary key for the material catalog product.' ;
    rdfs:domain ind:MaterialCatalog ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Master .

ind:abcClassification rdf:type rdf:Property ;
    rdfs:label 'Abc Classification' ;
    rdfs:comment 'Inventory classification based on value and consumption frequency. A=High value/critical items requiring tight control, B=Moderate value, C=Low value/high volume items. Drives inventory policy and cycle counting frequency.' ;
    rdfs:domain ind:MaterialCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alternativeUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Alternative Unit Of Measure' ;
    rdfs:comment 'Secondary unit of measure for materials that can be ordered or issued in multiple units (e.g., cement ordered in bags but tracked in tons). Supports conversion factor calculations.' ;
    rdfs:domain ind:MaterialCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baseUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Base Unit Of Measure' ;
    rdfs:comment 'Primary unit of measure for material quantity tracking, ordering, and inventory management. Aligns with industry standards for construction materials (EA=Each, M=Meter, M2=Square Meter, M3=Cubic Meter, KG=Kilogram, TON=Metric Ton). [ENUM-REF-CANDIDATE: EA|M|M2|M3|KG|TON|L|GAL|FT|YD|LB|BAG|BOX|ROLL — 14 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:MaterialCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bimObjectReference rdf:type rdf:Property ;
    rdfs:label 'Bim Object Reference' ;
    rdfs:comment 'Unique identifier linking the material to its corresponding 3D object in BIM 360 or other BIM platforms. Enables digital twin integration and clash detection during design and construction phases.' ;
    rdfs:domain ind:MaterialCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCurrency rdf:type rdf:Property ;
    rdfs:label 'Cost Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for standard cost (e.g., USD, EUR, GBP). Supports multi-currency procurement and financial consolidation.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countryOfOrigin rdf:type rdf:Property ;
    rdfs:label 'Country Of Origin' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code indicating where the material is manufactured or sourced. Required for customs compliance, trade regulations, and local content reporting.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:createdDate rdf:type rdf:Property ;
    rdfs:label 'Created Date' ;
    rdfs:comment 'Date when the material master record was first created in the system. Used for audit trail and master data governance.' ;
    rdfs:domain ind:MaterialCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:customsTariffNumber rdf:type rdf:Property ;
    rdfs:label 'Customs Tariff Number' ;
    rdfs:comment 'Harmonized System (HS) code for international trade classification. Used for customs clearance, duty calculation, and import/export documentation for cross-border procurement.' ;
    rdfs:domain ind:MaterialCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dimensionUnit rdf:type rdf:Property ;
    rdfs:label 'Dimension Unit' ;
    rdfs:comment 'Unit of measure for length, width, and height dimensions. Typically meters (M) for construction industry standards.' ;
    rdfs:domain ind:MaterialCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:environmentalCertification rdf:type rdf:Property ;
    rdfs:label 'Environmental Certification' ;
    rdfs:comment 'Environmental sustainability certification held by the material (e.g., LEED certified, FSC certified, Energy Star). Supports green building requirements and sustainability reporting.' ;
    rdfs:domain ind:MaterialCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grossWeight rdf:type rdf:Property ;
    rdfs:label 'Gross Weight' ;
    rdfs:comment 'Total weight of the material including packaging, measured in kilograms. Used for logistics planning, transportation cost calculation, and site delivery scheduling.' ;
    rdfs:domain ind:MaterialCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hazardClass rdf:type rdf:Property ;
    rdfs:label 'Hazard Class' ;
    rdfs:comment 'UN hazard classification code for hazardous materials (e.g., Class 3 Flammable Liquids, Class 8 Corrosives). Required for transportation, storage, and safety data sheet (SDS) compliance.' ;
    rdfs:domain ind:MaterialCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:height rdf:type rdf:Property ;
    rdfs:label 'Height' ;
    rdfs:comment 'Height dimension of the material in meters. Essential for volume calculations and warehouse stacking constraints.' ;
    rdfs:domain ind:MaterialCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastModifiedDate rdf:type rdf:Property ;
    rdfs:label 'Last Modified Date' ;
    rdfs:comment 'Date when the material master record was last updated. Tracks data currency and supports change management processes.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:length rdf:type rdf:Property ;
    rdfs:label 'Length' ;
    rdfs:comment 'Length dimension of the material in meters. Critical for structural materials (beams, pipes, cables) and storage space planning.' ;
    rdfs:domain ind:MaterialCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:manufacturerPartNumber rdf:type rdf:Property ;
    rdfs:label 'Manufacturer Part Number' ;
    rdfs:comment 'Manufacturer\'s unique part number or model code for the material. Critical for exact specification matching, warranty claims, and spare parts procurement.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialGroup rdf:type rdf:Property ;
    rdfs:label 'Material Group' ;
    rdfs:comment 'Classification code grouping materials by procurement category (e.g., concrete, steel, MEP equipment, PPE). Used for procurement strategy, vendor assignment, and spend analysis.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialNumber rdf:type rdf:Property ;
    rdfs:label 'Material Number' ;
    rdfs:comment 'Unique business identifier for the material as defined in SAP MM Material Master. This is the externally-known code used across MTO (Material Take-Off), PO (Purchase Order), and goods receipt processes.' ;
    rdfs:domain ind:MaterialCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialStatus rdf:type rdf:Property ;
    rdfs:label 'Material Status' ;
    rdfs:comment 'Current lifecycle status of the material in the catalog. Controls procurement eligibility and inventory transactions. Blocked materials cannot be ordered; obsolete materials are phased out.' ;
    rdfs:domain ind:MaterialCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumOrderQuantity rdf:type rdf:Property ;
    rdfs:label 'Minimum Order Quantity' ;
    rdfs:comment 'Smallest quantity that can be ordered from suppliers in base unit of measure. Drives procurement batch sizing and inventory optimization.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netWeight rdf:type rdf:Property ;
    rdfs:label 'Net Weight' ;
    rdfs:comment 'Weight of the material excluding packaging, measured in kilograms. Used for material quantity verification and yield calculations in construction processes.' ;
    rdfs:domain ind:MaterialCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:procurementLeadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Procurement Lead Time Days' ;
    rdfs:comment 'Standard number of days from PO (Purchase Order) issuance to material delivery on site. Used for project scheduling, MRP (Material Requirements Planning), and critical path analysis.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:qualityInspectionRequired rdf:type rdf:Property ;
    rdfs:label 'Quality Inspection Required' ;
    rdfs:comment 'Flag indicating whether incoming goods receipt requires quality inspection per ITP (Inspection and Test Plan) before acceptance. Triggers QA/QC workflow in goods receipt process.' ;
    rdfs:domain ind:MaterialCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:shortDescription rdf:type rdf:Property ;
    rdfs:label 'Short Description' ;
    rdfs:comment 'Abbreviated description of the material for display in transaction screens, reports, and mobile applications. Limited to 40 characters for operational efficiency.' ;
    rdfs:domain ind:MaterialCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardCost rdf:type rdf:Property ;
    rdfs:label 'Standard Cost' ;
    rdfs:comment 'Baseline unit cost of the material used for project budgeting, cost estimation, and variance analysis. Updated periodically based on procurement history and market conditions.' ;
    rdfs:domain ind:MaterialCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:storageCondition rdf:type rdf:Property ;
    rdfs:label 'Storage Condition' ;
    rdfs:comment 'Required environmental conditions for material storage to maintain quality and safety. Drives warehouse zone assignment and inventory handling procedures. [ENUM-REF-CANDIDATE: ambient|climate_controlled|refrigerated|dry|ventilated|hazmat_certified|outdoor_covered|outdoor_uncovered — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:MaterialCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valuationClass rdf:type rdf:Property ;
    rdfs:label 'Valuation Class' ;
    rdfs:comment 'SAP valuation class code linking material to general ledger (GL) accounts for inventory valuation and cost of goods sold (COGS) posting. Drives financial accounting integration.' ;
    rdfs:domain ind:MaterialCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:volume rdf:type rdf:Property ;
    rdfs:label 'Volume' ;
    rdfs:comment 'Volumetric measurement of the material in cubic meters. Used for bulk materials (concrete, aggregates) and transportation capacity planning.' ;
    rdfs:domain ind:MaterialCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volumeUnit rdf:type rdf:Property ;
    rdfs:label 'Volume Unit' ;
    rdfs:comment 'Unit of measure for volume field. Typically cubic meters (M3) for construction bulk materials.' ;
    rdfs:domain ind:MaterialCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:weightUnit rdf:type rdf:Property ;
    rdfs:label 'Weight Unit' ;
    rdfs:comment 'Unit of measure for gross and net weight fields. Typically kilograms (KG) or metric tons (TON) for construction materials.' ;
    rdfs:domain ind:MaterialCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:width rdf:type rdf:Property ;
    rdfs:label 'Width' ;
    rdfs:comment 'Width dimension of the material in meters. Used for area calculations and storage layout planning.' ;
    rdfs:domain ind:MaterialCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:poAmendmentId rdf:type rdf:Property ;
    rdfs:label 'Po Amendment Id' ;
    rdfs:comment 'Unique identifier for the purchase order amendment record. Primary key for the po_amendment product.' ;
    rdfs:domain ind:PoAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approvalWorkflowId rdf:type rdf:Property ;
    rdfs:label 'Approval Workflow Id' ;
    rdfs:comment 'Identifier of the approval workflow instance used to process this amendment. Tracks the routing and authorization path.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ApprovalWorkflow .

ind:amendedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Amended Delivery Date' ;
    rdfs:comment 'The revised delivery or completion date after this amendment. New scheduled milestone post-change.' ;
    rdfs:domain ind:PoAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:amendedPoValue rdf:type rdf:Property ;
    rdfs:label 'Amended Po Value' ;
    rdfs:comment 'The revised total monetary value of the purchase order after this amendment is applied. New committed amount post-change.' ;
    rdfs:domain ind:PoAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:amendedQuantity rdf:type rdf:Property ;
    rdfs:label 'Amended Quantity' ;
    rdfs:comment 'The revised quantity of materials or services after this amendment. New committed quantity post-change.' ;
    rdfs:domain ind:PoAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Budget Impact Flag' ;
    rdfs:comment 'Indicates whether this amendment requires budget reallocation or additional funding approval. True if budget impact exceeds threshold, false otherwise.' ;
    rdfs:domain ind:PoAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:coReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Co Reference Number' ;
    rdfs:comment 'Reference number of the associated Change Order (CO) document if this amendment originated from a formal change order process. Links PO amendment to project change management.' ;
    rdfs:domain ind:PoAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impactOnSchedule rdf:type rdf:Property ;
    rdfs:label 'Impact On Schedule' ;
    rdfs:comment 'Assessment of how this amendment affects the project schedule: no_impact (no schedule change), acceleration (schedule shortened), delay (schedule extended), or critical_path_affected (impacts critical path activities).' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:implementationDate rdf:type rdf:Property ;
    rdfs:label 'Implementation Date' ;
    rdfs:comment 'Date when the amendment was executed and reflected in operational systems (ERP, procurement, scheduling). Tracks system update completion.' ;
    rdfs:domain ind:PoAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:initiatedBy rdf:type rdf:Property ;
    rdfs:label 'Initiated By' ;
    rdfs:comment 'Name or identifier of the person or role who initiated this amendment request. Tracks accountability for change origination.' ;
    rdfs:domain ind:PoAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Original Delivery Date' ;
    rdfs:comment 'The originally scheduled delivery date for materials or completion date for services before this amendment.' ;
    rdfs:domain ind:PoAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:originalPoValue rdf:type rdf:Property ;
    rdfs:label 'Original Po Value' ;
    rdfs:comment 'The total monetary value of the purchase order before this amendment. Baseline amount for calculating value delta.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:originalQuantity rdf:type rdf:Property ;
    rdfs:label 'Original Quantity' ;
    rdfs:comment 'The original quantity of materials or services specified in the purchase order before amendment. Used for quantity change tracking.' ;
    rdfs:domain ind:PoAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityUom rdf:type rdf:Property ;
    rdfs:label 'Quantity Uom' ;
    rdfs:comment 'Unit of measure for quantity fields (e.g., EA for each, TON for tons, M3 for cubic meters, KG for kilograms). Standardizes quantity interpretation.' ;
    rdfs:domain ind:PoAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valueDelta rdf:type rdf:Property ;
    rdfs:label 'Value Delta' ;
    rdfs:comment 'The net change in purchase order value resulting from this amendment (amended_po_value minus original_po_value). Positive indicates increase, negative indicates decrease.' ;
    rdfs:domain ind:PoAmendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:poLineId rdf:type rdf:Property ;
    rdfs:label 'Po Line Id' ;
    rdfs:comment 'Unique identifier for the purchase order line item. Primary key for the PO line entity.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accountAssignmentCategory rdf:type rdf:Property ;
    rdfs:label 'Account Assignment Category' ;
    rdfs:comment 'SAP account assignment category indicating how costs are allocated: K=Cost Center, A=Asset, F=Order, P=Project, N=Network, U=Unknown. Determines financial posting logic.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:buyerName rdf:type rdf:Property ;
    rdfs:label 'Buyer Name' ;
    rdfs:comment 'Name of the procurement professional responsible for sourcing and purchasing this line item. Used for vendor communication and procurement accountability.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deletionIndicator rdf:type rdf:Property ;
    rdfs:label 'Deletion Indicator' ;
    rdfs:comment 'Boolean flag indicating whether this line item has been marked for deletion. True if the line is logically deleted but retained for audit purposes.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deliveryDate rdf:type rdf:Property ;
    rdfs:label 'Delivery Date' ;
    rdfs:comment 'The scheduled or requested delivery date for the material or completion date for the service on this line item. Critical for project scheduling and material planning.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:freeTextNote rdf:type rdf:Property ;
    rdfs:label 'Free Text Note' ;
    rdfs:comment 'Additional free-form notes or special instructions related to this line item, such as quality requirements, packaging instructions, or delivery constraints.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:goodsReceiptIndicator rdf:type rdf:Property ;
    rdfs:label 'Goods Receipt Indicator' ;
    rdfs:comment 'Boolean flag indicating whether a goods receipt is required for this line item. True if GR is mandatory before invoice processing.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:incoterms rdf:type rdf:Property ;
    rdfs:label 'Incoterms' ;
    rdfs:comment 'Standard trade terms defining the responsibilities of buyers and sellers for delivery, insurance, and risk transfer per ICC Incoterms 2020. [ENUM-REF-CANDIDATE: EXW|FCA|CPT|CIP|DAP|DPU|DDP|FAS|FOB|CFR|CIF — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incotermsLocation rdf:type rdf:Property ;
    rdfs:label 'Incoterms Location' ;
    rdfs:comment 'The specific named place or port associated with the Incoterms designation, defining the point of delivery or risk transfer.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceReceiptIndicator rdf:type rdf:Property ;
    rdfs:label 'Invoice Receipt Indicator' ;
    rdfs:comment 'Boolean flag indicating whether invoice verification is required for this line item. True if IR is mandatory for payment processing.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:invoicedQuantity rdf:type rdf:Property ;
    rdfs:label 'Invoiced Quantity' ;
    rdfs:comment 'The cumulative quantity that has been invoiced to date against this line item. Used for three-way matching and payment reconciliation.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:itemCategory rdf:type rdf:Property ;
    rdfs:label 'Item Category' ;
    rdfs:comment 'Classification of the line item type indicating the procurement scenario: standard purchase, service procurement, consignment, subcontracting, or stock transfer.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineStatus rdf:type rdf:Property ;
    rdfs:label 'Line Status' ;
    rdfs:comment 'Current lifecycle status of the purchase order line item indicating its fulfillment state: open (not yet received), partially received, fully received, closed (completed), or cancelled.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netValue rdf:type rdf:Property ;
    rdfs:label 'Net Value' ;
    rdfs:comment 'The total net value of this line item calculated as ordered quantity multiplied by unit price, before taxes and discounts.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:outstandingQuantity rdf:type rdf:Property ;
    rdfs:label 'Outstanding Quantity' ;
    rdfs:comment 'The remaining quantity yet to be delivered, calculated as ordered quantity minus goods receipt quantity. Critical for expediting and delivery monitoring.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overDeliveryTolerancePercent rdf:type rdf:Property ;
    rdfs:label 'Over Delivery Tolerance Percent' ;
    rdfs:comment 'The acceptable percentage by which the vendor may over-deliver beyond the ordered quantity without requiring approval. Used for goods receipt tolerance checking.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plantCode rdf:type rdf:Property ;
    rdfs:label 'Plant Code' ;
    rdfs:comment 'The plant or site location code where the material will be delivered or the service will be performed. Used for multi-site inventory and logistics management.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceUnit rdf:type rdf:Property ;
    rdfs:label 'Price Unit' ;
    rdfs:comment 'The quantity of units to which the unit price applies (e.g., price per 1, per 10, per 100 units). Used for bulk pricing scenarios.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:requisitionerName rdf:type rdf:Property ;
    rdfs:label 'Requisitioner Name' ;
    rdfs:comment 'Name of the person or department who requested this material or service, used for accountability and follow-up communication.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shortText rdf:type rdf:Property ;
    rdfs:label 'Short Text' ;
    rdfs:comment 'Brief descriptive text for the line item, typically used for quick identification and reporting purposes.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:underDeliveryTolerancePercent rdf:type rdf:Property ;
    rdfs:label 'Under Delivery Tolerance Percent' ;
    rdfs:comment 'The acceptable percentage by which the vendor may under-deliver below the ordered quantity without penalty. Used for goods receipt tolerance checking.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vendorMaterialNumber rdf:type rdf:Property ;
    rdfs:label 'Vendor Material Number' ;
    rdfs:comment 'The suppliers own material or part number for the item being procured. Used for cross-referencing and supplier communication.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:procurementFrameworkAgreementId rdf:type rdf:Property ;
    rdfs:label 'Procurement Framework Agreement Id' ;
    rdfs:comment 'Unique identifier for the procurement framework agreement record. Primary key.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProcurementFrameworkAgreement .

ind:primaryProcurementEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Procurement Employee Id' ;
    rdfs:comment 'Reference to the procurement professional or buyer responsible for managing this framework agreement.' ;
    rdfs:domain ind:ProcurementFrameworkAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:agreementName rdf:type rdf:Property ;
    rdfs:label 'Agreement Name' ;
    rdfs:comment 'Descriptive name or title of the framework agreement for easy identification and reference (e.g., \'Concrete Supply Framework 2024-2026\').' ;
    rdfs:domain ind:ProcurementFrameworkAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:autoRenewalFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Renewal Flag' ;
    rdfs:comment 'Indicates whether this framework agreement automatically renews upon expiration unless explicitly terminated (True) or requires explicit renewal action (False).' ;
    rdfs:domain ind:ProcurementFrameworkAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:callOffMechanism rdf:type rdf:Property ;
    rdfs:label 'Call Off Mechanism' ;
    rdfs:comment 'Method by which individual purchase orders or material releases are issued against this framework agreement (PO against agreement, release order, direct call-off, scheduled delivery, or project allocation).' ;
    rdfs:domain ind:ProcurementFrameworkAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commodityCategoryCode rdf:type rdf:Property ;
    rdfs:label 'Commodity Category Code' ;
    rdfs:comment 'Classification code identifying the procurement category or commodity group covered by this framework agreement (e.g., concrete, formwork, scaffolding, PPE, steel reinforcement).' ;
    rdfs:domain ind:ProcurementFrameworkAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commodityCategoryDescription rdf:type rdf:Property ;
    rdfs:label 'Commodity Category Description' ;
    rdfs:comment 'Detailed description of the commodity or material category covered under this framework agreement.' ;
    rdfs:domain ind:ProcurementFrameworkAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceCertificationsRequired rdf:type rdf:Property ;
    rdfs:label 'Compliance Certifications Required' ;
    rdfs:comment 'List of mandatory compliance certifications, standards, or regulatory approvals required for materials or services procured under this framework agreement (e.g., ISO certifications, LEED compliance, OSHA standards).' ;
    rdfs:domain ind:ProcurementFrameworkAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumCommitmentValue rdf:type rdf:Property ;
    rdfs:label 'Maximum Commitment Value' ;
    rdfs:comment 'Maximum financial commitment or ceiling amount that can be procured under this framework agreement over its entire validity period.' ;
    rdfs:domain ind:ProcurementFrameworkAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maximumOrderQuantity rdf:type rdf:Property ;
    rdfs:label 'Maximum Order Quantity' ;
    rdfs:comment 'Maximum quantity that can be ordered in a single call-off or purchase order under this framework agreement.' ;
    rdfs:domain ind:ProcurementFrameworkAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pricingScheduleReference rdf:type rdf:Property ;
    rdfs:label 'Pricing Schedule Reference' ;
    rdfs:comment 'Reference identifier or document number for the detailed pricing schedule, rate card, or price list associated with this framework agreement.' ;
    rdfs:domain ind:ProcurementFrameworkAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:procurementOrganizationCode rdf:type rdf:Property ;
    rdfs:label 'Procurement Organization Code' ;
    rdfs:comment 'Code identifying the procurement organization or business unit that owns and manages this framework agreement.' ;
    rdfs:domain ind:ProcurementFrameworkAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityRequirements rdf:type rdf:Property ;
    rdfs:label 'Quality Requirements' ;
    rdfs:comment 'Quality assurance and quality control standards, specifications, and requirements that materials or services under this framework agreement must meet.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalTerms rdf:type rdf:Property ;
    rdfs:label 'Renewal Terms' ;
    rdfs:comment 'Terms and conditions governing the renewal or extension of this framework agreement, including notice periods, renewal options, and conditions.' ;
    rdfs:domain ind:ProcurementFrameworkAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sustainabilityCriteria rdf:type rdf:Property ;
    rdfs:label 'Sustainability Criteria' ;
    rdfs:comment 'Environmental and sustainability requirements or preferences specified in the framework agreement, such as recycled content, carbon footprint limits, or LEED material requirements.' ;
    rdfs:domain ind:ProcurementFrameworkAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminationNoticePeriodDays rdf:type rdf:Property ;
    rdfs:label 'Termination Notice Period Days' ;
    rdfs:comment 'Number of days advance notice required by either party to terminate this framework agreement before its natural expiration.' ;
    rdfs:domain ind:ProcurementFrameworkAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalSpendToDate rdf:type rdf:Property ;
    rdfs:label 'Total Spend To Date' ;
    rdfs:comment 'Cumulative monetary value of all purchase orders and call-offs issued against this framework agreement since its effective start date.' ;
    rdfs:domain ind:ProcurementFrameworkAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:utilizationPercentage rdf:type rdf:Property ;
    rdfs:label 'Utilization Percentage' ;
    rdfs:comment 'Percentage of the maximum commitment value that has been utilized through purchase orders and call-offs to date.' ;
    rdfs:domain ind:ProcurementFrameworkAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:buyerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Buyer Employee Id' ;
    rdfs:comment 'Foreign key linking to hr.employee. Business justification: Required for PO creation audit; links PO buyer to employee responsible for issuance, used in spend analysis and compliance reports.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:purchaseRequisitionId rdf:type rdf:Property ;
    rdfs:label 'Purchase Requisition Id' ;
    rdfs:comment 'Foreign key linking to procurement.purchase_requisition. Business justification: Add link from purchase order to its originating purchase requisition to capture parent-child relationship.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PurchaseRequisition .

ind:cumulativeAmendmentValue rdf:type rdf:Property ;
    rdfs:label 'Cumulative Amendment Value' ;
    rdfs:comment 'Net change in purchase order value resulting from all amendments and change orders (positive or negative delta from original value).' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:currentRevisionNumber rdf:type rdf:Property ;
    rdfs:label 'Current Revision Number' ;
    rdfs:comment 'Revision number tracking minor corrections or clarifications within the current version. Used for document control and audit trail.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:currentVersionNumber rdf:type rdf:Property ;
    rdfs:label 'Current Version Number' ;
    rdfs:comment 'Version number of the purchase order reflecting amendments and change orders. Increments with each approved modification.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deliveryAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Delivery Address Line1' ;
    rdfs:comment 'Primary street address line for material or equipment delivery to construction site or warehouse.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Delivery Address Line2' ;
    rdfs:comment 'Secondary address line for delivery location (building, floor, gate number, or site-specific instructions).' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryCity rdf:type rdf:Property ;
    rdfs:label 'Delivery City' ;
    rdfs:comment 'City or municipality for delivery destination.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryCountryCode rdf:type rdf:Property ;
    rdfs:label 'Delivery Country Code' ;
    rdfs:comment 'Three-letter ISO country code for delivery destination (e.g., USA, CAN, GBR).' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryPostalCode rdf:type rdf:Property ;
    rdfs:label 'Delivery Postal Code' ;
    rdfs:comment 'Postal or ZIP code for delivery destination.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryStateProvince rdf:type rdf:Property ;
    rdfs:label 'Delivery State Province' ;
    rdfs:comment 'State, province, or region for delivery destination.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gmpAmount rdf:type rdf:Property ;
    rdfs:label 'Gmp Amount' ;
    rdfs:comment 'The contractual ceiling amount for this purchase order when GMP terms apply. Vendor cannot exceed this amount without approved change orders.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gmpFlag rdf:type rdf:Property ;
    rdfs:label 'Gmp Flag' ;
    rdfs:comment 'Indicates whether this purchase order is subject to a Guaranteed Maximum Price contract, capping the total cost exposure.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:issuedDate rdf:type rdf:Property ;
    rdfs:label 'Issued Date' ;
    rdfs:comment 'Date on which the purchase order was formally issued to the vendor. Marks the start of the contractual commitment.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastAmendmentType rdf:type rdf:Property ;
    rdfs:label 'Last Amendment Type' ;
    rdfs:comment 'Classification of the most recent amendment: scope change, quantity adjustment, price revision, delivery reschedule, formal change order, or terms modification.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:poStatus rdf:type rdf:Property ;
    rdfs:label 'Po Status' ;
    rdfs:comment 'Current lifecycle status of the purchase order in the procurement workflow. Tracks progression from draft through approval, issuance, receipt, and closure. [ENUM-REF-CANDIDATE: draft|pending_approval|approved|issued|acknowledged|in_progress|partially_received|fully_received|closed|cancelled — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:poType rdf:type rdf:Property ;
    rdfs:label 'Po Type' ;
    rdfs:comment 'Classification of purchase order by procurement pattern: standard (one-time material/equipment), blanket (recurring supply agreement), framework (multi-project master agreement), subcontract (labor/construction services), service (professional services), rental (equipment lease).' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promisedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Promised Delivery Date' ;
    rdfs:comment 'Vendor-committed delivery date as confirmed in purchase order acknowledgment. Used for schedule risk assessment and expediting.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requestedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Requested Delivery Date' ;
    rdfs:comment 'Target date by which materials, equipment, or services are required on site. Used for procurement lead time planning and CPM schedule integration.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sapDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Document Number' ;
    rdfs:comment 'SAP MM system-generated unique document number for this purchase order. Used for ERP integration and cross-system reconciliation.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalPoValue rdf:type rdf:Property ;
    rdfs:label 'Total Po Value' ;
    rdfs:comment 'Total monetary value of the purchase order including all line items, taxes, and charges. Expressed in the currency specified by currency_code.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:requestorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Requestor Employee Id' ;
    rdfs:comment 'Foreign key linking to hr.employee. Business justification: Identifies the employee who raised the PR; needed for requisition approval workflow and spend accountability.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:budgetAvailableFlag rdf:type rdf:Property ;
    rdfs:label 'Budget Available Flag' ;
    rdfs:comment 'Indicates whether sufficient budget is available in the assigned WBS element or cost center to cover the estimated cost of this requisition. True if budget is available, False if insufficient.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:conversionDate rdf:type rdf:Property ;
    rdfs:label 'Conversion Date' ;
    rdfs:comment 'Date when the purchase requisition was converted to an RFQ or PO document.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:conversionStatus rdf:type rdf:Property ;
    rdfs:label 'Conversion Status' ;
    rdfs:comment 'Indicates whether and how the approved purchase requisition has been converted into downstream procurement documents (RFQ for competitive bidding or direct PO for known vendors).' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:convertedDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Converted Document Number' ;
    rdfs:comment 'Document number of the RFQ or PO that was created from this purchase requisition, establishing traceability through the procurement lifecycle.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentApproverName rdf:type rdf:Property ;
    rdfs:label 'Current Approver Name' ;
    rdfs:comment 'Name of the individual currently responsible for reviewing and approving the purchase requisition in the workflow sequence.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedTotalCost rdf:type rdf:Property ;
    rdfs:label 'Estimated Total Cost' ;
    rdfs:comment 'Total estimated cost for the requisition line, calculated as quantity multiplied by estimated unit cost. Used for budget availability verification.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedUnitCost rdf:type rdf:Property ;
    rdfs:label 'Estimated Unit Cost' ;
    rdfs:comment 'Estimated cost per unit of the requested material or service, used for budget checking and preliminary cost estimation.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:justificationNotes rdf:type rdf:Property ;
    rdfs:label 'Justification Notes' ;
    rdfs:comment 'Business justification and rationale for the purchase requisition, including project need, schedule impact, and any special circumstances requiring expedited processing.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mtoReference rdf:type rdf:Property ;
    rdfs:label 'Mto Reference' ;
    rdfs:comment 'Reference to the Material Take-Off document or line item from which this requisition was derived, linking procurement to engineering quantity estimates.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prNumber rdf:type rdf:Property ;
    rdfs:label 'Pr Number' ;
    rdfs:comment 'Business identifier for the purchase requisition, externally visible and used in procurement workflows and communications.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prStatus rdf:type rdf:Property ;
    rdfs:label 'Pr Status' ;
    rdfs:comment 'Current lifecycle status of the purchase requisition in the approval and conversion workflow. [ENUM-REF-CANDIDATE: draft|pending_approval|approved|rejected|converted|cancelled|closed — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prType rdf:type rdf:Property ;
    rdfs:label 'Pr Type' ;
    rdfs:comment 'Classification of the purchase requisition based on procurement category: standard materials, subcontract services, general services, stock transfers between sites, consignment arrangements, or equipment rental.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredVendorCode rdf:type rdf:Property ;
    rdfs:label 'Preferred Vendor Code' ;
    rdfs:comment 'Vendor code of the preferred or suggested supplier for this requisition, if the requester has a specific vendor recommendation based on prior performance or technical requirements.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:procurementStrategy rdf:type rdf:Property ;
    rdfs:label 'Procurement Strategy' ;
    rdfs:comment 'Sourcing approach to be used for fulfilling this requisition based on value, complexity, vendor availability, and time constraints.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requesterEmail rdf:type rdf:Property ;
    rdfs:label 'Requester Email' ;
    rdfs:comment 'Email address of the requester for communication regarding the purchase requisition status, clarifications, and approvals.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requesterName rdf:type rdf:Property ;
    rdfs:label 'Requester Name' ;
    rdfs:comment 'Full name of the individual who created and submitted the purchase requisition.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestingDepartment rdf:type rdf:Property ;
    rdfs:label 'Requesting Department' ;
    rdfs:comment 'Name or code of the department or functional unit that originated the purchase requisition (e.g., Site Operations, Engineering, Procurement, MEP).' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiredDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Required Delivery Date' ;
    rdfs:comment 'Date by which the requested materials, equipment, or services must be delivered to the project site or requesting location to meet project schedule requirements.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requisitionDate rdf:type rdf:Property ;
    rdfs:label 'Requisition Date' ;
    rdfs:comment 'Date when the purchase requisition was created and submitted by the requesting party. Principal business event timestamp for the requisition.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:technicalSpecificationAttached rdf:type rdf:Property ;
    rdfs:label 'Technical Specification Attached' ;
    rdfs:comment 'Indicates whether detailed technical specifications, drawings, or engineering documents are attached to support the requisition evaluation and vendor quotation process.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:urgencyClassification rdf:type rdf:Property ;
    rdfs:label 'Urgency Classification' ;
    rdfs:comment 'Priority level of the purchase requisition based on project schedule impact and delivery timeline requirements. Emergency requisitions bypass standard approval workflows.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rfqId rdf:type rdf:Property ;
    rdfs:label 'Rfq Id' ;
    rdfs:comment 'Unique identifier for the Request for Quotation record. Primary key for the RFQ entity.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Rfq .

ind:awardedVendorId rdf:type rdf:Property ;
    rdfs:label 'Awarded Vendor Id' ;
    rdfs:comment 'Identifier of the vendor to whom the contract or purchase order was awarded following RFQ evaluation. Null if RFQ is not yet awarded or was cancelled.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vendor .

ind:awardedAmount rdf:type rdf:Property ;
    rdfs:label 'Awarded Amount' ;
    rdfs:comment 'Total monetary value of the contract or purchase order awarded to the winning vendor. Null if RFQ is not yet awarded.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bimReference rdf:type rdf:Property ;
    rdfs:label 'Bim Reference' ;
    rdfs:comment 'Reference to BIM model elements or clash detection reports that vendors should review to ensure dimensional and spatial compatibility of materials or equipment.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:buyerContactEmail rdf:type rdf:Property ;
    rdfs:label 'Buyer Contact Email' ;
    rdfs:comment 'Email address of the buyer or procurement contact for vendor inquiries and quotation submissions.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:buyerContactName rdf:type rdf:Property ;
    rdfs:label 'Buyer Contact Name' ;
    rdfs:comment 'Name of the procurement professional or buyer responsible for managing this RFQ and serving as the primary point of contact for vendors.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:buyerContactPhone rdf:type rdf:Property ;
    rdfs:label 'Buyer Contact Phone' ;
    rdfs:comment 'Phone number of the buyer or procurement contact for urgent vendor communications.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cancellationReason rdf:type rdf:Property ;
    rdfs:label 'Cancellation Reason' ;
    rdfs:comment 'Explanation for why the RFQ was cancelled or withdrawn, if applicable. May include project scope changes, budget constraints, or inadequate vendor response.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invitedVendorCount rdf:type rdf:Property ;
    rdfs:label 'Invited Vendor Count' ;
    rdfs:comment 'Number of vendors invited to submit quotations for this RFQ. Used to track competitive bidding and ensure adequate market coverage.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:issuingDepartment rdf:type rdf:Property ;
    rdfs:label 'Issuing Department' ;
    rdfs:comment 'Name or code of the department or business unit that issued the RFQ, such as Procurement, Project Management, or Engineering.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseCount rdf:type rdf:Property ;
    rdfs:label 'Response Count' ;
    rdfs:comment 'Number of vendor quotations received in response to this RFQ. Indicates level of vendor interest and competitive response.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rfqStatus rdf:type rdf:Property ;
    rdfs:label 'Rfq Status' ;
    rdfs:comment 'Current lifecycle status of the RFQ. Tracks progression from draft creation through vendor response collection to final award or cancellation. [ENUM-REF-CANDIDATE: draft|issued|open|closed|awarded|cancelled|withdrawn — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rfqType rdf:type rdf:Property ;
    rdfs:label 'Rfq Type' ;
    rdfs:comment 'Classification of the RFQ based on the category of procurement: materials (concrete, steel), equipment (cranes, generators), services (engineering, testing), or subcontract work packages.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorPrequalificationRequired rdf:type rdf:Property ;
    rdfs:label 'Vendor Prequalification Required' ;
    rdfs:comment 'Indicates whether vendors must be prequalified or approved before they can submit quotations. Ensures only qualified vendors participate in the bidding process.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rfqLineId rdf:type rdf:Property ;
    rdfs:label 'Rfq Line Id' ;
    rdfs:comment 'Unique identifier for the RFQ line item. Primary key for this entity.' ;
    rdfs:domain ind:RfqLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:preferredVendorId rdf:type rdf:Property ;
    rdfs:label 'Preferred Vendor Id' ;
    rdfs:comment 'Reference to a preferred or pre-qualified vendor for this item, if applicable.' ;
    rdfs:domain ind:RfqLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vendor .

ind:serviceId rdf:type rdf:Property ;
    rdfs:label 'Service Id' ;
    rdfs:comment 'Reference to the service master record when the line item represents a service rather than a material (e.g., engineering, labor, consulting).' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Service .

ind:drawingReference rdf:type rdf:Property ;
    rdfs:label 'Drawing Reference' ;
    rdfs:comment 'Reference to the engineering drawing, CAD file, or design document number that illustrates or specifies this item.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedTotalAmount rdf:type rdf:Property ;
    rdfs:label 'Estimated Total Amount' ;
    rdfs:comment 'The total estimated cost for this line item (quantity × estimated unit price), used for internal budget tracking.' ;
    rdfs:domain ind:RfqLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualityRequirement rdf:type rdf:Property ;
    rdfs:label 'Quality Requirement' ;
    rdfs:comment 'Description of quality standards, certifications, or inspection requirements that the material or service must meet (e.g., ISO 9001, ASTM standards, factory acceptance test).' ;
    rdfs:domain ind:RfqLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceOfSupply rdf:type rdf:Property ;
    rdfs:label 'Source Of Supply' ;
    rdfs:comment 'Indicates the preferred or required sourcing strategy for this item: local, regional, international, preferred vendor, or open market.' ;
    rdfs:domain ind:RfqLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorEvaluationCriteria rdf:type rdf:Property ;
    rdfs:label 'Vendor Evaluation Criteria' ;
    rdfs:comment 'Specific criteria or weighting factors to be used when evaluating vendor quotations for this line item (e.g., price 60%, delivery 20%, quality 20%).' ;
    rdfs:domain ind:RfqLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourcingPlanId rdf:type rdf:Property ;
    rdfs:label 'Sourcing Plan Id' ;
    rdfs:comment 'Primary key for sourcing_plan' ;
    rdfs:domain ind:SourcingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:expeditingFrequency rdf:type rdf:Property ;
    rdfs:label 'Expediting Frequency' ;
    rdfs:comment 'Frequency of expediting reviews and supplier progress checks (e.g., weekly, monthly, milestone-based).' ;
    rdfs:domain ind:SourcingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expeditingMethod rdf:type rdf:Property ;
    rdfs:label 'Expediting Method' ;
    rdfs:comment 'Primary method used for expediting and progress monitoring (e.g., site visits to vendor facility, video conference, third-party inspection).' ;
    rdfs:domain ind:SourcingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expeditingRequired rdf:type rdf:Property ;
    rdfs:label 'Expediting Required' ;
    rdfs:comment 'Indicates whether active expediting and progress monitoring of the supplier is required due to schedule criticality or complexity.' ;
    rdfs:domain ind:SourcingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inspectionRequirements rdf:type rdf:Property ;
    rdfs:label 'Inspection Requirements' ;
    rdfs:comment 'Description of quality inspection and testing requirements for the procured materials or equipment (e.g., FAT, SAT, third-party certification, mill test certificates).' ;
    rdfs:domain ind:SourcingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isLongLeadItem rdf:type rdf:Property ;
    rdfs:label 'Is Long Lead Item' ;
    rdfs:comment 'Indicates whether this sourcing plan covers long-lead items requiring early procurement action due to extended manufacturing or delivery lead times.' ;
    rdfs:domain ind:SourcingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:packagingStrategy rdf:type rdf:Property ;
    rdfs:label 'Packaging Strategy' ;
    rdfs:comment 'Description of how procurement scope is bundled or split into packages for tendering (e.g., single package, split by trade, split by project phase, geographic split).' ;
    rdfs:domain ind:SourcingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedAwardDate rdf:type rdf:Property ;
    rdfs:label 'Planned Award Date' ;
    rdfs:comment 'Target date for awarding the purchase order or contract to the selected supplier. Critical milestone for procurement lead time calculation.' ;
    rdfs:domain ind:SourcingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:plannedBidClosingDate rdf:type rdf:Property ;
    rdfs:label 'Planned Bid Closing Date' ;
    rdfs:comment 'Target date by which vendor bids or proposals are due for evaluation.' ;
    rdfs:domain ind:SourcingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:plannedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Planned Delivery Date' ;
    rdfs:comment 'Target date for material or equipment delivery to site. Must align with construction schedule requirements and site readiness.' ;
    rdfs:domain ind:SourcingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:plannedInstallationDate rdf:type rdf:Property ;
    rdfs:label 'Planned Installation Date' ;
    rdfs:comment 'Target date for installation or commissioning of the procured materials or equipment. Drives backward scheduling of procurement activities.' ;
    rdfs:domain ind:SourcingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:plannedRfqDate rdf:type rdf:Property ;
    rdfs:label 'Planned Rfq Date' ;
    rdfs:comment 'Target date for issuing the RFQ or RFP to potential suppliers. Aligns with project procurement schedule milestones.' ;
    rdfs:domain ind:SourcingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:preferredSupplierList rdf:type rdf:Property ;
    rdfs:label 'Preferred Supplier List' ;
    rdfs:comment 'Comma-separated list of preferred or prequalified supplier names or codes to be invited for this procurement.' ;
    rdfs:domain ind:SourcingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskClassification rdf:type rdf:Property ;
    rdfs:label 'Risk Classification' ;
    rdfs:comment 'Risk level associated with this procurement based on factors such as value, complexity, lead time, supplier market, and schedule impact.' ;
    rdfs:domain ind:SourcingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourcingMethod rdf:type rdf:Property ;
    rdfs:label 'Sourcing Method' ;
    rdfs:comment 'Procurement strategy and method to be used for acquiring the materials or services (e.g., competitive bidding, sole source negotiation, call-off from framework agreement).' ;
    rdfs:domain ind:SourcingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierPrequalificationRequired rdf:type rdf:Property ;
    rdfs:label 'Supplier Prequalification Required' ;
    rdfs:comment 'Indicates whether suppliers must be prequalified before being invited to bid for this procurement.' ;
    rdfs:domain ind:SourcingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:addressLine1 rdf:type rdf:Property ;
    rdfs:label 'Address Line 1' ;
    rdfs:comment 'First line of the vendor\'s registered business address. Typically contains street number and street name. Used for correspondence, legal notices, and payment remittance.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressLine2 rdf:type rdf:Property ;
    rdfs:label 'Address Line 2' ;
    rdfs:comment 'Second line of the vendor\'s business address. Contains suite, floor, building, or other secondary address information. Nullable if not applicable.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:annualRevenueAmount rdf:type rdf:Property ;
    rdfs:label 'Annual Revenue Amount' ;
    rdfs:comment 'Vendor\'s reported annual revenue in the vendor\'s default currency. Used for vendor size classification, capacity assessment, and financial stability evaluation. Typically self-reported or obtained from financial statements.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:auditResult rdf:type rdf:Property ;
    rdfs:label 'Audit Result' ;
    rdfs:comment 'Outcome of the most recent vendor audit. Passed indicates full compliance; passed with conditions indicates minor findings requiring corrective action; failed indicates major non-conformances; not audited indicates no audit has been conducted.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bondingCapacityAmount rdf:type rdf:Property ;
    rdfs:label 'Bonding Capacity Amount' ;
    rdfs:comment 'Maximum bonding capacity available to the vendor in the vendor\'s default currency. Represents the total value of performance bonds and payment bonds the vendor can secure from their surety. Critical for subcontractor prequalification and large contract awards.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:diversityClassification rdf:type rdf:Property ;
    rdfs:label 'Diversity Classification' ;
    rdfs:comment 'Diversity certification status for the vendor. MBE (Minority Business Enterprise), WBE (Women Business Enterprise), DBE (Disadvantaged Business Enterprise), SDVOSB (Service-Disabled Veteran-Owned Small Business), HUBZone (Historically Underutilized Business Zone). Used for diversity spend reporting and compliance with client diversity requirements.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredVendorFlag rdf:type rdf:Property ;
    rdfs:label 'Preferred Vendor Flag' ;
    rdfs:comment 'Boolean flag indicating whether this vendor has preferred vendor status. Preferred vendors receive priority consideration for bid invitations, expedited approval processes, and favorable payment terms based on proven performance and strategic relationship.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:prequalificationScore rdf:type rdf:Property ;
    rdfs:label 'Prequalification Score' ;
    rdfs:comment 'Composite score from the vendor prequalification process evaluating financial stability, technical capability, safety record, quality performance, and past project experience. Scale typically 0-100. Used for vendor ranking and bid invitation decisions.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualityCertification rdf:type rdf:Property ;
    rdfs:label 'Quality Certification' ;
    rdfs:comment 'Quality management system certifications held by the vendor. Common certifications include ISO 9001 (Quality Management), ISO 14001 (Environmental Management), ISO 45001 (Occupational Health and Safety). Multiple certifications separated by semicolons.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationDate rdf:type rdf:Property ;
    rdfs:label 'Registration Date' ;
    rdfs:comment 'Date when the vendor was first registered in the vendor master system. Marks the beginning of the vendor relationship and is used for vendor tenure analysis and anniversary tracking.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:suspensionEndDate rdf:type rdf:Property ;
    rdfs:label 'Suspension End Date' ;
    rdfs:comment 'Planned or actual date when vendor suspension will be or was lifted. Nullable for indefinite suspensions or vendors that have never been suspended. Used for reinstatement planning and compliance tracking.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:suspensionStartDate rdf:type rdf:Property ;
    rdfs:label 'Suspension Start Date' ;
    rdfs:comment 'Date when vendor suspension or blocking became effective. Used to track suspension duration and trigger review processes. Nullable for vendors that have never been suspended.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:taxIdentificationNumber rdf:type rdf:Property ;
    rdfs:label 'Tax Identification Number' ;
    rdfs:comment 'Government-issued tax identification number for the vendor. Used for tax reporting, 1099 processing, and compliance with tax regulations. Format varies by jurisdiction (EIN in USA, VAT number in EU, GST number in other regions).' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorName rdf:type rdf:Property ;
    rdfs:label 'Vendor Name' ;
    rdfs:comment 'Full legal name of the vendor organization as registered with tax authorities. Used on contracts, purchase orders, and payment documents. Must match legal registration documents.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorStatus rdf:type rdf:Property ;
    rdfs:label 'Vendor Status' ;
    rdfs:comment 'Current lifecycle status of the vendor in the vendor master. Approved vendors can receive purchase orders; prospective vendors are under evaluation; suspended vendors have temporary restrictions; blocked vendors cannot receive new orders; inactive vendors are no longer used; under_review vendors are being re-qualified.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorDocumentId rdf:type rdf:Property ;
    rdfs:label 'Vendor Document Id' ;
    rdfs:comment 'Unique identifier for the vendor-submitted document record. Primary key for the vendor document entity.' ;
    rdfs:domain ind:VendorDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:submittedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Submitted By Employee Id' ;
    rdfs:comment 'Foreign key linking to hr.employee. Business justification: Links vendor document submission to the responsible employee; supports document control and accountability.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:supersededByDocumentVendorDocumentId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Document Vendor Document Id' ;
    rdfs:comment 'Identifier of the newer vendor document that supersedes this document. Used to maintain document version history and ensure users reference the latest approved version.' ;
    rdfs:domain ind:VendorDocument ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VendorDocument .

ind:documentCategory rdf:type rdf:Property ;
    rdfs:label 'Document Category' ;
    rdfs:comment 'High-level categorization of the document by business function: technical, quality, compliance, commercial, safety, or environmental.' ;
    rdfs:domain ind:VendorDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentFormat rdf:type rdf:Property ;
    rdfs:label 'Document Format' ;
    rdfs:comment 'File format or media type of the submitted document. Common formats include PDF, DWG (AutoCAD), DXF, DOCX, XLSX, JPG, PNG, ZIP, or native CAD formats. [ENUM-REF-CANDIDATE: pdf|dwg|dxf|docx|xlsx|jpg|png|zip|native_cad — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:VendorDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:itpReference rdf:type rdf:Property ;
    rdfs:label 'Itp Reference' ;
    rdfs:comment 'Reference number of the Inspection and Test Plan to which this document submission is linked. Used to track ITP compliance and hold point releases.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:linkedDrawingNumber rdf:type rdf:Property ;
    rdfs:label 'Linked Drawing Number' ;
    rdfs:comment 'Reference number of the engineering drawing or BIM model to which this document is related. Used to establish traceability between vendor documents and design deliverables.' ;
    rdfs:domain ind:VendorDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ncrReference rdf:type rdf:Property ;
    rdfs:label 'Ncr Reference' ;
    rdfs:comment 'Reference number of any Non-Conformance Report raised against this document or the materials/equipment it describes. Links to the NCR record for quality tracking.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorEvaluationId rdf:type rdf:Property ;
    rdfs:label 'Vendor Evaluation Id' ;
    rdfs:comment 'Primary key for vendor_evaluation' ;
    rdfs:domain ind:VendorEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryVendorEvaluatorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Vendor Evaluator Employee Id' ;
    rdfs:comment 'Identifier of the procurement manager or project manager who conducted the vendor evaluation.' ;
    rdfs:domain ind:VendorEvaluation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:avlEntryDate rdf:type rdf:Property ;
    rdfs:label 'Avl Entry Date' ;
    rdfs:comment 'Date when the vendor was added to the AVL (Approved Vendor List) following successful pre-qualification. Null for vendors not yet approved.' ;
    rdfs:domain ind:VendorEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:bidInvitationEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Bid Invitation Eligible Flag' ;
    rdfs:comment 'Boolean indicator (True/False) determining whether the vendor is currently eligible to receive bid invitations for RFP (Request for Proposal) and RFQ (Request for Quotation) based on evaluation outcome and qualification status.' ;
    rdfs:domain ind:VendorEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:bondingLimitAmount rdf:type rdf:Property ;
    rdfs:label 'Bonding Limit Amount' ;
    rdfs:comment 'Maximum contract value (in USD) for which the vendor can provide performance and payment bonds. Critical for pre-qualification and determines eligibility for large-scale EPC (Engineering Procurement and Construction) projects.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:commercialComplianceScore rdf:type rdf:Property ;
    rdfs:label 'Commercial Compliance Score' ;
    rdfs:comment 'Numerical score (0-100) evaluating the vendor\'s adherence to contract terms, invoicing accuracy, payment terms compliance, and commercial documentation completeness.' ;
    rdfs:domain ind:VendorEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:correctiveActionDescription rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Description' ;
    rdfs:comment 'Detailed description of corrective actions required from the vendor to address performance gaps, quality issues, HSE violations, or compliance deficiencies identified during evaluation.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evaluationDate rdf:type rdf:Property ;
    rdfs:label 'Evaluation Date' ;
    rdfs:comment 'Date when the evaluation was formally completed and scored. Represents the business event timestamp for the assessment.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:evaluationNotes rdf:type rdf:Property ;
    rdfs:label 'Evaluation Notes' ;
    rdfs:comment 'Free-text field capturing additional observations, strengths, weaknesses, and contextual information from the evaluator that supplements the quantitative scores.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evaluationNumber rdf:type rdf:Property ;
    rdfs:label 'Evaluation Number' ;
    rdfs:comment 'Business identifier for the vendor evaluation record. Format: VE-YYYYMMDD followed by sequence number.' ;
    rdfs:domain ind:VendorEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evaluationPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Evaluation Period End Date' ;
    rdfs:comment 'End date of the performance evaluation period. For periodic reviews, defines the close of the assessment window.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:evaluationPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Evaluation Period Start Date' ;
    rdfs:comment 'Start date of the performance evaluation period. For periodic reviews, defines the beginning of the assessment window. For pre-qualification, represents the date evaluation commenced.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:evaluationStatus rdf:type rdf:Property ;
    rdfs:label 'Evaluation Status' ;
    rdfs:comment 'Current lifecycle status of the vendor evaluation. Tracks progression from draft through approval or rejection.' ;
    rdfs:domain ind:VendorEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evaluationType rdf:type rdf:Property ;
    rdfs:label 'Evaluation Type' ;
    rdfs:comment 'Type of vendor evaluation being conducted. Pre-qualification for new vendors entering AVL (Approved Vendor List), periodic review for ongoing performance assessment, project-specific for bid eligibility, re-qualification for expired certifications, or incident-triggered for corrective action follow-up.' ;
    rdfs:domain ind:VendorEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialHealthScore rdf:type rdf:Property ;
    rdfs:label 'Financial Health Score' ;
    rdfs:comment 'Numerical score (0-100) assessing the vendor\'s financial stability based on credit rating, liquidity ratios, debt-to-equity, and financial statement analysis. Critical for pre-qualification and bonding capacity assessment.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hseIncidentCount rdf:type rdf:Property ;
    rdfs:label 'Hse Incident Count' ;
    rdfs:comment 'Total number of HSE (Health Safety and Environment) incidents (including LTI, near-misses, and safety violations) involving the vendor during the evaluation period.' ;
    rdfs:domain ind:VendorEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hseRatingScore rdf:type rdf:Property ;
    rdfs:label 'Hse Rating Score' ;
    rdfs:comment 'Numerical score (0-100) assessing the vendor\'s HSE (Health Safety and Environment) performance including TRIR (Total Recordable Incident Rate), LTI (Lost Time Injury) frequency, safety certifications (ISO 45001), and HSE management system maturity.' ;
    rdfs:domain ind:VendorEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:insuranceVerifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Insurance Verified Flag' ;
    rdfs:comment 'Boolean indicator (True/False) confirming that the vendor\'s general liability, professional indemnity, and workers\' compensation insurance policies have been verified and meet project requirements.' ;
    rdfs:domain ind:VendorEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:onTimeDeliveryRate rdf:type rdf:Property ;
    rdfs:label 'On Time Delivery Rate' ;
    rdfs:comment 'Percentage (0-100) of deliveries completed on or before the scheduled delivery date during the evaluation period. Key KPI for schedule performance and reliability.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overallKpiRating rdf:type rdf:Property ;
    rdfs:label 'Overall Kpi Rating' ;
    rdfs:comment 'Composite numerical score (0-100) representing the weighted average of all evaluation dimensions (financial, technical, HSE, quality, delivery, responsiveness, commercial). Determines overall vendor performance grade.' ;
    rdfs:domain ind:VendorEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:performanceGrade rdf:type rdf:Property ;
    rdfs:label 'Performance Grade' ;
    rdfs:comment 'Letter grade (A through F) assigned based on overall KPI rating. A=Excellent (90-100), B=Good (80-89), C=Satisfactory (70-79), D=Marginal (60-69), F=Unsatisfactory (<60). Drives vendor tier classification and bid invitation priority.' ;
    rdfs:domain ind:VendorEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualificationExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Qualification Expiry Date' ;
    rdfs:comment 'Date when the vendor\'s qualification status expires and requires renewal through re-evaluation. Typically set 12-24 months from evaluation date for qualified vendors.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qualificationStatus rdf:type rdf:Property ;
    rdfs:label 'Qualification Status' ;
    rdfs:comment 'Resulting qualification status of the vendor based on evaluation outcome. Determines vendor eligibility for bid invitations and PO (Purchase Order) issuance.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityAcceptanceRate rdf:type rdf:Property ;
    rdfs:label 'Quality Acceptance Rate' ;
    rdfs:comment 'Percentage (0-100) of delivered materials or services that passed quality inspection on first submission without NCR (Non-Conformance Report) during the evaluation period.' ;
    rdfs:domain ind:VendorEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualityCertificationScore rdf:type rdf:Property ;
    rdfs:label 'Quality Certification Score' ;
    rdfs:comment 'Numerical score (0-100) evaluating the vendor\'s quality management certifications (ISO 9001), QA/QC (Quality Assurance/Quality Control) processes, inspection capabilities, and adherence to ITP (Inspection and Test Plan) requirements.' ;
    rdfs:domain ind:VendorEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:responsivenessScore rdf:type rdf:Property ;
    rdfs:label 'Responsiveness Score' ;
    rdfs:comment 'Numerical score (0-100) assessing the vendor\'s responsiveness to RFI (Request for Information), RFQ (Request for Quotation), change orders, and issue resolution. Measures communication effectiveness and turnaround time.' ;
    rdfs:domain ind:VendorEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:technicalCapabilityScore rdf:type rdf:Property ;
    rdfs:label 'Technical Capability Score' ;
    rdfs:comment 'Numerical score (0-100) evaluating the vendor\'s technical competence, equipment availability, workforce skills, past project experience, and ability to meet technical specifications.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vendorInvoiceId rdf:type rdf:Property ;
    rdfs:label 'Vendor Invoice Id' ;
    rdfs:comment 'Unique identifier for the vendor invoice record. Primary key.' ;
    rdfs:domain ind:VendorInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:blockedReason rdf:type rdf:Property ;
    rdfs:label 'Blocked Reason' ;
    rdfs:comment 'Reason why the invoice is blocked from payment, such as pending approval, missing documentation, price variance, or quality hold.' ;
    rdfs:domain ind:VendorInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fiDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Fi Document Number' ;
    rdfs:comment 'The SAP FI document number generated when the invoice is posted to the financial accounting system. This is the system-generated accounting document reference.' ;
    rdfs:domain ind:VendorInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceGrossAmount rdf:type rdf:Property ;
    rdfs:label 'Invoice Gross Amount' ;
    rdfs:comment 'Total invoice amount before taxes and adjustments. Represents the base value of goods or services invoiced.' ;
    rdfs:domain ind:VendorInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:invoiceNetAmount rdf:type rdf:Property ;
    rdfs:label 'Invoice Net Amount' ;
    rdfs:comment 'Total invoice amount payable after applying taxes, discounts, and adjustments. This is the final amount due to the vendor.' ;
    rdfs:domain ind:VendorInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:invoiceReceivedDate rdf:type rdf:Property ;
    rdfs:label 'Invoice Received Date' ;
    rdfs:comment 'The date the invoice was received by the procurement or accounts payable department.' ;
    rdfs:domain ind:VendorInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:vendorQualificationId rdf:type rdf:Property ;
    rdfs:label 'Vendor Qualification Id' ;
    rdfs:comment 'Unique identifier for the vendor qualification record. Primary key for the vendor qualification entity.' ;
    rdfs:domain ind:VendorQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryVendorAssessedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Vendor Assessed By Employee Id' ;
    rdfs:comment 'Reference to the procurement or QA/QC (Quality Assurance/Quality Control) employee who conducted the qualification assessment.' ;
    rdfs:domain ind:VendorQualification ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:approvedMaterialCategories rdf:type rdf:Property ;
    rdfs:label 'Approved Material Categories' ;
    rdfs:comment 'Comma-separated list of material categories the vendor is qualified to supply. Examples include concrete, steel, MEP (Mechanical Electrical and Plumbing) equipment, formwork, aggregates. Aligns with MTO (Material Take-Off) classification.' ;
    rdfs:domain ind:VendorQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedServiceTypes rdf:type rdf:Property ;
    rdfs:label 'Approved Service Types' ;
    rdfs:comment 'Comma-separated list of service types the vendor is qualified to provide. Examples include earthworks, structural steel erection, electrical installation, HVAC installation, concrete placement, surveying.' ;
    rdfs:domain ind:VendorQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bondingCapacityCurrency rdf:type rdf:Property ;
    rdfs:label 'Bonding Capacity Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for bonding capacity limit. Typically USD for US-based projects.' ;
    rdfs:domain ind:VendorQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bondingCapacityLimit rdf:type rdf:Property ;
    rdfs:label 'Bonding Capacity Limit' ;
    rdfs:comment 'Maximum bonding capacity available from the vendor\'s surety company. Determines the maximum contract value the vendor can undertake. Critical for GC (General Contractor) and major subcontractor qualifications.' ;
    rdfs:domain ind:VendorQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hsePerformanceRating rdf:type rdf:Property ;
    rdfs:label 'Hse Performance Rating' ;
    rdfs:comment 'HSE (Health Safety and Environment) performance rating based on TRIR (Total Recordable Incident Rate), LTI (Lost Time Injury) frequency, safety audit results, and compliance with OSHA (Occupational Safety and Health Administration) standards. Critical factor for vendor approval.' ;
    rdfs:domain ind:VendorQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceCertificateExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Insurance Certificate Expiry Date' ;
    rdfs:comment 'Expiry date of the vendor\'s insurance certificate. Procurement tracks this to ensure continuous coverage throughout contract execution.' ;
    rdfs:domain ind:VendorQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:insuranceGeneralLiabilityLimit rdf:type rdf:Property ;
    rdfs:label 'Insurance General Liability Limit' ;
    rdfs:comment 'General liability insurance coverage limit. Minimum requirements typically range from $1M to $10M depending on project size and risk profile.' ;
    rdfs:domain ind:VendorQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:insuranceWorkersCompVerified rdf:type rdf:Property ;
    rdfs:label 'Insurance Workers Comp Verified' ;
    rdfs:comment 'Indicates whether valid workers compensation insurance has been verified. Mandatory for all vendors providing on-site labor per OSHA (Occupational Safety and Health Administration) requirements.' ;
    rdfs:domain ind:VendorQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:iso14001CertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Iso 14001 Certificate Number' ;
    rdfs:comment 'Certificate number for ISO 14001 Environmental Management System certification.' ;
    rdfs:domain ind:VendorQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iso14001Certified rdf:type rdf:Property ;
    rdfs:label 'Iso 14001 Certified' ;
    rdfs:comment 'Indicates whether the vendor holds valid ISO 14001 Environmental Management System certification. Increasingly required for LEED (Leadership in Energy and Environmental Design) projects and environmentally sensitive sites.' ;
    rdfs:domain ind:VendorQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:iso14001ExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Iso 14001 Expiry Date' ;
    rdfs:comment 'Expiry date of ISO 14001 certification. Critical for projects with EPA (Environmental Protection Agency) compliance requirements.' ;
    rdfs:domain ind:VendorQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:iso45001CertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Iso 45001 Certificate Number' ;
    rdfs:comment 'Certificate number for ISO 45001 Occupational Health and Safety Management System certification.' ;
    rdfs:domain ind:VendorQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iso45001Certified rdf:type rdf:Property ;
    rdfs:label 'Iso 45001 Certified' ;
    rdfs:comment 'Indicates whether the vendor holds valid ISO 45001 Occupational Health and Safety Management System certification. Demonstrates commitment to worker safety and HSE (Health Safety and Environment) excellence.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:iso45001ExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Iso 45001 Expiry Date' ;
    rdfs:comment 'Expiry date of ISO 45001 certification. Monitored to ensure ongoing HSE (Health Safety and Environment) compliance.' ;
    rdfs:domain ind:VendorQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:iso9001CertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Iso 9001 Certificate Number' ;
    rdfs:comment 'Certificate number for ISO 9001 Quality Management System certification. Used for verification with certification body.' ;
    rdfs:domain ind:VendorQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iso9001Certified rdf:type rdf:Property ;
    rdfs:label 'Iso 9001 Certified' ;
    rdfs:comment 'Indicates whether the vendor holds valid ISO 9001 Quality Management System certification. Often mandatory for critical material suppliers and major subcontractors.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:iso9001ExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Iso 9001 Expiry Date' ;
    rdfs:comment 'Expiry date of ISO 9001 certification. Procurement monitors this to ensure vendors maintain valid certification throughout contract execution.' ;
    rdfs:domain ind:VendorQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ltiFrequencyRate rdf:type rdf:Property ;
    rdfs:label 'Lti Frequency Rate' ;
    rdfs:comment 'LTI (Lost Time Injury) frequency rate calculated as (number of LTIs × 1,000,000) / total hours worked. Measures severity of safety incidents. Target is typically below 1.0 for qualified vendors.' ;
    rdfs:domain ind:VendorQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pastPerformanceScore rdf:type rdf:Property ;
    rdfs:label 'Past Performance Score' ;
    rdfs:comment 'Composite past performance score ranging from 0.00 to 100.00. Based on historical project delivery, quality, schedule adherence, cost control, and client satisfaction. Derived from completed project evaluations and NCR (Non-Conformance Report) history.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualificationAssessmentDate rdf:type rdf:Property ;
    rdfs:label 'Qualification Assessment Date' ;
    rdfs:comment 'Date when the qualification assessment was conducted. Includes site visits, document reviews, financial analysis, and technical capability evaluation.' ;
    rdfs:domain ind:VendorQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qualificationCategory rdf:type rdf:Property ;
    rdfs:label 'Qualification Category' ;
    rdfs:comment 'Primary category of goods or services the vendor is qualified to supply. MEP (Mechanical Electrical and Plumbing) is a specialized category for building systems contractors.' ;
    rdfs:domain ind:VendorQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualificationNumber rdf:type rdf:Property ;
    rdfs:label 'Qualification Number' ;
    rdfs:comment 'Business identifier for the vendor qualification record. Externally visible unique reference number used in procurement communications and AVL (Approved Vendor List) documentation.' ;
    rdfs:domain ind:VendorQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualificationStartDate rdf:type rdf:Property ;
    rdfs:label 'Qualification Start Date' ;
    rdfs:comment 'Effective date from which the vendor qualification becomes valid. Vendors can only receive PO (Purchase Order) assignments on or after this date.' ;
    rdfs:domain ind:VendorQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qualificationType rdf:type rdf:Property ;
    rdfs:label 'Qualification Type' ;
    rdfs:comment 'Type of qualification process being conducted. Initial for new vendors, renewal for periodic re-assessment, re-qualification for vendors returning after suspension, conditional for limited-scope approval, emergency for urgent project needs.' ;
    rdfs:domain ind:VendorQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityDefectRate rdf:type rdf:Property ;
    rdfs:label 'Quality Defect Rate' ;
    rdfs:comment 'Historical quality defect rate expressed as percentage of deliverables requiring rework or NCR (Non-Conformance Report) issuance. Lower values indicate better quality performance. Target is typically below 5.00%.' ;
    rdfs:domain ind:VendorQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:suspensionDate rdf:type rdf:Property ;
    rdfs:label 'Suspension Date' ;
    rdfs:comment 'Date when the vendor qualification was suspended. Suspended vendors cannot receive new PO (Purchase Order) assignments until re-qualified.' ;
    rdfs:domain ind:VendorQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:trirRate rdf:type rdf:Property ;
    rdfs:label 'Trir Rate' ;
    rdfs:comment 'TRIR (Total Recordable Incident Rate) calculated as (number of recordable incidents × 200,000) / total hours worked. Industry benchmark for construction is typically below 3.0. Lower values indicate better safety performance.' ;
    rdfs:domain ind:VendorQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vendorQuotationId rdf:type rdf:Property ;
    rdfs:label 'Vendor Quotation Id' ;
    rdfs:comment 'Unique identifier for the vendor quotation record. Primary key for this entity.' ;
    rdfs:domain ind:VendorQuotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:awardRecommendation rdf:type rdf:Property ;
    rdfs:label 'Award Recommendation' ;
    rdfs:comment 'Procurement team recommendation on whether to award the PO to this vendor based on evaluation results.' ;
    rdfs:domain ind:VendorQuotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commercialExceptions rdf:type rdf:Property ;
    rdfs:label 'Commercial Exceptions' ;
    rdfs:comment 'Vendor-declared exceptions or deviations from RFQ commercial terms (payment, delivery, penalties, etc.). Must be evaluated during bid tabulation.' ;
    rdfs:domain ind:VendorQuotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviationsFromSpecification rdf:type rdf:Property ;
    rdfs:label 'Deviations From Specification' ;
    rdfs:comment 'Vendor-declared exceptions, deviations, or clarifications to the RFQ technical specifications. Critical for commercial evaluation and risk assessment.' ;
    rdfs:domain ind:VendorQuotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discountPercentage rdf:type rdf:Property ;
    rdfs:label 'Discount Percentage' ;
    rdfs:comment 'Percentage discount offered by vendor from list price or previous quotation. Used for price negotiation and historical benchmarking.' ;
    rdfs:domain ind:VendorQuotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quotationNumber rdf:type rdf:Property ;
    rdfs:label 'Quotation Number' ;
    rdfs:comment 'Vendor-assigned unique reference number for this quotation. External business identifier used for correspondence and tracking.' ;
    rdfs:domain ind:VendorQuotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quotationStatus rdf:type rdf:Property ;
    rdfs:label 'Quotation Status' ;
    rdfs:comment 'Current lifecycle status of the vendor quotation in the evaluation and award process.' ;
    rdfs:domain ind:VendorQuotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quotedQuantity rdf:type rdf:Property ;
    rdfs:label 'Quoted Quantity' ;
    rdfs:comment 'Quantity of material or service the vendor is quoting for. Must align with RFQ requested quantity.' ;
    rdfs:domain ind:VendorQuotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:technicalComplianceStatus rdf:type rdf:Property ;
    rdfs:label 'Technical Compliance Status' ;
    rdfs:comment 'Assessment of whether the quoted material meets the technical specifications defined in the RFQ. Evaluated by engineering team.' ;
    rdfs:domain ind:VendorQuotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalPrice rdf:type rdf:Property ;
    rdfs:label 'Total Price' ;
    rdfs:comment 'Total quoted price for the full quantity (unit price × quantity). May include or exclude taxes and freight depending on quotation terms.' ;
    rdfs:domain ind:VendorQuotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:warrantyTerms rdf:type rdf:Property ;
    rdfs:label 'Warranty Terms' ;
    rdfs:comment 'Detailed warranty terms and conditions including coverage scope, exclusions, and claim procedures.' ;
    rdfs:domain ind:VendorQuotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvingAuthorityEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Approving Authority Employee Id' ;
    rdfs:comment 'Foreign key linking to hr.employee. Business justification: Baseline changes must be approved by a specific employee for audit trails and compliance.' ;
    rdfs:domain ind:ProjectBaseline ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:approvalLevel rdf:type rdf:Property ;
    rdfs:label 'Approval Level' ;
    rdfs:comment 'Governance tier at which this baseline was approved, reflecting the authorization hierarchy. Higher-value or re-baseline revisions typically require elevated approval levels per PMO governance policy.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baselineNumber rdf:type rdf:Property ;
    rdfs:label 'Baseline Number' ;
    rdfs:comment 'Externally-known alphanumeric identifier for the baseline record, used in PMO reporting, EVM analysis, and audit documentation. Format: BL-{ProjectCode}-{SequenceNumber}.' ;
    rdfs:domain ind:ProjectBaseline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baselineStatus rdf:type rdf:Property ;
    rdfs:label 'Baseline Status' ;
    rdfs:comment 'Current lifecycle state of the baseline record within the PMO approval workflow. Draft baselines are under preparation; pending_approval awaits sign-off; approved is the active authorized baseline; superseded indicates a newer revision has replaced it; cancelled denotes a withdrawn baseline.' ;
    rdfs:domain ind:ProjectBaseline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baselineType rdf:type rdf:Property ;
    rdfs:label 'Baseline Type' ;
    rdfs:comment 'Classification of the baseline record indicating the nature of the snapshot: original (initial approved baseline), revised (minor scope/cost adjustment), re_baseline (full project re-baselining), co_incorporation (Change Order incorporated), re_forecast (updated forecast adopted as new baseline), management_reserve_release (management reserve funds released into budget).' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetAfterRevision rdf:type rdf:Property ;
    rdfs:label 'Budget After Revision' ;
    rdfs:comment 'Total approved budget amount immediately following this baseline revision. Together with budget_before_revision, provides the complete budget delta audit trail for PMO governance and financial audit requirements.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetAtCompletion rdf:type rdf:Property ;
    rdfs:label 'Budget At Completion' ;
    rdfs:comment 'Total approved budget for the project or WBS element as captured in this baseline snapshot, representing the Budget at Completion (BAC) in the EVM framework. This is the total planned cost against which CPI (Cost Performance Index) and cost variance are measured.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetBeforeRevision rdf:type rdf:Property ;
    rdfs:label 'Budget Before Revision' ;
    rdfs:comment 'Total approved budget amount immediately prior to this baseline revision. Enables audit trail tracking of budget evolution and quantification of the budget delta introduced by each revision.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coValueIncorporated rdf:type rdf:Property ;
    rdfs:label 'Co Value Incorporated' ;
    rdfs:comment 'Total monetary value of Change Orders (COs) incorporated into this baseline revision. Quantifies the cumulative scope change impact on the approved budget for audit trail and contract administration purposes.' ;
    rdfs:domain ind:ProjectBaseline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costAccountCode rdf:type rdf:Property ;
    rdfs:label 'Cost Account Code' ;
    rdfs:comment 'Cost account or cost code identifier at which this baseline budget is allocated, enabling WBS-level budget breakdown and cost-account-level EVM variance analysis. Aligns with the project cost coding structure in SAP S/4HANA and Viewpoint Vista.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:durationDays rdf:type rdf:Property ;
    rdfs:label 'Duration Days' ;
    rdfs:comment 'Approved total duration of the project or WBS element in calendar days as captured in this baseline snapshot. Derived from baseline start and finish dates; stored explicitly for EVM schedule variance analysis and reporting.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:finishDate rdf:type rdf:Property ;
    rdfs:label 'Finish Date' ;
    rdfs:comment 'Approved planned finish date for the project or WBS element as captured in this baseline snapshot. Used as the schedule reference for SPI (Schedule Performance Index) calculation and milestone tracking.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isClientApproved rdf:type rdf:Property ;
    rdfs:label 'Is Client Approved' ;
    rdfs:comment 'Boolean flag indicating whether the client or owner has formally approved this baseline revision. Relevant for contract-driven baselines under FIDIC, GMP (Guaranteed Maximum Price), or EPC delivery models where client sign-off is contractually required.' ;
    rdfs:domain ind:ProjectBaseline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isCurrentBaseline rdf:type rdf:Property ;
    rdfs:label 'Is Current Baseline' ;
    rdfs:comment 'Boolean flag indicating whether this record represents the currently active approved baseline for the project or WBS element. Only one baseline per project/WBS should have this flag set to True at any point in time.' ;
    rdfs:domain ind:ProjectBaseline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:plannedValue rdf:type rdf:Property ;
    rdfs:label 'Planned Value' ;
    rdfs:comment 'Planned Value (PV) — the authorized budget assigned to scheduled work in this baseline snapshot, also known as Budgeted Cost of Work Scheduled (BCWS) in EVM methodology. Serves as the EVM performance measurement baseline reference.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:primaveraBaselineReference rdf:type rdf:Property ;
    rdfs:label 'Primavera Baseline Reference' ;
    rdfs:comment 'Source system identifier for this baseline record as assigned by Oracle Primavera P6. Enables traceability and reconciliation between the lakehouse Silver Layer and the operational scheduling system.' ;
    rdfs:domain ind:ProjectBaseline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revisionJustification rdf:type rdf:Property ;
    rdfs:label 'Revision Justification' ;
    rdfs:comment 'Narrative explanation of the business reason for this baseline revision, including the drivers of scope, schedule, or cost changes. Required for PMO governance approval and financial audit documentation.' ;
    rdfs:domain ind:ProjectBaseline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapProjectVersion rdf:type rdf:Property ;
    rdfs:label 'Sap Project Version' ;
    rdfs:comment 'SAP S/4HANA Project Systems version identifier corresponding to this baseline snapshot. Used for reconciliation between the ERP project budget version and the Primavera schedule baseline.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleDataDate rdf:type rdf:Property ;
    rdfs:label 'Schedule Data Date' ;
    rdfs:comment 'The data date (status date) of the Oracle Primavera P6 schedule from which this baseline snapshot was extracted. Defines the point-in-time reference for all schedule parameters captured in this record.' ;
    rdfs:domain ind:ProjectBaseline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:varianceAtCompletion rdf:type rdf:Property ;
    rdfs:label 'Variance At Completion' ;
    rdfs:comment 'Variance at Completion (VAC) — the difference between the Budget at Completion (BAC) and the Estimate at Completion (EAC) at the time this baseline was established. Provides a forward-looking cost performance indicator for PMO reporting.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:commissioningPackageId rdf:type rdf:Property ;
    rdfs:label 'Commissioning Package Id' ;
    rdfs:comment 'Unique surrogate identifier for the commissioning package record in the silver layer lakehouse. Primary key for this entity.' ;
    rdfs:domain ind:CommissioningPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:responsibleEngineerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Responsible Engineer Employee Id' ;
    rdfs:comment 'Foreign key linking to hr.employee. Business justification: Commissioning engineer is recorded for safety sign-off and system acceptance documentation.' ;
    rdfs:domain ind:CommissioningPackage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:areaLocation rdf:type rdf:Property ;
    rdfs:label 'Area Location' ;
    rdfs:comment 'Physical area, zone, or location on the project site where the systems and equipment within this commissioning package are installed (e.g., \'Substation Block C\', \'Pump House Level 2\', \'North Terminal Building\').' ;
    rdfs:domain ind:CommissioningPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clientRepresentative rdf:type rdf:Property ;
    rdfs:label 'Client Representative' ;
    rdfs:comment 'Name or identifier of the client\'s authorised representative who witnesses commissioning activities and signs off on the handover certificate for this package.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commissioningContractor rdf:type rdf:Property ;
    rdfs:label 'Commissioning Contractor' ;
    rdfs:comment 'Name of the specialist commissioning contractor or subcontractor responsible for executing the commissioning activities for this package, where commissioning is subcontracted rather than performed by the GC (General Contractor).' ;
    rdfs:domain ind:CommissioningPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commissioningSequence rdf:type rdf:Property ;
    rdfs:label 'Commissioning Sequence' ;
    rdfs:comment 'Numeric sequence order in which this commissioning package is to be executed relative to other packages on the project. Drives the commissioning schedule integration with Oracle Primavera P6 CPM (Critical Path Method) scheduling.' ;
    rdfs:domain ind:CommissioningPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fatDate rdf:type rdf:Property ;
    rdfs:label 'Fat Date' ;
    rdfs:comment 'Date on which the FAT (Factory Acceptance Test) was conducted or is scheduled to be conducted for the equipment within this commissioning package.' ;
    rdfs:domain ind:CommissioningPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fatStatus rdf:type rdf:Property ;
    rdfs:label 'Fat Status' ;
    rdfs:comment 'Current status of the FAT (Factory Acceptance Test) for the equipment or systems within this commissioning package. FAT is conducted at the manufacturer\'s facility prior to shipment to verify equipment meets specification. [ENUM-REF-CANDIDATE: not_required|pending|scheduled|in_progress|passed|failed|conditionally_passed — promote to reference product]' ;
    rdfs:domain ind:CommissioningPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:handoverCertificateRef rdf:type rdf:Property ;
    rdfs:label 'Handover Certificate Ref' ;
    rdfs:comment 'Document reference number of the formal handover certificate issued upon successful completion of commissioning and acceptance of this package by the client or operations team. Registered in Aconex document management.' ;
    rdfs:domain ind:CommissioningPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mechanicalCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Mechanical Completion Date' ;
    rdfs:comment 'Date on which mechanical completion was achieved for this commissioning package, confirming that all physical construction and installation works are complete and the system is ready for pre-commissioning activities.' ;
    rdfs:domain ind:CommissioningPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:omDocumentationRef rdf:type rdf:Property ;
    rdfs:label 'Om Documentation Ref' ;
    rdfs:comment 'Document reference number for the O&M (Operations and Maintenance) manual package associated with this commissioning package, as registered in Aconex. Required for handover gate approval.' ;
    rdfs:domain ind:CommissioningPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operationalReadinessVerified rdf:type rdf:Property ;
    rdfs:label 'Operational Readiness Verified' ;
    rdfs:comment 'Indicates whether operational readiness has been formally verified for this commissioning package, confirming that O&M (Operations and Maintenance) documentation, spare parts, and trained operators are in place prior to handover.' ;
    rdfs:domain ind:CommissioningPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:packageName rdf:type rdf:Property ;
    rdfs:label 'Package Name' ;
    rdfs:comment 'Human-readable name or title of the commissioning package describing the system or sub-system grouping (e.g., \'Cooling Water System – Train A\', \'HV Switchgear Room 3B\').' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preCommissioningComplete rdf:type rdf:Property ;
    rdfs:label 'Pre Commissioning Complete' ;
    rdfs:comment 'Indicates whether all pre-commissioning activities (mechanical completion checks, loop checks, flushing, pressure testing) for this package have been formally completed and signed off, enabling progression to active commissioning.' ;
    rdfs:domain ind:CommissioningPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priorityTag rdf:type rdf:Property ;
    rdfs:label 'Priority Tag' ;
    rdfs:comment 'Priority classification assigned to the commissioning package indicating its criticality to the overall project commissioning schedule and operational readiness. Critical packages are on the commissioning critical path.' ;
    rdfs:domain ind:CommissioningPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:punchListCatACount rdf:type rdf:Property ;
    rdfs:label 'Punch List Cat A Count' ;
    rdfs:comment 'Number of Category A punch list items for this commissioning package. Category A items are safety-critical or operationally blocking deficiencies that must be resolved before the system can be energised or operated.' ;
    rdfs:domain ind:CommissioningPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:punchListCatBCount rdf:type rdf:Property ;
    rdfs:label 'Punch List Cat B Count' ;
    rdfs:comment 'Number of Category B punch list items for this commissioning package. Category B items are non-safety-critical deficiencies that must be resolved before final handover but do not prevent initial commissioning.' ;
    rdfs:domain ind:CommissioningPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:punchListCatCCount rdf:type rdf:Property ;
    rdfs:label 'Punch List Cat C Count' ;
    rdfs:comment 'Number of Category C punch list items for this commissioning package. Category C items are minor observations or improvements that may be resolved during the DLP (Defects Liability Period) after handover.' ;
    rdfs:domain ind:CommissioningPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:punchListClosedCount rdf:type rdf:Property ;
    rdfs:label 'Punch List Closed Count' ;
    rdfs:comment 'Number of punch list items that have been formally closed and verified as resolved for this commissioning package. Used to track closure progress and calculate closure percentage.' ;
    rdfs:domain ind:CommissioningPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:punchListClosurePct rdf:type rdf:Property ;
    rdfs:label 'Punch List Closure Pct' ;
    rdfs:comment 'Percentage of total punch list items that have been formally closed for this commissioning package, calculated as (closed items / total items) × 100. Key KPI for commissioning readiness and handover gate reviews.' ;
    rdfs:domain ind:CommissioningPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:punchListTotalItems rdf:type rdf:Property ;
    rdfs:label 'Punch List Total Items' ;
    rdfs:comment 'Total number of punch list items (deficiencies, outstanding works, and snag items) identified during commissioning inspections for this package. Includes all Category A, B, and C items.' ;
    rdfs:domain ind:CommissioningPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:satDate rdf:type rdf:Property ;
    rdfs:label 'Sat Date' ;
    rdfs:comment 'Date on which the SAT (Site Acceptance Test) was conducted or is scheduled to be conducted for the systems within this commissioning package.' ;
    rdfs:domain ind:CommissioningPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:satStatus rdf:type rdf:Property ;
    rdfs:label 'Sat Status' ;
    rdfs:comment 'Current status of the SAT (Site Acceptance Test) for the systems within this commissioning package. SAT is conducted on-site after installation to verify the system operates correctly in its installed environment. [ENUM-REF-CANDIDATE: not_required|pending|scheduled|in_progress|passed|failed|conditionally_passed — promote to reference product]' ;
    rdfs:domain ind:CommissioningPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subsystemNumber rdf:type rdf:Property ;
    rdfs:label 'Subsystem Number' ;
    rdfs:comment 'Engineering sub-system tag or number providing finer granularity within the parent system, used to sequence commissioning activities at the sub-system level and track partial turnover.' ;
    rdfs:domain ind:CommissioningPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:systemDescription rdf:type rdf:Property ;
    rdfs:label 'System Description' ;
    rdfs:comment 'Detailed narrative description of the system, sub-system, or equipment grouping covered by this commissioning package, including functional purpose and physical boundaries as defined in the engineering design documentation and BIM (Building Information Modeling) model.' ;
    rdfs:domain ind:CommissioningPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:systemNumber rdf:type rdf:Property ;
    rdfs:label 'System Number' ;
    rdfs:comment 'Engineering system tag or number identifying the process or facility system to which this commissioning package belongs, aligned with the plant/facility numbering scheme and P&ID (Piping and Instrumentation Diagram) references.' ;
    rdfs:domain ind:CommissioningPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mainContractorVendorId rdf:type rdf:Property ;
    rdfs:label 'Main Contractor Vendor Id' ;
    rdfs:comment 'Foreign key linking to procurement.vendor. Business justification: Main EPC contractor assignment for each project; required for contract management, reporting, and regulatory compliance.' ;
    rdfs:domain ind:ConstructionProject ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vendor .

ind:primaryContactId rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Id' ;
    rdfs:comment 'Foreign key linking to client.contact. Business justification: Required for Project Communication Plan to identify primary client contact for status reports and issue escalation.' ;
    rdfs:domain ind:ConstructionProject ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Contact .

ind:approvedBudget rdf:type rdf:Property ;
    rdfs:label 'Approved Budget' ;
    rdfs:comment 'Total approved project budget including all cost codes, contingency, and approved change orders (CO). Used as the control budget for EVM (Earned Value Management) and cost performance index (CPI) calculations in SAP S/4HANA Project Systems.' ;
    rdfs:domain ind:ConstructionProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bidNumber rdf:type rdf:Property ;
    rdfs:label 'Bid Number' ;
    rdfs:comment 'Reference number of the original bid or tender submission (RFP/RFQ) from which this project was awarded. Links project execution back to the pre-award opportunity in Salesforce CRM for win/loss analytics.' ;
    rdfs:domain ind:ConstructionProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cpi rdf:type rdf:Property ;
    rdfs:label 'Cpi' ;
    rdfs:comment 'EVM (Earned Value Management) Cost Performance Index (CPI) calculated as Earned Value divided by Actual Cost. A CPI below 1.0 indicates cost overrun. Updated monthly from SAP S/4HANA Project Systems and Oracle Primavera P6 progress data.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:forecastCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Forecast Completion Date' ;
    rdfs:comment 'Current forecast date for project completion based on latest schedule update and progress data from Oracle Primavera P6. Reflects approved EOT (Extension of Time) claims and current schedule performance.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:hseRiskLevel rdf:type rdf:Property ;
    rdfs:label 'Hse Risk Level' ;
    rdfs:comment 'Overall HSE (Health Safety and Environment) risk classification for the project based on project type, location, scope complexity, and hazard profile. Determines the level of HSE oversight, inspection frequency, and SWMS (Safe Work Method Statement) requirements as managed in Intelex.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jvPartnerSharePct rdf:type rdf:Property ;
    rdfs:label 'Jv Partner Share Pct' ;
    rdfs:comment 'The company\'s ownership or participation percentage in the Joint Venture (JV) arrangement for this project. Used for financial consolidation, P&L (Profit and Loss) attribution, and EBITDA reporting. Null when is_joint_venture is False.' ;
    rdfs:domain ind:ConstructionProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:physicalProgressPct rdf:type rdf:Property ;
    rdfs:label 'Physical Progress Pct' ;
    rdfs:comment 'Overall physical percentage completion of the project as reported in the latest progress update from Oracle Primavera P6 and HCSS HeavyJob. Used for earned value calculations, client progress billing, and PMO dashboard reporting.' ;
    rdfs:domain ind:ConstructionProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pmoClassification rdf:type rdf:Property ;
    rdfs:label 'Pmo Classification' ;
    rdfs:comment 'PMO (Project Management Office) tier classification that determines the level of governance, reporting frequency, and executive oversight applied to the project. Tier 1 projects receive the highest level of PMO scrutiny.' ;
    rdfs:domain ind:ConstructionProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaveraProjectReference rdf:type rdf:Property ;
    rdfs:label 'Primavera Project Reference' ;
    rdfs:comment 'Native project identifier in Oracle Primavera P6 scheduling system. Used for cross-system data integration between the enterprise data platform and the scheduling system of record for activity, resource, and baseline data.' ;
    rdfs:domain ind:ConstructionProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:procoreProjectReference rdf:type rdf:Property ;
    rdfs:label 'Procore Project Reference' ;
    rdfs:comment 'Native project identifier in Procore construction management platform. Used for cross-system integration to retrieve daily logs, RFIs (Requests for Information), submittals, change orders, and drawing management data.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectStatus rdf:type rdf:Property ;
    rdfs:label 'Project Status' ;
    rdfs:comment 'Current lifecycle state of the construction project from prospect through to completion or cancellation. Drives PMO governance workflows and financial reporting eligibility.' ;
    rdfs:domain ind:ConstructionProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retentionPct rdf:type rdf:Property ;
    rdfs:label 'Retention Pct' ;
    rdfs:comment 'Contractual retention percentage withheld by the client from each progress payment certificate. Typically released in two tranches: at practical completion and at DLP (Defects Liability Period) expiry. Used in cash flow forecasting.' ;
    rdfs:domain ind:ConstructionProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sapProjectDefinition rdf:type rdf:Property ;
    rdfs:label 'Sap Project Definition' ;
    rdfs:comment 'SAP S/4HANA Project Systems project definition code (PS-DEF) that serves as the root WBS element for all cost postings, purchase orders, and financial transactions related to this project in the ERP system.' ;
    rdfs:domain ind:ConstructionProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteLatitude rdf:type rdf:Property ;
    rdfs:label 'Site Latitude' ;
    rdfs:comment 'Geographic latitude coordinate of the primary project site in decimal degrees (WGS84). Used for GIS (Geographic Information System) mapping, logistics routing, and environmental impact assessments.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:siteLongitude rdf:type rdf:Property ;
    rdfs:label 'Site Longitude' ;
    rdfs:comment 'Geographic longitude coordinate of the primary project site in decimal degrees (WGS84). Used for GIS (Geographic Information System) mapping, logistics routing, and environmental impact assessments.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:spi rdf:type rdf:Property ;
    rdfs:label 'Spi' ;
    rdfs:comment 'EVM (Earned Value Management) Schedule Performance Index (SPI) calculated as Earned Value divided by Planned Value. An SPI below 1.0 indicates schedule delay. Updated monthly from Oracle Primavera P6 progress reporting.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:responsibleManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Responsible Manager Employee Id' ;
    rdfs:comment 'Foreign key linking to hr.employee. Business justification: Cost account manager employee is required for financial accountability and reporting.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:accountDescription rdf:type rdf:Property ;
    rdfs:label 'Account Description' ;
    rdfs:comment 'Human-readable description of the cost account scope, such as \'Structural Concrete — Foundation Works\' or \'MEP Subcontract — Electrical Rough-In\'. Used in cost reports, BOQ reconciliation, and EVM reporting.' ;
    rdfs:domain ind:CostAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Approved Budget Amount' ;
    rdfs:comment 'Current approved budget for this cost account inclusive of all approved Change Orders (COs). Equivalent to Budget at Completion (BAC) in EVM terminology. Updated each time a CO is approved and posted to the cost account. The primary budget control figure used by project cost controllers.' ;
    rdfs:domain ind:CostAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:baselineFinishDate rdf:type rdf:Property ;
    rdfs:label 'Baseline Finish Date' ;
    rdfs:comment 'Planned completion date for the scope of work associated with this cost account as established in the approved project baseline schedule. Used for schedule performance tracking and Earned Value Management (EVM) analysis.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:baselineStartDate rdf:type rdf:Property ;
    rdfs:label 'Baseline Start Date' ;
    rdfs:comment 'Planned start date for the scope of work associated with this cost account as established in the approved project baseline schedule. Used for Planned Value (PV) calculation and schedule variance analysis in EVM reporting.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:budgetUnitRate rdf:type rdf:Property ;
    rdfs:label 'Budget Unit Rate' ;
    rdfs:comment 'Budgeted cost per unit of measure for this cost account (Approved Budget divided by Budgeted Quantity). Used for unit rate benchmarking, bid analysis, and productivity monitoring. Expressed in the cost account currency per unit of measure.' ;
    rdfs:domain ind:CostAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:changeOrderAmount rdf:type rdf:Property ;
    rdfs:label 'Change Order Amount' ;
    rdfs:comment 'Cumulative value of all approved Change Orders (COs) posted to this cost account. Represents the delta between the original budget and the current approved budget. Tracked separately to support contract administration and CO impact analysis.' ;
    rdfs:domain ind:CostAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costToCompleteAmount rdf:type rdf:Property ;
    rdfs:label 'Cost To Complete Amount' ;
    rdfs:comment 'Estimated remaining cost required to complete the scope of work for this cost account. Calculated as Forecast Cost at Completion minus Actual Cost to Date. Used by cost controllers to project future cash requirements and update project financial forecasts.' ;
    rdfs:domain ind:CostAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:earnedValueAmount rdf:type rdf:Property ;
    rdfs:label 'Earned Value Amount' ;
    rdfs:comment 'Budgeted cost of work performed (BCWP) for this cost account, representing the value of completed work expressed in budget terms. Core EVM metric used to calculate Cost Performance Index (CPI) and Schedule Performance Index (SPI) at the cost account level.' ;
    rdfs:domain ind:CostAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:forecastCostAtCompletion rdf:type rdf:Property ;
    rdfs:label 'Forecast Cost At Completion' ;
    rdfs:comment 'Project cost controller\'s current best estimate of the total cost to complete this cost account, including actual costs to date plus estimated cost to complete (ETC). Equivalent to Estimate at Completion (EAC) in EVM. Updated periodically during project cost reviews.' ;
    rdfs:domain ind:CostAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:forecastFinishDate rdf:type rdf:Property ;
    rdfs:label 'Forecast Finish Date' ;
    rdfs:comment 'Current forecast completion date for the scope of work associated with this cost account. Updated during project schedule reviews. Used to assess Extension of Time (EOT) impacts and project completion forecasting.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:forecastStartDate rdf:type rdf:Property ;
    rdfs:label 'Forecast Start Date' ;
    rdfs:comment 'Current forecast start date for the scope of work associated with this cost account, updated during project schedule reviews. Compared against the baseline start date to identify schedule slippage and its cost impact.' ;
    rdfs:domain ind:CostAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isSubcontractScope rdf:type rdf:Property ;
    rdfs:label 'Is Subcontract Scope' ;
    rdfs:comment 'Indicates whether the scope of work for this cost account is executed by a subcontractor (True) or by the General Contractor\'s (GC) own forces (False). Drives subcontract management workflows, retention tracking, and payment certification processes.' ;
    rdfs:domain ind:CostAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:phaseCode rdf:type rdf:Property ;
    rdfs:label 'Phase Code' ;
    rdfs:comment 'Project phase or stage code associated with this cost account (e.g., \'DESIGN\', \'PROCURE\', \'CONSTRUCT\', \'COMMISSION\'). Enables cost tracking and reporting by EPC phase. Sourced from Viewpoint Vista and HCSS HeavyJob phase coding.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedValueAmount rdf:type rdf:Property ;
    rdfs:label 'Planned Value Amount' ;
    rdfs:comment 'Budgeted cost of work scheduled (BCWS) for this cost account as of the reporting data date. Represents the cumulative planned spend per the project baseline schedule. Used with Earned Value to compute Schedule Variance (SV) and SPI.' ;
    rdfs:domain ind:CostAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityActual rdf:type rdf:Property ;
    rdfs:label 'Quantity Actual' ;
    rdfs:comment 'Actual quantity of work completed and posted against this cost account to date. Compared against budgeted quantity to assess production efficiency and unit cost performance. Sourced from HCSS HeavyJob production entries and field daily logs.' ;
    rdfs:domain ind:CostAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityBudgeted rdf:type rdf:Property ;
    rdfs:label 'Quantity Budgeted' ;
    rdfs:comment 'Original budgeted quantity of work for this cost account as derived from the Bill of Quantities (BOQ) or Material Take-Off (MTO). Expressed in the unit of measure applicable to the cost type (e.g., m3 for concrete, tonnes for steel, hours for labor). Enables unit rate analysis and productivity benchmarking.' ;
    rdfs:domain ind:CostAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reportingPeriodDate rdf:type rdf:Property ;
    rdfs:label 'Reporting Period Date' ;
    rdfs:comment 'The data date or cut-off date as of which the cost account financial figures (actual cost, earned value, planned value, forecast) are reported. Aligns with the project monthly cost report cycle and EVM data date in Oracle Primavera P6.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:deliverableId rdf:type rdf:Property ;
    rdfs:label 'Deliverable Id' ;
    rdfs:comment 'Unique surrogate identifier for the project deliverable record in the silver layer lakehouse. Primary key for this entity.' ;
    rdfs:domain ind:Deliverable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:acceptanceDate rdf:type rdf:Property ;
    rdfs:label 'Acceptance Date' ;
    rdfs:comment 'Date on which the deliverable was formally accepted by the client or approving authority. Used for handover milestone tracking and DLP commencement.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:acceptanceStatus rdf:type rdf:Property ;
    rdfs:label 'Acceptance Status' ;
    rdfs:comment 'Client or reviewer acceptance status of the deliverable following formal review. Indicates whether the deliverable has been accepted, accepted with comments, or rejected and requires resubmission.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualIssueDate rdf:type rdf:Property ;
    rdfs:label 'Actual Issue Date' ;
    rdfs:comment 'Date on which the deliverable was actually issued or transmitted. Populated upon completion and used to calculate schedule variance and support DLP (Defects Liability Period) tracking.' ;
    rdfs:domain ind:Deliverable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:deliverableCategory rdf:type rdf:Property ;
    rdfs:label 'Deliverable Category' ;
    rdfs:comment 'High-level category grouping the deliverable within the EPC (Engineering, Procurement, and Construction) project phases. Supports phase-based reporting and PMO governance. [ENUM-REF-CANDIDATE: engineering|procurement|construction|commissioning|handover|safety|quality — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Deliverable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliverableCode rdf:type rdf:Property ;
    rdfs:label 'Deliverable Code' ;
    rdfs:comment 'Unique alphanumeric code identifying the deliverable within the project document control system. Typically assigned by the document management system (e.g., Aconex or Procore) and used for transmittal and correspondence tracking.' ;
    rdfs:domain ind:Deliverable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliverableStatus rdf:type rdf:Property ;
    rdfs:label 'Deliverable Status' ;
    rdfs:comment 'Current lifecycle status of the deliverable within the review and approval workflow. Tracks progression from initiation through approval or rejection in the document control system. [ENUM-REF-CANDIDATE: not_started|in_progress|under_review|approved|rejected|superseded|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Deliverable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliverableType rdf:type rdf:Property ;
    rdfs:label 'Deliverable Type' ;
    rdfs:comment 'Classification of the deliverable by its output category. Distinguishes engineering drawings, specifications, reports, calculations, procedures, commissioning packages, handover documents, and Inspection and Test Plans (ITPs). [ENUM-REF-CANDIDATE: engineering_drawing|specification|report|calculation|procedure|commissioning_package|handover_document|inspection_test_plan|method_statement|data_sheet — promote to reference product]' ;
    rdfs:domain ind:Deliverable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eotApplicable rdf:type rdf:Property ;
    rdfs:label 'Eot Applicable' ;
    rdfs:comment 'Indicates whether an Extension of Time (EOT) claim has been applied to the planned issue date of this deliverable. Supports contract administration and schedule delay analysis.' ;
    rdfs:domain ind:Deliverable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:forecastIssueDate rdf:type rdf:Property ;
    rdfs:label 'Forecast Issue Date' ;
    rdfs:comment 'Current forecast date for issuing the deliverable, updated during project progress reviews. Reflects schedule changes and is compared against the planned issue date to identify delays.' ;
    rdfs:domain ind:Deliverable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isContractual rdf:type rdf:Property ;
    rdfs:label 'Is Contractual' ;
    rdfs:comment 'Indicates whether this deliverable is a contractually mandated output as defined in the contract scope of work or BOQ (Bill of Quantities). Distinguishes contractual obligations from internally generated technical documents.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isDlpApplicable rdf:type rdf:Property ;
    rdfs:label 'Is Dlp Applicable' ;
    rdfs:comment 'Indicates whether this deliverable is subject to the Defects Liability Period (DLP) obligations under the contract. Enables DLP tracking and defect notification management.' ;
    rdfs:domain ind:Deliverable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isHandoverRequired rdf:type rdf:Property ;
    rdfs:label 'Is Handover Required' ;
    rdfs:comment 'Indicates whether this deliverable must be included in the project handover package to the client. Supports commissioning and handover completeness tracking.' ;
    rdfs:domain ind:Deliverable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nativeFileFormat rdf:type rdf:Property ;
    rdfs:label 'Native File Format' ;
    rdfs:comment 'File format of the deliverable document (e.g., PDF, DWG, DXF, REVIT, IFC, XLSX). Supports document management, BIM coordination, and digital handover requirements. [ENUM-REF-CANDIDATE: PDF|DWG|DXF|REVIT|IFC|XLSX|DOCX|XML|CSV — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Deliverable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewReturnDate rdf:type rdf:Property ;
    rdfs:label 'Review Return Date' ;
    rdfs:comment 'Actual date on which the reviewer returned comments or approval decision. Compared against review due date to track reviewer compliance and contract obligations.' ;
    rdfs:domain ind:Deliverable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:revisionStatusCode rdf:type rdf:Property ;
    rdfs:label 'Revision Status Code' ;
    rdfs:comment 'Industry-standard document issue purpose code indicating the intent of the current revision: IFR (Issued for Review), IFC (Issued for Construction), IFI (Issued for Information), IFB (Issued for Bid), AFC (Approved for Construction), AFD (Approved for Design), ASB (As-Built). Critical for construction document control. [ENUM-REF-CANDIDATE: IFR|IFC|IFI|IFB|AFC|AFD|ASB — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Deliverable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageLocationUrl rdf:type rdf:Property ;
    rdfs:label 'Storage Location Url' ;
    rdfs:comment 'URL or path to the deliverable file stored in the document management system (e.g., Aconex, Autodesk BIM 360, or SharePoint). Provides direct access to the source document.' ;
    rdfs:domain ind:Deliverable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:weightFactor rdf:type rdf:Property ;
    rdfs:label 'Weight Factor' ;
    rdfs:comment 'Relative weighting of this deliverable within the project progress measurement system. Used to calculate weighted progress and Earned Value (EV) contributions at the project or WBS level.' ;
    rdfs:domain ind:Deliverable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:evmPeriodRecordId rdf:type rdf:Property ;
    rdfs:label 'Evm Period Record Id' ;
    rdfs:comment 'Unique surrogate identifier for each EVM period record. Primary key for the evm_period_record data product in the Databricks Silver Layer.' ;
    rdfs:domain ind:EvmPeriodRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reportingPeriodId rdf:type rdf:Property ;
    rdfs:label 'Reporting Period Id' ;
    rdfs:comment 'Reference to the fiscal or project reporting period (e.g., monthly cut) for which this EVM record applies. Enables period-over-period trend analysis.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ReportingPeriod .

ind:acwp rdf:type rdf:Property ;
    rdfs:label 'Acwp' ;
    rdfs:comment 'The cumulative actual cost incurred for work performed as of the data date. Also known as Actual Cost (AC). Sourced from SAP S/4HANA Project Systems actual postings and Viewpoint Vista job costing.' ;
    rdfs:domain ind:EvmPeriodRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:baselineCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Baseline Completion Date' ;
    rdfs:comment 'The approved baseline scheduled completion date for this WBS element or project as established at NTP (Notice to Proceed) or last approved baseline revision. Used to calculate schedule variance in time terms.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:bcwp rdf:type rdf:Property ;
    rdfs:label 'Bcwp' ;
    rdfs:comment 'The cumulative budgeted cost of work actually performed (earned) as of the data date. Also known as Earned Value (EV). Computed from physical_percent_complete multiplied by budget_at_completion.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bcws rdf:type rdf:Property ;
    rdfs:label 'Bcws' ;
    rdfs:comment 'The cumulative budgeted cost of work that was planned to be completed as of the data date, per the approved baseline schedule. Also known as Planned Value (PV). Core EVM metric sourced from Oracle Primavera P6 baseline.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cpiTrend rdf:type rdf:Property ;
    rdfs:label 'Cpi Trend' ;
    rdfs:comment 'Directional trend of the CPI compared to the previous reporting period. Indicates whether cost performance is improving, stable, or deteriorating. Used in PMO dashboard reporting and management escalation.' ;
    rdfs:domain ind:EvmPeriodRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eac rdf:type rdf:Property ;
    rdfs:label 'Eac' ;
    rdfs:comment 'The current forecast of total cost to complete the entire scope of work. Represents the best estimate of final project cost including all actuals to date plus estimated cost to complete. Core to P&L reporting and project financial health monitoring.' ;
    rdfs:domain ind:EvmPeriodRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:earnedQuantity rdf:type rdf:Property ;
    rdfs:label 'Earned Quantity' ;
    rdfs:comment 'The quantity of work physically completed and verified as of the data date, expressed in the unit of measure applicable to the WBS element (e.g., m3 of concrete poured, linear metres of pipe installed). Used in units-complete measurement method.' ;
    rdfs:domain ind:EvmPeriodRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:etc rdf:type rdf:Property ;
    rdfs:label 'Etc' ;
    rdfs:comment 'The current forecast of remaining cost required to complete all outstanding scope of work from the data date to project completion. Calculated as EAC minus ACWP.' ;
    rdfs:domain ind:EvmPeriodRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:forecastMethod rdf:type rdf:Property ;
    rdfs:label 'Forecast Method' ;
    rdfs:comment 'The methodology used to derive the Estimate at Completion (EAC) for this period record. Governs how the EAC and ETC values were calculated. [ENUM-REF-CANDIDATE: cpi_based|management_override|bottom_up_reestimate|cpi_spi_composite|eac_equals_bac — promote to reference product]' ;
    rdfs:domain ind:EvmPeriodRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:installedQuantity rdf:type rdf:Property ;
    rdfs:label 'Installed Quantity' ;
    rdfs:comment 'The total quantity of material or work physically installed in the permanent works as of the data date. May differ from earned quantity when rework or rejection adjustments apply.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:managementNarrative rdf:type rdf:Property ;
    rdfs:label 'Management Narrative' ;
    rdfs:comment 'Free-text management commentary explaining significant cost or schedule variances, corrective actions, risks, and forecast assumptions for this reporting period. Required for client monthly reporting and PMO governance packs.' ;
    rdfs:domain ind:EvmPeriodRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementDate rdf:type rdf:Property ;
    rdfs:label 'Measurement Date' ;
    rdfs:comment 'The date on which the physical progress measurement was conducted and verified in the field. May differ from the period end date when field surveys are conducted prior to period close.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:measurementLevel rdf:type rdf:Property ;
    rdfs:label 'Measurement Level' ;
    rdfs:comment 'Indicates the hierarchical level at which EVM metrics are measured and reported in this record (e.g., project summary, WBS level, or control account). [ENUM-REF-CANDIDATE: project|wbs_level_1|wbs_level_2|wbs_level_3|activity|control_account — promote to reference product]' ;
    rdfs:domain ind:EvmPeriodRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:periodAcwp rdf:type rdf:Property ;
    rdfs:label 'Period Acwp' ;
    rdfs:comment 'The actual cost incurred for the current reporting period only. Enables period-on-period cost trend analysis and monthly P&L reporting. Sourced from SAP S/4HANA actual cost postings.' ;
    rdfs:domain ind:EvmPeriodRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:periodBcwp rdf:type rdf:Property ;
    rdfs:label 'Period Bcwp' ;
    rdfs:comment 'The earned value (BCWP) for the current reporting period only. Enables period-on-period trend analysis and supports monthly progress payment certificate calculations.' ;
    rdfs:domain ind:EvmPeriodRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:periodBcws rdf:type rdf:Property ;
    rdfs:label 'Period Bcws' ;
    rdfs:comment 'The planned value (BCWS) for the current reporting period only, as distinct from the cumulative BCWS. Enables period-on-period trend analysis and monthly progress billing reconciliation.' ;
    rdfs:domain ind:EvmPeriodRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:periodEndDate rdf:type rdf:Property ;
    rdfs:label 'Period End Date' ;
    rdfs:comment 'The calendar end date of the reporting period covered by this EVM record. Defines the data cut-off for progress measurement and cost capture.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:periodStartDate rdf:type rdf:Property ;
    rdfs:label 'Period Start Date' ;
    rdfs:comment 'The calendar start date of the reporting period covered by this EVM record. Used to bound the measurement window for progress and cost data.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:physicalPercentComplete rdf:type rdf:Property ;
    rdfs:label 'Physical Percent Complete' ;
    rdfs:comment 'The verified physical progress percentage for this WBS element or project as of the data date. Measured by the verifying engineer and used to compute earned value (BCWP/EV). Range: 0.00 to 100.00.' ;
    rdfs:domain ind:EvmPeriodRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:progressMeasurementMethod rdf:type rdf:Property ;
    rdfs:label 'Progress Measurement Method' ;
    rdfs:comment 'The approved method used to calculate physical percent complete for this WBS element or activity. Governs how earned value (BCWP/EV) is computed. [ENUM-REF-CANDIDATE: weighted_steps|milestone|units_complete|level_of_effort|percent_complete|50_50_rule — promote to reference product]' ;
    rdfs:domain ind:EvmPeriodRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Quantity Unit Of Measure' ;
    rdfs:comment 'The unit of measure applicable to earned_quantity and installed_quantity for this WBS element (e.g., m3, LM, EA, TON, m2). Sourced from the BOQ (Bill of Quantities).' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:spiTrend rdf:type rdf:Property ;
    rdfs:label 'Spi Trend' ;
    rdfs:comment 'Directional trend of the SPI compared to the previous reporting period. Indicates whether schedule performance is improving, stable, or deteriorating. Used in PMO dashboard reporting and client monthly reporting.' ;
    rdfs:domain ind:EvmPeriodRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tcpi rdf:type rdf:Property ;
    rdfs:label 'Tcpi' ;
    rdfs:comment 'The cost performance efficiency required on remaining work to meet the budget at completion (BAC) or estimate at completion (EAC). Calculated as (BAC minus BCWP) divided by (BAC minus ACWP). Indicates future cost efficiency needed.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vac rdf:type rdf:Property ;
    rdfs:label 'Vac' ;
    rdfs:comment 'The projected cost variance at project completion, calculated as BAC minus EAC. A positive value indicates projected under-budget completion; negative indicates projected cost overrun. Critical for P&L forecasting and EBITDA reporting.' ;
    rdfs:domain ind:EvmPeriodRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:verifyingEngineer rdf:type rdf:Property ;
    rdfs:label 'Verifying Engineer' ;
    rdfs:comment 'The name or identifier of the engineer or quantity surveyor who independently verified and certified the physical percent complete measurement for this period record. Required for progress payment certification.' ;
    rdfs:domain ind:EvmPeriodRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forecastId rdf:type rdf:Property ;
    rdfs:label 'Forecast Id' ;
    rdfs:comment 'Unique surrogate identifier for the rolling project cost and schedule forecast record in the Databricks Silver Layer. Primary key for the forecast data product.' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:forecastEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Forecast Employee Id' ;
    rdfs:comment 'Reference to the user (typically PMO Director or Project Controls Manager) who approved this forecast record for P&L reporting and PMO governance submission.' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:forecastPreparedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Forecast Prepared By User Employee Id' ;
    rdfs:comment 'Reference to the user (typically Project Controls Engineer or Cost Manager) who prepared and submitted this forecast record for PMO review.' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualCostToDate rdf:type rdf:Property ;
    rdfs:label 'Actual Cost To Date' ;
    rdfs:comment 'Total actual cost incurred on the project or WBS element from inception through the reporting period data date. Represents the Actual Cost of Work Performed (ACWP) in EVM terminology. Sourced from SAP S/4HANA cost postings.' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bacCost rdf:type rdf:Property ;
    rdfs:label 'Bac Cost' ;
    rdfs:comment 'The approved Budget at Completion (BAC) for the project or WBS element as of the reporting period, representing the total authorized budget. Used as the denominator for cost variance and variance at completion calculations.' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contingencyRemaining rdf:type rdf:Property ;
    rdfs:label 'Contingency Remaining' ;
    rdfs:comment 'The remaining contingency budget available for the project or WBS element as of the reporting period, after accounting for approved contingency drawdowns. Tracked separately from the base EAC to support risk-adjusted forecasting.' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costTrendIndicator rdf:type rdf:Property ;
    rdfs:label 'Cost Trend Indicator' ;
    rdfs:comment 'Management assessment of the directional trend in cost performance compared to the prior reporting period. Improving indicates the EAC has decreased; stable indicates no material change; deteriorating indicates the EAC has increased. Used for executive dashboard traffic-light reporting.' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costVariancePct rdf:type rdf:Property ;
    rdfs:label 'Cost Variance Pct' ;
    rdfs:comment 'Cost variance expressed as a percentage of the Budget at Completion (BAC), calculated as (BAC - EAC) / BAC × 100. Enables normalized comparison of cost performance across projects of different sizes.' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:eacCost rdf:type rdf:Property ;
    rdfs:label 'Eac Cost' ;
    rdfs:comment 'The current forward-looking Estimate at Completion (EAC) representing the total forecasted final cost of the project or WBS element as of the reporting period. Core EVM metric used for P&L reporting and PMO governance. Sourced from SAP S/4HANA Project Systems.' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:eacMovement rdf:type rdf:Property ;
    rdfs:label 'Eac Movement' ;
    rdfs:comment 'The change in Estimate at Completion (EAC) between the current and prior reporting period (current EAC minus prior period EAC). Positive values indicate cost growth; negative values indicate cost reduction. Key metric for P&L bridge and PMO governance reporting.' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:earnedValue rdf:type rdf:Property ;
    rdfs:label 'Earned Value' ;
    rdfs:comment 'The Earned Value (EV), also known as Budgeted Cost of Work Performed (BCWP), representing the budgeted value of work physically completed as of the reporting period. Core EVM input for CPI and SPI calculations.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:etcCost rdf:type rdf:Property ;
    rdfs:label 'Etc Cost' ;
    rdfs:comment 'The Estimate to Complete (ETC) representing the forecasted remaining cost required to finish the project or WBS element from the reporting period data date. Calculated as EAC minus actual cost to date. Key input for cash flow forecasting.' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:finalCost rdf:type rdf:Property ;
    rdfs:label 'Final Cost' ;
    rdfs:comment 'The management-adjusted forecast of the total final cost at project completion, which may differ from the EAC where management applies judgment overlays, risk provisions, or contingency drawdowns not yet reflected in the bottom-up EAC. Used for P&L reporting.' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:forecastNumber rdf:type rdf:Property ;
    rdfs:label 'Forecast Number' ;
    rdfs:comment 'Externally-known business identifier for this forecast record, typically formatted as a project code plus reporting period reference (e.g., PRJ-2024-FCT-007). Used in PMO governance reports and P&L submissions.' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isClientReported rdf:type rdf:Property ;
    rdfs:label 'Is Client Reported' ;
    rdfs:comment 'Indicates whether this forecast record has been formally reported to the client as part of contractual project reporting obligations. True indicates the forecast has been shared with the client; False indicates it is an internal management forecast only.' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:managementReserveRemaining rdf:type rdf:Property ;
    rdfs:label 'Management Reserve Remaining' ;
    rdfs:comment 'The remaining management reserve held at the project level as of the reporting period. Management reserve is distinct from contingency and is controlled by senior management for unknown-unknown risks. Tracked for PMO governance.' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:narrativeCommentary rdf:type rdf:Property ;
    rdfs:label 'Narrative Commentary' ;
    rdfs:comment 'Free-text management commentary explaining the key drivers of cost and schedule variances, significant changes from the prior period forecast, risk events, and corrective actions. Required for PMO governance reporting and client-facing project status reports.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorPeriodEac rdf:type rdf:Property ;
    rdfs:label 'Prior Period Eac' ;
    rdfs:comment 'The approved Estimate at Completion (EAC) from the immediately preceding reporting period. Stored on the forecast record to enable period-over-period movement analysis without requiring a self-join, supporting PMO trend reporting and P&L bridge analysis.' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reportingCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Reporting Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter code for the functional or reporting currency to which project amounts are converted for consolidated P&L and PMO portfolio reporting. Distinct from the project transaction currency.' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskProvisionAmount rdf:type rdf:Property ;
    rdfs:label 'Risk Provision Amount' ;
    rdfs:comment 'The quantified risk provision included in the forecast final cost to cover identified project risks that have not yet materialized. Distinct from contingency; represents probabilistic risk exposure recognized in the P&L forecast.' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scheduleTrendIndicator rdf:type rdf:Property ;
    rdfs:label 'Schedule Trend Indicator' ;
    rdfs:comment 'Management assessment of the directional trend in schedule performance compared to the prior reporting period. Improving indicates the forecast completion date has advanced; stable indicates no material change; deteriorating indicates further delay. Used for executive dashboard reporting.' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:handoverCertificateId rdf:type rdf:Property ;
    rdfs:label 'Handover Certificate Id' ;
    rdfs:comment 'Unique system-generated identifier for the handover certificate record. Primary key for the handover_certificate data product within the project domain.' ;
    rdfs:domain ind:HandoverCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:clientSignatoryContactId rdf:type rdf:Property ;
    rdfs:label 'Client Signatory Contact Id' ;
    rdfs:comment 'Foreign key linking to client.contact. Business justification: Handover certificate requires linking to the client signatory contact for legal sign-off tracking and audit compliance.' ;
    rdfs:domain ind:HandoverCertificate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Contact .

ind:asBuiltDrawingReference rdf:type rdf:Property ;
    rdfs:label 'As Built Drawing Reference' ;
    rdfs:comment 'Document transmittal or register reference for the as-built drawings submitted as part of the handover package. Confirms that record drawings have been delivered to the client.' ;
    rdfs:domain ind:HandoverCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificateStatus rdf:type rdf:Property ;
    rdfs:label 'Certificate Status' ;
    rdfs:comment 'Current lifecycle status of the handover certificate. Draft: under preparation; Issued: formally submitted to client; Accepted: client has signed acceptance; Rejected: client has declined acceptance; Superseded: replaced by a revised certificate.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clientSignatoryTitle rdf:type rdf:Property ;
    rdfs:label 'Client Signatory Title' ;
    rdfs:comment 'Job title or designation of the client representative who signed the handover certificate (e.g., Client Project Manager, Engineer\'s Representative, Owner\'s Representative). Validates the authority level of the acceptance.' ;
    rdfs:domain ind:HandoverCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commissioningCompleted rdf:type rdf:Property ;
    rdfs:label 'Commissioning Completed' ;
    rdfs:comment 'Indicates whether commissioning activities have been fully completed for the works included in the handover scope. Commissioning completion is a mandatory prerequisite for final handover in EPC and infrastructure projects.' ;
    rdfs:domain ind:HandoverCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contractorSignatoryName rdf:type rdf:Property ;
    rdfs:label 'Contractor Signatory Name' ;
    rdfs:comment 'Full name of the authorized contractor representative who signed the handover certificate on behalf of the contractor organization. Required for contractual validity of the certificate.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractorSignatoryTitle rdf:type rdf:Property ;
    rdfs:label 'Contractor Signatory Title' ;
    rdfs:comment 'Job title or designation of the contractor representative who signed the handover certificate (e.g., Project Director, Site Manager, Construction Manager). Validates the authority level of the signatory.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engineerSignatoryName rdf:type rdf:Property ;
    rdfs:label 'Engineer Signatory Name' ;
    rdfs:comment 'Full name of the Engineer (or Engineer\'s Representative) under FIDIC contracts who countersigns the handover certificate. Applicable under FIDIC Red/Yellow/Silver Book delivery models where an independent Engineer administers the contract.' ;
    rdfs:domain ind:HandoverCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eotDaysApplied rdf:type rdf:Property ;
    rdfs:label 'Eot Days Applied' ;
    rdfs:comment 'Total number of Extension of Time (EOT) days granted and applied to the contractual completion date for the scope covered by this handover certificate. Affects LD liability calculation and schedule performance reporting.' ;
    rdfs:domain ind:HandoverCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fatCompleted rdf:type rdf:Property ;
    rdfs:label 'Fat Completed' ;
    rdfs:comment 'Indicates whether Factory Acceptance Testing (FAT) has been completed for all equipment and systems included in the handover scope. FAT is a prerequisite for handover in EPC and MEP-intensive projects.' ;
    rdfs:domain ind:HandoverCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:handoverType rdf:type rdf:Property ;
    rdfs:label 'Handover Type' ;
    rdfs:comment 'Classification of the handover certificate indicating the nature and extent of the transfer of works. Partial: a defined portion of works; Sectional: a contractually defined section; Substantial Completion: works are practically complete with minor outstanding items; Final: all works including punch list resolved; Provisional: conditional acceptance pending outstanding items.' ;
    rdfs:domain ind:HandoverCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hseClearanceObtained rdf:type rdf:Property ;
    rdfs:label 'Hse Clearance Obtained' ;
    rdfs:comment 'Indicates whether all required Health, Safety, and Environment (HSE) clearances and regulatory approvals have been obtained prior to handover. Includes OSHA compliance, environmental permits, and occupancy certificates.' ;
    rdfs:domain ind:HandoverCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:itpCompleted rdf:type rdf:Property ;
    rdfs:label 'Itp Completed' ;
    rdfs:comment 'Indicates whether all Inspection and Test Plan (ITP) hold points and witness points for the works scope have been completed and signed off prior to handover. ITP completion is a mandatory QA/QC prerequisite for handover.' ;
    rdfs:domain ind:HandoverCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ldLiabilityEndDate rdf:type rdf:Property ;
    rdfs:label 'Ld Liability End Date' ;
    rdfs:comment 'The date on which the contractor\'s exposure to Liquidated Damages (LD) for delay ceases, typically aligned with the handover acceptance date. Critical for financial exposure tracking and contract administration.' ;
    rdfs:domain ind:HandoverCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:omManualReference rdf:type rdf:Property ;
    rdfs:label 'Om Manual Reference' ;
    rdfs:comment 'Document reference number for the Operations and Maintenance (O&M) manual submitted as part of the handover package. Confirms that O&M documentation has been provided to the client as a condition of handover.' ;
    rdfs:domain ind:HandoverCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:procoreSubmittalReference rdf:type rdf:Property ;
    rdfs:label 'Procore Submittal Reference' ;
    rdfs:comment 'The submittal identifier assigned to the handover certificate package in Procore Construction Management. Enables cross-system traceability between the data lakehouse and the operational construction management platform.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:punchListCloseDate rdf:type rdf:Property ;
    rdfs:label 'Punch List Close Date' ;
    rdfs:comment 'The date by which all outstanding punch list items are contractually required to be resolved and closed. Agreed between contractor and client at the time of handover.' ;
    rdfs:domain ind:HandoverCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:punchListCriticalCount rdf:type rdf:Property ;
    rdfs:label 'Punch List Critical Count' ;
    rdfs:comment 'Number of punch list items classified as critical or Category A at the time of handover, representing items that must be resolved before or immediately after handover. Distinct from total punch list count.' ;
    rdfs:domain ind:HandoverCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:punchListItemCount rdf:type rdf:Property ;
    rdfs:label 'Punch List Item Count' ;
    rdfs:comment 'Total number of outstanding punch list items (minor defects, incomplete works, or non-conformances) recorded at the time of handover certificate issuance. A key indicator of completion quality at handover.' ;
    rdfs:domain ind:HandoverCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:regulatoryApprovalReference rdf:type rdf:Property ;
    rdfs:label 'Regulatory Approval Reference' ;
    rdfs:comment 'Reference number or identifier of the regulatory authority approval (e.g., building permit, occupancy certificate, environmental clearance) obtained as a condition of handover. Required for compliance with IBC, OSHA, and EPA regulations.' ;
    rdfs:domain ind:HandoverCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retentionReleaseEligible rdf:type rdf:Property ;
    rdfs:label 'Retention Release Eligible' ;
    rdfs:comment 'Indicates whether the issuance of this handover certificate triggers eligibility for release of contractual retention monies held by the client. Typically, substantial completion or final handover certificates trigger partial or full retention release.' ;
    rdfs:domain ind:HandoverCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:satCompleted rdf:type rdf:Property ;
    rdfs:label 'Sat Completed' ;
    rdfs:comment 'Indicates whether Site Acceptance Testing (SAT) has been completed for all systems and equipment included in the handover scope. SAT confirms that systems function correctly in their installed environment prior to handover.' ;
    rdfs:domain ind:HandoverCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sparePartsDelivered rdf:type rdf:Property ;
    rdfs:label 'Spare Parts Delivered' ;
    rdfs:comment 'Indicates whether all contractually required spare parts and consumables have been delivered to the client as part of the handover package. Spare parts delivery is a standard handover condition in EPC and infrastructure contracts.' ;
    rdfs:domain ind:HandoverCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:worksLocation rdf:type rdf:Property ;
    rdfs:label 'Works Location' ;
    rdfs:comment 'Physical location or site area description of the works being handed over (e.g., Building A - Floors 1-5, Highway Section KM 12-18, Substation Block C). Provides geographic and spatial context for the handover scope.' ;
    rdfs:domain ind:HandoverCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualCost rdf:type rdf:Property ;
    rdfs:label 'Actual Cost' ;
    rdfs:comment 'Total actual costs incurred for work performed within this phase to date, representing the Actual Cost of Work Performed (ACWP) in EVM terminology. Sourced from SAP S/4HANA and Viewpoint Vista job costing modules.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualFinishDate rdf:type rdf:Property ;
    rdfs:label 'Actual Finish Date' ;
    rdfs:comment 'The date on which all work within this phase was physically completed and accepted. Populated upon phase gate approval or formal handover documentation sign-off.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:baselineDurationDays rdf:type rdf:Property ;
    rdfs:label 'Baseline Duration Days' ;
    rdfs:comment 'Approved baseline duration of the phase in calendar days, derived from the original project schedule. Used as the denominator for schedule performance measurement and variance reporting.' ;
    rdfs:domain ind:Phase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:budgetedCost rdf:type rdf:Property ;
    rdfs:label 'Budgeted Cost' ;
    rdfs:comment 'The approved budget allocated to this phase, representing the Budgeted Cost of Work Scheduled (BCWS) or Planned Value (PV) in EVM terminology. Sourced from SAP S/4HANA Project Systems cost planning and used for cost variance analysis.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contingencyBudget rdf:type rdf:Property ;
    rdfs:label 'Contingency Budget' ;
    rdfs:comment 'Contingency reserve allocated to this phase to cover identified and unidentified risks. Managed separately from the base budget in SAP S/4HANA Project Systems and released upon formal risk event occurrence.' ;
    rdfs:domain ind:Phase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deliverablesChecklist rdf:type rdf:Property ;
    rdfs:label 'Deliverables Checklist' ;
    rdfs:comment 'Structured list or description of mandatory deliverables required for phase completion (e.g., IFC drawings, BOQ, ITP, commissioning dossier). Stored as a delimited string or JSON-serialized list. Supports phase-gate governance and QA/QC compliance.' ;
    rdfs:domain ind:Phase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliverablesCompletionPct rdf:type rdf:Property ;
    rdfs:label 'Deliverables Completion Pct' ;
    rdfs:comment 'Percentage of mandatory phase deliverables that have been completed and accepted as of the latest update (0.00–100.00). Supports phase gate readiness assessment and PMO reporting.' ;
    rdfs:domain ind:Phase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:evmWeightPct rdf:type rdf:Property ;
    rdfs:label 'Evm Weight Pct' ;
    rdfs:comment 'Weighting factor assigned to this phase for EVM (Earned Value Management) rollup to the project level, expressed as a percentage of total project value (0.00–100.00). All phase weights must sum to 100 per project. Drives CPI and SPI calculations.' ;
    rdfs:domain ind:Phase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:floatDays rdf:type rdf:Property ;
    rdfs:label 'Float Days' ;
    rdfs:comment 'Total float (slack) available for this phase in calendar days, as calculated by CPM (Critical Path Method) analysis in Oracle Primavera P6. Negative float indicates a schedule overrun. Used for schedule risk assessment and EOT (Extension of Time) claims.' ;
    rdfs:domain ind:Phase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:gateApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Gate Approval Date' ;
    rdfs:comment 'The date on which the phase gate was formally approved by the authorized approver, permitting progression to the next project phase. Recorded in the PMO governance register and Aconex document management system.' ;
    rdfs:domain ind:Phase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:gateApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Gate Approval Status' ;
    rdfs:comment 'Current approval status of the phase gate review. Controls authorization to proceed to the next phase. Managed through PMO governance workflows and documented in Aconex or Procore approval workflows.' ;
    rdfs:domain ind:Phase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gateApproverName rdf:type rdf:Property ;
    rdfs:label 'Gate Approver Name' ;
    rdfs:comment 'Name or role title of the individual or authority who approved the phase gate (e.g., Project Director, Client Representative, PMO Head). Provides audit trail for governance accountability.' ;
    rdfs:domain ind:Phase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gateReviewCriteria rdf:type rdf:Property ;
    rdfs:label 'Gate Review Criteria' ;
    rdfs:comment 'Textual description of the mandatory completion criteria and deliverables that must be satisfied before the phase gate can be approved and the next phase authorized. Aligned with PMO governance and FIDIC contract requirements.' ;
    rdfs:domain ind:Phase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hsePlanApproved rdf:type rdf:Property ;
    rdfs:label 'Hse Plan Approved' ;
    rdfs:comment 'Indicates whether the HSE (Health Safety and Environment) plan for this phase has been formally approved prior to commencement. A prerequisite for phase authorization under OSHA and ISO 45001 compliance requirements.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ldExposureAmount rdf:type rdf:Property ;
    rdfs:label 'Ld Exposure Amount' ;
    rdfs:comment 'Calculated financial exposure to Liquidated Damages (LD) for this phase based on contractual LD rate and current schedule delay. Used for financial risk reporting and contract administration. Expressed in the phase currency.' ;
    rdfs:domain ind:Phase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:leedApplicable rdf:type rdf:Property ;
    rdfs:label 'Leed Applicable' ;
    rdfs:comment 'Indicates whether LEED (Leadership in Energy and Environmental Design) sustainability requirements apply to this phase. When true, phase deliverables and activities must comply with USGBC LEED certification criteria.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:milestoneCount rdf:type rdf:Property ;
    rdfs:label 'Milestone Count' ;
    rdfs:comment 'Total number of contractual or PMO-defined milestones associated with this phase. Provides a summary indicator of phase complexity and governance checkpoint density for PMO reporting.' ;
    rdfs:domain ind:Phase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:phaseDescription rdf:type rdf:Property ;
    rdfs:label 'Phase Description' ;
    rdfs:comment 'Detailed narrative description of the scope of work, objectives, and key activities encompassed within this project phase. Used in project documentation, client reporting, and PMO governance records.' ;
    rdfs:domain ind:Phase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phaseName rdf:type rdf:Property ;
    rdfs:label 'Phase Name' ;
    rdfs:comment 'Human-readable name of the construction project lifecycle phase (e.g., Front-End Engineering Design, Procurement, Construction, Commissioning). Used in reporting, dashboards, and PMO governance documents.' ;
    rdfs:domain ind:Phase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phaseStatus rdf:type rdf:Property ;
    rdfs:label 'Phase Status' ;
    rdfs:comment 'Current lifecycle state of the construction project phase. Drives PMO governance workflows, EVM reporting eligibility, and phase-gate approval triggers. Sourced from Oracle Primavera P6 activity status.' ;
    rdfs:domain ind:Phase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phaseType rdf:type rdf:Property ;
    rdfs:label 'Phase Type' ;
    rdfs:comment 'Standardized classification of the phase within the EPC/DB/DBB/PPP project lifecycle. Drives phase-gate governance rules, EVM rollup logic, and reporting hierarchies. [ENUM-REF-CANDIDATE: feasibility|pre_construction|feed|detailed_engineering|procurement|construction|pre_commissioning|commissioning|handover|dlp — promote to reference product]' ;
    rdfs:domain ind:Phase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedFinishDate rdf:type rdf:Property ;
    rdfs:label 'Planned Finish Date' ;
    rdfs:comment 'Baseline-scheduled finish date for the phase as established in the approved project schedule. Used for schedule variance analysis, milestone tracking, and contractual deadline compliance.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qualityPlanApproved rdf:type rdf:Property ;
    rdfs:label 'Quality Plan Approved' ;
    rdfs:comment 'Indicates whether the Quality Management Plan (including ITP - Inspection and Test Plan) for this phase has been formally approved. Required under ISO 9001 and contract QA/QC requirements before phase work commences.' ;
    rdfs:domain ind:Phase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sapWbsElement rdf:type rdf:Property ;
    rdfs:label 'Sap Wbs Element' ;
    rdfs:comment 'The SAP S/4HANA Project Systems WBS element code corresponding to this phase. Enables cost and budget data reconciliation between the lakehouse and SAP PS for financial reporting and EVM analysis.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Sequence Number' ;
    rdfs:comment 'Integer ordering of the phase within the project lifecycle. Determines the execution sequence for scheduling, phase-gate progression, and earned value rollup. Lower numbers execute first.' ;
    rdfs:domain ind:Phase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:progressMeasurementId rdf:type rdf:Property ;
    rdfs:label 'Progress Measurement Id' ;
    rdfs:comment 'Unique surrogate identifier for each periodic physical progress measurement record. Primary key for the progress_measurement data product in the project domain Silver layer.' ;
    rdfs:domain ind:ProgressMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:billingPeriodReference rdf:type rdf:Property ;
    rdfs:label 'Billing Period Reference' ;
    rdfs:comment 'Reference identifier of the progress billing certificate or payment application period to which this measurement contributes (e.g., IPC-007, PA-2024-03). Links measurement data to the contract administration billing cycle.' ;
    rdfs:domain ind:ProgressMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isBillingEligible rdf:type rdf:Property ;
    rdfs:label 'Is Billing Eligible' ;
    rdfs:comment 'Indicates whether this approved progress measurement qualifies for inclusion in a progress billing certificate or payment application (True/False). Controlled by measurement_status and contract billing terms.' ;
    rdfs:domain ind:ProgressMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isMilestone rdf:type rdf:Property ;
    rdfs:label 'Is Milestone' ;
    rdfs:comment 'Indicates whether this progress measurement corresponds to a contractual or project milestone event (True) rather than a continuous activity (False). Milestone measurements trigger specific billing and reporting actions.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:measurementNumber rdf:type rdf:Property ;
    rdfs:label 'Measurement Number' ;
    rdfs:comment 'Externally-known business identifier for this measurement record, typically formatted as a sequential reference number (e.g., PM-2024-00123). Used in progress billing certificates and PMO reporting.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementSource rdf:type rdf:Property ;
    rdfs:label 'Measurement Source' ;
    rdfs:comment 'Originating operational system from which this progress measurement was sourced. Supports data lineage traceability across HCSS HeavyJob production tracking, Procore field management, and Oracle Primavera P6.' ;
    rdfs:domain ind:ProgressMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementStatus rdf:type rdf:Property ;
    rdfs:label 'Measurement Status' ;
    rdfs:comment 'Current workflow lifecycle state of the progress measurement record, from initial field capture through engineer verification to client approval. Controls eligibility for progress billing.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementType rdf:type rdf:Property ;
    rdfs:label 'Measurement Type' ;
    rdfs:comment 'Classifies whether this measurement record captures physical progress only, financial progress (cost-based), or a combined physical and financial assessment. Determines which EVM fields are populated.' ;
    rdfs:domain ind:ProgressMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:periodInstalledQuantity rdf:type rdf:Property ;
    rdfs:label 'Period Installed Quantity' ;
    rdfs:comment 'Physical quantity of work installed or completed during the current reporting period only (incremental, not cumulative). Feeds period progress billing and production rate analysis in HCSS HeavyJob.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedPercentComplete rdf:type rdf:Property ;
    rdfs:label 'Planned Percent Complete' ;
    rdfs:comment 'Baseline-scheduled percent complete for this WBS element or activity as of the measurement date, derived from the approved project baseline in Primavera P6. Used to compute SPI (Schedule Performance Index) variance.' ;
    rdfs:domain ind:ProgressMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:previousPercentComplete rdf:type rdf:Property ;
    rdfs:label 'Previous Percent Complete' ;
    rdfs:comment 'Physical percent complete recorded in the immediately preceding reporting period. Enables period-over-period progress increment calculation and trend analysis without requiring a self-join.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reportingPeriodCode rdf:type rdf:Property ;
    rdfs:label 'Reporting Period Code' ;
    rdfs:comment 'Reference to the defined reporting period (weekly, monthly, or milestone-based) within which this progress measurement falls. Used for period-over-period EVM (Earned Value Management) analysis.' ;
    rdfs:domain ind:ProgressMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:verifierName rdf:type rdf:Property ;
    rdfs:label 'Verifier Name' ;
    rdfs:comment 'Full name of the engineer or site supervisor who physically verified and signed off this progress measurement. Retained for audit trail and contractual accountability under FIDIC and ISO 9001 requirements.' ;
    rdfs:domain ind:ProgressMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workArea rdf:type rdf:Property ;
    rdfs:label 'Work Area' ;
    rdfs:comment 'Physical site area, zone, or work front where the measured work is being performed (e.g., Zone A, Block 3, Pier 7). Aligns with site work front definitions used in HCSS HeavyJob and Procore daily logs.' ;
    rdfs:domain ind:ProgressMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectBudgetRevisionId rdf:type rdf:Property ;
    rdfs:label 'Project Budget Revision Id' ;
    rdfs:comment 'Unique surrogate identifier for each budget revision record within the project lifecycle. Primary key for the project_budget_revision data product.' ;
    rdfs:domain ind:ProjectBudgetRevision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryProjectEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Project Employee Id' ;
    rdfs:comment 'System user identifier of the person who formally approved this budget revision in the ERP or project management system. Provides a traceable link to the approver\'s user record for audit and governance purposes.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:baseCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Base Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter code for the project\'s base reporting currency to which all revision amounts are converted for consolidated financial reporting.' ;
    rdfs:domain ind:ProjectBudgetRevision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetCategory rdf:type rdf:Property ;
    rdfs:label 'Budget Category' ;
    rdfs:comment 'High-level cost category to which the budget revision applies. Enables cost category-level budget variance analysis across labour, materials, equipment, subcontract, indirect costs, contingency, and management reserve. [ENUM-REF-CANDIDATE: labour|materials|equipment|subcontract|indirect|contingency|management_reserve — promote to reference product]' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clientApprovedFlag rdf:type rdf:Property ;
    rdfs:label 'Client Approved Flag' ;
    rdfs:comment 'Indicates whether the budget revision has been formally approved by the client or owner, as distinct from internal project approval. Relevant for contract variations under FIDIC or GMP (Guaranteed Maximum Price) contracts where client sign-off is required.' ;
    rdfs:domain ind:ProjectBudgetRevision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contractBudgetImpact rdf:type rdf:Property ;
    rdfs:label 'Contract Budget Impact' ;
    rdfs:comment 'The portion of the budget revision amount that has a direct impact on the contract value (i.e., is recoverable from the client under the contract terms). Distinguishes between client-recoverable and internally-absorbed budget changes.' ;
    rdfs:domain ind:ProjectBudgetRevision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:controlAccountManager rdf:type rdf:Property ;
    rdfs:label 'Control Account Manager' ;
    rdfs:comment 'Name or identifier of the Control Account Manager (CAM) responsible for the WBS element or cost account affected by this revision. The CAM is accountable for budget performance under EVM (Earned Value Management) governance.' ;
    rdfs:domain ind:ProjectBudgetRevision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evmBaselineFlag rdf:type rdf:Property ;
    rdfs:label 'Evm Baseline Flag' ;
    rdfs:comment 'Indicates whether this revision updates the Performance Measurement Baseline (PMB) used for EVM (Earned Value Management) calculations including CPI and SPI. True if the revision is incorporated into the PMB; False if it is held outside (e.g., management reserve).' ;
    rdfs:domain ind:ProjectBudgetRevision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:externalRevisionReference rdf:type rdf:Property ;
    rdfs:label 'External Revision Reference' ;
    rdfs:comment 'The revision identifier or budget version number as recorded in the originating source system (e.g., SAP budget document number, Primavera P6 budget version ID). Enables cross-system reconciliation and traceability.' ;
    rdfs:domain ind:ProjectBudgetRevision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:internalBudgetImpact rdf:type rdf:Property ;
    rdfs:label 'Internal Budget Impact' ;
    rdfs:comment 'The portion of the budget revision amount absorbed internally by the contractor (not recoverable from the client). Represents the P&L (Profit and Loss) impact of the revision on the project\'s financial performance.' ;
    rdfs:domain ind:ProjectBudgetRevision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:justificationNarrative rdf:type rdf:Property ;
    rdfs:label 'Justification Narrative' ;
    rdfs:comment 'Free-text narrative providing the business rationale and supporting context for the budget revision. Required for audit trail compliance and PMO governance review. Captures scope changes, risk events, commercial decisions, or management directives driving the revision.' ;
    rdfs:domain ind:ProjectBudgetRevision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskEventReference rdf:type rdf:Property ;
    rdfs:label 'Risk Event Reference' ;
    rdfs:comment 'Reference to the risk register entry or risk event that triggered this budget revision, where applicable. Links budget revisions to the project risk management framework for risk-cost correlation analysis.' ;
    rdfs:domain ind:ProjectBudgetRevision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scopeChangeDescription rdf:type rdf:Property ;
    rdfs:label 'Scope Change Description' ;
    rdfs:comment 'Structured description of the scope change or event that necessitated this budget revision. Distinct from justification_narrative — this field captures the technical scope impact (e.g., additional earthworks volume, design change to structural steel) rather than the commercial rationale.' ;
    rdfs:domain ind:ProjectBudgetRevision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:aconexMailRef rdf:type rdf:Property ;
    rdfs:label 'Aconex Mail Ref' ;
    rdfs:comment 'Aconex correspondence or transmittal reference number for the formal change order submission and approval correspondence. Provides document management traceability.' ;
    rdfs:domain ind:ProjectChangeOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetLineItemRef rdf:type rdf:Property ;
    rdfs:label 'Budget Line Item Ref' ;
    rdfs:comment 'Reference to the project budget line item or BOQ (Bill of Quantities) item that this change order modifies. Enables budget impact tracking at line-item level.' ;
    rdfs:domain ind:ProjectChangeOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coNumber rdf:type rdf:Property ;
    rdfs:label 'Co Number' ;
    rdfs:comment 'Externally-visible sequential identifier for the change order as issued on the project (e.g., CO-00042). Used in all formal correspondence, contract administration, and client reporting.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contingencyDrawnAmount rdf:type rdf:Property ;
    rdfs:label 'Contingency Drawn Amount' ;
    rdfs:comment 'Amount drawn from the project contingency reserve to fund this change order, if applicable. Tracks contingency consumption at the CO level for project financial management.' ;
    rdfs:domain ind:ProjectChangeOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contractClauseReference rdf:type rdf:Property ;
    rdfs:label 'Contract Clause Reference' ;
    rdfs:comment 'Specific contract clause or FIDIC sub-clause under which the change order is raised (e.g., \'FIDIC Clause 13.1 — Right to Vary\'). Establishes contractual entitlement.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costImpactCurrency rdf:type rdf:Property ;
    rdfs:label 'Cost Impact Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the cost impact amount (e.g., USD, EUR, GBP). Required for multi-currency project environments.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:directCostAmount rdf:type rdf:Property ;
    rdfs:label 'Direct Cost Amount' ;
    rdfs:comment 'Direct labour, material, and equipment cost component of the change order before overhead and profit mark-up. Used for cost breakdown analysis and BOQ reconciliation.' ;
    rdfs:domain ind:ProjectChangeOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:drawingRevision rdf:type rdf:Property ;
    rdfs:label 'Drawing Revision' ;
    rdfs:comment 'Drawing revision number or BIM (Building Information Modeling) model version that forms the basis of the change order scope. Ensures design traceability.' ;
    rdfs:domain ind:ProjectChangeOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eotGrantedDays rdf:type rdf:Property ;
    rdfs:label 'Eot Granted Days' ;
    rdfs:comment 'Number of calendar days of Extension of Time formally approved and granted by the engineer or owner in response to this change order. May differ from the claimed schedule impact.' ;
    rdfs:domain ind:ProjectChangeOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isDisputed rdf:type rdf:Property ;
    rdfs:label 'Is Disputed' ;
    rdfs:comment 'Indicates whether the change order is subject to a formal dispute or claim between the contractor and the client/owner. True if disputed; False if agreed.' ;
    rdfs:domain ind:ProjectChangeOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isLdApplicable rdf:type rdf:Property ;
    rdfs:label 'Is Ld Applicable' ;
    rdfs:comment 'Indicates whether Liquidated Damages (LD) provisions are applicable to this change order in the event of delay. Relevant for schedule-impacting COs.' ;
    rdfs:domain ind:ProjectChangeOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:linkedNcrNumber rdf:type rdf:Property ;
    rdfs:label 'Linked Ncr Number' ;
    rdfs:comment 'Reference number of the Non-Conformance Report (NCR) associated with this change order, where the CO is issued to remediate a quality non-conformance.' ;
    rdfs:domain ind:ProjectChangeOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:linkedRfiNumber rdf:type rdf:Property ;
    rdfs:label 'Linked Rfi Number' ;
    rdfs:comment 'Reference number of the Request for Information (RFI) that triggered or is associated with this change order. Provides traceability from design query to contractual change.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overheadAndProfitAmount rdf:type rdf:Property ;
    rdfs:label 'Overhead And Profit Amount' ;
    rdfs:comment 'Overhead and profit mark-up applied to the direct cost to arrive at the total cost impact. Expressed in the contract currency.' ;
    rdfs:domain ind:ProjectChangeOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:procoreCoReference rdf:type rdf:Property ;
    rdfs:label 'Procore Co Reference' ;
    rdfs:comment 'Native change order identifier from the Procore Construction Management system. Used for data lineage, source system traceability, and reconciliation between the lakehouse and Procore.' ;
    rdfs:domain ind:ProjectChangeOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectChangeOrderDescription rdf:type rdf:Property ;
    rdfs:label 'Project Change Order Description' ;
    rdfs:comment 'Detailed narrative describing the scope of work added, reduced, or modified by this change order. Captures the full business justification and technical scope.' ;
    rdfs:domain ind:ProjectChangeOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapCoDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Co Document Number' ;
    rdfs:comment 'SAP S/4HANA project system document number generated when the approved change order is posted to the financial ledger. Enables reconciliation between project management and ERP.' ;
    rdfs:domain ind:ProjectChangeOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scopeOfWorkSummary rdf:type rdf:Property ;
    rdfs:label 'Scope Of Work Summary' ;
    rdfs:comment 'Concise summary of the physical scope of work added, removed, or modified by this change order. Complements the detailed description for executive reporting and CO registers.' ;
    rdfs:domain ind:ProjectChangeOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectMilestoneId rdf:type rdf:Property ;
    rdfs:label 'Project Milestone Id' ;
    rdfs:comment 'Unique surrogate identifier for each project milestone record in the Construction lakehouse Silver layer. Primary key for the project_milestone data product.' ;
    rdfs:domain ind:ProjectMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ownerContactId rdf:type rdf:Property ;
    rdfs:label 'Owner Contact Id' ;
    rdfs:comment 'Foreign key linking to client.contact. Business justification: Milestone owner contact needed for client notifications and acceptance sign-off per Milestone Management process.' ;
    rdfs:domain ind:ProjectMilestone ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Contact .

ind:predecessorMilestoneProjectMilestoneId rdf:type rdf:Property ;
    rdfs:label 'Predecessor Milestone Project Milestone Id' ;
    rdfs:comment 'Reference to the immediately preceding milestone in the project schedule logic chain. Supports Critical Path Method (CPM) analysis and schedule dependency tracking within the milestone network.' ;
    rdfs:domain ind:ProjectMilestone ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProjectMilestone .

ind:acceptanceCriteria rdf:type rdf:Property ;
    rdfs:label 'Acceptance Criteria' ;
    rdfs:comment 'Formal criteria that must be satisfied for the milestone to be considered achieved and accepted by the client or engineer. May reference ITP (Inspection and Test Plan) requirements, regulatory sign-offs, or contractual deliverable submissions.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eotDaysApproved rdf:type rdf:Property ;
    rdfs:label 'Eot Days Approved' ;
    rdfs:comment 'Total number of calendar days of approved Extension of Time (EOT) granted for this milestone under the contract. Reflects cumulative approved EOT claims that have adjusted the baseline date. Zero if no EOT has been granted.' ;
    rdfs:domain ind:ProjectMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:eotReference rdf:type rdf:Property ;
    rdfs:label 'Eot Reference' ;
    rdfs:comment 'Reference number of the approved EOT (Extension of Time) claim or contract amendment that adjusted the baseline date for this milestone. Used for contract administration audit trail and dispute resolution.' ;
    rdfs:domain ind:ProjectMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hseClearanceRequired rdf:type rdf:Property ;
    rdfs:label 'Hse Clearance Required' ;
    rdfs:comment 'Indicates whether HSE (Health, Safety and Environment) regulatory clearance or permit is a prerequisite for achieving this milestone (e.g., commissioning milestones requiring OSHA or EPA sign-off). True = HSE clearance must be obtained before milestone can be marked complete.' ;
    rdfs:domain ind:ProjectMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isLdTrigger rdf:type rdf:Property ;
    rdfs:label 'Is Ld Trigger' ;
    rdfs:comment 'Indicates whether missing this milestone triggers Liquidated Damages (LD) as specified in the contract. True = LD clause applies upon delay; False = no LD exposure for this milestone. Critical for contract risk management and financial exposure reporting.' ;
    rdfs:domain ind:ProjectMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPaymentTrigger rdf:type rdf:Property ;
    rdfs:label 'Is Payment Trigger' ;
    rdfs:comment 'Indicates whether achievement of this milestone triggers a contractual payment event or progress payment certificate under the contract payment schedule. True = milestone completion initiates a payment claim or invoice; False = no direct payment linkage.' ;
    rdfs:domain ind:ProjectMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ldCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Ld Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the Liquidated Damages (LD) daily rate (e.g., USD, EUR, GBP, AED). Ensures correct financial exposure reporting in multi-currency international EPC projects.' ;
    rdfs:domain ind:ProjectMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leedRelated rdf:type rdf:Property ;
    rdfs:label 'Leed Related' ;
    rdfs:comment 'Indicates whether this milestone is associated with LEED (Leadership in Energy and Environmental Design) certification requirements or green building compliance deliverables. True = milestone contributes to LEED certification pathway.' ;
    rdfs:domain ind:ProjectMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:milestoneCategory rdf:type rdf:Property ;
    rdfs:label 'Milestone Category' ;
    rdfs:comment 'Functional category grouping the milestone within the EPC (Engineering, Procurement, and Construction) project lifecycle phase. Supports schedule performance analysis by phase and PMO reporting. [ENUM-REF-CANDIDATE: design|procurement|construction|commissioning|handover|safety|financial|administrative — promote to reference product]' ;
    rdfs:domain ind:ProjectMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:milestoneStatus rdf:type rdf:Property ;
    rdfs:label 'Milestone Status' ;
    rdfs:comment 'Current lifecycle state of the milestone tracking its progress toward completion. \'not_started\' = work not yet begun; \'in_progress\' = activities underway; \'completed\' = milestone achieved; \'overdue\' = past planned date without completion; \'waived\' = formally waived by contract amendment; \'deferred\' = postponed with approved EOT (Extension of Time).' ;
    rdfs:domain ind:ProjectMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationAdvanceDays rdf:type rdf:Property ;
    rdfs:label 'Notification Advance Days' ;
    rdfs:comment 'Number of calendar days in advance of the milestone date that formal notification must be issued to the client or engineer, as required by the contract. Applicable when notification_required = True. Supports contract compliance monitoring.' ;
    rdfs:domain ind:ProjectMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:notificationRequired rdf:type rdf:Property ;
    rdfs:label 'Notification Required' ;
    rdfs:comment 'Indicates whether formal written notification to the client or engineer is contractually required prior to or upon achievement of this milestone. True = notification obligation exists per contract; False = no formal notification required.' ;
    rdfs:domain ind:ProjectMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:procoreMilestoneReference rdf:type rdf:Property ;
    rdfs:label 'Procore Milestone Reference' ;
    rdfs:comment 'The corresponding milestone or schedule item identifier in Procore Construction Management platform. Supports cross-system reconciliation between the scheduling system of record (Primavera P6) and the construction management platform (Procore).' ;
    rdfs:domain ind:ProjectMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectMilestoneDescription rdf:type rdf:Property ;
    rdfs:label 'Project Milestone Description' ;
    rdfs:comment 'Detailed narrative description of the milestone, including the scope of work, acceptance criteria, and deliverables required to formally achieve the milestone. Sourced from the contract schedule or project execution plan.' ;
    rdfs:domain ind:ProjectMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signOffDocumentRef rdf:type rdf:Property ;
    rdfs:label 'Sign Off Document Ref' ;
    rdfs:comment 'Reference number of the formal sign-off document, completion certificate, or taking-over certificate issued upon milestone achievement (e.g., Aconex document number, Procore submittal reference). Provides audit trail for contract administration and handover documentation.' ;
    rdfs:domain ind:ProjectMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalFloatDays rdf:type rdf:Property ;
    rdfs:label 'Total Float Days' ;
    rdfs:comment 'Total schedule float in calendar days available for this milestone before it impacts the project completion date, as calculated by the CPM (Critical Path Method) schedule engine in Oracle Primavera P6. Zero or negative float indicates critical or super-critical status.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:riskRegisterId rdf:type rdf:Property ;
    rdfs:label 'Risk Register Id' ;
    rdfs:comment 'Unique surrogate identifier for each risk register entry in the project risk register. Primary key for the risk_register data product.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryRiskRaisedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Risk Raised By Employee Id' ;
    rdfs:comment 'Reference to the workforce member who originally identified and raised this risk entry in the register. Supports accountability tracking and risk identification trend analysis.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:affectedDiscipline rdf:type rdf:Property ;
    rdfs:label 'Affected Discipline' ;
    rdfs:comment 'Construction or engineering discipline most affected by this risk (e.g., Civil, Structural, MEP, Geotechnical, Electrical, Procurement). Supports discipline-level risk reporting and resource allocation for mitigation.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contingencyCostAmount rdf:type rdf:Property ;
    rdfs:label 'Contingency Cost Amount' ;
    rdfs:comment 'Monetary contingency reserve allocated to this risk entry, expressed in the project currency. Feeds into the project contingency budget managed through SAP S/4HANA Project Systems and PMO cost control.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contingencyPlan rdf:type rdf:Property ;
    rdfs:label 'Contingency Plan' ;
    rdfs:comment 'Description of the fallback actions to be executed if the risk event is realized despite mitigation efforts. Defines trigger conditions, response steps, and responsible parties for contingency activation.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costImpactRating rdf:type rdf:Property ;
    rdfs:label 'Cost Impact Rating' ;
    rdfs:comment 'Qualitative rating of the potential cost impact if the risk event is realized, using the standard five-point PMO scale. Used in risk matrix scoring and contingency reserve determination.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hseRiskFlag rdf:type rdf:Property ;
    rdfs:label 'Hse Risk Flag' ;
    rdfs:comment 'Indicates whether this risk has a Health, Safety, and Environment (HSE) dimension requiring notification to the HSE team and potential entry into the Intelex HSE management system for regulatory compliance.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mitigationResponseType rdf:type rdf:Property ;
    rdfs:label 'Mitigation Response Type' ;
    rdfs:comment 'Standard risk response strategy type applied to this risk: avoid (eliminate the risk), transfer (shift to another party via contract/insurance), mitigate (reduce probability/impact), accept (acknowledge and monitor), exploit (maximise opportunity), or enhance (increase opportunity probability/impact).' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:probabilityScore rdf:type rdf:Property ;
    rdfs:label 'Probability Score' ;
    rdfs:comment 'Quantitative probability of the risk event occurring, expressed as a decimal between 0.0000 and 1.0000 (e.g., 0.3500 = 35%). Used in risk scoring calculations and Monte Carlo simulation inputs for contingency management.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualityImpactRating rdf:type rdf:Property ;
    rdfs:label 'Quality Impact Rating' ;
    rdfs:comment 'Qualitative rating of the potential quality impact if the risk event is realized. Supports QA/QC risk assessment and Non-Conformance Report (NCR) prevention planning.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryRiskFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Risk Flag' ;
    rdfs:comment 'Indicates whether this risk involves a regulatory or permitting dimension (e.g., EPA environmental permits, OSHA compliance, IBC building code, LEED certification requirements). Triggers regulatory compliance review.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:residualProbabilityScore rdf:type rdf:Property ;
    rdfs:label 'Residual Probability Score' ;
    rdfs:comment 'Quantitative probability of the risk event occurring after mitigation actions have been applied, expressed as a decimal between 0.0000 and 1.0000. Measures the effectiveness of the risk response strategy.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:riskProximity rdf:type rdf:Property ;
    rdfs:label 'Risk Proximity' ;
    rdfs:comment 'Indicates the time horizon within which the risk event is expected to occur: immediate (within 30 days), near_term (30–90 days), medium_term (90–180 days), or long_term (beyond 180 days). Supports prioritisation of risk response actions.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskStatus rdf:type rdf:Property ;
    rdfs:label 'Risk Status' ;
    rdfs:comment 'Current lifecycle status of the risk register entry: open (active, being monitored), mitigated (response actions applied), closed (no longer applicable), realized (risk event has occurred), or transferred (risk transferred to another party via contract/insurance). LIFECYCLE_STATUS for this entity.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskTitle rdf:type rdf:Property ;
    rdfs:label 'Risk Title' ;
    rdfs:comment 'Short, human-readable title summarising the risk or opportunity. Used as the primary display label in PMO dashboards, risk reports, and executive summaries. IDENTITY_LABEL for this entity.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskTrigger rdf:type rdf:Property ;
    rdfs:label 'Risk Trigger' ;
    rdfs:comment 'Description of the early warning indicators or conditions that signal the risk event is about to occur or has been triggered. Used to activate contingency plans and alert the risk owner.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskType rdf:type rdf:Property ;
    rdfs:label 'Risk Type' ;
    rdfs:comment 'Indicates whether the register entry represents a threat (negative impact) or an opportunity (positive impact) to the project. Supports balanced risk and opportunity management per PMO governance.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleImpactRating rdf:type rdf:Property ;
    rdfs:label 'Schedule Impact Rating' ;
    rdfs:comment 'Qualitative rating of the potential schedule impact if the risk event is realized, using the standard five-point PMO scale. Informs Extension of Time (EOT) exposure analysis and Critical Path Method (CPM) schedule risk assessment.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemRef rdf:type rdf:Property ;
    rdfs:label 'Source System Ref' ;
    rdfs:comment 'The native identifier of this risk record in the originating operational system (e.g., Procore risk ID, Primavera P6 risk code). Enables traceability from the silver layer back to the source system for reconciliation and audit.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryTeamEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Team Employee Id' ;
    rdfs:comment 'Reference to the workforce domain employee master record for the individual assigned to this project role. Distinct from the project-specific assignment record.' ;
    rdfs:domain ind:TeamMember ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualManDays rdf:type rdf:Property ;
    rdfs:label 'Actual Man Days' ;
    rdfs:comment 'Actual man-days expended by this team member on the project to date. Sourced from HCSS HeavyJob time tracking and used for EVM (Earned Value Management) performance measurement and cost control.' ;
    rdfs:domain ind:TeamMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allocationPercentage rdf:type rdf:Property ;
    rdfs:label 'Allocation Percentage' ;
    rdfs:comment 'Percentage of the team member\'s working time allocated to this project assignment (0.00–100.00). Supports resource leveling, cost allocation across multiple projects, and workforce planning in Oracle Primavera P6.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costRateDaily rdf:type rdf:Property ;
    rdfs:label 'Cost Rate Daily' ;
    rdfs:comment 'Fully-loaded daily cost rate for this team member\'s assignment, used for project cost allocation, EVM (Earned Value Management) calculations, and budget forecasting. Expressed in the project\'s base currency.' ;
    rdfs:domain ind:TeamMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hseInductionDate rdf:type rdf:Property ;
    rdfs:label 'Hse Induction Date' ;
    rdfs:comment 'Date on which the team member completed the mandatory HSE (Health Safety and Environment) site induction. Required before site access is granted. Tracked for OSHA and ISO 45001 compliance.' ;
    rdfs:domain ind:TeamMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:hseInductionStatus rdf:type rdf:Property ;
    rdfs:label 'Hse Induction Status' ;
    rdfs:comment 'Current status of the team member\'s mandatory HSE site induction. Controls site access authorization and is monitored for compliance with OSHA and ISO 45001 requirements.' ;
    rdfs:domain ind:TeamMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isKeyPersonnel rdf:type rdf:Property ;
    rdfs:label 'Is Key Personnel' ;
    rdfs:comment 'Indicates whether this team member is designated as Key Personnel under the contract terms (e.g., FIDIC, EPC contract schedules). Key Personnel replacements typically require client approval and are subject to contractual obligations.' ;
    rdfs:domain ind:TeamMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:medicalFitnessExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Medical Fitness Expiry Date' ;
    rdfs:comment 'Expiry date of the team member\'s medical fitness certificate required for site deployment. Monitored to ensure ongoing compliance with OSHA and ISO 45001 occupational health requirements.' ;
    rdfs:domain ind:TeamMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nationality rdf:type rdf:Property ;
    rdfs:label 'Nationality' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code representing the team member\'s nationality. Required for visa and work permit management, local content compliance reporting, and workforce diversity tracking.' ;
    rdfs:domain ind:TeamMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedManDays rdf:type rdf:Property ;
    rdfs:label 'Planned Man Days' ;
    rdfs:comment 'Total planned man-days budgeted for this team member\'s assignment on the project. Used for resource planning, schedule development, and baseline establishment in Oracle Primavera P6.' ;
    rdfs:domain ind:TeamMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:primaryCertification rdf:type rdf:Property ;
    rdfs:label 'Primary Certification' ;
    rdfs:comment 'Primary professional certification or licence held by the team member relevant to their project role (e.g., PE – Professional Engineer, PMP – Project Management Professional, NEBOSH, LEED AP, CQE). Used for competency verification and regulatory compliance.' ;
    rdfs:domain ind:TeamMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:professionalGrade rdf:type rdf:Property ;
    rdfs:label 'Professional Grade' ;
    rdfs:comment 'Internal professional grade or seniority level of the team member as defined in the company\'s grading structure (e.g., G1–G10, Senior, Principal, Director). Confidential HR data used for cost rate assignment and succession planning. [ENUM-REF-CANDIDATE: promote to reference product per HR grading framework]' ;
    rdfs:domain ind:TeamMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roleCategory rdf:type rdf:Property ;
    rdfs:label 'Role Category' ;
    rdfs:comment 'Functional category grouping the project role for workforce planning, reporting, and analytics. Enables aggregation of team composition by discipline across the project portfolio. [ENUM-REF-CANDIDATE: management|engineering|hse|commercial|planning|quality|commissioning|support — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TeamMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roleTitle rdf:type rdf:Property ;
    rdfs:label 'Role Title' ;
    rdfs:comment 'Formal project role title assigned to the team member on this project (e.g., Project Director, Project Manager, Construction Manager, Site Manager, Resident Engineer, HSE Manager, QA/QC Manager, Cost Engineer, Planner, Commissioning Manager, Interface Manager). [ENUM-REF-CANDIDATE: Project Director|Project Manager|Construction Manager|Site Manager|Resident Engineer|HSE Manager|QA/QC Manager|Cost Engineer|Planner|Commissioning Manager|Interface Manager|MEP Manager|Procurement Manager|Design Manager — promote to reference product]' ;
    rdfs:domain ind:TeamMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rotationSchedule rdf:type rdf:Property ;
    rdfs:label 'Rotation Schedule' ;
    rdfs:comment 'Work rotation schedule applicable to this team member\'s assignment (e.g., 28 days on / 28 days off for remote sites, 5/2 for office-based roles). Drives accommodation planning, travel logistics, and per diem calculations. [ENUM-REF-CANDIDATE: 28/28|21/21|14/14|6/2|5/2|residential|non_rotational — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TeamMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemAssignmentReference rdf:type rdf:Property ;
    rdfs:label 'Source System Assignment Reference' ;
    rdfs:comment 'Native identifier of this team member assignment record in the originating operational system (e.g., Primavera P6 resource assignment ID, SAP SuccessFactors assignment ID). Enables traceability and reconciliation between the lakehouse and source systems.' ;
    rdfs:domain ind:TeamMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workLocationType rdf:type rdf:Property ;
    rdfs:label 'Work Location Type' ;
    rdfs:comment 'Classification of the team member\'s primary work location type for this assignment. Drives per diem entitlements, accommodation planning, and HSE induction requirements.' ;
    rdfs:domain ind:TeamMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workPermitExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Work Permit Expiry Date' ;
    rdfs:comment 'Expiry date of the team member\'s work permit or visa for the project host country. Monitored to prevent illegal working and ensure continuous regulatory compliance.' ;
    rdfs:domain ind:TeamMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assignedWarehouseId rdf:type rdf:Property ;
    rdfs:label 'Assigned Warehouse Id' ;
    rdfs:comment 'Foreign key linking to material.warehouse. Business justification: Supports Site Staging Plan linking each WBS element to its dedicated staging warehouse.' ;
    rdfs:domain ind:WbsElement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Warehouse .

ind:parentWbsElementId rdf:type rdf:Property ;
    rdfs:label 'Parent Wbs Element Id' ;
    rdfs:comment 'Self-referencing identifier pointing to the immediate parent WBS node, enabling hierarchical decomposition of project scope. Null for root-level WBS elements.' ;
    rdfs:domain ind:WbsElement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WbsElement .

ind:responsibleOrgUnitId rdf:type rdf:Property ;
    rdfs:label 'Responsible Org Unit Id' ;
    rdfs:comment 'Foreign key linking to hr.org_unit. Business justification: Required for cost allocation reports linking WBS responsibility to org unit managing the work.' ;
    rdfs:domain ind:WbsElement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrgUnit .

ind:wbsNodeId rdf:type rdf:Property ;
    rdfs:label 'Wbs Node Id' ;
    rdfs:comment 'Foreign key linking to schedule.wbs_node. Business justification: Required for integrated Earned Value reporting aligning cost WBS with schedule hierarchy; project managers need to map WBS elements to schedule nodes.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WbsNode .

ind:actualQuantity rdf:type rdf:Property ;
    rdfs:label 'Actual Quantity' ;
    rdfs:comment 'Actual quantity of work completed and installed to date for this WBS element, as recorded in HCSS HeavyJob field production tracking. Compared against planned_quantity for production performance analysis.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvedBudgetChanges rdf:type rdf:Property ;
    rdfs:label 'Approved Budget Changes' ;
    rdfs:comment 'Cumulative value of approved Change Orders (CO) that have modified the original budget for this WBS element. Reconciles original_budget_cost to budgeted_cost.' ;
    rdfs:domain ind:WbsElement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:boqItemReference rdf:type rdf:Property ;
    rdfs:label 'Boq Item Reference' ;
    rdfs:comment 'Reference number or code linking this WBS element to the corresponding Bill of Quantities (BOQ) line item in the contract. Enables traceability between scope decomposition and contract pricing.' ;
    rdfs:domain ind:WbsElement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chargeType rdf:type rdf:Property ;
    rdfs:label 'Charge Type' ;
    rdfs:comment 'Classification of costs associated with this WBS element: direct (billable to project scope), indirect (overhead allocation), overhead, contingency (risk reserve), or provisional (BOQ provisional sum). Affects cost reporting and contract billing.' ;
    rdfs:domain ind:WbsElement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:csiDivisionCode rdf:type rdf:Property ;
    rdfs:label 'Csi Division Code' ;
    rdfs:comment 'CSI MasterFormat division code classifying the type of construction work for this WBS element (e.g., 03 = Concrete, 05 = Metals, 26 = Electrical). Enables industry-standard scope classification and benchmarking.' ;
    rdfs:domain ind:WbsElement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evmEnabled rdf:type rdf:Property ;
    rdfs:label 'Evm Enabled' ;
    rdfs:comment 'Flag indicating whether this WBS element is included in the project\'s EVM (Earned Value Management) performance measurement baseline. Summary and planning package nodes may be excluded from direct EVM measurement.' ;
    rdfs:domain ind:WbsElement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:originalBudgetCost rdf:type rdf:Property ;
    rdfs:label 'Original Budget Cost' ;
    rdfs:comment 'The initial approved budget for this WBS element at project baseline, before any approved change orders or budget transfers. Enables variance analysis between original and current budget.' ;
    rdfs:domain ind:WbsElement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:percentCompleteMethod rdf:type rdf:Property ;
    rdfs:label 'Percent Complete Method' ;
    rdfs:comment 'Method used to calculate percent complete for EVM purposes: physical (field measurement), units_complete (quantity-based), duration (time-proportional), weighted_milestone, level_of_effort, or fixed_formula (e.g., 0/100, 50/50). Configured in Oracle Primavera P6.' ;
    rdfs:domain ind:WbsElement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsibleDiscipline rdf:type rdf:Property ;
    rdfs:label 'Responsible Discipline' ;
    rdfs:comment 'Engineering or construction discipline accountable for executing this WBS element (e.g., Civil, Structural, MEP, Electrical, Mechanical, Instrumentation). Used for resource planning and discipline-level cost reporting.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemWbsReference rdf:type rdf:Property ;
    rdfs:label 'Source System Wbs Reference' ;
    rdfs:comment 'Native identifier of this WBS element in the originating operational system (e.g., Primavera P6 WBS Object ID, SAP PS WBS Element internal number). Supports data lineage and reconciliation between the lakehouse and source systems.' ;
    rdfs:domain ind:WbsElement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wbsLevel rdf:type rdf:Property ;
    rdfs:label 'Wbs Level' ;
    rdfs:comment 'Integer depth of the WBS node within the project hierarchy (Level 1 = project root, Level 2 = major deliverable, Level 3+ = sub-deliverable or work package). Used for hierarchical filtering, rollup aggregation, and reporting drill-down.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:wbsName rdf:type rdf:Property ;
    rdfs:label 'Wbs Name' ;
    rdfs:comment 'Human-readable name or title of the WBS element describing the scope deliverable or work package (e.g., \'Substructure Works\', \'Electrical Installation – Level 3\'). Used in reports, dashboards, and EVM analysis.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wbsStatus rdf:type rdf:Property ;
    rdfs:label 'Wbs Status' ;
    rdfs:comment 'Current lifecycle status of the WBS element indicating whether work is active, not yet started, on hold, completed, or cancelled. Drives EVM eligibility and cost control reporting.' ;
    rdfs:domain ind:WbsElement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wbsType rdf:type rdf:Property ;
    rdfs:label 'Wbs Type' ;
    rdfs:comment 'Classification of the WBS node by its role in the hierarchy: \'summary\' (rollup node), \'work_package\' (lowest deliverable-level node), \'control_account\' (EVM measurement point), or \'planning_package\' (future scope not yet detailed). Drives EVM rollup logic and cost control granularity.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acceptanceTestId rdf:type rdf:Property ;
    rdfs:label 'Acceptance Test Id' ;
    rdfs:comment 'Unique identifier for the acceptance test record. Primary key for the acceptance test entity.' ;
    rdfs:domain ind:AcceptanceTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:equipmentAssetId rdf:type rdf:Property ;
    rdfs:label 'Equipment Asset Id' ;
    rdfs:comment 'Reference to the equipment or asset being tested. Links to the equipment asset master record.' ;
    rdfs:domain ind:AcceptanceTest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Asset .

ind:ncrId rdf:type rdf:Property ;
    rdfs:label 'Ncr Id' ;
    rdfs:comment 'Foreign key linking to quality.ncr. Business justification: When defects are identified during acceptance testing, an NCR may be raised; many acceptance tests can reference the same NCR.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Ncr .

ind:acceptanceCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Acceptance Certificate Number' ;
    rdfs:comment 'Reference number of the formal acceptance certificate issued upon successful completion of the test. Links to the document management system.' ;
    rdfs:domain ind:AcceptanceTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceStandard rdf:type rdf:Property ;
    rdfs:label 'Compliance Standard' ;
    rdfs:comment 'Industry standards or regulatory codes that the equipment must comply with. Examples include ASME, API, IEC, NFPA, or project-specific standards.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractorName rdf:type rdf:Property ;
    rdfs:label 'Contractor Name' ;
    rdfs:comment 'Name of the contractor or subcontractor responsible for the equipment or system being tested.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionRequired rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Required' ;
    rdfs:comment 'Description of corrective actions required to address any defects or non-conformances identified during the test. Links to NCR (Non-Conformance Report) if applicable.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defectsIdentified rdf:type rdf:Property ;
    rdfs:label 'Defects Identified' ;
    rdfs:comment 'List of specific defects or non-conformances identified during the acceptance test. Each defect should be documented with severity and required corrective action.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retestDate rdf:type rdf:Property ;
    rdfs:label 'Retest Date' ;
    rdfs:comment 'Scheduled or actual date for retest after corrective actions. Null if no retest is required.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:retestRequired rdf:type rdf:Property ;
    rdfs:label 'Retest Required' ;
    rdfs:comment 'Indicates whether a retest is required after corrective actions are completed. True if the test failed or had conditional pass requiring verification.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:testDurationHours rdf:type rdf:Property ;
    rdfs:label 'Test Duration Hours' ;
    rdfs:comment 'Total duration of the acceptance test in hours. Captures the time from test start to completion.' ;
    rdfs:domain ind:AcceptanceTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:testEngineerName rdf:type rdf:Property ;
    rdfs:label 'Test Engineer Name' ;
    rdfs:comment 'Name of the engineer or technician who conducted the acceptance test. Primary responsible party for test execution.' ;
    rdfs:domain ind:AcceptanceTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testFindings rdf:type rdf:Property ;
    rdfs:label 'Test Findings' ;
    rdfs:comment 'Detailed findings and observations from the acceptance test execution. Documents any deviations, defects, or non-conformances identified during testing.' ;
    rdfs:domain ind:AcceptanceTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testHumidityPercent rdf:type rdf:Property ;
    rdfs:label 'Test Humidity Percent' ;
    rdfs:comment 'Relative humidity percentage during the acceptance test. Environmental condition that may affect test results for sensitive equipment.' ;
    rdfs:domain ind:AcceptanceTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:testLocation rdf:type rdf:Property ;
    rdfs:label 'Test Location' ;
    rdfs:comment 'Physical location where the acceptance test was performed. For FAT, typically the manufacturer\'s facility name and address. For SAT, the project site location.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testNumber rdf:type rdf:Property ;
    rdfs:label 'Test Number' ;
    rdfs:comment 'Unique business identifier for the acceptance test. Externally visible test reference number used in documentation and correspondence.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testProcedureReference rdf:type rdf:Property ;
    rdfs:label 'Test Procedure Reference' ;
    rdfs:comment 'Reference to the approved test procedure or ITP (Inspection and Test Plan) document that governs this acceptance test. Links to the document management system.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testProcedureVersion rdf:type rdf:Property ;
    rdfs:label 'Test Procedure Version' ;
    rdfs:comment 'Version number of the test procedure document used during the test execution. Ensures traceability to the correct revision.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testReportReference rdf:type rdf:Property ;
    rdfs:label 'Test Report Reference' ;
    rdfs:comment 'Reference to the detailed test report document. Links to the document management system for full test documentation including measurements, photos, and witness signatures.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testStatus rdf:type rdf:Property ;
    rdfs:label 'Test Status' ;
    rdfs:comment 'Current lifecycle status of the acceptance test. Tracks progression from scheduling through execution to final acceptance decision.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testTemperatureC rdf:type rdf:Property ;
    rdfs:label 'Test Temperature C' ;
    rdfs:comment 'Ambient temperature in degrees Celsius during the acceptance test. Environmental condition that may affect test results.' ;
    rdfs:domain ind:AcceptanceTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:testType rdf:type rdf:Property ;
    rdfs:label 'Test Type' ;
    rdfs:comment 'Type of acceptance test being performed. FAT (Factory Acceptance Test) is conducted at the manufacturer\'s facility before shipment. SAT (Site Acceptance Test) is conducted at the project site after installation.' ;
    rdfs:domain ind:AcceptanceTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:witnessParty rdf:type rdf:Property ;
    rdfs:label 'Witness Party' ;
    rdfs:comment 'Names and organizations of all parties who witnessed the acceptance test. Typically includes client representatives, consultant engineers, and regulatory inspectors.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityAuditId rdf:type rdf:Property ;
    rdfs:label 'Quality Audit Id' ;
    rdfs:comment 'Unique identifier for the quality audit record. Primary key.' ;
    rdfs:domain ind:QualityAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:leadAuditorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Lead Auditor Employee Id' ;
    rdfs:comment 'Foreign key linking to hr.employee. Business justification: Audit reports require the lead auditor\'s employee ID for internal audit tracking and regulator-required audit logs.' ;
    rdfs:domain ind:QualityAudit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:areasAudited rdf:type rdf:Property ;
    rdfs:label 'Areas Audited' ;
    rdfs:comment 'Comma-separated list of physical locations, work areas, or processes audited (e.g., \'Site Office, Concrete Batching Plant, Welding Shop, Material Testing Lab\').' ;
    rdfs:domain ind:QualityAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditScope rdf:type rdf:Property ;
    rdfs:label 'Audit Scope' ;
    rdfs:comment 'Description of the audit scope including processes, areas, activities, or clauses covered (e.g., \'ISO 9001 clauses 7.1-7.5, site QA/QC processes, material testing laboratory\').' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditStatus rdf:type rdf:Property ;
    rdfs:label 'Audit Status' ;
    rdfs:comment 'Current lifecycle status of the audit: planned (scheduled but not started), in_progress (audit fieldwork underway), completed (audit report issued), closed (all corrective actions verified), cancelled (audit not conducted).' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditeeDepartment rdf:type rdf:Property ;
    rdfs:label 'Auditee Department' ;
    rdfs:comment 'The department, division, or functional area being audited.' ;
    rdfs:domain ind:QualityAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditeeRepresentativeName rdf:type rdf:Property ;
    rdfs:label 'Auditee Representative Name' ;
    rdfs:comment 'Name of the primary representative from the audited area who participated in the audit.' ;
    rdfs:domain ind:QualityAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditorOrganization rdf:type rdf:Property ;
    rdfs:label 'Auditor Organization' ;
    rdfs:comment 'Name of the organization conducting the audit (internal department, client organization, or third-party certification body).' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carRaisedCount rdf:type rdf:Property ;
    rdfs:label 'Car Raised Count' ;
    rdfs:comment 'Total number of Corrective Action Requests (CARs) raised as a result of the audit findings requiring formal corrective action.' ;
    rdfs:domain ind:QualityAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:certificationStandard rdf:type rdf:Property ;
    rdfs:label 'Certification Standard' ;
    rdfs:comment 'The ISO or industry standard being audited for certification (e.g., \'ISO 9001:2015\', \'ISO 14001:2015\', \'ISO 45001:2018\').' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closedBy rdf:type rdf:Property ;
    rdfs:label 'Closed By' ;
    rdfs:comment 'Name of the quality manager or authorized person who formally closed the audit.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conclusion rdf:type rdf:Property ;
    rdfs:label 'Conclusion' ;
    rdfs:comment 'Overall audit conclusion: satisfactory (no major issues), satisfactory_with_observations (minor issues noted), unsatisfactory (major non-conformances requiring action), not_recommended_for_certification (for certification audits).' ;
    rdfs:domain ind:QualityAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:criteria rdf:type rdf:Property ;
    rdfs:label 'Criteria' ;
    rdfs:comment 'The standards, specifications, or requirements against which the audit is conducted (e.g., \'ISO 9001:2015, Project Quality Plan Rev 3, Contract Specification Section 5\').' ;
    rdfs:domain ind:QualityAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentsReviewed rdf:type rdf:Property ;
    rdfs:label 'Documents Reviewed' ;
    rdfs:comment 'Summary or list of key documents reviewed during the audit (e.g., \'Quality Plan, ITP registers, NCR logs, calibration certificates\').' ;
    rdfs:domain ind:QualityAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:followUpAuditRequired rdf:type rdf:Property ;
    rdfs:label 'Follow Up Audit Required' ;
    rdfs:comment 'Indicates whether a follow-up audit is required to verify closure of corrective actions (True) or not (False).' ;
    rdfs:domain ind:QualityAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:leadAuditorName rdf:type rdf:Property ;
    rdfs:label 'Lead Auditor Name' ;
    rdfs:comment 'Full name of the lead auditor responsible for conducting and reporting the audit.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:majorNcCount rdf:type rdf:Property ;
    rdfs:label 'Major Nc Count' ;
    rdfs:comment 'Total number of major non-conformances identified: systemic failures, complete absence of required processes, or situations that could result in delivery of non-conforming product/service.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minorNcCount rdf:type rdf:Property ;
    rdfs:label 'Minor Nc Count' ;
    rdfs:comment 'Total number of minor non-conformances identified: isolated lapses or single failures that do not indicate systemic breakdown.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:personnelInterviewed rdf:type rdf:Property ;
    rdfs:label 'Personnel Interviewed' ;
    rdfs:comment 'Comma-separated list of roles or names of personnel interviewed during the audit.' ;
    rdfs:domain ind:QualityAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:positiveFindings rdf:type rdf:Property ;
    rdfs:label 'Positive Findings' ;
    rdfs:comment 'Description of positive practices, strengths, or areas of excellence identified during the audit.' ;
    rdfs:domain ind:QualityAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportIssuedDate rdf:type rdf:Property ;
    rdfs:label 'Report Issued Date' ;
    rdfs:comment 'The date when the formal audit report was issued to the auditee.' ;
    rdfs:domain ind:QualityAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:teamMembers rdf:type rdf:Property ;
    rdfs:label 'Team Members' ;
    rdfs:comment 'Comma-separated list of audit team member names who participated in the audit.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checklistId rdf:type rdf:Property ;
    rdfs:label 'Checklist Id' ;
    rdfs:comment 'Unique identifier for the quality inspection checklist template. Primary key.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Checklist .

ind:activityType rdf:type rdf:Property ;
    rdfs:label 'Activity Type' ;
    rdfs:comment 'Classification of the construction activity type that this checklist applies to, aligned with WBS (Work Breakdown Structure) and ITP (Inspection and Test Plan) categories. [ENUM-REF-CANDIDATE: concrete_pour|rebar_placement|formwork_erection|waterproofing|structural_steel_erection|welding|mechanical_installation|electrical_installation|piping_installation|excavation|backfill|piling|painting|insulation|commissioning|other — 16 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableStandard rdf:type rdf:Property ;
    rdfs:label 'Applicable Standard' ;
    rdfs:comment 'Reference to the governing technical standard, code, or specification that this checklist enforces (e.g., \'ACI 318\', \'AISC 360\', \'ASME B31.3\', \'IBC 2018\', \'ASTM C39\').' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:averagePassRate rdf:type rdf:Property ;
    rdfs:label 'Average Pass Rate' ;
    rdfs:comment 'Historical average pass rate (percentage) for inspections conducted using this checklist, used to identify problematic activities or checklist items.' ;
    rdfs:domain ind:Checklist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:checklistCode rdf:type rdf:Property ;
    rdfs:label 'Checklist Code' ;
    rdfs:comment 'Externally-known unique business identifier for the checklist template, used for reference in inspection documentation and ITP (Inspection and Test Plan) workflows.' ;
    rdfs:domain ind:Checklist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checklistDescription rdf:type rdf:Property ;
    rdfs:label 'Checklist Description' ;
    rdfs:comment 'Detailed description of the checklist purpose, scope, and applicability, including any special instructions or prerequisites for use.' ;
    rdfs:domain ind:Checklist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checklistName rdf:type rdf:Property ;
    rdfs:label 'Checklist Name' ;
    rdfs:comment 'Human-readable name of the checklist template describing the inspection scope (e.g., \'Concrete Pour Inspection\', \'Rebar Placement Verification\', \'Waterproofing Application Check\').' ;
    rdfs:domain ind:Checklist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:criticalItemsCount rdf:type rdf:Property ;
    rdfs:label 'Critical Items Count' ;
    rdfs:comment 'Number of check items in this checklist that are classified as critical and must pass for overall acceptance.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:estimatedDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Estimated Duration Minutes' ;
    rdfs:comment 'Estimated time in minutes required to complete the inspection using this checklist, used for resource planning and scheduling.' ;
    rdfs:domain ind:Checklist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:frequency rdf:type rdf:Property ;
    rdfs:label 'Frequency' ;
    rdfs:comment 'Frequency or trigger for when this checklist should be used (e.g., per concrete pour, daily for ongoing work, per material batch). [ENUM-REF-CANDIDATE: per_occurrence|daily|weekly|monthly|per_batch|per_lot|as_required — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdPointFlag rdf:type rdf:Property ;
    rdfs:label 'Hold Point Flag' ;
    rdfs:comment 'Indicates whether this checklist represents a hold point where work cannot proceed until inspection is completed and accepted.' ;
    rdfs:domain ind:Checklist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inspectionStage rdf:type rdf:Property ;
    rdfs:label 'Inspection Stage' ;
    rdfs:comment 'Phase of construction activity when this checklist should be applied, aligned with ITP (Inspection and Test Plan) hold points and witness points.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ncrTriggerThreshold rdf:type rdf:Property ;
    rdfs:label 'Ncr Trigger Threshold' ;
    rdfs:comment 'Criteria that automatically trigger the issuance of an NCR (Non-Conformance Report) when inspection results fail to meet this threshold.' ;
    rdfs:domain ind:Checklist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiredEquipment rdf:type rdf:Property ;
    rdfs:label 'Required Equipment' ;
    rdfs:comment 'List of tools, instruments, or equipment required to perform the inspection per this checklist (e.g., \'tape measure, level, ultrasonic thickness gauge, calibrated thermometer\').' ;
    rdfs:domain ind:Checklist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiredQualifications rdf:type rdf:Property ;
    rdfs:label 'Required Qualifications' ;
    rdfs:comment 'Qualifications, certifications, or competencies required for the inspector who will use this checklist (e.g., \'AWS CWI\', \'ACI Level 1\', \'ASNT NDT Level II\').' ;
    rdfs:domain ind:Checklist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalCheckItems rdf:type rdf:Property ;
    rdfs:label 'Total Check Items' ;
    rdfs:comment 'Total number of individual verification items or questions included in this checklist template.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:usageCount rdf:type rdf:Property ;
    rdfs:label 'Usage Count' ;
    rdfs:comment 'Number of times this checklist template has been used in actual field inspections, used for analytics and continuous improvement.' ;
    rdfs:domain ind:Checklist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:witnessPointFlag rdf:type rdf:Property ;
    rdfs:label 'Witness Point Flag' ;
    rdfs:comment 'Indicates whether this checklist represents a witness point where the client or third-party inspector must be notified and given opportunity to witness the inspection.' ;
    rdfs:domain ind:Checklist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:checklistExecutionId rdf:type rdf:Property ;
    rdfs:label 'Checklist Execution Id' ;
    rdfs:comment 'Unique identifier for the completed checklist execution instance. Primary key for this quality inspection record.' ;
    rdfs:domain ind:ChecklistExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:permitToWorkId rdf:type rdf:Property ;
    rdfs:label 'Permit To Work Id' ;
    rdfs:comment 'Foreign key linking to safety.permit_to_work. Business justification: Checklist execution on site requires a Permit-to-Work; linking records the permit governing the execution for safety compliance.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PermitToWork .

ind:primaryChecklistEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Checklist Employee Id' ;
    rdfs:comment 'Reference to the qualified QA/QC inspector who performed the checklist execution. Must be a certified quality professional.' ;
    rdfs:domain ind:ChecklistExecution ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryChecklistApprovedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Checklist Approved By Employee Id' ;
    rdfs:comment 'Reference to the QA/QC manager or authorized person who approved the checklist execution results.' ;
    rdfs:domain ind:ChecklistExecution ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:compliancePercentage rdf:type rdf:Property ;
    rdfs:label 'Compliance Percentage' ;
    rdfs:comment 'Calculated percentage of checklist items that passed inspection, excluding N/A items. Formula: (pass_count / (total_items - na_count)) * 100.' ;
    rdfs:domain ind:ChecklistExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:criticalFailureFlag rdf:type rdf:Property ;
    rdfs:label 'Critical Failure Flag' ;
    rdfs:comment 'Indicates whether any critical or safety-related inspection items failed, requiring immediate stop-work or remediation.' ;
    rdfs:domain ind:ChecklistExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:documentReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Document Reference Number' ;
    rdfs:comment 'Reference number linking this checklist execution to the project document management system for archival and retrieval.' ;
    rdfs:domain ind:ChecklistExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:executionDate rdf:type rdf:Property ;
    rdfs:label 'Execution Date' ;
    rdfs:comment 'Date when the quality inspection checklist was executed on site.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:executionEndTime rdf:type rdf:Property ;
    rdfs:label 'Execution End Time' ;
    rdfs:comment 'Timestamp when the inspector completed the checklist execution and submitted the results.' ;
    rdfs:domain ind:ChecklistExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:executionNumber rdf:type rdf:Property ;
    rdfs:label 'Execution Number' ;
    rdfs:comment 'Business-readable unique identifier for this checklist execution, often formatted as project-discipline-sequence (e.g., PRJ001-QC-0123).' ;
    rdfs:domain ind:ChecklistExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:executionStartTime rdf:type rdf:Property ;
    rdfs:label 'Execution Start Time' ;
    rdfs:comment 'Timestamp when the inspector began the checklist execution on site.' ;
    rdfs:domain ind:ChecklistExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:failCount rdf:type rdf:Property ;
    rdfs:label 'Fail Count' ;
    rdfs:comment 'Number of checklist items that failed inspection criteria and require corrective action.' ;
    rdfs:domain ind:ChecklistExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:humidityPercentage rdf:type rdf:Property ;
    rdfs:label 'Humidity Percentage' ;
    rdfs:comment 'Relative humidity percentage at the time of inspection, relevant for coating, painting, and material testing activities.' ;
    rdfs:domain ind:ChecklistExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inspectorRemarks rdf:type rdf:Property ;
    rdfs:label 'Inspector Remarks' ;
    rdfs:comment 'General observations, comments, or notes recorded by the inspector during the checklist execution. Provides context for inspection results.' ;
    rdfs:domain ind:ChecklistExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectorSignatureCaptured rdf:type rdf:Property ;
    rdfs:label 'Inspector Signature Captured' ;
    rdfs:comment 'Indicates whether the inspector\'s digital signature was captured as part of the checklist sign-off process.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inspectorSignatureTimestamp rdf:type rdf:Property ;
    rdfs:label 'Inspector Signature Timestamp' ;
    rdfs:comment 'Timestamp when the inspector digitally signed off on the completed checklist execution.' ;
    rdfs:domain ind:ChecklistExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:naCount rdf:type rdf:Property ;
    rdfs:label 'Na Count' ;
    rdfs:comment 'Number of checklist items marked as not applicable to this specific inspection instance.' ;
    rdfs:domain ind:ChecklistExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ncrGeneratedFlag rdf:type rdf:Property ;
    rdfs:label 'Ncr Generated Flag' ;
    rdfs:comment 'Indicates whether this inspection resulted in the generation of one or more NCRs (Non-Conformance Reports) for failed items.' ;
    rdfs:domain ind:ChecklistExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:overallResult rdf:type rdf:Property ;
    rdfs:label 'Overall Result' ;
    rdfs:comment 'Overall outcome of the checklist execution: pass (all items compliant), fail (one or more critical failures), conditional pass (minor defects requiring remediation), or not applicable.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:passCount rdf:type rdf:Property ;
    rdfs:label 'Pass Count' ;
    rdfs:comment 'Number of checklist items that passed inspection criteria.' ;
    rdfs:domain ind:ChecklistExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:temperatureCelsius rdf:type rdf:Property ;
    rdfs:label 'Temperature Celsius' ;
    rdfs:comment 'Ambient temperature in Celsius at the time of inspection, critical for concrete curing, welding, and coating applications.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalItems rdf:type rdf:Property ;
    rdfs:label 'Total Items' ;
    rdfs:comment 'Total number of inspection items in the executed checklist.' ;
    rdfs:domain ind:ChecklistExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:witnessName rdf:type rdf:Property ;
    rdfs:label 'Witness Name' ;
    rdfs:comment 'Full name of the witness who co-signed the inspection for display and reporting purposes.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:witnessRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Witness Required Flag' ;
    rdfs:comment 'Indicates whether this inspection requires a witness signature from client, consultant, or third-party inspector per contract requirements.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:witnessSignatureCaptured rdf:type rdf:Property ;
    rdfs:label 'Witness Signature Captured' ;
    rdfs:comment 'Indicates whether the witness\'s digital signature was captured as part of the checklist sign-off process.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:witnessSignatureTimestamp rdf:type rdf:Property ;
    rdfs:label 'Witness Signature Timestamp' ;
    rdfs:comment 'Timestamp when the witness digitally signed off on the completed checklist execution.' ;
    rdfs:domain ind:ChecklistExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:workActivityDescription rdf:type rdf:Property ;
    rdfs:label 'Work Activity Description' ;
    rdfs:comment 'Detailed description of the specific construction work activity or deliverable being inspected (e.g., \'Foundation concrete pour - Grid A1 to A5\', \'HVAC ductwork installation - Level 3\').' ;
    rdfs:domain ind:ChecklistExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:concretePourRecordId rdf:type rdf:Property ;
    rdfs:label 'Concrete Pour Record Id' ;
    rdfs:comment 'Unique identifier for the concrete pour record. Primary key for this quality assurance document.' ;
    rdfs:domain ind:ConcretePourRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:carbonEmissionId rdf:type rdf:Property ;
    rdfs:label 'Carbon Emission Id' ;
    rdfs:comment 'Foreign key linking to sustainability.carbon_emission. Business justification: Concrete pours are a major source of CO₂; associating each pour with a carbon emission record enables accurate scope-1/2 emissions calculation.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CarbonEmission .

ind:ambientTemperatureC rdf:type rdf:Property ;
    rdfs:label 'Ambient Temperature C' ;
    rdfs:comment 'Ambient air temperature at the time of concrete placement, measured in degrees Celsius.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvedSubmittalNumber rdf:type rdf:Property ;
    rdfs:label 'Approved Submittal Number' ;
    rdfs:comment 'Reference number of the approved material submittal package for the concrete mix design.' ;
    rdfs:domain ind:ConcretePourRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:batchPlantName rdf:type rdf:Property ;
    rdfs:label 'Batch Plant Name' ;
    rdfs:comment 'Name of the concrete batching plant that supplied the concrete for this pour.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clientWitnessName rdf:type rdf:Property ;
    rdfs:label 'Client Witness Name' ;
    rdfs:comment 'Name of the client representative who witnessed the concrete pour, if applicable.' ;
    rdfs:domain ind:ConcretePourRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:concreteGrade rdf:type rdf:Property ;
    rdfs:label 'Concrete Grade' ;
    rdfs:comment 'Specified concrete strength grade (e.g., C25, C30, C40) indicating the characteristic compressive strength.' ;
    rdfs:domain ind:ConcretePourRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:concretePourRecordLevel rdf:type rdf:Property ;
    rdfs:label 'Concrete Pour Record Level' ;
    rdfs:comment 'Building level or elevation where the concrete pour occurred (e.g., basement, ground floor, level 3).' ;
    rdfs:domain ind:ConcretePourRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:concreteTemperatureC rdf:type rdf:Property ;
    rdfs:label 'Concrete Temperature C' ;
    rdfs:comment 'Temperature of the fresh concrete at the time of placement, measured in degrees Celsius.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:consultantWitnessName rdf:type rdf:Property ;
    rdfs:label 'Consultant Witness Name' ;
    rdfs:comment 'Name of the consultant or third-party representative who witnessed the concrete pour, if applicable.' ;
    rdfs:domain ind:ConcretePourRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cubeSampleIds rdf:type rdf:Property ;
    rdfs:label 'Cube Sample Ids' ;
    rdfs:comment 'Comma-separated list of concrete cube sample identifiers taken from this pour for compressive strength testing.' ;
    rdfs:domain ind:ConcretePourRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:curingDurationDays rdf:type rdf:Property ;
    rdfs:label 'Curing Duration Days' ;
    rdfs:comment 'Planned or actual duration of the concrete curing period in days.' ;
    rdfs:domain ind:ConcretePourRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:curingMethod rdf:type rdf:Property ;
    rdfs:label 'Curing Method' ;
    rdfs:comment 'Method used for curing the concrete after placement (e.g., wet covering, curing compound, plastic sheeting, water ponding).' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:curingStartDate rdf:type rdf:Property ;
    rdfs:label 'Curing Start Date' ;
    rdfs:comment 'Date when the concrete curing process began.' ;
    rdfs:domain ind:ConcretePourRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cylinderSampleIds rdf:type rdf:Property ;
    rdfs:label 'Cylinder Sample Ids' ;
    rdfs:comment 'Comma-separated list of concrete cylinder sample identifiers taken from this pour for compressive strength testing.' ;
    rdfs:domain ind:ConcretePourRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryDocketNumbers rdf:type rdf:Property ;
    rdfs:label 'Delivery Docket Numbers' ;
    rdfs:comment 'Comma-separated list of delivery docket or ticket numbers for all concrete trucks that delivered to this pour.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:elementLocation rdf:type rdf:Property ;
    rdfs:label 'Element Location' ;
    rdfs:comment 'Specific location description of the structural element within the project (e.g., grid reference, building zone).' ;
    rdfs:domain ind:ConcretePourRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:elementType rdf:type rdf:Property ;
    rdfs:label 'Element Type' ;
    rdfs:comment 'Type of structural element being poured (e.g., foundation, slab, column, beam, wall). [ENUM-REF-CANDIDATE: foundation|slab|column|beam|wall|deck|footing|pile_cap|shear_wall|retaining_wall — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ConcretePourRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gridReference rdf:type rdf:Property ;
    rdfs:label 'Grid Reference' ;
    rdfs:comment 'Grid coordinate reference identifying the exact location of the pour within the construction drawings.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectorSignatureDate rdf:type rdf:Property ;
    rdfs:label 'Inspector Signature Date' ;
    rdfs:comment 'Date when the inspector signed off on the concrete pour record.' ;
    rdfs:domain ind:ConcretePourRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mixDesignReference rdf:type rdf:Property ;
    rdfs:label 'Mix Design Reference' ;
    rdfs:comment 'Reference code or identifier for the approved concrete mix design specification used for this pour.' ;
    rdfs:domain ind:ConcretePourRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ncrRaised rdf:type rdf:Property ;
    rdfs:label 'Ncr Raised' ;
    rdfs:comment 'Indicates whether a Non-Conformance Report (NCR) was raised for this concrete pour (True/False).' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:numberOfSamplesTaken rdf:type rdf:Property ;
    rdfs:label 'Number Of Samples Taken' ;
    rdfs:comment 'Total number of concrete test samples (cubes or cylinders) taken from this pour.' ;
    rdfs:domain ind:ConcretePourRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:numberOfTrucks rdf:type rdf:Property ;
    rdfs:label 'Number Of Trucks' ;
    rdfs:comment 'Total number of concrete delivery trucks used for this pour.' ;
    rdfs:domain ind:ConcretePourRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pourDate rdf:type rdf:Property ;
    rdfs:label 'Pour Date' ;
    rdfs:comment 'The date on which the concrete pour was executed.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pourEndTime rdf:type rdf:Property ;
    rdfs:label 'Pour End Time' ;
    rdfs:comment 'Timestamp when the concrete placement was completed.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:pourNumber rdf:type rdf:Property ;
    rdfs:label 'Pour Number' ;
    rdfs:comment 'Unique business identifier for this concrete pour event, typically assigned sequentially within the project.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pourStartTime rdf:type rdf:Property ;
    rdfs:label 'Pour Start Time' ;
    rdfs:comment 'Timestamp when the concrete placement began.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:pourStatus rdf:type rdf:Property ;
    rdfs:label 'Pour Status' ;
    rdfs:comment 'Current lifecycle status of the concrete pour activity. [ENUM-REF-CANDIDATE: planned|approved|in_progress|completed|curing|tested|accepted|rejected — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slumpSpecificationMm rdf:type rdf:Property ;
    rdfs:label 'Slump Specification Mm' ;
    rdfs:comment 'Specified acceptable slump range for this concrete mix (e.g., 75-100mm).' ;
    rdfs:domain ind:ConcretePourRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slumpTestPassed rdf:type rdf:Property ;
    rdfs:label 'Slump Test Passed' ;
    rdfs:comment 'Indicates whether the slump test result met the specification requirements (True/False).' ;
    rdfs:domain ind:ConcretePourRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:slumpTestResultMm rdf:type rdf:Property ;
    rdfs:label 'Slump Test Result Mm' ;
    rdfs:comment 'Measured slump value in millimeters from the concrete workability test performed on site.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierName rdf:type rdf:Property ;
    rdfs:label 'Supplier Name' ;
    rdfs:comment 'Name of the concrete supplier company providing the ready-mix concrete.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalPourVolumeM3 rdf:type rdf:Property ;
    rdfs:label 'Total Pour Volume M3' ;
    rdfs:comment 'Total volume of concrete placed during this pour event, measured in cubic meters.' ;
    rdfs:domain ind:ConcretePourRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:correctiveActionId rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Id' ;
    rdfs:comment 'Primary key for corrective_action' ;
    rdfs:domain ind:CorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:linkedChangeOrderProjectChangeOrderId rdf:type rdf:Property ;
    rdfs:label 'Linked Change Order Project Change Order Id' ;
    rdfs:comment 'Reference to the Change Order (CO) generated as a result of this corrective action, if cost or schedule impacts require contract modification.' ;
    rdfs:domain ind:CorrectiveAction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProjectChangeOrder .

ind:linkedDocumentRfiId rdf:type rdf:Property ;
    rdfs:label 'Linked Document Rfi Id' ;
    rdfs:comment 'Reference to the Request for Information (RFI) issued to clarify design or specification ambiguities related to this corrective action.' ;
    rdfs:domain ind:CorrectiveAction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Rfi .

ind:primaryCorrectiveEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Corrective Employee Id' ;
    rdfs:comment 'Reference to the employee, subcontractor, or organizational unit assigned to execute this corrective action.' ;
    rdfs:domain ind:CorrectiveAction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:quaternaryCorrectiveLastModifiedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Quaternary Corrective Last Modified By Employee Id' ;
    rdfs:comment 'Reference to the user who last modified this corrective action record.' ;
    rdfs:domain ind:CorrectiveAction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryCorrectiveCreatedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Corrective Created By Employee Id' ;
    rdfs:comment 'Reference to the user who created this corrective action record.' ;
    rdfs:domain ind:CorrectiveAction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actionDescription rdf:type rdf:Property ;
    rdfs:label 'Action Description' ;
    rdfs:comment 'Detailed narrative of the specific remediation steps to be taken, including scope, method, materials, and acceptance criteria.' ;
    rdfs:domain ind:CorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actionStatus rdf:type rdf:Property ;
    rdfs:label 'Action Status' ;
    rdfs:comment 'Current lifecycle state of the corrective action: open (assigned but not started), in_progress (work underway), pending_verification (awaiting QA/QC review), verified (effectiveness confirmed), closed (completed and accepted), cancelled (no longer required).' ;
    rdfs:domain ind:CorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignedDate rdf:type rdf:Property ;
    rdfs:label 'Assigned Date' ;
    rdfs:comment 'Date when the corrective action was formally assigned to the responsible party.' ;
    rdfs:domain ind:CorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectivenessReviewComments rdf:type rdf:Property ;
    rdfs:label 'Effectiveness Review Comments' ;
    rdfs:comment 'Detailed comments from the effectiveness review, including evidence of resolution, lessons learned, and recommendations for process improvement.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectivenessReviewDate rdf:type rdf:Property ;
    rdfs:label 'Effectiveness Review Date' ;
    rdfs:comment 'Date when the effectiveness of the corrective action was formally reviewed, typically 30-90 days after implementation.' ;
    rdfs:domain ind:CorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectivenessReviewOutcome rdf:type rdf:Property ;
    rdfs:label 'Effectiveness Review Outcome' ;
    rdfs:comment 'Result of the effectiveness review: effective (action resolved the issue and prevented recurrence), partially_effective (issue partially resolved, additional action required), ineffective (action did not resolve the issue), pending_review (awaiting final assessment).' ;
    rdfs:domain ind:CorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isSystemicIssue rdf:type rdf:Property ;
    rdfs:label 'Is Systemic Issue' ;
    rdfs:comment 'Indicates whether the root cause analysis identified this as a systemic issue requiring organization-wide corrective action across multiple projects or processes.' ;
    rdfs:domain ind:CorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lessonsLearned rdf:type rdf:Property ;
    rdfs:label 'Lessons Learned' ;
    rdfs:comment 'Summary of lessons learned from this corrective action, including process improvements, training needs, and recommendations for future projects.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recurrencePreventionMeasures rdf:type rdf:Property ;
    rdfs:label 'Recurrence Prevention Measures' ;
    rdfs:comment 'Specific measures implemented to prevent recurrence of the non-conformance, such as updated work instructions, additional inspections, or supplier quality audits.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiresClientApproval rdf:type rdf:Property ;
    rdfs:label 'Requires Client Approval' ;
    rdfs:comment 'Indicates whether the corrective action requires formal approval from the client or project owner before implementation.' ;
    rdfs:domain ind:CorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiresDesignChange rdf:type rdf:Property ;
    rdfs:label 'Requires Design Change' ;
    rdfs:comment 'Indicates whether the corrective action requires a formal design change, triggering BIM (Building Information Modeling) revision and engineering approval workflows.' ;
    rdfs:domain ind:CorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rootCauseAnalysis rdf:type rdf:Property ;
    rdfs:label 'Root Cause Analysis' ;
    rdfs:comment 'Summary of the root cause investigation findings that informed this corrective action, often using 5-Why, Fishbone, or Fault Tree Analysis methods.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Target Completion Date' ;
    rdfs:comment 'Planned date by which the corrective action must be completed to meet project schedule and compliance requirements.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:verificationMethod rdf:type rdf:Property ;
    rdfs:label 'Verification Method' ;
    rdfs:comment 'Method used to verify the effectiveness of the corrective action: inspection (visual check), testing (material or functional test), document_review (record verification), audit (formal QA/QC audit), site_observation (field walkdown), measurement (dimensional or performance measurement).' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verifiedByName rdf:type rdf:Property ;
    rdfs:label 'Verified By Name' ;
    rdfs:comment 'Name of the individual who performed the verification of the corrective action.' ;
    rdfs:domain ind:CorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defectId rdf:type rdf:Property ;
    rdfs:label 'Defect Id' ;
    rdfs:comment 'Unique identifier for the defect record. Primary key for the defect entity.' ;
    rdfs:domain ind:Defect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:identifiedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Identified By Employee Id' ;
    rdfs:comment 'Foreign key linking to hr.employee. Business justification: Defect register records which employee identified the defect, needed for root-cause analysis and performance reporting.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:inspectionId rdf:type rdf:Property ;
    rdfs:label 'Inspection Id' ;
    rdfs:comment 'System identifier for the inspection record during which this defect was identified (e.g., ITP inspection, FAT, SAT, DLP walkthrough).' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Inspection .

ind:wasteRecordId rdf:type rdf:Property ;
    rdfs:label 'Waste Record Id' ;
    rdfs:comment 'Foreign key linking to sustainability.waste_record. Business justification: Defects often generate waste; linking a defect to the waste record that captures the disposed material supports waste tracking and cost analysis.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WasteRecord .

ind:actualRectificationDate rdf:type rdf:Property ;
    rdfs:label 'Actual Rectification Date' ;
    rdfs:comment 'Actual date when the defect rectification work was completed.' ;
    rdfs:domain ind:Defect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assignedTo rdf:type rdf:Property ;
    rdfs:label 'Assigned To' ;
    rdfs:comment 'Name of the individual or team currently assigned to manage or rectify the defect.' ;
    rdfs:domain ind:Defect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defectDescription rdf:type rdf:Property ;
    rdfs:label 'Defect Description' ;
    rdfs:comment 'Detailed description of the defect including nature, extent, and any observable symptoms or deviations from specification.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defectNumber rdf:type rdf:Property ;
    rdfs:label 'Defect Number' ;
    rdfs:comment 'Business-facing unique identifier or reference number for the defect, typically used in correspondence and reporting.' ;
    rdfs:domain ind:Defect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defectStatus rdf:type rdf:Property ;
    rdfs:label 'Defect Status' ;
    rdfs:comment 'Current lifecycle status of the defect: open (newly identified), assigned (allocated to responsible party), in_progress (rectification underway), rectified (work completed, awaiting verification), verified (inspected and accepted), closed (fully resolved), rejected (not a valid defect). [ENUM-REF-CANDIDATE: open|assigned|in_progress|rectified|verified|closed|rejected — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Defect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defectType rdf:type rdf:Property ;
    rdfs:label 'Defect Type' ;
    rdfs:comment 'Classification of the defect by nature: workmanship (poor execution), material (defective materials), design (design flaw), installation (incorrect installation), finish (cosmetic/surface defects), structural (load-bearing issues), MEP (Mechanical Electrical Plumbing systems), or other. [ENUM-REF-CANDIDATE: workmanship|material|design|installation|finish|structural|MEP|other — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Defect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dlpExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Dlp Expiry Date' ;
    rdfs:comment 'Date when the Defects Liability Period (DLP) expires for the work package or project area where this defect was identified. Defects identified before this date must be rectified by the contractor at no cost to the client.' ;
    rdfs:domain ind:Defect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:identifiedBy rdf:type rdf:Property ;
    rdfs:label 'Identified By' ;
    rdfs:comment 'Name of the person or role who identified the defect (e.g., QA/QC inspector, client representative, commissioning engineer, site supervisor).' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:identifiedPhase rdf:type rdf:Property ;
    rdfs:label 'Identified Phase' ;
    rdfs:comment 'Project phase during which the defect was identified: construction (during active construction), pre_commissioning (before system startup), commissioning (during FAT/SAT), handover (at project handover), DLP (Defects Liability Period), post_handover (after final handover).' ;
    rdfs:domain ind:Defect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impactOnHandover rdf:type rdf:Property ;
    rdfs:label 'Impact On Handover' ;
    rdfs:comment 'Indicates whether the defect impacts project handover or commissioning milestones (True if it blocks handover, False otherwise).' ;
    rdfs:domain ind:Defect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:locationBuilding rdf:type rdf:Property ;
    rdfs:label 'Location Building' ;
    rdfs:comment 'Building or structure identifier where the defect is located (e.g., Building A, Main Terminal, Power Block 1).' ;
    rdfs:domain ind:Defect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:locationGridReference rdf:type rdf:Property ;
    rdfs:label 'Location Grid Reference' ;
    rdfs:comment 'Grid reference or coordinate system identifier pinpointing the defect location on construction drawings (e.g., Grid A-3, Column Line B/5).' ;
    rdfs:domain ind:Defect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:locationLevel rdf:type rdf:Property ;
    rdfs:label 'Location Level' ;
    rdfs:comment 'Floor or level identifier where the defect is located (e.g., Ground Floor, Level 3, Basement 2, Roof).' ;
    rdfs:domain ind:Defect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:locationZone rdf:type rdf:Property ;
    rdfs:label 'Location Zone' ;
    rdfs:comment 'Zone, area, or room identifier where the defect is located (e.g., Zone A, Room 301, Lobby, Mechanical Room).' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:photoReference rdf:type rdf:Property ;
    rdfs:label 'Photo Reference' ;
    rdfs:comment 'Reference or file path to photographic evidence of the defect, typically stored in document management system (e.g., Aconex, BIM 360).' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rectificationCost rdf:type rdf:Property ;
    rdfs:label 'Rectification Cost' ;
    rdfs:comment 'Estimated or actual cost incurred to rectify the defect, typically borne by the responsible contractor.' ;
    rdfs:domain ind:Defect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rectificationMethod rdf:type rdf:Property ;
    rdfs:label 'Rectification Method' ;
    rdfs:comment 'Description of the method or approach used to rectify the defect (e.g., rework, replacement, repair, adjustment, re-finishing).' ;
    rdfs:domain ind:Defect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsibleContractorName rdf:type rdf:Property ;
    rdfs:label 'Responsible Contractor Name' ;
    rdfs:comment 'Name of the contractor or subcontractor responsible for rectifying the defect.' ;
    rdfs:domain ind:Defect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:severity rdf:type rdf:Property ;
    rdfs:label 'Severity' ;
    rdfs:comment 'Severity classification of the defect: critical (safety/structural risk, immediate action required), major (significant impact on functionality or performance), minor (limited impact, does not affect primary function), cosmetic (aesthetic only, no functional impact).' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetRectificationDate rdf:type rdf:Property ;
    rdfs:label 'Target Rectification Date' ;
    rdfs:comment 'Target or planned date by which the defect should be rectified, often driven by DLP (Defects Liability Period) expiry or contractual milestones.' ;
    rdfs:domain ind:Defect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:itpLineId rdf:type rdf:Property ;
    rdfs:label 'Itp Line Id' ;
    rdfs:comment 'Foreign key linking to quality.itp_line. Business justification: Link inspection to its ITP line for proper hierarchy; inspection may occur multiple times per line.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ItpLine .

ind:checklistTemplateName rdf:type rdf:Property ;
    rdfs:label 'Checklist Template Name' ;
    rdfs:comment 'Name of the checklist template used (e.g., Concrete Pour Inspection Checklist, Structural Steel Welding Inspection, MEP Rough-in Checklist). Provides human-readable context.' ;
    rdfs:domain ind:Inspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checklistVersion rdf:type rdf:Property ;
    rdfs:label 'Checklist Version' ;
    rdfs:comment 'Version number of the checklist template used at the time of inspection. Ensures audit trail of which criteria were applied.' ;
    rdfs:domain ind:Inspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endTime rdf:type rdf:Property ;
    rdfs:label 'End Time' ;
    rdfs:comment 'Precise timestamp when the inspection activity was completed and all checklist items verified.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:humidityPercent rdf:type rdf:Property ;
    rdfs:label 'Humidity Percent' ;
    rdfs:comment 'Relative humidity percentage at the time of inspection. Relevant for coating, painting, and other moisture-sensitive quality checks.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inspectorCertification rdf:type rdf:Property ;
    rdfs:label 'Inspector Certification' ;
    rdfs:comment 'Professional certification or qualification held by the inspector (e.g., AWS CWI for welding, ACI for concrete, ASNT for NDT). Validates inspector competency.' ;
    rdfs:domain ind:Inspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:itemsFailed rdf:type rdf:Property ;
    rdfs:label 'Items Failed' ;
    rdfs:comment 'Count of checklist items that did not meet acceptance criteria and failed verification. Typically triggers NCR (Non-Conformance Report) creation.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:itemsNotApplicable rdf:type rdf:Property ;
    rdfs:label 'Items Not Applicable' ;
    rdfs:comment 'Count of checklist items marked as not applicable to this specific inspection instance due to scope or conditions.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:itemsPassed rdf:type rdf:Property ;
    rdfs:label 'Items Passed' ;
    rdfs:comment 'Count of checklist items that met acceptance criteria and passed verification.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:photoCount rdf:type rdf:Property ;
    rdfs:label 'Photo Count' ;
    rdfs:comment 'Number of photographs captured during the inspection as visual evidence of conditions, defects, or compliance.' ;
    rdfs:domain ind:Inspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reinspectionDate rdf:type rdf:Property ;
    rdfs:label 'Reinspection Date' ;
    rdfs:comment 'Scheduled date for follow-up reinspection to verify corrective actions have been implemented and defects resolved.' ;
    rdfs:domain ind:Inspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reinspectionRequired rdf:type rdf:Property ;
    rdfs:label 'Reinspection Required' ;
    rdfs:comment 'Boolean flag indicating whether a follow-up reinspection is required after corrective actions are completed. True indicates reinspection needed; false indicates no reinspection required.' ;
    rdfs:domain ind:Inspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:startTime rdf:type rdf:Property ;
    rdfs:label 'Start Time' ;
    rdfs:comment 'Precise timestamp when the inspection activity commenced on site or at the facility.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:workPackageReference rdf:type rdf:Property ;
    rdfs:label 'Work Package Reference' ;
    rdfs:comment 'Reference to the work package, activity, or WBS (Work Breakdown Structure) element being inspected. Links quality verification to project schedule and scope.' ;
    rdfs:domain ind:Inspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qcInspectorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Qc Inspector Employee Id' ;
    rdfs:comment 'Foreign key linking to hr.employee. Business justification: ITP approval workflow requires tracking the internal QC inspector responsible for the plan, enabling accountability and audit trails.' ;
    rdfs:domain ind:Itp ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:clientInspectorResponsibleParty rdf:type rdf:Property ;
    rdfs:label 'Client Inspector Responsible Party' ;
    rdfs:comment 'Name or role of the client or third-party inspector responsible for witnessing or reviewing inspections per this ITP.' ;
    rdfs:domain ind:Itp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defectLiabilityPeriodDays rdf:type rdf:Property ;
    rdfs:label 'Defect Liability Period Days' ;
    rdfs:comment 'Duration in days of the defects liability period applicable to work covered by this ITP. Defines the warranty period for quality defects.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:documentStorageLocation rdf:type rdf:Property ;
    rdfs:label 'Document Storage Location' ;
    rdfs:comment 'Physical or digital location where the ITP document and related inspection records are stored (e.g., Aconex folder path, SharePoint URL, physical file reference).' ;
    rdfs:domain ind:Itp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fatRequired rdf:type rdf:Property ;
    rdfs:label 'Fat Required' ;
    rdfs:comment 'Indicates whether a Factory Acceptance Test is required as part of this ITP. Applicable to equipment and prefabricated components.' ;
    rdfs:domain ind:Itp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:holdPointRequired rdf:type rdf:Property ;
    rdfs:label 'Hold Point Required' ;
    rdfs:comment 'Indicates whether this ITP includes mandatory hold points where work cannot proceed until inspection approval is obtained. Critical for compliance and risk management.' ;
    rdfs:domain ind:Itp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inspectionFrequency rdf:type rdf:Property ;
    rdfs:label 'Inspection Frequency' ;
    rdfs:comment 'Frequency or sampling rate for inspections defined in this ITP (e.g., \'100% inspection\', \'Every 10th unit\', \'Daily\', \'Per shift\'). Defines the intensity of quality control.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:itpNumber rdf:type rdf:Property ;
    rdfs:label 'Itp Number' ;
    rdfs:comment 'Business identifier for the ITP document, typically following a project-specific numbering convention. Used for external reference and document control.' ;
    rdfs:domain ind:Itp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialTestCertificateRequired rdf:type rdf:Property ;
    rdfs:label 'Material Test Certificate Required' ;
    rdfs:comment 'Indicates whether material test certificates must be submitted and verified as part of this ITP. Common for structural materials and critical components.' ;
    rdfs:domain ind:Itp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ndtMethodRequired rdf:type rdf:Property ;
    rdfs:label 'Ndt Method Required' ;
    rdfs:comment 'Type of non-destructive testing method required by this ITP, if applicable. Critical for structural integrity verification in construction. [ENUM-REF-CANDIDATE: none|visual|ultrasonic|radiographic|magnetic_particle|liquid_penetrant|eddy_current — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Itp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qcInspectorResponsibleParty rdf:type rdf:Property ;
    rdfs:label 'Qc Inspector Responsible Party' ;
    rdfs:comment 'Name or role of the contractor QC inspector responsible for verifying compliance with this ITP before submission to the client.' ;
    rdfs:domain ind:Itp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewPointRequired rdf:type rdf:Property ;
    rdfs:label 'Review Point Required' ;
    rdfs:comment 'Indicates whether this ITP includes review points where inspection records and test results must be submitted for review by the client or engineer.' ;
    rdfs:domain ind:Itp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:satRequired rdf:type rdf:Property ;
    rdfs:label 'Sat Required' ;
    rdfs:comment 'Indicates whether a Site Acceptance Test is required as part of this ITP. Applicable to installed equipment and systems commissioning.' ;
    rdfs:domain ind:Itp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:testMethodReference rdf:type rdf:Property ;
    rdfs:label 'Test Method Reference' ;
    rdfs:comment 'Reference to the standard test methods or procedures to be used for testing under this ITP (e.g., \'ASTM E165\', \'ISO 9712\', \'ACI 318 Section 5.6\').' ;
    rdfs:domain ind:Itp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:witnessPointRequired rdf:type rdf:Property ;
    rdfs:label 'Witness Point Required' ;
    rdfs:comment 'Indicates whether this ITP includes witness points where the client or third-party inspector must be notified and given the opportunity to witness the inspection.' ;
    rdfs:domain ind:Itp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:workPackageDescription rdf:type rdf:Property ;
    rdfs:label 'Work Package Description' ;
    rdfs:comment 'Detailed description of the construction work package, activity, or deliverable that this ITP covers. Defines the scope of inspection and testing.' ;
    rdfs:domain ind:Itp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsibleCrewId rdf:type rdf:Property ;
    rdfs:label 'Responsible Crew Id' ;
    rdfs:comment 'Foreign key linking to workforce.crew. Business justification: ITP line often executed by a crew; linking crew provides crew-level accountability.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Crew .

ind:activityDescription rdf:type rdf:Property ;
    rdfs:label 'Activity Description' ;
    rdfs:comment 'Detailed description of the specific inspection or test activity to be performed at this hold point, witness point, or review point.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calibrationRequired rdf:type rdf:Property ;
    rdfs:label 'Calibration Required' ;
    rdfs:comment 'Indicates whether the test equipment used for this inspection must have valid calibration certificates before use.' ;
    rdfs:domain ind:ItpLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:clientWitnessRequired rdf:type rdf:Property ;
    rdfs:label 'Client Witness Required' ;
    rdfs:comment 'Indicates whether the client or their representative must be present to witness this inspection activity before work can proceed.' ;
    rdfs:domain ind:ItpLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:consultantWitnessRequired rdf:type rdf:Property ;
    rdfs:label 'Consultant Witness Required' ;
    rdfs:comment 'Indicates whether the consultant or engineer must be present to witness this inspection activity before work can proceed.' ;
    rdfs:domain ind:ItpLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:environmentalConditions rdf:type rdf:Property ;
    rdfs:label 'Environmental Conditions' ;
    rdfs:comment 'Any specific environmental conditions or constraints that must be met during inspection (e.g., temperature range, humidity limits, weather restrictions, lighting requirements).' ;
    rdfs:domain ind:ItpLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdPointType rdf:type rdf:Property ;
    rdfs:label 'Hold Point Type' ;
    rdfs:comment 'Classification of the inspection point. Hold: work cannot proceed without approval. Witness: client/consultant must be present. Review: documentation review only. Surveillance: periodic monitoring.' ;
    rdfs:domain ind:ItpLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionMethod rdf:type rdf:Property ;
    rdfs:label 'Inspection Method' ;
    rdfs:comment 'The method or technique to be used for performing the inspection or test (e.g., visual inspection, ultrasonic testing, dimensional check, pressure test, material sampling).' ;
    rdfs:domain ind:ItpLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:itpLineStatus rdf:type rdf:Property ;
    rdfs:label 'Itp Line Status' ;
    rdfs:comment 'Current status of this ITP line item in its lifecycle. Planned: not yet ready. Ready: prerequisites met. In Progress: inspection underway. Completed: inspection finished. Waived: inspection waived by authority. Cancelled: no longer required.' ;
    rdfs:domain ind:ItpLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ncrTriggerCriteria rdf:type rdf:Property ;
    rdfs:label 'Ncr Trigger Criteria' ;
    rdfs:comment 'The specific conditions or findings that would trigger the issuance of a Non-Conformance Report (NCR) if this inspection fails.' ;
    rdfs:domain ind:ItpLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationLeadTimeHours rdf:type rdf:Property ;
    rdfs:label 'Notification Lead Time Hours' ;
    rdfs:comment 'The minimum advance notice in hours that must be given to client, consultant, or third-party witnesses before performing this inspection.' ;
    rdfs:domain ind:ItpLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:requiredDocumentation rdf:type rdf:Property ;
    rdfs:label 'Required Documentation' ;
    rdfs:comment 'List of documents, certificates, or records that must be produced as evidence of inspection completion (e.g., test certificates, inspection reports, material certificates, calibration records).' ;
    rdfs:domain ind:ItpLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:samplingPlan rdf:type rdf:Property ;
    rdfs:label 'Sampling Plan' ;
    rdfs:comment 'The statistical sampling plan or sample size requirements for this inspection activity (e.g., AQL levels, sample quantity, sampling method).' ;
    rdfs:domain ind:ItpLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sequenceDependency rdf:type rdf:Property ;
    rdfs:label 'Sequence Dependency' ;
    rdfs:comment 'Description of any prerequisite inspections or activities that must be completed before this inspection can be performed.' ;
    rdfs:domain ind:ItpLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testEquipmentRequired rdf:type rdf:Property ;
    rdfs:label 'Test Equipment Required' ;
    rdfs:comment 'List of specialized test equipment, instruments, or tools required to perform this inspection or test (e.g., ultrasonic tester, pressure gauge, theodolite, concrete slump cone).' ;
    rdfs:domain ind:ItpLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thirdPartyWitnessRequired rdf:type rdf:Property ;
    rdfs:label 'Third Party Witness Required' ;
    rdfs:comment 'Indicates whether a third-party inspector, certification body, or regulatory authority must witness this inspection activity.' ;
    rdfs:domain ind:ItpLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:labTestId rdf:type rdf:Property ;
    rdfs:label 'Lab Test Id' ;
    rdfs:comment 'Unique identifier for the laboratory test record. Primary key for the lab_test product.' ;
    rdfs:domain ind:LabTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:originalTestLabTestId rdf:type rdf:Property ;
    rdfs:label 'Original Test Lab Test Id' ;
    rdfs:comment 'Reference to the original lab_test_id if this record represents a retest. Null for initial tests.' ;
    rdfs:domain ind:LabTest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LabTest .

ind:sampleId rdf:type rdf:Property ;
    rdfs:label 'Sample Id' ;
    rdfs:comment 'Unique identifier assigned to the material sample submitted for testing. Typically follows project-specific or laboratory numbering conventions.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Sample .

ind:deliveryTicketNumber rdf:type rdf:Property ;
    rdfs:label 'Delivery Ticket Number' ;
    rdfs:comment 'Delivery docket or ticket number associated with the material delivery from which the sample was taken.' ;
    rdfs:domain ind:LabTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:laboratoryAccreditationNumber rdf:type rdf:Property ;
    rdfs:label 'Laboratory Accreditation Number' ;
    rdfs:comment 'Accreditation certificate number or registration number issued by the national accreditation body (e.g., UKAS, A2LA, NATA) confirming the laboratory meets ISO/IEC 17025 standards.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:laboratoryName rdf:type rdf:Property ;
    rdfs:label 'Laboratory Name' ;
    rdfs:comment 'Name of the accredited testing laboratory that performed the test.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measuredResult rdf:type rdf:Property ;
    rdfs:label 'Measured Result' ;
    rdfs:comment 'Numerical value of the test result as measured by the laboratory.' ;
    rdfs:domain ind:LabTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:resultUnit rdf:type rdf:Property ;
    rdfs:label 'Result Unit' ;
    rdfs:comment 'Unit of measure for the test result, such as MPa, psi, kg/m3, percent, mm, or other applicable units.' ;
    rdfs:domain ind:LabTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retestFlag rdf:type rdf:Property ;
    rdfs:label 'Retest Flag' ;
    rdfs:comment 'Indicates whether this test is a retest following a previous failure or non-conformance.' ;
    rdfs:domain ind:LabTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sampledBy rdf:type rdf:Property ;
    rdfs:label 'Sampled By' ;
    rdfs:comment 'Name or identifier of the person or organization responsible for collecting the sample.' ;
    rdfs:domain ind:LabTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:samplingDate rdf:type rdf:Property ;
    rdfs:label 'Sampling Date' ;
    rdfs:comment 'Date when the material sample was collected from the construction site or delivery location.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:samplingLocation rdf:type rdf:Property ;
    rdfs:label 'Sampling Location' ;
    rdfs:comment 'Physical location or grid reference where the sample was collected, including building, floor, zone, or chainage reference.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specificationRequirement rdf:type rdf:Property ;
    rdfs:label 'Specification Requirement' ;
    rdfs:comment 'Required or target value per project specifications or applicable standards against which the test result is evaluated.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testAgeDays rdf:type rdf:Property ;
    rdfs:label 'Test Age Days' ;
    rdfs:comment 'Age of the sample at the time of testing, measured in days from sampling date. Critical for concrete cube/cylinder tests (typically 7, 28, or 56 days).' ;
    rdfs:domain ind:LabTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:testCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Test Certificate Number' ;
    rdfs:comment 'Unique certificate number issued by the laboratory for the test report, used for verification and traceability.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testParameter rdf:type rdf:Property ;
    rdfs:label 'Test Parameter' ;
    rdfs:comment 'The specific property or characteristic being measured, such as compressive strength, slump, moisture content, or gradation.' ;
    rdfs:domain ind:LabTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testResultStatus rdf:type rdf:Property ;
    rdfs:label 'Test Result Status' ;
    rdfs:comment 'Pass/fail determination based on comparison of measured result against specification requirements and tolerances.' ;
    rdfs:domain ind:LabTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testedBy rdf:type rdf:Property ;
    rdfs:label 'Tested By' ;
    rdfs:comment 'Name or identifier of the laboratory technician or engineer who performed the test.' ;
    rdfs:domain ind:LabTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:toleranceLowerLimit rdf:type rdf:Property ;
    rdfs:label 'Tolerance Lower Limit' ;
    rdfs:comment 'Minimum acceptable value for the test parameter. Results below this threshold constitute a failure.' ;
    rdfs:domain ind:LabTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:toleranceUpperLimit rdf:type rdf:Property ;
    rdfs:label 'Tolerance Upper Limit' ;
    rdfs:comment 'Maximum acceptable value for the test parameter. Results above this threshold may constitute a failure depending on the parameter.' ;
    rdfs:domain ind:LabTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:witnessRequired rdf:type rdf:Property ;
    rdfs:label 'Witness Required' ;
    rdfs:comment 'Indicates whether client, consultant, or third-party witness was required to be present during testing per contract or ITP requirements.' ;
    rdfs:domain ind:LabTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:clientNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Client Notification Date' ;
    rdfs:comment 'Date when the client was formally notified of the non-conformance. Null if client notification was not required.' ;
    rdfs:domain ind:Ncr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:clientNotificationRequired rdf:type rdf:Property ;
    rdfs:label 'Client Notification Required' ;
    rdfs:comment 'Indicates whether the client must be formally notified of this non-conformance per contract requirements. Typically true for major or critical NCRs.' ;
    rdfs:domain ind:Ncr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:correctiveActionCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Completion Date' ;
    rdfs:comment 'Actual date when the corrective action was completed. Compared against target date for performance measurement.' ;
    rdfs:domain ind:Ncr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:correctiveActionResponsibleParty rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Responsible Party' ;
    rdfs:comment 'Name or identifier of the person or organization responsible for implementing the corrective action.' ;
    rdfs:domain ind:Ncr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionTargetDate rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Target Date' ;
    rdfs:comment 'Planned target date for completion of the corrective action. Used for tracking and escalation if deadlines are missed.' ;
    rdfs:domain ind:Ncr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dispositionApprovedBy rdf:type rdf:Property ;
    rdfs:label 'Disposition Approved By' ;
    rdfs:comment 'Name or identifier of the person who approved the disposition decision. Typically a senior QA/QC manager, project manager, or client representative.' ;
    rdfs:domain ind:Ncr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispositionApprovedDate rdf:type rdf:Property ;
    rdfs:label 'Disposition Approved Date' ;
    rdfs:comment 'Date when the disposition was formally approved, allowing corrective action to proceed.' ;
    rdfs:domain ind:Ncr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dispositionJustification rdf:type rdf:Property ;
    rdfs:label 'Disposition Justification' ;
    rdfs:comment 'Technical and business justification for the selected disposition, including engineering analysis, code compliance assessment, and impact on functionality.' ;
    rdfs:domain ind:Ncr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedCostImpact rdf:type rdf:Property ;
    rdfs:label 'Estimated Cost Impact' ;
    rdfs:comment 'Estimated financial cost impact of the non-conformance including rework, material replacement, schedule delay, and potential liquidated damages. Used for cost tracking and recovery.' ;
    rdfs:domain ind:Ncr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:holdReleaseDate rdf:type rdf:Property ;
    rdfs:label 'Hold Release Date' ;
    rdfs:comment 'Date when the hold was released, allowing work to resume. Null if no hold was placed or if hold is still active.' ;
    rdfs:domain ind:Ncr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:holdStatus rdf:type rdf:Property ;
    rdfs:label 'Hold Status' ;
    rdfs:comment 'Indicates whether a hold has been placed on the affected work or material, preventing further work until the NCR is resolved. True if hold is active, False otherwise.' ;
    rdfs:domain ind:Ncr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ncrCategory rdf:type rdf:Property ;
    rdfs:label 'Ncr Category' ;
    rdfs:comment 'High-level classification of the type of non-conformance to support trend analysis and root cause categorization.' ;
    rdfs:domain ind:Ncr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ncrDescription rdf:type rdf:Property ;
    rdfs:label 'Ncr Description' ;
    rdfs:comment 'Detailed narrative description of the non-conformance, including what was observed, what was expected per specifications, and the extent of the deviation.' ;
    rdfs:domain ind:Ncr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ncrNumber rdf:type rdf:Property ;
    rdfs:label 'Ncr Number' ;
    rdfs:comment 'Business identifier for the NCR, typically following a project-specific numbering convention. Externally visible reference number used in correspondence and documentation.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ncrStatus rdf:type rdf:Property ;
    rdfs:label 'Ncr Status' ;
    rdfs:comment 'Current lifecycle status of the NCR tracking its progression from identification through closure. Reflects the workflow state in the CAPA (Corrective and Preventive Action) cycle. [ENUM-REF-CANDIDATE: draft|open|under_investigation|pending_disposition|corrective_action_in_progress|verification_pending|closed|cancelled — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Ncr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preventiveActionDescription rdf:type rdf:Property ;
    rdfs:label 'Preventive Action Description' ;
    rdfs:comment 'Description of preventive actions to be taken to prevent recurrence of similar non-conformances. Addresses systemic issues identified in root cause analysis.' ;
    rdfs:domain ind:Ncr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preventiveActionResponsibleParty rdf:type rdf:Property ;
    rdfs:label 'Preventive Action Responsible Party' ;
    rdfs:comment 'Name or identifier of the person or organization responsible for implementing the preventive action.' ;
    rdfs:domain ind:Ncr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityAffected rdf:type rdf:Property ;
    rdfs:label 'Quantity Affected' ;
    rdfs:comment 'Numeric quantity of work, material, or units affected by the non-conformance (e.g., 150 cubic meters of concrete, 25 welds, 500 linear meters of pipe).' ;
    rdfs:domain ind:Ncr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reportedBy rdf:type rdf:Property ;
    rdfs:label 'Reported By' ;
    rdfs:comment 'Name or identifier of the person who identified and reported the non-conformance. Typically a QA/QC inspector, site engineer, or subcontractor representative.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportedByOrganization rdf:type rdf:Property ;
    rdfs:label 'Reported By Organization' ;
    rdfs:comment 'Organization or company that the reporting person represents (e.g., General Contractor, Subcontractor, Client, Third-Party Inspector).' ;
    rdfs:domain ind:Ncr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationPerformedBy rdf:type rdf:Property ;
    rdfs:label 'Verification Performed By' ;
    rdfs:comment 'Name or identifier of the person who performed the verification of corrective action effectiveness. Typically a QA/QC inspector or independent verifier.' ;
    rdfs:domain ind:Ncr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationResult rdf:type rdf:Property ;
    rdfs:label 'Verification Result' ;
    rdfs:comment 'Outcome of the verification activity indicating whether the corrective action was effective and the non-conformance is resolved.' ;
    rdfs:domain ind:Ncr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ndtRecordId rdf:type rdf:Property ;
    rdfs:label 'Ndt Record Id' ;
    rdfs:comment 'Unique identifier for the NDT record. Primary key for the NDT record entity.' ;
    rdfs:domain ind:NdtRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:calibrationDueDate rdf:type rdf:Property ;
    rdfs:label 'Calibration Due Date' ;
    rdfs:comment 'The date by which the NDT equipment must be recalibrated to remain valid for testing.' ;
    rdfs:domain ind:NdtRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:calibrationReference rdf:type rdf:Property ;
    rdfs:label 'Calibration Reference' ;
    rdfs:comment 'Reference number or certificate number of the equipment calibration record, ensuring the equipment was within valid calibration at the time of testing.' ;
    rdfs:domain ind:NdtRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:componentDescription rdf:type rdf:Property ;
    rdfs:label 'Component Description' ;
    rdfs:comment 'Description of the structural element, weld, or pressure system component being tested (e.g., pipe weld joint, structural beam, pressure vessel).' ;
    rdfs:domain ind:NdtRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:componentIdentifier rdf:type rdf:Property ;
    rdfs:label 'Component Identifier' ;
    rdfs:comment 'Unique identifier or tag number of the component being tested, as per engineering drawings or asset register.' ;
    rdfs:domain ind:NdtRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equipmentUsed rdf:type rdf:Property ;
    rdfs:label 'Equipment Used' ;
    rdfs:comment 'Description or model of the NDT equipment used (e.g., ultrasonic flaw detector, X-ray machine, magnetic yoke).' ;
    rdfs:domain ind:NdtRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:indicationCount rdf:type rdf:Property ;
    rdfs:label 'Indication Count' ;
    rdfs:comment 'Number of indications or defects identified during the NDT.' ;
    rdfs:domain ind:NdtRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:indicationFindings rdf:type rdf:Property ;
    rdfs:label 'Indication Findings' ;
    rdfs:comment 'Detailed description of any indications, discontinuities, or defects found during the NDT (e.g., crack, porosity, lack of fusion, slag inclusion).' ;
    rdfs:domain ind:NdtRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:indicationSeverity rdf:type rdf:Property ;
    rdfs:label 'Indication Severity' ;
    rdfs:comment 'Severity classification of the most significant indication found (minor, major, critical) based on acceptance criteria.' ;
    rdfs:domain ind:NdtRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ndtMethod rdf:type rdf:Property ;
    rdfs:label 'Ndt Method' ;
    rdfs:comment 'The NDT method used: RT (Radiographic Testing), UT (Ultrasonic Testing), MT (Magnetic Particle Testing), PT (Dye Penetrant Testing), VT (Visual Testing), ET (Eddy Current Testing), LT (Leak Testing). [ENUM-REF-CANDIDATE: RT|UT|MT|PT|VT|ET|LT — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:repairRequired rdf:type rdf:Property ;
    rdfs:label 'Repair Required' ;
    rdfs:comment 'Indicates whether repair or corrective action is required based on the NDT findings (True/False).' ;
    rdfs:domain ind:NdtRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:technicianCertificationExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Technician Certification Expiry Date' ;
    rdfs:comment 'Expiry date of the NDT technician\'s certification, ensuring the technician was qualified at the time of testing.' ;
    rdfs:domain ind:NdtRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:technicianCertificationLevel rdf:type rdf:Property ;
    rdfs:label 'Technician Certification Level' ;
    rdfs:comment 'Certification level of the NDT technician as per ASNT SNT-TC-1A or PCN (Level I, Level II, Level III).' ;
    rdfs:domain ind:NdtRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technicianCertificationNumber rdf:type rdf:Property ;
    rdfs:label 'Technician Certification Number' ;
    rdfs:comment 'Unique certification number issued to the NDT technician by the certifying body (ASNT, PCN, or equivalent).' ;
    rdfs:domain ind:NdtRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technicianName rdf:type rdf:Property ;
    rdfs:label 'Technician Name' ;
    rdfs:comment 'Full name of the NDT technician who performed the test.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:weldNumber rdf:type rdf:Property ;
    rdfs:label 'Weld Number' ;
    rdfs:comment 'Unique identifier for the weld joint being tested, if applicable. Used for traceability in welding quality control.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedByName rdf:type rdf:Property ;
    rdfs:label 'Approved By Name' ;
    rdfs:comment 'Name of the individual who formally approved the quality plan for implementation.' ;
    rdfs:domain ind:QualityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedByRole rdf:type rdf:Property ;
    rdfs:label 'Approved By Role' ;
    rdfs:comment 'Organizational role or title of the approver (e.g., Project Director, Quality Director).' ;
    rdfs:domain ind:QualityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditScheduleReference rdf:type rdf:Property ;
    rdfs:label 'Audit Schedule Reference' ;
    rdfs:comment 'Reference to the internal and external audit schedule defined for the project.' ;
    rdfs:domain ind:QualityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calibrationProcedureReference rdf:type rdf:Property ;
    rdfs:label 'Calibration Procedure Reference' ;
    rdfs:comment 'Reference to the procedure for calibration and maintenance of inspection, measuring, and test equipment.' ;
    rdfs:domain ind:QualityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clientApprovedByName rdf:type rdf:Property ;
    rdfs:label 'Client Approved By Name' ;
    rdfs:comment 'Name of the client representative who approved the quality plan.' ;
    rdfs:domain ind:QualityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:continuousImprovementMechanism rdf:type rdf:Property ;
    rdfs:label 'Continuous Improvement Mechanism' ;
    rdfs:comment 'Description of mechanisms for continuous improvement, including lessons learned, corrective actions, and preventive actions.' ;
    rdfs:domain ind:QualityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractReference rdf:type rdf:Property ;
    rdfs:label 'Contract Reference' ;
    rdfs:comment 'Reference to the construction contract that mandates this quality plan.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentControlProcedure rdf:type rdf:Property ;
    rdfs:label 'Document Control Procedure' ;
    rdfs:comment 'Description of document control procedures for quality records, including numbering, distribution, revision, and archival.' ;
    rdfs:domain ind:QualityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:handoverQualityRequirements rdf:type rdf:Property ;
    rdfs:label 'Handover Quality Requirements' ;
    rdfs:comment 'Description of quality documentation and completion criteria required for project handover and commissioning.' ;
    rdfs:domain ind:QualityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionRegimeSummary rdf:type rdf:Property ;
    rdfs:label 'Inspection Regime Summary' ;
    rdfs:comment 'High-level summary of the inspection and testing regime, including hold points, witness points, and surveillance activities.' ;
    rdfs:domain ind:QualityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:itpRegisterReference rdf:type rdf:Property ;
    rdfs:label 'Itp Register Reference' ;
    rdfs:comment 'Reference to the master ITP register that lists all inspection and test plans governed by this quality plan.' ;
    rdfs:domain ind:QualityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialControlProcedure rdf:type rdf:Property ;
    rdfs:label 'Material Control Procedure' ;
    rdfs:comment 'Description of procedures for material receipt, inspection, storage, and traceability.' ;
    rdfs:domain ind:QualityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ncrProcedureReference rdf:type rdf:Property ;
    rdfs:label 'Ncr Procedure Reference' ;
    rdfs:comment 'Reference to the procedure for raising, investigating, and closing Non-Conformance Reports.' ;
    rdfs:domain ind:QualityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:organizationalStructure rdf:type rdf:Property ;
    rdfs:label 'Organizational Structure' ;
    rdfs:comment 'Description of the project quality organization, including roles, responsibilities, and reporting lines.' ;
    rdfs:domain ind:QualityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preparedByName rdf:type rdf:Property ;
    rdfs:label 'Prepared By Name' ;
    rdfs:comment 'Name of the individual or team responsible for preparing the quality plan.' ;
    rdfs:domain ind:QualityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preparedByRole rdf:type rdf:Property ;
    rdfs:label 'Prepared By Role' ;
    rdfs:comment 'Organizational role or title of the person who prepared the quality plan (e.g., Quality Manager, QA/QC Engineer).' ;
    rdfs:domain ind:QualityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityManagerName rdf:type rdf:Property ;
    rdfs:label 'Quality Manager Name' ;
    rdfs:comment 'Name of the designated Quality Manager responsible for implementing this plan.' ;
    rdfs:domain ind:QualityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityObjectives rdf:type rdf:Property ;
    rdfs:label 'Quality Objectives' ;
    rdfs:comment 'Specific, measurable quality objectives defined for the project (e.g., zero NCRs in critical systems, 100% ITP compliance).' ;
    rdfs:domain ind:QualityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityPolicyReference rdf:type rdf:Property ;
    rdfs:label 'Quality Policy Reference' ;
    rdfs:comment 'Reference to the organizational quality policy document that this plan implements.' ;
    rdfs:domain ind:QualityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewedByName rdf:type rdf:Property ;
    rdfs:label 'Reviewed By Name' ;
    rdfs:comment 'Name of the individual who reviewed the quality plan for technical accuracy and completeness.' ;
    rdfs:domain ind:QualityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewedByRole rdf:type rdf:Property ;
    rdfs:label 'Reviewed By Role' ;
    rdfs:comment 'Organizational role or title of the reviewer (e.g., Project Manager, Senior QA/QC Manager).' ;
    rdfs:domain ind:QualityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subcontractorQualityManagement rdf:type rdf:Property ;
    rdfs:label 'Subcontractor Quality Management' ;
    rdfs:comment 'Description of quality management requirements and oversight procedures for subcontractors and suppliers.' ;
    rdfs:domain ind:QualityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingRequirements rdf:type rdf:Property ;
    rdfs:label 'Training Requirements' ;
    rdfs:comment 'Description of quality-related training requirements for project personnel, including induction, competency assessments, and certifications.' ;
    rdfs:domain ind:QualityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:punchItemId rdf:type rdf:Property ;
    rdfs:label 'Punch Item Id' ;
    rdfs:comment 'Unique identifier for the punch list item. Primary key.' ;
    rdfs:domain ind:PunchItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:punchListId rdf:type rdf:Property ;
    rdfs:label 'Punch List Id' ;
    rdfs:comment 'Reference to the parent punch list record that contains this item. Links the item to the overall punch list inspection event.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PunchList .

ind:responsiblePartyEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Responsible Party Employee Id' ;
    rdfs:comment 'Foreign key linking to hr.employee. Business justification: Punch list items are assigned to a responsible employee; linking enables tracking of responsibility and performance.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:costImpact rdf:type rdf:Property ;
    rdfs:label 'Cost Impact' ;
    rdfs:comment 'Estimated or actual cost incurred to rectify the punch item. Used for financial tracking and back-charge to responsible parties.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deferredToDlp rdf:type rdf:Property ;
    rdfs:label 'Deferred To Dlp' ;
    rdfs:comment 'Flag indicating whether the punch item was deferred to the DLP (Defects Liability Period) for post-handover rectification. True if deferred; false otherwise.' ;
    rdfs:domain ind:PunchItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:punchItemCategory rdf:type rdf:Property ;
    rdfs:label 'Punch Item Category' ;
    rdfs:comment 'Classification of the punch item by discipline or trade. Structural covers concrete, steel, and load-bearing elements; MEP (Mechanical Electrical and Plumbing) covers HVAC, electrical, plumbing, and fire protection; Architectural covers doors, windows, ceilings, and interior finishes; Civil covers site work, paving, and drainage; Finishes covers painting, flooring, and decorative elements; Landscaping covers external plantings and hardscapes.' ;
    rdfs:domain ind:PunchItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:punchItemStatus rdf:type rdf:Property ;
    rdfs:label 'Punch Item Status' ;
    rdfs:comment 'Current lifecycle status of the punch item. Open indicates newly identified; in_progress indicates work underway; completed indicates work finished awaiting verification; verified indicates inspection passed; closed indicates final acceptance; rejected indicates failed verification requiring rework.' ;
    rdfs:domain ind:PunchItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationInspector rdf:type rdf:Property ;
    rdfs:label 'Verification Inspector' ;
    rdfs:comment 'Name of the inspector or quality engineer who verified that the punch item was satisfactorily completed. Provides accountability for quality sign-off.' ;
    rdfs:domain ind:PunchItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualCloseoutDate rdf:type rdf:Property ;
    rdfs:label 'Actual Closeout Date' ;
    rdfs:comment 'The actual date on which the punch list was fully closed, indicating all items have been resolved and accepted. Nullable until closure is achieved.' ;
    rdfs:domain ind:PunchList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:closedItemsCount rdf:type rdf:Property ;
    rdfs:label 'Closed Items Count' ;
    rdfs:comment 'The current count of punch list items that have been resolved and closed. Indicates progress toward full punch list closure.' ;
    rdfs:domain ind:PunchList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dlpCommencementGate rdf:type rdf:Property ;
    rdfs:label 'Dlp Commencement Gate' ;
    rdfs:comment 'Boolean flag indicating whether closure of this punch list triggers the start of the Defects Liability Period (DLP). True means DLP clock starts upon punch list closure.' ;
    rdfs:domain ind:PunchList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:handoverGate rdf:type rdf:Property ;
    rdfs:label 'Handover Gate' ;
    rdfs:comment 'Boolean flag indicating whether closure of this punch list is a contractual gate for project handover. True means handover cannot proceed until this list is closed.' ;
    rdfs:domain ind:PunchList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:openItemsCount rdf:type rdf:Property ;
    rdfs:label 'Open Items Count' ;
    rdfs:comment 'The current count of punch list items that remain open or unresolved. Used to track progress toward close-out.' ;
    rdfs:domain ind:PunchList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:projectArea rdf:type rdf:Property ;
    rdfs:label 'Project Area' ;
    rdfs:comment 'The physical area, zone, building, or section of the project to which this punch list applies (e.g., \'Building A\', \'Zone 3\', \'East Wing\', \'Substation 2\').' ;
    rdfs:domain ind:PunchList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:punchListName rdf:type rdf:Property ;
    rdfs:label 'Punch List Name' ;
    rdfs:comment 'Descriptive name or title for the punch list, often indicating the milestone, area, or phase it relates to (e.g., \'Mechanical Completion - Building A\', \'Practical Completion - Zone 3\').' ;
    rdfs:domain ind:PunchList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:punchListNumber rdf:type rdf:Property ;
    rdfs:label 'Punch List Number' ;
    rdfs:comment 'Business identifier for the punch list, typically a human-readable code or number used for tracking and reference in project documentation and handover processes.' ;
    rdfs:domain ind:PunchList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsiblePartyType rdf:type rdf:Property ;
    rdfs:label 'Responsible Party Type' ;
    rdfs:comment 'Classification of the party responsible for punch list resolution. Helps route accountability and track performance by party type.' ;
    rdfs:domain ind:PunchList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetCloseoutDate rdf:type rdf:Property ;
    rdfs:label 'Target Closeout Date' ;
    rdfs:comment 'The planned or contractually required date by which all items on the punch list must be resolved and the list closed. Critical for handover and DLP (Defects Liability Period) commencement.' ;
    rdfs:domain ind:PunchList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:totalItemsCount rdf:type rdf:Property ;
    rdfs:label 'Total Items Count' ;
    rdfs:comment 'The total number of punch list items (defects, incomplete works, commissioning tasks) recorded on this punch list.' ;
    rdfs:domain ind:PunchList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:creationDate rdf:type rdf:Property ;
    rdfs:label 'Creation Date' ;
    rdfs:comment 'The date on which the punch list was initially created or issued. Marks the start of the close-out tracking process for the associated milestone.' ;
    rdfs:domain ind:PunchList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qualitySubmittalId rdf:type rdf:Property ;
    rdfs:label 'Quality Submittal Id' ;
    rdfs:comment 'Unique identifier for the quality submittal record. Primary key.' ;
    rdfs:domain ind:QualitySubmittal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualReviewDays rdf:type rdf:Property ;
    rdfs:label 'Actual Review Days' ;
    rdfs:comment 'Actual number of days taken to complete the review from submission to disposition. Used for performance tracking and schedule impact analysis.' ;
    rdfs:domain ind:QualitySubmittal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approvalCode rdf:type rdf:Property ;
    rdfs:label 'Approval Code' ;
    rdfs:comment 'Standard approval code indicating the disposition: A=Approved, B=Approved with Comments, C=Approved as Noted, D=Rejected, E=Resubmit, R=For Review Only. Industry-standard coding per AIA and FIDIC practices.' ;
    rdfs:domain ind:QualitySubmittal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractorResponse rdf:type rdf:Property ;
    rdfs:label 'Contractor Response' ;
    rdfs:comment 'Contractors response to reviewer comments, including actions taken, clarifications provided, or justification for resubmission.' ;
    rdfs:domain ind:QualitySubmittal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractualReviewDays rdf:type rdf:Property ;
    rdfs:label 'Contractual Review Days' ;
    rdfs:comment 'Number of calendar or working days allowed per contract for the review and return of submittals. Used to monitor compliance with contract terms.' ;
    rdfs:domain ind:QualitySubmittal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:finalApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Final Approval Date' ;
    rdfs:comment 'Date when the submittal received final approval and was cleared for procurement or construction use.' ;
    rdfs:domain ind:QualitySubmittal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:manufacturerModelNumber rdf:type rdf:Property ;
    rdfs:label 'Manufacturer Model Number' ;
    rdfs:comment 'Specific model number, catalog number, or product code from the manufacturer identifying the exact product being submitted.' ;
    rdfs:domain ind:QualitySubmittal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Resubmission Date' ;
    rdfs:comment 'Date when the revised submittal was resubmitted following initial review comments or rejection.' ;
    rdfs:domain ind:QualitySubmittal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:resubmissionRequired rdf:type rdf:Property ;
    rdfs:label 'Resubmission Required' ;
    rdfs:comment 'Flag indicating whether the submittal must be revised and resubmitted for further review based on reviewer comments or rejection.' ;
    rdfs:domain ind:QualitySubmittal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reviewCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Review Completion Date' ;
    rdfs:comment 'Date when the review was completed and the submittal disposition was communicated back to the contractor.' ;
    rdfs:domain ind:QualitySubmittal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reviewPriority rdf:type rdf:Property ;
    rdfs:label 'Review Priority' ;
    rdfs:comment 'Priority level assigned to the submittal review based on schedule criticality and impact on construction progress.' ;
    rdfs:domain ind:QualitySubmittal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewStartDate rdf:type rdf:Property ;
    rdfs:label 'Review Start Date' ;
    rdfs:comment 'Date when the formal review process began. Used to track review duration and compliance with contractual review periods.' ;
    rdfs:domain ind:QualitySubmittal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reviewerOrganization rdf:type rdf:Property ;
    rdfs:label 'Reviewer Organization' ;
    rdfs:comment 'Organization or company name of the reviewing party (e.g., design consultant, client representative, third-party inspector).' ;
    rdfs:domain ind:QualitySubmittal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submittalDescription rdf:type rdf:Property ;
    rdfs:label 'Submittal Description' ;
    rdfs:comment 'Detailed description of the submittal content, scope, and purpose. Provides context for reviewers on what is being submitted and why.' ;
    rdfs:domain ind:QualitySubmittal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testCertificateId rdf:type rdf:Property ;
    rdfs:label 'Test Certificate Id' ;
    rdfs:comment 'Primary key for test_certificate' ;
    rdfs:domain ind:TestCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deliveryLotNumber rdf:type rdf:Property ;
    rdfs:label 'Delivery Lot Number' ;
    rdfs:comment 'Delivery or shipment lot number identifying the specific material consignment from which the sample was taken. Links certificate to goods receipt.' ;
    rdfs:domain ind:TestCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:heatNumber rdf:type rdf:Property ;
    rdfs:label 'Heat Number' ;
    rdfs:comment 'Steel mill heat number for steel and rebar materials, identifying the specific furnace melt. Essential for metallurgical traceability.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingLaboratory rdf:type rdf:Property ;
    rdfs:label 'Issuing Laboratory' ;
    rdfs:comment 'Name of the testing laboratory or organization that performed the tests and issued the certificate.' ;
    rdfs:domain ind:TestCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:passFailStatus rdf:type rdf:Property ;
    rdfs:label 'Pass Fail Status' ;
    rdfs:comment 'Overall determination of whether the tested material meets the specification requirements. Conditional pass indicates minor deviations requiring engineering review.' ;
    rdfs:domain ind:TestCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testParameters rdf:type rdf:Property ;
    rdfs:label 'Test Parameters' ;
    rdfs:comment 'List of specific properties or characteristics measured during testing (e.g., compressive strength, yield strength, elongation, gradation, moisture content). Stored as structured text or JSON.' ;
    rdfs:domain ind:TestCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testResults rdf:type rdf:Property ;
    rdfs:label 'Test Results' ;
    rdfs:comment 'Measured values and outcomes for each test parameter. Stored as structured text or JSON containing parameter-value pairs with units.' ;
    rdfs:domain ind:TestCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:weldRecordId rdf:type rdf:Property ;
    rdfs:label 'Weld Record Id' ;
    rdfs:comment 'Unique identifier for the weld record. Primary key for weld inspection and traceability documentation.' ;
    rdfs:domain ind:WeldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:acceptanceStandard rdf:type rdf:Property ;
    rdfs:label 'Acceptance Standard' ;
    rdfs:comment 'Industry code or standard against which the weld quality is evaluated. Defines acceptance criteria for defects, dimensions, and mechanical properties.' ;
    rdfs:domain ind:WeldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baseMaterialGrade rdf:type rdf:Property ;
    rdfs:label 'Base Material Grade' ;
    rdfs:comment 'Material specification and grade of the base metal being welded. Critical for ensuring compatibility with welding procedures and filler materials.' ;
    rdfs:domain ind:WeldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fillerMaterialGrade rdf:type rdf:Property ;
    rdfs:label 'Filler Material Grade' ;
    rdfs:comment 'Specification and grade of the welding consumable (electrode, wire, or rod) used to create the weld joint.' ;
    rdfs:domain ind:WeldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interpassTemperatureC rdf:type rdf:Property ;
    rdfs:label 'Interpass Temperature C' ;
    rdfs:comment 'Maximum temperature maintained between weld passes, measured in degrees Celsius. Controls cooling rate and prevents overheating.' ;
    rdfs:domain ind:WeldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:jointType rdf:type rdf:Property ;
    rdfs:label 'Joint Type' ;
    rdfs:comment 'Classification of the weld joint configuration based on the geometry and orientation of the components being joined. [ENUM-REF-CANDIDATE: butt|fillet|corner|edge|lap|plug|slot|tee — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:WeldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialThicknessMm rdf:type rdf:Property ;
    rdfs:label 'Material Thickness Mm' ;
    rdfs:comment 'Thickness of the base material being welded, measured in millimeters. Influences welding parameters and inspection requirements.' ;
    rdfs:domain ind:WeldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ndtDate rdf:type rdf:Property ;
    rdfs:label 'Ndt Date' ;
    rdfs:comment 'Date on which the NDT inspection was performed. Must occur after weld execution date.' ;
    rdfs:domain ind:WeldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ndtInspectorCertification rdf:type rdf:Property ;
    rdfs:label 'Ndt Inspector Certification' ;
    rdfs:comment 'Certification number of the NDT inspector verifying their qualification level and authorization to perform the specified NDT method.' ;
    rdfs:domain ind:WeldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ndtInspectorName rdf:type rdf:Property ;
    rdfs:label 'Ndt Inspector Name' ;
    rdfs:comment 'Full name of the certified NDT inspector who performed the inspection. Required for traceability and accountability.' ;
    rdfs:domain ind:WeldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ndtReportNumber rdf:type rdf:Property ;
    rdfs:label 'Ndt Report Number' ;
    rdfs:comment 'Unique identifier for the NDT inspection report documenting the test method, results, and inspector certification.' ;
    rdfs:domain ind:WeldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ndtResult rdf:type rdf:Property ;
    rdfs:label 'Ndt Result' ;
    rdfs:comment 'Outcome of the NDT inspection indicating whether the weld meets acceptance criteria or requires remediation.' ;
    rdfs:domain ind:WeldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preheatTemperatureC rdf:type rdf:Property ;
    rdfs:label 'Preheat Temperature C' ;
    rdfs:comment 'Temperature to which the base material was preheated before welding, measured in degrees Celsius. Required for certain materials to prevent cracking.' ;
    rdfs:domain ind:WeldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pwhtCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Pwht Completion Date' ;
    rdfs:comment 'Date on which post-weld heat treatment was completed. Null if PWHT was not required or not yet performed.' ;
    rdfs:domain ind:WeldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pwhtRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Pwht Required Flag' ;
    rdfs:comment 'Indicates whether post-weld heat treatment is required per the WPS or material specification. True if PWHT is mandatory, False otherwise.' ;
    rdfs:domain ind:WeldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:qcApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Qc Approval Date' ;
    rdfs:comment 'Date on which the QC inspector approved the weld record and certified that it meets all acceptance criteria.' ;
    rdfs:domain ind:WeldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qcInspectorName rdf:type rdf:Property ;
    rdfs:label 'Qc Inspector Name' ;
    rdfs:comment 'Full name of the internal QC inspector who verified and approved the weld record. Responsible for final quality sign-off.' ;
    rdfs:domain ind:WeldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reworkCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Rework Completion Date' ;
    rdfs:comment 'Date on which any required rework or repair of the weld was completed. Null if no rework was required.' ;
    rdfs:domain ind:WeldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reworkRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Rework Required Flag' ;
    rdfs:comment 'Indicates whether the weld requires repair, grinding, or re-welding to meet acceptance criteria. True if rework is needed, False if weld is acceptable as-is.' ;
    rdfs:domain ind:WeldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:weldDate rdf:type rdf:Property ;
    rdfs:label 'Weld Date' ;
    rdfs:comment 'Date on which the welding activity was performed. Principal business event timestamp for the weld record lifecycle.' ;
    rdfs:domain ind:WeldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:weldLengthMm rdf:type rdf:Property ;
    rdfs:label 'Weld Length Mm' ;
    rdfs:comment 'Total length of the weld seam measured in millimeters. Used for production tracking and inspection planning.' ;
    rdfs:domain ind:WeldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:weldPosition rdf:type rdf:Property ;
    rdfs:label 'Weld Position' ;
    rdfs:comment 'Spatial orientation of the weld joint during welding. Positions are classified per AWS standards (1G through 6G for pipe, or flat/horizontal/vertical/overhead for plate). [ENUM-REF-CANDIDATE: 1G|2G|3G|4G|5G|6G|flat|horizontal|vertical|overhead — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:WeldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:weldType rdf:type rdf:Property ;
    rdfs:label 'Weld Type' ;
    rdfs:comment 'Welding process method used: SMAW (Shielded Metal Arc Welding), GMAW (Gas Metal Arc Welding), GTAW (Gas Tungsten Arc Welding), FCAW (Flux-Cored Arc Welding), SAW (Submerged Arc Welding), PAW (Plasma Arc Welding).' ;
    rdfs:domain ind:WeldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:welderStamp rdf:type rdf:Property ;
    rdfs:label 'Welder Stamp' ;
    rdfs:comment 'Unique stamp or mark applied by the welder to identify their work on the physical weld joint. Provides field-level traceability.' ;
    rdfs:domain ind:WeldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wpsNumber rdf:type rdf:Property ;
    rdfs:label 'Wps Number' ;
    rdfs:comment 'Reference to the approved Welding Procedure Specification that governs the welding parameters, techniques, and materials for this weld. Ensures compliance with qualified welding procedures.' ;
    rdfs:domain ind:WeldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wqcNumber rdf:type rdf:Property ;
    rdfs:label 'Wqc Number' ;
    rdfs:comment 'Certificate number of the qualified welder who performed the weld. Verifies that the welder is certified and authorized to perform welding under the specified WPS.' ;
    rdfs:domain ind:WeldRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chemicalRegisterId rdf:type rdf:Property ;
    rdfs:label 'Chemical Register Id' ;
    rdfs:comment 'System-generated unique identifier for each chemical register record.' ;
    rdfs:domain ind:ChemicalRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hazardRegisterId rdf:type rdf:Property ;
    rdfs:label 'Hazard Register Id' ;
    rdfs:comment 'Foreign key linking to safety.hazard_register. Business justification: Chemical registers are tied to hazards they address; linking to hazard_register creates a direct relationship for hazard-chemical mapping.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:HazardRegister .

ind:chemicalFamily rdf:type rdf:Property ;
    rdfs:label 'Chemical Family' ;
    rdfs:comment 'Broad chemical family or class (e.g., solvents, acids, bases).' ;
    rdfs:domain ind:ChemicalRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chemicalName rdf:type rdf:Property ;
    rdfs:label 'Chemical Name' ;
    rdfs:comment 'Common or trade name of the hazardous chemical.' ;
    rdfs:domain ind:ChemicalRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chemicalRegisterStatus rdf:type rdf:Property ;
    rdfs:label 'Chemical Register Status' ;
    rdfs:comment 'Current lifecycle status of the chemical record.' ;
    rdfs:domain ind:ChemicalRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlMeasures rdf:type rdf:Property ;
    rdfs:label 'Control Measures' ;
    rdfs:comment 'Engineering or administrative controls applied to mitigate the chemical\'s hazards.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emergencyProcedure rdf:type rdf:Property ;
    rdfs:label 'Emergency Procedure' ;
    rdfs:comment 'Step-by-step actions to take in case of a spill, fire, or exposure.' ;
    rdfs:domain ind:ChemicalRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exposureLimitPle rdf:type rdf:Property ;
    rdfs:label 'Exposure Limit Ple' ;
    rdfs:comment 'Maximum time-weighted average exposure limit for an 8-hour workday, as defined by OSHA.' ;
    rdfs:domain ind:ChemicalRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exposureLimitTlv rdf:type rdf:Property ;
    rdfs:label 'Exposure Limit Tlv' ;
    rdfs:comment 'Recommended exposure limit for an 8-hour workday, as defined by ACGIH.' ;
    rdfs:domain ind:ChemicalRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exposureLimitUnit rdf:type rdf:Property ;
    rdfs:label 'Exposure Limit Unit' ;
    rdfs:comment 'Unit of measure for the exposure limits.' ;
    rdfs:domain ind:ChemicalRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ghsClassification rdf:type rdf:Property ;
    rdfs:label 'Ghs Classification' ;
    rdfs:comment 'GHS hazard classes and pictograms applicable to the chemical. [ENUM-REF-CANDIDATE: acute_toxicity|skin_corrosion|serious_eyes_damage|environmental_hazard|flammable|oxidizing|carcinogenic|reproductive_toxicity|specific_target_organs|hazardous_to_the_environment|other — promote to reference product]' ;
    rdfs:domain ind:ChemicalRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazardCategory rdf:type rdf:Property ;
    rdfs:label 'Hazard Category' ;
    rdfs:comment 'Broad category describing the type of hazard (e.g., toxic, flammable, corrosive). [ENUM-REF-CANDIDATE: toxic|flammable|corrosive|reactive|environmental|oxidizer|explosive|other — promote to reference product]' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazardStatement rdf:type rdf:Property ;
    rdfs:label 'Hazard Statement' ;
    rdfs:comment 'Standardized statement describing the nature of the hazard (e.g., H301).' ;
    rdfs:domain ind:ChemicalRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isQuantitiesVerified rdf:type rdf:Property ;
    rdfs:label 'Is Quantities Verified' ;
    rdfs:comment 'Indicates whether the on-site quantity has been physically verified.' ;
    rdfs:domain ind:ChemicalRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:manufacturerContact rdf:type rdf:Property ;
    rdfs:label 'Manufacturer Contact' ;
    rdfs:comment 'Primary email address for the chemical manufacturer or supplier.' ;
    rdfs:domain ind:ChemicalRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:precautionaryStatement rdf:type rdf:Property ;
    rdfs:label 'Precautionary Statement' ;
    rdfs:comment 'Standardized precautionary measures recommended for the chemical (e.g., P210).' ;
    rdfs:domain ind:ChemicalRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productCode rdf:type rdf:Property ;
    rdfs:label 'Product Code' ;
    rdfs:comment 'Internal catalogue or SKU code used by the organization to track the chemical.' ;
    rdfs:domain ind:ChemicalRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryComplianceStatus rdf:type rdf:Property ;
    rdfs:label 'Regulatory Compliance Status' ;
    rdfs:comment 'Current compliance status with OSHA Hazard Communication Standard and other applicable regulations.' ;
    rdfs:domain ind:ChemicalRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiredPpe rdf:type rdf:Property ;
    rdfs:label 'Required Ppe' ;
    rdfs:comment 'PPE items that must be worn when handling the chemical (e.g., gloves, goggles, respirator).' ;
    rdfs:domain ind:ChemicalRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sdsDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Sds Document Reference' ;
    rdfs:comment 'Reference (e.g., file path or document ID) to the current SDS for the chemical.' ;
    rdfs:domain ind:ChemicalRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sdsLastUpdated rdf:type rdf:Property ;
    rdfs:label 'Sds Last Updated' ;
    rdfs:comment 'Date when the SDS was last reviewed or revised.' ;
    rdfs:domain ind:ChemicalRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sdsVersion rdf:type rdf:Property ;
    rdfs:label 'Sds Version' ;
    rdfs:comment 'Version number or revision identifier of the SDS.' ;
    rdfs:domain ind:ChemicalRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageTemperatureC rdf:type rdf:Property ;
    rdfs:label 'Storage Temperature C' ;
    rdfs:comment 'Recommended storage temperature range in degrees Celsius.' ;
    rdfs:domain ind:ChemicalRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:environmentalMonitoringId rdf:type rdf:Property ;
    rdfs:label 'Environmental Monitoring Id' ;
    rdfs:comment 'Primary key for environmental_monitoring' ;
    rdfs:domain ind:EnvironmentalMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:correctiveActionReference rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Reference' ;
    rdfs:comment 'Reference number of the corrective action record raised in Intelex HSE management system in response to this monitoring exceedance. Provides traceability between the environmental measurement and the remediation workflow.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:detectionLimit rdf:type rdf:Property ;
    rdfs:label 'Detection Limit' ;
    rdfs:comment 'The minimum detection limit (MDL) of the instrument or analytical method for this parameter, expressed in the same unit as measurement_value. Used to contextualise results flagged as \'below_detection_limit\' and for regulatory reporting of non-detects.' ;
    rdfs:domain ind:EnvironmentalMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exceedanceMagnitude rdf:type rdf:Property ;
    rdfs:label 'Exceedance Magnitude' ;
    rdfs:comment 'The absolute difference between the measured value and the threshold limit when an exceedance is detected. Null when exceedance_flag is False. Used to prioritise severity of environmental non-compliance and escalation response.' ;
    rdfs:domain ind:EnvironmentalMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:instrumentCalibrationDate rdf:type rdf:Property ;
    rdfs:label 'Instrument Calibration Date' ;
    rdfs:comment 'The date on which the monitoring instrument was last calibrated prior to this measurement. Used to verify that measurements were taken with a calibrated instrument within the required calibration interval, supporting regulatory defensibility.' ;
    rdfs:domain ind:EnvironmentalMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:instrumentCalibrationDueDate rdf:type rdf:Property ;
    rdfs:label 'Instrument Calibration Due Date' ;
    rdfs:comment 'The date by which the monitoring instrument must next be calibrated to remain within its valid calibration period. Measurements taken after this date may be flagged as non-compliant for regulatory reporting purposes.' ;
    rdfs:domain ind:EnvironmentalMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:instrumentCode rdf:type rdf:Property ;
    rdfs:label 'Instrument Code' ;
    rdfs:comment 'Unique identifier or asset tag of the instrument, sensor, or analyser used to take the measurement (e.g., dust monitor serial number, noise meter ID, water quality probe ID). Supports instrument calibration traceability and equipment maintenance records.' ;
    rdfs:domain ind:EnvironmentalMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:instrumentType rdf:type rdf:Property ;
    rdfs:label 'Instrument Type' ;
    rdfs:comment 'Classification of the instrument or sensor type used for the measurement (e.g., \'Dust Monitor\', \'Sound Level Meter\', \'Vibration Meter\', \'Multi-parameter Water Quality Probe\', \'Gas Analyser\'). Used for equipment management and calibration scheduling. [ENUM-REF-CANDIDATE: dust_monitor|sound_level_meter|vibration_meter|water_quality_probe|gas_analyser|turbidimeter|pH_meter|portable_gas_detector — promote to reference product]' ;
    rdfs:domain ind:EnvironmentalMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:laboratoryReportNumber rdf:type rdf:Property ;
    rdfs:label 'Laboratory Report Number' ;
    rdfs:comment 'The unique report or chain-of-custody number issued by the analytical laboratory for the sample analysis. Provides traceability from the field sample to the laboratory result and supports regulatory audit documentation.' ;
    rdfs:domain ind:EnvironmentalMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementTimestamp rdf:type rdf:Property ;
    rdfs:label 'Measurement Timestamp' ;
    rdfs:comment 'The exact date and time at which the environmental measurement or reading was taken in the field. This is the principal real-world event time, distinct from record creation audit timestamps. Stored in ISO 8601 format with timezone offset.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:measurementValue rdf:type rdf:Property ;
    rdfs:label 'Measurement Value' ;
    rdfs:comment 'The numeric reading or measured value recorded for the environmental parameter at the monitoring location and timestamp. This is the principal quantitative observation for this record. Precision to 6 decimal places to accommodate trace-level contaminant readings.' ;
    rdfs:domain ind:EnvironmentalMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:monitoringLocationCode rdf:type rdf:Property ;
    rdfs:label 'Monitoring Location Code' ;
    rdfs:comment 'Unique alphanumeric code identifying the designated monitoring point or station as defined in the environmental monitoring plan or permit. Used as the externally-known identifier in regulatory submissions and Intelex records.' ;
    rdfs:domain ind:EnvironmentalMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monitoringLocationName rdf:type rdf:Property ;
    rdfs:label 'Monitoring Location Name' ;
    rdfs:comment 'Descriptive name or label of the specific monitoring point or station where the measurement was taken (e.g., \'North Perimeter Fence Line\', \'Discharge Point DP-01\', \'Borehole BH-03\'). Used in permit compliance reports and environmental monitoring plans.' ;
    rdfs:domain ind:EnvironmentalMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monitoringMethod rdf:type rdf:Property ;
    rdfs:label 'Monitoring Method' ;
    rdfs:comment 'The analytical or measurement method used to obtain the reading (e.g., EPA Method 40 CFR Part 50, ISO 10523 for pH, AS/NZS 4360 for noise). Ensures traceability and regulatory defensibility of measurement results.' ;
    rdfs:domain ind:EnvironmentalMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monitoringParameter rdf:type rdf:Property ;
    rdfs:label 'Monitoring Parameter' ;
    rdfs:comment 'The specific environmental parameter being measured at this monitoring point (e.g., PM10, PM2.5, NO2, SO2, noise level dB(A), vibration velocity, pH, turbidity, TSS, BOD, lead, arsenic). Aligned with EPA and ISO 14001 environmental monitoring parameter classifications. [ENUM-REF-CANDIDATE: PM10|PM2.5|NO2|SO2|CO|noise_dba|vibration_velocity|pH|turbidity|TSS|BOD|COD|lead|arsenic|benzene|TPH — promote to reference product]' ;
    rdfs:domain ind:EnvironmentalMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monitoringRecordStatus rdf:type rdf:Property ;
    rdfs:label 'Monitoring Record Status' ;
    rdfs:comment 'Current workflow status of the environmental monitoring record within the Intelex HSE management system. Tracks the record through data entry, verification by the environmental manager, regulatory submission, and closure.' ;
    rdfs:domain ind:EnvironmentalMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monitoringReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Monitoring Reference Number' ;
    rdfs:comment 'Externally-known unique alphanumeric reference number assigned to this monitoring record, used in regulatory submissions, permit compliance reports, and Intelex HSE management system. Format: ENV-{SITE_CODE}-{SEQUENCE}.' ;
    rdfs:domain ind:EnvironmentalMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parameterCategory rdf:type rdf:Property ;
    rdfs:label 'Parameter Category' ;
    rdfs:comment 'High-level classification of the environmental monitoring parameter into the primary environmental media or impact category. Used for domain-level reporting and ISO 14001 environmental aspect categorisation.' ;
    rdfs:domain ind:EnvironmentalMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:permitReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Permit Reference Number' ;
    rdfs:comment 'The reference number of the environmental permit, consent, or licence under which this monitoring is required. Links the measurement to the specific regulatory instrument that mandates monitoring at this location for this parameter.' ;
    rdfs:domain ind:EnvironmentalMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatorNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Regulator Notification Date' ;
    rdfs:comment 'The date on which the exceedance or monitoring result was formally notified to the relevant regulatory authority. Null if reported_to_regulator is False. Used to verify compliance with permit notification timeframes.' ;
    rdfs:domain ind:EnvironmentalMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryStandardReference rdf:type rdf:Property ;
    rdfs:label 'Regulatory Standard Reference' ;
    rdfs:comment 'The specific regulatory standard, guideline, or code of practice that defines the threshold limit for this parameter (e.g., \'EPA NAAQS PM10 150 µg/m³ 24-hr\', \'OSHA PEL 1910.1000 Table Z-1\', \'ISO 14001:2015 Clause 9.1.1\'). Provides traceability for threshold values used in exceedance determination.' ;
    rdfs:domain ind:EnvironmentalMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportedToRegulator rdf:type rdf:Property ;
    rdfs:label 'Reported To Regulator' ;
    rdfs:comment 'Indicates whether this monitoring result (particularly exceedances) has been formally reported to the relevant regulatory authority (e.g., EPA, state environmental agency) as required by the environmental permit or applicable legislation.' ;
    rdfs:domain ind:EnvironmentalMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sampleDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Sample Duration Minutes' ;
    rdfs:comment 'The duration in minutes over which the sample or measurement was collected or averaged. Relevant for time-averaged parameters such as noise (LAeq), air quality (24-hour PM10), and vibration. Null for instantaneous grab samples.' ;
    rdfs:domain ind:EnvironmentalMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sampleType rdf:type rdf:Property ;
    rdfs:label 'Sample Type' ;
    rdfs:comment 'Indicates the sampling methodology used to obtain the measurement — whether it is a grab sample (instantaneous), composite sample (time-averaged), continuous real-time reading, passive diffusion sample, or integrated sample over a defined period. Affects interpretation of results.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thresholdLimit rdf:type rdf:Property ;
    rdfs:label 'Threshold Limit' ;
    rdfs:comment 'The maximum permissible value (or minimum, for parameters like pH) for the monitored parameter as defined by the applicable environmental permit, regulatory standard, or project-specific environmental management plan. Used to determine exceedance status.' ;
    rdfs:domain ind:EnvironmentalMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:thresholdType rdf:type rdf:Property ;
    rdfs:label 'Threshold Type' ;
    rdfs:comment 'Indicates whether the threshold limit represents a maximum permissible value, minimum required value, action level trigger, or alert level for the monitored parameter. Determines the logic used to evaluate exceedance.' ;
    rdfs:domain ind:EnvironmentalMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:windDirection rdf:type rdf:Property ;
    rdfs:label 'Wind Direction' ;
    rdfs:comment 'Cardinal or intercardinal wind direction at the time of measurement. Used in conjunction with wind speed for air quality dispersion analysis and to determine whether site activities are the source of elevated readings at downwind monitoring points. [ENUM-REF-CANDIDATE: N|NE|E|SE|S|SW|W|NW — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:EnvironmentalMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:windSpeedMs rdf:type rdf:Property ;
    rdfs:label 'Wind Speed Ms' ;
    rdfs:comment 'Wind speed in metres per second recorded at or near the monitoring location at the time of measurement. Critical contextual data for air quality and dust dispersion modelling and for assessing whether exceedances are attributable to site activities.' ;
    rdfs:domain ind:EnvironmentalMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:linkedIncidentId rdf:type rdf:Property ;
    rdfs:label 'Linked Incident Id' ;
    rdfs:comment 'Reference to an incident record in the Intelex HSE system that triggered or is associated with this hazard entry. Enables traceability between reactive incident data and proactive hazard management records.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Incident .

ind:actualClosureDate rdf:type rdf:Property ;
    rdfs:label 'Actual Closure Date' ;
    rdfs:comment 'Date on which the hazard was verified as eliminated or controlled to an acceptable residual risk level and the record was formally closed. Null if the hazard remains open or controlled.' ;
    rdfs:domain ind:HazardRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:affectedWorkersCount rdf:type rdf:Property ;
    rdfs:label 'Affected Workers Count' ;
    rdfs:comment 'Estimated number of workers potentially exposed to this hazard during normal site operations. Used for exposure assessment, risk prioritisation, and OSHA regulatory reporting.' ;
    rdfs:domain ind:HazardRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:controlMeasuresDescription rdf:type rdf:Property ;
    rdfs:label 'Control Measures Description' ;
    rdfs:comment 'Narrative description of all control measures currently in place to manage the hazard, including engineering controls, administrative procedures, PPE requirements, and permit conditions. Sourced from Intelex corrective actions and SWMS documentation.' ;
    rdfs:domain ind:HazardRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:environmentalAspect rdf:type rdf:Property ;
    rdfs:label 'Environmental Aspect' ;
    rdfs:comment 'Indicates whether this hazard also constitutes an environmental aspect with potential environmental impact (e.g., chemical spill risk, dust generation, noise pollution). True = environmental aspect present. Supports ISO 14001 environmental management integration.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hazardReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Hazard Reference Number' ;
    rdfs:comment 'Externally-known alphanumeric identifier assigned to the hazard record, used in HSE correspondence, toolbox meeting (TBM) briefings, and regulatory submissions. Sourced from Intelex HSE Management system.' ;
    rdfs:domain ind:HazardRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazardStatus rdf:type rdf:Property ;
    rdfs:label 'Hazard Status' ;
    rdfs:comment 'Current lifecycle status of the hazard record. open = identified but controls not yet fully implemented; controlled = controls in place and residual risk is tolerable; eliminated = hazard has been fully removed; closed = record closed after verification. Drives the live hazard inventory for site visibility.' ;
    rdfs:domain ind:HazardRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazardTitle rdf:type rdf:Property ;
    rdfs:label 'Hazard Title' ;
    rdfs:comment 'Short, human-readable title describing the hazard (e.g., \'Unguarded floor opening — Level 3\', \'Overhead power line proximity — Zone B\'). Used in pre-start briefings and toolbox meeting topic selection.' ;
    rdfs:domain ind:HazardRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazardType rdf:type rdf:Property ;
    rdfs:label 'Hazard Type' ;
    rdfs:comment 'Classification of the hazard by primary injury mechanism aligned with OSHA Fatal Four and construction industry taxonomy. Values: fall (working at height), struck_by (moving objects/vehicles), caught_between (pinch/crush points), electrocution (electrical contact), excavation_collapse (trench/shoring failure), chemical_exposure (hazardous substances). [ENUM-REF-CANDIDATE: fall|struck_by|caught_between|electrocution|excavation_collapse|chemical_exposure|fire_explosion|noise|manual_handling|biological — promote to reference product]' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hierarchyOfControls rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Of Controls' ;
    rdfs:comment 'Highest level of the hierarchy of controls applied to manage this hazard, per ISO 45001 and OSHA guidance. Values: elimination (remove hazard), substitution (replace with lesser hazard), engineering (physical barriers/guards), administrative (procedures/training), ppe (Personal Protective Equipment). Drives control effectiveness assessment.' ;
    rdfs:domain ind:HazardRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:identificationSource rdf:type rdf:Property ;
    rdfs:label 'Identification Source' ;
    rdfs:comment 'The originating activity or process through which the hazard was identified. Supports root-cause analysis and evaluation of hazard identification program effectiveness. Values: risk_assessment, inspection, incident, audit, near_miss, worker_report.' ;
    rdfs:domain ind:HazardRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initialConsequenceRating rdf:type rdf:Property ;
    rdfs:label 'Initial Consequence Rating' ;
    rdfs:comment 'Numeric consequence/severity score assigned during initial risk assessment before controls are applied, typically on a 1–5 scale (1=Insignificant, 5=Catastrophic). Component of the initial risk rating matrix (likelihood × consequence).' ;
    rdfs:domain ind:HazardRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:initialLikelihoodRating rdf:type rdf:Property ;
    rdfs:label 'Initial Likelihood Rating' ;
    rdfs:comment 'Numeric likelihood score assigned during initial risk assessment before controls are applied, typically on a 1–5 scale (1=Rare, 5=Almost Certain). Component of the initial risk rating matrix (likelihood × consequence).' ;
    rdfs:domain ind:HazardRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:initialRiskLevel rdf:type rdf:Property ;
    rdfs:label 'Initial Risk Level' ;
    rdfs:comment 'Qualitative risk band derived from the initial risk score (e.g., low, medium, high, critical). Used for risk prioritisation, escalation thresholds, and executive HSE dashboards.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initialRiskScore rdf:type rdf:Property ;
    rdfs:label 'Initial Risk Score' ;
    rdfs:comment 'Pre-control risk score calculated as the product of initial_likelihood_rating × initial_consequence_rating. Represents the inherent risk level before any control measures are applied. Used to prioritise hazard treatment actions.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:intelexRecordReference rdf:type rdf:Property ;
    rdfs:label 'Intelex Record Reference' ;
    rdfs:comment 'Source system record identifier from the Intelex HSE Management platform. Used for data lineage, reconciliation, and bi-directional synchronisation between the Databricks Silver layer and the operational Intelex system.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:permitToWorkRequired rdf:type rdf:Property ;
    rdfs:label 'Permit To Work Required' ;
    rdfs:comment 'Indicates whether a Permit to Work (PTW) is mandatory before any work activity associated with this hazard can commence. True = PTW required (e.g., confined space entry, hot work, electrical isolation). Integrates with Intelex Permit to Work module.' ;
    rdfs:domain ind:HazardRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ppeRequirements rdf:type rdf:Property ;
    rdfs:label 'Ppe Requirements' ;
    rdfs:comment 'Specific PPE items mandated for workers operating in proximity to this hazard (e.g., \'Hard hat, safety harness, hi-vis vest, safety glasses\'). Supports PPE compliance checks during pre-start briefings and site inspections.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryNotificationRequired rdf:type rdf:Property ;
    rdfs:label 'Regulatory Notification Required' ;
    rdfs:comment 'Indicates whether this hazard requires formal notification to a regulatory authority (e.g., OSHA, EPA) due to its nature or severity. True = notification required. Supports regulatory compliance workflow management.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:residualConsequenceRating rdf:type rdf:Property ;
    rdfs:label 'Residual Consequence Rating' ;
    rdfs:comment 'Numeric consequence/severity score after all control measures have been applied, on the same 1–5 scale as initial_consequence_rating. Reflects the effectiveness of controls in reducing severity of potential harm.' ;
    rdfs:domain ind:HazardRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:residualLikelihoodRating rdf:type rdf:Property ;
    rdfs:label 'Residual Likelihood Rating' ;
    rdfs:comment 'Numeric likelihood score after all control measures have been applied, on the same 1–5 scale as initial_likelihood_rating. Reflects the effectiveness of controls in reducing probability of harm.' ;
    rdfs:domain ind:HazardRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:residualRiskLevel rdf:type rdf:Property ;
    rdfs:label 'Residual Risk Level' ;
    rdfs:comment 'Qualitative risk band derived from the residual risk score after controls are applied. Determines whether the hazard is tolerable (low/medium) or requires escalation and further treatment (high/critical).' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteZone rdf:type rdf:Property ;
    rdfs:label 'Site Zone' ;
    rdfs:comment 'Designated zone, area, or work front on the construction site where the hazard is located (e.g., \'Zone A — Excavation\', \'Level 4 — Formwork\', \'Laydown Area 2\'). Used for spatial hazard mapping and pre-start briefing targeting.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:swmsReference rdf:type rdf:Property ;
    rdfs:label 'Swms Reference' ;
    rdfs:comment 'Document reference number of the Safe Work Method Statement (SWMS) that addresses this hazard and its control measures. Links the hazard register to the SWMS document library in Aconex or Procore.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetClosureDate rdf:type rdf:Property ;
    rdfs:label 'Target Closure Date' ;
    rdfs:comment 'Target date by which the hazard is expected to be eliminated or reduced to a tolerable residual risk level. Used for corrective action scheduling and overdue hazard reporting.' ;
    rdfs:domain ind:HazardRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:tbmTopicFlag rdf:type rdf:Property ;
    rdfs:label 'Tbm Topic Flag' ;
    rdfs:comment 'Indicates whether this hazard has been selected or is recommended as a topic for an upcoming Toolbox Meeting (TBM). True = flagged for TBM discussion. Supports automated TBM topic selection from the live hazard register.' ;
    rdfs:domain ind:HazardRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hseInspectionId rdf:type rdf:Property ;
    rdfs:label 'Hse Inspection Id' ;
    rdfs:comment 'Unique system-generated identifier for each HSE inspection record. Primary key for the hse_inspection data product. Entity role: TRANSACTION_HEADER — represents a discrete field inspection event with a defined lifecycle.' ;
    rdfs:domain ind:HseInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hsePlanId rdf:type rdf:Property ;
    rdfs:label 'Hse Plan Id' ;
    rdfs:comment 'Foreign key linking to safety.hse_plan. Business justification: HSE inspection evaluates the HSE plan; adding a FK provides direct navigation from inspection to the plan it reviews.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:HsePlan .

ind:primaryHseEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Hse Employee Id' ;
    rdfs:comment 'Reference to the HSE officer, supervisor, or manager who conducted the inspection. Enables inspector workload tracking, competency verification, and accountability reporting. PARTY_REFERENCE category.' ;
    rdfs:domain ind:HseInspection ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:criticalDeficiencyCount rdf:type rdf:Property ;
    rdfs:label 'Critical Deficiency Count' ;
    rdfs:comment 'Number of deficiencies classified as critical or high severity — those posing immediate risk to life, health, or structural integrity. Triggers mandatory stop-work authority and escalation protocols.' ;
    rdfs:domain ind:HseInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deficiencyCount rdf:type rdf:Property ;
    rdfs:label 'Deficiency Count' ;
    rdfs:comment 'Total number of distinct deficiencies or non-conformances identified during the inspection. Each deficiency may link to a corrective action record for remediation tracking.' ;
    rdfs:domain ind:HseInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:drillEvacuationComplete rdf:type rdf:Property ;
    rdfs:label 'Drill Evacuation Complete' ;
    rdfs:comment 'Indicates whether all personnel in the drill area were successfully evacuated and accounted for at the muster point during an emergency drill. Null for non-drill inspection types.' ;
    rdfs:domain ind:HseInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:drillMusterAccuracyPct rdf:type rdf:Property ;
    rdfs:label 'Drill Muster Accuracy Pct' ;
    rdfs:comment 'Percentage of expected personnel correctly accounted for at the designated muster point during an emergency drill. Expressed as a decimal percentage (e.g., 98.00 = 98%). Null for non-drill inspection types.' ;
    rdfs:domain ind:HseInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:drillResponseTimeSeconds rdf:type rdf:Property ;
    rdfs:label 'Drill Response Time Seconds' ;
    rdfs:comment 'Measured response time in seconds from drill initiation to full muster point assembly during an emergency drill exercise. Used to assess emergency preparedness against target response time benchmarks.' ;
    rdfs:domain ind:HseInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:drillType rdf:type rdf:Property ;
    rdfs:label 'Drill Type' ;
    rdfs:comment 'For inspections of type \'emergency_drill\', specifies the category of drill exercise conducted. Null for non-drill inspection types.' ;
    rdfs:domain ind:HseInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:generalObservations rdf:type rdf:Property ;
    rdfs:label 'General Observations' ;
    rdfs:comment 'Free-text field capturing the inspector\'s overall field observations, positive findings, and contextual notes not captured by structured checklist items. Supports qualitative safety culture assessment.' ;
    rdfs:domain ind:HseInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:highestDeficiencySeverity rdf:type rdf:Property ;
    rdfs:label 'Highest Deficiency Severity' ;
    rdfs:comment 'The most severe deficiency classification recorded during the inspection. Used for risk prioritisation, escalation routing, and executive safety dashboards.' ;
    rdfs:domain ind:HseInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:immediateActionDescription rdf:type rdf:Property ;
    rdfs:label 'Immediate Action Description' ;
    rdfs:comment 'Narrative description of any immediate corrective actions taken on site during the inspection to mitigate identified hazards or deficiencies before formal remediation.' ;
    rdfs:domain ind:HseInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:immediateActionTaken rdf:type rdf:Property ;
    rdfs:label 'Immediate Action Taken' ;
    rdfs:comment 'Indicates whether immediate corrective action was taken on site at the time of inspection to address identified deficiencies, prior to formal corrective action workflow initiation.' ;
    rdfs:domain ind:HseInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inspectionEndTime rdf:type rdf:Property ;
    rdfs:label 'Inspection End Time' ;
    rdfs:comment 'Precise date and time when the inspection was concluded on site. Combined with start time to derive inspection duration for workload and thoroughness analytics.' ;
    rdfs:domain ind:HseInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:inspectionStartTime rdf:type rdf:Property ;
    rdfs:label 'Inspection Start Time' ;
    rdfs:comment 'Precise date and time when the inspection commenced on site. Used for duration calculation and scheduling compliance verification.' ;
    rdfs:domain ind:HseInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:intelexInspectionRef rdf:type rdf:Property ;
    rdfs:label 'Intelex Inspection Ref' ;
    rdfs:comment 'Source system reference identifier from the Intelex HSE Management platform Inspections module. Enables traceability back to the operational system of record for audit and reconciliation purposes.' ;
    rdfs:domain ind:HseInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isScheduled rdf:type rdf:Property ;
    rdfs:label 'Is Scheduled' ;
    rdfs:comment 'Indicates whether the inspection was pre-planned and scheduled (True) or conducted on an ad-hoc/unannounced basis (False). Supports analysis of proactive vs reactive inspection activity.' ;
    rdfs:domain ind:HseInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:photoEvidenceCount rdf:type rdf:Property ;
    rdfs:label 'Photo Evidence Count' ;
    rdfs:comment 'Number of photographs attached to the inspection record as evidence of conditions observed, deficiencies identified, or positive practices noted. Supports dispute resolution and regulatory submissions.' ;
    rdfs:domain ind:HseInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:photoEvidenceReference rdf:type rdf:Property ;
    rdfs:label 'Photo Evidence Reference' ;
    rdfs:comment 'Document management system reference or folder path pointing to photographic evidence files associated with this inspection. Typically links to Aconex or Intelex document store.' ;
    rdfs:domain ind:HseInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ppeComplianceRate rdf:type rdf:Property ;
    rdfs:label 'Ppe Compliance Rate' ;
    rdfs:comment 'Percentage of workers observed wearing required Personal Protective Equipment (PPE) correctly at the time of inspection. Expressed as a decimal percentage (e.g., 95.50 = 95.5%). Key leading indicator for HSE performance dashboards.' ;
    rdfs:domain ind:HseInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:siteArea rdf:type rdf:Property ;
    rdfs:label 'Site Area' ;
    rdfs:comment 'Specific physical area, zone, or work front on the construction site where the inspection was conducted (e.g., Zone A – Excavation, Level 3 Formwork, North Laydown Yard). Enables spatial analysis of safety performance.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stopWorkIssued rdf:type rdf:Property ;
    rdfs:label 'Stop Work Issued' ;
    rdfs:comment 'Indicates whether a stop-work order was issued as a result of critical deficiencies identified during the inspection. Triggers immediate escalation and mandatory corrective action before work resumes.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:totalItemsChecked rdf:type rdf:Property ;
    rdfs:label 'Total Items Checked' ;
    rdfs:comment 'Total number of checklist line items assessed during the inspection. Used as the denominator for compliance rate calculations and inspection thoroughness metrics.' ;
    rdfs:domain ind:HseInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:workerCountObserved rdf:type rdf:Property ;
    rdfs:label 'Worker Count Observed' ;
    rdfs:comment 'Number of workers present in the inspected area at the time of the inspection. Used to contextualise exposure levels and normalise deficiency rates per worker.' ;
    rdfs:domain ind:HseInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:applicableRegulations rdf:type rdf:Property ;
    rdfs:label 'Applicable Regulations' ;
    rdfs:comment 'Comma-separated list of regulatory frameworks, standards, and governing body requirements applicable to this HSE Plan (e.g., OSHA 29 CFR 1926, ISO 45001:2018, ISO 14001:2015, NFPA 70E, local jurisdiction building codes). Drives compliance obligation tracking.' ;
    rdfs:domain ind:HsePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditFrequencyMonths rdf:type rdf:Property ;
    rdfs:label 'Audit Frequency Months' ;
    rdfs:comment 'Frequency in months at which formal HSE audits must be conducted on the project as specified in the HSE Plan. Drives the audit schedule in Intelex and ensures compliance with ISO 45001 internal audit requirements.' ;
    rdfs:domain ind:HsePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:clientHseRequirements rdf:type rdf:Property ;
    rdfs:label 'Client Hse Requirements' ;
    rdfs:comment 'Summary of client-specific HSE requirements and standards that must be incorporated into the project HSE Plan, beyond the contractor\'s standard requirements. Sourced from the contract HSE specification or client HSE management system.' ;
    rdfs:domain ind:HsePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:environmentalAspects rdf:type rdf:Property ;
    rdfs:label 'Environmental Aspects' ;
    rdfs:comment 'Description of the significant environmental aspects and impacts identified for the project (e.g., noise, dust, stormwater runoff, waste management, soil contamination, protected species). Informs the environmental management controls within the HSE Plan.' ;
    rdfs:domain ind:HsePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hseObjectiveDescription rdf:type rdf:Property ;
    rdfs:label 'Hse Objective Description' ;
    rdfs:comment 'Narrative description of the project-level HSE objectives and targets established for this plan period (e.g., zero LTI, TRIR below 0.5, 100% PPE compliance, zero environmental non-conformances). Aligns with corporate HSE KPI framework.' ;
    rdfs:domain ind:HsePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentReportingProcedure rdf:type rdf:Property ;
    rdfs:label 'Incident Reporting Procedure' ;
    rdfs:comment 'Description or document reference number for the incident reporting and investigation procedure defined in the HSE Plan. Specifies notification timelines, investigation requirements, and regulatory reporting obligations (e.g., OSHA 300 log, fatality notification within 8 hours).' ;
    rdfs:domain ind:HsePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inductionRequired rdf:type rdf:Property ;
    rdfs:label 'Induction Required' ;
    rdfs:comment 'Indicates whether all personnel must complete a formal site HSE induction before commencing work on the project, as mandated by the HSE Plan. When true, no worker may access the site without a valid induction record.' ;
    rdfs:domain ind:HsePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ltiTarget rdf:type rdf:Property ;
    rdfs:label 'Lti Target' ;
    rdfs:comment 'Target number of Lost Time Injuries (LTI) for the project duration as defined in the HSE Plan. Typically set to zero for major construction projects. Used as a benchmark for HSE performance reporting.' ;
    rdfs:domain ind:HsePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:musterPointDescription rdf:type rdf:Property ;
    rdfs:label 'Muster Point Description' ;
    rdfs:comment 'Description and location of the designated emergency assembly/muster point(s) for the construction site. Critical for emergency evacuation procedures and headcount verification.' ;
    rdfs:domain ind:HsePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nearestHospital rdf:type rdf:Property ;
    rdfs:label 'Nearest Hospital' ;
    rdfs:comment 'Name and address of the nearest hospital or medical facility to the construction site. Mandatory field for emergency response planning and first aid procedures documentation.' ;
    rdfs:domain ind:HsePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planTitle rdf:type rdf:Property ;
    rdfs:label 'Plan Title' ;
    rdfs:comment 'Official title of the HSE Plan document as it appears on the cover page and in the document register (e.g., \'Project HSE Management Plan — Highway 7 Extension\').' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ptwRequired rdf:type rdf:Property ;
    rdfs:label 'Ptw Required' ;
    rdfs:comment 'Indicates whether a formal Permit to Work (PTW) system is mandated on this project as per the HSE Plan. When true, designated high-risk activities (hot work, confined space entry, electrical isolation, working at height) require a PTW before commencement.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:siteSpecificHazards rdf:type rdf:Property ;
    rdfs:label 'Site Specific Hazards' ;
    rdfs:comment 'Narrative description of the key site-specific hazards identified for this project (e.g., working at height, confined spaces, high-voltage proximity, ground contamination, extreme weather, traffic management). Informs the risk control hierarchy documented in the plan.' ;
    rdfs:domain ind:HsePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subcontractorHseRequirements rdf:type rdf:Property ;
    rdfs:label 'Subcontractor Hse Requirements' ;
    rdfs:comment 'Description of the HSE requirements imposed on subcontractors working under this project HSE Plan, including pre-qualification criteria, SWMS submission requirements, induction obligations, and compliance monitoring expectations.' ;
    rdfs:domain ind:HsePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:swmsRequired rdf:type rdf:Property ;
    rdfs:label 'Swms Required' ;
    rdfs:comment 'Indicates whether Safe Work Method Statements (SWMS) are mandated for high-risk construction work activities on this project as per the HSE Plan. When true, SWMS must be prepared and approved before commencing designated high-risk activities.' ;
    rdfs:domain ind:HsePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tbmFrequency rdf:type rdf:Property ;
    rdfs:label 'Tbm Frequency' ;
    rdfs:comment 'Required frequency of Toolbox Meetings (TBM) as mandated by the HSE Plan. TBMs are pre-work safety briefings conducted with the workforce to communicate hazards, controls, and daily work instructions.' ;
    rdfs:domain ind:HsePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trirTarget rdf:type rdf:Property ;
    rdfs:label 'Trir Target' ;
    rdfs:comment 'Target Total Recordable Incident Rate (TRIR) for the project as defined in the HSE Plan. Expressed per 200,000 man-hours worked. Used as the primary lagging indicator for HSE performance benchmarking.' ;
    rdfs:domain ind:HsePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reporterContactId rdf:type rdf:Property ;
    rdfs:label 'Reporter Contact Id' ;
    rdfs:comment 'Foreign key linking to client.contact. Business justification: Incident logging captures the client contact who reported the event, enabling audit trails and follow-up communication.' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Contact .

ind:swmsId rdf:type rdf:Property ;
    rdfs:label 'Swms Id' ;
    rdfs:comment 'Reference to the Safe Work Method Statement (SWMS) applicable to the task being performed at the time of the incident. Used to assess whether the SWMS was adequate, followed, or requires revision as a corrective action.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Swms .

ind:bodyPartAffected rdf:type rdf:Property ;
    rdfs:label 'Body Part Affected' ;
    rdfs:comment 'Specific body part injured (e.g., right hand, lower back, left eye, head). Required field for OSHA 300 log and BLS injury classification. Supports ergonomic and PPE gap analysis. [ENUM-REF-CANDIDATE: head|eye|neck|back|shoulder|arm|hand|finger|leg|knee|foot|toe|multiple|other — promote to reference product]' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionCount rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Count' ;
    rdfs:comment 'Number of corrective actions raised against this incident. Provides a quick indicator of investigation depth and systemic response. Detailed corrective actions are tracked in the corrective_action product linked to this incident.' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:createdAt rdf:type rdf:Property ;
    rdfs:label 'Created At' ;
    rdfs:comment 'System audit timestamp recording when the incident record was first created in the data platform. Supports data lineage and Silver layer audit trail requirements.' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:daysAwayFromWork rdf:type rdf:Property ;
    rdfs:label 'Days Away From Work' ;
    rdfs:comment 'Number of calendar days the injured worker was away from work due to the incident, excluding the day of injury. Core component of the DART (Days Away, Restricted, or Transferred) rate calculation and OSHA 300 log column G.' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:daysRestrictedOrTransferred rdf:type rdf:Property ;
    rdfs:label 'Days Restricted Or Transferred' ;
    rdfs:comment 'Number of calendar days the injured worker was on restricted work duty or transferred to another job due to the incident. Combined with days_away_from_work to compute the DART (Days Away, Restricted, or Transferred) rate. Maps to OSHA 300 log column H.' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:environmentalMediaAffected rdf:type rdf:Property ;
    rdfs:label 'Environmental Media Affected' ;
    rdfs:comment 'Environmental media impacted by the incident (soil, groundwater, surface water, air). Populated only when is_environmental_event is true. Required for EPA reportable quantity determination and ISO 14001 environmental incident reporting.' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:immediateCause rdf:type rdf:Property ;
    rdfs:label 'Immediate Cause' ;
    rdfs:comment 'Direct, proximate cause of the incident as determined during initial investigation (e.g., struck by falling object, slip on wet surface, equipment malfunction, electrical contact). Supports causal pattern analysis.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentStatus rdf:type rdf:Property ;
    rdfs:label 'Incident Status' ;
    rdfs:comment 'Current lifecycle state of the incident record within the Intelex workflow. Drives investigation assignment, corrective action tracking, and regulatory notification obligations.' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentType rdf:type rdf:Property ;
    rdfs:label 'Incident Type' ;
    rdfs:comment 'Primary classification of the safety event (e.g., injury, near_miss, unsafe_condition, property_damage, environmental_event, dangerous_occurrence, behavioral_observation). Drives OSHA recordability determination and TRIR contribution. [ENUM-REF-CANDIDATE: injury|near_miss|unsafe_condition|property_damage|environmental_event|dangerous_occurrence|behavioral_observation — promote to reference product]' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:injuredPartyJobTitle rdf:type rdf:Property ;
    rdfs:label 'Injured Party Job Title' ;
    rdfs:comment 'Job title or trade classification of the injured party at the time of the incident (e.g., Ironworker, Electrician, Crane Operator). Used for occupational injury pattern analysis and targeted safety training.' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:injuredPartyName rdf:type rdf:Property ;
    rdfs:label 'Injured Party Name' ;
    rdfs:comment 'Full name of the person injured or involved in the incident. Required for OSHA 300 log, workers compensation claim, and medical case management. Classified as restricted PII.' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:injuredPartyType rdf:type rdf:Property ;
    rdfs:label 'Injured Party Type' ;
    rdfs:comment 'Classification of the person involved in the incident. Determines OSHA recordability scope (employees and supervised workers are recordable; visitors may not be). Affects workers compensation claim eligibility.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:injuryNature rdf:type rdf:Property ;
    rdfs:label 'Injury Nature' ;
    rdfs:comment 'Nature or type of the injury or illness sustained (e.g., laceration, fracture, sprain, burn, crush injury, chemical exposure, heat stress). Required for OSHA 300 log and BLS OIICS coding. [ENUM-REF-CANDIDATE: laceration|fracture|sprain_strain|burn|crush|chemical_exposure|heat_stress|contusion|amputation|other — promote to reference product]' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationCompletedDate rdf:type rdf:Property ;
    rdfs:label 'Investigation Completed Date' ;
    rdfs:comment 'Date on which the formal incident investigation was completed and root cause analysis finalized. Used to measure investigation cycle time compliance (typically 5–10 business days per HSE policy) and trigger corrective action issuance.' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:investigationLead rdf:type rdf:Property ;
    rdfs:label 'Investigation Lead' ;
    rdfs:comment 'Name or identifier of the HSE officer or supervisor assigned as lead investigator for the incident. Supports investigation accountability tracking and workload management within the HSE team.' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isEnvironmentalEvent rdf:type rdf:Property ;
    rdfs:label 'Is Environmental Event' ;
    rdfs:comment 'Indicates whether the incident involved an environmental impact such as a spill, release, or contamination event. Triggers EPA reporting obligations and ISO 14001 environmental management corrective action workflows.' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isFitForDuty rdf:type rdf:Property ;
    rdfs:label 'Is Fit For Duty' ;
    rdfs:comment 'Indicates whether the injured worker has been medically cleared for full unrestricted duty upon return to work. Prevents premature return to hazardous tasks and supports site access control decisions.' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isLti rdf:type rdf:Property ;
    rdfs:label 'Is Lti' ;
    rdfs:comment 'Indicates whether the incident resulted in at least one full calendar day away from work beyond the day of injury. LTI (Lost Time Injury) flag is the primary driver of LTIFR (Lost Time Injury Frequency Rate) calculations and executive safety KPI dashboards.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isOshaRecordable rdf:type rdf:Property ;
    rdfs:label 'Is Osha Recordable' ;
    rdfs:comment 'Indicates whether the incident meets OSHA recordability criteria under 29 CFR 1904.7 (medical treatment beyond first aid, days away, restricted work, job transfer, loss of consciousness, or diagnosis of a significant injury). Drives OSHA 300 log inclusion and TRIR calculation.' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:occurredAt rdf:type rdf:Property ;
    rdfs:label 'Occurred At' ;
    rdfs:comment 'The precise date and time the safety event occurred on site. Principal business event timestamp used for OSHA 300 log date, TRIR period attribution, and trend analysis. Distinct from the report creation timestamp.' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:ppeCompliance rdf:type rdf:Property ;
    rdfs:label 'Ppe Compliance' ;
    rdfs:comment 'Indicates whether the injured party was wearing required Personal Protective Equipment (PPE) at the time of the incident. Non-compliance is a key causal factor and triggers disciplinary and training corrective actions.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:propertyDamageAmount rdf:type rdf:Property ;
    rdfs:label 'Property Damage Amount' ;
    rdfs:comment 'Estimated monetary value of property, plant, or equipment damage resulting from the incident in USD. Used for insurance claim valuation, project cost impact reporting, and safety cost of poor quality (COPQ) analysis.' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatoryNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Regulatory Notification Date' ;
    rdfs:comment 'Date on which the regulatory authority (OSHA, EPA, or other) was formally notified of the incident. Used to verify compliance with mandatory notification timeframes and document regulatory correspondence.' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryNotificationStatus rdf:type rdf:Property ;
    rdfs:label 'Regulatory Notification Status' ;
    rdfs:comment 'Status of mandatory regulatory notification to OSHA or other governing bodies. OSHA requires fatality notification within 8 hours and inpatient hospitalization within 24 hours. Tracks compliance with notification deadlines.' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportedAt rdf:type rdf:Property ;
    rdfs:label 'Reported At' ;
    rdfs:comment 'Date and time the incident was formally reported and entered into the Intelex system. Used to measure reporting lag compliance (OSHA requires reporting of fatalities within 8 hours and hospitalizations within 24 hours).' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:returnToWorkDate rdf:type rdf:Property ;
    rdfs:label 'Return To Work Date' ;
    rdfs:comment 'Date the injured worker returned to full or modified duty following the incident. Used to calculate actual days away from work, close the LTI case, and update DART rate calculations. Triggers fitness-for-duty clearance workflow.' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rootCauseCategory rdf:type rdf:Property ;
    rdfs:label 'Root Cause Category' ;
    rdfs:comment 'High-level root cause category identified through formal investigation (e.g., inadequate_procedure, equipment_failure, human_error, environmental_condition, inadequate_supervision, training_deficiency). Drives systemic corrective action programs. [ENUM-REF-CANDIDATE: inadequate_procedure|equipment_failure|human_error|environmental_condition|inadequate_supervision|training_deficiency|design_deficiency — promote to reference product]' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shift rdf:type rdf:Property ;
    rdfs:label 'Shift' ;
    rdfs:comment 'Work shift during which the incident occurred (day, night, swing). Shift-based incident analysis identifies fatigue-related patterns and informs shift rotation and supervision scheduling decisions.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:treatingPhysician rdf:type rdf:Property ;
    rdfs:label 'Treating Physician' ;
    rdfs:comment 'Name of the physician or medical professional who provided treatment to the injured party. Required for OSHA 300 log and workers compensation case management. Classified as confidential due to medical case sensitivity.' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:treatmentType rdf:type rdf:Property ;
    rdfs:label 'Treatment Type' ;
    rdfs:comment 'Type of medical treatment provided to the injured party. Distinguishes first aid cases (non-recordable) from medical treatment cases (OSHA recordable). Drives case management workflow and workers compensation claim initiation.' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:updatedAt rdf:type rdf:Property ;
    rdfs:label 'Updated At' ;
    rdfs:comment 'System audit timestamp recording the most recent modification to the incident record. Used to detect stale investigations and track investigation progress velocity.' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:workersCompClaimRef rdf:type rdf:Property ;
    rdfs:label 'Workers Comp Claim Ref' ;
    rdfs:comment 'Reference number of the workers compensation insurance claim associated with this incident. Links the safety event record to the financial claims management system for cost tracking and insurance reporting.' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentInvestigationId rdf:type rdf:Property ;
    rdfs:label 'Incident Investigation Id' ;
    rdfs:comment 'Unique system-generated identifier for the incident investigation record. Primary key for this entity in the Databricks Silver Layer.' ;
    rdfs:domain ind:IncidentInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryIncidentEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Incident Employee Id' ;
    rdfs:comment 'Reference to the employee or Health Safety and Environment (HSE) professional designated as the lead investigator responsible for conducting and managing the investigation.' ;
    rdfs:domain ind:IncidentInvestigation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryIncidentApprovedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Incident Approved By Employee Id' ;
    rdfs:comment 'Reference to the manager or executive who formally approved and signed off the completed investigation report, confirming acceptance of findings and corrective actions.' ;
    rdfs:domain ind:IncidentInvestigation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:contributingFactors rdf:type rdf:Property ;
    rdfs:label 'Contributing Factors' ;
    rdfs:comment 'Narrative description of secondary factors that contributed to the incident, such as environmental conditions, equipment state, worker fatigue, or inadequate supervision. Supports multi-causal analysis.' ;
    rdfs:domain ind:IncidentInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionSummary rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Summary' ;
    rdfs:comment 'Summary description of the corrective and preventive actions recommended by the investigation team to address root causes and prevent recurrence. Detailed individual actions are tracked in the corrective action register.' ;
    rdfs:domain ind:IncidentInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentCategory rdf:type rdf:Property ;
    rdfs:label 'Incident Category' ;
    rdfs:comment 'High-level category of the incident type such as fall from height, struck-by, caught-in/between, electrical, chemical exposure, vehicle collision, or fire. Used for trend analysis and targeted safety interventions. [ENUM-REF-CANDIDATE: fall_from_height|struck_by|caught_in_between|electrical|chemical_exposure|vehicle|fire|ergonomic|other — promote to reference product]' ;
    rdfs:domain ind:IncidentInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentClassification rdf:type rdf:Property ;
    rdfs:label 'Incident Classification' ;
    rdfs:comment 'Severity classification of the incident under investigation per OSHA and ISO 45001 reporting categories. Lost Time Injury (LTI) and fatality classifications trigger mandatory regulatory reporting. [ENUM-REF-CANDIDATE: fatality|lti|medical_treatment|first_aid|near_miss|property_damage|environmental — promote to reference product]' ;
    rdfs:domain ind:IncidentInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationCloseDate rdf:type rdf:Property ;
    rdfs:label 'Investigation Close Date' ;
    rdfs:comment 'Date on which the investigation was formally closed following completion of root cause analysis, corrective action assignment, and management sign-off. Nullable until closure.' ;
    rdfs:domain ind:IncidentInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:investigationFindings rdf:type rdf:Property ;
    rdfs:label 'Investigation Findings' ;
    rdfs:comment 'Comprehensive narrative summary of all findings from the investigation, including evidence gathered, witness statements reviewed, site conditions observed, and conclusions drawn by the investigation team.' ;
    rdfs:domain ind:IncidentInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationMethodology rdf:type rdf:Property ;
    rdfs:label 'Investigation Methodology' ;
    rdfs:comment 'Root cause analysis methodology applied during the investigation. Common methods include 5-Why analysis, Fishbone (Ishikawa) diagram, Bowtie analysis, Fault Tree Analysis, and TapRooT. [ENUM-REF-CANDIDATE: 5_why|fishbone|bowtie|fault_tree|taproot|other — promote to reference product]' ;
    rdfs:domain ind:IncidentInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationNumber rdf:type rdf:Property ;
    rdfs:label 'Investigation Number' ;
    rdfs:comment 'Externally-known unique alphanumeric reference code assigned to the investigation, used in correspondence, regulatory submissions, and audit trails. Format: INV-YYYY-NNNNNN.' ;
    rdfs:domain ind:IncidentInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationTeamMembers rdf:type rdf:Property ;
    rdfs:label 'Investigation Team Members' ;
    rdfs:comment 'Names and roles of all personnel who participated in the investigation team, including the lead investigator, HSE representative, site supervisor, and any subject matter experts. Stored as a structured text list.' ;
    rdfs:domain ind:IncidentInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationType rdf:type rdf:Property ;
    rdfs:label 'Investigation Type' ;
    rdfs:comment 'Classification of the investigation scope and formality level. Formal investigations are conducted for Lost Time Injuries (LTI), fatalities, and high-potential incidents. Informal investigations cover minor incidents and near-misses.' ;
    rdfs:domain ind:IncidentInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isRecordable rdf:type rdf:Property ;
    rdfs:label 'Is Recordable' ;
    rdfs:comment 'Indicates whether the incident meets OSHA recordability criteria and must be entered on the OSHA 300 Log. Recordable incidents include work-related fatalities, injuries, and illnesses meeting specific severity thresholds.' ;
    rdfs:domain ind:IncidentInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRegulatoryReportable rdf:type rdf:Property ;
    rdfs:label 'Is Regulatory Reportable' ;
    rdfs:comment 'Indicates whether the incident requires mandatory notification to a regulatory authority such as OSHA, EPA, or local government within a prescribed timeframe (e.g., OSHA requires fatality reporting within 8 hours).' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lostTimeDays rdf:type rdf:Property ;
    rdfs:label 'Lost Time Days' ;
    rdfs:comment 'Number of calendar days lost due to the incident as determined by the investigation. Used in calculating Lost Time Injury (LTI) frequency rates and Total Recordable Incident Rate (TRIR) for OSHA regulatory reporting.' ;
    rdfs:domain ind:IncidentInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:managementReviewDate rdf:type rdf:Property ;
    rdfs:label 'Management Review Date' ;
    rdfs:comment 'Date on which senior management formally reviewed and accepted the investigation report and corrective action plan. Required for ISO 45001 management review compliance.' ;
    rdfs:domain ind:IncidentInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ppeComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Ppe Compliance Flag' ;
    rdfs:comment 'Indicates whether the injured party was wearing the required Personal Protective Equipment (PPE) at the time of the incident. Non-compliance is a key contributing factor captured in the investigation.' ;
    rdfs:domain ind:IncidentInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ptwReference rdf:type rdf:Property ;
    rdfs:label 'Ptw Reference' ;
    rdfs:comment 'Reference number of the Permit to Work (PTW) that was active or should have been active for the work activity at the time of the incident. Used to assess whether permit controls were adequate or absent.' ;
    rdfs:domain ind:IncidentInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reference Number' ;
    rdfs:comment 'Reference or case number assigned by the regulatory authority (e.g., OSHA case number) upon submission of the incident report. Used for tracking regulatory correspondence and compliance status.' ;
    rdfs:domain ind:IncidentInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatorySubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Regulatory Submission Date' ;
    rdfs:comment 'Date on which the incident investigation report or notification was formally submitted to the relevant regulatory authority (e.g., OSHA, EPA). Nullable for non-reportable incidents.' ;
    rdfs:domain ind:IncidentInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rootCauseDescription rdf:type rdf:Property ;
    rdfs:label 'Root Cause Description' ;
    rdfs:comment 'Detailed narrative of the fundamental systemic root cause(s) identified through the investigation methodology (e.g., 5-Why, Fishbone). Represents the deepest causal factor that, if corrected, would prevent recurrence.' ;
    rdfs:domain ind:IncidentInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:swmsInPlaceFlag rdf:type rdf:Property ;
    rdfs:label 'Swms In Place Flag' ;
    rdfs:comment 'Indicates whether a valid Safe Work Method Statement (SWMS) was in place and accessible for the work activity being performed at the time of the incident. Absence of SWMS is a key systemic cause indicator.' ;
    rdfs:domain ind:IncidentInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:systemicCause rdf:type rdf:Property ;
    rdfs:label 'Systemic Cause' ;
    rdfs:comment 'Organisational or management system failure that allowed the immediate and root causes to exist, such as inadequate procedures, insufficient training, or failed management controls. Distinct from immediate and root causes.' ;
    rdfs:domain ind:IncidentInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:witnessCount rdf:type rdf:Property ;
    rdfs:label 'Witness Count' ;
    rdfs:comment 'Number of witnesses interviewed during the investigation. Indicates the breadth of evidence gathering and supports completeness assessment of the investigation.' ;
    rdfs:domain ind:IncidentInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:workAreaDescription rdf:type rdf:Property ;
    rdfs:label 'Work Area Description' ;
    rdfs:comment 'Specific work area, zone, or location within the construction site where the incident occurred, such as excavation zone, scaffolding level, electrical room, or crane operating radius.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:performingAuthorityEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Performing Authority Employee Id' ;
    rdfs:comment 'Foreign key linking to hr.employee. Business justification: Permit issuance must record the authorized employee performing the work for compliance reporting.' ;
    rdfs:domain ind:PermitToWork ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:concurrentPermitFlag rdf:type rdf:Property ;
    rdfs:label 'Concurrent Permit Flag' ;
    rdfs:comment 'Indicates whether this permit is being executed concurrently with other active permits in the same work area. Triggers additional interface risk assessment requirements.' ;
    rdfs:domain ind:PermitToWork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:emergencyRescuePlan rdf:type rdf:Property ;
    rdfs:label 'Emergency Rescue Plan' ;
    rdfs:comment 'Reference to or description of the emergency rescue and evacuation plan applicable to the permitted work. Mandatory for confined space entry and working at heights permits.' ;
    rdfs:domain ind:PermitToWork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gasTestRequired rdf:type rdf:Property ;
    rdfs:label 'Gas Test Required' ;
    rdfs:comment 'Indicates whether atmospheric gas testing is required prior to and during the permitted work (mandatory for confined space entry and hot work near flammable materials).' ;
    rdfs:domain ind:PermitToWork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gasTestResult rdf:type rdf:Property ;
    rdfs:label 'Gas Test Result' ;
    rdfs:comment 'Result of the atmospheric gas test conducted prior to commencing the permitted work. Must be \'pass\' before work can proceed when gas_test_required is True.' ;
    rdfs:domain ind:PermitToWork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isolationDetails rdf:type rdf:Property ;
    rdfs:label 'Isolation Details' ;
    rdfs:comment 'Description of the specific isolation points, energy sources, and lockout/tagout procedures required for the permitted work. Populated when isolation_required is True.' ;
    rdfs:domain ind:PermitToWork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isolationRequired rdf:type rdf:Property ;
    rdfs:label 'Isolation Required' ;
    rdfs:comment 'Indicates whether energy isolation (lockout/tagout) is required before commencing the permitted work. Mandatory for electrical, mechanical, and process isolation scenarios.' ;
    rdfs:domain ind:PermitToWork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:issuingAuthorityName rdf:type rdf:Property ;
    rdfs:label 'Issuing Authority Name' ;
    rdfs:comment 'Full name of the qualified person (typically HSE Manager, Area Authority, or Responsible Engineer) who issued and authorized the permit. Required for regulatory audit and sign-off chain documentation.' ;
    rdfs:domain ind:PermitToWork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingAuthorityRole rdf:type rdf:Property ;
    rdfs:label 'Issuing Authority Role' ;
    rdfs:comment 'Job title or role designation of the person who issued the permit (e.g., HSE Manager, Area Authority, Electrical Supervisor). Validates competency and authorization level.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastExtendedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Extended Timestamp' ;
    rdfs:comment 'Date and time of the most recent extension of the permit validity period. Populated when extension_count is greater than zero.' ;
    rdfs:domain ind:PermitToWork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:performingAuthorityName rdf:type rdf:Property ;
    rdfs:label 'Performing Authority Name' ;
    rdfs:comment 'Full name of the person responsible for executing the permitted work (typically the Supervisor or Foreman accepting the permit). Part of the mandatory sign-off chain.' ;
    rdfs:domain ind:PermitToWork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:performingAuthorityRole rdf:type rdf:Property ;
    rdfs:label 'Performing Authority Role' ;
    rdfs:comment 'Job title or role of the person accepting and executing the permitted work (e.g., Foreman, Tradesperson, Subcontractor Supervisor). Validates competency for the work type.' ;
    rdfs:domain ind:PermitToWork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:permitStatus rdf:type rdf:Property ;
    rdfs:label 'Permit Status' ;
    rdfs:comment 'Current lifecycle state of the permit within the approval and execution workflow. Drives field access control and compliance dashboards. [ENUM-REF-CANDIDATE: draft|pending_approval|approved|active|suspended|closed|cancelled — promote to reference product]' ;
    rdfs:domain ind:PermitToWork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reinstatementDetails rdf:type rdf:Property ;
    rdfs:label 'Reinstatement Details' ;
    rdfs:comment 'Description of site reinstatement actions completed upon permit closure, including removal of isolations, restoration of services, and area clearance confirmation.' ;
    rdfs:domain ind:PermitToWork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tbmConductedFlag rdf:type rdf:Property ;
    rdfs:label 'Tbm Conducted Flag' ;
    rdfs:comment 'Indicates whether a Toolbox Meeting (TBM) was conducted with the work crew prior to commencing the permitted work. Mandatory pre-work safety briefing requirement.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tbmRecordReference rdf:type rdf:Property ;
    rdfs:label 'Tbm Record Reference' ;
    rdfs:comment 'Reference to the Toolbox Meeting record conducted prior to commencing the permitted work. Links the PTW to the pre-work safety briefing documentation.' ;
    rdfs:domain ind:PermitToWork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:workLocationDescription rdf:type rdf:Property ;
    rdfs:label 'Work Location Description' ;
    rdfs:comment 'Specific location within the site where the permitted work is to be performed, including zone, level, grid reference, or equipment tag. Supplements the site_id with granular location detail.' ;
    rdfs:domain ind:PermitToWork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workerCount rdf:type rdf:Property ;
    rdfs:label 'Worker Count' ;
    rdfs:comment 'Number of workers authorized to perform work under this permit. Used for site headcount control, emergency muster, and HSE exposure tracking.' ;
    rdfs:domain ind:PermitToWork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:validFrom rdf:type rdf:Property ;
    rdfs:label 'Valid From' ;
    rdfs:comment 'The date and time from which the permit is valid and work may commence. Must not precede the issued_timestamp. Used to enforce temporal access controls on site.' ;
    rdfs:domain ind:PermitToWork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:ppeRegisterId rdf:type rdf:Property ;
    rdfs:label 'Ppe Register Id' ;
    rdfs:comment 'Unique system-generated identifier for each PPE issuance record in the master register. Primary key for the ppe_register data product. Entity role: MASTER_RESOURCE — represents a physical PPE item assigned to a worker.' ;
    rdfs:domain ind:PpeRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:issuedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Issued By Employee Id' ;
    rdfs:comment 'Foreign key linking to hr.employee. Business justification: PPE issuance must be signed off by the issuing employee to satisfy audit and regulatory PPE traceability.' ;
    rdfs:domain ind:PpeRegister ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:certificationClass rdf:type rdf:Property ;
    rdfs:label 'Certification Class' ;
    rdfs:comment 'Specific class, type, or rating within the certification standard (e.g., \'Type I\', \'Type II\', \'Class E\', \'Class G\', \'Level A\', \'P100\', \'N95\', \'FFP3\'). Provides granular compliance detail beyond the standard name.' ;
    rdfs:domain ind:PpeRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:colour rdf:type rdf:Property ;
    rdfs:label 'Colour' ;
    rdfs:comment 'Colour of the PPE item. Used for site-specific colour-coding schemes (e.g., hard hat colour denoting trade or visitor status) and high-visibility garment compliance verification.' ;
    rdfs:domain ind:PpeRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionStatus rdf:type rdf:Property ;
    rdfs:label 'Condition Status' ;
    rdfs:comment 'Current physical condition assessment of the PPE item as determined during the most recent inspection. \'condemned\' indicates the item must be immediately withdrawn from service. Drives replacement and corrective action workflows.' ;
    rdfs:domain ind:PpeRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fitTestDate rdf:type rdf:Property ;
    rdfs:label 'Fit Test Date' ;
    rdfs:comment 'Date on which the most recent fit test was conducted for this PPE item and worker combination. Applicable to tight-fitting respirators. Null if fit_test_required is False.' ;
    rdfs:domain ind:PpeRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fitTestRequired rdf:type rdf:Property ;
    rdfs:label 'Fit Test Required' ;
    rdfs:comment 'Indicates whether a formal fit test is required for this PPE item (True for tight-fitting respirators per OSHA 29 CFR 1910.134, False for loose-fitting or non-respiratory items). Drives fit-test scheduling workflows.' ;
    rdfs:domain ind:PpeRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:issuanceStatus rdf:type rdf:Property ;
    rdfs:label 'Issuance Status' ;
    rdfs:comment 'Current lifecycle status of this PPE issuance record. Tracks whether the item is currently issued to the worker, has been returned, replaced, condemned, or reported lost. Distinct from condition_status (physical state) and compliance_status (regulatory state).' ;
    rdfs:domain ind:PpeRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:itemName rdf:type rdf:Property ;
    rdfs:label 'Item Name' ;
    rdfs:comment 'Human-readable name of the PPE item (e.g., \'Hard Hat Type II\', \'Safety Harness Full Body\', \'Anti-Fog Safety Goggles\'). Used in reports, compliance dashboards, and worker-facing documentation.' ;
    rdfs:domain ind:PpeRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manufactureDate rdf:type rdf:Property ;
    rdfs:label 'Manufacture Date' ;
    rdfs:comment 'Date of manufacture as stated on the PPE item or packaging. Used to calculate age-based retirement for items such as hard hats (typically 5-year service life from manufacture) and harnesses.' ;
    rdfs:domain ind:PpeRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextInspectionDate rdf:type rdf:Property ;
    rdfs:label 'Next Inspection Date' ;
    rdfs:comment 'Scheduled date for the next formal inspection of the PPE item. Calculated from last inspection date and inspection frequency policy. Drives proactive compliance scheduling in Intelex.' ;
    rdfs:domain ind:PpeRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ppeCategory rdf:type rdf:Property ;
    rdfs:label 'Ppe Category' ;
    rdfs:comment 'Primary body-protection category of the PPE item per OSHA 1926 Subpart E classification. Drives category-level compliance monitoring and ensures all hazard zones are covered. [ENUM-REF-CANDIDATE: head|eye_face|hearing|respiratory|fall_protection|hand|foot|body|high_visibility — promote to reference product]' ;
    rdfs:domain ind:PpeRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:replacementDate rdf:type rdf:Property ;
    rdfs:label 'Replacement Date' ;
    rdfs:comment 'Date on which the PPE item was replaced with a new item, either due to expiry, damage, or scheduled replacement. Links to the new issuance record for traceability.' ;
    rdfs:domain ind:PpeRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:returnDate rdf:type rdf:Property ;
    rdfs:label 'Return Date' ;
    rdfs:comment 'Date on which the PPE item was returned by the worker (e.g., upon project completion, employment termination, or item replacement). Null if item is still in active use. Closes the issuance lifecycle.' ;
    rdfs:domain ind:PpeRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:serviceLifeMonths rdf:type rdf:Property ;
    rdfs:label 'Service Life Months' ;
    rdfs:comment 'Maximum service life of the PPE item in months from manufacture date, as specified by the manufacturer or applicable standard (e.g., 60 months for hard hats per ANSI Z89.1, 120 months for harnesses per ANSI Z359.1). Used to calculate mandatory retirement date.' ;
    rdfs:domain ind:PpeRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:size rdf:type rdf:Property ;
    rdfs:label 'Size' ;
    rdfs:comment 'Size designation of the PPE item as issued to the worker (e.g., \'M\', \'L\', \'XL\', \'universal\'). Ensures correct fit for effective protection. Incorrect sizing is a common compliance failure. [ENUM-REF-CANDIDATE: XS|S|M|L|XL|XXL|XXXL|universal|custom — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingDate rdf:type rdf:Property ;
    rdfs:label 'Training Date' ;
    rdfs:comment 'Date on which the worker completed PPE training for this item type. Used to verify training currency and schedule refresher training. Sourced from SAP SuccessFactors Learning module.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:workerAcknowledgement rdf:type rdf:Property ;
    rdfs:label 'Worker Acknowledgement' ;
    rdfs:comment 'Indicates whether the worker has formally acknowledged receipt and understanding of correct usage requirements for this PPE item (True/False). Signed acknowledgement is a legal requirement under OSHA 1926 Subpart E and site HSE procedures.' ;
    rdfs:domain ind:PpeRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:riskAssessmentId rdf:type rdf:Property ;
    rdfs:label 'Risk Assessment Id' ;
    rdfs:comment 'Unique surrogate identifier for each risk assessment record in the hazard and risk register. Primary key for the risk_assessment data product.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RiskAssessment .

ind:responsiblePersonEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Responsible Person Employee Id' ;
    rdfs:comment 'Foreign key linking to hr.employee. Business justification: Risk assessments assign a responsible employee; required for accountability and HSE audit trails.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:controlHierarchy rdf:type rdf:Property ;
    rdfs:label 'Control Hierarchy' ;
    rdfs:comment 'Highest level of the Hierarchy of Controls applied to this hazard: Eliminate, Substitute, Engineering controls, Administrative controls, or Personal Protective Equipment (PPE). Reflects the most effective control measure in place.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:environmentalImpactDescription rdf:type rdf:Property ;
    rdfs:label 'Environmental Impact Description' ;
    rdfs:comment 'Description of the environmental impact or aspect associated with this hazard, where applicable (e.g., soil contamination from chemical spill, noise pollution, stormwater runoff). Populated when environmental_aspect is True.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initialConsequence rdf:type rdf:Property ;
    rdfs:label 'Initial Consequence' ;
    rdfs:comment 'Consequence/severity score assigned before control measures are applied, rated on the project risk matrix scale (typically 1–5: 1=Insignificant, 2=Minor, 3=Moderate, 4=Major, 5=Catastrophic).' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:initialLikelihood rdf:type rdf:Property ;
    rdfs:label 'Initial Likelihood' ;
    rdfs:comment 'Likelihood score assigned before control measures are applied, rated on the project risk matrix scale (typically 1–5: 1=Rare, 2=Unlikely, 3=Possible, 4=Likely, 5=Almost Certain).' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:linkedPtwNumber rdf:type rdf:Property ;
    rdfs:label 'Linked Ptw Number' ;
    rdfs:comment 'Reference number of the Permit to Work (PTW) issued in conjunction with this risk assessment. Supports traceability between hazard controls and formal work authorisation.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:linkedSwmsNumber rdf:type rdf:Property ;
    rdfs:label 'Linked Swms Number' ;
    rdfs:comment 'Reference number of the Safe Work Method Statement (SWMS) document that was developed using or references this risk assessment. Enables traceability between risk assessments and SWMS documentation.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryRequirement rdf:type rdf:Property ;
    rdfs:label 'Regulatory Requirement' ;
    rdfs:comment 'Specific regulatory standard, clause, or legal obligation that this risk assessment addresses (e.g., OSHA 29 CFR 1926.502 Fall Protection, ISO 45001 Clause 6.1.2, EPA 40 CFR). Supports compliance reporting.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:residualConsequence rdf:type rdf:Property ;
    rdfs:label 'Residual Consequence' ;
    rdfs:comment 'Consequence/severity score after all control measures have been applied, rated on the project risk matrix scale (typically 1–5). Reflects the remaining severity of harm post-control.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:residualLikelihood rdf:type rdf:Property ;
    rdfs:label 'Residual Likelihood' ;
    rdfs:comment 'Likelihood score after all control measures have been applied, rated on the project risk matrix scale (typically 1–5). Reflects the remaining probability of the hazard being realised post-control.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:responsiblePartyRole rdf:type rdf:Property ;
    rdfs:label 'Responsible Party Role' ;
    rdfs:comment 'Job role or organisational function of the person responsible for implementing and monitoring the control measures associated with this risk assessment.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskMatrixVersion rdf:type rdf:Property ;
    rdfs:label 'Risk Matrix Version' ;
    rdfs:comment 'Version identifier of the project or corporate risk matrix used to score likelihood and consequence for this assessment. Ensures consistent interpretation of risk scores across assessments and over time.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceType rdf:type rdf:Property ;
    rdfs:label 'Source Type' ;
    rdfs:comment 'Origin or trigger that led to the identification and recording of this hazard — e.g., field inspection, incident investigation, design review, JHA session, HSE audit, near-miss report, or Toolbox Meeting (TBM). [ENUM-REF-CANDIDATE: inspection|incident|design_review|jha|audit|near_miss|toolbox_meeting — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyAuditId rdf:type rdf:Property ;
    rdfs:label 'Safety Audit Id' ;
    rdfs:comment 'Unique system-generated identifier for the safety audit record. Primary key for the safety_audit data product. Entity role: TRANSACTION_HEADER — represents a discrete formal HSE audit event with its own lifecycle, scope, team, findings, and close-out status.' ;
    rdfs:domain ind:SafetyAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:aconexDocumentRef rdf:type rdf:Property ;
    rdfs:label 'Aconex Document Ref' ;
    rdfs:comment 'Document reference number in the Aconex document management system for the formal audit report. Enables direct retrieval of the audit report from the document control system.' ;
    rdfs:domain ind:SafetyAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditeeName rdf:type rdf:Property ;
    rdfs:label 'Auditee Name' ;
    rdfs:comment 'Name of the individual, department, or subcontractor organisation being audited. Represents the PARTY_REFERENCE for this transaction — the primary counterparty subject to the audit.' ;
    rdfs:domain ind:SafetyAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditeeOrganisation rdf:type rdf:Property ;
    rdfs:label 'Auditee Organisation' ;
    rdfs:comment 'Name of the company or organisational unit being audited (e.g., subcontractor company name, internal business unit). Distinguishes between audits of internal teams versus subcontractors.' ;
    rdfs:domain ind:SafetyAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionPlanDueDate rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Plan Due Date' ;
    rdfs:comment 'Deadline by which the auditee must submit a formal corrective action plan (CAPA) addressing all non-conformances raised in the audit. Drives CAPA workflow in Intelex.' ;
    rdfs:domain ind:SafetyAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:criteriaCompliant rdf:type rdf:Property ;
    rdfs:label 'Criteria Compliant' ;
    rdfs:comment 'Number of audit criteria assessed as fully compliant. Together with total_criteria_assessed, provides the raw data for compliance score calculation and trend reporting.' ;
    rdfs:domain ind:SafetyAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:findingDetail rdf:type rdf:Property ;
    rdfs:label 'Finding Detail' ;
    rdfs:comment 'Embedded narrative summary of key audit findings captured at the header level for quick reference. Full individual finding records with severity, standard clause, responsible party, and due date are managed in the linked audit_finding child entity.' ;
    rdfs:domain ind:SafetyAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:immediateActionRequired rdf:type rdf:Property ;
    rdfs:label 'Immediate Action Required' ;
    rdfs:comment 'Indicates whether the audit identified at least one finding requiring immediate corrective action due to imminent risk to worker safety or regulatory non-compliance. Triggers escalation workflow in Intelex.' ;
    rdfs:domain ind:SafetyAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:intelexAuditReference rdf:type rdf:Property ;
    rdfs:label 'Intelex Audit Reference' ;
    rdfs:comment 'Source system identifier for this audit record in the Intelex HSE Management platform. Used for data lineage, reconciliation, and drill-back to the operational system of record.' ;
    rdfs:domain ind:SafetyAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextAuditDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Audit Due Date' ;
    rdfs:comment 'Scheduled date for the next audit of the same scope and auditee, derived from the audit frequency plan. Used to drive the audit schedule and ensure compliance with ISO 45001 internal audit programme requirements.' ;
    rdfs:domain ind:SafetyAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:observationCount rdf:type rdf:Property ;
    rdfs:label 'Observation Count' ;
    rdfs:comment 'Number of observations raised during the audit. Observations are potential risks or areas of concern that do not yet constitute non-conformances but warrant monitoring.' ;
    rdfs:domain ind:SafetyAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ofiCount rdf:type rdf:Property ;
    rdfs:label 'Ofi Count' ;
    rdfs:comment 'Number of opportunities for improvement (OFIs) identified during the audit. OFIs are positive suggestions for enhancing HSE performance beyond current compliance requirements.' ;
    rdfs:domain ind:SafetyAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:openFindingsCount rdf:type rdf:Property ;
    rdfs:label 'Open Findings Count' ;
    rdfs:comment 'Number of audit findings that remain open (not yet resolved and verified) at the time of the last record update. Key metric for audit close-out tracking and corrective action management.' ;
    rdfs:domain ind:SafetyAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:programmeRef rdf:type rdf:Property ;
    rdfs:label 'Programme Ref' ;
    rdfs:comment 'Reference to the annual or project-level audit programme under which this audit was scheduled. Enables tracking of audit programme completion and coverage across the organisation.' ;
    rdfs:domain ind:SafetyAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryStandard rdf:type rdf:Property ;
    rdfs:label 'Regulatory Standard' ;
    rdfs:comment 'Primary regulatory or management system standard against which the audit was conducted (e.g., OSHA 29 CFR 1926, ISO 45001:2018, ISO 14001:2015, site-specific HSE plan). Multiple standards may be listed separated by semicolons.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportIssueDate rdf:type rdf:Property ;
    rdfs:label 'Report Issue Date' ;
    rdfs:comment 'Date on which the formal audit report was issued to the auditee and relevant stakeholders. Used to track reporting timeliness and trigger finding response deadlines.' ;
    rdfs:domain ind:SafetyAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:totalCriteriaAssessed rdf:type rdf:Property ;
    rdfs:label 'Total Criteria Assessed' ;
    rdfs:comment 'Total number of audit criteria or checklist items evaluated during the audit. Used as the denominator for compliance score calculation and for comparing audit rigour across audits.' ;
    rdfs:domain ind:SafetyAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalFindings rdf:type rdf:Property ;
    rdfs:label 'Total Findings' ;
    rdfs:comment 'Total number of audit findings raised across all severity levels (non-conformances, observations, and opportunities for improvement). Provides a headline count for executive reporting.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:trainingId rdf:type rdf:Property ;
    rdfs:label 'Training Id' ;
    rdfs:comment 'Unique identifier for the safety training record. Primary key.' ;
    rdfs:domain ind:Training ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:trainerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Trainer Employee Id' ;
    rdfs:comment 'Foreign key linking to hr.employee. Business justification: When training is delivered by an internal trainer, the trainer\'s employee ID is required for training records and competency tracking.' ;
    rdfs:domain ind:Training ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:attendanceStatus rdf:type rdf:Property ;
    rdfs:label 'Attendance Status' ;
    rdfs:comment 'Worker\'s attendance status for the training session: attended (full participation), absent (did not attend), partial (attended part of the session), or excused (authorized absence).' ;
    rdfs:domain ind:Training ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationIssued rdf:type rdf:Property ;
    rdfs:label 'Certification Issued' ;
    rdfs:comment 'Indicates whether a formal certificate or card was issued to the worker upon successful completion of the training. True if issued, False if not.' ;
    rdfs:domain ind:Training ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:languageOfInstruction rdf:type rdf:Property ;
    rdfs:label 'Language Of Instruction' ;
    rdfs:comment 'Primary language in which the training was delivered (e.g., English, Spanish, Mandarin). Important for multilingual workforce compliance.' ;
    rdfs:domain ind:Training ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialsProvided rdf:type rdf:Property ;
    rdfs:label 'Materials Provided' ;
    rdfs:comment 'Description of training materials provided to the worker (e.g., \'OSHA handbook, safety manual, PPE (Personal Protective Equipment) checklist, online access credentials\').' ;
    rdfs:domain ind:Training ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextRefresherDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Refresher Due Date' ;
    rdfs:comment 'Date by which the worker must complete refresher training to maintain compliance. Format: yyyy-MM-dd. Null if no refresher is required.' ;
    rdfs:domain ind:Training ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:refresherFrequencyMonths rdf:type rdf:Property ;
    rdfs:label 'Refresher Frequency Months' ;
    rdfs:comment 'Number of months between required refresher training sessions (e.g., 12 for annual refresher, 36 for three-year renewal). Null if no refresher is required.' ;
    rdfs:domain ind:Training ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:refresherRequired rdf:type rdf:Property ;
    rdfs:label 'Refresher Required' ;
    rdfs:comment 'Indicates whether periodic refresher training is required to maintain competency and compliance. True if refresher is required, False if one-time training is sufficient.' ;
    rdfs:domain ind:Training ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:trainerCertificationNumber rdf:type rdf:Property ;
    rdfs:label 'Trainer Certification Number' ;
    rdfs:comment 'Certification or accreditation number of the trainer, verifying their authorization to deliver the specific training (e.g., OSHA Outreach Trainer ID).' ;
    rdfs:domain ind:Training ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingCode rdf:type rdf:Property ;
    rdfs:label 'Training Code' ;
    rdfs:comment 'Unique alphanumeric code identifying the specific training course or module (e.g., OSHA10, OSHA30, INDUCT01, HEIGHTS01).' ;
    rdfs:domain ind:Training ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:swmsApprovedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Swms Approved By Employee Id' ;
    rdfs:comment 'Reference to the workforce record of the HSE Manager or authorised approver who formally approved this SWMS for use on site. Approval is a mandatory step before work can commence.' ;
    rdfs:domain ind:Swms ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:swmsEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Swms Employee Id' ;
    rdfs:comment 'Reference to the workforce record of the supervisor or foreman responsible for ensuring the SWMS is implemented and adhered to on site. The responsible supervisor must sign off on the SWMS prior to work commencement.' ;
    rdfs:domain ind:Swms ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:swmsPreparedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Swms Prepared By Employee Id' ;
    rdfs:comment 'Reference to the workforce record of the HSE professional or site engineer who prepared and authored this SWMS document. Provides accountability for document authorship.' ;
    rdfs:domain ind:Swms ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:applicableLegislation rdf:type rdf:Property ;
    rdfs:label 'Applicable Legislation' ;
    rdfs:comment 'List of applicable legislation, regulations, codes of practice, and industry standards that govern the high-risk activity described in this SWMS (e.g., OSHA 29 CFR 1926, IBC, NFPA, AISC, ACI). Required for regulatory compliance documentation.' ;
    rdfs:domain ind:Swms ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competencyRequirements rdf:type rdf:Property ;
    rdfs:label 'Competency Requirements' ;
    rdfs:comment 'Description of mandatory competency, certification, and licence requirements for workers performing the activity (e.g., Working at Heights certificate, Confined Space Entry certificate, Crane Operator licence). Supports workforce compliance verification.' ;
    rdfs:domain ind:Swms ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emergencyProcedures rdf:type rdf:Property ;
    rdfs:label 'Emergency Procedures' ;
    rdfs:comment 'Description of emergency response procedures specific to the high-risk activity, including evacuation routes, first aid requirements, emergency contacts, and incident notification protocols.' ;
    rdfs:domain ind:Swms ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:environmentalControls rdf:type rdf:Property ;
    rdfs:label 'Environmental Controls' ;
    rdfs:comment 'Description of environmental control measures required during the activity to prevent environmental harm, including spill containment, dust suppression, noise management, and waste disposal procedures.' ;
    rdfs:domain ind:Swms ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initialRiskConsequence rdf:type rdf:Property ;
    rdfs:label 'Initial Risk Consequence' ;
    rdfs:comment 'Consequence severity rating of the identified hazard before any control measures are applied (inherent risk). Combined with initial_risk_likelihood to produce the initial risk rating score.' ;
    rdfs:domain ind:Swms ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initialRiskLikelihood rdf:type rdf:Property ;
    rdfs:label 'Initial Risk Likelihood' ;
    rdfs:comment 'Likelihood rating of the identified hazard materialising before any control measures are applied (inherent risk). Used in conjunction with initial_risk_consequence to derive the initial risk rating per the risk matrix.' ;
    rdfs:domain ind:Swms ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initialRiskRating rdf:type rdf:Property ;
    rdfs:label 'Initial Risk Rating' ;
    rdfs:comment 'Overall risk rating derived from the combination of initial_risk_likelihood and initial_risk_consequence before any control measures are applied. Represents the inherent risk level of the activity.' ;
    rdfs:domain ind:Swms ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plantEquipmentRequired rdf:type rdf:Property ;
    rdfs:label 'Plant Equipment Required' ;
    rdfs:comment 'List of plant, equipment, and tools required to perform the high-risk activity safely as described in this SWMS (e.g., EWP, crane, excavator, scaffolding, welding equipment). Supports equipment deployment planning.' ;
    rdfs:domain ind:Swms ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ptwType rdf:type rdf:Property ;
    rdfs:label 'Ptw Type' ;
    rdfs:comment 'Type of Permit to Work (PTW) required in conjunction with this SWMS. Populated only when ptw_required is True. Drives the PTW issuance workflow in Intelex.' ;
    rdfs:domain ind:Swms ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:residualRiskConsequence rdf:type rdf:Property ;
    rdfs:label 'Residual Risk Consequence' ;
    rdfs:comment 'Consequence severity rating after all control measures have been applied. Combined with residual_risk_likelihood to produce the residual risk rating.' ;
    rdfs:domain ind:Swms ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:residualRiskLikelihood rdf:type rdf:Property ;
    rdfs:label 'Residual Risk Likelihood' ;
    rdfs:comment 'Likelihood rating of the hazard materialising after all control measures have been applied. Used to assess the effectiveness of controls and determine if the residual risk is acceptable.' ;
    rdfs:domain ind:Swms ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:residualRiskRating rdf:type rdf:Property ;
    rdfs:label 'Residual Risk Rating' ;
    rdfs:comment 'Overall risk rating after all control measures have been applied. Represents the residual risk level that must be accepted or further mitigated before work can proceed. Extreme residual risk requires escalation to HSE Manager.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:swmsNumber rdf:type rdf:Property ;
    rdfs:label 'Swms Number' ;
    rdfs:comment 'Externally-known unique document reference number for the SWMS, used for document control, transmittals, and regulatory submissions. Typically formatted as SWMS-[ProjectCode]-[Sequence]. Sourced from Intelex or Aconex document management.' ;
    rdfs:domain ind:Swms ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tbmRequired rdf:type rdf:Property ;
    rdfs:label 'Tbm Required' ;
    rdfs:comment 'Indicates whether a Toolbox Meeting (TBM) must be conducted with all workers before commencing the activity. TBMs are used to communicate SWMS content and obtain worker acknowledgement.' ;
    rdfs:domain ind:Swms ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:workSteps rdf:type rdf:Property ;
    rdfs:label 'Work Steps' ;
    rdfs:comment 'Sequential step-by-step description of the work procedure for the high-risk activity, detailing the specific actions workers must follow to complete the task safely. Core operational content of the SWMS.' ;
    rdfs:domain ind:Swms ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workerAcknowledgementRequired rdf:type rdf:Property ;
    rdfs:label 'Worker Acknowledgement Required' ;
    rdfs:comment 'Indicates whether all workers performing the activity must sign the SWMS to confirm they have read, understood, and agree to comply with the documented procedures and controls.' ;
    rdfs:domain ind:Swms ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:toolboxMeetingId rdf:type rdf:Property ;
    rdfs:label 'Toolbox Meeting Id' ;
    rdfs:comment 'Primary key for toolbox_meeting' ;
    rdfs:domain ind:ToolboxMeeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:facilitatorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Facilitator Employee Id' ;
    rdfs:comment 'Reference to the employee (supervisor, HSE officer, or foreman) who conducted and facilitated the Toolbox Meeting. Required for accountability and competency verification under ISO 45001.' ;
    rdfs:domain ind:ToolboxMeeting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualAttendeeCount rdf:type rdf:Property ;
    rdfs:label 'Actual Attendee Count' ;
    rdfs:comment 'Actual number of workers who attended and signed off on the Toolbox Meeting. Used to compute attendance rate and demonstrate safety communication compliance under OSHA and ISO 45001.' ;
    rdfs:domain ind:ToolboxMeeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:attendanceRatePct rdf:type rdf:Property ;
    rdfs:label 'Attendance Rate Pct' ;
    rdfs:comment 'Percentage of planned attendees who actually attended and signed off on the Toolbox Meeting (actual_attendee_count / planned_attendee_count × 100). Key HSE KPI for safety communication coverage reporting.' ;
    rdfs:domain ind:ToolboxMeeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:controlMeasuresCommunicated rdf:type rdf:Property ;
    rdfs:label 'Control Measures Communicated' ;
    rdfs:comment 'Description of the specific hazard control measures (elimination, substitution, engineering controls, administrative controls, PPE) communicated to attendees. Demonstrates hierarchy-of-controls compliance per ISO 45001 Clause 8.1.2.' ;
    rdfs:domain ind:ToolboxMeeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionRaised rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Raised' ;
    rdfs:comment 'Indicates whether any corrective actions or follow-up items were raised as a result of the Toolbox Meeting (e.g., identified hazards requiring remediation, equipment defects reported). Triggers workflow in Intelex for corrective action tracking.' ;
    rdfs:domain ind:ToolboxMeeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:documentAttachmentReference rdf:type rdf:Property ;
    rdfs:label 'Document Attachment Reference' ;
    rdfs:comment 'Reference identifier or URL to supporting documents attached to the Toolbox Meeting record in Intelex or Aconex (e.g., signed attendance sheet, topic handout, SWMS extract). Supports document control under ISO 45001 Clause 7.5.' ;
    rdfs:domain ind:ToolboxMeeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emergencyProceduresReviewed rdf:type rdf:Property ;
    rdfs:label 'Emergency Procedures Reviewed' ;
    rdfs:comment 'Indicates whether emergency response procedures (evacuation routes, muster points, emergency contacts) were reviewed with attendees during the Toolbox Meeting.' ;
    rdfs:domain ind:ToolboxMeeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:facilitatorName rdf:type rdf:Property ;
    rdfs:label 'Facilitator Name' ;
    rdfs:comment 'Full name of the person who facilitated the Toolbox Meeting (supervisor, HSE officer, or foreman). Retained for accountability and regulatory audit purposes. Classified as confidential as it identifies an employee.' ;
    rdfs:domain ind:ToolboxMeeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilitatorQualification rdf:type rdf:Property ;
    rdfs:label 'Facilitator Qualification' ;
    rdfs:comment 'HSE qualification or certification held by the meeting facilitator (e.g., OSHA 30-Hour, ISO 45001 Lead Auditor, First Aid). Supports competency verification requirements under ISO 45001 Clause 7.2.' ;
    rdfs:domain ind:ToolboxMeeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazardsHighlighted rdf:type rdf:Property ;
    rdfs:label 'Hazards Highlighted' ;
    rdfs:comment 'Description of the specific site hazards communicated to attendees during the Toolbox Meeting, drawn from the linked risk assessment or SWMS (Safe Work Method Statement). Supports evidence of hazard communication under OSHA and ISO 45001.' ;
    rdfs:domain ind:ToolboxMeeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hseTopicCategory rdf:type rdf:Property ;
    rdfs:label 'Hse Topic Category' ;
    rdfs:comment 'Primary HSE topic category covered in the Toolbox Meeting (e.g., Working at Heights, Confined Space, Electrical Safety, Manual Handling, Environmental Compliance). Used for topic frequency analysis and gap identification. [ENUM-REF-CANDIDATE: working_at_heights|confined_space|electrical_safety|manual_handling|environmental|fire_prevention|excavation|crane_lifting|ppe_compliance|chemical_handling — promote to reference product]' ;
    rdfs:domain ind:ToolboxMeeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentReviewIncluded rdf:type rdf:Property ;
    rdfs:label 'Incident Review Included' ;
    rdfs:comment 'Indicates whether a review of recent incidents, near-misses, or LTI (Lost Time Injury) events was included in the Toolbox Meeting agenda. Supports learning-from-incidents culture and ISO 45001 Clause 10.2 requirements.' ;
    rdfs:domain ind:ToolboxMeeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:interpreterRequired rdf:type rdf:Property ;
    rdfs:label 'Interpreter Required' ;
    rdfs:comment 'Indicates whether an interpreter or translator was required and used during the Toolbox Meeting to communicate safety information to non-English-speaking workers.' ;
    rdfs:domain ind:ToolboxMeeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:languageConducted rdf:type rdf:Property ;
    rdfs:label 'Language Conducted' ;
    rdfs:comment 'ISO 639-2 three-letter language code for the primary language in which the Toolbox Meeting was conducted. Supports multilingual workforce compliance and OSHA Hazard Communication requirements for non-English-speaking workers.' ;
    rdfs:domain ind:ToolboxMeeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:meetingDate rdf:type rdf:Property ;
    rdfs:label 'Meeting Date' ;
    rdfs:comment 'Calendar date on which the Toolbox Meeting was conducted. Used for scheduling compliance checks, frequency reporting, and OSHA recordkeeping.' ;
    rdfs:domain ind:ToolboxMeeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:meetingReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Meeting Reference Number' ;
    rdfs:comment 'Externally-known unique business identifier for the Toolbox Meeting as assigned by the HSE management system (Intelex). Used for cross-referencing in safety registers, audit trails, and regulatory submissions.' ;
    rdfs:domain ind:ToolboxMeeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:meetingStatus rdf:type rdf:Property ;
    rdfs:label 'Meeting Status' ;
    rdfs:comment 'Current lifecycle status of the Toolbox Meeting record. Drives workflow in Intelex and determines whether the meeting counts toward HSE compliance metrics.' ;
    rdfs:domain ind:ToolboxMeeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:meetingType rdf:type rdf:Property ;
    rdfs:label 'Meeting Type' ;
    rdfs:comment 'Classification of the Toolbox Meeting by its operational purpose. Pre-shift meetings occur at the start of each work shift; pre-task meetings are conducted immediately before a specific high-risk activity begins.' ;
    rdfs:domain ind:ToolboxMeeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedAttendeeCount rdf:type rdf:Property ;
    rdfs:label 'Planned Attendee Count' ;
    rdfs:comment 'Number of workers expected to attend the Toolbox Meeting based on the crew deployment plan. Used to calculate attendance rate and identify gaps in safety communication coverage.' ;
    rdfs:domain ind:ToolboxMeeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ppeRequirementsCommunicated rdf:type rdf:Property ;
    rdfs:label 'Ppe Requirements Communicated' ;
    rdfs:comment 'Indicates whether PPE (Personal Protective Equipment) requirements specific to the work activity were communicated to attendees during the Toolbox Meeting. Supports PPE compliance tracking under OSHA PPE standards.' ;
    rdfs:domain ind:ToolboxMeeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ptwReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Ptw Reference Number' ;
    rdfs:comment 'Reference number of the Permit to Work (PTW) associated with this Toolbox Meeting, where the meeting was conducted as part of the PTW pre-work briefing process.' ;
    rdfs:domain ind:ToolboxMeeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signOffMethod rdf:type rdf:Property ;
    rdfs:label 'Sign Off Method' ;
    rdfs:comment 'Method used to capture attendee acknowledgement and sign-off for the Toolbox Meeting. Determines the evidentiary value of the attendance record for regulatory compliance purposes.' ;
    rdfs:domain ind:ToolboxMeeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:swmsReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Swms Reference Number' ;
    rdfs:comment 'Reference number of the Safe Work Method Statement (SWMS) reviewed or communicated during this Toolbox Meeting. Links the TBM to the formal SWMS document for high-risk construction work.' ;
    rdfs:domain ind:ToolboxMeeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradeGroup rdf:type rdf:Property ;
    rdfs:label 'Trade Group' ;
    rdfs:comment 'The trade or crew group attending the Toolbox Meeting (e.g., Civil, Structural Steel, MEP (Mechanical Electrical Plumbing), Concrete, Earthworks). Used to segment HSE communication effectiveness by trade.' ;
    rdfs:domain ind:ToolboxMeeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleCalendarId rdf:type rdf:Property ;
    rdfs:label 'Schedule Calendar Id' ;
    rdfs:comment 'Identifier of the calendar to which the activity is assigned.' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ScheduleCalendar .

ind:activityCode rdf:type rdf:Property ;
    rdfs:label 'Activity Code' ;
    rdfs:comment 'Business identifier code assigned to the activity (e.g., unique activity number).' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:activityName rdf:type rdf:Property ;
    rdfs:label 'Activity Name' ;
    rdfs:comment 'Human-readable name or title of the activity.' ;
    rdfs:domain ind:Activity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:activityStatus rdf:type rdf:Property ;
