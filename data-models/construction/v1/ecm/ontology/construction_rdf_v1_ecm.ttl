    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:readyActivities rdf:type rdf:Property ;
    rdfs:label 'Ready Activities' ;
    rdfs:comment 'Number of activities marked as ready for execution.' ;
