    rdfs:range xsd:decimal .

ind:paymentScheduleNewDate rdf:type rdf:Property ;
    rdfs:label 'Payment Schedule New Date' ;
    rdfs:comment 'New date for the next payment after amendment.' ;
    rdfs:domain ind:Amendment ;
