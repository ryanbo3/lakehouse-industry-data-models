    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:progressUpdateId rdf:type rdf:Property ;
    rdfs:label 'Progress Update Id' ;
    rdfs:comment 'Unique surrogate key for the schedule progress update record.' ;
    rdfs:domain ind:ProgressUpdate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualUnits rdf:type rdf:Property ;
    rdfs:label 'Actual Units' ;
    rdfs:comment 'Actual quantity of work units performed (e.g., labor hours, cubic meters).' ;
