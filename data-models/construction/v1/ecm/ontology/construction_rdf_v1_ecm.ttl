ind:holidayExceptions rdf:type rdf:Property ;
    rdfs:label 'Holiday Exceptions' ;
    rdfs:comment 'Comma-separated list or description of holidays and non-working dates that override the regular schedule.' ;
    rdfs:domain ind:ScheduleCalendar ;
    rdf:type owl:DatatypeProperty ;
