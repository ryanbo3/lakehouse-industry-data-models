ind:approvalStatus rdf:type rdf:Property ;
    rdfs:label 'Approval Status' ;
    rdfs:comment 'Current lifecycle state of the approval record.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedBidPrice rdf:type rdf:Property ;
    rdfs:label 'Approved Bid Price' ;
    rdfs:comment 'Final approved monetary amount for the bid.' ;
