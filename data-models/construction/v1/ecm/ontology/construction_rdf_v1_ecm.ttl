    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subcontractNumber rdf:type rdf:Property ;
    rdfs:label 'Subcontract Number' ;
    rdfs:comment 'External contract number or code assigned to the subcontract as defined in the main contract documents.' ;
    rdfs:domain ind:Subcontract ;
