ind:claimCurrency rdf:type rdf:Property ;
    rdfs:label 'Claim Currency' ;
    rdfs:comment 'Three-letter ISO currency code for the claimed amount.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimReasonCode rdf:type rdf:Property ;
    rdfs:label 'Claim Reason Code' ;
    rdfs:comment 'Standardized code describing the underlying reason for the claim (e.g., delayed_payment, scope_change).' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dabReference rdf:type rdf:Property ;
    rdfs:label 'Dab Reference' ;
    rdfs:comment 'Reference identifier for the Dispute Adjudication Board case associated with the dispute.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeDescription rdf:type rdf:Property ;
    rdfs:label 'Dispute Description' ;
    rdfs:comment 'Detailed narrative describing the nature and background of the dispute.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeNumber rdf:type rdf:Property ;
    rdfs:label 'Dispute Number' ;
    rdfs:comment 'Business visible identifier or reference number assigned to the dispute.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeType rdf:type rdf:Property ;
    rdfs:label 'Dispute Type' ;
    rdfs:comment 'Category of the dispute indicating the primary issue area. [ENUM-REF-CANDIDATE: payment|scope|delay|quality|safety|environment|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationDeadline rdf:type rdf:Property ;
    rdfs:label 'Escalation Deadline' ;
    rdfs:comment 'Date by which the dispute must be escalated to higher authority if not resolved.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fidicClause rdf:type rdf:Property ;
    rdfs:label 'Fidic Clause' ;
    rdfs:comment 'Specific FIDIC clause cited as governing the dispute resolution process.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalCostAmount rdf:type rdf:Property ;
    rdfs:label 'Legal Cost Amount' ;
    rdfs:comment 'Total legal fees incurred for handling the dispute.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:legalCostCurrency rdf:type rdf:Property ;
    rdfs:label 'Legal Cost Currency' ;
    rdfs:comment 'Currency of the legal cost amount.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netSettlementAmount rdf:type rdf:Property ;
    rdfs:label 'Net Settlement Amount' ;
    rdfs:comment 'Final monetary amount agreed upon to settle the dispute, after adjustments.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:resolutionAmount rdf:type rdf:Property ;
    rdfs:label 'Resolution Amount' ;
    rdfs:comment 'Monetary amount associated with the resolution (e.g., payment made, penalty applied).' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:resolutionCurrency rdf:type rdf:Property ;
    rdfs:label 'Resolution Currency' ;
    rdfs:comment 'ISO currency code for the resolution amount.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementCurrency rdf:type rdf:Property ;
    rdfs:label 'Settlement Currency' ;
    rdfs:comment 'ISO currency code for the net settlement amount.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportingDocumentRefs rdf:type rdf:Property ;
    rdfs:label 'Supporting Document Refs' ;
    rdfs:comment 'Comma-separated list of document identifiers or URLs that provide evidence for the dispute.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractEotClaimId rdf:type rdf:Property ;
    rdfs:label 'Contract Eot Claim Id' ;
    rdfs:comment 'System generated unique identifier for the EOT claim record.' ;
    rdfs:domain ind:ContractEotClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:claimRelatedNcrId rdf:type rdf:Property ;
    rdfs:label 'Claim Related Ncr Id' ;
    rdfs:comment 'Identifier of a Non-Conformance Report linked to the claim.' ;
    rdfs:domain ind:ContractEotClaim ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Ncr .

ind:claimRelatedRfiId rdf:type rdf:Property ;
    rdfs:label 'Claim Related Rfi Id' ;
    rdfs:comment 'Identifier of a Request for Information that is associated with the claim.' ;
    rdfs:domain ind:ContractEotClaim ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Rfi .

ind:primaryContractEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Contract Employee Id' ;
    rdfs:comment 'Identifier of the engineer or assessor responsible for the claim evaluation.' ;
    rdfs:domain ind:ContractEotClaim ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryContractClaimUpdatedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Contract Claim Updated By User Employee Id' ;
    rdfs:comment 'System user identifier who last modified the claim.' ;
    rdfs:domain ind:ContractEotClaim ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:claimApprovedBy rdf:type rdf:Property ;
    rdfs:label 'Claim Approved By' ;
    rdfs:comment 'Name of the individual who approved or rejected the claim.' ;
    rdfs:domain ind:ContractEotClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimAssessorComments rdf:type rdf:Property ;
    rdfs:label 'Claim Assessor Comments' ;
    rdfs:comment 'Free-text comments entered by the engineer or assessor during evaluation.' ;
    rdfs:domain ind:ContractEotClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimCreatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Claim Created Timestamp' ;
    rdfs:comment 'Timestamp when the claim record was first created in the system.' ;
    rdfs:domain ind:ContractEotClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:claimDecisionDate rdf:type rdf:Property ;
    rdfs:label 'Claim Decision Date' ;
    rdfs:comment 'Date when the final decision on the claim was recorded.' ;
    rdfs:domain ind:ContractEotClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:claimExternalReference rdf:type rdf:Property ;
    rdfs:label 'Claim External Reference' ;
    rdfs:comment 'Reference number used by external parties (e.g., client or auditor) to identify the claim.' ;
    rdfs:domain ind:ContractEotClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimFinalAmount rdf:type rdf:Property ;
    rdfs:label 'Claim Final Amount' ;
    rdfs:comment 'Final monetary amount after any adjustments or partial approvals.' ;
    rdfs:domain ind:ContractEotClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:claimFinalDays rdf:type rdf:Property ;
    rdfs:label 'Claim Final Days' ;
    rdfs:comment 'Total number of days finally approved for the extension.' ;
    rdfs:domain ind:ContractEotClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:claimImpactOnMilestones rdf:type rdf:Property ;
    rdfs:label 'Claim Impact On Milestones' ;
    rdfs:comment 'Explanation of how the extension affects key project milestones.' ;
    rdfs:domain ind:ContractEotClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimIsCritical rdf:type rdf:Property ;
    rdfs:label 'Claim Is Critical' ;
    rdfs:comment 'True if the claim is deemed critical to project delivery or financial exposure.' ;
    rdfs:domain ind:ContractEotClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:claimNewScheduleDate rdf:type rdf:Property ;
    rdfs:label 'Claim New Schedule Date' ;
    rdfs:comment 'Projected completion date after applying the approved extension.' ;
    rdfs:domain ind:ContractEotClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:claimNotes rdf:type rdf:Property ;
    rdfs:label 'Claim Notes' ;
    rdfs:comment 'Additional free-form notes captured by any stakeholder.' ;
    rdfs:domain ind:ContractEotClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimNumber rdf:type rdf:Property ;
    rdfs:label 'Claim Number' ;
    rdfs:comment 'Unique claim number assigned by the contractor or system for tracking.' ;
    rdfs:domain ind:ContractEotClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimOriginalScheduleDate rdf:type rdf:Property ;
    rdfs:label 'Claim Original Schedule Date' ;
    rdfs:comment 'Baseline project completion date before any extensions.' ;
    rdfs:domain ind:ContractEotClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:claimPriority rdf:type rdf:Property ;
    rdfs:label 'Claim Priority' ;
    rdfs:comment 'Priority level assigned to the claim for processing urgency.' ;
    rdfs:domain ind:ContractEotClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimResolutionDate rdf:type rdf:Property ;
    rdfs:label 'Claim Resolution Date' ;
    rdfs:comment 'Date when the claim was fully closed and any adjustments were posted.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:claimReviewDate rdf:type rdf:Property ;
    rdfs:label 'Claim Review Date' ;
    rdfs:comment 'Date on which the claim was formally reviewed by the project engineer.' ;
    rdfs:domain ind:ContractEotClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:claimSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Claim Source System' ;
    rdfs:comment 'Originating operational system where the claim was first recorded.' ;
    rdfs:domain ind:ContractEotClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimStatus rdf:type rdf:Property ;
    rdfs:label 'Claim Status' ;
    rdfs:comment 'Current processing status of the claim within the claim lifecycle.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimStatusReason rdf:type rdf:Property ;
    rdfs:label 'Claim Status Reason' ;
    rdfs:comment 'Explanation for the current status, such as reason for rejection or hold.' ;
    rdfs:domain ind:ContractEotClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimSubmissionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Claim Submission Timestamp' ;
    rdfs:comment 'Date and time when the contractor formally submitted the EOT claim.' ;
    rdfs:domain ind:ContractEotClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:claimType rdf:type rdf:Property ;
    rdfs:label 'Claim Type' ;
    rdfs:comment 'Category describing the contractual basis for the time extension request.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Claim Updated Timestamp' ;
    rdfs:comment 'Timestamp of the most recent modification to the claim record.' ;
    rdfs:domain ind:ContractEotClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:daysAssessed rdf:type rdf:Property ;
    rdfs:label 'Days Assessed' ;
    rdfs:comment 'Number of days approved by the engineer after assessment.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:daysClaimed rdf:type rdf:Property ;
    rdfs:label 'Days Claimed' ;
    rdfs:comment 'Number of calendar days the contractor claims as an extension.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:delayEventDescription rdf:type rdf:Property ;
    rdfs:label 'Delay Event Description' ;
    rdfs:comment 'Narrative description of the event that caused the schedule delay.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:determinationOutcome rdf:type rdf:Property ;
    rdfs:label 'Determination Outcome' ;
    rdfs:comment 'Final decision result after engineering review.' ;
    rdfs:domain ind:ContractEotClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entitlementBasis rdf:type rdf:Property ;
    rdfs:label 'Entitlement Basis' ;
    rdfs:comment 'FIDIC sub-clause or contractual provision that justifies the claim.' ;
    rdfs:domain ind:ContractEotClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:liquidatedDamagesImpact rdf:type rdf:Property ;
    rdfs:label 'Liquidated Damages Impact' ;
    rdfs:comment 'Estimated reduction in liquidated damages exposure due to the approved extension.' ;
    rdfs:domain ind:ContractEotClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contractMilestoneId rdf:type rdf:Property ;
    rdfs:label 'Contract Milestone Id' ;
    rdfs:comment 'System-generated unique identifier for the contract milestone record.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ContractMilestone .

ind:responsiblePartyId rdf:type rdf:Property ;
    rdfs:label 'Responsible Party Id' ;
    rdfs:comment 'Identifier of the party (e.g., contractor, project manager) responsible for delivering the milestone.' ;
    rdfs:domain ind:ContractMilestone ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:actualDate rdf:type rdf:Property ;
    rdfs:label 'Actual Date' ;
    rdfs:comment 'Date the milestone was actually achieved or certified.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:amendmentReason rdf:type rdf:Property ;
    rdfs:label 'Amendment Reason' ;
    rdfs:comment 'Reason provided for the most recent amendment to the milestone.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractMilestoneDescription rdf:type rdf:Property ;
    rdfs:label 'Contract Milestone Description' ;
    rdfs:comment 'Free-text description providing additional context for the milestone.' ;
    rdfs:domain ind:ContractMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractMilestoneStatus rdf:type rdf:Property ;
    rdfs:label 'Contract Milestone Status' ;
    rdfs:comment 'Current lifecycle status of the milestone.' ;
    rdfs:domain ind:ContractMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costVarianceAmount rdf:type rdf:Property ;
    rdfs:label 'Cost Variance Amount' ;
    rdfs:comment 'Difference between milestone_value and amount actually paid.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:defectsNotifiedDate rdf:type rdf:Property ;
    rdfs:label 'Defects Notified Date' ;
    rdfs:comment 'Date the employer formally notified the contractor of defects.' ;
    rdfs:domain ind:ContractMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dlpStartDate rdf:type rdf:Property ;
    rdfs:label 'Dlp Start Date' ;
    rdfs:comment 'Start date of the Defects Liability Period associated with the milestone.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:finalCertificateIssuedDate rdf:type rdf:Property ;
    rdfs:label 'Final Certificate Issued Date' ;
    rdfs:comment 'Date the final completion certificate was issued.' ;
    rdfs:domain ind:ContractMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:forecastDate rdf:type rdf:Property ;
    rdfs:label 'Forecast Date' ;
    rdfs:comment 'Updated forecasted date based on progress and risk assessments.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ldRatePerDay rdf:type rdf:Property ;
    rdfs:label 'Ld Rate Per Day' ;
    rdfs:comment 'Daily rate applied if liquidated damages are triggered.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ldTriggered rdf:type rdf:Property ;
    rdfs:label 'Ld Triggered' ;
    rdfs:comment 'Indicates whether liquidated damages have been incurred for this milestone.' ;
    rdfs:domain ind:ContractMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:milestoneCode rdf:type rdf:Property ;
    rdfs:label 'Milestone Code' ;
    rdfs:comment 'Business identifier code for the milestone, used in contracts and payment schedules.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:milestoneName rdf:type rdf:Property ;
    rdfs:label 'Milestone Name' ;
    rdfs:comment 'Descriptive name of the milestone (e.g., Notice to Proceed, Practical Completion).' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:milestoneType rdf:type rdf:Property ;
    rdfs:label 'Milestone Type' ;
    rdfs:comment 'Classification of the milestone type according to contract terminology.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:milestoneValue rdf:type rdf:Property ;
    rdfs:label 'Milestone Value' ;
    rdfs:comment 'Monetary value of the milestone, often linked to a payment certificate.' ;
    rdfs:domain ind:ContractMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:outstandingDefectsFlag rdf:type rdf:Property ;
    rdfs:label 'Outstanding Defects Flag' ;
    rdfs:comment 'Indicates whether any defects remain unresolved at DLP expiry.' ;
    rdfs:domain ind:ContractMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:paymentCertificateDate rdf:type rdf:Property ;
    rdfs:label 'Payment Certificate Date' ;
    rdfs:comment 'Date the payment certificate was issued.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Payment Certificate Number' ;
    rdfs:comment 'Reference number of the payment certificate linked to the milestone.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:performanceCertificateDate rdf:type rdf:Property ;
    rdfs:label 'Performance Certificate Date' ;
    rdfs:comment 'Date the performance certificate was issued.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:performanceCertificateIssued rdf:type rdf:Property ;
    rdfs:label 'Performance Certificate Issued' ;
    rdfs:comment 'Flag showing if a performance certificate has been issued for the milestone.' ;
    rdfs:domain ind:ContractMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:plannedDate rdf:type rdf:Property ;
    rdfs:label 'Planned Date' ;
    rdfs:comment 'Date originally scheduled for the milestone in the contract baseline.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rectificationDeadline rdf:type rdf:Property ;
    rdfs:label 'Rectification Deadline' ;
    rdfs:comment 'Deadline by which the contractor must rectify notified defects.' ;
    rdfs:domain ind:ContractMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:retentionAmount rdf:type rdf:Property ;
    rdfs:label 'Retention Amount' ;
    rdfs:comment 'Portion of the milestone value retained until final acceptance.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:retentionReleaseDate rdf:type rdf:Property ;
    rdfs:label 'Retention Release Date' ;
    rdfs:comment 'Scheduled date for releasing retained amounts after final acceptance.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scheduleVarianceDays rdf:type rdf:Property ;
    rdfs:label 'Schedule Variance Days' ;
    rdfs:comment 'Difference in days between planned_date and actual_date.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:clientContactId rdf:type rdf:Property ;
    rdfs:label 'Client Contact Id' ;
    rdfs:comment 'Foreign key linking to client.contact. Business justification: Needed for Communication Log and Regulatory Contact Register to identify the primary client contact responsible for a contract party.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Contact .

ind:contactEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Contact Employee Id' ;
    rdfs:comment 'Foreign key linking to hr.employee. Business justification: Identifies the internal employee liaison for each contract party; used in communication logs and stakeholder registers.' ;
    rdfs:domain ind:Party ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:bankAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Bank Account Number' ;
    rdfs:comment 'Account number used for contract-related payments.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankName rdf:type rdf:Property ;
    rdfs:label 'Bank Name' ;
    rdfs:comment 'Financial institution where the party\'s account is held.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactEmail rdf:type rdf:Property ;
    rdfs:label 'Contact Email' ;
    rdfs:comment 'Main email used for contractual communications.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactPhone rdf:type rdf:Property ;
    rdfs:label 'Contact Phone' ;
    rdfs:comment 'Primary telephone number for reaching the party.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Insurance Certificate Number' ;
    rdfs:comment 'Reference number of the insurance policy covering the party.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Insurance Expiry Date' ;
    rdfs:comment 'Date when the provided insurance coverage ends.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isJvPartner rdf:type rdf:Property ;
    rdfs:label 'Is Jv Partner' ;
    rdfs:comment 'True when the party participates as a JV partner in the contract.' ;
    rdfs:domain ind:Party ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPrimaryParty rdf:type rdf:Property ;
    rdfs:label 'Is Primary Party' ;
    rdfs:comment 'True when the party is the main responsible entity for the contract.' ;
    rdfs:domain ind:Party ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:legalEntityName rdf:type rdf:Property ;
    rdfs:label 'Legal Entity Name' ;
    rdfs:comment 'Official registered name of the corporate entity.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:liabilityLimitAmount rdf:type rdf:Property ;
    rdfs:label 'Liability Limit Amount' ;
    rdfs:comment 'Monetary cap on the party\'s contractual liability.' ;
    rdfs:domain ind:Party ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:participationPercentage rdf:type rdf:Property ;
    rdfs:label 'Participation Percentage' ;
    rdfs:comment 'Percentage of ownership or profit share for joint-venture partners.' ;
    rdfs:domain ind:Party ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:partyName rdf:type rdf:Property ;
    rdfs:label 'Party Name' ;
    rdfs:comment 'Full legal name of the party (individual or organization) as it appears in the contract.' ;
    rdfs:domain ind:Party ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partyStatus rdf:type rdf:Property ;
    rdfs:label 'Party Status' ;
    rdfs:comment 'Operational status of the party within the contract management system.' ;
    rdfs:domain ind:Party ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partyType rdf:type rdf:Property ;
    rdfs:label 'Party Type' ;
    rdfs:comment 'Category that defines the business role of the party in construction contracts.' ;
    rdfs:domain ind:Party ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Record Source System' ;
    rdfs:comment 'Name of the operational system of record that originated the party data.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roleInContract rdf:type rdf:Property ;
    rdfs:label 'Role In Contract' ;
    rdfs:comment 'The functional role the party plays for the specific contract (e.g., owner, contractor).' ;
    rdfs:domain ind:Party ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signatoryAuthority rdf:type rdf:Property ;
    rdfs:label 'Signatory Authority' ;
    rdfs:comment 'True when the party is authorized to execute the contract on behalf of its organization.' ;
    rdfs:domain ind:Party ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:taxIdentifier rdf:type rdf:Property ;
    rdfs:label 'Tax Identifier' ;
    rdfs:comment 'Government-issued tax ID for the party.' ;
    rdfs:domain ind:Party ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentCertificateId rdf:type rdf:Property ;
    rdfs:label 'Payment Certificate Id' ;
    rdfs:comment 'System-generated unique identifier for the payment certificate record.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PaymentCertificate .

ind:primaryPaymentEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Payment Employee Id' ;
    rdfs:comment 'Identifier of the person or authority who certified the payment.' ;
    rdfs:domain ind:PaymentCertificate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualPaymentDate rdf:type rdf:Property ;
    rdfs:label 'Actual Payment Date' ;
    rdfs:comment 'Date on which the payment was actually received.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:advanceRecoveryAmount rdf:type rdf:Property ;
    rdfs:label 'Advance Recovery Amount' ;
    rdfs:comment 'Amount recovered against any previously paid advances.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:certificationDate rdf:type rdf:Property ;
    rdfs:label 'Certification Date' ;
    rdfs:comment 'Timestamp when the certificate was formally issued.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationVersion rdf:type rdf:Property ;
    rdfs:label 'Certification Version' ;
    rdfs:comment 'Version number for revised certificates.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certifiedAmount rdf:type rdf:Property ;
    rdfs:label 'Certified Amount' ;
    rdfs:comment 'Gross amount certified for payment before deductions.' ;
    rdfs:domain ind:PaymentCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:invoiceDate rdf:type rdf:Property ;
    rdfs:label 'Invoice Date' ;
    rdfs:comment 'Date the invoice was issued.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:invoiceNumber rdf:type rdf:Property ;
    rdfs:label 'Invoice Number' ;
    rdfs:comment 'Reference to the invoice generated for this certificate.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isAdvanceRecovered rdf:type rdf:Property ;
    rdfs:label 'Is Advance Recovered' ;
    rdfs:comment 'True when an advance payment is being recovered.' ;
    rdfs:domain ind:PaymentCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isLdApplied rdf:type rdf:Property ;
    rdfs:label 'Is Ld Applied' ;
    rdfs:comment 'True when liquidated damages are deducted.' ;
    rdfs:domain ind:PaymentCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPayWhenPaid rdf:type rdf:Property ;
    rdfs:label 'Is Pay When Paid' ;
    rdfs:comment 'Indicates whether payment is contingent on receipt of funds from the client.' ;
    rdfs:domain ind:PaymentCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRetentionApplied rdf:type rdf:Property ;
    rdfs:label 'Is Retention Applied' ;
    rdfs:comment 'Indicates if retention is being held for this certificate.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ldDeductionAmount rdf:type rdf:Property ;
    rdfs:label 'Ld Deduction Amount' ;
    rdfs:comment 'Deduction applied for liquidated damages, if any.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netAmountDue rdf:type rdf:Property ;
    rdfs:label 'Net Amount Due' ;
    rdfs:comment 'Final payable amount after all deductions.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentCertificateStatus rdf:type rdf:Property ;
    rdfs:label 'Payment Certificate Status' ;
    rdfs:comment 'Current lifecycle state of the certificate.' ;
    rdfs:domain ind:PaymentCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentDueDate rdf:type rdf:Property ;
    rdfs:label 'Payment Due Date' ;
    rdfs:comment 'Date by which the net amount is contractually due.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentMethod rdf:type rdf:Property ;
    rdfs:label 'Payment Method' ;
    rdfs:comment 'Means by which the payment will be made.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentStatus rdf:type rdf:Property ;
    rdfs:label 'Payment Status' ;
    rdfs:comment 'Current status of the payment transaction.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentType rdf:type rdf:Property ;
    rdfs:label 'Payment Type' ;
    rdfs:comment 'Indicates whether the certificate is for an interim or final payment.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workProgressPercent rdf:type rdf:Property ;
    rdfs:label 'Work Progress Percent' ;
    rdfs:comment 'Percentage of work completed as reported for this certificate.' ;
    rdfs:domain ind:PaymentCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contractRetentionLedgerId rdf:type rdf:Property ;
    rdfs:label 'Contract Retention Ledger Id' ;
    rdfs:comment 'System-generated unique identifier for each retention ledger record.' ;
    rdfs:domain ind:ContractRetentionLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contractMilestoneCode rdf:type rdf:Property ;
    rdfs:label 'Contract Milestone Code' ;
    rdfs:comment 'Code representing the contract milestone tied to this retention entry.' ;
    rdfs:domain ind:ContractRetentionLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractRetentionLedgerStatus rdf:type rdf:Property ;
    rdfs:label 'Contract Retention Ledger Status' ;
    rdfs:comment 'Current lifecycle status of the retention ledger entry.' ;
    rdfs:domain ind:ContractRetentionLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cumulativeRetentionBalance rdf:type rdf:Property ;
    rdfs:label 'Cumulative Retention Balance' ;
    rdfs:comment 'Running total of retention still held after this release.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:effectiveTimestamp rdf:type rdf:Property ;
    rdfs:label 'Effective Timestamp' ;
    rdfs:comment 'Exact point in time when the retention entry became effective.' ;
    rdfs:domain ind:ContractRetentionLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:releaseAmount rdf:type rdf:Property ;
    rdfs:label 'Release Amount' ;
    rdfs:comment 'Amount of retention released in this transaction (partial or full).' ;
    rdfs:domain ind:ContractRetentionLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:releaseReason rdf:type rdf:Property ;
    rdfs:label 'Release Reason' ;
    rdfs:comment 'Free-text explanation for why the retention was released (e.g., milestone achieved, DLP expiry).' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retentionAdjustmentAmount rdf:type rdf:Property ;
    rdfs:label 'Retention Adjustment Amount' ;
    rdfs:comment 'Monetary adjustment to the retention (positive or negative) applied after initial calculation.' ;
    rdfs:domain ind:ContractRetentionLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:retentionAdjustmentReason rdf:type rdf:Property ;
    rdfs:label 'Retention Adjustment Reason' ;
    rdfs:comment 'Explanation for why a retention adjustment was made.' ;
    rdfs:domain ind:ContractRetentionLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retentionBondAmount rdf:type rdf:Property ;
    rdfs:label 'Retention Bond Amount' ;
    rdfs:comment 'Monetary value of the retention bond when substitution occurs.' ;
    rdfs:domain ind:ContractRetentionLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:retentionBondCurrency rdf:type rdf:Property ;
    rdfs:label 'Retention Bond Currency' ;
    rdfs:comment 'Currency of the retention bond amount.' ;
    rdfs:domain ind:ContractRetentionLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retentionBondSubstitutedFlag rdf:type rdf:Property ;
    rdfs:label 'Retention Bond Substituted Flag' ;
    rdfs:comment 'Indicates whether a retention bond was used in place of cash retention.' ;
