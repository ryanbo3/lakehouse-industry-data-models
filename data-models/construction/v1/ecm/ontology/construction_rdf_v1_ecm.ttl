    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:separationProcessedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Separation Processed By Employee Id' ;
    rdfs:comment 'Identifier of the HR staff member who processed the separation.' ;
    rdfs:domain ind:Separation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:benefitsTerminationDate rdf:type rdf:Property ;
    rdfs:label 'Benefits Termination Date' ;
    rdfs:comment 'Date on which employee benefits coverage ends.' ;
