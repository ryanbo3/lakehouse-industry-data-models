    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DocumentRegister .

ind:rfiId rdf:type rdf:Property ;
    rdfs:label 'Rfi Id' ;
    rdfs:comment 'Foreign key linking to design.rfi. Business justification: Bid clarifications often arise from RFIs; linking a clarification to its originating RFI tracks the source of the question.' ;
    rdfs:domain ind:Construction ;
