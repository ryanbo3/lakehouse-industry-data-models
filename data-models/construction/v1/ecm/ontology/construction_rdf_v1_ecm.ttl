ind:glAccountId rdf:type rdf:Property ;
    rdfs:label 'Gl Account Id' ;
    rdfs:comment 'Foreign key linking to finance.gl_account. Business justification: Maps bid bond liability to a GL account for proper accounting entry, essential for financial statements and bond guarantee reporting.' ;
    rdfs:domain ind:Construction ;
