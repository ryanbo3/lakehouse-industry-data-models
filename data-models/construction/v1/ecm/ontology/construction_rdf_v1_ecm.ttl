ind:subject rdf:type rdf:Property ;
    rdfs:label 'Subject' ;
    rdfs:comment 'Brief summary of the communication subject.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountId rdf:type rdf:Property ;
    rdfs:label 'Account Id' ;
    rdfs:comment 'Unique identifier of the client organization that the opportunity targets.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Account .

ind:costCenterId rdf:type rdf:Property ;
    rdfs:label 'Cost Center Id' ;
    rdfs:comment 'Foreign key linking to finance.cost_center. Business justification: Required for Cost Allocation Report: tracks which finance cost center funds bid preparation expenses, essential for budgeting and profitability analysis of each bid opportunity.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostCenter .

ind:esgReportId rdf:type rdf:Property ;
    rdfs:label 'Esg Report Id' ;
    rdfs:comment 'Foreign key linking to sustainability.esg_report. Business justification: ESG compliance review during bid qualification requires linking each opportunity to the relevant ESG report per regulatory ESG reporting mandates.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EsgReport .

ind:jvPartnerId rdf:type rdf:Property ;
    rdfs:label 'Jv Partner Id' ;
    rdfs:comment 'Foreign key linking to bid.jv_partner. Business justification: Bid opportunity may involve a joint venture partner; replace string with FK to jv_partner for referential integrity.' ;
    rdfs:domain ind:Bid ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:JvPartner .

ind:bidBondAmount rdf:type rdf:Property ;
    rdfs:label 'Bid Bond Amount' ;
    rdfs:comment 'Financial guarantee amount required to submit the bid.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bidDecision rdf:type rdf:Property ;
    rdfs:label 'Bid Decision' ;
    rdfs:comment 'Decision on whether to submit a bid for the opportunity.' ;
    rdfs:domain ind:BidOpportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bidDueDate rdf:type rdf:Property ;
    rdfs:label 'Bid Due Date' ;
    rdfs:comment 'Final date by which the bid must be submitted.' ;
    rdfs:domain ind:BidOpportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:countryCode rdf:type rdf:Property ;
    rdfs:label 'Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the project location.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discountAmount rdf:type rdf:Property ;
    rdfs:label 'Discount Amount' ;
    rdfs:comment 'Any discount applied to the estimated contract value during bid preparation.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedContractValue rdf:type rdf:Property ;
    rdfs:label 'Estimated Contract Value' ;
    rdfs:comment 'Projected total contract value before any adjustments.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:expectedEndDate rdf:type rdf:Property ;
    rdfs:label 'Expected End Date' ;
    rdfs:comment 'Planned completion date of the project if the bid is won.' ;
    rdfs:domain ind:BidOpportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:expectedStartDate rdf:type rdf:Property ;
    rdfs:label 'Expected Start Date' ;
    rdfs:comment 'Planned start date of the project if the bid is won.' ;
    rdfs:domain ind:BidOpportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:gmpType rdf:type rdf:Property ;
    rdfs:label 'Gmp Type' ;
    rdfs:comment 'Type of pricing model used in the bid (e.g., Guaranteed Maximum Price).' ;
    rdfs:domain ind:BidOpportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isJointVenture rdf:type rdf:Property ;
    rdfs:label 'Is Joint Venture' ;
    rdfs:comment 'Indicates whether the bid is being submitted as a joint venture.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:marketSegment rdf:type rdf:Property ;
    rdfs:label 'Market Segment' ;
    rdfs:comment 'Business segment or market category the opportunity belongs to.' ;
    rdfs:domain ind:BidOpportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netEstimatedValue rdf:type rdf:Property ;
    rdfs:label 'Net Estimated Value' ;
    rdfs:comment 'Estimated contract value after discounts and adjustments.' ;
    rdfs:domain ind:BidOpportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:opportunityName rdf:type rdf:Property ;
    rdfs:label 'Opportunity Name' ;
    rdfs:comment 'Descriptive name of the bid opportunity, typically reflecting the project or client.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:opportunityNumber rdf:type rdf:Property ;
    rdfs:label 'Opportunity Number' ;
    rdfs:comment 'External reference number assigned to the opportunity, used in client communications and reporting.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pipelineForecastCategory rdf:type rdf:Property ;
    rdfs:label 'Pipeline Forecast Category' ;
    rdfs:comment 'Classification used for forecasting and reporting of the opportunity.' ;
    rdfs:domain ind:BidOpportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:probabilityOfWin rdf:type rdf:Property ;
    rdfs:label 'Probability Of Win' ;
    rdfs:comment 'Estimated likelihood of winning the opportunity expressed as a percentage.' ;
    rdfs:domain ind:BidOpportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:projectType rdf:type rdf:Property ;
    rdfs:label 'Project Type' ;
    rdfs:comment 'Classification of the project type for the opportunity.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceChannel rdf:type rdf:Property ;
    rdfs:label 'Source Channel' ;
    rdfs:comment 'Origin channel through which the opportunity was generated.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stage rdf:type rdf:Property ;
    rdfs:label 'Stage' ;
    rdfs:comment 'Current lifecycle stage of the opportunity within the sales pipeline.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:winLossStatus rdf:type rdf:Property ;
    rdfs:label 'Win Loss Status' ;
    rdfs:comment 'Outcome of the opportunity after the bid process concludes.' ;
    rdfs:domain ind:BidOpportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bidPrequalificationId rdf:type rdf:Property ;
    rdfs:label 'Bid Prequalification Id' ;
    rdfs:comment 'Unique surrogate key for each prequalification record.' ;
    rdfs:domain ind:BidPrequalification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:regulatoryObligationId rdf:type rdf:Property ;
    rdfs:label 'Regulatory Obligation Id' ;
    rdfs:comment 'Foreign key linking to compliance.regulatory_obligation. Business justification: Prequalification process validates that the contractor meets required regulatory obligations for the project.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RegulatoryObligation .

ind:bidBondCurrency rdf:type rdf:Property ;
    rdfs:label 'Bid Bond Currency' ;
    rdfs:comment 'ISO 4217 currency code for the bid bond amount.' ;
    rdfs:domain ind:BidPrequalification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bidBondExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Bid Bond Expiry Date' ;
    rdfs:comment 'Date the bid bond must be released or returned.' ;
    rdfs:domain ind:BidPrequalification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:bidBondRequired rdf:type rdf:Property ;
    rdfs:label 'Bid Bond Required' ;
    rdfs:comment 'Indicates whether a bid bond must be posted for this prequalification.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:bidPrequalificationStatus rdf:type rdf:Property ;
    rdfs:label 'Bid Prequalification Status' ;
    rdfs:comment 'Current lifecycle status of the prequalification.' ;
    rdfs:domain ind:BidPrequalification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveFrom rdf:type rdf:Property ;
    rdfs:label 'Effective From' ;
    rdfs:comment 'Date the prequalification becomes effective for tender participation.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectiveUntil rdf:type rdf:Property ;
    rdfs:label 'Effective Until' ;
    rdfs:comment 'Date the prequalification ceases to be effective (nullable for open-ended).' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:evaluationScore rdf:type rdf:Property ;
    rdfs:label 'Evaluation Score' ;
    rdfs:comment 'Numeric score (0-100) from the client’s evaluation of the prequalification.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:financialCapacityCurrency rdf:type rdf:Property ;
    rdfs:label 'Financial Capacity Currency' ;
    rdfs:comment 'ISO 4217 currency code for the financial capacity threshold.' ;
    rdfs:domain ind:BidPrequalification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialCapacityThreshold rdf:type rdf:Property ;
    rdfs:label 'Financial Capacity Threshold' ;
    rdfs:comment 'Minimum financial capacity (in currency) required to be eligible.' ;
    rdfs:domain ind:BidPrequalification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hssePerformanceScore rdf:type rdf:Property ;
    rdfs:label 'Hsse Performance Score' ;
    rdfs:comment 'Score (0-100) summarising health, safety, security and environmental performance.' ;
    rdfs:domain ind:BidPrequalification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastReviewDate rdf:type rdf:Property ;
    rdfs:label 'Last Review Date' ;
    rdfs:comment 'Date the prequalification was last reviewed for renewal or amendment.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:prequalificationCategory rdf:type rdf:Property ;
    rdfs:label 'Prequalification Category' ;
    rdfs:comment 'Classification of the prequalification based on scope and partnership type.' ;
    rdfs:domain ind:BidPrequalification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:procurementCategory rdf:type rdf:Property ;
    rdfs:label 'Procurement Category' ;
    rdfs:comment 'High-level category of goods or services the prequalification covers.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reference rdf:type rdf:Property ;
    rdfs:label 'Reference' ;
    rdfs:comment 'Business identifier assigned to the prequalification (e.g., PQ-2023-001).' ;
    rdfs:domain ind:Bid ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryApprovalRequired rdf:type rdf:Property ;
    rdfs:label 'Regulatory Approval Required' ;
    rdfs:comment 'True if external regulatory approval is needed for the prequalification.' ;
    rdfs:domain ind:Bid ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Regulatory Approval Status' ;
    rdfs:comment 'Current status of any required regulatory approval.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionDate rdf:type rdf:Property ;
    rdfs:label 'Submission Date' ;
    rdfs:comment 'Date the prequalification was submitted to the client.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technicalCapacityScore rdf:type rdf:Property ;
    rdfs:label 'Technical Capacity Score' ;
    rdfs:comment 'Score (0-100) reflecting technical capability to deliver the work.' ;
    rdfs:domain ind:BidPrequalification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:versionNumber rdf:type rdf:Property ;
    rdfs:label 'Version Number' ;
    rdfs:comment 'Incremental version of the prequalification record for change tracking.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bidRiskId rdf:type rdf:Property ;
    rdfs:label 'Bid Risk Id' ;
    rdfs:comment 'System-generated unique identifier for the bid risk record.' ;
    rdfs:domain ind:BidRisk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bidEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Bid Employee Id' ;
    rdfs:comment 'FK to hr.employee' ;
    rdfs:domain ind:BidRisk ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:climateRiskAssessmentId rdf:type rdf:Property ;
    rdfs:label 'Climate Risk Assessment Id' ;
    rdfs:comment 'Foreign key linking to sustainability.climate_risk_assessment. Business justification: Bid risk registers include climate risk assessments; the FK ties each risk entry to its detailed climate risk assessment.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ClimateRiskAssessment .

ind:ownerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Owner Employee Id' ;
    rdfs:comment 'FK to hr.employee' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:permitConditionId rdf:type rdf:Property ;
    rdfs:label 'Permit Condition Id' ;
    rdfs:comment 'Foreign key linking to compliance.permit_condition. Business justification: Risk register links each risk to a specific permit condition that may trigger compliance penalties.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PermitCondition .

ind:primaryBidEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Bid Employee Id' ;
    rdfs:comment 'Identifier of the person or organisation responsible for managing the risk.' ;
    rdfs:domain ind:BidRisk ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:relatedBidBidSubmissionId rdf:type rdf:Property ;
    rdfs:label 'Related Bid Bid Submission Id' ;
    rdfs:comment 'Identifier of the bid to which this risk is attached.' ;
    rdfs:domain ind:BidRisk ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Submission .

ind:assessmentMethod rdf:type rdf:Property ;
    rdfs:label 'Assessment Method' ;
    rdfs:comment 'Methodology used to evaluate the risk.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attachedDocuments rdf:type rdf:Property ;
    rdfs:label 'Attached Documents' ;
    rdfs:comment 'Comma-separated list of document identifiers linked to the risk.' ;
    rdfs:domain ind:BidRisk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bidRiskStatus rdf:type rdf:Property ;
    rdfs:label 'Bid Risk Status' ;
    rdfs:comment 'Current lifecycle state of the risk.' ;
    rdfs:domain ind:BidRisk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closedDate rdf:type rdf:Property ;
    rdfs:label 'Closed Date' ;
    rdfs:comment 'Date the risk was formally closed.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contingencyAmount rdf:type rdf:Property ;
    rdfs:label 'Contingency Amount' ;
    rdfs:comment 'Financial reserve allocated to cover the risk in the bid price.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contingencyPercentage rdf:type rdf:Property ;
    rdfs:label 'Contingency Percentage' ;
    rdfs:comment 'Contingency expressed as a percentage of the estimated cost impact.' ;
    rdfs:domain ind:Bid ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exposureCurrency rdf:type rdf:Property ;
    rdfs:label 'Exposure Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for monetary impact fields.' ;
    rdfs:domain ind:BidRisk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:identifiedDate rdf:type rdf:Property ;
    rdfs:label 'Identified Date' ;
    rdfs:comment 'Date the risk was first recorded.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:impactCost rdf:type rdf:Property ;
    rdfs:label 'Impact Cost' ;
    rdfs:comment 'Estimated monetary impact if the risk materialises, expressed in the project currency.' ;
    rdfs:domain ind:BidRisk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:impactQuality rdf:type rdf:Property ;
    rdfs:label 'Impact Quality' ;
    rdfs:comment 'Qualitative effect of the risk on project quality standards.' ;
    rdfs:domain ind:BidRisk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impactScheduleDays rdf:type rdf:Property ;
    rdfs:label 'Impact Schedule Days' ;
    rdfs:comment 'Estimated schedule delay in days caused by the risk.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isKeyRisk rdf:type rdf:Property ;
    rdfs:label 'Is Key Risk' ;
    rdfs:comment 'Flag indicating whether the risk is considered a key risk for the bid.' ;
    rdfs:domain ind:BidRisk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mitigationEndDate rdf:type rdf:Property ;
    rdfs:label 'Mitigation End Date' ;
    rdfs:comment 'Planned or actual completion date for mitigation.' ;
    rdfs:domain ind:BidRisk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mitigationStartDate rdf:type rdf:Property ;
    rdfs:label 'Mitigation Start Date' ;
    rdfs:comment 'Planned start date for mitigation activities.' ;
    rdfs:domain ind:BidRisk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mitigationStrategy rdf:type rdf:Property ;
    rdfs:label 'Mitigation Strategy' ;
    rdfs:comment 'Planned actions to reduce probability or impact of the risk.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:origin rdf:type rdf:Property ;
    rdfs:label 'Origin' ;
    rdfs:comment 'Origin of the risk, indicating whether it arises from internal processes or external factors.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priority rdf:type rdf:Property ;
    rdfs:label 'Priority' ;
    rdfs:comment 'Prioritisation level used for reporting and escalation.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:probabilityRating rdf:type rdf:Property ;
    rdfs:label 'Probability Rating' ;
    rdfs:comment 'Likelihood of the risk occurring, expressed as a qualitative rating.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:residualImpactCost rdf:type rdf:Property ;
    rdfs:label 'Residual Impact Cost' ;
    rdfs:comment 'Estimated monetary impact remaining after mitigation.' ;
    rdfs:domain ind:BidRisk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:residualProbability rdf:type rdf:Property ;
    rdfs:label 'Residual Probability' ;
    rdfs:comment 'Likelihood of the risk after mitigation actions are applied.' ;
    rdfs:domain ind:BidRisk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:residualRiskScore rdf:type rdf:Property ;
    rdfs:label 'Residual Risk Score' ;
    rdfs:comment 'Risk score after mitigation, used for ongoing monitoring.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewFrequency rdf:type rdf:Property ;
    rdfs:label 'Review Frequency' ;
    rdfs:comment 'How often the risk is reviewed and re-assessed.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskCategory rdf:type rdf:Property ;
    rdfs:label 'Risk Category' ;
    rdfs:comment 'Primary classification of the risk affecting the bid phase.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskCode rdf:type rdf:Property ;
    rdfs:label 'Risk Code' ;
    rdfs:comment 'External reference code used by project teams to identify the risk in reports and documents.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskDescription rdf:type rdf:Property ;
    rdfs:label 'Risk Description' ;
    rdfs:comment 'Detailed narrative describing the nature, cause and potential consequences of the risk.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:score rdf:type rdf:Property ;
    rdfs:label 'Score' ;
    rdfs:comment 'Composite score derived from probability and impact, used for prioritisation.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:title rdf:type rdf:Property ;
    rdfs:label 'Title' ;
    rdfs:comment 'Brief human-readable title that summarises the risk.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionId rdf:type rdf:Property ;
    rdfs:label 'Submission Id' ;
    rdfs:comment 'Unique identifier for the bid submission event.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Submission .

ind:compliancePermitId rdf:type rdf:Property ;
    rdfs:label 'Compliance Permit Id' ;
    rdfs:comment 'Foreign key linking to compliance.permit. Business justification: Bid Submission Compliance Checklist requires attaching the required permit; ensures bid proceeds only when permit is secured.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CompliancePermit .

ind:firmProfileId rdf:type rdf:Property ;
    rdfs:label 'Firm Profile Id' ;
    rdfs:comment 'Foreign key linking to subcontractor.firm_profile. Business justification: Required for the Bid Submission Tracking report, which records which subcontractor submitted each bid; essential for award decision and compliance audit.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FirmProfile .

ind:itpId rdf:type rdf:Property ;
    rdfs:label 'Itp Id' ;
    rdfs:comment 'Foreign key linking to quality.itp. Business justification: Bid submission includes the Inspection Test Plan register for client review; linking ties each submission to its ITP.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Itp .

ind:scheduleBaselineId rdf:type rdf:Property ;
    rdfs:label 'Schedule Baseline Id' ;
    rdfs:comment 'Foreign key linking to schedule.schedule_baseline. Business justification: Bid submissions reference the baseline schedule for time-based pricing and risk assessment, required for Bid Evaluation Dashboard.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ScheduleBaseline .

ind:acknowledgementReference rdf:type rdf:Property ;
    rdfs:label 'Acknowledgement Reference' ;
    rdfs:comment 'Reference number received from the client confirming receipt.' ;
    rdfs:domain ind:Submission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bidBondExpiry rdf:type rdf:Property ;
    rdfs:label 'Bid Bond Expiry' ;
    rdfs:comment 'Expiration date of the bid bond.' ;
    rdfs:domain ind:Bid ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:bidBondType rdf:type rdf:Property ;
    rdfs:label 'Bid Bond Type' ;
    rdfs:comment 'Type of bid bond provided.' ;
    rdfs:domain ind:Bid ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bidPrice rdf:type rdf:Property ;
    rdfs:label 'Bid Price' ;
    rdfs:comment 'Total monetary amount offered in the bid at submission.' ;
    rdfs:domain ind:Submission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bidPriceAdjustment rdf:type rdf:Property ;
    rdfs:label 'Bid Price Adjustment' ;
    rdfs:comment 'Any adjustment (e.g., discount, fee) applied to the base bid price.' ;
    rdfs:domain ind:Submission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bidType rdf:type rdf:Property ;
    rdfs:label 'Bid Type' ;
    rdfs:comment 'Contractual pricing structure of the bid.' ;
    rdfs:domain ind:Bid ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commercialScore rdf:type rdf:Property ;
    rdfs:label 'Commercial Score' ;
    rdfs:comment 'Score assigned to the commercial portion of the bid.' ;
    rdfs:domain ind:Submission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:documentsAttachedCount rdf:type rdf:Property ;
    rdfs:label 'Documents Attached Count' ;
    rdfs:comment 'Number of supporting documents attached to the submission.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:estimatedDurationMonths rdf:type rdf:Property ;
    rdfs:label 'Estimated Duration Months' ;
    rdfs:comment 'Projected duration of the project in months as estimated in the bid.' ;
    rdfs:domain ind:Bid ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:evaluationMethod rdf:type rdf:Property ;
    rdfs:label 'Evaluation Method' ;
    rdfs:comment 'Method used to evaluate the bid (e.g., two-envelope).' ;
    rdfs:domain ind:Bid ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lateSubmissionFlag rdf:type rdf:Property ;
    rdfs:label 'Late Submission Flag' ;
    rdfs:comment 'True if the submission was received after the deadline.' ;
    rdfs:domain ind:Submission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:numberOfCopies rdf:type rdf:Property ;
    rdfs:label 'Number Of Copies' ;
    rdfs:comment 'Count of physical copies submitted, if applicable.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:projectLocation rdf:type rdf:Property ;
    rdfs:label 'Project Location' ;
    rdfs:comment 'Free-form description of the project site location.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referenceNumber rdf:type rdf:Property ;
    rdfs:label 'Reference Number' ;
    rdfs:comment 'External reference number assigned to the bid submission.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regionCode rdf:type rdf:Property ;
    rdfs:label 'Region Code' ;
    rdfs:comment 'Three-letter code representing the geographic region of the project.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionMethod rdf:type rdf:Property ;
    rdfs:label 'Submission Method' ;
    rdfs:comment 'Method used to deliver the bid submission.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionStatus rdf:type rdf:Property ;
    rdfs:label 'Submission Status' ;
    rdfs:comment 'Current lifecycle status of the bid submission.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Submission Timestamp' ;
    rdfs:comment 'Date and time when the bid was formally submitted.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:technicalScore rdf:type rdf:Property ;
    rdfs:label 'Technical Score' ;
    rdfs:comment 'Score assigned to the technical portion of the bid (if two-envelope).' ;
    rdfs:domain ind:Submission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:boqId rdf:type rdf:Property ;
    rdfs:label 'Boq Id' ;
    rdfs:comment 'System-generated unique identifier for each BOQ master record.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Boq .

ind:bimModelId rdf:type rdf:Property ;
    rdfs:label 'Bim Model Id' ;
    rdfs:comment 'Foreign key linking to design.bim_model. Business justification: Required for Quantity Takeoff: BOQ creation uses BIM model geometry to derive quantities; the BOQ must reference the BIM model used.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BimModel .

ind:drawingId rdf:type rdf:Property ;
    rdfs:label 'Drawing Id' ;
    rdfs:comment 'Foreign key linking to design.drawing. Business justification: Required for Quantity Takeoff: BOQ lines are derived from construction drawings; linking each BOQ to its source drawing enables traceability.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Drawing .

ind:preparedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Prepared By Employee Id' ;
    rdfs:comment 'Foreign key linking to hr.employee. Business justification: Needed for BOQ audit trail; the employee who prepares the Bill of Quantities must be recorded for compliance and accountability.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:approvalDate rdf:type rdf:Property ;
    rdfs:label 'Approval Date' ;
    rdfs:comment 'Calendar date on which the BOQ was signed off by the project controls authority.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:boqDescription rdf:type rdf:Property ;
    rdfs:label 'Boq Description' ;
    rdfs:comment 'Narrative field for additional context, special instructions, or remarks from the estimator.' ;
    rdfs:domain ind:Boq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:boqStatus rdf:type rdf:Property ;
    rdfs:label 'Boq Status' ;
    rdfs:comment 'Indicates whether the BOQ is still being edited, has been issued to bidders, approved, revised, or archived.' ;
    rdfs:domain ind:Boq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:boqType rdf:type rdf:Property ;
    rdfs:label 'Boq Type' ;
    rdfs:comment 'Classifies the BOQ as measured (based on take-off), provisional (estimated), or approximate (high-level).' ;
    rdfs:domain ind:Boq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:containsConfidentialPricing rdf:type rdf:Property ;
    rdfs:label 'Contains Confidential Pricing' ;
    rdfs:comment 'True if the BOQ includes pricing that must be treated as confidential per contract and regulatory policy.' ;
    rdfs:domain ind:Boq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:currency rdf:type rdf:Property ;
    rdfs:label 'Currency' ;
    rdfs:comment 'Three-letter currency identifier (e.g., USD, EUR) used for the total_value field.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exchangeRate rdf:type rdf:Property ;
    rdfs:label 'Exchange Rate' ;
    rdfs:comment 'Rate used to convert the BOQ total_value to the company\'s reporting currency.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exchangeRateDate rdf:type rdf:Property ;
    rdfs:label 'Exchange Rate Date' ;
    rdfs:comment 'Effective date for the exchange_rate value.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:preparationDate rdf:type rdf:Property ;
    rdfs:label 'Preparation Date' ;
    rdfs:comment 'Calendar date on which the BOQ document was initially compiled.' ;
    rdfs:domain ind:Boq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:specificationStandard rdf:type rdf:Property ;
    rdfs:label 'Specification Standard' ;
    rdfs:comment 'Industry standard governing the format and measurement rules of the BOQ (e.g., NRM, POMI, CESMM).' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalQuantity rdf:type rdf:Property ;
    rdfs:label 'Total Quantity' ;
    rdfs:comment 'Aggregate of the quantity field from all BOQ line items, expressed in the unit defined by the specification standard.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalValue rdf:type rdf:Property ;
    rdfs:label 'Total Value' ;
    rdfs:comment 'Aggregate price of all line items in the BOQ, expressed in the selected currency.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:updatedBy rdf:type rdf:Property ;
    rdfs:label 'Updated By' ;
    rdfs:comment 'Login or employee identifier of the last person to modify the BOQ.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:versionLabel rdf:type rdf:Property ;
    rdfs:label 'Version Label' ;
    rdfs:comment 'Human-readable version identifier shown on the BOQ cover page.' ;
    rdfs:domain ind:Boq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:createdBy rdf:type rdf:Property ;
    rdfs:label 'Created By' ;
    rdfs:comment 'Login or employee identifier of the estimator who initially created the BOQ.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bidBoqLineId rdf:type rdf:Property ;
    rdfs:label 'Bid Boq Line Id' ;
    rdfs:comment 'Unique identifier for the BOQ line item.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BidBoqLine .

ind:sustainableMaterialId rdf:type rdf:Property ;
    rdfs:label 'Sustainable Material Id' ;
    rdfs:comment 'Foreign key linking to sustainability.sustainable_material. Business justification: BOQ lines may specify sustainable materials; linking each line to the sustainable_material record enables tracking of green procurement.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SustainableMaterial .

ind:actualCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Actual Completion Date' ;
    rdfs:comment 'Date when the work was actually completed.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:bidBoqLineDescription rdf:type rdf:Property ;
    rdfs:label 'Bid Boq Line Description' ;
    rdfs:comment 'Detailed textual description of the work item.' ;
    rdfs:domain ind:BidBoqLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bidBoqLineStatus rdf:type rdf:Property ;
    rdfs:label 'Bid Boq Line Status' ;
    rdfs:comment 'Current lifecycle status of the BOQ line.' ;
    rdfs:domain ind:BidBoqLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeOrderFlag rdf:type rdf:Property ;
    rdfs:label 'Change Order Flag' ;
    rdfs:comment 'Indicates if the line originated from a change order.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:changeOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Change Order Number' ;
    rdfs:comment 'Reference number of the associated change order, if any.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCategory rdf:type rdf:Property ;
    rdfs:label 'Cost Category' ;
    rdfs:comment 'Classification of cost type for budgeting and reporting.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterCode rdf:type rdf:Property ;
    rdfs:label 'Cost Center Code' ;
    rdfs:comment 'Internal cost center associated with the line for accounting.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Estimated Completion Date' ;
    rdfs:comment 'Planned date for completing the work represented by the line.' ;
    rdfs:domain ind:BidBoqLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isCriticalPath rdf:type rdf:Property ;
    rdfs:label 'Is Critical Path' ;
    rdfs:comment 'Marks the line as part of the project critical path.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isGmpApplicable rdf:type rdf:Property ;
    rdfs:label 'Is Gmp Applicable' ;
    rdfs:comment 'Indicates if the line is included in a Guaranteed Maximum Price bid.' ;
    rdfs:domain ind:BidBoqLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isLumpSum rdf:type rdf:Property ;
    rdfs:label 'Is Lump Sum' ;
    rdfs:comment 'Indicates if the line is part of a lump-sum bid component.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isTaxable rdf:type rdf:Property ;
    rdfs:label 'Is Taxable' ;
    rdfs:comment 'Indicates whether the line item is subject to tax.' ;
    rdfs:domain ind:BidBoqLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:itemCode rdf:type rdf:Property ;
    rdfs:label 'Item Code' ;
    rdfs:comment 'Standardized code for the work item as defined in the company\'s catalog.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:labourCost rdf:type rdf:Property ;
    rdfs:label 'Labour Cost' ;
    rdfs:comment 'Cost component attributable to labour for the line item.' ;
    rdfs:domain ind:BidBoqLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lineSequence rdf:type rdf:Property ;
    rdfs:label 'Line Sequence' ;
    rdfs:comment 'Sequential order of the line within the BOQ.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:materialCost rdf:type rdf:Property ;
    rdfs:label 'Material Cost' ;
    rdfs:comment 'Cost component attributable to materials.' ;
    rdfs:domain ind:BidBoqLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overheadAmount rdf:type rdf:Property ;
    rdfs:label 'Overhead Amount' ;
    rdfs:comment 'Allocated overhead amount for the line item.' ;
    rdfs:domain ind:BidBoqLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plantCost rdf:type rdf:Property ;
    rdfs:label 'Plant Cost' ;
    rdfs:comment 'Cost component attributable to plant/equipment usage.' ;
    rdfs:domain ind:BidBoqLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:profitMarginPercent rdf:type rdf:Property ;
    rdfs:label 'Profit Margin Percent' ;
    rdfs:comment 'Target profit margin percentage applied to the line.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantity rdf:type rdf:Property ;
    rdfs:label 'Quantity' ;
    rdfs:comment 'Quantity of the item required as per take-off.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskLevel rdf:type rdf:Property ;
    rdfs:label 'Risk Level' ;
    rdfs:comment 'Risk classification for the line item.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subcontractCost rdf:type rdf:Property ;
    rdfs:label 'Subcontract Cost' ;
    rdfs:comment 'Cost component attributable to subcontracted work.' ;
    rdfs:domain ind:BidBoqLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taxAmount rdf:type rdf:Property ;
    rdfs:label 'Tax Amount' ;
    rdfs:comment 'Calculated tax amount for the line item.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taxRate rdf:type rdf:Property ;
    rdfs:label 'Tax Rate' ;
    rdfs:comment 'Applicable tax rate percentage for taxable items.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalAmount rdf:type rdf:Property ;
    rdfs:label 'Total Amount' ;
    rdfs:comment 'Calculated total cost for the line (quantity × unit_rate).' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Unit Of Measure' ;
    rdfs:comment 'Measurement unit for the quantity (e.g., meter, kilogram, piece). [ENUM-REF-CANDIDATE: unit|kg|m|m2|m3|l|pcs|hr — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitRate rdf:type rdf:Property ;
    rdfs:label 'Unit Rate' ;
    rdfs:comment 'Price per unit of measure for the item.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wbsCode rdf:type rdf:Property ;
    rdfs:label 'Wbs Code' ;
    rdfs:comment 'Code linking the line to the project WBS hierarchy.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workSection rdf:type rdf:Property ;
    rdfs:label 'Work Section' ;
    rdfs:comment 'Higher-level grouping of work items (e.g., civil, structural, MEP).' ;
    rdfs:domain ind:BidBoqLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimateId rdf:type rdf:Property ;
    rdfs:label 'Estimate Id' ;
    rdfs:comment 'Unique system-generated identifier for the cost estimate record.' ;
    rdfs:domain ind:Bid ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Estimate .

ind:designSubmittalId rdf:type rdf:Property ;
    rdfs:label 'Design Submittal Id' ;
    rdfs:comment 'Foreign key linking to design.design_submittal. Business justification: Estimators rely on design submittals to verify scope and specifications; the estimate must reference the submittal it is based on.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DesignSubmittal .

ind:embodiedCarbonAssessmentId rdf:type rdf:Property ;
    rdfs:label 'Embodied Carbon Assessment Id' ;
    rdfs:comment 'Foreign key linking to sustainability.embodied_carbon_assessment. Business justification: Cost estimating processes incorporate embodied carbon assessments to evaluate carbon impact, necessitating a direct FK from estimate to the assessment.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EmbodiedCarbonAssessment .

ind:envImpactAssessmentId rdf:type rdf:Property ;
    rdfs:label 'Env Impact Assessment Id' ;
    rdfs:comment 'Foreign key linking to compliance.env_impact_assessment. Business justification: Cost estimate incorporates mitigation measures identified in the environmental impact assessment.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EnvImpactAssessment .

ind:laborRateId rdf:type rdf:Property ;
    rdfs:label 'Labor Rate Id' ;
    rdfs:comment 'Foreign key linking to workforce.labor_rate. Business justification: Required for estimate cost calculations that use labor rates defined in workforce.labor_rate; estimators reference these rates to price labor components.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LaborRate .

ind:basePricingDate rdf:type rdf:Property ;
    rdfs:label 'Base Pricing Date' ;
    rdfs:comment 'Date on which the unit rates and cost data were sourced for the estimate.' ;
    rdfs:domain ind:Estimate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:costBreakdownVersion rdf:type rdf:Property ;
    rdfs:label 'Cost Breakdown Version' ;
    rdfs:comment 'Version identifier for the detailed cost breakdown structure used in the estimate.' ;
    rdfs:domain ind:Estimate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentReference rdf:type rdf:Property ;
    rdfs:label 'Document Reference' ;
    rdfs:comment 'Identifier or path to the electronic document containing the full estimate details.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationAllowance rdf:type rdf:Property ;
    rdfs:label 'Escalation Allowance' ;
    rdfs:comment 'Allowance expressed as a percentage to account for price escalation over time.' ;
    rdfs:domain ind:Estimate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimateCategory rdf:type rdf:Property ;
    rdfs:label 'Estimate Category' ;
    rdfs:comment 'Business category indicating the nature of the work the estimate covers.' ;
    rdfs:domain ind:Estimate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimateName rdf:type rdf:Property ;
    rdfs:label 'Estimate Name' ;
    rdfs:comment 'Human-readable name or title of the estimate for easy identification.' ;
    rdfs:domain ind:Estimate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimateNumber rdf:type rdf:Property ;
    rdfs:label 'Estimate Number' ;
    rdfs:comment 'External reference number assigned to the estimate, used in bid documentation and communications.' ;
    rdfs:domain ind:Estimate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimateStatus rdf:type rdf:Property ;
    rdfs:label 'Estimate Status' ;
    rdfs:comment 'Current lifecycle status of the estimate within the bid process.' ;
    rdfs:domain ind:Estimate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimateType rdf:type rdf:Property ;
    rdfs:label 'Estimate Type' ;
    rdfs:comment 'Classification of the estimate based on its level of detail and development stage.' ;
    rdfs:domain ind:Estimate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatingMethod rdf:type rdf:Property ;
    rdfs:label 'Estimating Method' ;
    rdfs:comment 'Methodology used to develop the cost estimate.' ;
    rdfs:domain ind:Estimate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expirationDate rdf:type rdf:Property ;
    rdfs:label 'Expiration Date' ;
    rdfs:comment 'Date after which the estimate is no longer valid for bid submission.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isGmp rdf:type rdf:Property ;
    rdfs:label 'Is Gmp' ;
    rdfs:comment 'Indicates whether the estimate is prepared as a GMP (True) or not (False).' ;
    rdfs:domain ind:Estimate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isLocked rdf:type rdf:Property ;
    rdfs:label 'Is Locked' ;
    rdfs:comment 'True when the estimate is locked from further edits after approval.' ;
    rdfs:domain ind:Estimate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:overheadPercentage rdf:type rdf:Property ;
    rdfs:label 'Overhead Percentage' ;
    rdfs:comment 'Overhead cost expressed as a percentage of direct costs.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:profitMarginPercentage rdf:type rdf:Property ;
    rdfs:label 'Profit Margin Percentage' ;
    rdfs:comment 'Desired profit margin expressed as a percentage of total cost.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revisionDate rdf:type rdf:Property ;
    rdfs:label 'Revision Date' ;
    rdfs:comment 'Date when the current revision of the estimate was created.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:riskFactor rdf:type rdf:Property ;
    rdfs:label 'Risk Factor' ;
    rdfs:comment 'Numeric factor representing the overall risk level applied to the estimate.' ;
    rdfs:domain ind:Bid ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scheduleImpactDays rdf:type rdf:Property ;
    rdfs:label 'Schedule Impact Days' ;
    rdfs:comment 'Estimated impact on project schedule expressed in days if the estimate is accepted.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalEstimatedCost rdf:type rdf:Property ;
    rdfs:label 'Total Estimated Cost' ;
    rdfs:comment 'Aggregated cost of the estimate before taxes, including all cost components.' ;
