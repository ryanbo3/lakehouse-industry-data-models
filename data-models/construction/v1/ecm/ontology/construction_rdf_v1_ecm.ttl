    rdfs:range xsd:boolean .

ind:scheduleCalendarDescription rdf:type rdf:Property ;
    rdfs:label 'Schedule Calendar Description' ;
    rdfs:comment 'Free-form description providing additional context about the calendar.' ;
    rdfs:domain ind:ScheduleCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleCalendarStatus rdf:type rdf:Property ;
    rdfs:label 'Schedule Calendar Status' ;
    rdfs:comment 'Current lifecycle status of the calendar.' ;
    rdfs:domain ind:ScheduleCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shiftPattern rdf:type rdf:Property ;
    rdfs:label 'Shift Pattern' ;
    rdfs:comment 'Definition of work shifts applied to the calendar.' ;
