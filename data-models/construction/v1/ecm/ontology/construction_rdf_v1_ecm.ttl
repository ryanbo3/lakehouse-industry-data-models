    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:separationEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Separation Employee Id' ;
    rdfs:comment 'Unique identifier of the employee who is separating.' ;
