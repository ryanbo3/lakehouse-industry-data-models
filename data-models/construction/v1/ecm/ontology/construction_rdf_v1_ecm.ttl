    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:bidRevisionTriggered rdf:type rdf:Property ;
    rdfs:label 'Bid Revision Triggered' ;
    rdfs:comment 'Indicates whether the clarification caused a formal bid revision.' ;
