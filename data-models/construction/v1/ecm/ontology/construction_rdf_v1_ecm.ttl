    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retentionReleasePercentage rdf:type rdf:Property ;
    rdfs:label 'Retention Release Percentage' ;
    rdfs:comment 'Percentage of the total retention released in this transaction.' ;
    rdfs:domain ind:ContractRetentionLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:retentionReleaseSequence rdf:type rdf:Property ;
    rdfs:label 'Retention Release Sequence' ;
    rdfs:comment 'Ordinal number indicating the order of releases for a given contract.' ;
    rdfs:domain ind:ContractRetentionLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:retentionReleaseType rdf:type rdf:Property ;
    rdfs:label 'Retention Release Type' ;
    rdfs:comment 'Reason category for the retention release (e.g., practical completion, DLP expiry).' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retentionSource rdf:type rdf:Property ;
    rdfs:label 'Retention Source' ;
    rdfs:comment 'Origin of the retention amount (e.g., regular payment certificate, change order, or manual adjustment).' ;
    rdfs:domain ind:ContractRetentionLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractScopeId rdf:type rdf:Property ;
    rdfs:label 'Contract Scope Id' ;
    rdfs:comment 'Unique identifier for the contract scope record.' ;
    rdfs:domain ind:ContractScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:technicalSpecificationId rdf:type rdf:Property ;
    rdfs:label 'Technical Specification Id' ;
    rdfs:comment 'Identifier for the technical specification linked to the scope.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TechnicalSpecification .

ind:wbsElementId rdf:type rdf:Property ;
    rdfs:label 'Wbs Element Id' ;
    rdfs:comment 'Reference to the WBS element that the scope aligns to.' ;
