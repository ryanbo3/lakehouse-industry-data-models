    rdfs:label 'Parent Account Id' ;
    rdfs:comment 'Reference to the parent account record for clients that are subsidiaries or divisions within a larger corporate hierarchy. Enables account hierarchy traversal for consolidated reporting and group-level relationship management.' ;
    rdfs:domain ind:Client ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Account .

ind:primaryUltimateParentAccountId rdf:type rdf:Property ;
    rdfs:label 'Primary Ultimate Parent Account Id' ;
    rdfs:comment 'Reference to the top-level account in the corporate hierarchy (ultimate holding entity). Used for group-level exposure analysis, consolidated pipeline reporting, and enterprise relationship management.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Account .

ind:segmentId rdf:type rdf:Property ;
    rdfs:label 'Segment Id' ;
    rdfs:comment 'Foreign key linking to client.segment. Business justification: An account belongs to a single segment classification; using a foreign key to segment normalizes the model and removes the redundant string column.' ;
    rdfs:domain ind:Client ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Segment .

ind:accountStatus rdf:type rdf:Property ;
    rdfs:label 'Account Status' ;
    rdfs:comment 'Current lifecycle status of the client account. Controls whether the account is eligible for new project bids, contract awards, and CRM pipeline activities.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountType rdf:type rdf:Property ;
    rdfs:label 'Account Type' ;
    rdfs:comment 'Classification of the client account by ownership and sector type. Drives contract template selection, compliance requirements, and reporting segmentation. [ENUM-REF-CANDIDATE: public_sector|private_sector|government_body|corporate_sponsor|jv_entity|ppp_authority — promote to reference product]' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:annualRevenue rdf:type rdf:Property ;
    rdfs:label 'Annual Revenue' ;
    rdfs:comment 'Reported or estimated annual revenue of the client organisation in the account\'s billing currency. Used for client segmentation, credit assessment, and strategic account prioritisation.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:billingAddress rdf:type rdf:Property ;
    rdfs:label 'Billing Address' ;
    rdfs:comment 'Address to which invoices and financial correspondence are directed for this client account. May differ from the registered address. Used in SAP S/4HANA accounts receivable and Viewpoint Vista job costing.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bimRequirementLevel rdf:type rdf:Property ;
    rdfs:label 'Bim Requirement Level' ;
    rdfs:comment 'Level of Building Information Modeling (BIM) mandated by the client for construction projects. Drives design collaboration tooling requirements (e.g., Autodesk BIM 360), data exchange standards, and project delivery methodology.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clientTier rdf:type rdf:Property ;
    rdfs:label 'Client Tier' ;
    rdfs:comment 'Strategic segmentation tier assigned to the client based on revenue potential, relationship depth, and strategic importance. Tier 1 represents the highest-value clients. Drives account management resource allocation and executive engagement levels.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditLimit rdf:type rdf:Property ;
    rdfs:label 'Credit Limit' ;
    rdfs:comment 'Maximum outstanding receivable balance approved for this client account. Used by the finance team to manage exposure and payment risk on construction contracts. Expressed in the account\'s billing currency.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditRating rdf:type rdf:Property ;
    rdfs:label 'Credit Rating' ;
    rdfs:comment 'External credit rating assigned to the client organisation by a recognised credit rating agency (e.g., S&P, Moody\'s, Fitch) or internal credit assessment score. Used for financial risk evaluation, payment terms negotiation, and bonding/surety decisions.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crmAccountCode rdf:type rdf:Property ;
    rdfs:label 'Crm Account Code' ;
    rdfs:comment 'Source system identifier for the account as recorded in Salesforce CRM. Used for cross-system reconciliation and lineage tracing back to the operational system of record.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:doNotContact rdf:type rdf:Property ;
    rdfs:label 'Do Not Contact' ;
    rdfs:comment 'Indicates whether outbound marketing and unsolicited commercial communications to this client account are restricted. Set to True when the client has opted out of communications or is subject to legal/regulatory restrictions. Supports GDPR compliance.' ;
    rdfs:domain ind:Client ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dunsNumber rdf:type rdf:Property ;
    rdfs:label 'Duns Number' ;
    rdfs:comment 'Nine-digit Dun & Bradstreet Data Universal Numbering System identifier for the client organisation. Used for credit assessment, supplier/client qualification, and global entity resolution.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employeeCount rdf:type rdf:Property ;
    rdfs:label 'Employee Count' ;
    rdfs:comment 'Approximate number of employees in the client organisation. Used as a proxy for organisational scale, procurement capacity, and client segmentation in CRM analytics.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:eotPolicy rdf:type rdf:Property ;
    rdfs:label 'Eot Policy' ;
    rdfs:comment 'Client\'s standard policy for granting Extension of Time (EOT) on construction contracts. Indicates whether the client follows standard FIDIC provisions, applies strict timelines, or allows flexible negotiation. Used in bid risk evaluation.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hseComplianceRequired rdf:type rdf:Property ;
    rdfs:label 'Hse Compliance Required' ;
    rdfs:comment 'Indicates whether this client mandates specific Health, Safety and Environment (HSE) compliance standards (e.g., ISO 45001, OSHA requirements, client-specific HSE plans) as a condition of contract. Drives HSE planning and prequalification requirements.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:industrySector rdf:type rdf:Property ;
    rdfs:label 'Industry Sector' ;
    rdfs:comment 'Primary industry sector of the client organisation (e.g., Infrastructure, Energy, Real Estate, Transportation, Healthcare, Government). Used for market segmentation and opportunity pipeline analytics in Salesforce CRM.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isJvEntity rdf:type rdf:Property ;
    rdfs:label 'Is Jv Entity' ;
    rdfs:comment 'Indicates whether this client account represents a Joint Venture (JV) entity formed specifically for a construction project or programme. JV entities require special contract administration, profit-sharing arrangements, and consolidated reporting.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastModifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Modified Timestamp' ;
    rdfs:comment 'Timestamp of the most recent update to the account record in the source Salesforce CRM system. Used for change data capture, incremental ETL processing, and audit trail maintenance.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lastProjectAwardDate rdf:type rdf:Property ;
    rdfs:label 'Last Project Award Date' ;
    rdfs:comment 'Date of the most recent contract or project award from this client. Used to identify dormant accounts, measure relationship recency, and prioritise re-engagement activities in the CRM pipeline.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ldClauseStandard rdf:type rdf:Property ;
    rdfs:label 'Ld Clause Standard' ;
    rdfs:comment 'Indicates whether this client typically enforces Liquidated Damages (LD) clauses in construction contracts, and whether the LD terms are standard or negotiable. Informs bid risk assessment and contract strategy.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leedCertificationRequired rdf:type rdf:Property ;
    rdfs:label 'Leed Certification Required' ;
    rdfs:comment 'Indicates whether this client requires LEED (Leadership in Energy and Environmental Design) certification for construction projects. Drives design, procurement, and construction methodology decisions to meet green building standards.' ;
    rdfs:domain ind:Client ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:legalName rdf:type rdf:Property ;
    rdfs:label 'Legal Name' ;
    rdfs:comment 'Full registered legal name of the client/owner organisation as it appears on contracts, invoices, and regulatory filings. This is the authoritative identity label for the account.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ntpAuthorityLevel rdf:type rdf:Property ;
    rdfs:label 'Ntp Authority Level' ;
    rdfs:comment 'Describes the client\'s internal authority level or approval threshold required to issue a Notice to Proceed (NTP) on construction contracts. Used in contract administration to understand client governance and approval workflows.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentTerms rdf:type rdf:Property ;
    rdfs:label 'Payment Terms' ;
    rdfs:comment 'Standard payment terms agreed with the client for construction contracts (e.g., Net 30, Net 60, milestone-based, progress payment). Drives accounts receivable management and cash flow forecasting in SAP S/4HANA.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredContractType rdf:type rdf:Property ;
    rdfs:label 'Preferred Contract Type' ;
    rdfs:comment 'Client\'s preferred contract delivery model for construction engagements. Options include Engineering Procurement and Construction (EPC), Guaranteed Maximum Price (GMP), Design-Bid-Build (DBB), Design-Build (DB), Public-Private Partnership (PPP), and Build-Operate-Transfer (BOT). Informs bid strategy and contract template selection. [ENUM-REF-CANDIDATE: EPC|GMP|DBB|DB|PPP|BOT|FIDIC — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prequalificationExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Prequalification Expiry Date' ;
    rdfs:comment 'Date on which the client\'s prequalification approval expires and requires renewal. Used to trigger re-assessment workflows and ensure compliance before new contract awards.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:registeredAddress rdf:type rdf:Property ;
    rdfs:label 'Registered Address' ;
    rdfs:comment 'Full registered office address of the client organisation as recorded with the relevant business registry. Used for legal correspondence, contract execution, and regulatory filings.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationNumber rdf:type rdf:Property ;
    rdfs:label 'Registration Number' ;
    rdfs:comment 'Official company or entity registration number issued by the relevant national or state business registry authority. Used for legal entity verification and compliance due diligence.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipStartDate rdf:type rdf:Property ;
    rdfs:label 'Relationship Start Date' ;
    rdfs:comment 'Date on which the business relationship with this client was formally established (e.g., first contract award, first NTP issued, or CRM account creation date). Used for relationship tenure analysis and loyalty segmentation.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:taxNumber rdf:type rdf:Property ;
    rdfs:label 'Tax Number' ;
    rdfs:comment 'Government-issued tax identification number (e.g., EIN, VAT number, GST number) for the client entity. Required for invoicing, contract administration, and financial reporting under IFRS/GAAP.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradingName rdf:type rdf:Property ;
    rdfs:label 'Trading Name' ;
    rdfs:comment 'Operating or brand name used by the client organisation in day-to-day business, which may differ from the registered legal name. Used in CRM displays and correspondence.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:websiteUrl rdf:type rdf:Property ;
    rdfs:label 'Website Url' ;
    rdfs:comment 'Official website address of the client organisation. Used for due diligence, background research, and CRM account enrichment.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountCreditProfileId rdf:type rdf:Property ;
    rdfs:label 'Account Credit Profile Id' ;
    rdfs:comment 'Unique surrogate identifier for the account credit profile record in the Databricks Silver Layer. Primary key for this entity.' ;
    rdfs:domain ind:AccountCreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:clientAccountId rdf:type rdf:Property ;
    rdfs:label 'Client Account Id' ;
    rdfs:comment 'Reference to the client account for which this credit profile applies. Links to the master client account entity in the client domain.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Account .

ind:creditApprovedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Credit Approved By Employee Id' ;
    rdfs:comment 'Foreign key linking to hr.employee. Business justification: Credit approval workflow tracks the approving HR employee, enabling audit and compliance reports.' ;
    rdfs:domain ind:AccountCreditProfile ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:approvedPaymentTerms rdf:type rdf:Property ;
    rdfs:label 'Approved Payment Terms' ;
    rdfs:comment 'Contractually approved payment terms for this client account, governing the number of days within which invoices must be settled or the basis on which payments are triggered. Milestone-based and retention-release terms are common in EPC and FIDIC contracts. [ENUM-REF-CANDIDATE: net_30|net_45|net_60|net_90|milestone_based|retention_release|advance_payment|progress_claim — promote to reference product]' ;
    rdfs:domain ind:AccountCreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bdRelationshipContext rdf:type rdf:Property ;
    rdfs:label 'Bd Relationship Context' ;
    rdfs:comment 'Business Development (BD) team\'s qualitative assessment of the strategic importance and relationship health of this client account, used as input to the internal credit scoring process. Strategic key accounts may receive more favourable credit terms.' ;
    rdfs:domain ind:AccountCreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clientSegment rdf:type rdf:Property ;
    rdfs:label 'Client Segment' ;
    rdfs:comment 'Business segment classification of the client account for credit risk segmentation and portfolio analysis. Supports differentiated credit policies for Public-Private Partnership (PPP), Build-Operate-Transfer (BOT), Joint Venture (JV), and private developer clients. [ENUM-REF-CANDIDATE: public_sector|private_sector|ppp|bot|jv_partner|developer|utility|epc_owner|multilateral — promote to reference product]' ;
    rdfs:domain ind:Client ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditApprovedDate rdf:type rdf:Property ;
    rdfs:label 'Credit Approved Date' ;
    rdfs:comment 'Date on which the current credit limit and payment terms were formally approved by the authorised finance approver.' ;
    rdfs:domain ind:AccountCreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:creditHoldDate rdf:type rdf:Property ;
    rdfs:label 'Credit Hold Date' ;
    rdfs:comment 'Date on which the credit hold was applied to this client account. Null if no credit hold is currently active.' ;
    rdfs:domain ind:AccountCreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:creditHoldFlag rdf:type rdf:Property ;
    rdfs:label 'Credit Hold Flag' ;
    rdfs:comment 'Indicates whether this client account is currently placed on credit hold, blocking the issuance of new contracts, purchase orders, or progress claims until the hold is resolved. True = credit hold active; False = normal trading.' ;
    rdfs:domain ind:AccountCreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:creditHoldReason rdf:type rdf:Property ;
    rdfs:label 'Credit Hold Reason' ;
    rdfs:comment 'Reason code explaining why the credit hold was applied to this client account. Populated only when credit_hold_flag is True. Supports root-cause analysis and escalation workflows.' ;
    rdfs:domain ind:AccountCreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditInsuranceFlag rdf:type rdf:Property ;
    rdfs:label 'Credit Insurance Flag' ;
    rdfs:comment 'Indicates whether trade credit insurance has been obtained to cover the financial exposure to this client account. True = credit insurance in place; False = no credit insurance.' ;
    rdfs:domain ind:AccountCreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:creditInsuranceLimitAmount rdf:type rdf:Property ;
    rdfs:label 'Credit Insurance Limit Amount' ;
    rdfs:comment 'Maximum insured amount covered by the trade credit insurance policy for this client account. Populated only when credit_insurance_flag is True.' ;
    rdfs:domain ind:AccountCreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditInsuranceProvider rdf:type rdf:Property ;
    rdfs:label 'Credit Insurance Provider' ;
    rdfs:comment 'Name of the trade credit insurance provider covering the exposure to this client account (e.g., Euler Hermes, Coface, Atradius). Populated only when credit_insurance_flag is True.' ;
    rdfs:domain ind:AccountCreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditLimitAmount rdf:type rdf:Property ;
    rdfs:label 'Credit Limit Amount' ;
    rdfs:comment 'Maximum approved credit exposure the business is willing to extend to this client account at any point in time, expressed in the profile currency. Used in contract terms negotiation and financial risk management.' ;
    rdfs:domain ind:AccountCreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditLimitChangeReason rdf:type rdf:Property ;
    rdfs:label 'Credit Limit Change Reason' ;
    rdfs:comment 'Free-text explanation of the reason for the most recent change to the credit limit, such as improved payment history, new contract award, rating upgrade, or financial distress. Supports audit trail and governance requirements.' ;
    rdfs:domain ind:AccountCreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditReviewFrequency rdf:type rdf:Property ;
    rdfs:label 'Credit Review Frequency' ;
    rdfs:comment 'Frequency at which this client account\'s credit profile is formally reviewed. \'triggered\' indicates review is event-driven (e.g., new contract award, overdue threshold breach) rather than calendar-based.' ;
    rdfs:domain ind:AccountCreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentExposureAmount rdf:type rdf:Property ;
    rdfs:label 'Current Exposure Amount' ;
    rdfs:comment 'Total current financial exposure to this client account, comprising all open invoices (billed but unpaid), unbilled certified work, and retention receivables. Used to assess utilisation against the approved credit limit.' ;
    rdfs:domain ind:AccountCreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dsoDays rdf:type rdf:Property ;
    rdfs:label 'Dso Days' ;
    rdfs:comment 'Average number of days this client account takes to pay invoices, calculated over the trailing review period. DSO (Days Sales Outstanding) is a key accounts receivable metric used to assess payment behaviour and cash flow risk. Sourced from SAP S/4HANA AR aging analysis.' ;
    rdfs:domain ind:AccountCreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:effectiveFromDate rdf:type rdf:Property ;
    rdfs:label 'Effective From Date' ;
    rdfs:comment 'Date from which the current credit profile terms (credit limit, payment terms, rating) became effective. Supports temporal tracking of credit profile changes over time.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectiveUntilDate rdf:type rdf:Property ;
    rdfs:label 'Effective Until Date' ;
    rdfs:comment 'Date until which the current credit profile terms are valid. Null for open-ended profiles. Triggers a review workflow when the current date approaches this date.' ;
    rdfs:domain ind:AccountCreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:externalCreditRating rdf:type rdf:Property ;
    rdfs:label 'External Credit Rating' ;
    rdfs:comment 'Credit rating assigned to the client by an external credit rating agency such as Dun & Bradstreet (D&B), Standard & Poor\'s (S&P), Moody\'s, or Fitch. Examples: AAA, AA+, BBB-, Ba1, 5A1 (D&B PAYDEX). Null if no external rating is available.' ;
    rdfs:domain ind:AccountCreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalRatingAgency rdf:type rdf:Property ;
    rdfs:label 'External Rating Agency' ;
    rdfs:comment 'Name of the external credit rating agency that issued the external_credit_rating for this client account. Enables multi-agency comparison and source traceability.' ;
    rdfs:domain ind:AccountCreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalRatingDate rdf:type rdf:Property ;
    rdfs:label 'External Rating Date' ;
    rdfs:comment 'Date on which the external credit rating was issued or last confirmed by the rating agency. Used to assess the currency and relevance of the external rating.' ;
    rdfs:domain ind:AccountCreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:internalCreditScore rdf:type rdf:Property ;
    rdfs:label 'Internal Credit Score' ;
    rdfs:comment 'Internally calculated credit score assigned to this client account by the finance team, typically on a scale of 0–100 or 0–1000, reflecting payment history, financial strength, project delivery track record, and relationship context provided by Business Development (BD). Higher scores indicate lower credit risk.' ;
    rdfs:domain ind:AccountCreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastCreditReviewDate rdf:type rdf:Property ;
    rdfs:label 'Last Credit Review Date' ;
    rdfs:comment 'Date on which the most recent formal credit review was completed by the finance team. Triggers periodic reassessment workflows and ensures credit profiles remain current.' ;
    rdfs:domain ind:AccountCreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:liquidatedDamagesExposureAmount rdf:type rdf:Property ;
    rdfs:label 'Liquidated Damages Exposure Amount' ;
    rdfs:comment 'Maximum financial exposure to Liquidated Damages (LD) that the client could apply against the business under active contracts, based on contractual LD rates and project delay risk. Informs credit risk and P&L exposure assessments.' ;
    rdfs:domain ind:AccountCreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nextCreditReviewDate rdf:type rdf:Property ;
    rdfs:label 'Next Credit Review Date' ;
    rdfs:comment 'Scheduled date for the next periodic credit review of this client account. Supports proactive credit management and ensures timely reassessment before contract renewals or new bid submissions.' ;
    rdfs:domain ind:AccountCreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:overdueBalanceAmount rdf:type rdf:Property ;
    rdfs:label 'Overdue Balance Amount' ;
    rdfs:comment 'Total outstanding invoice balance that has exceeded the approved payment terms due date as of the last credit review or system refresh. A key indicator for credit hold decisions and risk escalation.' ;
    rdfs:domain ind:AccountCreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentHistoryRating rdf:type rdf:Property ;
    rdfs:label 'Payment History Rating' ;
    rdfs:comment 'Qualitative rating of the client\'s historical payment behaviour based on analysis of invoice settlement patterns, frequency of late payments, and dispute history. Derived from AR aging data in SAP S/4HANA and Viewpoint Vista.' ;
    rdfs:domain ind:AccountCreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentTermsDays rdf:type rdf:Property ;
    rdfs:label 'Payment Terms Days' ;
    rdfs:comment 'Numeric representation of the approved payment terms expressed as the number of calendar days from invoice date to due date (e.g., 30 for net-30, 60 for net-60). Complements the approved_payment_terms field for precise DSO calculation and aging analysis.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:previousCreditLimitAmount rdf:type rdf:Property ;
    rdfs:label 'Previous Credit Limit Amount' ;
    rdfs:comment 'Credit limit that was in effect prior to the most recent credit review. Enables trend analysis and audit trail of credit limit changes over time.' ;
    rdfs:domain ind:AccountCreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:profileReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Profile Reference Number' ;
    rdfs:comment 'Externally-known alphanumeric reference code assigned to this credit profile, used in correspondence with finance teams and credit agencies. Format: CP- followed by 6-12 alphanumeric characters.' ;
    rdfs:domain ind:AccountCreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profileStatus rdf:type rdf:Property ;
    rdfs:label 'Profile Status' ;
    rdfs:comment 'Current lifecycle status of the credit profile. \'active\' indicates normal trading terms apply; \'credit_hold\' indicates all new work or invoicing is blocked pending resolution of overdue balances or risk concerns; \'under_review\' indicates a periodic or triggered reassessment is in progress.' ;
    rdfs:domain ind:AccountCreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retentionPercentage rdf:type rdf:Property ;
    rdfs:label 'Retention Percentage' ;
    rdfs:comment 'Percentage of each progress claim withheld by the client as retention money under the contract, typically released upon practical completion and expiry of the Defects Liability Period (DLP). Standard construction retention rates range from 5% to 10%.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:retentionReleaseTerms rdf:type rdf:Property ;
    rdfs:label 'Retention Release Terms' ;
    rdfs:comment 'Terms governing when withheld retention money is released by the client. Common construction arrangements include 50% on practical completion and 50% on Defects Liability Period (DLP) expiry, or full release on a specific milestone.' ;
    rdfs:domain ind:AccountCreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sovereignCountryCode rdf:type rdf:Property ;
    rdfs:label 'Sovereign Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the sovereign government entity when sovereign_risk_flag is True. Used for country-level risk aggregation and geopolitical exposure reporting.' ;
    rdfs:domain ind:AccountCreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sovereignRiskFlag rdf:type rdf:Property ;
    rdfs:label 'Sovereign Risk Flag' ;
    rdfs:comment 'Indicates whether this client account is a government entity or state-owned enterprise subject to sovereign risk considerations, including political risk, currency controls, and delayed payment due to public procurement cycles. True = sovereign/government client; False = private sector client.' ;
    rdfs:domain ind:AccountCreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:specialPaymentArrangementFlag rdf:type rdf:Property ;
    rdfs:label 'Special Payment Arrangement Flag' ;
    rdfs:comment 'Indicates whether a special payment arrangement has been agreed with this client account, such as a retention release schedule, milestone-based payment plan, advance payment structure, or deferred payment agreement. True = special arrangement in place; False = standard terms apply.' ;
    rdfs:domain ind:AccountCreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:specialPaymentArrangementNotes rdf:type rdf:Property ;
    rdfs:label 'Special Payment Arrangement Notes' ;
    rdfs:comment 'Free-text description of the specific terms of the special payment arrangement, including key milestones, retention percentages, release conditions, or deferred payment schedules agreed with the client.' ;
    rdfs:domain ind:AccountCreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialPaymentArrangementType rdf:type rdf:Property ;
    rdfs:label 'Special Payment Arrangement Type' ;
    rdfs:comment 'Type of special payment arrangement in place for this client account. Populated only when special_payment_arrangement_flag is True. Retention release schedules and milestone-based payments are standard in FIDIC and EPC contracts.' ;
    rdfs:domain ind:AccountCreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountHierarchyId rdf:type rdf:Property ;
    rdfs:label 'Account Hierarchy Id' ;
    rdfs:comment 'Unique surrogate identifier for each parent-child account hierarchy relationship record in the construction client domain.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:childAccountId rdf:type rdf:Property ;
    rdfs:label 'Child Account Id' ;
    rdfs:comment 'Identifier of the child account in the hierarchy (e.g., subsidiary, regional office, JV entity, or branch). References the client account that sits one level below the parent in the corporate structure.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Account .

ind:approvedDate rdf:type rdf:Property ;
    rdfs:label 'Approved Date' ;
    rdfs:comment 'Date on which this hierarchy relationship was formally approved by the designated authority (e.g., board resolution date, legal sign-off date). Null if not yet approved.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:arrangementType rdf:type rdf:Property ;
    rdfs:label 'Arrangement Type' ;
    rdfs:comment 'Classifies the overarching commercial or legal arrangement governing this hierarchy relationship. \'corporate\' = standard corporate ownership; \'jv\' = Joint Venture (JV); \'ppp\' = Public-Private Partnership (PPP); \'bot\' = Build-Operate-Transfer (BOT); \'consortium\' = project-specific consortium; \'spe\' = Special Purpose Entity.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consolidationMethod rdf:type rdf:Property ;
    rdfs:label 'Consolidation Method' ;
    rdfs:comment 'Accounting consolidation method applied to this hierarchy relationship for financial reporting. \'full\' = full consolidation (>50% control); \'proportionate\' = proportionate consolidation for JV; \'equity\' = equity method for associates; \'none\' = no consolidation (e.g., branch or division).' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crmHierarchyCode rdf:type rdf:Property ;
    rdfs:label 'Crm Hierarchy Code' ;
    rdfs:comment 'External identifier for this hierarchy relationship as recorded in Salesforce CRM. Enables traceability and reconciliation between the lakehouse silver layer and the CRM system of record.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Data Source System' ;
    rdfs:comment 'Identifies the operational system of record from which this hierarchy relationship record was sourced (e.g., Salesforce CRM, SAP S/4HANA). Supports data lineage tracking and reconciliation in the Databricks Lakehouse silver layer.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dissolutionDate rdf:type rdf:Property ;
    rdfs:label 'Dissolution Date' ;
    rdfs:comment 'Date on which the JV, consortium, or subsidiary relationship was formally dissolved or wound up. Applicable primarily to JV (Joint Venture) and SPE (Special Purpose Entity) arrangements. Null if not dissolved.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectiveToDate rdf:type rdf:Property ;
    rdfs:label 'Effective To Date' ;
    rdfs:comment 'Date on which this parent-child hierarchy relationship ceases to be active. Null indicates the relationship is currently open-ended and active. Supports historical hierarchy versioning and corporate restructuring tracking.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:erpHierarchyCode rdf:type rdf:Property ;
    rdfs:label 'Erp Hierarchy Code' ;
    rdfs:comment 'External identifier for this hierarchy relationship as recorded in SAP S/4HANA Business Partner Hierarchy. Supports financial consolidation and intercompany transaction management.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicRegion rdf:type rdf:Property ;
    rdfs:label 'Geographic Region' ;
    rdfs:comment 'Geographic region or territory associated with this hierarchy relationship (e.g., North America, Middle East, Asia Pacific). Used for regional consolidated reporting and client portfolio analysis.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:governingLawCountry rdf:type rdf:Property ;
    rdfs:label 'Governing Law Country' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the jurisdiction whose laws govern this hierarchy relationship agreement (e.g., USA, GBR, SGP). Relevant for cross-border JV and PPP structures.' ;
    rdfs:domain ind:Client ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hierarchyCode rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying this hierarchy relationship, used for cross-system referencing in SAP S/4HANA and Salesforce CRM integrations.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hierarchyLevel rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Level' ;
    rdfs:comment 'Numeric depth of the child account within the corporate hierarchy tree. Level 1 represents the ultimate parent (root), with each subsequent level incrementing by 1. Enables consolidated reporting across multi-tier enterprise client groups.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hierarchyPath rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Path' ;
    rdfs:comment 'Full materialized path string representing the ancestry chain from root to child account (e.g., \'/1001/1045/1078\'). Supports efficient tree traversal queries and consolidated reporting without recursive joins.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hierarchyStatus rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Status' ;
    rdfs:comment 'Current lifecycle status of the hierarchy relationship. \'active\' = currently in force; \'inactive\' = no longer operative; \'pending\' = awaiting approval or legal completion; \'dissolved\' = JV or entity formally wound up; \'suspended\' = temporarily on hold pending review.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hierarchyVersion rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Version' ;
    rdfs:comment 'Version number of this hierarchy relationship record, incremented each time the relationship is modified (e.g., ownership percentage change, restructuring). Supports temporal versioning and audit history.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isPrimaryHierarchy rdf:type rdf:Property ;
    rdfs:label 'Is Primary Hierarchy' ;
    rdfs:comment 'Indicates whether this is the primary or default hierarchy relationship for the child account when multiple hierarchy paths exist (e.g., a subsidiary may belong to both a geographic and a functional hierarchy). True = primary hierarchy; False = secondary or alternate hierarchy.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jvAgreementNumber rdf:type rdf:Property ;
    rdfs:label 'Jv Agreement Number' ;
    rdfs:comment 'Reference number of the Joint Venture (JV) agreement document governing this hierarchy relationship, where applicable. Links to the formal JV deed or partnership agreement registered in Aconex or the document management system.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leadPartnerFlag rdf:type rdf:Property ;
    rdfs:label 'Lead Partner Flag' ;
    rdfs:comment 'Indicates whether the parent account is the designated lead partner or managing entity in a JV (Joint Venture) or consortium arrangement. True = lead/managing partner; False = non-lead participant.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ownershipPercentage rdf:type rdf:Property ;
    rdfs:label 'Ownership Percentage' ;
    rdfs:comment 'Percentage of ownership or equity stake held by the parent account in the child account. Critical for JV (Joint Venture) and subsidiary consolidation under IFRS 10/11. Ranges from 0.00 to 100.00.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:relationshipType rdf:type rdf:Property ;
    rdfs:label 'Relationship Type' ;
    rdfs:comment 'Classifies the nature of the parent-child relationship. \'subsidiary\' indicates full or majority ownership; \'jv_partner\' denotes a Joint Venture (JV) arrangement; \'branch\' indicates a regional or operational office; \'division\' indicates an internal business unit; \'holding\' indicates a holding company structure; \'associate\' indicates a minority-stake or affiliated entity. [ENUM-REF-CANDIDATE: subsidiary|jv_partner|branch|division|holding|associate|consortium_member|spe — promote to reference product if additional types are needed]' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restructuringReason rdf:type rdf:Property ;
    rdfs:label 'Restructuring Reason' ;
    rdfs:comment 'Free-text description of the business reason for creating or modifying this hierarchy relationship (e.g., corporate merger, JV formation, divestiture, regional reorganization). Provides audit context for hierarchy changes.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sectorClassification rdf:type rdf:Property ;
    rdfs:label 'Sector Classification' ;
    rdfs:comment 'Classifies the client sector for the hierarchy relationship, enabling segmentation of consolidated reporting across public-sector, private-sector, PPP (Public-Private Partnership), government, and NGO client groups.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceRecordReference rdf:type rdf:Property ;
    rdfs:label 'Source Record Reference' ;
    rdfs:comment 'The unique identifier of this hierarchy record in the originating source system (e.g., Salesforce Account Hierarchy ID or SAP Business Partner Hierarchy node ID). Enables end-to-end data lineage from source to silver layer.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:votingRightsPercentage rdf:type rdf:Property ;
    rdfs:label 'Voting Rights Percentage' ;
    rdfs:comment 'Percentage of voting rights held by the parent account in the child entity. May differ from ownership percentage in JV (Joint Venture) or PPP (Public-Private Partnership) structures where governance rights are separately negotiated.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:addressId rdf:type rdf:Property ;
    rdfs:label 'Address Id' ;
    rdfs:comment 'Unique surrogate identifier for each client address record in the Construction data platform. Serves as the primary key for the client_address entity.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Address .

ind:addressStatus rdf:type rdf:Property ;
    rdfs:label 'Address Status' ;
    rdfs:comment 'Current lifecycle status of the address record. Active indicates the address is in current use; inactive means it is no longer used; pending_validation awaits address verification; superseded means it has been replaced by a newer address; undeliverable indicates mail or correspondence has been returned.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressType rdf:type rdf:Property ;
    rdfs:label 'Address Type' ;
    rdfs:comment 'Classifies the functional purpose of the address. Registered office is the legal domicile; billing is used for invoice delivery; correspondence is the preferred mailing address; project_site_liaison is the on-site contact office for a specific project; head_office and branch_office denote organisational hierarchy locations. [ENUM-REF-CANDIDATE: registered_office|billing|correspondence|project_site_liaison|head_office|branch_office — promote to reference product]' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attentionTo rdf:type rdf:Property ;
    rdfs:label 'Attention To' ;
    rdfs:comment 'Name of the specific individual or department to whom correspondence should be directed at this address (e.g., \'Attn: Contracts Manager\' or \'Attn: Finance Department\'). Used in formal contract correspondence and RFI (Request for Information) transmittals.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:buildingName rdf:type rdf:Property ;
    rdfs:label 'Building Name' ;
    rdfs:comment 'Name of the building or complex at this address (e.g., \'Empire State Building\', \'One Canada Square\', \'Dubai World Trade Centre\'). Used for precise address identification in dense urban environments and for formal correspondence headers.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countryName rdf:type rdf:Property ;
    rdfs:label 'Country Name' ;
    rdfs:comment 'Full English name of the country corresponding to the country_code. Stored for display and reporting purposes to avoid repeated lookups against the ISO country reference table.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emailAddress rdf:type rdf:Property ;
    rdfs:label 'Email Address' ;
    rdfs:comment 'General email address associated with this address location (e.g., a departmental or office inbox). Used for electronic correspondence, transmittal delivery via Aconex, and formal notice under contract. Distinct from individual contact email addresses.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:faxNumber rdf:type rdf:Property ;
    rdfs:label 'Fax Number' ;
    rdfs:comment 'Fax number associated with this address location. Retained for clients and jurisdictions where fax remains a legally recognised method of formal notice delivery under FIDIC contract conditions.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:floorLevel rdf:type rdf:Property ;
    rdfs:label 'Floor Level' ;
    rdfs:comment 'Floor or level number within a building at this address (e.g., \'Level 12\', \'Ground Floor\', \'Basement 2\'). Used for precise delivery instructions and visitor access coordination for client site visits.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:formatType rdf:type rdf:Property ;
    rdfs:label 'Format Type' ;
    rdfs:comment 'Indicates the structural format of the address to support correct rendering and printing. Western follows street-city-state-postal conventions; eastern follows country-specific formats (e.g., Japan, China); po_box is a post office box address; free_form is an unstructured address entry.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isBillingAddress rdf:type rdf:Property ;
    rdfs:label 'Is Billing Address' ;
    rdfs:comment 'Indicates whether this address is designated as the billing address for invoice delivery and accounts receivable correspondence. Used by SAP S/4HANA AR (Accounts Receivable) module for invoice routing.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPrimary rdf:type rdf:Property ;
    rdfs:label 'Is Primary' ;
    rdfs:comment 'Indicates whether this address is the primary address for the client account. Only one address per client should be flagged as primary at any given time. Used to determine the default address for correspondence and contract documentation.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRegisteredOffice rdf:type rdf:Property ;
    rdfs:label 'Is Registered Office' ;
    rdfs:comment 'Indicates whether this address is the legally registered office address of the client entity. Required for contract execution, legal notices under FIDIC conditions, and regulatory compliance filings.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jurisdictionCode rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Code' ;
    rdfs:comment 'Legal and regulatory jurisdiction code applicable to this address, combining ISO 3166-1 country code and subdivision code (e.g., US-CA for California, AU-NSW for New South Wales). Used for tax jurisdiction mapping, OSHA/EPA regulatory compliance, and contract law determination.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:latitude rdf:type rdf:Property ;
    rdfs:label 'Latitude' ;
    rdfs:comment 'Geographic latitude coordinate of the address in decimal degrees (WGS 84 datum). Supports GIS (Geographic Information System) mapping, proximity analysis to active construction sites, and spatial analytics for project planning.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:line1 rdf:type rdf:Property ;
    rdfs:label 'Line 1' ;
    rdfs:comment 'Primary street address line including building number, street name, and suite or unit number. Represents the first line of the postal address as used in official correspondence and contract documentation.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:line2 rdf:type rdf:Property ;
    rdfs:label 'Line 2' ;
    rdfs:comment 'Secondary address line for additional location details such as floor number, building name, industrial estate, or campus identifier. Optional field used when the primary line is insufficient.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:line3 rdf:type rdf:Property ;
    rdfs:label 'Line 3' ;
    rdfs:comment 'Tertiary address line used for additional locality or district information, particularly relevant for international clients in regions where addresses require more than two street lines.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:longitude rdf:type rdf:Property ;
    rdfs:label 'Longitude' ;
    rdfs:comment 'Geographic longitude coordinate of the address in decimal degrees (WGS 84 datum). Used in conjunction with latitude for GIS (Geographic Information System) spatial analysis, site proximity calculations, and mapping of client office locations.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:phoneNumber rdf:type rdf:Property ;
    rdfs:label 'Phone Number' ;
    rdfs:comment 'Primary telephone number associated with this address location. Used for direct contact with the client office at this address for project coordination, site liaison, and contract administration purposes.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:poBoxNumber rdf:type rdf:Property ;
    rdfs:label 'Po Box Number' ;
    rdfs:comment 'Post Office (PO) Box number for clients who receive correspondence via a PO Box rather than a street address. Common for government agencies, public-sector clients, and clients in regions where PO Box delivery is standard.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postalCode rdf:type rdf:Property ;
    rdfs:label 'Postal Code' ;
    rdfs:comment 'Postal or ZIP code for the address. Used for mail routing, geographic clustering of clients, and regional analytics. Format varies by country (e.g., 5-digit US ZIP, alphanumeric UK postcode).' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredCorrespondenceLanguage rdf:type rdf:Property ;
    rdfs:label 'Preferred Correspondence Language' ;
    rdfs:comment 'ISO 639-1 or ISO 639-2 language code indicating the preferred language for correspondence sent to this address (e.g., \'en\' for English, \'fr\' for French, \'ar\' for Arabic). Supports multilingual client communication in international construction markets.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:region rdf:type rdf:Property ;
    rdfs:label 'Region' ;
    rdfs:comment 'Broad geographic region grouping for the address (e.g., North America, Middle East, Asia Pacific, Europe). Used for regional portfolio reporting, business development segmentation, and PMO (Project Management Office) territory alignment.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemAddressCode rdf:type rdf:Property ;
    rdfs:label 'Source System Address Code' ;
    rdfs:comment 'The native identifier of this address record in the originating operational system (e.g., Salesforce CRM Address ID, SAP S/4HANA partner address number). Used for data lineage, reconciliation, and cross-system deduplication.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:suiteUnitNumber rdf:type rdf:Property ;
    rdfs:label 'Suite Unit Number' ;
    rdfs:comment 'Suite, unit, or office number within a building at this address. Provides the final level of address precision for multi-tenant buildings where multiple client offices may occupy the same floor.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxJurisdictionCode rdf:type rdf:Property ;
    rdfs:label 'Tax Jurisdiction Code' ;
    rdfs:comment 'Specific tax jurisdiction code for the address as used in SAP S/4HANA tax determination. May differ from the general jurisdiction code in federal/state/local tax overlay scenarios. Used for sales tax, VAT, and withholding tax calculations on client invoices.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timeZone rdf:type rdf:Property ;
    rdfs:label 'Time Zone' ;
    rdfs:comment 'IANA time zone identifier for the address location (e.g., America/New_York, Asia/Dubai, Australia/Sydney). Used for scheduling client communications, meeting coordination, and project milestone notifications across global construction operations.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationDate rdf:type rdf:Property ;
    rdfs:label 'Validation Date' ;
    rdfs:comment 'Date on which the address was last validated against a postal authority or address verification service. Used to schedule re-validation cycles and assess data quality freshness.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:validationSource rdf:type rdf:Property ;
    rdfs:label 'Validation Source' ;
    rdfs:comment 'Name of the service or system used to validate the address (e.g., USPS, Google Maps API, Loqate, SmartyStreets). Provides traceability for data quality audits and vendor management.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationStatus rdf:type rdf:Property ;
    rdfs:label 'Validation Status' ;
    rdfs:comment 'Result of the address validation process against a postal authority or third-party address verification service. Validated means the address has been confirmed as deliverable; not_validated means validation has not been attempted; failed means the address could not be verified; partial means only some components were verified.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interactionId rdf:type rdf:Property ;
    rdfs:label 'Interaction Id' ;
    rdfs:comment 'Unique surrogate identifier for each client interaction record in the silver layer. Primary key for the client_interaction data product.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contactId rdf:type rdf:Property ;
    rdfs:label 'Contact Id' ;
    rdfs:comment 'Reference to the primary client-side stakeholder contact who participated in this interaction. Maps to the Salesforce CRM Contact object.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Contact .

ind:actionItemOwner rdf:type rdf:Property ;
    rdfs:label 'Action Item Owner' ;
    rdfs:comment 'Name or identifier of the person (internal or client-side) responsible for completing the primary action item arising from this interaction.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actionItems rdf:type rdf:Property ;
    rdfs:label 'Action Items' ;
    rdfs:comment 'Free-text description of agreed action items arising from the interaction, including the responsible party and expected completion date. Supports follow-up tracking and accountability management.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channel rdf:type rdf:Property ;
    rdfs:label 'Channel' ;
    rdfs:comment 'Medium through which the interaction was conducted. Distinguishes in-person, virtual (video conference), hybrid, or phone-only engagements. Supports channel mix analytics for BD strategy.' ;
    rdfs:domain ind:Client ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clientSeniorityLevel rdf:type rdf:Property ;
    rdfs:label 'Client Seniority Level' ;
    rdfs:comment 'Highest seniority level of client-side attendees present at the interaction (e.g., C-Suite, VP/Director, Manager). Supports executive engagement tracking and account strategy analytics.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crmActivityCode rdf:type rdf:Property ;
    rdfs:label 'Crm Activity Code' ;
    rdfs:comment 'External identifier from the Salesforce CRM Activity, Task, or Event object that is the source of record for this interaction. Enables traceability back to the originating system.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crmRecordType rdf:type rdf:Property ;
    rdfs:label 'Crm Record Type' ;
    rdfs:comment 'Salesforce CRM object type from which this interaction record was sourced (Task, Event, Call Log, or Email Log). Supports data lineage and source system traceability.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:durationMinutes rdf:type rdf:Property ;
    rdfs:label 'Duration Minutes' ;
    rdfs:comment 'Total duration of the interaction in minutes as recorded by the interaction owner. May be entered directly or derived from start/end timestamps. Supports engagement intensity analysis.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:endTimestamp rdf:type rdf:Property ;
    rdfs:label 'End Timestamp' ;
    rdfs:comment 'Precise date and time when the interaction concluded. Used in conjunction with start timestamp to derive interaction duration for BD activity analytics.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:entertainmentCost rdf:type rdf:Property ;
    rdfs:label 'Entertainment Cost' ;
    rdfs:comment 'Monetary cost incurred for client entertainment events associated with this interaction (e.g., business dinners, hospitality). Subject to anti-bribery and gifts policy compliance. Stored in the organisation\'s base currency.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:externalAttendeeCount rdf:type rdf:Property ;
    rdfs:label 'External Attendee Count' ;
    rdfs:comment 'Total number of client-side or third-party participants in the interaction. Supports stakeholder engagement breadth analysis.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:externalAttendees rdf:type rdf:Property ;
    rdfs:label 'External Attendees' ;
    rdfs:comment 'Comma-separated list of client-side or third-party attendees (names and organisations) who participated in the interaction. Supports stakeholder mapping and relationship history tracking.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:followupCompleted rdf:type rdf:Property ;
    rdfs:label 'Followup Completed' ;
    rdfs:comment 'Indicates whether the required follow-up action arising from this interaction has been completed. Supports BD activity compliance and pipeline hygiene reporting.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:followupDueDate rdf:type rdf:Property ;
    rdfs:label 'Followup Due Date' ;
    rdfs:comment 'Target date by which the follow-up action or next interaction should be completed. Used for BD pipeline management and relationship cadence monitoring.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:giftsHospitalityDeclared rdf:type rdf:Property ;
    rdfs:label 'Gifts Hospitality Declared' ;
    rdfs:comment 'Indicates whether any gifts or hospitality provided during this interaction have been formally declared in accordance with the organisation\'s anti-bribery and corruption policy. Supports compliance and audit requirements.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:interactionDate rdf:type rdf:Property ;
    rdfs:label 'Interaction Date' ;
    rdfs:comment 'Calendar date on which the interaction took place or is scheduled to take place. Used for BD activity KPI reporting (interactions per account per quarter).' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:interactionDescription rdf:type rdf:Property ;
    rdfs:label 'Interaction Description' ;
    rdfs:comment 'Detailed narrative of the interaction including agenda, topics discussed, key decisions made, and context. Supports account review preparation and relationship history tracking.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interactionStatus rdf:type rdf:Property ;
    rdfs:label 'Interaction Status' ;
    rdfs:comment 'Current lifecycle status of the interaction record. Indicates whether the interaction was planned, successfully completed, cancelled, rescheduled, or resulted in a no-show.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interactionType rdf:type rdf:Property ;
    rdfs:label 'Interaction Type' ;
    rdfs:comment 'Classification of the interaction channel or format. Distinguishes formal meetings, site visits, phone calls, presentations, entertainment events, and formal correspondence. [ENUM-REF-CANDIDATE: meeting|site_visit|phone_call|presentation|entertainment|correspondence|video_call|email|workshop|conference — promote to reference product]' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:internalAttendeeCount rdf:type rdf:Property ;
    rdfs:label 'Internal Attendee Count' ;
    rdfs:comment 'Total number of internal employees who participated in the interaction. Supports BD resource allocation analysis and engagement intensity KPIs.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:internalAttendees rdf:type rdf:Property ;
    rdfs:label 'Internal Attendees' ;
    rdfs:comment 'Comma-separated list of internal employees (names or employee IDs) who participated in the interaction. Supports account review preparation and engagement coverage analysis.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isBillable rdf:type rdf:Property ;
    rdfs:label 'Is Billable' ;
    rdfs:comment 'Indicates whether the time or cost associated with this interaction is billable to the client or project. Relevant for reimbursable contract types (e.g., cost-plus, EPC reimbursable).' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isExecutiveEngagement rdf:type rdf:Property ;
    rdfs:label 'Is Executive Engagement' ;
    rdfs:comment 'Indicates whether this interaction involved C-suite or executive-level participants from either the internal organisation or the client side. Supports executive engagement KPI reporting and account strategy reviews.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:linkedCoReference rdf:type rdf:Property ;
    rdfs:label 'Linked Co Reference' ;
    rdfs:comment 'Reference number of the Change Order (CO) discussed during this interaction, if applicable. Supports contract administration and commercial dispute tracking.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:linkedRfpReference rdf:type rdf:Property ;
    rdfs:label 'Linked Rfp Reference' ;
    rdfs:comment 'Reference number or identifier of the Request for Proposal (RFP) associated with this interaction, if applicable. Supports bid pursuit tracking and BD pipeline management.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:location rdf:type rdf:Property ;
    rdfs:label 'Location' ;
    rdfs:comment 'Physical or virtual location where the interaction took place (e.g., client head office address, project site name, video conference platform). Maps to Salesforce CRM Event Location field.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outcome rdf:type rdf:Property ;
    rdfs:label 'Outcome' ;
    rdfs:comment 'Overall result or conclusion of the interaction as assessed by the interaction owner. Indicates whether the engagement moved the relationship or opportunity forward, was neutral, or raised concerns requiring escalation.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purpose rdf:type rdf:Property ;
    rdfs:label 'Purpose' ;
    rdfs:comment 'Primary business purpose or intent of the interaction. Distinguishes relationship-building activities from bid pursuit, project review, issue resolution, contract negotiation, or commissioning and handover discussions. [ENUM-REF-CANDIDATE: relationship_building|bid_pursuit|project_review|issue_resolution|contract_negotiation|handover|technical_review|commercial_discussion — promote to reference product]' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sentimentIndicator rdf:type rdf:Property ;
    rdfs:label 'Sentiment Indicator' ;
    rdfs:comment 'Qualitative assessment of the client\'s sentiment or disposition observed during the interaction, as recorded by the interaction owner. Supports relationship health monitoring and account review preparation.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:startTimestamp rdf:type rdf:Property ;
    rdfs:label 'Start Timestamp' ;
    rdfs:comment 'Precise date and time when the interaction commenced. Supports duration calculation and scheduling analytics. Sourced from Salesforce CRM Event start datetime.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:topicsDiscussed rdf:type rdf:Property ;
    rdfs:label 'Topics Discussed' ;
    rdfs:comment 'Structured or free-text list of key topics covered during the interaction (e.g., contract scope, change orders, project schedule, new bid opportunities, relationship concerns). Supports thematic analysis of client engagement.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualAwardDate rdf:type rdf:Property ;
    rdfs:label 'Actual Award Date' ;
    rdfs:comment 'Date on which the contract was formally awarded. Populated upon win outcome. Used for win/loss analysis and BD cycle time measurement.' ;
    rdfs:domain ind:ClientOpportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:bidCostEstimate rdf:type rdf:Property ;
    rdfs:label 'Bid Cost Estimate' ;
    rdfs:comment 'Internal estimate of the cost to prepare and submit the bid (tendering cost), including estimating, engineering, and proposal resources. Used for bid cost tracking and ROI analysis on BD spend.' ;
    rdfs:domain ind:ClientOpportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bidNoBidDecision rdf:type rdf:Property ;
    rdfs:label 'Bid No Bid Decision' ;
    rdfs:comment 'Formal decision outcome from the bid/no-bid review process indicating whether the company will pursue this opportunity. Pending_review indicates the decision gate has not yet been completed.' ;
    rdfs:domain ind:ClientOpportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bidNoBidDecisionDate rdf:type rdf:Property ;
    rdfs:label 'Bid No Bid Decision Date' ;
    rdfs:comment 'Date on which the formal bid/no-bid decision was made and recorded. Used for governance audit trails and BD cycle time analysis.' ;
    rdfs:domain ind:ClientOpportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:bidSubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Bid Submission Date' ;
    rdfs:comment 'Actual or planned date on which the bid/tender/proposal was or is to be submitted to the client. Critical scheduling milestone for BD and estimating teams.' ;
    rdfs:domain ind:ClientOpportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:bimRequired rdf:type rdf:Property ;
    rdfs:label 'Bim Required' ;
    rdfs:comment 'Indicates whether the client mandates Building Information Modeling (BIM) as a project delivery requirement. True = BIM is contractually required. Drives technology and resource planning for the bid.' ;
    rdfs:domain ind:Client ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:boqAvailable rdf:type rdf:Property ;
    rdfs:label 'Boq Available' ;
    rdfs:comment 'Indicates whether a Bill of Quantities (BOQ) has been issued by the client as part of the tender package. True = BOQ provided; False = lump-sum or design-build without BOQ. Affects estimating approach and bid strategy.' ;
    rdfs:domain ind:ClientOpportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:clientOpportunityDescription rdf:type rdf:Property ;
    rdfs:label 'Client Opportunity Description' ;
    rdfs:comment 'Free-text narrative describing the scope, nature, and key characteristics of the construction opportunity. Provides context for BD team members reviewing the pipeline and supports AI/ML-based opportunity classification.' ;
    rdfs:domain ind:ClientOpportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competitorNames rdf:type rdf:Property ;
    rdfs:label 'Competitor Names' ;
    rdfs:comment 'Names of known competing firms bidding on the same opportunity. Free-text or comma-separated list. Confidential competitive intelligence used for bid strategy and market positioning analysis.' ;
    rdfs:domain ind:ClientOpportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryModel rdf:type rdf:Property ;
    rdfs:label 'Delivery Model' ;
    rdfs:comment 'Contract delivery model under which the construction project will be executed. EPC = Engineering Procurement and Construction; GMP = Guaranteed Maximum Price; DBB = Design-Bid-Build; DB = Design-Build; PPP = Public-Private Partnership; BOT = Build-Operate-Transfer; FIDIC = FIDIC-based contract. Drives risk allocation and commercial strategy. [ENUM-REF-CANDIDATE: EPC|GMP|DBB|DB|PPP|BOT|FIDIC — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:esgRequirements rdf:type rdf:Property ;
    rdfs:label 'Esg Requirements' ;
    rdfs:comment 'Description of any Environmental, Social, and Governance (ESG) requirements specified by the client for this opportunity (e.g., carbon targets, local content requirements, diversity commitments). Free-text field for BD qualification notes.' ;
    rdfs:domain ind:ClientOpportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedAwardDate rdf:type rdf:Property ;
    rdfs:label 'Expected Award Date' ;
    rdfs:comment 'Anticipated date on which the contract is expected to be formally awarded to the company. Used for pipeline close-date forecasting and resource mobilization planning.' ;
    rdfs:domain ind:ClientOpportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:expectedNtpDate rdf:type rdf:Property ;
    rdfs:label 'Expected Ntp Date' ;
    rdfs:comment 'Anticipated date on which the client will issue the Notice to Proceed (NTP), authorizing the start of construction work. Used for resource planning and revenue recognition scheduling.' ;
    rdfs:domain ind:ClientOpportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isJvBid rdf:type rdf:Property ;
    rdfs:label 'Is Jv Bid' ;
    rdfs:comment 'Indicates whether this opportunity is being pursued as a Joint Venture (JV) arrangement. True = JV bid; False = sole-entity bid. Drives JV governance and risk review processes.' ;
    rdfs:domain ind:ClientOpportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jvPartnerNames rdf:type rdf:Property ;
    rdfs:label 'Jv Partner Names' ;
    rdfs:comment 'Names of Joint Venture (JV) partners with whom the company intends to bid on this opportunity. Relevant for JV-structured bids common in large infrastructure and EPC projects. Confidential commercial information.' ;
    rdfs:domain ind:ClientOpportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lossReason rdf:type rdf:Property ;
    rdfs:label 'Loss Reason' ;
    rdfs:comment 'Reason code or description explaining why the opportunity was lost or withdrawn (e.g., price, technical score, client relationship, competitor strength, scope mismatch). Populated when win_loss_outcome is \'lost\' or \'withdrawn\'. Used for BD lessons-learned and competitive intelligence. [ENUM-REF-CANDIDATE: price|technical_score|client_relationship|competitor_strength|scope_mismatch|capacity|no_bid_decision|other — promote to reference product]' ;
    rdfs:domain ind:ClientOpportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextAction rdf:type rdf:Property ;
    rdfs:label 'Next Action' ;
    rdfs:comment 'Description of the next planned business development action required to advance this opportunity (e.g., \'Submit EOI by 15-Mar\', \'Attend client briefing\', \'Complete bid/no-bid review\'). Operational field used by BD team for pipeline management.' ;
    rdfs:domain ind:ClientOpportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextActionDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Action Due Date' ;
    rdfs:comment 'Target date by which the next business development action must be completed. Used for BD pipeline hygiene, follow-up scheduling, and opportunity stagnation alerts.' ;
    rdfs:domain ind:ClientOpportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:opportunityStatus rdf:type rdf:Property ;
    rdfs:label 'Opportunity Status' ;
    rdfs:comment 'Lifecycle status of the opportunity record indicating whether it is actively pursued, won, lost, on hold, or cancelled. Distinct from pipeline_stage which tracks the BD workflow step.' ;
    rdfs:domain ind:ClientOpportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pipelineStage rdf:type rdf:Property ;
    rdfs:label 'Pipeline Stage' ;
    rdfs:comment 'Current stage of the opportunity in the business development pipeline. Drives pipeline forecasting and BD reporting. [ENUM-REF-CANDIDATE: prospect|qualification|bid_preparation|submitted|negotiation|awarded|lost|no_bid — promote to reference product]' ;
    rdfs:domain ind:ClientOpportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:probabilityOfWinPct rdf:type rdf:Property ;
    rdfs:label 'Probability Of Win Pct' ;
    rdfs:comment 'Estimated probability (0–100%) that the company will be awarded this contract. Used to calculate weighted pipeline value for revenue forecasting. Assigned by the BD owner and reviewed at stage gates.' ;
    rdfs:domain ind:ClientOpportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:projectDurationMonths rdf:type rdf:Property ;
    rdfs:label 'Project Duration Months' ;
    rdfs:comment 'Estimated duration of the construction project in months from NTP to practical completion. Used for resource planning, revenue phasing, and schedule risk assessment.' ;
    rdfs:domain ind:ClientOpportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:projectLocationCountry rdf:type rdf:Property ;
    rdfs:label 'Project Location Country' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code for the country where the construction project will be executed (e.g., USA, ARE, GBR). Used for geographic pipeline analysis and regulatory compliance scoping.' ;
    rdfs:domain ind:ClientOpportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectLocationRegion rdf:type rdf:Property ;
    rdfs:label 'Project Location Region' ;
    rdfs:comment 'State, province, or region where the construction project will be executed. Used for regional pipeline reporting, resource planning, and jurisdictional compliance (e.g., OSHA state plans, local building codes).' ;
    rdfs:domain ind:ClientOpportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rfpIssueDate rdf:type rdf:Property ;
    rdfs:label 'Rfp Issue Date' ;
    rdfs:comment 'Date on which the client issued the Request for Proposal (RFP) or Invitation to Tender (ITT). Marks the formal start of the bid preparation phase.' ;
    rdfs:domain ind:ClientOpportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rfqNumber rdf:type rdf:Property ;
    rdfs:label 'Rfq Number' ;
    rdfs:comment 'Client-issued Request for Quotation (RFQ) or Request for Proposal (RFP) reference number. Used for cross-referencing with client procurement documents and Aconex correspondence.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sector rdf:type rdf:Property ;
    rdfs:label 'Sector' ;
    rdfs:comment 'Sector classification of the client commissioning the work: public-sector (government/municipal), private-sector (developer/corporate), or PPP/BOT (public-private partnership or build-operate-transfer arrangement). Used for client segmentation and reporting.' ;
    rdfs:domain ind:Client ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceCrmOpportunityCode rdf:type rdf:Property ;
    rdfs:label 'Source Crm Opportunity Code' ;
    rdfs:comment 'Original opportunity identifier from the Salesforce CRM system of record. Used for data lineage, cross-system reconciliation, and traceability back to the operational source.' ;
    rdfs:domain ind:ClientOpportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strategicPriority rdf:type rdf:Property ;
    rdfs:label 'Strategic Priority' ;
    rdfs:comment 'Internal strategic priority classification assigned to this opportunity by BD leadership. Tier 1 = highest strategic importance (must-win); Tier 2 = important but not critical; Tier 3 = opportunistic. Drives resource allocation for bid preparation.' ;
    rdfs:domain ind:ClientOpportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:weightedPipelineValue rdf:type rdf:Property ;
    rdfs:label 'Weighted Pipeline Value' ;
    rdfs:comment 'Estimated contract value multiplied by the probability of win percentage, representing the risk-adjusted contribution of this opportunity to the revenue forecast. Key metric for executive pipeline reporting.' ;
    rdfs:domain ind:ClientOpportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:winLossOutcome rdf:type rdf:Property ;
    rdfs:label 'Win Loss Outcome' ;
    rdfs:comment 'Final outcome of the opportunity after the bid process concludes. Won = contract awarded to company; Lost = awarded to competitor; Withdrawn = company withdrew bid; No_award = client cancelled procurement. Drives win rate analytics and BD performance reporting.' ;
    rdfs:domain ind:ClientOpportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clientPrequalificationId rdf:type rdf:Property ;
    rdfs:label 'Client Prequalification Id' ;
    rdfs:comment 'Unique surrogate identifier for each client prequalification record in the Databricks Silver Layer. Primary key for this entity.' ;
    rdfs:domain ind:ClientPrequalification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approvingAuthority rdf:type rdf:Property ;
    rdfs:label 'Approving Authority' ;
    rdfs:comment 'Name or designation of the client-side authority (individual, committee, or department) that reviewed and approved or rejected the prequalification submission.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clientContactEmail rdf:type rdf:Property ;
    rdfs:label 'Client Contact Email' ;
    rdfs:comment 'Email address of the primary client contact responsible for this prequalification. Used for submission correspondence and renewal notifications.' ;
    rdfs:domain ind:ClientPrequalification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clientContactName rdf:type rdf:Property ;
    rdfs:label 'Client Contact Name' ;
    rdfs:comment 'Name of the primary contact person at the client organization responsible for managing this prequalification process.' ;
    rdfs:domain ind:Client ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionResolutionDate rdf:type rdf:Property ;
    rdfs:label 'Condition Resolution Date' ;
    rdfs:comment 'The date by which all imposed conditions must be resolved or evidenced to the client to convert a conditional approval to full approval.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contractDeliveryMethod rdf:type rdf:Property ;
    rdfs:label 'Contract Delivery Method' ;
    rdfs:comment 'The project delivery method for which this prequalification applies: Engineering Procurement and Construction (EPC), Design-Build (DB), Design-Bid-Build (DBB), Guaranteed Maximum Price (GMP), Build-Operate-Transfer (BOT), or Public-Private Partnership (PPP).' ;
    rdfs:domain ind:ClientPrequalification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:environmentalCertificationRequired rdf:type rdf:Property ;
    rdfs:label 'Environmental Certification Required' ;
    rdfs:comment 'Indicates whether the client requires ISO 14001 or equivalent environmental management certification as part of the prequalification criteria.' ;
    rdfs:domain ind:ClientPrequalification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:financialAuditRequired rdf:type rdf:Property ;
    rdfs:label 'Financial Audit Required' ;
    rdfs:comment 'Indicates whether the client requires submission of audited financial statements as part of the prequalification documentation package.' ;
    rdfs:domain ind:ClientPrequalification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:geographicScope rdf:type rdf:Property ;
    rdfs:label 'Geographic Scope' ;
    rdfs:comment 'The geographic region, country, or territory for which this prequalification is valid. Prequalification may be limited to specific jurisdictions or project locations.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hseCertificationRequired rdf:type rdf:Property ;
    rdfs:label 'Hse Certification Required' ;
    rdfs:comment 'Indicates whether the client requires valid HSE certifications (e.g., ISO 45001, OSHA compliance) as a mandatory condition of prequalification in this category.' ;
    rdfs:domain ind:ClientPrequalification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:insuranceVerificationRequired rdf:type rdf:Property ;
    rdfs:label 'Insurance Verification Required' ;
    rdfs:comment 'Indicates whether the client requires proof of adequate insurance coverage (professional indemnity, public liability, workers compensation) as a prequalification condition.' ;
    rdfs:domain ind:ClientPrequalification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maxProjectValue rdf:type rdf:Property ;
    rdfs:label 'Max Project Value' ;
    rdfs:comment 'The maximum single-project contract value (in the specified currency) for which the firm is prequalified by this client. Bids exceeding this threshold require separate approval or re-prequalification.' ;
    rdfs:domain ind:ClientPrequalification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumPassingScore rdf:type rdf:Property ;
    rdfs:label 'Minimum Passing Score' ;
    rdfs:comment 'The minimum score threshold set by the client that the construction firm must achieve to receive an approved prequalification status in this category.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:prequalificationNumber rdf:type rdf:Property ;
    rdfs:label 'Prequalification Number' ;
    rdfs:comment 'Externally-known unique reference number assigned by the client organization to this prequalification submission. Used in all correspondence and bid eligibility checks.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityCertificationRequired rdf:type rdf:Property ;
    rdfs:label 'Quality Certification Required' ;
    rdfs:comment 'Indicates whether the client mandates a valid ISO 9001 or equivalent quality management system certification as a prequalification requirement.' ;
    rdfs:domain ind:ClientPrequalification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:referenceProjectsRequired rdf:type rdf:Property ;
    rdfs:label 'Reference Projects Required' ;
    rdfs:comment 'Minimum number of comparable completed projects the client requires the firm to demonstrate as part of the prequalification submission.' ;
    rdfs:domain ind:ClientPrequalification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rejectionReason rdf:type rdf:Property ;
    rdfs:label 'Rejection Reason' ;
    rdfs:comment 'Explanation provided by the client for rejecting the prequalification submission. Populated only when prequalification_status is \'rejected\'. Used for gap analysis and resubmission planning.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalActionsRequired rdf:type rdf:Property ;
    rdfs:label 'Renewal Actions Required' ;
    rdfs:comment 'Free-text description of specific actions, documentation updates, or re-submissions required by the client to successfully renew this prequalification.' ;
    rdfs:domain ind:ClientPrequalification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalDueDate rdf:type rdf:Property ;
    rdfs:label 'Renewal Due Date' ;
    rdfs:comment 'The date by which the firm must initiate the renewal process to maintain uninterrupted prequalification status. Typically set before the expiry date to allow processing time.' ;
    rdfs:domain ind:ClientPrequalification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:renewalPeriodMonths rdf:type rdf:Property ;
    rdfs:label 'Renewal Period Months' ;
    rdfs:comment 'The duration in months of each prequalification validity period before renewal is required. Typically 12, 24, or 36 months depending on client policy.' ;
    rdfs:domain ind:ClientPrequalification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:renewalRequired rdf:type rdf:Property ;
    rdfs:label 'Renewal Required' ;
    rdfs:comment 'Indicates whether this prequalification requires periodic renewal to remain valid, as opposed to a one-time permanent approval.' ;
    rdfs:domain ind:ClientPrequalification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rfpEligibilityFlag rdf:type rdf:Property ;
    rdfs:label 'Rfp Eligibility Flag' ;
    rdfs:comment 'Indicates whether the firm is currently eligible to receive and respond to RFPs from this client in the specified work category, based on active prequalification status.' ;
    rdfs:domain ind:ClientPrequalification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rfqEligibilityFlag rdf:type rdf:Property ;
    rdfs:label 'Rfq Eligibility Flag' ;
    rdfs:comment 'Indicates whether the firm is currently eligible to receive and respond to RFQs from this client in the specified work category, based on active prequalification status.' ;
    rdfs:domain ind:ClientPrequalification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:submittedTrir rdf:type rdf:Property ;
    rdfs:label 'Submitted Trir' ;
    rdfs:comment 'The firm\'s actual TRIR value submitted as part of the prequalification documentation, typically based on the most recent 12-month or 3-year rolling average.' ;
    rdfs:domain ind:ClientPrequalification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trirThreshold rdf:type rdf:Property ;
    rdfs:label 'Trir Threshold' ;
    rdfs:comment 'The maximum Total Recordable Incident Rate (TRIR) the client permits for prequalification. If the firm\'s TRIR exceeds this value, prequalification may be denied or revoked.' ;
    rdfs:domain ind:ClientPrequalification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:workCategory rdf:type rdf:Property ;
    rdfs:label 'Work Category' ;
    rdfs:comment 'The construction discipline or scope category for which prequalification has been assessed (e.g., civil, MEP, EPC, marine, tunneling, structural, roads, bridges). Determines which types of RFPs/RFQs the firm is eligible to bid on. [ENUM-REF-CANDIDATE: civil|mep|epc|marine|tunneling|structural|roads|bridges|power|rail — promote to reference product]' ;
    rdfs:domain ind:ClientPrequalification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:yearsExperienceRequired rdf:type rdf:Property ;
    rdfs:label 'Years Experience Required' ;
    rdfs:comment 'Minimum number of years of relevant construction experience in the specified work category that the client requires for prequalification.' ;
    rdfs:domain ind:ClientPrequalification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:projectEngagementId rdf:type rdf:Property ;
    rdfs:label 'Project Engagement Id' ;
    rdfs:comment 'Unique surrogate identifier for the client project engagement record. Primary key for this bridge entity linking a client account to a specific construction project.' ;
    rdfs:domain ind:ProjectEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:agreementId rdf:type rdf:Property ;
    rdfs:label 'Agreement Id' ;
    rdfs:comment 'Reference to the primary contract governing this client-project engagement (e.g., EPC, FIDIC, GMP, DB, DBB, or PPP/BOT contract). Links to the contract master record.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Agreement .

ind:projectManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Project Manager Employee Id' ;
    rdfs:comment 'Foreign key linking to hr.employee. Business justification: Each project engagement is assigned a project manager (HR employee), essential for schedule, cost, and risk reporting.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:advancePaymentAmount rdf:type rdf:Property ;
    rdfs:label 'Advance Payment Amount' ;
    rdfs:comment 'The value of any advance payment made by the client to the contractor at the commencement of this engagement, typically secured by an advance payment guarantee. Expressed in the contract currency.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvedVariationValue rdf:type rdf:Property ;
    rdfs:label 'Approved Variation Value' ;
    rdfs:comment 'The cumulative value of all approved Change Orders (CO) / variations issued by the client on this engagement to date. Reflects the net adjustment to the original contract value due to scope changes.' ;
    rdfs:domain ind:ProjectEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bidReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Bid Reference Number' ;
    rdfs:comment 'The reference number assigned to the original bid or tender submission (RFP/RFQ response) that led to this engagement being awarded. Links the engagement back to the opportunity pipeline in the CRM.' ;
    rdfs:domain ind:ProjectEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clientRole rdf:type rdf:Property ;
    rdfs:label 'Client Role' ;
    rdfs:comment 'The functional role the client plays in this project engagement. Distinguishes between the primary owner, co-sponsor in a joint venture (JV), lead JV partner, funding agency (e.g., government body), end-user of the completed asset, or developer. [ENUM-REF-CANDIDATE: owner|co_sponsor|jv_lead|funding_agency|end_user|developer|ppp_authority|bot_concessionaire — promote to reference product if additional roles are needed]' ;
    rdfs:domain ind:ProjectEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:communicationPreference rdf:type rdf:Property ;
    rdfs:label 'Communication Preference' ;
    rdfs:comment 'The client\'s preferred channel for formal project communications and correspondence on this engagement. Determines how RFIs, submittals, transmittals, and official notices are delivered.' ;
    rdfs:domain ind:ProjectEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractCurrency rdf:type rdf:Property ;
    rdfs:label 'Contract Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the contract value and financial commitments in this engagement (e.g., USD, EUR, GBP, AED). Required for multi-currency project reporting and IFRS/GAAP compliance.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Contract Reference Number' ;
    rdfs:comment 'The externally-known contract number or agreement reference assigned to the governing contract for this engagement. Used for cross-referencing with contract administration systems and client correspondence.' ;
    rdfs:domain ind:ProjectEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractValue rdf:type rdf:Property ;
    rdfs:label 'Contract Value' ;
    rdfs:comment 'The total awarded contract value for this client-project engagement as agreed at contract execution. Represents the baseline financial commitment from the client. Expressed in the contract currency.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:disputeStatus rdf:type rdf:Property ;
    rdfs:label 'Dispute Status' ;
    rdfs:comment 'Current status of any formal contractual dispute between the client and the contractor on this engagement. Tracks the dispute resolution lifecycle from initial notice through negotiation, adjudication, or arbitration to resolution.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dlpEndDate rdf:type rdf:Property ;
    rdfs:label 'Dlp End Date' ;
    rdfs:comment 'The date on which the Defects Liability Period (DLP) expires, after which the contractor\'s obligation to rectify defects at no cost to the client ceases. Critical for contract close-out and final account settlement.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:engagementEndDate rdf:type rdf:Property ;
    rdfs:label 'Engagement End Date' ;
    rdfs:comment 'The date on which the client\'s formal involvement in the project is expected to conclude or has concluded. Typically aligned with project handover, Defects Liability Period (DLP) expiry, or BOT concession end date. Nullable for open-ended engagements.' ;
    rdfs:domain ind:ProjectEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:engagementNotes rdf:type rdf:Property ;
    rdfs:label 'Engagement Notes' ;
    rdfs:comment 'Free-text field for capturing qualitative notes, special conditions, or contextual information relevant to this client-project engagement that are not captured in structured fields. Used by account managers and project directors.' ;
    rdfs:domain ind:ProjectEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engagementReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Engagement Reference Number' ;
    rdfs:comment 'Externally-known alphanumeric reference code assigned to this client-project engagement. Used in correspondence, transmittals, and CRM tracking to uniquely identify the engagement across systems.' ;
    rdfs:domain ind:ProjectEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engagementStartDate rdf:type rdf:Property ;
    rdfs:label 'Engagement Start Date' ;
    rdfs:comment 'The date on which the client\'s formal involvement in the project commenced. Typically aligned with the Notice to Proceed (NTP) date or the contract execution date.' ;
    rdfs:domain ind:ProjectEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:engagementStatus rdf:type rdf:Property ;
    rdfs:label 'Engagement Status' ;
    rdfs:comment 'Current lifecycle state of the client-project engagement. Tracks whether the engagement is actively ongoing, pending formal commencement (awaiting NTP), on hold, completed at project handover, terminated early, or cancelled prior to commencement.' ;
    rdfs:domain ind:ProjectEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engagementType rdf:type rdf:Property ;
    rdfs:label 'Engagement Type' ;
    rdfs:comment 'Classification of the contractual or commercial arrangement type governing this engagement. Reflects the delivery model: EPC (Engineering Procurement and Construction), Design-Build (DB), Design-Bid-Build (DBB), Public-Private Partnership (PPP), Build-Operate-Transfer (BOT), Guaranteed Maximum Price (GMP), framework agreement, or direct award. [ENUM-REF-CANDIDATE: epc|design_build|design_bid_build|ppp|bot|gmp|framework|direct_award — promote to reference product]' ;
    rdfs:domain ind:ProjectEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eotDaysGranted rdf:type rdf:Property ;
    rdfs:label 'Eot Days Granted' ;
    rdfs:comment 'The total number of calendar days of Extension of Time (EOT) formally granted by the client to the contractor on this engagement to date. Adjusts the contractual completion date and affects LD exposure.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fundingSource rdf:type rdf:Property ;
    rdfs:label 'Funding Source' ;
    rdfs:comment 'Classification of the primary funding mechanism used by the client to finance this project engagement. Supports financial risk assessment and reporting. [ENUM-REF-CANDIDATE: government_grant|private_equity|bank_loan|bond_issuance|multilateral|internal_budget|mixed|ppp_concession — promote to reference product]' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:handoverDate rdf:type rdf:Property ;
    rdfs:label 'Handover Date' ;
    rdfs:comment 'The actual or planned date on which the completed project asset was or is expected to be handed over to the client. Marks the transition from construction to the Defects Liability Period (DLP) or Operations and Maintenance (O&M) phase.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:hseRequirementsClassification rdf:type rdf:Property ;
    rdfs:label 'Hse Requirements Classification' ;
    rdfs:comment 'Classification of the HSE (Health, Safety and Environment) requirements imposed by the client for this engagement. Reflects the risk profile and regulatory environment: standard (baseline OSHA/ISO 45001), enhanced (client-specific elevated requirements), or critical (high-hazard environments such as nuclear, offshore, or major infrastructure).' ;
    rdfs:domain ind:ProjectEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceComplianceVerified rdf:type rdf:Property ;
    rdfs:label 'Insurance Compliance Verified' ;
    rdfs:comment 'Indicates whether the contractor\'s required insurance policies (e.g., professional indemnity, public liability, contractor\'s all-risk) have been verified as compliant with the client\'s contractual requirements for this engagement.' ;
    rdfs:domain ind:ProjectEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jvParticipationPercentage rdf:type rdf:Property ;
    rdfs:label 'Jv Participation Percentage' ;
    rdfs:comment 'The client\'s ownership or participation share percentage in a Joint Venture (JV) arrangement for this project. Applicable when the client role is co-sponsor or JV lead. Null for sole-owner engagements.' ;
    rdfs:domain ind:ProjectEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Updated Timestamp' ;
    rdfs:comment 'The timestamp at which this client-project engagement record was most recently modified. Supports change tracking, data freshness monitoring, and incremental data pipeline processing in the Databricks Silver layer.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:liquidatedDamagesRate rdf:type rdf:Property ;
    rdfs:label 'Liquidated Damages Rate' ;
    rdfs:comment 'The contractually agreed daily or weekly Liquidated Damages (LD) rate payable by the contractor to the client in the event of project delay beyond the agreed completion date. Expressed in the contract currency per day.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ntpDate rdf:type rdf:Property ;
    rdfs:label 'Ntp Date' ;
    rdfs:comment 'The date on which the Notice to Proceed (NTP) was formally issued by the client to the contractor, authorizing commencement of construction works. A critical contractual milestone in the engagement lifecycle.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:performanceBondRequired rdf:type rdf:Property ;
    rdfs:label 'Performance Bond Required' ;
    rdfs:comment 'Indicates whether the client has required the contractor to provide a performance bond as a financial security instrument for this engagement. Affects contract financial structuring and risk management.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:relationshipTier rdf:type rdf:Property ;
    rdfs:label 'Relationship Tier' ;
    rdfs:comment 'Segmentation tier assigned to this client engagement based on strategic importance, revenue contribution, and long-term relationship value. Drives account management priority and resource allocation.' ;
    rdfs:domain ind:ProjectEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:repeatClient rdf:type rdf:Property ;
    rdfs:label 'Repeat Client' ;
    rdfs:comment 'Indicates whether this client has previously engaged the construction company on one or more prior projects. Supports client relationship analytics, win-rate reporting, and strategic account management.' ;
    rdfs:domain ind:ProjectEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reportingFrequency rdf:type rdf:Property ;
    rdfs:label 'Reporting Frequency' ;
    rdfs:comment 'The agreed frequency at which formal project progress reports are submitted to the client for this engagement. Governs the reporting cadence for schedule, cost, and HSE performance updates.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:satisfactionScore rdf:type rdf:Property ;
    rdfs:label 'Satisfaction Score' ;
    rdfs:comment 'Numeric score representing the client\'s satisfaction with the construction company\'s performance on this engagement, typically captured through formal client satisfaction surveys. Scored on a standardized scale (e.g., 1.00–5.00 or 0.00–10.00).' ;
    rdfs:domain ind:ProjectEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:satisfactionSurveyDate rdf:type rdf:Property ;
    rdfs:label 'Satisfaction Survey Date' ;
    rdfs:comment 'The date on which the most recent client satisfaction survey was conducted for this engagement. Used to track the currency of satisfaction data and schedule follow-up surveys.' ;
    rdfs:domain ind:ProjectEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:surveyId rdf:type rdf:Property ;
    rdfs:label 'Survey Id' ;
    rdfs:comment 'Unique system-generated identifier for each client satisfaction survey record. Primary key for the client_survey data product.' ;
    rdfs:domain ind:Survey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:respondentContactId rdf:type rdf:Property ;
    rdfs:label 'Respondent Contact Id' ;
    rdfs:comment 'Reference to the individual stakeholder contact at the client organisation who completed or responded to this survey.' ;
    rdfs:domain ind:Survey ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Contact .

ind:administrationDate rdf:type rdf:Property ;
    rdfs:label 'Administration Date' ;
    rdfs:comment 'The date on which the survey was formally administered or distributed to the client respondent. Principal business event date for this transaction.' ;
    rdfs:domain ind:Survey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:clientSector rdf:type rdf:Property ;
    rdfs:label 'Client Sector' ;
    rdfs:comment 'Sector classification of the client at the time of survey, distinguishing between public-sector, private-sector, Public-Private Partnership (PPP), Build-Operate-Transfer (BOT), and Joint Venture (JV) arrangements. Enables sector-level satisfaction benchmarking.' ;
    rdfs:domain ind:Client ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:communicationScore rdf:type rdf:Property ;
    rdfs:label 'Communication Score' ;
    rdfs:comment 'Client-rated score for the quality, frequency, and clarity of communication from the construction company, including reporting, RFI (Request for Information) responses, and stakeholder engagement.' ;
    rdfs:domain ind:Survey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contractType rdf:type rdf:Property ;
    rdfs:label 'Contract Type' ;
    rdfs:comment 'The type of construction contract under which the associated project is delivered (e.g., EPC – Engineering Procurement and Construction, DB – Design-Build, DBB – Design-Bid-Build, GMP – Guaranteed Maximum Price, FIDIC). Provides commercial context for interpreting satisfaction scores. [ENUM-REF-CANDIDATE: epc|db|dbb|gmp|fidic|cost_plus|lump_sum — promote to reference product]' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costManagementScore rdf:type rdf:Property ;
    rdfs:label 'Cost Management Score' ;
    rdfs:comment 'Client-rated score for the construction company\'s transparency, accuracy, and control of project costs, including change order (CO) management and budget reporting.' ;
    rdfs:domain ind:Survey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dueDate rdf:type rdf:Property ;
    rdfs:label 'Due Date' ;
    rdfs:comment 'Target date by which the client respondent is expected to complete and return the survey. Used for follow-up scheduling and response rate monitoring.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:escalationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Escalation Required Flag' ;
    rdfs:comment 'Indicates whether the survey results have triggered an escalation to senior management or executive leadership due to critically low scores or identified relationship risks.' ;
    rdfs:domain ind:Survey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:followUpCompletedDate rdf:type rdf:Property ;
    rdfs:label 'Follow Up Completed Date' ;
    rdfs:comment 'Actual date on which all recommended follow-up engagement actions were completed and closed. Used to measure responsiveness and account management effectiveness.' ;
    rdfs:domain ind:Survey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:followUpDueDate rdf:type rdf:Property ;
    rdfs:label 'Follow Up Due Date' ;
    rdfs:comment 'Target date by which the recommended follow-up engagement actions must be completed. Used for account management task scheduling and overdue action reporting.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:followUpStatus rdf:type rdf:Property ;
    rdfs:label 'Follow Up Status' ;
    rdfs:comment 'Current status of the follow-up actions identified from this survey. Tracks whether recommended engagement actions have been initiated, completed, or escalated to senior management.' ;
    rdfs:domain ind:Survey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:innovationScore rdf:type rdf:Property ;
    rdfs:label 'Innovation Score' ;
    rdfs:comment 'Client-rated score for the construction company\'s contribution of innovative solutions, value engineering, and use of technologies such as BIM (Building Information Modeling) on the project.' ;
    rdfs:domain ind:Survey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isAnonymous rdf:type rdf:Property ;
    rdfs:label 'Is Anonymous' ;
    rdfs:comment 'Indicates whether the survey response was collected anonymously, without recording the respondent\'s identity. When True, respondent_contact_id must be null. Affects how feedback can be used in account management discussions.' ;
    rdfs:domain ind:Survey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:keyRisksSummary rdf:type rdf:Property ;
    rdfs:label 'Key Risks Summary' ;
    rdfs:comment 'Structured summary of the primary risks identified to the client relationship from this survey cycle, including commercial, delivery, communication, and reputational risk themes. Informs account management action planning.' ;
    rdfs:domain ind:Survey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:languageCode rdf:type rdf:Property ;
    rdfs:label 'Language Code' ;
    rdfs:comment 'ISO 639-1 language code indicating the language in which the survey was administered and completed (e.g., en, fr, ar, zh-CN). Supports multilingual client engagement in global construction programmes.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:npsCategory rdf:type rdf:Property ;
    rdfs:label 'Nps Category' ;
    rdfs:comment 'Derived classification of the respondent based on their NPS score: Promoter (score 9-10), Passive (score 7-8), or Detractor (score 0-6). Used for segmentation in account management and relationship risk reporting.' ;
    rdfs:domain ind:Survey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:npsScore rdf:type rdf:Property ;
    rdfs:label 'Nps Score' ;
    rdfs:comment 'Net Promoter Score (NPS) rating provided by the client respondent on a scale of 0 to 10, indicating likelihood to recommend the construction company to others. Classifies respondents as Promoters (9-10), Passives (7-8), or Detractors (0-6). Key relationship health KPI.' ;
    rdfs:domain ind:Survey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:overallSatisfactionScore rdf:type rdf:Property ;
    rdfs:label 'Overall Satisfaction Score' ;
    rdfs:comment 'Numeric rating representing the client\'s overall satisfaction with the construction company\'s performance, typically on a scale of 1.00 to 10.00 or 1.00 to 5.00. Primary quantitative outcome of the survey. Feeds executive account reviews and continuous improvement programs.' ;
    rdfs:domain ind:Survey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:projectMilestone rdf:type rdf:Property ;
    rdfs:label 'Project Milestone' ;
    rdfs:comment 'The specific project lifecycle milestone at which this survey was triggered. Aligns with key construction delivery phases including Notice to Proceed (NTP), practical completion, and Defects Liability Period (DLP) end. [ENUM-REF-CANDIDATE: contract_award|design_completion|construction_start|mid_construction|practical_completion|dlp_end|post_handover — promote to reference product]' ;
    rdfs:domain ind:Survey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityScore rdf:type rdf:Property ;
    rdfs:label 'Quality Score' ;
    rdfs:comment 'Client-rated score for the construction company\'s quality of workmanship, materials, and deliverables on the associated project. Aligns with QA/QC (Quality Assurance/Quality Control) performance measurement.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recommendedEngagementActions rdf:type rdf:Property ;
    rdfs:label 'Recommended Engagement Actions' ;
    rdfs:comment 'Documented recommended actions for the account management team to address identified risks, improve satisfaction, and strengthen the client relationship based on survey findings.' ;
    rdfs:domain ind:Survey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipHealthScore rdf:type rdf:Property ;
    rdfs:label 'Relationship Health Score' ;
    rdfs:comment 'Composite numeric score assessing the overall health of the client relationship, incorporating satisfaction, engagement frequency, issue resolution, and strategic alignment dimensions. Used for proactive account management and early identification of at-risk relationships.' ;
    rdfs:domain ind:Survey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:relationshipRiskLevel rdf:type rdf:Property ;
    rdfs:label 'Relationship Risk Level' ;
    rdfs:comment 'Assessed risk level for the client relationship based on survey outcomes and qualitative feedback. Drives escalation protocols and proactive account management interventions. Critical risk triggers executive review.' ;
    rdfs:domain ind:Survey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:repeatClientFlag rdf:type rdf:Property ;
    rdfs:label 'Repeat Client Flag' ;
    rdfs:comment 'Indicates whether the client is a repeat client with prior completed projects with the construction company at the time of survey. Used to contextualise satisfaction trends and loyalty analysis.' ;
    rdfs:domain ind:Survey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:respondentRole rdf:type rdf:Property ;
    rdfs:label 'Respondent Role' ;
    rdfs:comment 'The organisational role or title of the client stakeholder who responded to the survey. Used to segment feedback by decision-maker level and ensure appropriate seniority of respondents. [ENUM-REF-CANDIDATE: project_director|project_manager|commercial_manager|technical_lead|executive_sponsor|procurement_manager — promote to reference product]' ;
    rdfs:domain ind:Survey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseDate rdf:type rdf:Property ;
    rdfs:label 'Response Date' ;
    rdfs:comment 'The date on which the client respondent submitted their completed survey response. Used to calculate response turnaround time and track engagement timeliness.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:safetyScore rdf:type rdf:Property ;
    rdfs:label 'Safety Score' ;
    rdfs:comment 'Client-rated score for the construction company\'s HSE (Health, Safety and Environment) performance on site, including compliance with OSHA standards, incident management, and safety culture visibility.' ;
    rdfs:domain ind:Survey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scheduleScore rdf:type rdf:Property ;
    rdfs:label 'Schedule Score' ;
    rdfs:comment 'Client-rated score for the construction company\'s adherence to project schedule and milestone delivery commitments. Reflects client perception of Schedule Performance Index (SPI) outcomes.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scoreScaleMax rdf:type rdf:Property ;
    rdfs:label 'Score Scale Max' ;
    rdfs:comment 'The maximum possible value on the scoring scale used for this survey (e.g., 5.00 or 10.00). Required to normalise and compare scores across surveys using different rating scales.' ;
    rdfs:domain ind:Survey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:strategicImportanceRating rdf:type rdf:Property ;
    rdfs:label 'Strategic Importance Rating' ;
    rdfs:comment 'Internal classification of the client\'s strategic importance to the business at the time of survey, reflecting revenue contribution, repeat business potential, and market positioning. Informs prioritisation of follow-up actions and executive engagement.' ;
    rdfs:domain ind:Survey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surveyStatus rdf:type rdf:Property ;
    rdfs:label 'Survey Status' ;
    rdfs:comment 'Current lifecycle state of the survey record. Tracks progression from draft preparation through distribution, response collection, and final completion or cancellation.' ;
    rdfs:domain ind:Survey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surveyType rdf:type rdf:Property ;
    rdfs:label 'Survey Type' ;
    rdfs:comment 'Classification of the survey by its trigger or cadence. Milestone surveys are administered at defined project lifecycle events (post-award, mid-project, post-handover); periodic surveys follow a fixed calendar schedule; ad-hoc surveys are triggered by specific relationship events. [ENUM-REF-CANDIDATE: milestone|periodic|ad_hoc|post_award|mid_project|post_handover — promote to reference product]' ;
    rdfs:domain ind:Survey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verbatimFeedback rdf:type rdf:Property ;
    rdfs:label 'Verbatim Feedback' ;
    rdfs:comment 'Free-text verbatim comments and qualitative feedback provided by the client respondent. Captures unstructured insights not covered by scored categories. Used for sentiment analysis and continuous improvement programs.' ;
    rdfs:domain ind:Survey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:version rdf:type rdf:Property ;
    rdfs:label 'Version' ;
    rdfs:comment 'Version identifier of the survey template or questionnaire used for this administration. Ensures comparability of scores across survey cycles and supports longitudinal trend analysis when templates are updated.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportsToContactId rdf:type rdf:Property ;
    rdfs:label 'Reports To Contact Id' ;
    rdfs:comment 'Self-referencing identifier pointing to the contact\'s direct manager or superior within the client organisation. Enables hierarchical stakeholder mapping and organisational chart modelling for large client accounts.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Contact .

ind:accountManager rdf:type rdf:Property ;
    rdfs:label 'Account Manager' ;
    rdfs:comment 'Full name of the internal account manager or business development representative responsible for managing the relationship with this contact. Used for ownership assignment and pipeline accountability in Salesforce CRM.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:birthdate rdf:type rdf:Property ;
    rdfs:label 'Birthdate' ;
    rdfs:comment 'Date of birth of the contact. Stored for relationship personalisation purposes (e.g., milestone acknowledgements) and identity verification in regulated markets. Handled under strict GDPR data minimisation principles.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contactStatus rdf:type rdf:Property ;
    rdfs:label 'Contact Status' ;
    rdfs:comment 'Current lifecycle status of the contact record within the CRM system. \'active\' indicates an engaged stakeholder; \'inactive\' indicates no recent engagement; \'archived\' indicates the contact has left the organisation; \'do_not_contact\' indicates a communication opt-out or legal restriction.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactType rdf:type rdf:Property ;
    rdfs:label 'Contact Type' ;
    rdfs:comment 'Classification of the contact\'s functional role in the client relationship (e.g., owner representative, technical representative, procurement officer, legal counsel, executive sponsor, financial approver). Drives stakeholder engagement strategy and communication routing. [ENUM-REF-CANDIDATE: owner|technical|procurement|legal|executive|financial|hse|commercial — promote to reference product]' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crmContactCode rdf:type rdf:Property ;
    rdfs:label 'Crm Contact Code' ;
    rdfs:comment 'External identifier for this contact as recorded in Salesforce CRM Contact object. Used for cross-system reconciliation and data lineage tracing back to the operational system of record.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataConsentDate rdf:type rdf:Property ;
    rdfs:label 'Data Consent Date' ;
    rdfs:comment 'Date on which the contact\'s data processing consent was last recorded or updated. Required for GDPR compliance audit trails to demonstrate lawful basis for processing personal data.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dataConsentStatus rdf:type rdf:Property ;
    rdfs:label 'Data Consent Status' ;
    rdfs:comment 'Current status of the contact\'s consent for personal data processing under applicable privacy regulations (GDPR, CCPA). Tracks whether consent has been granted, withdrawn, is pending confirmation, or is not required (e.g., legitimate interest basis).' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decisionAuthorityLevel rdf:type rdf:Property ;
    rdfs:label 'Decision Authority Level' ;
    rdfs:comment 'Indicates the contact\'s level of decision-making authority within the client organisation for construction project approvals, contract awards, and change order authorisations. Supports bid strategy and stakeholder influence mapping.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:department rdf:type rdf:Property ;
    rdfs:label 'Department' ;
    rdfs:comment 'Organisational department or business unit within the client organisation to which the contact belongs (e.g., Engineering, Procurement, Legal, Finance). Supports targeted stakeholder engagement and communication routing.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:email rdf:type rdf:Property ;
    rdfs:label 'Email' ;
    rdfs:comment 'Primary business email address of the contact used for official project correspondence, RFI responses, bid submissions, and CRM communication tracking. Sourced from Salesforce CRM.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emailOptOut rdf:type rdf:Property ;
    rdfs:label 'Email Opt Out' ;
    rdfs:comment 'Indicates whether the contact has opted out of email marketing communications specifically. Distinct from do_not_contact which covers all channels. Enforces GDPR consent management and CAN-SPAM compliance.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:firstName rdf:type rdf:Property ;
    rdfs:label 'First Name' ;
    rdfs:comment 'Given name of the individual stakeholder contact as recorded in Salesforce CRM. Used for personalised correspondence and formal communication in client relationship management.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fullName rdf:type rdf:Property ;
    rdfs:label 'Full Name' ;
    rdfs:comment 'Complete display name of the contact (e.g., salutation + first + last name) as stored in Salesforce CRM. Used in formal correspondence, bid submissions, and contract administration documents.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:influenceScore rdf:type rdf:Property ;
    rdfs:label 'Influence Score' ;
    rdfs:comment 'Numeric score (typically 1–10) representing the contact\'s level of influence over project award decisions, contract negotiations, and change order approvals. Used in bid strategy and stakeholder mapping for major infrastructure pursuits.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isDecisionMaker rdf:type rdf:Property ;
    rdfs:label 'Is Decision Maker' ;
    rdfs:comment 'Indicates whether this contact has final decision-making authority for contract awards, change orders (CO), or project approvals. Critical for bid management and opportunity pipeline qualification in Salesforce CRM.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isExecutiveSponsor rdf:type rdf:Property ;
    rdfs:label 'Is Executive Sponsor' ;
    rdfs:comment 'Indicates whether this contact holds the role of executive sponsor for the client relationship. Executive sponsors are senior client representatives who champion the construction partnership at the strategic level.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPrimaryContact rdf:type rdf:Property ;
    rdfs:label 'Is Primary Contact' ;
    rdfs:comment 'Indicates whether this contact is the designated primary point of contact for the client account. Only one contact per account should be flagged as primary. Used to route official correspondence and contract notifications.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jobTitle rdf:type rdf:Property ;
    rdfs:label 'Job Title' ;
    rdfs:comment 'Official job title or position of the contact within their organisation (e.g., Project Director, Procurement Manager, Chief Engineer). Used to identify the contact\'s functional role in client engagement and bid management.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastActivityDate rdf:type rdf:Property ;
    rdfs:label 'Last Activity Date' ;
    rdfs:comment 'Date of the most recent logged activity (call, email, meeting, site visit) with this contact in Salesforce CRM. Used to measure engagement recency and identify at-risk relationships in client retention analytics.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastMeetingDate rdf:type rdf:Property ;
    rdfs:label 'Last Meeting Date' ;
    rdfs:comment 'Date of the most recent in-person or virtual meeting held with this contact. Used by account managers to track face-to-face engagement frequency and support relationship health assessments.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastName rdf:type rdf:Property ;
    rdfs:label 'Last Name' ;
    rdfs:comment 'Family name or surname of the individual stakeholder contact. Combined with first_name to form the full display name used in client-facing communications and CRM reporting.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:linkedinUrl rdf:type rdf:Property ;
    rdfs:label 'Linkedin Url' ;
    rdfs:comment 'LinkedIn professional profile URL for the contact. Used by business development and account management teams for relationship intelligence, stakeholder research, and pre-bid engagement in Salesforce CRM.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mailingCity rdf:type rdf:Property ;
    rdfs:label 'Mailing City' ;
    rdfs:comment 'City component of the contact\'s mailing address. Used in conjunction with mailing_street, mailing_state, and mailing_country for complete address resolution in client correspondence.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mailingCountry rdf:type rdf:Property ;
    rdfs:label 'Mailing Country' ;
    rdfs:comment 'ISO 3166-1 alpha-3 three-letter country code for the contact\'s mailing address (e.g., USA, GBR, ARE). Used for international project correspondence and GDPR/privacy jurisdiction determination.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mailingPostalCode rdf:type rdf:Property ;
    rdfs:label 'Mailing Postal Code' ;
    rdfs:comment 'Postal or ZIP code component of the contact\'s mailing address. Used for geographic segmentation, regional reporting, and formal document delivery in construction project administration.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mailingState rdf:type rdf:Property ;
    rdfs:label 'Mailing State' ;
    rdfs:comment 'State or province component of the contact\'s mailing address. Supports regional segmentation and compliance with jurisdiction-specific regulatory reporting requirements.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mailingStreet rdf:type rdf:Property ;
    rdfs:label 'Mailing Street' ;
    rdfs:comment 'Street address component of the contact\'s mailing address. Used for formal correspondence, contract document delivery, and regulatory notifications in construction project administration.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mobilePhone rdf:type rdf:Property ;
    rdfs:label 'Mobile Phone' ;
    rdfs:comment 'Mobile or cell phone number for the contact. Used for urgent site communications, HSE notifications, and out-of-hours contact during critical project milestones.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phone rdf:type rdf:Property ;
    rdfs:label 'Phone' ;
    rdfs:comment 'Primary business phone number for the contact, including country and area code. Used for direct communication during project execution, bid clarifications, and contract administration.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredCommunicationChannel rdf:type rdf:Property ;
    rdfs:label 'Preferred Communication Channel' ;
    rdfs:comment 'The contact\'s preferred method of communication for project correspondence, meeting invitations, and bid-related notifications. Sourced from Salesforce CRM and used to personalise outreach in opportunity pipeline management.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredLanguage rdf:type rdf:Property ;
    rdfs:label 'Preferred Language' ;
    rdfs:comment 'ISO 639-1 language code representing the contact\'s preferred language for written and verbal communication (e.g., \'en\', \'fr\', \'ar\', \'zh\'). Supports multilingual project environments common in global EPC and infrastructure projects.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipHealth rdf:type rdf:Property ;
    rdfs:label 'Relationship Health' ;
    rdfs:comment 'Qualitative assessment of the current health of the business relationship with this contact, as evaluated by the account manager or business development team. Used in CRM pipeline forecasting and client retention strategies.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salutation rdf:type rdf:Property ;
    rdfs:label 'Salutation' ;
    rdfs:comment 'Formal honorific or title prefix for the contact (e.g., Mr., Ms., Dr.) used in official correspondence, contract documents, and client communications.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:secondaryEmail rdf:type rdf:Property ;
    rdfs:label 'Secondary Email' ;
    rdfs:comment 'Alternate or secondary email address for the contact, used as a fallback communication channel or for personal correspondence when the primary email is unavailable.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:source rdf:type rdf:Property ;
    rdfs:label 'Source' ;
    rdfs:comment 'Origin channel through which this contact was acquired or first identified (e.g., CRM import, referral, industry conference, Request for Proposal (RFP) response, website enquiry, partner introduction). Supports lead source analytics in Salesforce CRM.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clientFrameworkAgreementId rdf:type rdf:Property ;
    rdfs:label 'Client Framework Agreement Id' ;
    rdfs:comment 'Unique surrogate identifier for the framework agreement record in the lakehouse silver layer. Primary key.' ;
    rdfs:domain ind:ClientFrameworkAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contractManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Contract Manager Employee Id' ;
    rdfs:comment 'Foreign key linking to hr.employee. Business justification: Framework agreements require a designated contract manager (HR employee) for oversight and performance tracking.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:parentAgreementClientFrameworkAgreementId rdf:type rdf:Property ;
    rdfs:label 'Parent Agreement Client Framework Agreement Id' ;
    rdfs:comment 'Self-referencing identifier linking a call-off contract or lot-level agreement to its parent framework agreement. Supports hierarchical agreement structures where individual call-offs are children of a master framework.' ;
    rdfs:domain ind:ClientFrameworkAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ClientFrameworkAgreement .

ind:agreementNumber rdf:type rdf:Property ;
    rdfs:label 'Agreement Number' ;
    rdfs:comment 'Externally-known unique reference number assigned to the framework agreement, used in correspondence, call-off orders, and contract administration. Typically issued by the client or procurement authority (e.g., FA-2024-HWY-001).' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agreementType rdf:type rdf:Property ;
    rdfs:label 'Agreement Type' ;
    rdfs:comment 'Classification of the long-term agreement structure. \'framework\' = competitive framework with multiple call-offs; \'master_service_agreement\' (MSA) = pre-agreed terms for repeat services; \'term_contract\' = fixed-duration works contract; \'blanket_order\' = open purchase order for repeat supply; \'call_off_contract\' = individual release under a parent framework.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ceilingValue rdf:type rdf:Property ;
    rdfs:label 'Ceiling Value' ;
    rdfs:comment 'Maximum total monetary value of all call-off orders that may be placed under this framework agreement over its full term. Acts as the Guaranteed Maximum Price (GMP) envelope for the framework. Expressed in the agreement currency.' ;
    rdfs:domain ind:ClientFrameworkAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:clientFrameworkAgreementStatus rdf:type rdf:Property ;
    rdfs:label 'Client Framework Agreement Status' ;
    rdfs:comment 'Current lifecycle state of the framework agreement. \'draft\' = being negotiated; \'active\' = in force and accepting call-offs; \'suspended\' = temporarily halted; \'expired\' = past expiry date with no renewal; \'terminated\' = ended early; \'under_renewal\' = renewal process initiated.' ;
    rdfs:domain ind:ClientFrameworkAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:committedValue rdf:type rdf:Property ;
    rdfs:label 'Committed Value' ;
    rdfs:comment 'Total value of all call-off orders formally issued against this framework agreement to date. Used to track utilisation against the ceiling value and support financial forecasting.' ;
    rdfs:domain ind:ClientFrameworkAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:disputeResolutionMechanism rdf:type rdf:Property ;
    rdfs:label 'Dispute Resolution Mechanism' ;
    rdfs:comment 'Contractual mechanism for resolving disputes arising under the framework. \'dab\' = Dispute Adjudication Board (FIDIC); \'arbitration\' = binding arbitration; \'adjudication\' = statutory adjudication; \'litigation\' = court proceedings; \'mediation\' = non-binding mediation.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:durationMonths rdf:type rdf:Property ;
    rdfs:label 'Duration Months' ;
    rdfs:comment 'Total planned duration of the framework agreement in calendar months from effective date to expiry date. Used for scheduling, resource planning, and renewal forecasting.' ;
    rdfs:domain ind:ClientFrameworkAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:effectiveDate rdf:type rdf:Property ;
    rdfs:label 'Effective Date' ;
    rdfs:comment 'Date on which the framework agreement becomes legally binding and call-offs may commence. Equivalent to the Notice to Proceed (NTP) date for the framework.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:extensionDurationMonths rdf:type rdf:Property ;
    rdfs:label 'Extension Duration Months' ;
    rdfs:comment 'Duration in calendar months of each individual extension option. Combined with extension_options to determine the maximum possible agreement term.' ;
    rdfs:domain ind:ClientFrameworkAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:extensionOptions rdf:type rdf:Property ;
    rdfs:label 'Extension Options' ;
    rdfs:comment 'Number of contractual extension options available to the client to extend the framework agreement beyond the original expiry date (e.g., 2 options of 12 months each).' ;
    rdfs:domain ind:ClientFrameworkAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:frameworkLot rdf:type rdf:Property ;
    rdfs:label 'Framework Lot' ;
    rdfs:comment 'Lot or package designation within a multi-lot framework agreement (e.g., \'Lot 1 – Civils\', \'Lot 2 – MEP\', \'Lot 3 – Highways\'). Applicable where the client has structured the framework into distinct work categories.' ;
    rdfs:domain ind:ClientFrameworkAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:governingLaw rdf:type rdf:Property ;
    rdfs:label 'Governing Law' ;
    rdfs:comment 'Legal jurisdiction and governing law under which the framework agreement is interpreted and enforced (e.g., \'English Law\', \'New York State Law\', \'UAE Federal Law\'). Critical for dispute resolution and contract administration.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hseRequirements rdf:type rdf:Property ;
    rdfs:label 'Hse Requirements' ;
    rdfs:comment 'Summary of Health, Safety and Environment (HSE) obligations and standards mandated under the framework agreement, such as OSHA compliance, ISO 45001 certification, SWMS submission, and minimum PPE standards.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incentiveMechanism rdf:type rdf:Property ;
    rdfs:label 'Incentive Mechanism' ;
    rdfs:comment 'Description of any pain/gain share, bonus, or incentive fee mechanism embedded in the framework agreement to reward performance above KPI thresholds or penalise underperformance.' ;
    rdfs:domain ind:ClientFrameworkAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceRequired rdf:type rdf:Property ;
    rdfs:label 'Insurance Required' ;
    rdfs:comment 'Indicates whether specific insurance requirements (e.g., professional indemnity, public liability, contractor\'s all-risk) are mandated under the framework agreement terms.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:kpiDescription rdf:type rdf:Property ;
    rdfs:label 'Kpi Description' ;
    rdfs:comment 'Narrative description of the performance KPIs defined in the framework agreement against which the contractor\'s performance will be measured across call-off orders (e.g., on-time delivery rate, defect rate, TRIR, CPI thresholds).' ;
    rdfs:domain ind:ClientFrameworkAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxCalloffValue rdf:type rdf:Property ;
    rdfs:label 'Max Calloff Value' ;
    rdfs:comment 'Maximum monetary value of a single call-off order permitted under this framework agreement without triggering a mini-competition or additional approval. Supports procurement governance.' ;
    rdfs:domain ind:ClientFrameworkAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minCalloffValue rdf:type rdf:Property ;
    rdfs:label 'Min Calloff Value' ;
    rdfs:comment 'Minimum monetary value of an individual call-off order that may be placed under this framework agreement. Ensures commercial viability of individual work packages.' ;
    rdfs:domain ind:ClientFrameworkAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:procurementRoute rdf:type rdf:Property ;
    rdfs:label 'Procurement Route' ;
    rdfs:comment 'Mechanism by which individual call-off orders are awarded under the framework. \'direct_award\' = awarded without further competition; \'mini_competition\' = secondary competition among framework members; \'competitive_tender\' = full re-tender; \'negotiated\' = negotiated with incumbent.' ;
    rdfs:domain ind:ClientFrameworkAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityStandard rdf:type rdf:Property ;
    rdfs:label 'Quality Standard' ;
    rdfs:comment 'Quality management standard or certification required of the contractor under the framework agreement (e.g., ISO 9001:2015, LEED Gold, ITP compliance). Supports QA/QC governance.' ;
    rdfs:domain ind:Client ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalNoticeDays rdf:type rdf:Property ;
    rdfs:label 'Renewal Notice Days' ;
    rdfs:comment 'Number of calendar days prior to expiry by which either party must serve notice of intent to renew or extend the framework agreement. Triggers CRM pipeline renewal workflow.' ;
    rdfs:domain ind:ClientFrameworkAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:scopeDescription rdf:type rdf:Property ;
    rdfs:label 'Scope Description' ;
    rdfs:comment 'Narrative description of the categories of works, services, or supply covered by the framework agreement (e.g., \'Highway maintenance, resurfacing, and drainage works across the Northern Region\').' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signedDate rdf:type rdf:Property ;
    rdfs:label 'Signed Date' ;
    rdfs:comment 'Date on which the framework agreement was formally executed (signed by all parties). May precede the effective date if there is a mobilisation period.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:terminationDate rdf:type rdf:Property ;
    rdfs:label 'Termination Date' ;
    rdfs:comment 'Actual date on which the framework agreement was terminated early, if applicable. Null if the agreement expired naturally or is still active.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:terminationReason rdf:type rdf:Property ;
    rdfs:label 'Termination Reason' ;
    rdfs:comment 'Reason for early termination of the framework agreement. \'client_default\' = client failed to meet obligations; \'contractor_default\' = contractor breach; \'mutual_agreement\' = both parties agreed; \'force_majeure\' = unforeseeable event; \'regulatory\' = regulatory or legal requirement; \'convenience\' = termination for convenience by client.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jvStructureId rdf:type rdf:Property ;
    rdfs:label 'Jv Structure Id' ;
    rdfs:comment 'Unique surrogate identifier for the Joint Venture (JV) structure record in the Databricks Silver Layer. Primary key for this entity.' ;
    rdfs:domain ind:JvStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:leadSponsorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Lead Sponsor Employee Id' ;
    rdfs:comment 'Foreign key linking to hr.employee. Business justification: Joint-venture lead sponsor is an HR employee responsible for overseeing JV execution, needed for governance and reporting.' ;
    rdfs:domain ind:JvStructure ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:primaryJvAccountId rdf:type rdf:Property ;
    rdfs:label 'Primary Jv Account Id' ;
    rdfs:comment 'Reference to the client or organisation entity designated as the lead sponsor or managing partner of the JV. The lead sponsor typically holds the primary contractual relationship with the project owner and manages JV operations.' ;
    rdfs:domain ind:JvStructure ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Account .

ind:aconexDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Aconex Document Reference' ;
    rdfs:comment 'Reference identifier for the JV agreement document as registered in the Aconex document management system. Enables direct traceability to the executed legal instrument and associated transmittals.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countryOfOperation rdf:type rdf:Property ;
    rdfs:label 'Country Of Operation' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the primary country where the JV\'s construction project is being executed. Used for regulatory compliance, HSE reporting, and geographic portfolio analysis.' ;
    rdfs:domain ind:JvStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:formationDate rdf:type rdf:Property ;
    rdfs:label 'Formation Date' ;
    rdfs:comment 'Calendar date on which the JV was formally constituted and the JV agreement became effective. Marks the start of the JV\'s legal existence and is used for financial reporting under IFRS 11.' ;
    rdfs:domain ind:JvStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:governingLawJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Governing Law Jurisdiction' ;
    rdfs:comment 'Specific legal jurisdiction or state/province within the governing law country that applies to the JV agreement (e.g., \'New South Wales\', \'Dubai International Financial Centre\'). Supplements governing_law_country for sub-national jurisdictions.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isActive rdf:type rdf:Property ;
    rdfs:label 'Is Active' ;
    rdfs:comment 'Boolean flag indicating whether the JV structure record is currently active and operational. False indicates the JV has been dissolved, superseded, or administratively deactivated. Used for data filtering in reporting and CRM pipeline views.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isLeadSponsorInternal rdf:type rdf:Property ;
    rdfs:label 'Is Lead Sponsor Internal' ;
    rdfs:comment 'Boolean flag indicating whether the lead sponsor of the JV is an internal entity (i.e., Construction itself or one of its subsidiaries) as opposed to an external third-party organisation. Drives internal vs. external reporting segmentation.' ;
    rdfs:domain ind:JvStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jvManagerEmail rdf:type rdf:Property ;
    rdfs:label 'Jv Manager Email' ;
    rdfs:comment 'Business email address of the designated JV Manager. Used for official correspondence, notifications, and stakeholder communication management.' ;
    rdfs:domain ind:JvStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jvManagerName rdf:type rdf:Property ;
    rdfs:label 'Jv Manager Name' ;
    rdfs:comment 'Full name of the designated JV Manager or Managing Director responsible for day-to-day operations and governance of the JV. This is a role-level contact, not a personal identifier.' ;
    rdfs:domain ind:JvStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jvManagerPhone rdf:type rdf:Property ;
    rdfs:label 'Jv Manager Phone' ;
    rdfs:comment 'Business phone number of the designated JV Manager for direct contact. Used for urgent project communications and stakeholder engagement.' ;
    rdfs:domain ind:JvStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jvName rdf:type rdf:Property ;
    rdfs:label 'Jv Name' ;
    rdfs:comment 'Official registered or trading name of the Joint Venture entity as stated in the JV agreement and used in all project correspondence, bid submissions, and regulatory filings.' ;
    rdfs:domain ind:JvStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jvReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Jv Reference Number' ;
    rdfs:comment 'Externally-known unique business identifier assigned to the JV arrangement, used in contracts, correspondence, and regulatory filings. Sourced from Salesforce CRM or Aconex document management.' ;
    rdfs:domain ind:JvStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jvShortName rdf:type rdf:Property ;
    rdfs:label 'Jv Short Name' ;
    rdfs:comment 'Abbreviated or commonly used name for the JV, used in internal reporting, dashboards, and project management systems such as Oracle Primavera P6 and Procore.' ;
    rdfs:domain ind:JvStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jvStatus rdf:type rdf:Property ;
    rdfs:label 'Jv Status' ;
    rdfs:comment 'Current lifecycle status of the JV arrangement. \'formation\' indicates the JV is being constituted; \'pending\' indicates awaiting regulatory or client approval; \'active\' indicates fully operational; \'suspended\' indicates temporarily halted; \'dissolved\' indicates the JV has been wound up.' ;
    rdfs:domain ind:JvStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jvType rdf:type rdf:Property ;
    rdfs:label 'Jv Type' ;
    rdfs:comment 'Classification of the JV arrangement by delivery model or legal structure. PPP (Public-Private Partnership), BOT (Build-Operate-Transfer), Consortium, Incorporated JV, Unincorporated JV, or EPC (Engineering Procurement and Construction) joint venture. [ENUM-REF-CANDIDATE: PPP|BOT|Consortium|Incorporated|Unincorporated|EPC — promote to reference product if additional types are required]' ;
    rdfs:domain ind:JvStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leedCertificationTarget rdf:type rdf:Property ;
    rdfs:label 'Leed Certification Target' ;
    rdfs:comment 'Target LEED (Leadership in Energy and Environmental Design) certification level for the project associated with this JV. Used for sustainability reporting and client commitment tracking.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:liabilityStructure rdf:type rdf:Property ;
    rdfs:label 'Liability Structure' ;
    rdfs:comment 'Legal liability arrangement between JV partners as defined in the JV agreement. \'joint_and_several\' means each partner is fully liable; \'several_only\' means each partner is liable only for their share. Critical for risk management and contract administration.' ;
    rdfs:domain ind:JvStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:managementStructureType rdf:type rdf:Property ;
    rdfs:label 'Management Structure Type' ;
    rdfs:comment 'Type of governance and management structure adopted by the JV. \'board\' indicates a formal board of directors; \'management_committee\' indicates a joint committee; \'single_manager\' indicates one partner manages on behalf of all; \'co_management\' indicates shared management responsibilities.' ;
    rdfs:domain ind:JvStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:participantCount rdf:type rdf:Property ;
    rdfs:label 'Participant Count' ;
    rdfs:comment 'Total number of participating entities (partners or members) in the JV arrangement. Used for governance reporting and to validate completeness of the JV participant roster.' ;
    rdfs:domain ind:JvStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:profitSharingBasis rdf:type rdf:Property ;
    rdfs:label 'Profit Sharing Basis' ;
    rdfs:comment 'Basis on which profits and losses are distributed among JV participants. \'equity_proportional\' aligns P&L distribution with equity share percentages; \'negotiated\' indicates a bespoke arrangement defined in the JV agreement.' ;
    rdfs:domain ind:JvStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectSector rdf:type rdf:Property ;
    rdfs:label 'Project Sector' ;
    rdfs:comment 'Primary industry sector of the construction project(s) associated with this JV. Used for client segmentation, pipeline forecasting in Salesforce CRM, and portfolio analytics. [ENUM-REF-CANDIDATE: infrastructure|energy|commercial|residential|industrial|transport|water|healthcare|education — promote to reference product]' ;
    rdfs:domain ind:Client ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationCountry rdf:type rdf:Property ;
    rdfs:label 'Registration Country' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the country in which the JV entity is legally registered. May differ from the governing law country for cross-border projects.' ;
    rdfs:domain ind:JvStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalCommittedCapital rdf:type rdf:Property ;
    rdfs:label 'Total Committed Capital' ;
    rdfs:comment 'Total capital committed by all JV participants as stated in the JV agreement, expressed in the JV\'s primary currency. Used for financial reporting, EBITDA analysis, and project cost control.' ;
    rdfs:domain ind:JvStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalEquityPct rdf:type rdf:Property ;
    rdfs:label 'Total Equity Pct' ;
    rdfs:comment 'Sum of all participating entities\' equity share percentages in the JV. Must equal 100.00% for a fully constituted JV. Used as a validation and audit control field.' ;
    rdfs:domain ind:JvStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rfpIssuanceId rdf:type rdf:Property ;
    rdfs:label 'Rfp Issuance Id' ;
    rdfs:comment 'Unique surrogate identifier for each RFP/RFQ/ITT issuance record in the system. Primary key for this entity.' ;
    rdfs:domain ind:RfpIssuance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rfpOwnerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Rfp Owner Employee Id' ;
    rdfs:comment 'Foreign key linking to hr.employee. Business justification: RFP issuance is owned by a procurement employee, needed for accountability and audit trails.' ;
    rdfs:domain ind:RfpIssuance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:addendumCount rdf:type rdf:Property ;
    rdfs:label 'Addendum Count' ;
    rdfs:comment 'The total number of addenda (amendments) issued by the client against this RFP since original issuance. Each addendum modifies the original RFP terms, scope, or schedule. Used to track document version history.' ;
    rdfs:domain ind:RfpIssuance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:anticipatedAwardDate rdf:type rdf:Property ;
    rdfs:label 'Anticipated Award Date' ;
    rdfs:comment 'The client\'s indicative target date for issuing the Notice to Proceed (NTP) or contract award, as stated in the RFP. Used for resource planning, bid team scheduling, and pipeline forecasting in Salesforce CRM.' ;
    rdfs:domain ind:RfpIssuance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:anticipatedCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Anticipated Completion Date' ;
    rdfs:comment 'The client\'s required or indicative project completion date as stated in the RFP. Defines the overall programme duration and is a key input to CPM (Critical Path Method) scheduling and resource planning.' ;
    rdfs:domain ind:RfpIssuance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:anticipatedStartDate rdf:type rdf:Property ;
    rdfs:label 'Anticipated Start Date' ;
    rdfs:comment 'The client\'s indicative target date for project commencement (Notice to Proceed / NTP) as stated in the RFP. Used for resource mobilisation planning and schedule baseline development in Oracle Primavera P6.' ;
    rdfs:domain ind:RfpIssuance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:bidBondPercentage rdf:type rdf:Property ;
    rdfs:label 'Bid Bond Percentage' ;
    rdfs:comment 'The bid bond (tender guarantee) value expressed as a percentage of the estimated contract value, as required by the client in the RFP. Typically ranges from 1% to 5% of contract value. Null if bid bond is not required.' ;
    rdfs:domain ind:RfpIssuance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bidValidityDays rdf:type rdf:Property ;
    rdfs:label 'Bid Validity Days' ;
    rdfs:comment 'The number of calendar days from the submission deadline during which the bidder\'s proposal must remain valid and binding, as specified in the RFP. Typically 60 to 180 days. Impacts financial exposure and resource commitment.' ;
    rdfs:domain ind:RfpIssuance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bimLevel rdf:type rdf:Property ;
    rdfs:label 'Bim Level' ;
    rdfs:comment 'The BIM maturity level required by the client in the RFP: level_1 (CAD-based), level_2 (collaborative BIM with federated models), or level_3 (fully integrated open BIM). Null if BIM is not required.' ;
    rdfs:domain ind:RfpIssuance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commercialScoreWeight rdf:type rdf:Property ;
    rdfs:label 'Commercial Score Weight' ;
    rdfs:comment 'The percentage weighting assigned to the commercial/price component of the bid evaluation, as specified in the RFP (e.g., 40.00 for 40%). Combined with technical_score_weight to total 100%. Null for quality-only evaluations.' ;
    rdfs:domain ind:RfpIssuance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:defectsLiabilityPeriodDays rdf:type rdf:Property ;
    rdfs:label 'Defects Liability Period Days' ;
    rdfs:comment 'The duration of the Defects Liability Period (DLP) in calendar days as specified in the RFP, commencing from the date of practical completion. Typically 365 or 730 days. Impacts warranty provisioning and post-completion resource planning.' ;
    rdfs:domain ind:RfpIssuance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:evaluationCriteria rdf:type rdf:Property ;
    rdfs:label 'Evaluation Criteria' ;
    rdfs:comment 'The overall evaluation methodology specified in the RFP for assessing and ranking bids: price_only (lowest price wins), price_quality (weighted price and technical), quality_only (technical merit), best_value (whole-life cost), or pass_fail (compliance-based). Drives bid strategy.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Issued Timestamp' ;
    rdfs:comment 'The system timestamp when this RFP issuance record was first created in the data platform. Represents the audit creation time, distinct from the business issue_date. Used for data lineage and audit trail.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:latestAddendumDate rdf:type rdf:Property ;
    rdfs:label 'Latest Addendum Date' ;
    rdfs:comment 'The date of the most recent addendum issued by the client against this RFP. Null if no addenda have been issued. Used to ensure bidders are working from the latest version of the solicitation document.' ;
    rdfs:domain ind:RfpIssuance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:leedCertificationLevel rdf:type rdf:Property ;
    rdfs:label 'Leed Certification Level' ;
    rdfs:comment 'The minimum LEED certification level required by the client as stated in the RFP: certified, silver, gold, or platinum. Null if LEED certification is not required.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:liquidatedDamagesApplicable rdf:type rdf:Property ;
    rdfs:label 'Liquidated Damages Applicable' ;
    rdfs:comment 'Indicates whether the RFP specifies that Liquidated Damages (LD) will apply for delays or non-performance (True) or not (False). LD clauses are a key risk factor in bid pricing and schedule planning.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:localContentRequirementPct rdf:type rdf:Property ;
    rdfs:label 'Local Content Requirement Pct' ;
    rdfs:comment 'Minimum percentage of local workforce, materials, or subcontractors required by the client as specified in the RFP. Common in public-sector and government-funded projects. Impacts procurement and subcontractor strategy.' ;
    rdfs:domain ind:RfpIssuance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:performanceBondPercentage rdf:type rdf:Property ;
    rdfs:label 'Performance Bond Percentage' ;
    rdfs:comment 'The performance bond value expressed as a percentage of the contract value, as specified in the RFP. Typically ranges from 5% to 10% of contract value. Null if performance bond is not required.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:preBidMeetingDate rdf:type rdf:Property ;
    rdfs:label 'Pre Bid Meeting Date' ;
    rdfs:comment 'Scheduled date and time of the mandatory or optional pre-bid conference/site visit where the client clarifies scope and answers bidder questions. Attendance may be a prerequisite for bid eligibility.' ;
    rdfs:domain ind:RfpIssuance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:preBidMeetingMandatory rdf:type rdf:Property ;
    rdfs:label 'Pre Bid Meeting Mandatory' ;
    rdfs:comment 'Indicates whether attendance at the pre-bid meeting is mandatory for bid eligibility (True) or optional (False). Mandatory attendance is a common client requirement for complex infrastructure projects.' ;
    rdfs:domain ind:RfpIssuance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:projectDescription rdf:type rdf:Property ;
    rdfs:label 'Project Description' ;
    rdfs:comment 'Detailed narrative description of the project scope, works, and deliverables as outlined in the RFP. Includes key scope elements such as civil works, MEP systems, infrastructure type, and geographic extent.' ;
    rdfs:domain ind:RfpIssuance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rfpDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Rfp Document Reference' ;
    rdfs:comment 'The document control reference number or URL/path to the official RFP package in the document management system (Aconex or Autodesk BIM 360). Enables direct retrieval of the source solicitation document.' ;
    rdfs:domain ind:RfpIssuance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rfpNumber rdf:type rdf:Property ;
    rdfs:label 'Rfp Number' ;
    rdfs:comment 'Externally-known reference number assigned by the client to uniquely identify this solicitation document (RFP, RFQ, or ITT). Used in all correspondence and bid submissions. Sourced from Salesforce CRM Bid Management or Aconex Document Management.' ;
    rdfs:domain ind:RfpIssuance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rfpStatus rdf:type rdf:Property ;
    rdfs:label 'Rfp Status' ;
    rdfs:comment 'Current lifecycle status of the RFP issuance: draft (being prepared), issued (released to market), amended (addendum issued), closed (submission deadline passed), cancelled (withdrawn by client), or awarded (contract awarded). Drives workflow and reporting.' ;
    rdfs:domain ind:RfpIssuance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:solicitationType rdf:type rdf:Property ;
    rdfs:label 'Solicitation Type' ;
    rdfs:comment 'Classification of the solicitation document type: RFP (Request for Proposal), RFQ (Request for Quotation), ITT (Invitation to Tender), EOI (Expression of Interest), or RFI (Request for Information). Determines the formality and evaluation process applied.' ;
    rdfs:domain ind:RfpIssuance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technicalScoreWeight rdf:type rdf:Property ;
    rdfs:label 'Technical Score Weight' ;
    rdfs:comment 'The percentage weighting assigned to the technical/quality component of the bid evaluation, as specified in the RFP (e.g., 60.00 for 60%). Combined with commercial_score_weight to total 100%. Null for price-only evaluations.' ;
    rdfs:domain ind:RfpIssuance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:parentSegmentId rdf:type rdf:Property ;
    rdfs:label 'Parent Segment Id' ;
    rdfs:comment 'Self-referencing identifier pointing to the parent segment in a segment hierarchy (e.g., a regional sub-segment referencing a global segment). Enables hierarchical segment structures for multi-level BD reporting and account planning roll-ups.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Segment .

ind:accountCountTarget rdf:type rdf:Property ;
    rdfs:label 'Account Count Target' ;
    rdfs:comment 'Planned number of client accounts to be assigned to this segment as part of the annual BD account planning cycle. Used to measure segment coverage and BD capacity planning in Salesforce CRM.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bdOwner rdf:type rdf:Property ;
    rdfs:label 'Bd Owner' ;
    rdfs:comment 'Name or identifier of the Business Development (BD) lead or team responsible for managing accounts and opportunities within this segment. Used for accountability tracking in Salesforce CRM and BD performance reporting.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bimRequirement rdf:type rdf:Property ;
    rdfs:label 'Bim Requirement' ;
    rdfs:comment 'Level of Building Information Modeling (BIM) requirement typically mandated by clients in this segment. \'mandatory\' = BIM required on all projects; \'preferred\' = BIM expected but not contractually required; \'optional\' = BIM accepted if offered; \'not_required\' = no BIM expectation. Drives Autodesk BIM 360 capability positioning in bids.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:criteriaDescription rdf:type rdf:Property ;
    rdfs:label 'Criteria Description' ;
    rdfs:comment 'Narrative description of the specific qualification criteria used to assign accounts to this segment, including revenue thresholds, project type filters, geographic scope, and strategic fit indicators. Supports BD team alignment and CRM configuration.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:criteriaVersion rdf:type rdf:Property ;
    rdfs:label 'Criteria Version' ;
    rdfs:comment 'Version identifier of the segmentation criteria framework used to define and classify this segment (e.g., \'v1.0\', \'v2.3\'). Enables tracking of changes to segmentation methodology over time and supports historical win-rate analysis by criteria version.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crmSegmentCode rdf:type rdf:Property ;
    rdfs:label 'Crm Segment Code' ;
    rdfs:comment 'External identifier for this segment as recorded in Salesforce CRM. Enables cross-system reconciliation between the Databricks Silver Layer and the CRM source of record for pipeline filtering and account assignment.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:esgFocus rdf:type rdf:Property ;
    rdfs:label 'Esg Focus' ;
    rdfs:comment 'Indicates whether clients in this segment place significant emphasis on Environmental, Social, and Governance (ESG) criteria in their procurement and project evaluation processes. Informs BD messaging, capability statements, and sustainability reporting alignment.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hseStandard rdf:type rdf:Property ;
    rdfs:label 'Hse Standard' ;
    rdfs:comment 'Primary Health, Safety, and Environment (HSE) standard required by clients in this segment. Drives HSE prequalification requirements and Intelex configuration for incident reporting and audit compliance. Values: iso_45001, osha, client_specific, none.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isGlobalSegment rdf:type rdf:Property ;
    rdfs:label 'Is Global Segment' ;
    rdfs:comment 'Indicates whether this segment is defined at a global level (applicable across all geographic regions) or is region-specific. Global segments are used for enterprise-wide BD strategy reporting; regional segments support local account planning.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jvPartnershipTypical rdf:type rdf:Property ;
    rdfs:label 'Jv Partnership Typical' ;
    rdfs:comment 'Indicates whether projects in this segment are typically pursued through Joint Venture (JV) arrangements rather than as a sole contractor. Informs BD partner strategy, JV structure planning, and bid resource allocation.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastReviewedDate rdf:type rdf:Property ;
    rdfs:label 'Last Reviewed Date' ;
    rdfs:comment 'Date on which this segment definition was last formally reviewed and validated by the BD or PMO team. Used to enforce review frequency governance and identify stale segment definitions.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextReviewDate rdf:type rdf:Property ;
    rdfs:label 'Next Review Date' ;
    rdfs:comment 'Scheduled date for the next formal review of this segment definition. Derived from last_reviewed_date and review_frequency but stored explicitly to support CRM workflow triggers and governance reporting.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:prequalificationRequired rdf:type rdf:Property ;
    rdfs:label 'Prequalification Required' ;
    rdfs:comment 'Indicates whether clients in this segment require formal contractor prequalification before issuing a Request for Proposal (RFP) or Request for Quotation (RFQ). Drives BD qualification workflow and Salesforce CRM opportunity stage configuration.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:primaryCountryCode rdf:type rdf:Property ;
    rdfs:label 'Primary Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 three-letter country code representing the primary target country for this segment (e.g., \'USA\', \'GBR\', \'AUS\'). Used for regulatory alignment and geographic BD targeting.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryFramework rdf:type rdf:Property ;
    rdfs:label 'Regulatory Framework' ;
    rdfs:comment 'Primary regulatory or standards framework governing procurement and project delivery for clients in this segment (e.g., \'FIDIC Red Book\', \'NEC4 ECC\', \'JCT Design and Build\', \'FAR/DFARS\' for US federal). Informs contract administration approach and compliance requirements.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueBandMaxUsd rdf:type rdf:Property ;
    rdfs:label 'Revenue Band Max Usd' ;
    rdfs:comment 'Maximum annual revenue threshold (in USD) defining the upper bound of the target client revenue band for this segment. A null value indicates an open-ended upper bound (e.g., mega-clients). Used alongside revenue_band_min_usd for client qualification.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revenueBandMinUsd rdf:type rdf:Property ;
    rdfs:label 'Revenue Band Min Usd' ;
    rdfs:comment 'Minimum annual revenue threshold (in USD) defining the lower bound of the target client revenue band for this segment. Used for client qualification and BD targeting criteria. Expressed in USD for cross-regional comparability.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:segmentCode rdf:type rdf:Property ;
    rdfs:label 'Segment Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying the segment, used in Salesforce CRM pipeline filtering, account planning, and BD reporting. Serves as the business-facing identifier across systems (e.g., \'PUB-INFRA-APAC-T1\').' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentDescription rdf:type rdf:Property ;
    rdfs:label 'Segment Description' ;
    rdfs:comment 'Detailed narrative describing the strategic rationale, target client profile, and BD focus for this segment. Used in account planning and BD resource allocation documentation.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentName rdf:type rdf:Property ;
    rdfs:label 'Segment Name' ;
    rdfs:comment 'Human-readable name of the client segment used in CRM dashboards, BD strategy documents, and account planning reports (e.g., \'Public Infrastructure – Asia Pacific – Key Account\').' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentStatus rdf:type rdf:Property ;
    rdfs:label 'Segment Status' ;
    rdfs:comment 'Current lifecycle status of the segment definition. \'active\' = currently used for BD targeting and CRM filtering; \'inactive\' = no longer targeted; \'under_review\' = pending re-classification; \'archived\' = retired segment retained for historical reporting.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strategicTier rdf:type rdf:Property ;
    rdfs:label 'Strategic Tier' ;
    rdfs:comment 'BD prioritization tier assigned to this segment indicating the level of strategic investment and relationship management effort. \'key_account\' = highest-priority clients with dedicated BD resources; \'growth\' = high-potential targets; \'standard\' = routine pipeline; \'dormant\' = inactive or deprioritized. Drives CRM pipeline weighting and BD resource allocation.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subSector rdf:type rdf:Property ;
    rdfs:label 'Sub Sector' ;
    rdfs:comment 'Detailed market sub-sector classification within the parent sector. Drives BD resource allocation and win-rate analysis by market vertical. Values: infrastructure (highways, airports, bridges), energy (power plants, renewables), commercial (offices, retail), residential (housing developments), industrial (factories, warehouses).' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetPipelineValueUsd rdf:type rdf:Property ;
    rdfs:label 'Target Pipeline Value Usd' ;
    rdfs:comment 'Annual BD pipeline value target (in USD) for this segment, set during strategic planning cycles. Used to measure pipeline coverage ratio and BD resource adequacy. Supports Salesforce CRM pipeline forecasting and PMO reporting.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetWinRatePct rdf:type rdf:Property ;
    rdfs:label 'Target Win Rate Pct' ;
    rdfs:comment 'Strategically defined target bid win rate (as a percentage, 0.00–100.00) for this segment, set during annual BD planning. Used as a benchmark for measuring BD performance and CRM pipeline health against actual win rates by segment.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:typicalContractDurationMonths rdf:type rdf:Property ;
    rdfs:label 'Typical Contract Duration Months' ;
    rdfs:comment 'Average or typical project/contract duration in months for engagements within this segment. Used in resource planning, scheduling baseline development in Oracle Primavera P6, and BD pipeline timing analysis.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:typicalProjectValueMaxUsd rdf:type rdf:Property ;
    rdfs:label 'Typical Project Value Max Usd' ;
    rdfs:comment 'Maximum typical contract or project value (in USD) expected from clients in this segment. A null value indicates no upper cap (e.g., mega-infrastructure programs). Used in BD resource sizing and pipeline forecasting.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:typicalProjectValueMinUsd rdf:type rdf:Property ;
    rdfs:label 'Typical Project Value Min Usd' ;
    rdfs:comment 'Minimum typical contract or project value (in USD) expected from clients in this segment. Used in bid/no-bid decision frameworks and BD pipeline prioritization. Reflects the lower bound of the Bill of Quantities (BOQ) range for this market.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:authorityNoticeId rdf:type rdf:Property ;
    rdfs:label 'Authority Notice Id' ;
    rdfs:comment 'System-generated unique identifier for the authority notice record.' ;
    rdfs:domain ind:AuthorityNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dailyLogId rdf:type rdf:Property ;
    rdfs:label 'Daily Log Id' ;
    rdfs:comment 'Identifier of the site/location where the notice applies.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DailyLog .

ind:documentRegisterId rdf:type rdf:Property ;
    rdfs:label 'Document Register Id' ;
    rdfs:comment 'Reference to a stored document (e.g., scanned notice) linked to this record.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DocumentRegister .

ind:appealDate rdf:type rdf:Property ;
    rdfs:label 'Appeal Date' ;
    rdfs:comment 'Date on which the appeal was lodged.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:appealLodgedFlag rdf:type rdf:Property ;
    rdfs:label 'Appeal Lodged Flag' ;
    rdfs:comment 'Indicates whether an appeal against the notice has been filed.' ;
    rdfs:domain ind:AuthorityNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:authorityNoticeStatus rdf:type rdf:Property ;
    rdfs:label 'Authority Notice Status' ;
    rdfs:comment 'Current lifecycle status of the notice.' ;
    rdfs:domain ind:AuthorityNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorityType rdf:type rdf:Property ;
    rdfs:label 'Authority Type' ;
    rdfs:comment 'Classification of the issuing authority by jurisdiction level.' ;
    rdfs:domain ind:AuthorityNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceCategory rdf:type rdf:Property ;
    rdfs:label 'Compliance Category' ;
    rdfs:comment 'High-level category of the compliance issue.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceOfficer rdf:type rdf:Property ;
    rdfs:label 'Compliance Officer' ;
    rdfs:comment 'Name of the internal officer responsible for managing the notice response.' ;
    rdfs:domain ind:AuthorityNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:noticeDate rdf:type rdf:Property ;
    rdfs:label 'Notice Date' ;
    rdfs:comment 'Date and time when the regulatory authority issued the notice.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:noticeNumber rdf:type rdf:Property ;
    rdfs:label 'Notice Number' ;
    rdfs:comment 'External reference number assigned by the issuing authority to the notice.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:noticeType rdf:type rdf:Property ;
    rdfs:label 'Notice Type' ;
    rdfs:comment 'Category of the notice describing its nature.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:penaltyAmount rdf:type rdf:Property ;
    rdfs:label 'Penalty Amount' ;
    rdfs:comment 'Monetary penalty imposed by the authority, if any.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:penaltyCurrency rdf:type rdf:Property ;
    rdfs:label 'Penalty Currency' ;
    rdfs:comment 'Three-letter ISO currency code for the penalty amount.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:penaltyDueDate rdf:type rdf:Property ;
    rdfs:label 'Penalty Due Date' ;
    rdfs:comment 'Date by which the penalty must be paid.' ;
    rdfs:domain ind:AuthorityNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulationBreached rdf:type rdf:Property ;
    rdfs:label 'Regulation Breached' ;
    rdfs:comment 'Specific regulation, code, or standard that was violated.' ;
    rdfs:domain ind:AuthorityNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remediationRequired rdf:type rdf:Property ;
    rdfs:label 'Remediation Required' ;
    rdfs:comment 'Actions required by the authority to remediate the violation.' ;
    rdfs:domain ind:AuthorityNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionDate rdf:type rdf:Property ;
    rdfs:label 'Resolution Date' ;
    rdfs:comment 'Date on which the notice was formally resolved.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:resolutionOutcome rdf:type rdf:Property ;
    rdfs:label 'Resolution Outcome' ;
    rdfs:comment 'Final outcome after the notice was addressed.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseSubmittedDate rdf:type rdf:Property ;
    rdfs:label 'Response Submitted Date' ;
    rdfs:comment 'Date on which the response was submitted.' ;
    rdfs:domain ind:AuthorityNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:responseSubmittedFlag rdf:type rdf:Property ;
    rdfs:label 'Response Submitted Flag' ;
    rdfs:comment 'Indicates whether a response has been submitted to the authority.' ;
    rdfs:domain ind:AuthorityNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:severityLevel rdf:type rdf:Property ;
    rdfs:label 'Severity Level' ;
    rdfs:comment 'Risk severity assigned to the notice by the authority.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:violationDescription rdf:type rdf:Property ;
    rdfs:label 'Violation Description' ;
    rdfs:comment 'Detailed description of the regulatory violation cited in the notice.' ;
    rdfs:domain ind:AuthorityNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceActionId rdf:type rdf:Property ;
    rdfs:label 'Compliance Action Id' ;
    rdfs:comment 'System-generated unique identifier for the compliance action record.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ComplianceAction .

ind:activityId rdf:type rdf:Property ;
    rdfs:label 'Activity Id' ;
    rdfs:comment 'Foreign key linking to schedule.activity. Business justification: Compliance actions (e.g., corrective measures) are assigned to the specific scheduled activity they address, supporting traceability of remediation.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Activity .

ind:ownerOrgUnitId rdf:type rdf:Property ;
    rdfs:label 'Owner Org Unit Id' ;
    rdfs:comment 'Foreign key linking to hr.org_unit. Business justification: Maps compliance actions to the owning org unit, replacing free-text department field to enable unit-level performance metrics.' ;
    rdfs:domain ind:ComplianceAction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrgUnit .

ind:primaryComplianceEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Compliance Employee Id' ;
    rdfs:comment 'Identifier of the internal or external party accountable for executing the action.' ;
    rdfs:domain ind:ComplianceAction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:projectBudgetId rdf:type rdf:Property ;
    rdfs:label 'Project Budget Id' ;
    rdfs:comment 'Foreign key linking to finance.project_budget. Business justification: Budgeting of compliance actions is tracked within the project budget to control allocated compliance funds.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProjectBudget .

ind:purchaseOrderId rdf:type rdf:Property ;
    rdfs:label 'Purchase Order Id' ;
    rdfs:comment 'Foreign key linking to procurement.purchase_order. Business justification: Compliance actions (e.g., corrective measures) are often triggered by a particular purchase order that caused a non-conformance.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PurchaseOrder .

ind:relatedAuditIsoAuditId rdf:type rdf:Property ;
    rdfs:label 'Related Audit Iso Audit Id' ;
    rdfs:comment 'Identifier of the audit or inspection that uncovered the issue.' ;
    rdfs:domain ind:ComplianceAction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IsoAudit .

ind:sourceFindingId rdf:type rdf:Property ;
    rdfs:label 'Source Finding Id' ;
    rdfs:comment 'Reference to the specific finding, observation, or notice that originated the action.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Finding .

ind:actionNumber rdf:type rdf:Property ;
    rdfs:label 'Action Number' ;
    rdfs:comment 'Human-readable identifier assigned to the corrective or preventive action, often used in reports and communications.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actionType rdf:type rdf:Property ;
    rdfs:label 'Action Type' ;
    rdfs:comment 'Classifies the action as corrective, preventive, or improvement.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Approval Timestamp' ;
    rdfs:comment 'Date-time when the action was formally approved.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:closureEvidenceUrl rdf:type rdf:Property ;
    rdfs:label 'Closure Evidence Url' ;
    rdfs:comment 'Web link or path to the evidence confirming action closure.' ;
    rdfs:domain ind:ComplianceAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:comments rdf:type rdf:Property ;
    rdfs:label 'Comments' ;
    rdfs:comment 'Free-form notes or remarks added by stakeholders.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:completedDate rdf:type rdf:Property ;
    rdfs:label 'Completed Date' ;
    rdfs:comment 'Actual date when the corrective or preventive work was finished.' ;
    rdfs:domain ind:ComplianceAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:complianceActionDescription rdf:type rdf:Property ;
    rdfs:label 'Compliance Action Description' ;
    rdfs:comment 'Detailed description of the corrective or preventive work to be performed.' ;
    rdfs:domain ind:ComplianceAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceActionStatus rdf:type rdf:Property ;
    rdfs:label 'Compliance Action Status' ;
    rdfs:comment 'Current lifecycle state of the compliance action.' ;
    rdfs:domain ind:ComplianceAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceArea rdf:type rdf:Property ;
    rdfs:label 'Compliance Area' ;
    rdfs:comment 'Domain of compliance impacted (e.g., safety, environment, quality).' ;
    rdfs:domain ind:ComplianceAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveMeasure rdf:type rdf:Property ;
    rdfs:label 'Corrective Measure' ;
    rdfs:comment 'Specific steps or measures that will address the identified non-conformance.' ;
    rdfs:domain ind:ComplianceAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costActual rdf:type rdf:Property ;
    rdfs:label 'Cost Actual' ;
    rdfs:comment 'Actual monetary cost incurred after action completion.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costEstimate rdf:type rdf:Property ;
    rdfs:label 'Cost Estimate' ;
    rdfs:comment 'Projected monetary cost to implement the action.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:externalAuthorityName rdf:type rdf:Property ;
    rdfs:label 'External Authority Name' ;
    rdfs:comment 'Name of the external regulatory body or agency.' ;
    rdfs:domain ind:ComplianceAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalNoticeDate rdf:type rdf:Property ;
    rdfs:label 'External Notice Date' ;
    rdfs:comment 'Date the external authority issued the notice or citation.' ;
    rdfs:domain ind:ComplianceAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isExternal rdf:type rdf:Property ;
    rdfs:label 'Is External' ;
    rdfs:comment 'True if the action is driven by an external regulator or agency.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRepeatAction rdf:type rdf:Property ;
    rdfs:label 'Is Repeat Action' ;
    rdfs:comment 'True if this action is a repeat of a previously recorded issue.' ;
    rdfs:domain ind:ComplianceAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastReviewedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Reviewed Timestamp' ;
    rdfs:comment 'Date-time when the action record was last reviewed for relevance or accuracy.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:mitigationPlan rdf:type rdf:Property ;
    rdfs:label 'Mitigation Plan' ;
    rdfs:comment 'Long-term plan to prevent recurrence of the issue.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monitoringEndDate rdf:type rdf:Property ;
    rdfs:label 'Monitoring End Date' ;
    rdfs:comment 'Date when the monitoring period ends.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:monitoringFrequency rdf:type rdf:Property ;
    rdfs:label 'Monitoring Frequency' ;
    rdfs:comment 'How often the post-action monitoring should occur.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monitoringRequired rdf:type rdf:Property ;
    rdfs:label 'Monitoring Required' ;
    rdfs:comment 'True if ongoing monitoring is required after closure.' ;
    rdfs:domain ind:ComplianceAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:monitoringStartDate rdf:type rdf:Property ;
    rdfs:label 'Monitoring Start Date' ;
    rdfs:comment 'Date when the monitoring period begins.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryReference rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reference' ;
    rdfs:comment 'Citation of the specific regulation, standard, or permit clause that triggered the action (e.g., OSHA 1910.120).' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:repeatActionCount rdf:type rdf:Property ;
    rdfs:label 'Repeat Action Count' ;
    rdfs:comment 'Number of times the same issue has been recorded.' ;
