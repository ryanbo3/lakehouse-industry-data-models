    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bondGuaranteeId rdf:type rdf:Property ;
    rdfs:label 'Bond Guarantee Id' ;
    rdfs:comment 'Unique surrogate key for the bond guarantee record.' ;
