    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contractChangeOrderId rdf:type rdf:Property ;
    rdfs:label 'Contract Change Order Id' ;
    rdfs:comment 'Identifier of a change order linked to this amendment, if applicable.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ContractChangeOrder .

ind:createdByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Created By Employee Id' ;
    rdfs:comment 'Foreign key linking to hr.employee. Business justification: Tracks employee who drafted a contract amendment; needed for amendment audit trails.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:amendmentCategory rdf:type rdf:Property ;
    rdfs:label 'Amendment Category' ;
    rdfs:comment 'High-level category of impact caused by the amendment.' ;
