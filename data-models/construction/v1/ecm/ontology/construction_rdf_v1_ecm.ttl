ind:workWeekDefinition rdf:type rdf:Property ;
    rdfs:label 'Work Week Definition' ;
    rdfs:comment 'Encoded representation (e.g., JSON string) of which days of the week are working days.' ;
    rdfs:domain ind:ScheduleCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedExtensionDays rdf:type rdf:Property ;
    rdfs:label 'Approved Extension Days' ;
    rdfs:comment 'Number of days approved by the employer after claim evaluation.' ;
    rdfs:domain ind:ScheduleEotClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:claimReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Claim Reference Number' ;
    rdfs:comment 'External business identifier assigned to the claim, used in contract administration and communications.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimSubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Claim Submission Date' ;
    rdfs:comment 'Date the claim was formally submitted to the employer or client.' ;
    rdfs:domain ind:ScheduleEotClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:claimedExtensionDays rdf:type rdf:Property ;
    rdfs:label 'Claimed Extension Days' ;
    rdfs:comment 'Number of calendar days the claimant requests to extend the contract completion date.' ;
    rdfs:domain ind:ScheduleEotClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:delayEndDate rdf:type rdf:Property ;
    rdfs:label 'Delay End Date' ;
    rdfs:comment 'Planned end date of the delay event as recorded in the project schedule.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:delayStartDate rdf:type rdf:Property ;
    rdfs:label 'Delay Start Date' ;
    rdfs:comment 'Planned start date of the delay event as recorded in the project schedule.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:justificationDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Justification Document Reference' ;
    rdfs:comment 'Reference (e.g., document number or URL) to supporting documentation submitted with the claim.' ;
    rdfs:domain ind:ScheduleEotClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportingScheduleAnalysisReference rdf:type rdf:Property ;
    rdfs:label 'Supporting Schedule Analysis Reference' ;
    rdfs:comment 'Identifier of the schedule analysis (e.g., critical path report) that substantiates the claim.' ;
    rdfs:domain ind:ScheduleEotClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleMilestoneId rdf:type rdf:Property ;
    rdfs:label 'Schedule Milestone Id' ;
    rdfs:comment 'System-generated unique identifier for the schedule milestone. _canonical_skip_reason: Entity does not fit a predefined role, treated as OTHER.' ;
    rdfs:domain ind:ScheduleMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ldExposureFlag rdf:type rdf:Property ;
    rdfs:label 'Ld Exposure Flag' ;
    rdfs:comment 'Indicates whether the milestone triggers liquidated damages if missed.' ;
    rdfs:domain ind:ScheduleMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scheduleMilestoneDescription rdf:type rdf:Property ;
    rdfs:label 'Schedule Milestone Description' ;
    rdfs:comment 'Detailed narrative describing the purpose and scope of the milestone.' ;
    rdfs:domain ind:ScheduleMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleMilestoneName rdf:type rdf:Property ;
    rdfs:label 'Schedule Milestone Name' ;
    rdfs:comment 'Human-readable name of the milestone as defined in the contract or project plan.' ;
    rdfs:domain ind:ScheduleMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleMilestoneStatus rdf:type rdf:Property ;
    rdfs:label 'Schedule Milestone Status' ;
    rdfs:comment 'Current status of the milestone reflecting progress and risk.' ;
    rdfs:domain ind:ScheduleMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleMilestoneType rdf:type rdf:Property ;
    rdfs:label 'Schedule Milestone Type' ;
    rdfs:comment 'Classification of the milestone (e.g., contract-driven, internal project, client-required, or regulatory).' ;
    rdfs:domain ind:ScheduleMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sequence rdf:type rdf:Property ;
    rdfs:label 'Sequence' ;
    rdfs:comment 'Ordinal position of the milestone within the overall schedule.' ;
    rdfs:domain ind:ScheduleMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:varianceDays rdf:type rdf:Property ;
    rdfs:label 'Variance Days' ;
    rdfs:comment 'Difference in days between planned (or baseline) date and actual/forecast date.' ;
    rdfs:domain ind:ScheduleMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:scheduleRiskId rdf:type rdf:Property ;
    rdfs:label 'Schedule Risk Id' ;
    rdfs:comment 'Unique identifier for the schedule risk entry. _canonical_skip_reason: Entity does not fit predefined role categories, classified as OTHER.' ;
    rdfs:domain ind:ScheduleRisk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contingencyReserveDays rdf:type rdf:Property ;
    rdfs:label 'Contingency Reserve Days' ;
    rdfs:comment 'Number of days of schedule contingency set aside for this risk.' ;
    rdfs:domain ind:ScheduleRisk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:monteCarloP50Date rdf:type rdf:Property ;
    rdfs:label 'Monte Carlo P50 Date' ;
    rdfs:comment 'Projected completion date at the 50th percentile from Monte Carlo simulation.' ;
    rdfs:domain ind:ScheduleRisk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:monteCarloP80Date rdf:type rdf:Property ;
    rdfs:label 'Monte Carlo P80 Date' ;
    rdfs:comment 'Projected completion date at the 80th percentile from Monte Carlo simulation.' ;
    rdfs:domain ind:ScheduleRisk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:monteCarloP85Date rdf:type rdf:Property ;
    rdfs:label 'Monte Carlo P85 Date' ;
    rdfs:comment 'Projected completion date at the 85th percentile from Monte Carlo simulation.' ;
    rdfs:domain ind:ScheduleRisk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ownerDepartment rdf:type rdf:Property ;
    rdfs:label 'Owner Department' ;
    rdfs:comment 'Department or business unit responsible for the risk.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownerRole rdf:type rdf:Property ;
    rdfs:label 'Owner Role' ;
    rdfs:comment 'Job role or title of the risk owner (e.g., Project Scheduler, Construction Manager).' ;
    rdfs:domain ind:ScheduleRisk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemReference rdf:type rdf:Property ;
    rdfs:label 'Source System Reference' ;
    rdfs:comment 'Unique identifier of the risk in the source system.' ;
    rdfs:domain ind:ScheduleRisk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentWbsWbsNodeId rdf:type rdf:Property ;
    rdfs:label 'Parent Wbs Wbs Node Id' ;
    rdfs:comment 'Identifier of the immediate parent WBS node; null for top-level nodes.' ;
    rdfs:domain ind:WbsNode ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WbsNode .

ind:actualDurationDays rdf:type rdf:Property ;
    rdfs:label 'Actual Duration Days' ;
    rdfs:comment 'Actual elapsed days from start to finish.' ;
    rdfs:domain ind:WbsNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:changeOrderIndicator rdf:type rdf:Property ;
    rdfs:label 'Change Order Indicator' ;
    rdfs:comment 'True if the node has been impacted by a change order.' ;
    rdfs:domain ind:WbsNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deletedFlag rdf:type rdf:Property ;
    rdfs:label 'Deleted Flag' ;
    rdfs:comment 'True if the node has been logically deleted; false otherwise.' ;
    rdfs:domain ind:WbsNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:earnedValueMethod rdf:type rdf:Property ;
    rdfs:label 'Earned Value Method' ;
    rdfs:comment 'Technique used to calculate earned value for the node.' ;
    rdfs:domain ind:WbsNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalReference rdf:type rdf:Property ;
    rdfs:label 'External Reference' ;
    rdfs:comment 'Identifier of the node in external systems (e.g., Primavera activity ID).' ;
    rdfs:domain ind:WbsNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedDurationDays rdf:type rdf:Property ;
    rdfs:label 'Planned Duration Days' ;
    rdfs:comment 'Planned duration of the node in calendar days.' ;
    rdfs:domain ind:WbsNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:wbsNodeDescription rdf:type rdf:Property ;
    rdfs:label 'Wbs Node Description' ;
    rdfs:comment 'Detailed textual description of the scope element.' ;
    rdfs:domain ind:WbsNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wbsNodeStatus rdf:type rdf:Property ;
    rdfs:label 'Wbs Node Status' ;
    rdfs:comment 'Current lifecycle status of the WBS node.' ;
    rdfs:domain ind:WbsNode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:concretePourId rdf:type rdf:Property ;
    rdfs:label 'Concrete Pour Id' ;
    rdfs:comment 'Unique system-generated identifier for each concrete pour event on site. Primary key for the concrete_pour data product.' ;
    rdfs:domain ind:ConcretePour ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pourSupervisorCraftWorkerId rdf:type rdf:Property ;
    rdfs:label 'Pour Supervisor Craft Worker Id' ;
    rdfs:comment 'Foreign key linking to workforce.craft_worker. Business justification: REQUIRED: Concrete pour supervision is assigned to a qualified foreman; FK supports QC, safety audit trails and traceability of pour responsibility.' ;
    rdfs:domain ind:ConcretePour ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CraftWorker .

ind:pourSupervisorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Pour Supervisor Employee Id' ;
    rdfs:comment 'Foreign key linking to hr.employee. Business justification: Concrete pour supervision is a safety-critical role; linking to employee satisfies HSE compliance and incident investigation.' ;
    rdfs:domain ind:ConcretePour ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:procoreDailyLogId rdf:type rdf:Property ;
    rdfs:label 'Procore Daily Log Id' ;
    rdfs:comment 'Reference identifier of the Procore daily log entry in which this pour event was recorded. Enables cross-system traceability between the lakehouse silver layer and the Procore source system.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DailyLog .

ind:curingStartTime rdf:type rdf:Property ;
    rdfs:label 'Curing Start Time' ;
    rdfs:comment 'Date and time when curing operations commenced after completion of the pour. Used to calculate curing duration compliance against specification requirements.' ;
    rdfs:domain ind:ConcretePour ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:cylinderSetReference rdf:type rdf:Property ;
    rdfs:label 'Cylinder Set Reference' ;
    rdfs:comment 'Unique reference number or label assigned to the set of test cylinders cast from this pour, used to track specimens through the laboratory testing process and link results back to the pour event.' ;
    rdfs:domain ind:ConcretePour ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:formworkDrawingRef rdf:type rdf:Property ;
    rdfs:label 'Formwork Drawing Ref' ;
    rdfs:comment 'Reference number of the approved formwork or structural drawing used for this pour, as registered in Autodesk BIM 360 or Aconex document management. Provides design traceability.' ;
    rdfs:domain ind:ConcretePour ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hcssProductionCode rdf:type rdf:Property ;
    rdfs:label 'Hcss Production Code' ;
    rdfs:comment 'Reference identifier of the HCSS HeavyJob production tracking record associated with this pour event. Enables cross-system traceability for cost coding and production rate analysis.' ;
    rdfs:domain ind:ConcretePour ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mixDesignCode rdf:type rdf:Property ;
    rdfs:label 'Mix Design Code' ;
    rdfs:comment 'Approved mix design code referencing the specific concrete formulation used for this pour, as registered in the material domain batch traceability records. Links to approved mix design submittals.' ;
    rdfs:domain ind:ConcretePour ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:placementMethod rdf:type rdf:Property ;
    rdfs:label 'Placement Method' ;
    rdfs:comment 'Method used to place the concrete into the formwork. Affects production rate, quality, and equipment resource planning. Examples: pump (boom pump or line pump), crane and bucket, conveyor belt, direct chute.' ;
    rdfs:domain ind:ConcretePour ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pourType rdf:type rdf:Property ;
    rdfs:label 'Pour Type' ;
    rdfs:comment 'Classification of the structural element type being poured. Used for production benchmarking, resource planning, and QA/QC ITP selection. [ENUM-REF-CANDIDATE: slab|column|beam|wall|footing|pile_cap|bridge_deck|other — promote to reference product]' ;
    rdfs:domain ind:ConcretePour ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qcHoldStatus rdf:type rdf:Property ;
    rdfs:label 'Qc Hold Status' ;
    rdfs:comment 'Quality Control (QC) hold status for this pour event. \'hold_applied\' means the pour is under QC review pending inspection or test results. \'hold_released\' means the hold has been cleared by the QA/QC engineer. \'rejected\' means the pour has been condemned and remediation is required.' ;
    rdfs:domain ind:ConcretePour ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qcInspector rdf:type rdf:Property ;
    rdfs:label 'Qc Inspector' ;
    rdfs:comment 'Name of the Quality Control (QC) inspector who witnessed the pour, conducted slump tests, and cast test cylinders. Required for QA/QC traceability and ITP sign-off.' ;
    rdfs:domain ind:ConcretePour ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relativeHumidityPct rdf:type rdf:Property ;
    rdfs:label 'Relative Humidity Pct' ;
    rdfs:comment 'Recorded relative humidity percentage at the pour location at time of placement. Relevant for evaporation rate calculations and plastic shrinkage cracking risk assessment per ACI 305R.' ;
    rdfs:domain ind:ConcretePour ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:slumpCompliant rdf:type rdf:Property ;
    rdfs:label 'Slump Compliant' ;
    rdfs:comment 'Indicates whether the measured slump result falls within the specified minimum and maximum limits. True = compliant; False = non-compliant, triggering QC review or NCR.' ;
    rdfs:domain ind:ConcretePour ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:slumpSpecifiedMaxMm rdf:type rdf:Property ;
    rdfs:label 'Slump Specified Max Mm' ;
    rdfs:comment 'Maximum allowable slump value in millimetres as specified in the concrete mix design or project specification. Exceedance triggers rejection or NCR issuance.' ;
    rdfs:domain ind:ConcretePour ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:slumpSpecifiedMinMm rdf:type rdf:Property ;
    rdfs:label 'Slump Specified Min Mm' ;
    rdfs:comment 'Minimum allowable slump value in millimetres as specified in the concrete mix design or project specification. Used for QC acceptance/rejection decisions.' ;
    rdfs:domain ind:ConcretePour ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:specifiedStrengthMpa rdf:type rdf:Property ;
    rdfs:label 'Specified Strength Mpa' ;
    rdfs:comment 'Design-specified characteristic compressive strength of the concrete in megapascals (MPa) at 28 days, as defined in the structural drawings and specification. Used for QC acceptance criteria.' ;
    rdfs:domain ind:ConcretePour ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:structureElement rdf:type rdf:Property ;
    rdfs:label 'Structure Element' ;
    rdfs:comment 'Name or designation of the structural element being poured, such as \'Pile Cap PC-01\', \'Column C3\', \'Slab Level 4\', \'Retaining Wall RW-02\'. Provides traceability to design drawings and BIM model elements.' ;
    rdfs:domain ind:ConcretePour ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testCylindersCast rdf:type rdf:Property ;
    rdfs:label 'Test Cylinders Cast' ;
    rdfs:comment 'Number of concrete test cylinders (or cubes) cast from this pour for compressive strength testing at specified curing ages (e.g., 7-day, 28-day). Minimum count is governed by specification and ACI/ASTM standards.' ;
    rdfs:domain ind:ConcretePour ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:truckLoadCount rdf:type rdf:Property ;
    rdfs:label 'Truck Load Count' ;
    rdfs:comment 'Total number of ready-mix concrete truck loads (agitator trucks) delivered and placed during this pour event. Used for logistics planning, docket reconciliation, and production rate analysis.' ;
    rdfs:domain ind:ConcretePour ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:volumePouredM3 rdf:type rdf:Property ;
    rdfs:label 'Volume Poured M3' ;
    rdfs:comment 'Total volume of concrete placed during this pour event, measured in cubic metres (m³). Derived from delivery docket quantities and used for earned value computation, material reconciliation, and production tracking in HCSS HeavyJob.' ;
    rdfs:domain ind:ConcretePour ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:windSpeedKmh rdf:type rdf:Property ;
    rdfs:label 'Wind Speed Kmh' ;
    rdfs:comment 'Recorded wind speed in kilometres per hour at the pour location at time of placement. Used in evaporation rate nomograph calculations to assess plastic shrinkage cracking risk.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:crewDeploymentId rdf:type rdf:Property ;
    rdfs:label 'Crew Deployment Id' ;
    rdfs:comment 'Unique surrogate identifier for each daily crew deployment record. Primary key for the crew_deployment data product in the site domain Silver layer.' ;
    rdfs:domain ind:CrewDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:leadForemanEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Lead Foreman Employee Id' ;
    rdfs:comment 'Employee identifier of the lead foreman from the workforce system (SAP SuccessFactors). Enables linkage to workforce domain records without duplicating personal data.' ;
    rdfs:domain ind:CrewDeployment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualHours rdf:type rdf:Property ;
    rdfs:label 'Actual Hours' ;
    rdfs:comment 'Total man-hours actually worked by the crew on this deployment date, as recorded in HCSS HeavyJob time tracking. Compared against planned_hours to compute productivity variance and feed EVM calculations.' ;
    rdfs:domain ind:CrewDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualProductionQty rdf:type rdf:Property ;
    rdfs:label 'Actual Production Qty' ;
    rdfs:comment 'Actual quantity of work output achieved by the crew on this deployment date, as recorded in HCSS HeavyJob production tracking. Compared against planned_production_qty for productivity analysis and earned value computation.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:crewCode rdf:type rdf:Property ;
    rdfs:label 'Crew Code' ;
    rdfs:comment 'Alphanumeric business identifier for the crew or gang as defined in HCSS HeavyJob (e.g., \'CIV-A\', \'CONC-03\'). Used for cost coding and production tracking lookups.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crewName rdf:type rdf:Property ;
    rdfs:label 'Crew Name' ;
    rdfs:comment 'Human-readable name or designation of the crew or gang being deployed (e.g., \'Civil Gang A\', \'Concrete Pour Crew 3\', \'Steel Erection Team North\'). Sourced from HCSS HeavyJob crew master.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crewType rdf:type rdf:Property ;
    rdfs:label 'Crew Type' ;
    rdfs:comment 'Classification of the crew by trade discipline. Drives resource planning, productivity benchmarking, and cost code allocation. [ENUM-REF-CANDIDATE: civil|mep|concrete|steel_erection|earthworks|finishing|specialist|formwork|rebar|waterproofing — promote to reference product]' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deploymentDate rdf:type rdf:Property ;
    rdfs:label 'Deployment Date' ;
    rdfs:comment 'Calendar date on which the crew is deployed to the work front. The principal business event date for this daily deployment record. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:deploymentNumber rdf:type rdf:Property ;
    rdfs:label 'Deployment Number' ;
    rdfs:comment 'Externally-known business identifier for this crew deployment record, typically generated by HCSS HeavyJob (e.g., CD-2024-00123). Used for cross-system referencing and field reporting.' ;
    rdfs:domain ind:CrewDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deploymentStatus rdf:type rdf:Property ;
    rdfs:label 'Deployment Status' ;
    rdfs:comment 'Current lifecycle state of the crew deployment record. Tracks whether the deployment is planned, actively in progress, completed, cancelled, or suspended due to site conditions.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hseToolboxMeetingHeld rdf:type rdf:Property ;
    rdfs:label 'Hse Toolbox Meeting Held' ;
    rdfs:comment 'Indicates whether a Toolbox Meeting (TBM) was conducted with this crew prior to commencing work on this deployment date (True) or not (False). Mandatory HSE compliance check per OSHA and ISO 45001 requirements.' ;
    rdfs:domain ind:CrewDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSubcontractorCrew rdf:type rdf:Property ;
    rdfs:label 'Is Subcontractor Crew' ;
    rdfs:comment 'Indicates whether this crew is supplied by a subcontractor (True) or is part of the general contractor\'s direct workforce (False). Drives cost segregation between self-performed and subcontracted labour.' ;
    rdfs:domain ind:CrewDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isWeatherImpacted rdf:type rdf:Property ;
    rdfs:label 'Is Weather Impacted' ;
    rdfs:comment 'Indicates whether adverse weather conditions materially impacted crew productivity or caused a work stoppage on this deployment date (True) or not (False). Supports Extension of Time (EOT) and delay claim substantiation.' ;
    rdfs:domain ind:CrewDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:leadForemanName rdf:type rdf:Property ;
    rdfs:label 'Lead Foreman Name' ;
    rdfs:comment 'Full name of the lead foreman or gang leader responsible for supervising this crew deployment. Captured from HCSS HeavyJob time tracking. Classified confidential as it identifies a named employee in a supervisory role.' ;
    rdfs:domain ind:CrewDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:permitToWorkNumber rdf:type rdf:Property ;
    rdfs:label 'Permit To Work Number' ;
    rdfs:comment 'Reference number of the Permit to Work (PTW) issued for this crew deployment, where the work activity requires a formal permit (e.g., hot work, confined space, excavation). Sourced from Intelex HSE management system.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedHours rdf:type rdf:Property ;
    rdfs:label 'Planned Hours' ;
    rdfs:comment 'Total man-hours planned for this crew deployment on the given date, as scheduled in Oracle Primavera P6. Used as the baseline for earned value computation and productivity variance analysis.' ;
    rdfs:domain ind:CrewDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedProductionQty rdf:type rdf:Property ;
    rdfs:label 'Planned Production Qty' ;
    rdfs:comment 'Target quantity of work output planned for this crew deployment (e.g., cubic metres of concrete, linear metres of pipe, tonnes of steel). Defined in HCSS HeavyJob production tracking against the cost code.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:productivityNotes rdf:type rdf:Property ;
    rdfs:label 'Productivity Notes' ;
    rdfs:comment 'Free-text field capturing foreman or site supervisor observations about crew productivity, constraints, delays, or notable events during this deployment. Sourced from HCSS HeavyJob or Procore daily log narrative.' ;
    rdfs:domain ind:CrewDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productivityRate rdf:type rdf:Property ;
    rdfs:label 'Productivity Rate' ;
    rdfs:comment 'Actual production output per man-hour achieved by this crew on this deployment date (actual_production_qty / actual_hours). Sourced from HCSS HeavyJob production tracking. Used for benchmarking and Schedule Performance Index (SPI) analysis.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shiftEndTime rdf:type rdf:Property ;
    rdfs:label 'Shift End Time' ;
    rdfs:comment 'Actual date and time the crew shift ended on site. Sourced from HCSS HeavyJob time tracking. Used in conjunction with shift_start_time to compute actual hours worked. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:shiftStartTime rdf:type rdf:Property ;
    rdfs:label 'Shift Start Time' ;
    rdfs:comment 'Actual date and time the crew shift commenced on site. Sourced from HCSS HeavyJob time tracking. Used for hours calculation, overtime determination, and HSE compliance. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:primaryDailyEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Daily Employee Id' ;
    rdfs:comment 'Reference to the site superintendent responsible for completing and signing off this daily log. The accountable party for the legal and operational record of site activity.' ;
    rdfs:domain ind:DailyLog ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:concreteVolumeM3 rdf:type rdf:Property ;
    rdfs:label 'Concrete Volume M3' ;
    rdfs:comment 'Total volume of concrete poured on site for the log date in cubic metres. Critical production metric for structural progress tracking, QA/QC compliance (ITP), and earned value computation. Sourced from Procore and HCSS HeavyJob.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:directLabourCount rdf:type rdf:Property ;
    rdfs:label 'Direct Labour Count' ;
    rdfs:comment 'Number of direct (GC-employed) workers on site for the log date, excluding subcontractor personnel. Used for workforce planning, payroll reconciliation, and labour productivity benchmarking.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:earthworksVolumeM3 rdf:type rdf:Property ;
    rdfs:label 'Earthworks Volume M3' ;
    rdfs:comment 'Total volume of earthworks (cut, fill, or excavation) completed on site for the log date in cubic metres. Key production quantity for earned value computation, BOQ progress measurement, and HCSS HeavyJob production tracking.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:eotImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Eot Impact Flag' ;
    rdfs:comment 'Indicates whether any event recorded in this daily log has been flagged as having a potential Extension of Time (EOT) impact on the project programme. True initiates EOT substantiation documentation under FIDIC Clause 8.4 or applicable contract conditions.' ;
    rdfs:domain ind:DailyLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:equipmentCount rdf:type rdf:Property ;
    rdfs:label 'Equipment Count' ;
    rdfs:comment 'Total number of major equipment units (plant and machinery) present and operational on site for the log date. Used for equipment utilisation tracking, cost coding in HCSS HeavyJob, and mobilisation/demobilisation records.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:eventCount rdf:type rdf:Property ;
    rdfs:label 'Event Count' ;
    rdfs:comment 'Total number of embedded line-item events (delay events, weather stoppages, utility strikes, design holds, access restrictions, safety observations) recorded within this daily log header. Supports event density analytics and claim complexity assessment.' ;
    rdfs:domain ind:DailyLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hasDelayEvent rdf:type rdf:Property ;
    rdfs:label 'Has Delay Event' ;
    rdfs:comment 'Indicates whether one or more delay events were recorded in the embedded line-item events for this daily log. True triggers downstream delay analysis workflows and EOT claim tracking. Key filter for delay analytics.' ;
    rdfs:domain ind:DailyLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hasSafetyObservation rdf:type rdf:Property ;
    rdfs:label 'Has Safety Observation' ;
    rdfs:comment 'Indicates whether one or more HSE safety observations or incidents were recorded in the embedded line-item events for this daily log. True triggers integration with Intelex HSE management for incident reporting and corrective action workflows.' ;
    rdfs:domain ind:DailyLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hcssLogReference rdf:type rdf:Property ;
    rdfs:label 'Hcss Log Reference' ;
    rdfs:comment 'Reference identifier linking this daily log to the corresponding field operations record in HCSS HeavyJob. Supports production tracking reconciliation and cost code validation between Procore and HCSS.' ;
    rdfs:domain ind:DailyLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:logDate rdf:type rdf:Property ;
    rdfs:label 'Log Date' ;
    rdfs:comment 'The calendar date for which this daily site log records field activities. The principal business event date — one log per project site per calendar day. Drives schedule performance and delay analysis.' ;
    rdfs:domain ind:DailyLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:logNumber rdf:type rdf:Property ;
    rdfs:label 'Log Number' ;
    rdfs:comment 'Externally-known sequential log number assigned by the construction management system (Procore) for this daily log. Used as the human-readable business identifier in correspondence, delay claims, and EOT substantiation. Format: DL-{ProjectCode}-{Year}-{Sequence}.' ;
    rdfs:domain ind:DailyLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:logStatus rdf:type rdf:Property ;
    rdfs:label 'Log Status' ;
    rdfs:comment 'Current workflow state of the daily log record. Draft indicates in-progress field entry; submitted indicates superintendent sign-off pending review; approved indicates accepted by project management; rejected indicates returned for correction; void indicates cancelled/superseded entry.' ;
    rdfs:domain ind:DailyLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ltiOccurredFlag rdf:type rdf:Property ;
    rdfs:label 'Lti Occurred Flag' ;
    rdfs:comment 'Indicates whether a Lost Time Injury (LTI) occurred on site on this log date. True triggers mandatory incident reporting to Intelex HSE system, regulatory notification under OSHA, and TRIR (Total Recordable Incident Rate) calculation update.' ;
    rdfs:domain ind:DailyLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ncrRaisedFlag rdf:type rdf:Property ;
    rdfs:label 'Ncr Raised Flag' ;
    rdfs:comment 'Indicates whether a Non-Conformance Report (NCR) was raised on this log date. True triggers integration with the QA/QC management workflow and requires corrective action documentation per ISO 9001.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:overallSiteStatus rdf:type rdf:Property ;
    rdfs:label 'Overall Site Status' ;
    rdfs:comment 'High-level classification of site productivity for the log date. Productive indicates full operations; partially_productive indicates reduced output due to delays or restrictions; non_productive indicates no billable work performed; shutdown indicates planned or emergency site closure.' ;
    rdfs:domain ind:DailyLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:permitToWorkCount rdf:type rdf:Property ;
    rdfs:label 'Permit To Work Count' ;
    rdfs:comment 'Number of active Permits to Work (PTW) issued and in force on site for the log date. Supports HSE compliance monitoring, Intelex PTW tracking, and regulatory audit evidence for high-risk work activities.' ;
    rdfs:domain ind:DailyLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:plannedActivitiesNarrative rdf:type rdf:Property ;
    rdfs:label 'Planned Activities Narrative' ;
    rdfs:comment 'Free-text description of the construction activities that were planned for the log date per the project schedule. Compared against work_performed_narrative to identify schedule variances and support look-ahead planning.' ;
    rdfs:domain ind:DailyLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:precipitationMm rdf:type rdf:Property ;
    rdfs:label 'Precipitation Mm' ;
    rdfs:comment 'Total rainfall or precipitation recorded at the site in millimetres for the log date. Key metric for weather delay claims, earthworks productivity assessment, and EOT substantiation under FIDIC Clause 8.4.' ;
    rdfs:domain ind:DailyLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:procoreLogReference rdf:type rdf:Property ;
    rdfs:label 'Procore Log Reference' ;
    rdfs:comment 'Source system identifier for this daily log record in the Procore Construction Management platform. Enables traceability and reconciliation between the Silver Layer data product and the operational system of record.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteAccessStatus rdf:type rdf:Property ;
    rdfs:label 'Site Access Status' ;
    rdfs:comment 'Operational access status of the construction site for the log date. Closed or restricted access directly impacts productivity and supports delay claim documentation. Partial indicates some work fronts accessible.' ;
    rdfs:domain ind:DailyLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subcontractorCount rdf:type rdf:Property ;
    rdfs:label 'Subcontractor Count' ;
    rdfs:comment 'Number of subcontractor personnel on site for the log date. Supports subcontractor performance monitoring, site coordination, and contract administration.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:superintendentSignOffTimestamp rdf:type rdf:Property ;
    rdfs:label 'Superintendent Sign Off Timestamp' ;
    rdfs:comment 'Date and time when the site superintendent formally signed off and submitted the daily log. Establishes the legal record timestamp for the site activity log. Critical for delay claim and EOT substantiation timelines.' ;
    rdfs:domain ind:DailyLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:temperatureHighC rdf:type rdf:Property ;
    rdfs:label 'Temperature High C' ;
    rdfs:comment 'Highest recorded ambient temperature at the site in degrees Celsius for the log date. Used for concrete pour suitability assessment, HSE heat stress monitoring, and weather delay substantiation.' ;
    rdfs:domain ind:DailyLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:temperatureLowC rdf:type rdf:Property ;
    rdfs:label 'Temperature Low C' ;
    rdfs:comment 'Lowest recorded ambient temperature at the site in degrees Celsius for the log date. Used for cold weather concreting assessment, frost protection requirements, and weather delay substantiation.' ;
    rdfs:domain ind:DailyLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalDelayDurationHrs rdf:type rdf:Property ;
    rdfs:label 'Total Delay Duration Hrs' ;
    rdfs:comment 'Aggregate duration in hours of all delay events recorded in the embedded line-item events for this daily log. Used for schedule impact quantification, EOT claim substantiation, and SPI (Schedule Performance Index) computation.' ;
    rdfs:domain ind:DailyLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalManpowerCount rdf:type rdf:Property ;
    rdfs:label 'Total Manpower Count' ;
    rdfs:comment 'Total number of workers (all trades combined) present on site for the log date. Includes direct labour and subcontractor personnel. Key input for productivity analysis, earned value computation, and labour cost reconciliation against HCSS HeavyJob cost codes.' ;
    rdfs:domain ind:DailyLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:visitorCount rdf:type rdf:Property ;
    rdfs:label 'Visitor Count' ;
    rdfs:comment 'Number of authorised visitors (client representatives, inspectors, auditors, regulatory officials) on site for the log date. Supports site access management, HSE induction compliance, and client engagement tracking.' ;
    rdfs:domain ind:DailyLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:workPerformedNarrative rdf:type rdf:Property ;
    rdfs:label 'Work Performed Narrative' ;
    rdfs:comment 'Free-text superintendent narrative describing all construction activities performed on site during the log date. Serves as the primary operational record and legal evidence base for progress claims, delay substantiation, and EOT applications. Sourced from Procore Daily Logs.' ;
    rdfs:domain ind:DailyLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:earthworkVolumeId rdf:type rdf:Property ;
    rdfs:label 'Earthwork Volume Id' ;
    rdfs:comment 'Unique system-generated identifier for each earthwork volume measurement record. Primary key for the earthwork_volume data product in the site domain.' ;
    rdfs:domain ind:EarthworkVolume ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:surveyorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Surveyor Employee Id' ;
    rdfs:comment 'Foreign key linking to hr.employee. Business justification: Survey data must be attributed to the responsible surveyor employee for QA/QC and regulatory reporting.' ;
    rdfs:domain ind:EarthworkVolume ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:boqItemCode rdf:type rdf:Property ;
    rdfs:label 'Boq Item Code' ;
    rdfs:comment 'Reference code linking this earthwork volume measurement to the corresponding Bill of Quantities (BOQ) line item in the contract. Enables direct reconciliation between measured quantities and contracted quantities for progress billing.' ;
    rdfs:domain ind:EarthworkVolume ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compactionFactor rdf:type rdf:Property ;
    rdfs:label 'Compaction Factor' ;
    rdfs:comment 'Dimensionless ratio representing the degree of compaction applied to fill material, expressed as the ratio of compacted volume to loose volume. Used to convert loose measure volumes to compacted measure for billing and quality compliance. Typical range 0.70–1.00.' ;
    rdfs:domain ind:EarthworkVolume ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contractedVolumeM3 rdf:type rdf:Property ;
    rdfs:label 'Contracted Volume M3' ;
    rdfs:comment 'The total earthwork volume (m³) contracted for this work area and material classification as per the BOQ (Bill of Quantities). Used as the baseline for progress measurement and earned value computation.' ;
    rdfs:domain ind:EarthworkVolume ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coordinateEasting rdf:type rdf:Property ;
    rdfs:label 'Coordinate Easting' ;
    rdfs:comment 'Easting coordinate (X-axis) of the centroid or reference point of the measured earthwork area in the project coordinate system. Supports GIS (Geographic Information System) integration and spatial reporting.' ;
    rdfs:domain ind:EarthworkVolume ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coordinateNorthing rdf:type rdf:Property ;
    rdfs:label 'Coordinate Northing' ;
    rdfs:comment 'Northing coordinate (Y-axis) of the centroid or reference point of the measured earthwork area in the project coordinate system. Supports GIS (Geographic Information System) integration and spatial reporting.' ;
    rdfs:domain ind:EarthworkVolume ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cumulativeCutVolumeM3 rdf:type rdf:Property ;
    rdfs:label 'Cumulative Cut Volume M3' ;
    rdfs:comment 'Total cut volume measured from project commencement to the end of the current reporting period, in cubic metres (m³). Used for progress billing certificates and earned value management (EVM) calculations.' ;
    rdfs:domain ind:EarthworkVolume ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cumulativeFillVolumeM3 rdf:type rdf:Property ;
    rdfs:label 'Cumulative Fill Volume M3' ;
    rdfs:comment 'Total fill volume measured from project commencement to the end of the current reporting period, in cubic metres (m³). Used for progress billing certificates and earned value management (EVM) calculations.' ;
    rdfs:domain ind:EarthworkVolume ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cutVolumeM3 rdf:type rdf:Property ;
    rdfs:label 'Cut Volume M3' ;
    rdfs:comment 'Volume of material excavated or cut from the natural ground level, measured in cubic metres (m³). Used in earthworks progress billing, BOQ (Bill of Quantities) reconciliation, and subcontractor quantity verification.' ;
    rdfs:domain ind:EarthworkVolume ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:disposalDistanceKm rdf:type rdf:Property ;
    rdfs:label 'Disposal Distance Km' ;
    rdfs:comment 'Average haul distance in kilometres from the excavation area to the designated spoil disposal site. Used for mass haul cost estimation and subcontractor haulage billing verification.' ;
    rdfs:domain ind:EarthworkVolume ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:disposalSiteReference rdf:type rdf:Property ;
    rdfs:label 'Disposal Site Reference' ;
    rdfs:comment 'Identifier or name of the approved spoil disposal site where surplus or unsuitable excavated material is transported. Required for environmental compliance, EPA reporting, and spoil tracking under ISO 14001.' ;
    rdfs:domain ind:EarthworkVolume ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engineerApprovalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Engineer Approval Timestamp' ;
    rdfs:comment 'Date and time when the resident engineer or project engineer formally approved the earthwork volume measurement for inclusion in the progress payment certificate.' ;
    rdfs:domain ind:EarthworkVolume ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:fillVolumeM3 rdf:type rdf:Property ;
    rdfs:label 'Fill Volume M3' ;
    rdfs:comment 'Volume of material placed and compacted as fill to raise ground levels, measured in cubic metres (m³). Used in earthworks progress billing and subcontractor quantity verification.' ;
    rdfs:domain ind:EarthworkVolume ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:heavyjobCostCode rdf:type rdf:Property ;
    rdfs:label 'Heavyjob Cost Code' ;
    rdfs:comment 'Cost code from HCSS HeavyJob used to classify this earthwork production activity for job costing, production tracking, and earned value computation. Aligns field production data with financial cost control.' ;
    rdfs:domain ind:EarthworkVolume ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isVariationOrder rdf:type rdf:Property ;
    rdfs:label 'Is Variation Order' ;
    rdfs:comment 'Indicates whether this earthwork volume measurement relates to a Change Order (CO) / variation order outside the original contracted scope. When true, the measurement must be linked to an approved variation for billing purposes.' ;
    rdfs:domain ind:EarthworkVolume ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:materialClassification rdf:type rdf:Property ;
    rdfs:label 'Material Classification' ;
    rdfs:comment 'Classification of the earthwork material type being measured. Drives compaction factors, disposal requirements, and unit rates for progress billing. Common values: topsoil, clay, rock, sand, gravel, mixed. [ENUM-REF-CANDIDATE: topsoil|clay|rock|sand|gravel|mixed|silt|fill_material|contaminated — promote to reference product]' ;
    rdfs:domain ind:EarthworkVolume ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementAccuracyM rdf:type rdf:Property ;
    rdfs:label 'Measurement Accuracy M' ;
    rdfs:comment 'Stated positional accuracy of the survey measurement in metres, as reported by the survey instrument or method. Used to assess measurement reliability and compliance with project QA/QC (Quality Assurance/Quality Control) tolerances.' ;
    rdfs:domain ind:EarthworkVolume ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:measurementReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Measurement Reference Number' ;
    rdfs:comment 'Externally-known unique alphanumeric identifier assigned to this earthwork volume measurement record, used in field reports, progress billing certificates, and subcontractor payment applications.' ;
    rdfs:domain ind:EarthworkVolume ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netMovementM3 rdf:type rdf:Property ;
    rdfs:label 'Net Movement M3' ;
    rdfs:comment 'Net earthwork volume movement calculated as cut volume minus fill volume, measured in cubic metres (m³). A positive value indicates net cut (more excavation than fill); negative indicates net fill. Supports mass haul planning and earthworks balance analysis.' ;
    rdfs:domain ind:EarthworkVolume ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:spoilVolumeM3 rdf:type rdf:Property ;
    rdfs:label 'Spoil Volume M3' ;
    rdfs:comment 'Volume of excavated material classified as spoil (surplus or unsuitable material) that must be removed from site and disposed of, measured in cubic metres (m³). Drives disposal cost tracking and environmental compliance reporting.' ;
    rdfs:domain ind:EarthworkVolume ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:surveyInstrumentCode rdf:type rdf:Property ;
    rdfs:label 'Survey Instrument Code' ;
    rdfs:comment 'Identifier of the survey instrument or equipment (e.g., total station serial number, drone registration ID, GPS unit ID) used to conduct the measurement. Supports equipment calibration traceability and QA/QC compliance.' ;
    rdfs:domain ind:EarthworkVolume ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surveyMethod rdf:type rdf:Property ;
    rdfs:label 'Survey Method' ;
    rdfs:comment 'The technique used to measure earthwork volumes on site. Accepted values include GPS (Global Positioning System), drone photogrammetry, total station, LiDAR, manual survey, and cross-section method. Affects measurement accuracy and acceptance criteria. [ENUM-REF-CANDIDATE: GPS|drone_photogrammetry|total_station|LiDAR|manual_survey|cross_section|RTK_GPS|BIM_model_comparison — promote to reference product]' ;
    rdfs:domain ind:EarthworkVolume ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surveyorLicenseNumber rdf:type rdf:Property ;
    rdfs:label 'Surveyor License Number' ;
    rdfs:comment 'Professional license or registration number of the surveyor who conducted the measurement. Required for regulatory compliance and quality assurance sign-off validation.' ;
    rdfs:domain ind:EarthworkVolume ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surveyorSignoffTimestamp rdf:type rdf:Property ;
    rdfs:label 'Surveyor Signoff Timestamp' ;
    rdfs:comment 'Date and time when the surveyor formally signed off on the earthwork volume measurement, confirming the accuracy of recorded quantities. Critical for audit trail and payment certification.' ;
    rdfs:domain ind:EarthworkVolume ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:swellFactor rdf:type rdf:Property ;
    rdfs:label 'Swell Factor' ;
    rdfs:comment 'Dimensionless ratio representing the increase in volume of excavated material compared to its in-situ volume (bank measure). Used to calculate haul volumes and truck load quantities for mass haul planning.' ;
    rdfs:domain ind:EarthworkVolume ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:workAreaCode rdf:type rdf:Property ;
    rdfs:label 'Work Area Code' ;
    rdfs:comment 'Alphanumeric code identifying the defined site area or work front where the earthwork activity was performed. Aligns with site logistics zoning and HCSS HeavyJob cost coding.' ;
    rdfs:domain ind:EarthworkVolume ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equipmentDeploymentId rdf:type rdf:Property ;
    rdfs:label 'Equipment Deployment Id' ;
    rdfs:comment 'Unique surrogate identifier for each equipment deployment record in the site domain. Primary key for the equipment_deployment data product.' ;
    rdfs:domain ind:EquipmentDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hcssEquipmentHoursId rdf:type rdf:Property ;
    rdfs:label 'Hcss Equipment Hours Id' ;
    rdfs:comment 'The source system record identifier from HCSS HeavyJob equipment hours module. Used for data lineage, reconciliation, and incremental load processing from the operational system of record.' ;
    rdfs:domain ind:EquipmentDeployment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Hours .

ind:breakdownDescription rdf:type rdf:Property ;
    rdfs:label 'Breakdown Description' ;
    rdfs:comment 'Free-text description of the nature of the equipment breakdown or mechanical failure, as recorded by the site supervisor or equipment operator. Populated only when breakdown_flag is True.' ;
    rdfs:domain ind:EquipmentDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:breakdownFlag rdf:type rdf:Property ;
    rdfs:label 'Breakdown Flag' ;
    rdfs:comment 'Indicates whether the equipment experienced a mechanical breakdown or unplanned failure during this deployment period. True = breakdown occurred; False = no breakdown. Triggers maintenance workflow in SAP S/4HANA Plant Maintenance.' ;
    rdfs:domain ind:EquipmentDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:breakdownHours rdf:type rdf:Property ;
    rdfs:label 'Breakdown Hours' ;
    rdfs:comment 'Total number of hours the equipment was unavailable due to mechanical breakdown or unplanned maintenance during the shift or reporting period. Feeds into equipment reliability and maintenance KPI reporting.' ;
    rdfs:domain ind:EquipmentDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deploymentReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Deployment Reference Number' ;
    rdfs:comment 'Externally-known alphanumeric identifier for this equipment deployment record, as assigned in HCSS HeavyJob or the site daily log system. Used for cross-system traceability and field reporting.' ;
    rdfs:domain ind:EquipmentDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fuelType rdf:type rdf:Property ;
    rdfs:label 'Fuel Type' ;
    rdfs:comment 'Type of fuel consumed by the equipment. Used for environmental emissions reporting and fuel cost categorization.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hourlyRate rdf:type rdf:Property ;
    rdfs:label 'Hourly Rate' ;
    rdfs:comment 'The contracted or internal charge rate for the equipment per operating hour, in the project currency. Used for job costing and cost-to-complete calculations. Confidential as it reflects commercial pricing.' ;
    rdfs:domain ind:EquipmentDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hsePermitNumber rdf:type rdf:Property ;
    rdfs:label 'Hse Permit Number' ;
    rdfs:comment 'Reference number of the Permit to Work (PTW) or HSE permit associated with this equipment deployment, where required by site safety regulations (e.g., crane lifts, confined space operations). Links to the Intelex HSE management system.' ;
    rdfs:domain ind:EquipmentDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maintenanceOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Maintenance Order Number' ;
    rdfs:comment 'Reference number of the corrective maintenance work order raised in SAP S/4HANA Plant Maintenance as a result of a breakdown during this deployment. Links field breakdown events to the maintenance management system.' ;
    rdfs:domain ind:EquipmentDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatorLicenseNumber rdf:type rdf:Property ;
    rdfs:label 'Operator License Number' ;
    rdfs:comment 'The certification or license number of the equipment operator, required for regulated equipment types (e.g., crane operators, forklift operators). Supports OSHA and ISO 45001 compliance verification.' ;
    rdfs:domain ind:EquipmentDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedProductionQuantity rdf:type rdf:Property ;
    rdfs:label 'Planned Production Quantity' ;
    rdfs:comment 'The target or budgeted production quantity for the equipment during this shift or reporting period, as derived from the project schedule and production plan. Enables variance analysis against actual production.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:preStartCheckFlag rdf:type rdf:Property ;
    rdfs:label 'Pre Start Check Flag' ;
    rdfs:comment 'Indicates whether a pre-start safety inspection was completed for the equipment prior to commencement of operations on this shift. True = pre-start check completed; False = not completed. Required for ISO 45001 and OSHA compliance.' ;
    rdfs:domain ind:EquipmentDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rentalOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Rental Order Number' ;
    rdfs:comment 'The Purchase Order (PO) or rental agreement reference number for externally rented or leased equipment. Links the deployment record to the procurement and accounts payable process.' ;
    rdfs:domain ind:EquipmentDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteLocationDescription rdf:type rdf:Property ;
    rdfs:label 'Site Location Description' ;
    rdfs:comment 'Descriptive reference to the physical location on site where the equipment is deployed (e.g., \'Zone A — North Embankment\', \'Pier 3 Foundation\', \'Runway 2 Subbase\'). Supports spatial tracking and site logistics management.' ;
    rdfs:domain ind:EquipmentDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fieldProgressId rdf:type rdf:Property ;
    rdfs:label 'Field Progress Id' ;
    rdfs:comment 'Unique surrogate identifier for each field progress measurement record in the silver layer lakehouse. Primary key for the field_progress data product.' ;
    rdfs:domain ind:FieldProgress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:productionEntryId rdf:type rdf:Property ;
    rdfs:label 'Production Entry Id' ;
    rdfs:comment 'The source system identifier of the HCSS HeavyJob production tracking record associated with this field progress measurement. Enables reconciliation between field production data and cost coding in HeavyJob.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProductionEntry .

ind:wbsActivityId rdf:type rdf:Property ;
    rdfs:label 'Wbs Activity Id' ;
    rdfs:comment 'Reference to the WBS activity or schedule activity in Oracle Primavera P6 against which this field progress measurement is recorded. Links field measurement to the schedule domain for EVM computation.' ;
    rdfs:domain ind:FieldProgress ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Activity .

ind:bimElementReference rdf:type rdf:Property ;
    rdfs:label 'Bim Element Reference' ;
    rdfs:comment 'The BIM (Building Information Modeling) element or object identifier from Autodesk BIM 360 corresponding to the physical work being measured. Enables 4D BIM progress visualization by linking field measurements to the 3D model.' ;
    rdfs:domain ind:FieldProgress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equipmentHours rdf:type rdf:Property ;
    rdfs:label 'Equipment Hours' ;
    rdfs:comment 'Total equipment operating hours logged against this activity during the measurement period. Sourced from HCSS HeavyJob equipment hour tracking. Used for equipment productivity analysis and cost-to-progress reconciliation.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fieldEngineerName rdf:type rdf:Property ;
    rdfs:label 'Field Engineer Name' ;
    rdfs:comment 'Full name of the field engineer or site engineer who physically performed and recorded the progress measurement. Provides accountability and traceability for the measurement. Classified as confidential PII as it identifies an individual employee.' ;
    rdfs:domain ind:FieldProgress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementNotes rdf:type rdf:Property ;
    rdfs:label 'Measurement Notes' ;
    rdfs:comment 'Free-text field for the field engineer to record observations, constraints, or qualifications relevant to the progress measurement (e.g., partial pour due to rain, access restriction, rework in progress). Supports contextual interpretation of progress data.' ;
    rdfs:domain ind:FieldProgress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementPeriodType rdf:type rdf:Property ;
    rdfs:label 'Measurement Period Type' ;
    rdfs:comment 'The reporting frequency or period type for this progress measurement (e.g., daily, weekly, monthly). Determines how the measurement aligns with project reporting cycles and EVM period cut-offs in Oracle Primavera P6.' ;
    rdfs:domain ind:FieldProgress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:progressDelta rdf:type rdf:Property ;
    rdfs:label 'Progress Delta' ;
    rdfs:comment 'The incremental percent complete gained in this measurement period, calculated as reported_percent_complete minus previous_percent_complete. Represents the period productivity for the activity and is used in period-based EVM reporting.' ;
    rdfs:domain ind:FieldProgress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reportedPercentComplete rdf:type rdf:Property ;
    rdfs:label 'Reported Percent Complete' ;
    rdfs:comment 'The cumulative percent complete for the WBS activity or BOQ line item as physically measured and reported by the field engineer at the time of this measurement. Expressed as a percentage (0.00–100.00). This is the ground-truth value used to compute BCWP in EVM.' ;
    rdfs:domain ind:FieldProgress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:liftPlanId rdf:type rdf:Property ;
    rdfs:label 'Lift Plan Id' ;
    rdfs:comment 'Unique system-generated identifier for the engineered lift plan record. Primary key for the lift_plan data product in the site domain.' ;
    rdfs:domain ind:LiftPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:craneOperatorCraftWorkerId rdf:type rdf:Property ;
    rdfs:label 'Crane Operator Craft Worker Id' ;
    rdfs:comment 'Foreign key linking to workforce.craft_worker. Business justification: REQUIRED: Crane operators are skilled craft workers; linking enables equipment-operator assignment, certification tracking and labor cost allocation.' ;
    rdfs:domain ind:LiftPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CraftWorker .

ind:primaryLiftEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Lift Employee Id' ;
    rdfs:comment 'Reference to the workforce record of the appointed person responsible for the lift plan. Used to verify competency certification and training records.' ;
    rdfs:domain ind:LiftPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:quaternaryLiftApprovedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Quaternary Lift Approved By Employee Id' ;
    rdfs:comment 'Reference to the workforce record of the authorising manager or HSE officer who approved the lift plan. Required before permit-to-lift can be issued.' ;
    rdfs:domain ind:LiftPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryLiftRiggerInChargeEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Lift Rigger In Charge Employee Id' ;
    rdfs:comment 'Reference to the workforce record of the qualified rigger-in-charge responsible for rigging the load and directing the lift operation.' ;
    rdfs:domain ind:LiftPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:appointedPersonName rdf:type rdf:Property ;
    rdfs:label 'Appointed Person Name' ;
    rdfs:comment 'Full name of the appointed person (lift supervisor or lift director) who is responsible for planning and supervising the crane lift operation. Required under ASME P30.1 and OSHA regulations.' ;
    rdfs:domain ind:LiftPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:boomLengthM rdf:type rdf:Property ;
    rdfs:label 'Boom Length M' ;
    rdfs:comment 'Configured boom length in metres used for the lift operation. Together with lift radius, determines the applicable rated capacity from the manufacturer load chart.' ;
    rdfs:domain ind:LiftPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capacityUtilisationPct rdf:type rdf:Property ;
    rdfs:label 'Capacity Utilisation Pct' ;
    rdfs:comment 'Percentage of the crane rated capacity utilised by the planned load weight at the specified radius and boom configuration. Lifts exceeding 75% trigger critical lift classification per ASME P30.1.' ;
    rdfs:domain ind:LiftPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:craneMake rdf:type rdf:Property ;
    rdfs:label 'Crane Make' ;
    rdfs:comment 'Manufacturer name of the crane equipment (e.g., Liebherr, Manitowoc, Terex). Used for load chart reference and manufacturer-specific operating procedures.' ;
    rdfs:domain ind:LiftPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:craneModel rdf:type rdf:Property ;
    rdfs:label 'Crane Model' ;
    rdfs:comment 'Model designation of the crane equipment as specified by the manufacturer. Required for load chart identification and rated capacity verification.' ;
    rdfs:domain ind:LiftPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:craneRatedCapacityT rdf:type rdf:Property ;
    rdfs:label 'Crane Rated Capacity T' ;
    rdfs:comment 'Maximum rated lifting capacity of the crane in metric tonnes as specified in the manufacturer load chart for the configured boom length and radius. Basis for critical lift classification.' ;
    rdfs:domain ind:LiftPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:craneType rdf:type rdf:Property ;
    rdfs:label 'Crane Type' ;
    rdfs:comment 'Classification of the crane equipment to be used for the lift operation. Determines applicable ASME B30 volume and OSHA regulatory requirements. [ENUM-REF-CANDIDATE: mobile_crawler|mobile_rough_terrain|mobile_all_terrain|tower_luffing|tower_hammerhead|overhead_bridge|gantry|derrick|knuckle_boom — promote to reference product]' ;
    rdfs:domain ind:LiftPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exclusionZoneRadiusM rdf:type rdf:Property ;
    rdfs:label 'Exclusion Zone Radius M' ;
    rdfs:comment 'Radius in metres of the exclusion zone to be established around the crane and lift area during the operation. No unauthorised personnel permitted within this zone during the lift.' ;
    rdfs:domain ind:LiftPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:groundBearingCapacityKpa rdf:type rdf:Property ;
    rdfs:label 'Ground Bearing Capacity Kpa' ;
    rdfs:comment 'Allowable ground bearing capacity in kilopascals at the crane setup location as determined by geotechnical investigation or site assessment. Must exceed the calculated ground bearing pressure.' ;
    rdfs:domain ind:LiftPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:groundBearingPressureKpa rdf:type rdf:Property ;
    rdfs:label 'Ground Bearing Pressure Kpa' ;
    rdfs:comment 'Calculated ground bearing pressure in kilopascals at the crane outrigger or crawler pad positions. Must be verified against site geotechnical data to confirm ground stability for the lift.' ;
    rdfs:domain ind:LiftPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hookHeightM rdf:type rdf:Property ;
    rdfs:label 'Hook Height M' ;
    rdfs:comment 'Maximum hook height in metres above ground level required for the lift operation. Used to verify clearance from overhead obstructions, power lines, and structures.' ;
    rdfs:domain ind:LiftPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:liftDate rdf:type rdf:Property ;
    rdfs:label 'Lift Date' ;
    rdfs:comment 'Scheduled or actual calendar date on which the crane lift operation is planned to be executed. Used for permit-to-lift validity and site scheduling.' ;
    rdfs:domain ind:LiftPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:liftDescription rdf:type rdf:Property ;
    rdfs:label 'Lift Description' ;
    rdfs:comment 'Narrative description of the lift operation including the nature of the load, purpose of the lift, and any special conditions or constraints relevant to the engineered lift plan.' ;
    rdfs:domain ind:LiftPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:liftDrawingReference rdf:type rdf:Property ;
    rdfs:label 'Lift Drawing Reference' ;
    rdfs:comment 'Document reference number for the engineered lift plan drawing showing crane position, load path, pick and set points, exclusion zone, and rigging arrangement. Stored in Aconex or Autodesk BIM 360.' ;
    rdfs:domain ind:LiftPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:liftEndTime rdf:type rdf:Property ;
    rdfs:label 'Lift End Time' ;
    rdfs:comment 'Planned or actual date and time when the crane lift operation is completed and the exclusion zone is released. Used for permit-to-lift closure.' ;
    rdfs:domain ind:LiftPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:liftRadiusM rdf:type rdf:Property ;
    rdfs:label 'Lift Radius M' ;
    rdfs:comment 'Horizontal distance in metres from the crane centreline of rotation to the centre of the load at the pick point. Determines rated capacity from the manufacturer load chart.' ;
    rdfs:domain ind:LiftPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:liftStartTime rdf:type rdf:Property ;
    rdfs:label 'Lift Start Time' ;
    rdfs:comment 'Planned or actual date and time when the crane lift operation commences. Used for shift scheduling, exclusion zone activation, and permit-to-lift window management.' ;
    rdfs:domain ind:LiftPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:liftType rdf:type rdf:Property ;
    rdfs:label 'Lift Type' ;
    rdfs:comment 'Classification of the lift operation per ASME B30 and OSHA criteria. Critical lifts involve loads exceeding 75% of crane rated capacity or lifts over energised equipment. Complex lifts involve multiple cranes or unusual conditions. [ENUM-REF-CANDIDATE: routine|critical|complex|tandem|blind — promote to reference product if additional types are required]' ;
    rdfs:domain ind:LiftPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loadWeightT rdf:type rdf:Property ;
    rdfs:label 'Load Weight T' ;
    rdfs:comment 'Total weight of the load to be lifted in metric tonnes, including the load itself, rigging hardware, spreader bars, and any attached accessories. Used to calculate percentage of rated capacity.' ;
    rdfs:domain ind:LiftPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:methodStatementReference rdf:type rdf:Property ;
    rdfs:label 'Method Statement Reference' ;
    rdfs:comment 'Document reference number for the Safe Work Method Statement (SWMS) associated with this lift plan. The SWMS details the step-by-step safe work procedure for the crane operation.' ;
    rdfs:domain ind:LiftPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outriggerMatRequired rdf:type rdf:Property ;
    rdfs:label 'Outrigger Mat Required' ;
    rdfs:comment 'Indicates whether crane outrigger mats or cribbing are required to distribute ground bearing pressure to within the allowable site capacity. Mandatory field for mobile crane setups.' ;
    rdfs:domain ind:LiftPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:overheadObstructionPresent rdf:type rdf:Property ;
    rdfs:label 'Overhead Obstruction Present' ;
    rdfs:comment 'Indicates whether overhead obstructions such as power lines, structures, or other cranes are present within the lift envelope. Triggers additional clearance assessment and OSHA power line safety requirements.' ;
    rdfs:domain ind:LiftPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:permitToLiftNumber rdf:type rdf:Property ;
    rdfs:label 'Permit To Lift Number' ;
    rdfs:comment 'Reference number of the permit-to-lift issued under the site HSE permit-to-work system. The permit-to-lift must be active and valid before the crane operation commences.' ;
    rdfs:domain ind:LiftPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pickPointDescription rdf:type rdf:Property ;
    rdfs:label 'Pick Point Description' ;
    rdfs:comment 'Description of the load pick-up location including grid reference, elevation, and any access or ground condition constraints at the pick point.' ;
    rdfs:domain ind:LiftPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:powerLineClearanceM rdf:type rdf:Property ;
    rdfs:label 'Power Line Clearance M' ;
    rdfs:comment 'Minimum clearance distance in metres between the crane boom, load line, or load and the nearest energised power line. Null if no power lines are present in the lift envelope.' ;
    rdfs:domain ind:LiftPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:procoreLiftPlanReference rdf:type rdf:Property ;
    rdfs:label 'Procore Lift Plan Reference' ;
    rdfs:comment 'External reference identifier for this lift plan record in the Procore construction management system. Used for cross-system traceability between the lakehouse silver layer and the operational source system.' ;
    rdfs:domain ind:LiftPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riggingConfiguration rdf:type rdf:Property ;
    rdfs:label 'Rigging Configuration' ;
    rdfs:comment 'Description of the rigging arrangement including sling type, number of legs, sling angle, shackle sizes, spreader bar details, and attachment points. Must be engineered for the specific load.' ;
    rdfs:domain ind:LiftPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:setPointDescription rdf:type rdf:Property ;
    rdfs:label 'Set Point Description' ;
    rdfs:comment 'Description of the load set-down or installation location including grid reference, elevation, and any structural or access constraints at the set point.' ;
    rdfs:domain ind:LiftPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slingType rdf:type rdf:Property ;
    rdfs:label 'Sling Type' ;
    rdfs:comment 'Primary sling type used in the rigging configuration. Determines applicable ASME B30 volume for inspection and working load limit requirements.' ;
    rdfs:domain ind:LiftPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:windSpeedLimitKmh rdf:type rdf:Property ;
    rdfs:label 'Wind Speed Limit Kmh' ;
    rdfs:comment 'Maximum allowable wind speed in kilometres per hour at which the lift operation may proceed, as specified in the crane manufacturer operating manual and lift plan engineering assessment.' ;
    rdfs:domain ind:LiftPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:materialDeliveryId rdf:type rdf:Property ;
    rdfs:label 'Material Delivery Id' ;
    rdfs:comment 'Unique surrogate identifier for each material delivery receipt event recorded at the construction site. Primary key for this entity. Role: TRANSACTION_HEADER.' ;
    rdfs:domain ind:MaterialDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryMaterialVendorId rdf:type rdf:Property ;
    rdfs:label 'Primary Material Vendor Id' ;
    rdfs:comment 'Reference to the supplier or vendor who delivered the materials. Links to the procurement domain supplier master for vendor performance tracking.' ;
    rdfs:domain ind:MaterialDelivery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vendor .

ind:receiverEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Receiver Employee Id' ;
    rdfs:comment 'Reference to the employee record of the site personnel who received and signed off on the delivery. Links to the workforce domain for accountability and audit trail purposes.' ;
    rdfs:domain ind:MaterialDelivery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:deliveryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Delivery Timestamp' ;
    rdfs:comment 'The precise date and time at which the delivery vehicle arrived at the site gate or laydown area. Supports site logistics scheduling, gate management, and time-stamped audit trails.' ;
    rdfs:domain ind:MaterialDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:deliveryValue rdf:type rdf:Property ;
    rdfs:label 'Delivery Value' ;
    rdfs:comment 'The total monetary value of the accepted delivery, calculated as quantity_accepted multiplied by unit_rate. Used for goods receipt posting, cost accrual, and three-way matching against the supplier invoice. Expressed in the project currency.' ;
    rdfs:domain ind:MaterialDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:discrepancyNotes rdf:type rdf:Property ;
    rdfs:label 'Discrepancy Notes' ;
    rdfs:comment 'Free-text field capturing details of any discrepancy identified at the point of receipt, including quantity shortfalls, damage descriptions, specification mismatches, or incorrect materials. Used to support NCR (Non-Conformance Report) creation and supplier claims.' ;
    rdfs:domain ind:MaterialDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:docketNumber rdf:type rdf:Property ;
    rdfs:label 'Docket Number' ;
    rdfs:comment 'The externally-issued delivery docket or delivery note number provided by the supplier on the physical delivery documentation. Used as the primary business identifier for the delivery event and for three-way matching against the PO and invoice.' ;
    rdfs:domain ind:MaterialDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:driverName rdf:type rdf:Property ;
    rdfs:label 'Driver Name' ;
    rdfs:comment 'The name of the delivery driver as recorded on the delivery docket or site gate register. Captured for site security, access control, and delivery audit trail purposes.' ;
    rdfs:domain ind:MaterialDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazardousMaterial rdf:type rdf:Property ;
    rdfs:label 'Hazardous Material' ;
    rdfs:comment 'Indicates whether the delivered material is classified as hazardous under applicable regulations (e.g., chemicals, solvents, fuels, asbestos-containing materials). When True, triggers HSE compliance protocols including MSDS verification and segregated storage.' ;
    rdfs:domain ind:MaterialDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:laydownZone rdf:type rdf:Property ;
    rdfs:label 'Laydown Zone' ;
    rdfs:comment 'The designated receiving location or laydown area on the site logistics plan where the delivered material was stored upon receipt (e.g., \'Zone A - Steel Yard\', \'Zone C - Concrete Batching Area\'). Supports site logistics management and material traceability.' ;
    rdfs:domain ind:MaterialDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:msdsVerified rdf:type rdf:Property ;
    rdfs:label 'Msds Verified' ;
    rdfs:comment 'Indicates whether the Material Safety Data Sheet (MSDS) or Safety Data Sheet (SDS) was verified and on file at the time of receipt for hazardous materials. Required for OSHA HazCom compliance and site HSE management.' ;
    rdfs:domain ind:MaterialDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:poLineNumber rdf:type rdf:Property ;
    rdfs:label 'Po Line Number' ;
    rdfs:comment 'The specific line item number on the Purchase Order (PO) to which this delivery relates. Enables precise three-way matching at the line level between the PO, goods receipt, and supplier invoice.' ;
    rdfs:domain ind:MaterialDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityAccepted rdf:type rdf:Property ;
    rdfs:label 'Quantity Accepted' ;
    rdfs:comment 'The quantity of material formally accepted after inspection at the point of receipt. May be less than quantity_delivered in cases of partial acceptance due to damage, non-conformance, or specification mismatch. Triggers stock update in the materials domain.' ;
    rdfs:domain ind:MaterialDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityDelivered rdf:type rdf:Property ;
    rdfs:label 'Quantity Delivered' ;
    rdfs:comment 'The actual quantity of material physically received at the site as measured or counted at the point of receipt. This is the principal quantitative fact for the delivery event and is used to update material stock records and reconcile against the PO quantity.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityOrdered rdf:type rdf:Property ;
    rdfs:label 'Quantity Ordered' ;
    rdfs:comment 'The quantity of material that was ordered on the associated Purchase Order (PO) line for this delivery. Enables immediate over/under delivery variance calculation at the point of receipt without requiring a join to the procurement domain.' ;
    rdfs:domain ind:MaterialDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityRejected rdf:type rdf:Property ;
    rdfs:label 'Quantity Rejected' ;
    rdfs:comment 'The quantity of material rejected at the point of receipt due to damage, non-conformance with specification, or incorrect material. Triggers a Non-Conformance Report (NCR) and return-to-supplier process.' ;
    rdfs:domain ind:MaterialDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:receivingInspector rdf:type rdf:Property ;
    rdfs:label 'Receiving Inspector' ;
    rdfs:comment 'The full name of the site personnel who physically received and inspected the delivery at the site gate or laydown area. This individual is accountable for the acceptance/rejection decision recorded on the delivery docket.' ;
    rdfs:domain ind:MaterialDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureSensitive rdf:type rdf:Property ;
    rdfs:label 'Temperature Sensitive' ;
    rdfs:comment 'Indicates whether the delivered material requires temperature-controlled storage conditions (e.g., epoxy resins, certain adhesives, bituminous products, or cold-chain materials). When True, triggers special handling and storage protocols on site.' ;
    rdfs:domain ind:MaterialDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:vehicleRegistration rdf:type rdf:Property ;
    rdfs:label 'Vehicle Registration' ;
    rdfs:comment 'The registration plate number of the delivery vehicle. Recorded at the site gate for security, access control, and logistics tracking purposes.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:foremanEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Foreman Employee Id' ;
    rdfs:comment 'Foreign key linking to hr.employee. Business justification: Production entry must record the foreman responsible for the work; required for safety audit and accountability in daily production reports.' ;
    rdfs:domain ind:ProductionEntry ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:budgetedProductionRate rdf:type rdf:Property ;
    rdfs:label 'Budgeted Production Rate' ;
    rdfs:comment 'The planned or budgeted production rate for this activity and cost code expressed as units per labor-hour. Sourced from the project estimate and HCSS HeavyJob budget. Used to compute production efficiency variance against actual production_rate.' ;
    rdfs:domain ind:ProductionEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cumulativeQuantity rdf:type rdf:Property ;
    rdfs:label 'Cumulative Quantity' ;
    rdfs:comment 'The total quantity of work installed to date for this activity and cost code, inclusive of the current entry. Represents the running total used for percent complete and progress billing milestone verification.' ;
    rdfs:domain ind:ProductionEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:entryDate rdf:type rdf:Property ;
    rdfs:label 'Entry Date' ;
    rdfs:comment 'The calendar date on which the production quantities were recorded. Represents the actual field execution date, not the data entry date. Core dimension for daily progress reporting and schedule performance analysis.' ;
    rdfs:domain ind:ProductionEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:entryNumber rdf:type rdf:Property ;
    rdfs:label 'Entry Number' ;
    rdfs:comment 'Externally-known alphanumeric identifier for this production entry as assigned by the source system (HCSS HeavyJob). Used for cross-system traceability and field reference. Format: PE-[YYYYMMDD]-[SEQ].' ;
    rdfs:domain ind:ProductionEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isBaselineRevision rdf:type rdf:Property ;
    rdfs:label 'Is Baseline Revision' ;
    rdfs:comment 'Indicates whether this production entry reflects a revision to the baseline budgeted quantity due to an approved Change Order (CO) or scope change. When true, the budgeted_quantity reflects the revised baseline.' ;
    rdfs:domain ind:ProductionEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRework rdf:type rdf:Property ;
    rdfs:label 'Is Rework' ;
    rdfs:comment 'Indicates whether this production entry represents rework (corrective re-execution of previously completed work) rather than new production. Rework quantities are tracked separately for quality cost analysis and NCR (Non-Conformance Report) linkage.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:productionRate rdf:type rdf:Property ;
    rdfs:label 'Production Rate' ;
    rdfs:comment 'The measured production rate for this entry expressed as units of work completed per labor-hour (e.g., CY/hr, LF/hr). Calculated from installed_quantity divided by total labor hours. Used for productivity benchmarking, crew efficiency analysis, and future bid estimation.' ;
    rdfs:domain ind:ProductionEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:productionType rdf:type rdf:Property ;
    rdfs:label 'Production Type' ;
    rdfs:comment 'Classification of the type of construction production activity being tracked. Enables domain-specific productivity benchmarking and reporting across earthworks, concrete, structural, MEP (Mechanical Electrical and Plumbing), and other work categories. [ENUM-REF-CANDIDATE: earthworks|concrete|structural_steel|paving|MEP|formwork|rebar|masonry|finishing|demolition|other — promote to reference product]' ;
    rdfs:domain ind:ProductionEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureC rdf:type rdf:Property ;
    rdfs:label 'Temperature C' ;
    rdfs:comment 'Recorded ambient temperature in degrees Celsius at the work front on the entry date. Used to assess weather-related productivity impacts, validate concrete pour conditions per ACI standards, and support EOT (Extension of Time) claims.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:workFrontLocation rdf:type rdf:Property ;
    rdfs:label 'Work Front Location' ;
    rdfs:comment 'Descriptive location identifier for the work front or zone where production was executed (e.g., \'Zone A — Grid 1-5\', \'Pier 3 Foundation\', \'Runway 2 Subbase\'). Supports spatial analysis and site logistics planning.' ;
    rdfs:domain ind:ProductionEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workItemDescription rdf:type rdf:Property ;
    rdfs:label 'Work Item Description' ;
    rdfs:comment 'Human-readable description of the specific work item or scope of work being tracked in this production entry (e.g., \'Concrete pour — Column Grid A1-A5\', \'Earthworks cut — Zone 3\'). Sourced from BOQ (Bill of Quantities) or activity description.' ;
    rdfs:domain ind:ProductionEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shiftReportId rdf:type rdf:Property ;
    rdfs:label 'Shift Report Id' ;
    rdfs:comment 'Unique system-generated identifier for the shift report record. Primary key for the shift_report data product in the site domain. Entity role: TRANSACTION_HEADER.' ;
    rdfs:domain ind:ShiftReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:activitiesNarrative rdf:type rdf:Property ;
    rdfs:label 'Activities Narrative' ;
    rdfs:comment 'Free-text description of the principal work activities performed during the shift, including scope completed, methods used, and notable observations. Sourced from HCSS HeavyJob field notes and Procore daily log entries.' ;
    rdfs:domain ind:ShiftReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:delayCause rdf:type rdf:Property ;
    rdfs:label 'Delay Cause' ;
    rdfs:comment 'Primary cause category for any delay experienced during the shift. Supports EOT claim substantiation, delay analysis, and root cause reporting. [ENUM-REF-CANDIDATE: weather|equipment_breakdown|material_shortage|access_restriction|design_change|labour_shortage|utility_conflict|other — promote to reference product]' ;
    rdfs:domain ind:ShiftReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:delayDurationHrs rdf:type rdf:Property ;
    rdfs:label 'Delay Duration Hrs' ;
    rdfs:comment 'Total hours of productive time lost during the shift due to delays (weather, equipment breakdown, material shortage, access restrictions, etc.). Used for Extension of Time (EOT) claims, Liquidated Damages (LD) assessment, and schedule impact analysis.' ;
    rdfs:domain ind:ShiftReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:equipmentUtilisationPct rdf:type rdf:Property ;
    rdfs:label 'Equipment Utilisation Pct' ;
    rdfs:comment 'Percentage of deployed equipment that was actively productive during the shift, calculated as productive equipment hours divided by total available equipment hours multiplied by 100. Key indicator for plant efficiency and idle cost identification.' ;
    rdfs:domain ind:ShiftReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:handoverNotes rdf:type rdf:Property ;
    rdfs:label 'Handover Notes' ;
    rdfs:comment 'Free-text notes prepared by the outgoing shift supervisor for the incoming shift team. Covers outstanding work, active risks, equipment status, pending permits, and critical instructions. Essential for 24-hour continuous operations continuity.' ;
    rdfs:domain ind:ShiftReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hcssShiftReference rdf:type rdf:Property ;
    rdfs:label 'Hcss Shift Reference' ;
    rdfs:comment 'Source system reference identifier from HCSS HeavyJob for this shift record. Enables bi-directional traceability between the lakehouse silver layer and the operational field management system for reconciliation and audit.' ;
    rdfs:domain ind:ShiftReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentCount rdf:type rdf:Property ;
    rdfs:label 'Incident Count' ;
    rdfs:comment 'Number of safety incidents (near misses, first aid, recordable, or Lost Time Injuries) that occurred during the shift. Distinct from safety observations. Triggers mandatory reporting to Intelex and regulatory notification under OSHA/ISO 45001.' ;
    rdfs:domain ind:ShiftReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:issuesCount rdf:type rdf:Property ;
    rdfs:label 'Issues Count' ;
    rdfs:comment 'Total number of open issues, constraints, or blockers identified during the shift that require resolution before or during the next shift. Drives issue escalation workflows and handover briefings.' ;
    rdfs:domain ind:ShiftReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ltiFlag rdf:type rdf:Property ;
    rdfs:label 'Lti Flag' ;
    rdfs:comment 'Indicates whether a Lost Time Injury (LTI) occurred during this shift. An LTI is a work-related injury or illness resulting in the worker being unable to return to work on the next scheduled shift. Triggers mandatory regulatory reporting and executive escalation.' ;
    rdfs:domain ind:ShiftReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:productionUnit rdf:type rdf:Property ;
    rdfs:label 'Production Unit' ;
    rdfs:comment 'Unit of measure for the production_quantity field (e.g., m3 for earthworks or concrete, lm for linear metres of pipeline, tonne for bulk materials). Ensures dimensional consistency for productivity benchmarking and earned value calculations. [ENUM-REF-CANDIDATE: m3|m2|lm|tonne|each|kg|m|hr — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportNumber rdf:type rdf:Property ;
    rdfs:label 'Report Number' ;
    rdfs:comment 'Externally-known alphanumeric identifier for the shift report, typically formatted as SR-[ProjectCode]-[Year]-[Sequence]. Used for document control, correspondence, and cross-system referencing in Procore and Aconex.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportStatus rdf:type rdf:Property ;
    rdfs:label 'Report Status' ;
    rdfs:comment 'Current workflow lifecycle state of the shift report. Tracks progression from field data entry (draft) through supervisor submission, review, and formal approval. Drives downstream integration with daily log consolidation.' ;
    rdfs:domain ind:ShiftReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyObservationCount rdf:type rdf:Property ;
    rdfs:label 'Safety Observation Count' ;
    rdfs:comment 'Number of HSE safety observations (positive or negative) recorded during the shift. Feeds into TRIR (Total Recordable Incident Rate) trending and Intelex HSE management reporting.' ;
    rdfs:domain ind:ShiftReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:shiftEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Shift End Timestamp' ;
    rdfs:comment 'Actual date and time when the shift concluded on site. Combined with shift_start_timestamp to derive total shift duration and labor hours. Null if shift is still in progress.' ;
    rdfs:domain ind:ShiftReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:shiftStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Shift Start Timestamp' ;
    rdfs:comment 'Actual date and time when the shift commenced on site. Principal business event timestamp for the shift lifecycle. Used for labor hour calculation, schedule adherence, and overtime analysis.' ;
    rdfs:domain ind:ShiftReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:supervisorSignOffTimestamp rdf:type rdf:Property ;
    rdfs:label 'Supervisor Sign Off Timestamp' ;
    rdfs:comment 'Date and time when the shift supervisor formally signed off and submitted the shift report. Marks the transition from draft to submitted status and initiates the review and approval workflow.' ;
    rdfs:domain ind:ShiftReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:totalHeadcount rdf:type rdf:Property ;
    rdfs:label 'Total Headcount' ;
    rdfs:comment 'Total number of all personnel on site during the shift, including direct labour, subcontractors, supervisors, and visitors. Used for site access control, emergency muster, and HSE compliance reporting.' ;
    rdfs:domain ind:ShiftReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalLabourHours rdf:type rdf:Property ;
    rdfs:label 'Total Labour Hours' ;
    rdfs:comment 'Total man-hours worked across all crew members during the shift, including direct labour and subcontractor labour. Core input for earned value management (EVM) cost performance index (CPI) calculations and labour productivity analysis.' ;
    rdfs:domain ind:ShiftReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:instructionId rdf:type rdf:Property ;
    rdfs:label 'Instruction Id' ;
    rdfs:comment 'Unique surrogate identifier for the site instruction record in the silver layer lakehouse. Primary key for this entity.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Instruction .

ind:issuingAuthorityCraftWorkerId rdf:type rdf:Property ;
    rdfs:label 'Issuing Authority Craft Worker Id' ;
    rdfs:comment 'Foreign key linking to workforce.craft_worker. Business justification: REQUIRED: Site instructions must be issued by a responsible craft worker (foreman/supervisor); FK provides accountability and audit trail for instruction enforcement.' ;
    rdfs:domain ind:Instruction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CraftWorker .

ind:issuingAuthorityEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Issuing Authority Employee Id' ;
    rdfs:comment 'Foreign key linking to hr.employee. Business justification: Internal site instructions are issued by a designated employee; linking records the issuer for traceability and compliance.' ;
    rdfs:domain ind:Instruction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:aconexMailReference rdf:type rdf:Property ;
    rdfs:label 'Aconex Mail Reference' ;
    rdfs:comment 'Reference number of the formal correspondence or transmittal in the Aconex Document Management system through which this site instruction was officially transmitted to the contractor.' ;
    rdfs:domain ind:Instruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedDrawingReference rdf:type rdf:Property ;
    rdfs:label 'Affected Drawing Reference' ;
    rdfs:comment 'Reference number(s) of the engineering drawings or BIM model elements affected by this site instruction, enabling traceability to design documents and supporting RFI and submittal processes.' ;
    rdfs:domain ind:Instruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedWbsCode rdf:type rdf:Property ;
    rdfs:label 'Affected Wbs Code' ;
    rdfs:comment 'Work Breakdown Structure (WBS) code identifying the specific work package or activity affected by this site instruction. Enables cost and schedule impact traceability within the project control framework.' ;
    rdfs:domain ind:Instruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractorAcknowledgmentDate rdf:type rdf:Property ;
    rdfs:label 'Contractor Acknowledgment Date' ;
    rdfs:comment 'Date on which the contractor formally acknowledged receipt of the site instruction. Contractually significant as it starts the clock for contractor response obligations and EOT notice periods under FIDIC.' ;
    rdfs:domain ind:Instruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contractorDisputeFlag rdf:type rdf:Property ;
    rdfs:label 'Contractor Dispute Flag' ;
    rdfs:comment 'Indicates whether the contractor has formally disputed the validity, scope, or commercial basis of this site instruction, triggering the contract dispute resolution process.' ;
    rdfs:domain ind:Instruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contractorResponseDate rdf:type rdf:Property ;
    rdfs:label 'Contractor Response Date' ;
    rdfs:comment 'Actual date on which the contractor submitted their formal response or cost/time claim in relation to this site instruction. Used to assess compliance with contractual response obligations.' ;
    rdfs:domain ind:Instruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contractorResponseDueDate rdf:type rdf:Property ;
    rdfs:label 'Contractor Response Due Date' ;
    rdfs:comment 'Contractually required date by which the contractor must submit a formal response, cost estimate, or notice of claim in relation to this site instruction, calculated from the acknowledgment date per contract conditions.' ;
    rdfs:domain ind:Instruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:estimatedTimeImpactDays rdf:type rdf:Property ;
    rdfs:label 'Estimated Time Impact Days' ;
    rdfs:comment 'Preliminary estimate of the number of calendar days by which this site instruction may extend the contract completion date, used for Extension of Time (EOT) assessment and CPM schedule analysis.' ;
    rdfs:domain ind:Instruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hseImplicationFlag rdf:type rdf:Property ;
    rdfs:label 'Hse Implication Flag' ;
    rdfs:comment 'Indicates whether this site instruction has Health, Safety, and Environment (HSE) implications requiring a Safe Work Method Statement (SWMS) update, permit to work review, or HSE authority notification before execution.' ;
    rdfs:domain ind:Instruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:instructionDescription rdf:type rdf:Property ;
    rdfs:label 'Instruction Description' ;
    rdfs:comment 'Full narrative description of the work, method change, or site condition to be addressed as directed by the issuing authority. This is the primary contractual content of the instruction.' ;
    rdfs:domain ind:Instruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:instructionNumber rdf:type rdf:Property ;
    rdfs:label 'Instruction Number' ;
    rdfs:comment 'Externally-known alphanumeric reference number assigned to the site instruction by the issuing authority. Used for correspondence, filing, and cross-referencing with contract documents and RFIs. Format: SI-[ProjectCode]-[SequenceNumber].' ;
    rdfs:domain ind:Instruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:instructionStatus rdf:type rdf:Property ;
    rdfs:label 'Instruction Status' ;
    rdfs:comment 'Current workflow lifecycle status of the site instruction from issuance through contractor acknowledgment to implementation and closure. [ENUM-REF-CANDIDATE: draft|issued|acknowledged|under_review|implemented|closed|disputed|cancelled — promote to reference product]' ;
    rdfs:domain ind:Instruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:instructionType rdf:type rdf:Property ;
    rdfs:label 'Instruction Type' ;
    rdfs:comment 'Classification of the nature and purpose of the site instruction, determining the downstream contractual and commercial treatment. [ENUM-REF-CANDIDATE: variation_order|method_change|safety_directive|quality_directive|access_instruction|suspension|acceleration|remedial_work — promote to reference product]' ;
    rdfs:domain ind:Instruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingOrganisation rdf:type rdf:Property ;
    rdfs:label 'Issuing Organisation' ;
    rdfs:comment 'Name of the organisation (client, engineer, or consultant firm) on behalf of which the site instruction was issued. Relevant for joint venture and multi-party project structures.' ;
    rdfs:domain ind:Instruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:physicalLocationDescription rdf:type rdf:Property ;
    rdfs:label 'Physical Location Description' ;
    rdfs:comment 'Textual description of the specific physical location, chainage, grid reference, or site zone where the instructed work is to be carried out, supporting field crew navigation and site logistics.' ;
    rdfs:domain ind:Instruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:procoreInstructionReference rdf:type rdf:Property ;
    rdfs:label 'Procore Instruction Reference' ;
    rdfs:comment 'Native identifier of this site instruction record in the Procore Construction Management system, used for data lineage, reconciliation, and integration with the source system of record.' ;
    rdfs:domain ind:Instruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityHoldRequired rdf:type rdf:Property ;
    rdfs:label 'Quality Hold Required' ;
    rdfs:comment 'Indicates whether a quality hold point or inspection is required before or after execution of the work directed by this site instruction, triggering an Inspection and Test Plan (ITP) checkpoint.' ;
    rdfs:domain ind:Instruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:specificationClauseReference rdf:type rdf:Property ;
    rdfs:label 'Specification Clause Reference' ;
    rdfs:comment 'Reference to the relevant contract specification clause, standard, or technical requirement that the site instruction relates to or invokes, supporting contractual compliance and dispute resolution.' ;
    rdfs:domain ind:Instruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supersededByInstructionNumber rdf:type rdf:Property ;
    rdfs:label 'Superseded By Instruction Number' ;
    rdfs:comment 'Instruction number of the subsequent site instruction that supersedes or replaces this one, enabling version chain traceability in the instruction register.' ;
    rdfs:domain ind:Instruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timeImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Time Impact Flag' ;
    rdfs:comment 'Indicates whether the site instruction is expected to result in a schedule delay or Extension of Time (EOT) claim. When true, triggers schedule impact assessment in the project domain.' ;
    rdfs:domain ind:Instruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:logisticsPlanId rdf:type rdf:Property ;
    rdfs:label 'Logistics Plan Id' ;
    rdfs:comment 'Unique surrogate identifier for the site logistics plan record in the Databricks Silver Layer. Primary key for this entity.' ;
    rdfs:domain ind:LogisticsPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bimModelRef rdf:type rdf:Property ;
    rdfs:label 'Bim Model Ref' ;
    rdfs:comment 'Reference to the BIM 360 model or federated model file that contains the 3D site logistics layout, including crane positions, laydown areas, and temporary works modeled in the BIM environment.' ;
    rdfs:domain ind:LogisticsPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clientApprovedDate rdf:type rdf:Property ;
    rdfs:label 'Client Approved Date' ;
    rdfs:comment 'Date on which the client or client\'s representative formally approved this logistics plan. Populated only when client_approval_required is True.' ;
    rdfs:domain ind:LogisticsPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:concreteWashoutAreaIncluded rdf:type rdf:Property ;
    rdfs:label 'Concrete Washout Area Included' ;
    rdfs:comment 'Indicates whether a designated concrete washout and truck washdown area is included in this logistics plan. Required for concrete pour operations to prevent cement slurry from entering stormwater drains.' ;
    rdfs:domain ind:LogisticsPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:constructionPhase rdf:type rdf:Property ;
    rdfs:label 'Construction Phase' ;
    rdfs:comment 'The construction phase or stage this logistics plan applies to (e.g., \'Mobilization\', \'Substructure\', \'Superstructure\', \'MEP Fit-Out\', \'Commissioning\', \'Demobilization\'). [ENUM-REF-CANDIDATE: mobilization|substructure|superstructure|mep_fit_out|finishing|commissioning|demobilization — promote to reference product]' ;
    rdfs:domain ind:LogisticsPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:craneLiftZoneCount rdf:type rdf:Property ;
    rdfs:label 'Crane Lift Zone Count' ;
    rdfs:comment 'Number of designated crane lift zones defined in this logistics plan. Crane lift zones are exclusion and operating areas for tower cranes, mobile cranes, and other lifting equipment, governed by lift plans.' ;
    rdfs:domain ind:LogisticsPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deliveryTimeWindowEnd rdf:type rdf:Property ;
    rdfs:label 'Delivery Time Window End' ;
    rdfs:comment 'Latest permitted time for material and equipment deliveries to the site gate, in HH:MM 24-hour format. Deliveries outside this window require special approval and may incur liquidated damages (LD) under planning conditions.' ;
    rdfs:domain ind:LogisticsPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryTimeWindowStart rdf:type rdf:Property ;
    rdfs:label 'Delivery Time Window Start' ;
    rdfs:comment 'Earliest permitted time for material and equipment deliveries to the site gate, in HH:MM 24-hour format. Restricts deliveries to avoid peak traffic periods and comply with local authority conditions.' ;
    rdfs:domain ind:LogisticsPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emergencyEgressRouteCount rdf:type rdf:Property ;
    rdfs:label 'Emergency Egress Route Count' ;
    rdfs:comment 'Number of designated emergency egress and evacuation routes defined in this logistics plan. Must comply with fire safety and emergency response regulations and be communicated via site induction.' ;
    rdfs:domain ind:LogisticsPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:firstAidFacilityCount rdf:type rdf:Property ;
    rdfs:label 'First Aid Facility Count' ;
    rdfs:comment 'Number of first aid stations and medical response points defined in this logistics plan. Must meet OSHA minimum ratios relative to peak site workforce headcount.' ;
    rdfs:domain ind:LogisticsPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fuelStorageIncluded rdf:type rdf:Property ;
    rdfs:label 'Fuel Storage Included' ;
    rdfs:comment 'Indicates whether this logistics plan includes a designated fuel storage and bunded refuelling area for plant and equipment on site. Triggers additional environmental and fire safety controls.' ;
    rdfs:domain ind:LogisticsPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hoardingPerimeterM rdf:type rdf:Property ;
    rdfs:label 'Hoarding Perimeter M' ;
    rdfs:comment 'Total length in metres of site hoarding (perimeter security fencing and public protection barriers) defined in this logistics plan. Used for cost estimation and compliance with public safety requirements.' ;
    rdfs:domain ind:LogisticsPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:laydownAreaCount rdf:type rdf:Property ;
    rdfs:label 'Laydown Area Count' ;
    rdfs:comment 'Number of designated material laydown and staging zones defined in this logistics plan. Each laydown area is a controlled zone for temporary storage of materials and equipment awaiting installation.' ;
    rdfs:domain ind:LogisticsPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:materialStagingZones rdf:type rdf:Property ;
    rdfs:label 'Material Staging Zones' ;
    rdfs:comment 'Narrative description of the designated material staging zones on site, including their locations, intended materials (e.g., rebar, formwork, precast elements), and capacity constraints as defined in the logistics plan.' ;
    rdfs:domain ind:LogisticsPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxVehicleSpeedKmh rdf:type rdf:Property ;
    rdfs:label 'Max Vehicle Speed Kmh' ;
    rdfs:comment 'Maximum permitted vehicle speed in kilometres per hour within the site boundary as defined in this logistics plan. Typically 10–15 km/h on construction sites to protect pedestrian workers.' ;
    rdfs:domain ind:LogisticsPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:peakWorkforceHeadcount rdf:type rdf:Property ;
    rdfs:label 'Peak Workforce Headcount' ;
    rdfs:comment 'Maximum number of workers (direct and subcontractor) expected on site simultaneously during the period covered by this logistics plan. Drives welfare facility sizing, emergency egress capacity, and traffic management intensity.' ;
    rdfs:domain ind:LogisticsPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:siteAreaSqm rdf:type rdf:Property ;
    rdfs:label 'Site Area Sqm' ;
    rdfs:comment 'Total area of the construction site in square metres covered by this logistics plan. Used for planning material staging density, welfare facility ratios, and emergency egress capacity.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:siteGateCount rdf:type rdf:Property ;
    rdfs:label 'Site Gate Count' ;
    rdfs:comment 'Number of controlled access gates defined in this logistics plan for entry and exit of personnel, vehicles, and materials. Includes separate pedestrian and vehicle gates where applicable.' ;
    rdfs:domain ind:LogisticsPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:siteLayoutDrawingRef rdf:type rdf:Property ;
    rdfs:label 'Site Layout Drawing Ref' ;
    rdfs:comment 'Document reference number or BIM 360 / Aconex document ID for the site layout drawing that accompanies this logistics plan, showing the physical arrangement of zones, routes, and facilities.' ;
    rdfs:domain ind:LogisticsPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tempAccessRoadCount rdf:type rdf:Property ;
    rdfs:label 'Temp Access Road Count' ;
    rdfs:comment 'Number of temporary access roads established within the site logistics plan for movement of vehicles, plant, and personnel. Includes haul roads, delivery routes, and internal circulation roads.' ;
    rdfs:domain ind:LogisticsPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:temporaryWorksIncluded rdf:type rdf:Property ;
    rdfs:label 'Temporary Works Included' ;
    rdfs:comment 'Indicates whether this logistics plan includes temporary works arrangements such as shoring, hoarding, temporary bridges, or scaffolding that require a separate temporary works design and approval.' ;
    rdfs:domain ind:LogisticsPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:temporaryWorksRef rdf:type rdf:Property ;
    rdfs:label 'Temporary Works Ref' ;
    rdfs:comment 'Document reference number for the temporary works design package associated with this logistics plan. Populated only when temporary_works_included is True.' ;
    rdfs:domain ind:LogisticsPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trafficManagementScheme rdf:type rdf:Property ;
    rdfs:label 'Traffic Management Scheme' ;
    rdfs:comment 'Type of traffic management arrangement implemented on site to separate pedestrian and vehicle movements. \'segregated\' means fully separated pedestrian and vehicle routes; \'controlled_crossing\' uses marshalled crossing points.' ;
    rdfs:domain ind:LogisticsPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wasteManagementZoneCount rdf:type rdf:Property ;
    rdfs:label 'Waste Management Zone Count' ;
    rdfs:comment 'Number of designated waste segregation and skip areas defined in this logistics plan for construction waste, hazardous materials, and recyclables. Supports compliance with EPA and ISO 14001 waste management requirements.' ;
    rdfs:domain ind:LogisticsPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:welfareFacilityCount rdf:type rdf:Property ;
    rdfs:label 'Welfare Facility Count' ;
    rdfs:comment 'Number of welfare facility units (site offices, canteens, toilets, first aid rooms, drying rooms) included in this logistics plan. Welfare provision must meet regulatory minimums per workforce headcount.' ;
    rdfs:domain ind:LogisticsPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:siteMobilizationId rdf:type rdf:Property ;
    rdfs:label 'Site Mobilization Id' ;
    rdfs:comment 'Unique surrogate identifier for the site mobilization record. Primary key for the site_mobilization data product in the Databricks Silver Layer.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SiteMobilization .

ind:accessRoadEstablished rdf:type rdf:Property ;
    rdfs:label 'Access Road Established' ;
    rdfs:comment 'Indicates whether the primary site access road and entry/exit gates have been constructed and are operational for heavy vehicle and workforce ingress/egress.' ;
    rdfs:domain ind:SiteMobilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:buildingPermitNumber rdf:type rdf:Property ;
    rdfs:label 'Building Permit Number' ;
    rdfs:comment 'Reference number of the building or construction permit issued by the local authority. Required before commencement of structural works and tracked for regulatory compliance.' ;
    rdfs:domain ind:SiteMobilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costBudget rdf:type rdf:Property ;
    rdfs:label 'Cost Budget' ;
    rdfs:comment 'Approved budget allocated for site mobilization activities including site establishment, temporary facilities, equipment transport, and initial workforce deployment. Expressed in the project currency.' ;
    rdfs:domain ind:SiteMobilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:environmentalPermitNumber rdf:type rdf:Property ;
    rdfs:label 'Environmental Permit Number' ;
    rdfs:comment 'Reference number of the primary environmental permit issued by the regulatory authority (e.g., EPA NPDES permit number). Required for regulatory compliance tracking and audit.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:environmentalPermitObtained rdf:type rdf:Property ;
    rdfs:label 'Environmental Permit Obtained' ;
    rdfs:comment 'Indicates whether all required environmental permits and approvals (e.g., EPA stormwater NPDES permit, land disturbance permit) have been obtained prior to ground disturbance.' ;
    rdfs:domain ind:SiteMobilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hsePlanApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Hse Plan Approval Date' ;
    rdfs:comment 'Date on which the site HSE plan was formally approved by the HSE Manager and client representative. Required for regulatory compliance and Intelex HSE management system records.' ;
    rdfs:domain ind:SiteMobilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:laydownAreaEstablished rdf:type rdf:Property ;
    rdfs:label 'Laydown Area Established' ;
    rdfs:comment 'Indicates whether the designated materials laydown and storage area has been prepared, demarcated, and made operational for receiving deliveries and storing equipment.' ;
    rdfs:domain ind:SiteMobilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mobilizationType rdf:type rdf:Property ;
    rdfs:label 'Mobilization Type' ;
    rdfs:comment 'Classification of the mobilization scope: full_site (complete site establishment), work_package (specific WBS package), temporary_camp (workforce accommodation), equipment_only (plant and machinery deployment), or partial (phased mobilization). [ENUM-REF-CANDIDATE: full_site|work_package|temporary_camp|equipment_only|partial|phased — promote to reference product]' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:peakWorkforceActual rdf:type rdf:Property ;
    rdfs:label 'Peak Workforce Actual' ;
    rdfs:comment 'Maximum number of workers (direct and subcontractor) actually recorded on site simultaneously during the mobilization period, as tracked in HCSS HeavyJob time records.' ;
    rdfs:domain ind:SiteMobilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:peakWorkforcePlanned rdf:type rdf:Property ;
    rdfs:label 'Peak Workforce Planned' ;
    rdfs:comment 'Maximum number of workers (direct and subcontractor) planned to be on site simultaneously at peak mobilization, as per the resource-loaded schedule in Oracle Primavera P6.' ;
    rdfs:domain ind:SiteMobilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:plannedDemobilizationDate rdf:type rdf:Property ;
    rdfs:label 'Planned Demobilization Date' ;
    rdfs:comment 'Baseline-scheduled date on which site demobilization was planned to be completed, as per the approved project schedule. Used for resource release planning and contract completion forecasting.' ;
    rdfs:domain ind:SiteMobilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:plannedMobilizationDate rdf:type rdf:Property ;
    rdfs:label 'Planned Mobilization Date' ;
    rdfs:comment 'Baseline-scheduled date on which site mobilization activities were planned to commence, as recorded in Oracle Primavera P6. Used for schedule variance analysis and earned value management (EVM).' ;
    rdfs:domain ind:SiteMobilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:siteClosureSignoffDate rdf:type rdf:Property ;
    rdfs:label 'Site Closure Signoff Date' ;
    rdfs:comment 'Date on which the formal site closure sign-off was completed by the client, engineer, and contractor, confirming all demobilization obligations have been fulfilled and the site has been restored.' ;
    rdfs:domain ind:SiteMobilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:siteFencingComplete rdf:type rdf:Property ;
    rdfs:label 'Site Fencing Complete' ;
    rdfs:comment 'Indicates whether site perimeter fencing and hoarding have been fully erected as part of site establishment. Key safety milestone required before workforce deployment.' ;
    rdfs:domain ind:SiteMobilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:siteOfficeEstablished rdf:type rdf:Property ;
    rdfs:label 'Site Office Established' ;
    rdfs:comment 'Indicates whether the temporary site office (including communications, IT infrastructure, and welfare facilities) has been established and is operational.' ;
    rdfs:domain ind:SiteMobilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:temporaryUtilitiesConnected rdf:type rdf:Property ;
    rdfs:label 'Temporary Utilities Connected' ;
    rdfs:comment 'Indicates whether temporary site utilities (power, water, telecommunications, sewage) have been connected and are operational. Prerequisite for sustained site operations.' ;
    rdfs:domain ind:SiteMobilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sitePermitId rdf:type rdf:Property ;
    rdfs:label 'Site Permit Id' ;
    rdfs:comment 'System generated unique identifier for the site permit record.' ;
    rdfs:domain ind:SitePermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primarySiteEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Site Employee Id' ;
    rdfs:comment 'Identifier of the person accountable for compliance with the permit.' ;
    rdfs:domain ind:SitePermit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiarySiteCloseOutByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Site Close Out By Employee Id' ;
    rdfs:comment 'Identifier of the person who signed off the permit close-out.' ;
    rdfs:domain ind:SitePermit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:attachedDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Attached Document Reference' ;
    rdfs:comment 'Identifier of the digital file storing the original permit document.' ;
    rdfs:domain ind:SitePermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closeOutTimestamp rdf:type rdf:Property ;
    rdfs:label 'Close Out Timestamp' ;
    rdfs:comment 'Timestamp when the permit was formally closed after work completion.' ;
    rdfs:domain ind:SitePermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:complianceReference rdf:type rdf:Property ;
    rdfs:label 'Compliance Reference' ;
    rdfs:comment 'Reference to the specific regulation or standard (e.g., OSHA 29 CFR 1926.55).' ;
    rdfs:domain ind:SitePermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditions rdf:type rdf:Property ;
    rdfs:label 'Conditions' ;
    rdfs:comment 'Textual description of conditions or restrictions imposed by the authority.' ;
    rdfs:domain ind:SitePermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expirationNoticeSent rdf:type rdf:Property ;
    rdfs:label 'Expiration Notice Sent' ;
    rdfs:comment 'True if an expiry notice has been sent to the responsible party.' ;
    rdfs:domain ind:SitePermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:extensionApprovedDate rdf:type rdf:Property ;
    rdfs:label 'Extension Approved Date' ;
    rdfs:comment 'Date an extension to the permit was approved.' ;
    rdfs:domain ind:SitePermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:extensionRequested rdf:type rdf:Property ;
    rdfs:label 'Extension Requested' ;
    rdfs:comment 'Indicates whether an extension to the permit expiry has been requested.' ;
    rdfs:domain ind:SitePermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isEnvironmental rdf:type rdf:Property ;
    rdfs:label 'Is Environmental' ;
    rdfs:comment 'True if the permit involves environmental impact (e.g., discharge, noise).' ;
    rdfs:domain ind:SitePermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSafetyCritical rdf:type rdf:Property ;
    rdfs:label 'Is Safety Critical' ;
    rdfs:comment 'Indicates whether the permit relates to a safety-critical activity.' ;
    rdfs:domain ind:SitePermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sitePermitStatus rdf:type rdf:Property ;
    rdfs:label 'Site Permit Status' ;
    rdfs:comment 'Current lifecycle status of the permit.' ;
    rdfs:domain ind:SitePermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accessRestriction rdf:type rdf:Property ;
    rdfs:label 'Access Restriction' ;
    rdfs:comment 'The access control classification for this work front. \'permit_required\' indicates a Permit to Work (PTW) is mandatory before entry; \'restricted_zone\' limits access to authorised personnel; \'exclusion_zone\' prohibits all non-essential access. Supports HSE compliance.' ;
    rdfs:domain ind:WorkFront ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualCrewSize rdf:type rdf:Property ;
    rdfs:label 'Actual Crew Size' ;
    rdfs:comment 'The actual number of direct labour workers present at this work front on the most recent reporting day. Compared against planned_crew_size to identify under-manning and productivity risks.' ;
    rdfs:domain ind:WorkFront ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:areaSqm rdf:type rdf:Property ;
    rdfs:label 'Area Sqm' ;
    rdfs:comment 'Total plan area of the work front in square metres. Used as the principal quantitative measure of the resource for production rate calculations, crew density planning, and progress measurement.' ;
    rdfs:domain ind:WorkFront ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:currentPhase rdf:type rdf:Property ;
    rdfs:label 'Current Phase' ;
    rdfs:comment 'The current construction phase being executed at this work front (e.g., \'Earthworks\', \'Foundation\', \'Structural\', \'MEP Rough-In\', \'Finishing\', \'Commissioning\'). Aligns with the project schedule phase hierarchy in Oracle Primavera P6. [ENUM-REF-CANDIDATE: earthworks|foundation|structural|mep_rough_in|finishing|commissioning|handover — promote to reference product]' ;
    rdfs:domain ind:WorkFront ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:environmentalSensitivity rdf:type rdf:Property ;
    rdfs:label 'Environmental Sensitivity' ;
    rdfs:comment 'Classification of the environmental sensitivity of the work front location. \'sensitive\' and \'protected\' areas require additional environmental controls and monitoring per ISO 14001 and EPA requirements. \'remediation_required\' indicates contaminated ground conditions.' ;
    rdfs:domain ind:WorkFront ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:frontCode rdf:type rdf:Property ;
    rdfs:label 'Front Code' ;
    rdfs:comment 'Externally-known alphanumeric code that uniquely identifies the work front within the project or site. Used in daily logs, production reports, and cost coding in HCSS HeavyJob and Procore.' ;
    rdfs:domain ind:WorkFront ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:frontName rdf:type rdf:Property ;
    rdfs:label 'Front Name' ;
    rdfs:comment 'Human-readable descriptive name of the work front (e.g., \'Zone A – Pile Cap Excavation\', \'North Abutment Face\'). Used in daily logs, progress reports, and field management interfaces.' ;
    rdfs:domain ind:WorkFront ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:frontStatus rdf:type rdf:Property ;
    rdfs:label 'Front Status' ;
    rdfs:comment 'Current lifecycle status of the work front. \'mobilizing\' indicates resources are being deployed; \'active\' indicates concurrent work is in progress; \'suspended\' indicates a temporary hold; \'demobilized\' indicates resources have been withdrawn; \'completed\' indicates all planned work is finished.' ;
    rdfs:domain ind:WorkFront ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:frontType rdf:type rdf:Property ;
    rdfs:label 'Front Type' ;
    rdfs:comment 'Classification of the spatial unit represented by this work front. Distinguishes between zone (broad area), area (defined boundary), face (excavation or structural face), sector, corridor, level (floor/elevation), or bay. [ENUM-REF-CANDIDATE: zone|area|face|sector|corridor|level|bay — promote to reference product if additional types are required]' ;
    rdfs:domain ind:WorkFront ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:heavyjobCostCenter rdf:type rdf:Property ;
    rdfs:label 'Heavyjob Cost Center' ;
    rdfs:comment 'The cost center identifier in HCSS HeavyJob associated with this work front. Used for field-level cost allocation, equipment hour tracking, and production rate reporting.' ;
    rdfs:domain ind:WorkFront ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isSubcontracted rdf:type rdf:Property ;
    rdfs:label 'Is Subcontracted' ;
    rdfs:comment 'Indicates whether the work at this work front is executed by a subcontractor rather than the general contractor\'s own workforce. Drives subcontractor management workflows and contract administration processes.' ;
    rdfs:domain ind:WorkFront ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:plannedCrewSize rdf:type rdf:Property ;
    rdfs:label 'Planned Crew Size' ;
    rdfs:comment 'The planned number of direct labour workers assigned to this work front per shift as defined in the resource-loaded schedule. Used for crew density analysis and productivity benchmarking.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:procoreLocationReference rdf:type rdf:Property ;
    rdfs:label 'Procore Location Reference' ;
    rdfs:comment 'The location identifier assigned to this work front in the Procore construction management system. Used to link daily logs, RFIs, submittals, and change orders to the correct spatial location.' ;
    rdfs:domain ind:WorkFront ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityItpReference rdf:type rdf:Property ;
    rdfs:label 'Quality Itp Reference' ;
    rdfs:comment 'Document reference number of the Inspection and Test Plan (ITP) applicable to the primary activities at this work front. Links field execution to the QA/QC management system and NCR tracking.' ;
    rdfs:domain ind:WorkFront ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:weatherSensitivity rdf:type rdf:Property ;
    rdfs:label 'Weather Sensitivity' ;
    rdfs:comment 'Classification of how sensitive the work activities at this work front are to adverse weather conditions. \'high\' sensitivity work fronts (e.g., concrete pours, earthworks) require weather monitoring and contingency planning.' ;
    rdfs:domain ind:WorkFront ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:zoneClassification rdf:type rdf:Property ;
    rdfs:label 'Zone Classification' ;
    rdfs:comment 'Discipline-based classification of the work front zone indicating the primary trade or engineering discipline active at this location. Supports resource planning and subcontractor assignment. [ENUM-REF-CANDIDATE: civil|structural|mep|architectural|earthworks|piling|finishing|commissioning — promote to reference product]' ;
    rdfs:domain ind:WorkFront ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:backChargeId rdf:type rdf:Property ;
    rdfs:label 'Back Charge Id' ;
    rdfs:comment 'Primary key for back_charge' ;
    rdfs:domain ind:BackCharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryBackEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Back Employee Id' ;
    rdfs:comment 'Reference to the user (project manager, site manager, or contracts administrator) who issued the back-charge notice. Links to the user or team member record.' ;
    rdfs:domain ind:BackCharge ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:approvedAmount rdf:type rdf:Property ;
    rdfs:label 'Approved Amount' ;
    rdfs:comment 'Final approved amount of the back-charge after any dispute resolution or negotiation. May differ from the total claimed amount if partially accepted or negotiated down.' ;
    rdfs:domain ind:BackCharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:backChargeNumber rdf:type rdf:Property ;
    rdfs:label 'Back Charge Number' ;
    rdfs:comment 'Externally visible unique business identifier for the back-charge record, typically formatted per company standards (e.g., BC-2024-001234). Used in correspondence and payment deductions.' ;
    rdfs:domain ind:BackCharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:backChargeStatus rdf:type rdf:Property ;
    rdfs:label 'Back Charge Status' ;
    rdfs:comment 'Current lifecycle status of the back-charge record. Tracks progression from draft through issuance, dispute resolution, approval, and final deduction or closure. [ENUM-REF-CANDIDATE: draft|issued|acknowledged|disputed|under_review|approved|rejected|deducted|closed|cancelled — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:BackCharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deductionAppliedAmount rdf:type rdf:Property ;
    rdfs:label 'Deduction Applied Amount' ;
    rdfs:comment 'Actual amount deducted from subcontractor payment certification or final account as a result of this back-charge. Reflects the financial recovery achieved.' ;
    rdfs:domain ind:BackCharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deductionDate rdf:type rdf:Property ;
    rdfs:label 'Deduction Date' ;
    rdfs:comment 'Date on which the back-charge amount was deducted from the subcontractor\'s payment. Nullable if deduction has not yet occurred.' ;
    rdfs:domain ind:BackCharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:equipmentCostAmount rdf:type rdf:Property ;
    rdfs:label 'Equipment Cost Amount' ;
    rdfs:comment 'Total equipment cost component of the back-charge, representing the cost of equipment usage (owned or rented) deployed to remedy the subcontractor default.' ;
    rdfs:domain ind:BackCharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:laborCostAmount rdf:type rdf:Property ;
    rdfs:label 'Labor Cost Amount' ;
    rdfs:comment 'Total labor cost component of the back-charge, representing the cost of general contractor or third-party labor deployed to remedy the subcontractor default or defect.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:materialCostAmount rdf:type rdf:Property ;
    rdfs:label 'Material Cost Amount' ;
    rdfs:comment 'Total material cost component of the back-charge, representing the cost of materials consumed to remedy the subcontractor default or replace damaged materials.' ;
    rdfs:domain ind:BackCharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ncrReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Ncr Reference Number' ;
    rdfs:comment 'Reference number of the associated Non-Conformance Report (NCR) that documented the quality defect or deficiency giving rise to this back-charge. Nullable if no formal NCR was raised.' ;
    rdfs:domain ind:BackCharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overheadCostAmount rdf:type rdf:Property ;
    rdfs:label 'Overhead Cost Amount' ;
    rdfs:comment 'Overhead and indirect cost component of the back-charge, including administrative costs, supervision, and markup applied per contract terms.' ;
    rdfs:domain ind:BackCharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reasonDescription rdf:type rdf:Property ;
    rdfs:label 'Reason Description' ;
    rdfs:comment 'Detailed narrative explanation of the circumstances and events that led to the back-charge. Includes specifics of the subcontractor default, defective work details, or damage caused.' ;
    rdfs:domain ind:Subcontractor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseDeadlineDate rdf:type rdf:Property ;
    rdfs:label 'Response Deadline Date' ;
    rdfs:comment 'Date by which the subcontractor must respond to the back-charge notice, either acknowledging the charge or raising a formal dispute. Typically contractually defined (e.g., 14 days from notification).' ;
    rdfs:domain ind:BackCharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:siteInstructionNumber rdf:type rdf:Property ;
    rdfs:label 'Site Instruction Number' ;
    rdfs:comment 'Reference number of the site instruction issued to the subcontractor directing remedial action or documenting the default. Nullable if no formal site instruction was issued.' ;
    rdfs:domain ind:BackCharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportingDocumentationPath rdf:type rdf:Property ;
    rdfs:label 'Supporting Documentation Path' ;
    rdfs:comment 'File path or document management system reference to supporting documentation for the back-charge (photos, inspection reports, cost breakdowns, correspondence). Typically stored in Aconex or BIM 360 document control.' ;
    rdfs:domain ind:BackCharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalClaimedAmount rdf:type rdf:Property ;
    rdfs:label 'Total Claimed Amount' ;
    rdfs:comment 'Total amount claimed in the back-charge, representing the sum of all cost components (labor, material, equipment, overhead) that the general contractor seeks to recover from the subcontractor.' ;
    rdfs:domain ind:BackCharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:responseId rdf:type rdf:Property ;
    rdfs:label 'Response Id' ;
    rdfs:comment 'Primary key for response' ;
    rdfs:domain ind:Response ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:awardCurrency rdf:type rdf:Property ;
    rdfs:label 'Award Currency' ;
    rdfs:comment 'Currency of the awarded contract value.' ;
    rdfs:domain ind:Response ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:awardValue rdf:type rdf:Property ;
    rdfs:label 'Award Value' ;
    rdfs:comment 'Monetary value of the contract awarded based on the winning bid.' ;
    rdfs:domain ind:Response ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bidAmount rdf:type rdf:Property ;
    rdfs:label 'Bid Amount' ;
    rdfs:comment 'Total monetary amount requested by the subcontractor in the bid (gross).' ;
    rdfs:domain ind:Response ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bidReference rdf:type rdf:Property ;
    rdfs:label 'Bid Reference' ;
    rdfs:comment 'External reference code assigned to the bid response, used for tracking and communication.' ;
    rdfs:domain ind:Response ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bondRequired rdf:type rdf:Property ;
    rdfs:label 'Bond Required' ;
    rdfs:comment 'Indicates whether a performance bond is required for this bid.' ;
    rdfs:domain ind:Response ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:commercialRanking rdf:type rdf:Property ;
    rdfs:label 'Commercial Ranking' ;
    rdfs:comment 'Numeric ranking of the bid based on commercial criteria such as price and payment terms.' ;
    rdfs:domain ind:Response ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:insuranceCoverageAmount rdf:type rdf:Property ;
    rdfs:label 'Insurance Coverage Amount' ;
    rdfs:comment 'Minimum insurance coverage amount required for the bid.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:technicalComplianceScore rdf:type rdf:Property ;
    rdfs:label 'Technical Compliance Score' ;
    rdfs:comment 'Score (0-100) reflecting how well the bid meets technical specifications and requirements.' ;
    rdfs:domain ind:Response ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:advancePaymentPercentage rdf:type rdf:Property ;
    rdfs:label 'Advance Payment Percentage' ;
    rdfs:comment 'Percentage of the contract value paid as an advance payment to the subcontractor upon contract signing or NTP, subject to advance payment guarantee.' ;
    rdfs:domain ind:ContractAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contractExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Contract Expiry Date' ;
    rdfs:comment 'Date on which the subcontract agreement expires or is scheduled for final closeout, including all warranty and retention obligations.' ;
    rdfs:domain ind:ContractAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contractName rdf:type rdf:Property ;
    rdfs:label 'Contract Name' ;
    rdfs:comment 'Descriptive name or title of the subcontract agreement, typically referencing the trade package or scope.' ;
    rdfs:domain ind:ContractAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractStatus rdf:type rdf:Property ;
    rdfs:label 'Contract Status' ;
    rdfs:comment 'Current lifecycle status of the subcontract agreement: draft (under negotiation), pending_approval (awaiting internal sign-off), awarded (signed but not started), active (work in progress), suspended (temporarily halted), completed (work finished), terminated (cancelled), closed (final settlement complete). [ENUM-REF-CANDIDATE: draft|pending_approval|awarded|active|suspended|completed|terminated|closed — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ContractAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentContractValue rdf:type rdf:Property ;
    rdfs:label 'Current Contract Value' ;
    rdfs:comment 'Current total contract value including all approved change orders, variations, and adjustments to date.' ;
    rdfs:domain ind:ContractAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:disputeResolutionMethod rdf:type rdf:Property ;
    rdfs:label 'Dispute Resolution Method' ;
    rdfs:comment 'Primary method for resolving disputes under this subcontract: negotiation, mediation, arbitration, litigation, or DAB (Dispute Adjudication Board) as per FIDIC.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:executedContractValue rdf:type rdf:Property ;
    rdfs:label 'Executed Contract Value' ;
    rdfs:comment 'Original signed contract value in the contract currency, representing the baseline commitment before any change orders or variations.' ;
    rdfs:domain ind:ContractAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fidicConditionsReference rdf:type rdf:Property ;
    rdfs:label 'Fidic Conditions Reference' ;
    rdfs:comment 'Reference to the FIDIC contract conditions edition and color book (e.g., Red Book 1999, Yellow Book 2017) governing the contractual framework and dispute resolution.' ;
    rdfs:domain ind:ContractAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Insurance Required Flag' ;
    rdfs:comment 'Boolean indicator whether the subcontractor is contractually required to maintain specific insurance coverage (e.g., general liability, professional indemnity, workers compensation).' ;
    rdfs:domain ind:ContractAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ldCapPercentage rdf:type rdf:Property ;
    rdfs:label 'Ld Cap Percentage' ;
    rdfs:comment 'Maximum total liquidated damages expressed as a percentage of the contract value (typically 10-20%), beyond which no further LDs are applied.' ;
    rdfs:domain ind:ContractAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentApplicationFrequency rdf:type rdf:Property ;
    rdfs:label 'Payment Application Frequency' ;
    rdfs:comment 'Frequency at which the subcontractor submits payment applications for work completed: monthly (calendar month), bi-weekly (every two weeks), milestone-based (upon achieving defined milestones), or completion-based (upon final completion).' ;
    rdfs:domain ind:ContractAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:performanceBondRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Performance Bond Required Flag' ;
    rdfs:comment 'Boolean indicator whether the subcontractor is required to provide a performance bond or bank guarantee to secure contract performance.' ;
    rdfs:domain ind:ContractAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scopeOfWorkDescription rdf:type rdf:Property ;
    rdfs:label 'Scope Of Work Description' ;
    rdfs:comment 'Detailed textual description of the work scope, deliverables, and responsibilities assigned to the subcontractor under this agreement.' ;
    rdfs:domain ind:ContractAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subcontractorRepresentativeName rdf:type rdf:Property ;
    rdfs:label 'Subcontractor Representative Name' ;
    rdfs:comment 'Name of the subcontractor representative or project manager designated as the primary point of contact for this agreement.' ;
    rdfs:domain ind:ContractAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradePackageCode rdf:type rdf:Property ;
    rdfs:label 'Trade Package Code' ;
    rdfs:comment 'Code identifying the trade package or scope-of-work category (e.g., MEP, civil works, structural steel, concrete, finishes).' ;
    rdfs:domain ind:ContractAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:finalAccountId rdf:type rdf:Property ;
    rdfs:label 'Final Account Id' ;
    rdfs:comment 'Primary key for final_account' ;
    rdfs:domain ind:FinalAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:claimsSettledValue rdf:type rdf:Property ;
    rdfs:label 'Claims Settled Value' ;
    rdfs:comment 'Total value of subcontractor claims (for delays, disruptions, variations, or EOT-related costs) that were agreed and settled as part of the final account.' ;
    rdfs:domain ind:FinalAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contractorSignatureDate rdf:type rdf:Property ;
    rdfs:label 'Contractor Signature Date' ;
    rdfs:comment 'Date on which the contractor signatory signed the final account document.' ;
    rdfs:domain ind:FinalAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:defectsLiabilityPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Defects Liability Period End Date' ;
    rdfs:comment 'The date on which the Defects Liability Period expires. Retention is typically released after this date and any defects are rectified.' ;
    rdfs:domain ind:FinalAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:disputeResolutionDate rdf:type rdf:Property ;
    rdfs:label 'Dispute Resolution Date' ;
    rdfs:comment 'Date on which the dispute was formally resolved and the final account was agreed, if initially disputed.' ;
    rdfs:domain ind:FinalAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:finalAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Final Account Number' ;
    rdfs:comment 'Business identifier for the final account settlement document. Typically follows organizational numbering convention (e.g., FA-2024-001234).' ;
    rdfs:domain ind:FinalAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:finalAccountStatus rdf:type rdf:Property ;
    rdfs:label 'Final Account Status' ;
    rdfs:comment 'Current lifecycle status of the final account settlement. Tracks progression from draft through agreement to closure or dispute resolution.' ;
    rdfs:domain ind:FinalAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:finalAgreedValue rdf:type rdf:Property ;
    rdfs:label 'Final Agreed Value' ;
    rdfs:comment 'The final settled contract value after all adjustments: original value plus approved COs plus claims minus back-charges minus LDs plus retention released. Represents the total financial close-out amount.' ;
    rdfs:domain ind:FinalAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:finalPaymentDueDate rdf:type rdf:Property ;
    rdfs:label 'Final Payment Due Date' ;
    rdfs:comment 'The contractual due date by which the final agreed value must be paid to the subcontractor. Typically defined in payment terms.' ;
    rdfs:domain ind:FinalAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:finalPaymentMadeDate rdf:type rdf:Property ;
    rdfs:label 'Final Payment Made Date' ;
    rdfs:comment 'Actual date on which the final payment was made to the subcontractor. Confirms financial closure.' ;
    rdfs:domain ind:FinalAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:finalPaymentReference rdf:type rdf:Property ;
    rdfs:label 'Final Payment Reference' ;
    rdfs:comment 'Payment transaction reference or remittance advice number for the final payment. Links to accounts payable records.' ;
    rdfs:domain ind:FinalAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:liquidatedDamagesDeducted rdf:type rdf:Property ;
    rdfs:label 'Liquidated Damages Deducted' ;
    rdfs:comment 'Total liquidated damages deducted from the final account for delays or non-performance as per the subcontract terms.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:performanceBondReleaseDate rdf:type rdf:Property ;
    rdfs:label 'Performance Bond Release Date' ;
    rdfs:comment 'Date on which the performance bond was formally released to the subcontractor or their surety.' ;
    rdfs:domain ind:FinalAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:performanceBondReleased rdf:type rdf:Property ;
    rdfs:label 'Performance Bond Released' ;
    rdfs:comment 'Indicates whether the subcontractor performance bond or guarantee has been released as part of the final account settlement. True if released, False if still held.' ;
    rdfs:domain ind:FinalAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:retentionReleased rdf:type rdf:Property ;
    rdfs:label 'Retention Released' ;
    rdfs:comment 'Total retention amount released to the subcontractor upon satisfactory completion and expiry of the Defects Liability Period (DLP). Typically 5-10% of contract value.' ;
    rdfs:domain ind:FinalAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:settlementDate rdf:type rdf:Property ;
    rdfs:label 'Settlement Date' ;
    rdfs:comment 'The date on which the final account was formally agreed and signed by both parties. Marks the financial close-out milestone.' ;
    rdfs:domain ind:FinalAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:subcontractorSignatoryName rdf:type rdf:Property ;
    rdfs:label 'Subcontractor Signatory Name' ;
    rdfs:comment 'Full name of the authorized representative from the subcontractor who signed the final account settlement.' ;
    rdfs:domain ind:FinalAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subcontractorSignatoryTitle rdf:type rdf:Property ;
    rdfs:label 'Subcontractor Signatory Title' ;
    rdfs:comment 'Job title or role of the subcontractor signatory (e.g., Managing Director, Commercial Manager, Project Director).' ;
    rdfs:domain ind:FinalAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subcontractorSignatureDate rdf:type rdf:Property ;
    rdfs:label 'Subcontractor Signature Date' ;
    rdfs:comment 'Date on which the subcontractor signatory signed the final account document.' ;
    rdfs:domain ind:FinalAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:totalApprovedChangeOrders rdf:type rdf:Property ;
    rdfs:label 'Total Approved Change Orders' ;
    rdfs:comment 'Cumulative value of all approved change orders that increased or decreased the subcontract scope and value. Sum of all CO amounts.' ;
    rdfs:domain ind:FinalAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalBackCharges rdf:type rdf:Property ;
    rdfs:label 'Total Back Charges' ;
    rdfs:comment 'Cumulative value of all back-charges levied against the subcontractor for defects, delays, rework, or other contractual breaches. Reduces final payment.' ;
    rdfs:domain ind:FinalAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:annualRevenueBand rdf:type rdf:Property ;
    rdfs:label 'Annual Revenue Band' ;
    rdfs:comment 'Banded annual revenue range of the subcontracting firm, used for financial capacity assessment during prequalification. Exact revenue figures are not captured to reduce sensitivity; banding provides sufficient granularity for risk tiering.' ;
    rdfs:domain ind:FirmProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bondingCapacityUsd rdf:type rdf:Property ;
    rdfs:label 'Bonding Capacity Usd' ;
    rdfs:comment 'Maximum aggregate bonding capacity in US dollars as certified by the firm\'s surety provider. Determines the maximum contract value the firm can be awarded. Critical for large EPC and GMP contract prequalification.' ;
    rdfs:domain ind:FirmProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:companyRegistrationNumber rdf:type rdf:Property ;
    rdfs:label 'Company Registration Number' ;
    rdfs:comment 'Government-issued company registration or incorporation number assigned by the relevant corporate registry (e.g., state secretary of state, Companies House). Used for legal identity verification and compliance checks.' ;
    rdfs:domain ind:FirmProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractorLicenseExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Contractor License Expiry Date' ;
    rdfs:comment 'Expiry date of the firm\'s primary contractor license. Triggers compliance alert workflow when approaching expiry. Firms with expired licenses cannot be awarded new subcontracts.' ;
    rdfs:domain ind:FirmProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contractorLicenseNumber rdf:type rdf:Property ;
    rdfs:label 'Contractor License Number' ;
    rdfs:comment 'Primary state or jurisdiction contractor license number held by the firm. Required for legal compliance on construction projects. Multiple licenses may exist; this captures the primary license for the firm\'s home jurisdiction.' ;
    rdfs:domain ind:FirmProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractorLicenseState rdf:type rdf:Property ;
    rdfs:label 'Contractor License State' ;
    rdfs:comment 'Two-letter state code of the jurisdiction that issued the primary contractor license. Used to validate the firm\'s legal authority to perform work in a given state.' ;
    rdfs:domain ind:FirmProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countryOfIncorporation rdf:type rdf:Property ;
    rdfs:label 'Country Of Incorporation' ;
    rdfs:comment 'ISO 3166-1 alpha-3 three-letter country code representing the jurisdiction in which the subcontracting firm is legally incorporated or registered (e.g., USA, AUS, GBR).' ;
    rdfs:domain ind:FirmProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dbeCertified rdf:type rdf:Property ;
    rdfs:label 'Dbe Certified' ;
    rdfs:comment 'Indicates whether the firm holds a valid Disadvantaged Business Enterprise (DBE) certification under the US DOT program. Required for compliance reporting on federally funded highway, airport, and transit projects.' ;
    rdfs:domain ind:FirmProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:diversityCertificationExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Diversity Certification Expiry Date' ;
    rdfs:comment 'Expiry date of the firm\'s most current MBE/WBE/DBE diversity certification. Triggers renewal notification workflow. Expired certifications cannot be counted toward project diversity spend goals.' ;
    rdfs:domain ind:FirmProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:emr rdf:type rdf:Property ;
    rdfs:label 'Emr' ;
    rdfs:comment 'Experience Modification Rate (EMR) — a workers\' compensation insurance metric reflecting the firm\'s historical safety performance relative to industry average. An EMR below 1.0 indicates better-than-average safety record. Used as a key HSE prequalification criterion per OSHA guidelines.' ;
    rdfs:domain ind:FirmProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:emrReferenceYear rdf:type rdf:Property ;
    rdfs:label 'Emr Reference Year' ;
    rdfs:comment 'The policy year to which the reported EMR value applies. EMR is recalculated annually; this field identifies the vintage of the current EMR on file.' ;
    rdfs:domain ind:FirmProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:firmStatus rdf:type rdf:Property ;
    rdfs:label 'Firm Status' ;
    rdfs:comment 'Current lifecycle status of the subcontracting firm within the enterprise\'s approved subcontractor registry. Drives eligibility for bid invitations, trade package awards, and payment processing.' ;
    rdfs:domain ind:FirmProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicCoverageRegions rdf:type rdf:Property ;
    rdfs:label 'Geographic Coverage Regions' ;
    rdfs:comment 'Comma-separated list of geographic regions or states where the firm is licensed and operationally capable of performing work (e.g., \'CA,TX,NV,AZ\'). Used for trade package sourcing and bid list construction.' ;
    rdfs:domain ind:FirmProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersAddress rdf:type rdf:Property ;
    rdfs:label 'Headquarters Address' ;
    rdfs:comment 'Full street address of the firm\'s registered headquarters or principal place of business. Used for correspondence, legal notices, and geographic coverage analysis.' ;
    rdfs:domain ind:FirmProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersCity rdf:type rdf:Property ;
    rdfs:label 'Headquarters City' ;
    rdfs:comment 'City of the firm\'s registered headquarters or principal place of business.' ;
    rdfs:domain ind:FirmProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersCountry rdf:type rdf:Property ;
    rdfs:label 'Headquarters Country' ;
    rdfs:comment 'ISO 3166-1 alpha-3 three-letter country code of the firm\'s registered headquarters country.' ;
    rdfs:domain ind:FirmProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersPostalCode rdf:type rdf:Property ;
    rdfs:label 'Headquarters Postal Code' ;
    rdfs:comment 'Postal or ZIP code of the firm\'s registered headquarters address.' ;
    rdfs:domain ind:FirmProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersState rdf:type rdf:Property ;
    rdfs:label 'Headquarters State' ;
    rdfs:comment 'Two-letter state or province code of the firm\'s registered headquarters.' ;
    rdfs:domain ind:FirmProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceGlExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Insurance Gl Expiry Date' ;
    rdfs:comment 'Expiry date of the firm\'s General Liability (GL) insurance certificate on file. Firms with expired GL insurance are blocked from site mobilization. Tracked separately from workers\' compensation and professional indemnity.' ;
    rdfs:domain ind:FirmProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:insuranceWcExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Insurance Wc Expiry Date' ;
    rdfs:comment 'Expiry date of the firm\'s Workers\' Compensation (WC) insurance certificate on file. Required for all firms deploying labor on construction sites. Expiry triggers compliance hold on site access.' ;
    rdfs:domain ind:FirmProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isUnionShop rdf:type rdf:Property ;
    rdfs:label 'Is Union Shop' ;
    rdfs:comment 'Indicates whether the subcontracting firm operates as a union shop (True) or open/merit shop (False). Determines eligibility for union-mandated project requirements and prevailing wage projects.' ;
    rdfs:domain ind:FirmProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:leedAccredited rdf:type rdf:Property ;
    rdfs:label 'Leed Accredited' ;
    rdfs:comment 'Indicates whether the firm holds LEED (Leadership in Energy and Environmental Design) accreditation or employs LEED-accredited professionals. Relevant for green building projects requiring LEED-certified subcontractors.' ;
    rdfs:domain ind:FirmProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mbeCertified rdf:type rdf:Property ;
    rdfs:label 'Mbe Certified' ;
    rdfs:comment 'Indicates whether the firm holds a valid Minority Business Enterprise (MBE) certification. Used for diversity spend tracking, DBE/MBE/WBE compliance reporting on federally funded projects, and supplier diversity program management.' ;
    rdfs:domain ind:FirmProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:naicsCode rdf:type rdf:Property ;
    rdfs:label 'Naics Code' ;
    rdfs:comment 'Six-digit North American Industry Classification System (NAICS) code identifying the firm\'s primary industry sector. Used for regulatory reporting, diversity spend tracking, and market segmentation analytics.' ;
    rdfs:domain ind:FirmProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryTradeClassification rdf:type rdf:Property ;
    rdfs:label 'Primary Trade Classification' ;
    rdfs:comment 'The principal construction trade or specialty discipline the firm is classified under (e.g., MEP - Mechanical Electrical Plumbing, Civil Works, Structural Steel, Concrete, Roofing, Earthworks, Specialty). Determines which trade packages the firm is eligible to bid on. [ENUM-REF-CANDIDATE: mep_mechanical|mep_electrical|mep_plumbing|civil|structural_steel|concrete|earthworks|roofing|glazing|fit_out|specialty — promote to reference product]' ;
    rdfs:domain ind:FirmProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sicCode rdf:type rdf:Property ;
    rdfs:label 'Sic Code' ;
    rdfs:comment 'Four-digit Standard Industrial Classification (SIC) code for the subcontracting firm. Used for legacy regulatory reporting, insurance underwriting, and cross-referencing with older procurement systems.' ;
    rdfs:domain ind:FirmProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:singleProjectBondLimitUsd rdf:type rdf:Property ;
    rdfs:label 'Single Project Bond Limit Usd' ;
    rdfs:comment 'Maximum bonding capacity for a single project in US dollars, as distinct from the aggregate bonding capacity. Used to assess the firm\'s eligibility for individual trade package awards.' ;
    rdfs:domain ind:FirmProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stateOfIncorporation rdf:type rdf:Property ;
    rdfs:label 'State Of Incorporation' ;
    rdfs:comment 'Two-letter state or province code where the firm is incorporated or registered (e.g., CA, TX, NY). Relevant for US-based entities for licensing and lien law compliance.' ;
    rdfs:domain ind:FirmProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trir rdf:type rdf:Property ;
    rdfs:label 'Trir' ;
    rdfs:comment 'Total Recordable Incident Rate (TRIR) — the number of OSHA-recordable incidents per 200,000 man-hours worked. A key HSE performance indicator used in subcontractor prequalification and ongoing performance evaluation.' ;
    rdfs:domain ind:FirmProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unionAffiliation rdf:type rdf:Property ;
    rdfs:label 'Union Affiliation' ;
    rdfs:comment 'Name or code of the labor union(s) the firm is affiliated with (e.g., IBEW, UA, Laborers International). Relevant for union project requirements, prevailing wage compliance, and collective bargaining agreement adherence.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wbeCertified rdf:type rdf:Property ;
    rdfs:label 'Wbe Certified' ;
    rdfs:comment 'Indicates whether the firm holds a valid Women-Owned Business Enterprise (WBE) certification. Used for diversity spend tracking and compliance reporting on projects with WBE participation goals.' ;
    rdfs:domain ind:FirmProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:yearsInBusiness rdf:type rdf:Property ;
    rdfs:label 'Years In Business' ;
    rdfs:comment 'Number of years the subcontracting firm has been in continuous operation since its founding or incorporation date. Used as a stability and experience indicator in prequalification scoring.' ;
    rdfs:domain ind:FirmProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:insuranceCertificateId rdf:type rdf:Property ;
    rdfs:label 'Insurance Certificate Id' ;
    rdfs:comment 'Unique identifier for the insurance certificate record. Primary key.' ;
    rdfs:domain ind:InsuranceCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:verifiedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Verified By Employee Id' ;
    rdfs:comment 'Foreign key linking to hr.employee. Business justification: Insurance compliance verification is performed by a designated HR/compliance employee; needed for regulatory reporting.' ;
    rdfs:domain ind:InsuranceCertificate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:additionalInsuredFlag rdf:type rdf:Property ;
    rdfs:label 'Additional Insured Flag' ;
    rdfs:comment 'Indicates whether the general contractor is named as an additional insured on the policy. Critical for liability protection and contract compliance.' ;
    rdfs:domain ind:InsuranceCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:aggregateLimit rdf:type rdf:Property ;
    rdfs:label 'Aggregate Limit' ;
    rdfs:comment 'The maximum amount the insurer will pay for all claims during the policy period. Distinct from per-occurrence coverage limits.' ;
    rdfs:domain ind:InsuranceCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:certificateHolderAddress rdf:type rdf:Property ;
    rdfs:label 'Certificate Holder Address' ;
    rdfs:comment 'The address of the certificate holder. Used for correspondence and verification purposes.' ;
    rdfs:domain ind:InsuranceCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificateHolderName rdf:type rdf:Property ;
    rdfs:label 'Certificate Holder Name' ;
    rdfs:comment 'The name of the entity to whom the certificate is issued, typically the general contractor or project owner. Confirms the certificate is issued for the correct party.' ;
    rdfs:domain ind:InsuranceCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coverageCurrency rdf:type rdf:Property ;
    rdfs:label 'Coverage Currency' ;
    rdfs:comment 'The currency in which the coverage amount is denominated. Three-letter ISO 4217 currency code.' ;
    rdfs:domain ind:InsuranceCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insurerRating rdf:type rdf:Property ;
    rdfs:label 'Insurer Rating' ;
    rdfs:comment 'The financial strength rating of the insurance company (e.g., A.M. Best rating). Used to assess the reliability and solvency of the insurer.' ;
    rdfs:domain ind:InsuranceCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nonComplianceReason rdf:type rdf:Property ;
    rdfs:label 'Non Compliance Reason' ;
    rdfs:comment 'The specific reason why the certificate is marked as non-compliant. Drives corrective action and communication with the subcontractor.' ;
    rdfs:domain ind:InsuranceCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:perOccurrenceLimit rdf:type rdf:Property ;
    rdfs:label 'Per Occurrence Limit' ;
    rdfs:comment 'The maximum amount the insurer will pay for a single claim or occurrence. Used to assess adequacy of coverage for high-risk activities.' ;
    rdfs:domain ind:InsuranceCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:primaryNonContributoryFlag rdf:type rdf:Property ;
    rdfs:label 'Primary Non Contributory Flag' ;
    rdfs:comment 'Indicates whether the subcontractor\'s insurance is primary and non-contributory to the general contractor\'s coverage. Ensures the subcontractor\'s policy pays first.' ;
    rdfs:domain ind:InsuranceCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:renewalReminderSentDate rdf:type rdf:Property ;
    rdfs:label 'Renewal Reminder Sent Date' ;
    rdfs:comment 'The date when a renewal reminder was sent to the subcontractor. Used to track proactive compliance management efforts.' ;
    rdfs:domain ind:InsuranceCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:waiverOfSubrogationFlag rdf:type rdf:Property ;
    rdfs:label 'Waiver Of Subrogation Flag' ;
    rdfs:comment 'Indicates whether the policy includes a waiver of subrogation in favor of the general contractor. Prevents the insurer from pursuing claims against the GC.' ;
    rdfs:domain ind:InsuranceCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lienWaiverId rdf:type rdf:Property ;
    rdfs:label 'Lien Waiver Id' ;
    rdfs:comment 'System-generated unique identifier for the lien waiver record.' ;
    rdfs:domain ind:LienWaiver ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:complianceMet rdf:type rdf:Property ;
    rdfs:label 'Compliance Met' ;
    rdfs:comment 'Indicates whether the waiver satisfies all statutory and contractual compliance requirements.' ;
    rdfs:domain ind:LienWaiver ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:filingDate rdf:type rdf:Property ;
    rdfs:label 'Filing Date' ;
    rdfs:comment 'Date the lien waiver was filed with the jurisdictional authority.' ;
    rdfs:domain ind:LienWaiver ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:filingReference rdf:type rdf:Property ;
    rdfs:label 'Filing Reference' ;
    rdfs:comment 'Reference number or identifier for the filing of the lien waiver with the appropriate authority.' ;
    rdfs:domain ind:LienWaiver ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jurisdictionState rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction State' ;
    rdfs:comment 'U.S. state or jurisdiction where the lien waiver is legally effective.' ;
    rdfs:domain ind:LienWaiver ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notarizationDate rdf:type rdf:Property ;
    rdfs:label 'Notarization Date' ;
    rdfs:comment 'Date the notarization of the lien waiver was completed.' ;
    rdfs:domain ind:LienWaiver ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:notarizationStatus rdf:type rdf:Property ;
    rdfs:label 'Notarization Status' ;
    rdfs:comment 'Indicates whether the waiver has been notarized.' ;
    rdfs:domain ind:LienWaiver ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waiverStatus rdf:type rdf:Property ;
    rdfs:label 'Waiver Status' ;
    rdfs:comment 'Current lifecycle status of the lien waiver.' ;
    rdfs:domain ind:LienWaiver ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amountCertifiedCurrent rdf:type rdf:Property ;
    rdfs:label 'Amount Certified Current' ;
    rdfs:comment 'Amount certified and approved by the certifying engineer or project manager for payment in this application, which may differ from the amount claimed if adjustments are made.' ;
    rdfs:domain ind:PaymentApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:amountClaimedCurrent rdf:type rdf:Property ;
    rdfs:label 'Amount Claimed Current' ;
    rdfs:comment 'Gross amount claimed by the subcontractor for work performed during this billing period before retention and back-charges.' ;
    rdfs:domain ind:PaymentApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:amountPreviouslyCertified rdf:type rdf:Property ;
    rdfs:label 'Amount Previously Certified' ;
    rdfs:comment 'Cumulative amount certified and approved in all previous payment applications prior to this one.' ;
    rdfs:domain ind:PaymentApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:backChargesApplied rdf:type rdf:Property ;
    rdfs:label 'Back Charges Applied' ;
    rdfs:comment 'Total back-charges deducted from this payment application for costs incurred by the general contractor to correct deficiencies, delays, or damages caused by the subcontractor.' ;
    rdfs:domain ind:PaymentApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contractValueOriginal rdf:type rdf:Property ;
    rdfs:label 'Contract Value Original' ;
    rdfs:comment 'Original total value of the subcontract agreement before any change orders or modifications.' ;
    rdfs:domain ind:PaymentApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contractValueRevised rdf:type rdf:Property ;
    rdfs:label 'Contract Value Revised' ;
    rdfs:comment 'Current total value of the subcontract including all approved change orders (CO) and modifications to date.' ;
    rdfs:domain ind:PaymentApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lienWaiverReceived rdf:type rdf:Property ;
    rdfs:label 'Lien Waiver Received' ;
    rdfs:comment 'Indicates whether a conditional or unconditional lien waiver has been received from the subcontractor for this payment application.' ;
    rdfs:domain ind:PaymentApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:materialsStoredToDate rdf:type rdf:Property ;
    rdfs:label 'Materials Stored To Date' ;
    rdfs:comment 'Cumulative value of materials delivered to site and properly stored but not yet incorporated into the work, eligible for payment per contract terms.' ;
    rdfs:domain ind:PaymentApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:otherDeductions rdf:type rdf:Property ;
    rdfs:label 'Other Deductions' ;
    rdfs:comment 'Other miscellaneous deductions applied to this payment application (e.g., insurance adjustments, warranty holdbacks, disputed amounts).' ;
    rdfs:domain ind:PaymentApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:percentCompleteCertified rdf:type rdf:Property ;
    rdfs:label 'Percent Complete Certified' ;
    rdfs:comment 'Overall percentage of contract work completion certified by the project engineer or quantity surveyor, which may differ from the claimed percentage after field verification.' ;
    rdfs:domain ind:PaymentApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:percentCompleteClaimed rdf:type rdf:Property ;
    rdfs:label 'Percent Complete Claimed' ;
    rdfs:comment 'Overall percentage of contract work completion claimed by the subcontractor in this payment application, calculated from Schedule of Values (SOV) line items.' ;
    rdfs:domain ind:PaymentApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:retentionReleaseMilestone rdf:type rdf:Property ;
    rdfs:label 'Retention Release Milestone' ;
    rdfs:comment 'The contractual milestone triggering retention release (practical completion, DLP expiry, final completion, or partial release per contract terms).' ;
    rdfs:domain ind:PaymentApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retentionReleasedCurrent rdf:type rdf:Property ;
    rdfs:label 'Retention Released Current' ;
    rdfs:comment 'Amount of previously withheld retention released to the subcontractor in this payment application, typically upon reaching practical completion or DLP (Defects Liability Period) expiry milestone.' ;
    rdfs:domain ind:PaymentApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:retentionWithheldCurrent rdf:type rdf:Property ;
    rdfs:label 'Retention Withheld Current' ;
    rdfs:comment 'Amount of retention withheld from the current billing period payment based on the retention percentage.' ;
    rdfs:domain ind:PaymentApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:retentionWithheldTotal rdf:type rdf:Property ;
    rdfs:label 'Retention Withheld Total' ;
    rdfs:comment 'Cumulative retention amount withheld from all payment applications to date.' ;
    rdfs:domain ind:PaymentApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:supportingDocumentsSubmitted rdf:type rdf:Property ;
    rdfs:label 'Supporting Documents Submitted' ;
    rdfs:comment 'Indicates whether all required supporting documentation (lien waivers, certified payroll, insurance certificates, progress photos) has been submitted with this payment application.' ;
    rdfs:domain ind:PaymentApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:totalEarnedToDate rdf:type rdf:Property ;
    rdfs:label 'Total Earned To Date' ;
    rdfs:comment 'Total amount earned by the subcontractor through this billing period (work completed plus materials stored).' ;
    rdfs:domain ind:PaymentApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:performanceScorecardId rdf:type rdf:Property ;
    rdfs:label 'Performance Scorecard Id' ;
    rdfs:comment 'Unique identifier for the subcontractor performance scorecard evaluation record.' ;
    rdfs:domain ind:PerformanceScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:evaluatorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Evaluator Employee Id' ;
    rdfs:comment 'Foreign key linking to hr.employee. Business justification: Scorecard evaluations are conducted by a specific employee; linking enables traceability and performance analytics.' ;
    rdfs:domain ind:PerformanceScorecard ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:performanceEsgReportId rdf:type rdf:Property ;
    rdfs:label 'Performance Esg Report Id' ;
    rdfs:comment 'Foreign key linking to sustainability.esg_report. Business justification: Scorecards evaluate subcontractor performance against ESG metrics; storing the ESG report used for assessment enables traceability.' ;
    rdfs:domain ind:PerformanceScorecard ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EsgReport .

ind:bidEligibilityStatus rdf:type rdf:Property ;
    rdfs:label 'Bid Eligibility Status' ;
    rdfs:comment 'Current bid eligibility status resulting from this performance evaluation: eligible for all future bids, restricted to certain project types, or ineligible for future bidding.' ;
    rdfs:domain ind:PerformanceScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeOrderDisputes rdf:type rdf:Property ;
    rdfs:label 'Change Order Disputes' ;
    rdfs:comment 'Number of disputed or contested change orders raised by or against the subcontractor during the evaluation period.' ;
    rdfs:domain ind:PerformanceScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:commercialConductScore rdf:type rdf:Property ;
    rdfs:label 'Commercial Conduct Score' ;
    rdfs:comment 'Numeric score (0-100) representing the subcontractor\'s commercial conduct including responsiveness to instructions, cooperation, documentation quality, and change order management.' ;
    rdfs:domain ind:PerformanceScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:evaluatorComments rdf:type rdf:Property ;
    rdfs:label 'Evaluator Comments' ;
    rdfs:comment 'Free-text comments and observations from the evaluator providing additional context, specific incidents, or qualitative assessment details.' ;
    rdfs:domain ind:PerformanceScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evaluatorRole rdf:type rdf:Property ;
    rdfs:label 'Evaluator Role' ;
    rdfs:comment 'The role or title of the person who conducted the evaluation (e.g., Project Manager, Construction Manager, PMO Director).' ;
    rdfs:domain ind:PerformanceScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:followUpRequired rdf:type rdf:Property ;
    rdfs:label 'Follow Up Required' ;
    rdfs:comment 'Boolean flag indicating whether follow-up actions, meetings, or corrective action plans are required based on this performance evaluation.' ;
    rdfs:domain ind:PerformanceScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hseComplianceViolations rdf:type rdf:Property ;
    rdfs:label 'Hse Compliance Violations' ;
    rdfs:comment 'Number of HSE compliance violations or safety infractions recorded during the evaluation period.' ;
    rdfs:domain ind:PerformanceScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hseLtiCount rdf:type rdf:Property ;
    rdfs:label 'Hse Lti Count' ;
    rdfs:comment 'Total number of Lost Time Injuries recorded for the subcontractor\'s workforce during the evaluation period.' ;
    rdfs:domain ind:PerformanceScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hseScore rdf:type rdf:Property ;
    rdfs:label 'Hse Score' ;
    rdfs:comment 'Numeric score (0-100) representing the subcontractor\'s overall HSE compliance and safety performance during the evaluation period.' ;
    rdfs:domain ind:PerformanceScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hseTrir rdf:type rdf:Property ;
    rdfs:label 'Hse Trir' ;
    rdfs:comment 'Total Recordable Incident Rate calculated as (Number of OSHA recordable incidents × 200,000) / Total hours worked. Industry standard HSE metric.' ;
    rdfs:domain ind:PerformanceScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:improvementAreas rdf:type rdf:Property ;
    rdfs:label 'Improvement Areas' ;
    rdfs:comment 'Detailed description of specific areas where the subcontractor needs to improve performance, including corrective actions required.' ;
    rdfs:domain ind:PerformanceScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overallRating rdf:type rdf:Property ;
    rdfs:label 'Overall Rating' ;
    rdfs:comment 'Overall categorical performance rating summarizing the subcontractor\'s performance across all evaluation dimensions.' ;
    rdfs:domain ind:PerformanceScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overallScore rdf:type rdf:Property ;
    rdfs:label 'Overall Score' ;
    rdfs:comment 'Weighted overall performance score (0-100) calculated from individual category scores (schedule, quality, HSE, productivity, commercial conduct).' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:prequalificationImpact rdf:type rdf:Property ;
    rdfs:label 'Prequalification Impact' ;
    rdfs:comment 'Impact of this performance scorecard on the subcontractor\'s prequalification status for future projects: automatic renewal, conditional renewal, requires detailed review, or disqualification.' ;
    rdfs:domain ind:PerformanceScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productivityScore rdf:type rdf:Property ;
    rdfs:label 'Productivity Score' ;
    rdfs:comment 'Numeric score (0-100) representing the subcontractor\'s productivity and efficiency in completing assigned work during the evaluation period.' ;
    rdfs:domain ind:PerformanceScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:productivityUnitsCompleted rdf:type rdf:Property ;
    rdfs:label 'Productivity Units Completed' ;
    rdfs:comment 'Total quantity of work units completed by the subcontractor during the evaluation period (e.g., cubic meters of concrete, linear meters of pipe, square meters of formwork).' ;
    rdfs:domain ind:PerformanceScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualityNcrCount rdf:type rdf:Property ;
    rdfs:label 'Quality Ncr Count' ;
    rdfs:comment 'Total number of Non-Conformance Reports issued against the subcontractor during the evaluation period.' ;
    rdfs:domain ind:PerformanceScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:qualityNcrRate rdf:type rdf:Property ;
    rdfs:label 'Quality Ncr Rate' ;
    rdfs:comment 'Rate of Non-Conformance Reports per unit of work completed (e.g., NCRs per 1000 work hours or per million dollars of work).' ;
    rdfs:domain ind:PerformanceScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recommendedAction rdf:type rdf:Property ;
    rdfs:label 'Recommended Action' ;
    rdfs:comment 'Recommended action based on the performance evaluation outcome: continue engagement, monitor closely, require improvement plan, place on watch-list, disqualify from future bids, or suspend from current work.' ;
    rdfs:domain ind:PerformanceScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rfiResponseTimelinessScore rdf:type rdf:Property ;
    rdfs:label 'Rfi Response Timeliness Score' ;
    rdfs:comment 'Score (0-100) measuring the subcontractor\'s timeliness in responding to RFIs and providing requested information.' ;
    rdfs:domain ind:PerformanceScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scheduleAdherenceSpi rdf:type rdf:Property ;
    rdfs:label 'Schedule Adherence Spi' ;
    rdfs:comment 'Schedule Performance Index measuring the subcontractor\'s adherence to planned schedule. SPI = Earned Value / Planned Value. Values >1.0 indicate ahead of schedule, <1.0 indicate behind schedule.' ;
    rdfs:domain ind:PerformanceScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:strengths rdf:type rdf:Property ;
    rdfs:label 'Strengths' ;
    rdfs:comment 'Description of the subcontractor\'s key strengths and positive performance aspects observed during the evaluation period.' ;
    rdfs:domain ind:PerformanceScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subcontractorAcknowledgementDate rdf:type rdf:Property ;
    rdfs:label 'Subcontractor Acknowledgement Date' ;
    rdfs:comment 'Date on which the subcontractor acknowledged receipt and review of the performance scorecard.' ;
    rdfs:domain ind:PerformanceScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:subcontractorResponse rdf:type rdf:Property ;
    rdfs:label 'Subcontractor Response' ;
    rdfs:comment 'Subcontractor\'s formal response or comments regarding the performance evaluation, including any disputes or corrective action commitments.' ;
    rdfs:domain ind:PerformanceScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subcontractorBondId rdf:type rdf:Property ;
    rdfs:label 'Subcontractor Bond Id' ;
    rdfs:comment 'Primary key for subcontractor_bond' ;
    rdfs:domain ind:SubcontractorBond ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:alertThresholdDays rdf:type rdf:Property ;
    rdfs:label 'Alert Threshold Days' ;
    rdfs:comment 'Number of days before expiry at which an alert should be triggered for bond renewal or replacement (e.g., 30, 60, 90 days).' ;
    rdfs:domain ind:SubcontractorBond ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bondCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Bond Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the bond amount (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:SubcontractorBond ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bondForm rdf:type rdf:Property ;
    rdfs:label 'Bond Form' ;
    rdfs:comment 'Standard bond form or template used: AIA A311 (performance and payment bond), AIA A312 (performance and payment bond - current), FIDIC (international standard), custom (project-specific), or statutory (government-mandated form).' ;
    rdfs:domain ind:SubcontractorBond ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bondPercentage rdf:type rdf:Property ;
    rdfs:label 'Bond Percentage' ;
    rdfs:comment 'Bond amount expressed as a percentage of the subcontract value (e.g., 10.00 for 10% performance bond).' ;
    rdfs:domain ind:SubcontractorBond ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bondPremiumRate rdf:type rdf:Property ;
    rdfs:label 'Bond Premium Rate' ;
    rdfs:comment 'Premium rate expressed as a percentage of the bond amount (e.g., 0.0150 for 1.5% premium rate).' ;
    rdfs:domain ind:SubcontractorBond ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:claimFiledDate rdf:type rdf:Property ;
    rdfs:label 'Claim Filed Date' ;
    rdfs:comment 'Date on which a claim was filed against the bond by the obligee. Null if no claim has been filed.' ;
    rdfs:domain ind:SubcontractorBond ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:claimPaidAmount rdf:type rdf:Property ;
    rdfs:label 'Claim Paid Amount' ;
    rdfs:comment 'Amount paid by the surety to settle the claim. Null if no payment made or no claim filed.' ;
    rdfs:domain ind:SubcontractorBond ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:complianceVerifiedBy rdf:type rdf:Property ;
    rdfs:label 'Compliance Verified By' ;
    rdfs:comment 'Name or identifier of the person or system that last verified bond compliance.' ;
    rdfs:domain ind:SubcontractorBond ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceVerifiedDate rdf:type rdf:Property ;
    rdfs:label 'Compliance Verified Date' ;
    rdfs:comment 'Date on which the bond was last verified for compliance with contract requirements (amount, surety rating, expiry).' ;
    rdfs:domain ind:SubcontractorBond ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:obligeeName rdf:type rdf:Property ;
    rdfs:label 'Obligee Name' ;
    rdfs:comment 'Name of the party protected by the bond, typically the general contractor (GC) or project owner.' ;
    rdfs:domain ind:SubcontractorBond ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:principalName rdf:type rdf:Property ;
    rdfs:label 'Principal Name' ;
    rdfs:comment 'Name of the principal party (subcontractor) whose performance is guaranteed by the bond.' ;
    rdfs:domain ind:SubcontractorBond ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:suretyCompanyAmBestRating rdf:type rdf:Property ;
    rdfs:label 'Surety Company Am Best Rating' ;
    rdfs:comment 'AM Best financial strength rating of the surety company (e.g., A++, A+, A, A-, B++). Indicates the surety\'s ability to meet its obligations.' ;
    rdfs:domain ind:SubcontractorBond ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:suretyCompanyName rdf:type rdf:Property ;
    rdfs:label 'Surety Company Name' ;
    rdfs:comment 'Legal name of the surety company or insurance carrier issuing the bond.' ;
    rdfs:domain ind:SubcontractorBond ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:suretyLicenseNumber rdf:type rdf:Property ;
    rdfs:label 'Surety License Number' ;
    rdfs:comment 'State or jurisdiction license number of the surety company authorizing it to issue bonds.' ;
    rdfs:domain ind:SubcontractorBond ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subcontractorChangeOrderId rdf:type rdf:Property ;
    rdfs:label 'Subcontractor Change Order Id' ;
    rdfs:comment 'Unique identifier for the subcontractor change order record. Primary key.' ;
    rdfs:domain ind:SubcontractorChangeOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:initiatedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Initiated By Employee Id' ;
    rdfs:comment 'Foreign key linking to hr.employee. Business justification: Change Order Initiation is recorded by the employee who raises it; required for audit trail and approval workflow.' ;
    rdfs:domain ind:SubcontractorChangeOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:changeAmount rdf:type rdf:Property ;
    rdfs:label 'Change Amount' ;
    rdfs:comment 'The net financial impact of this change order on the subcontract value. Positive for additions, negative for reductions, in the contract currency.' ;
    rdfs:domain ind:SubcontractorChangeOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coDescription rdf:type rdf:Property ;
    rdfs:label 'Co Description' ;
    rdfs:comment 'Detailed narrative describing the scope, rationale, and impact of the change order on the subcontract.' ;
    rdfs:domain ind:SubcontractorChangeOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coTitle rdf:type rdf:Property ;
    rdfs:label 'Co Title' ;
    rdfs:comment 'Short descriptive title summarizing the nature of the change order.' ;
    rdfs:domain ind:SubcontractorChangeOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contingencyAllocation rdf:type rdf:Property ;
    rdfs:label 'Contingency Allocation' ;
    rdfs:comment 'Amount of project contingency budget allocated to cover this change order, in the contract currency. Null if not funded from contingency.' ;
    rdfs:domain ind:SubcontractorChangeOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:executionCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Execution Completion Date' ;
    rdfs:comment 'The date on which work on the change order scope was completed on site, in yyyy-MM-dd format. Null if not yet completed.' ;
    rdfs:domain ind:SubcontractorChangeOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:executionStartDate rdf:type rdf:Property ;
    rdfs:label 'Execution Start Date' ;
    rdfs:comment 'The date on which work on the change order scope commenced on site, in yyyy-MM-dd format. Null if not yet started.' ;
    rdfs:domain ind:SubcontractorChangeOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isBackCharge rdf:type rdf:Property ;
    rdfs:label 'Is Back Charge' ;
    rdfs:comment 'Boolean flag indicating whether this change order represents a back charge to the subcontractor for defective work, delays, or other contractual breaches. True if back charge, False otherwise.' ;
    rdfs:domain ind:SubcontractorChangeOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isTimeAndMaterial rdf:type rdf:Property ;
    rdfs:label 'Is Time And Material' ;
    rdfs:comment 'Boolean flag indicating whether this change order is priced on a time-and-material basis rather than lump sum. True if T&M, False otherwise.' ;
    rdfs:domain ind:SubcontractorChangeOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tradePackage rdf:type rdf:Property ;
    rdfs:label 'Trade Package' ;
    rdfs:comment 'The trade or specialty package to which this change order applies (e.g., MEP, civil works, structural steel, concrete, finishes).' ;
    rdfs:domain ind:SubcontractorChangeOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subcontractorEotClaimId rdf:type rdf:Property ;
    rdfs:label 'Subcontractor Eot Claim Id' ;
    rdfs:comment 'Primary key for eot_claim' ;
    rdfs:domain ind:SubcontractorEotClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:baselineScheduleReference rdf:type rdf:Property ;
    rdfs:label 'Baseline Schedule Reference' ;
    rdfs:comment 'Reference identifier for the approved baseline schedule used as the basis for delay analysis and EOT assessment.' ;
    rdfs:domain ind:SubcontractorEotClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimSubmissionMethod rdf:type rdf:Property ;
    rdfs:label 'Claim Submission Method' ;
    rdfs:comment 'Method or channel through which the subcontractor submitted the EOT claim to the main contractor.' ;
    rdfs:domain ind:SubcontractorEotClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:concurrentDelayFlag rdf:type rdf:Property ;
    rdfs:label 'Concurrent Delay Flag' ;
    rdfs:comment 'Indicates whether the delay event occurred concurrently with other delays for which the subcontractor is responsible, affecting EOT entitlement.' ;
    rdfs:domain ind:SubcontractorEotClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contemporaneousRecordsReference rdf:type rdf:Property ;
    rdfs:label 'Contemporaneous Records Reference' ;
    rdfs:comment 'Reference identifiers or document numbers for contemporaneous project records (daily logs, progress reports, site instructions, correspondence) supporting the EOT claim.' ;
    rdfs:domain ind:SubcontractorEotClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costClaimAssociatedFlag rdf:type rdf:Property ;
    rdfs:label 'Cost Claim Associated Flag' ;
    rdfs:comment 'Indicates whether the subcontractor has submitted or intends to submit a separate cost claim for prolongation costs associated with this delay event.' ;
    rdfs:domain ind:SubcontractorEotClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:criticalPathImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Critical Path Impact Flag' ;
    rdfs:comment 'Indicates whether the delay event impacted activities on the project critical path, a key determinant of EOT entitlement.' ;
    rdfs:domain ind:SubcontractorEotClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:daysGranted rdf:type rdf:Property ;
    rdfs:label 'Days Granted' ;
    rdfs:comment 'Number of calendar days of schedule extension formally approved and granted to the subcontractor, adjusting the contractual completion date.' ;
    rdfs:domain ind:SubcontractorEotClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:delayCauseCategory rdf:type rdf:Property ;
    rdfs:label 'Delay Cause Category' ;
    rdfs:comment 'Classification of the root cause of the delay event determining entitlement and risk allocation under the subcontract terms.' ;
    rdfs:domain ind:SubcontractorEotClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:determinationAuthority rdf:type rdf:Property ;
    rdfs:label 'Determination Authority' ;
    rdfs:comment 'Name and role of the individual or entity authorized to make the determination decision on the EOT claim (e.g., Project Manager, Contract Administrator, Engineer).' ;
    rdfs:domain ind:SubcontractorEotClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:determinationDate rdf:type rdf:Property ;
    rdfs:label 'Determination Date' ;
    rdfs:comment 'Date when the contract administrator or project management office issued the formal determination decision on the EOT claim.' ;
    rdfs:domain ind:SubcontractorEotClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:determinationRationale rdf:type rdf:Property ;
    rdfs:label 'Determination Rationale' ;
    rdfs:comment 'Detailed explanation and justification for the determination decision, including reasons for any variance between days claimed and days granted.' ;
    rdfs:domain ind:SubcontractorEotClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ldExposureImpact rdf:type rdf:Property ;
    rdfs:label 'Ld Exposure Impact' ;
    rdfs:comment 'Assessment of how the granted EOT affects the subcontractor\'s exposure to liquidated damages for late completion.' ;
    rdfs:domain ind:SubcontractorEotClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:noticeComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Notice Compliance Flag' ;
    rdfs:comment 'Indicates whether the subcontractor complied with contractual notice requirements and timelines, which may affect claim entitlement.' ;
    rdfs:domain ind:SubcontractorEotClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scheduleAnalysisMethod rdf:type rdf:Property ;
    rdfs:label 'Schedule Analysis Method' ;
    rdfs:comment 'Methodology used to analyze the delay impact and quantify the time extension, following industry-standard delay analysis protocols.' ;
    rdfs:domain ind:SubcontractorEotClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportingDocumentationCount rdf:type rdf:Property ;
    rdfs:label 'Supporting Documentation Count' ;
    rdfs:comment 'Number of supporting documents (schedules, correspondence, photos, reports) attached to the EOT claim submission.' ;
    rdfs:domain ind:SubcontractorEotClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:subcontractorPrequalificationId rdf:type rdf:Property ;
    rdfs:label 'Subcontractor Prequalification Id' ;
    rdfs:comment 'Unique identifier for the subcontractor prequalification record.' ;
    rdfs:domain ind:SubcontractorPrequalification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primarySubcontractorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Subcontractor Employee Id' ;
    rdfs:comment 'Reference to the procurement or project management officer who conducted the prequalification evaluation and made the approval recommendation.' ;
    rdfs:domain ind:SubcontractorPrequalification ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:bondingLimitCurrency rdf:type rdf:Property ;
    rdfs:label 'Bonding Limit Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the bonding limit amount.' ;
    rdfs:domain ind:SubcontractorPrequalification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationRequirementsMet rdf:type rdf:Property ;
    rdfs:label 'Certification Requirements Met' ;
    rdfs:comment 'Indicates whether the subcontractor has provided all required industry certifications (ISO 9001, ISO 14001, ISO 45001, trade-specific licenses) as part of the prequalification.' ;
    rdfs:domain ind:SubcontractorPrequalification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:conditionalApprovalRequirements rdf:type rdf:Property ;
    rdfs:label 'Conditional Approval Requirements' ;
    rdfs:comment 'List of conditions or remedial actions the subcontractor must fulfill to convert conditional approval to full approval (e.g., submit updated insurance certificates, provide additional references).' ;
    rdfs:domain ind:SubcontractorPrequalification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eligibleProjectTypes rdf:type rdf:Property ;
    rdfs:label 'Eligible Project Types' ;
    rdfs:comment 'Comma-separated list of project types or sectors for which this prequalification is valid (e.g., commercial, infrastructure, energy, residential). Used to filter RFQ distribution.' ;
    rdfs:domain ind:SubcontractorPrequalification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialCapacityScore rdf:type rdf:Property ;
    rdfs:label 'Financial Capacity Score' ;
    rdfs:comment 'Evaluation score assessing the subcontractor\'s financial strength, liquidity, and ability to fund project work. Typically scored on a 0-100 scale.' ;
    rdfs:domain ind:SubcontractorPrequalification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:financialStatementsVerified rdf:type rdf:Property ;
    rdfs:label 'Financial Statements Verified' ;
    rdfs:comment 'Indicates whether the subcontractor\'s financial statements (balance sheet, P&L, cash flow) have been reviewed and verified by the evaluating officer or finance team.' ;
    rdfs:domain ind:SubcontractorPrequalification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:insuranceAdequacyScore rdf:type rdf:Property ;
    rdfs:label 'Insurance Adequacy Score' ;
    rdfs:comment 'Evaluation score assessing whether the subcontractor\'s insurance coverage (general liability, workers compensation, professional indemnity) meets project requirements. Typically scored on a 0-100 scale.' ;
    rdfs:domain ind:SubcontractorPrequalification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maximumContractCurrency rdf:type rdf:Property ;
    rdfs:label 'Maximum Contract Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the maximum contract value.' ;
    rdfs:domain ind:SubcontractorPrequalification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumContractValue rdf:type rdf:Property ;
    rdfs:label 'Maximum Contract Value' ;
    rdfs:comment 'Maximum trade package contract value the subcontractor is prequalified to bid on, based on financial capacity and bonding limits.' ;
    rdfs:domain ind:SubcontractorPrequalification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:referenceCheckCompleted rdf:type rdf:Property ;
    rdfs:label 'Reference Check Completed' ;
    rdfs:comment 'Indicates whether reference checks with previous clients or general contractors have been completed and verified as part of the evaluation process.' ;
    rdfs:domain ind:SubcontractorPrequalification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requalificationTrigger rdf:type rdf:Property ;
    rdfs:label 'Requalification Trigger' ;
    rdfs:comment 'Business event or condition that requires the subcontractor to undergo requalification before expiry date (e.g., major safety incident, financial distress, change in ownership, significant performance failure).' ;
    rdfs:domain ind:SubcontractorPrequalification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyRecordScore rdf:type rdf:Property ;
    rdfs:label 'Safety Record Score' ;
    rdfs:comment 'Evaluation score based on the subcontractor\'s historical safety performance, including TRIR (Total Recordable Incident Rate), LTI (Lost Time Injury) frequency, and HSE compliance. Typically scored on a 0-100 scale.' ;
    rdfs:domain ind:SubcontractorPrequalification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tradeCategory rdf:type rdf:Property ;
    rdfs:label 'Trade Category' ;
    rdfs:comment 'Primary trade or specialty category for which the subcontractor is being prequalified (e.g., MEP, civil works, structural steel, concrete, electrical, plumbing, HVAC).' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:awardedValue rdf:type rdf:Property ;
    rdfs:label 'Awarded Value' ;
    rdfs:comment 'Final contract value at which the trade package was awarded to the subcontractor.' ;
    rdfs:domain ind:TradePackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bidClosingDate rdf:type rdf:Property ;
    rdfs:label 'Bid Closing Date' ;
    rdfs:comment 'Deadline date by which subcontractors must submit their bids for this trade package.' ;
    rdfs:domain ind:TradePackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:bidOutDate rdf:type rdf:Property ;
    rdfs:label 'Bid Out Date' ;
    rdfs:comment 'Date when the trade package was issued to subcontractors for competitive bidding.' ;
    rdfs:domain ind:TradePackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:bondingRequired rdf:type rdf:Property ;
    rdfs:label 'Bonding Required' ;
    rdfs:comment 'Indicates whether performance and payment bonds are required from the subcontractor for this trade package.' ;
    rdfs:domain ind:TradePackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:budgetAllowance rdf:type rdf:Property ;
    rdfs:label 'Budget Allowance' ;
    rdfs:comment 'Budget allocation reserved for this trade package in the project cost plan.' ;
    rdfs:domain ind:TradePackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:csiMasterformatCode rdf:type rdf:Property ;
    rdfs:label 'Csi Masterformat Code' ;
    rdfs:comment 'CSI MasterFormat classification code for the scope of work (e.g., 03 30 00 for Cast-in-Place Concrete).' ;
    rdfs:domain ind:TradePackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:numberOfBiddersInvited rdf:type rdf:Property ;
    rdfs:label 'Number Of Bidders Invited' ;
    rdfs:comment 'Count of subcontractors invited to submit bids for this trade package.' ;
    rdfs:domain ind:TradePackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:numberOfBidsReceived rdf:type rdf:Property ;
    rdfs:label 'Number Of Bids Received' ;
    rdfs:comment 'Count of valid bids received from subcontractors by the bid closing date.' ;
    rdfs:domain ind:TradePackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:packagePriority rdf:type rdf:Property ;
    rdfs:label 'Package Priority' ;
    rdfs:comment 'Priority level of this trade package relative to other packages in the project (Critical, High, Medium, Low).' ;
    rdfs:domain ind:TradePackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packageReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Package Reference Number' ;
    rdfs:comment 'Externally-known unique reference number for the trade package used in bidding and contract documents.' ;
    rdfs:domain ind:TradePackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scopeNarrative rdf:type rdf:Property ;
    rdfs:label 'Scope Narrative' ;
    rdfs:comment 'Detailed textual description of the scope of work included in this trade package, including deliverables, exclusions, and boundaries.' ;
    rdfs:domain ind:TradePackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradeDisciplineCode rdf:type rdf:Property ;
    rdfs:label 'Trade Discipline Code' ;
    rdfs:comment 'Code representing the trade discipline (e.g., MEP, CIVIL, STRUCT, ARCH, ELEC, HVAC, PLUMB).' ;
    rdfs:domain ind:TradePackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:uniformatCode rdf:type rdf:Property ;
    rdfs:label 'Uniformat Code' ;
    rdfs:comment 'UniFormat II classification code for elemental cost planning (e.g., B2010 for Exterior Walls).' ;
    rdfs:domain ind:TradePackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:biodiversityAssessmentId rdf:type rdf:Property ;
    rdfs:label 'Biodiversity Assessment Id' ;
    rdfs:comment 'Unique identifier for each biodiversity assessment record.' ;
    rdfs:domain ind:BiodiversityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:baselineHabitatCondition rdf:type rdf:Property ;
    rdfs:label 'Baseline Habitat Condition' ;
    rdfs:comment 'Description of habitat condition before construction.' ;
    rdfs:domain ind:BiodiversityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:biodiversityUnitsGained rdf:type rdf:Property ;
    rdfs:label 'Biodiversity Units Gained' ;
    rdfs:comment 'Number of biodiversity units gained as a result of mitigation.' ;
    rdfs:domain ind:BiodiversityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:biodiversityUnitsLost rdf:type rdf:Property ;
    rdfs:label 'Biodiversity Units Lost' ;
    rdfs:comment 'Number of biodiversity units lost due to project impacts.' ;
    rdfs:domain ind:BiodiversityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:biodiversityUnitsPerHa rdf:type rdf:Property ;
    rdfs:label 'Biodiversity Units Per Ha' ;
    rdfs:comment 'Biodiversity units calculated per hectare of habitat.' ;
    rdfs:domain ind:BiodiversityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:climateRiskAssessment rdf:type rdf:Property ;
    rdfs:label 'Climate Risk Assessment' ;
    rdfs:comment 'Indicates whether a climate risk assessment was performed.' ;
    rdfs:domain ind:BiodiversityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:greenBuildingCertification rdf:type rdf:Property ;
    rdfs:label 'Green Building Certification' ;
    rdfs:comment 'Applicable green building certification(s) for the project.' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:habitatAreaHa rdf:type rdf:Property ;
    rdfs:label 'Habitat Area Ha' ;
    rdfs:comment 'Total area of the habitat in hectares.' ;
    rdfs:domain ind:BiodiversityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:habitatQualityScore rdf:type rdf:Property ;
    rdfs:label 'Habitat Quality Score' ;
    rdfs:comment 'Numeric score representing habitat quality (e.g., 0-1 scale).' ;
    rdfs:domain ind:BiodiversityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:metricFramework rdf:type rdf:Property ;
    rdfs:label 'Metric Framework' ;
    rdfs:comment 'Framework used for calculating biodiversity units.' ;
    rdfs:domain ind:BiodiversityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mitigationHierarchyApplied rdf:type rdf:Property ;
    rdfs:label 'Mitigation Hierarchy Applied' ;
    rdfs:comment 'Description of mitigation steps applied (avoid, minimise, restore, offset).' ;
    rdfs:domain ind:BiodiversityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monitoringPlanRequired rdf:type rdf:Property ;
    rdfs:label 'Monitoring Plan Required' ;
    rdfs:comment 'Indicates if a post-construction biodiversity monitoring plan is required.' ;
    rdfs:domain ind:BiodiversityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:monitoringStatus rdf:type rdf:Property ;
    rdfs:label 'Monitoring Status' ;
    rdfs:comment 'Current status of the biodiversity monitoring program.' ;
    rdfs:domain ind:BiodiversityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netBiodiversityUnits rdf:type rdf:Property ;
    rdfs:label 'Net Biodiversity Units' ;
    rdfs:comment 'Net biodiversity units (gained minus lost).' ;
    rdfs:domain ind:BiodiversityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:postConstructionHabitatCondition rdf:type rdf:Property ;
    rdfs:label 'Post Construction Habitat Condition' ;
    rdfs:comment 'Description of habitat condition after construction.' ;
    rdfs:domain ind:BiodiversityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:protectedSpeciesIdentified rdf:type rdf:Property ;
    rdfs:label 'Protected Species Identified' ;
    rdfs:comment 'Comma-separated list of protected species found on site.' ;
    rdfs:domain ind:BiodiversityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewer rdf:type rdf:Property ;
    rdfs:label 'Reviewer' ;
    rdfs:comment 'Name of the person who performed the latest review.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskAssessmentSummary rdf:type rdf:Property ;
    rdfs:label 'Risk Assessment Summary' ;
    rdfs:comment 'Brief summary of identified environmental risks.' ;
    rdfs:domain ind:BiodiversityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statutoryApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Statutory Approval Status' ;
    rdfs:comment 'Regulatory approval status for the assessment.' ;
    rdfs:domain ind:BiodiversityAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emissionSourceId rdf:type rdf:Property ;
    rdfs:label 'Emission Source Id' ;
    rdfs:comment 'Reference to the master record describing the specific emission source (e.g., a generator, vehicle, or process).' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EmissionSource .

ind:activityQuantity rdf:type rdf:Property ;
    rdfs:label 'Activity Quantity' ;
    rdfs:comment 'Measured amount of the activity (e.g., liters of fuel, kWh of electricity, tonnes of material).' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:activityUnit rdf:type rdf:Property ;
    rdfs:label 'Activity Unit' ;
    rdfs:comment 'Unit associated with the activity_quantity.' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:co2eTonnes rdf:type rdf:Property ;
    rdfs:label 'Co2e Tonnes' ;
    rdfs:comment 'Calculated carbon dioxide equivalent emissions for the record, expressed in metric tonnes.' ;
    rdfs:domain ind:CarbonEmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sourceCategory rdf:type rdf:Property ;
    rdfs:label 'Source Category' ;
    rdfs:comment 'High-level category of the emission source aligned with GHG Protocol definitions.' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carbonOffsetStatus rdf:type rdf:Property ;
    rdfs:label 'Carbon Offset Status' ;
    rdfs:comment 'Current lifecycle status of the offset transaction.' ;
    rdfs:domain ind:CarbonOffset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditType rdf:type rdf:Property ;
    rdfs:label 'Credit Type' ;
    rdfs:comment 'Category of emission reduction activity represented by the credit.' ;
    rdfs:domain ind:CarbonOffset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:esgReportPeriod rdf:type rdf:Property ;
    rdfs:label 'Esg Report Period' ;
    rdfs:comment 'Reporting period identifier (e.g., FY2023Q4) for which the offset is disclosed.' ;
    rdfs:domain ind:CarbonOffset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isRetired rdf:type rdf:Property ;
    rdfs:label 'Is Retired' ;
    rdfs:comment 'Indicates whether the offset credits have been retired (true) or are still active (false).' ;
    rdfs:domain ind:CarbonOffset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:offsetReference rdf:type rdf:Property ;
    rdfs:label 'Offset Reference' ;
    rdfs:comment 'External reference number or code assigned to the carbon offset transaction by the issuing registry or internal system.' ;
    rdfs:domain ind:CarbonOffset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:offsetStandard rdf:type rdf:Property ;
    rdfs:label 'Offset Standard' ;
    rdfs:comment 'Certification standard under which the offset credit is issued.' ;
    rdfs:domain ind:CarbonOffset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectCountryCode rdf:type rdf:Property ;
    rdfs:label 'Project Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code where the offset project is located.' ;
    rdfs:domain ind:CarbonOffset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectRegion rdf:type rdf:Property ;
    rdfs:label 'Project Region' ;
    rdfs:comment 'State, province, or region within the project country.' ;
    rdfs:domain ind:CarbonOffset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchasePriceUsd rdf:type rdf:Property ;
    rdfs:label 'Purchase Price Usd' ;
    rdfs:comment 'Monetary amount paid for the offset credits, expressed in US dollars.' ;
    rdfs:domain ind:CarbonOffset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityTco2e rdf:type rdf:Property ;
    rdfs:label 'Quantity Tco2e' ;
    rdfs:comment 'Number of metric tonnes of CO₂ equivalent that were offset.' ;
    rdfs:domain ind:CarbonOffset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:registryName rdf:type rdf:Property ;
    rdfs:label 'Registry Name' ;
    rdfs:comment 'Name of the registry where the offset credit is recorded (e.g., Verra Registry).' ;
    rdfs:domain ind:CarbonOffset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrySerialNumber rdf:type rdf:Property ;
    rdfs:label 'Registry Serial Number' ;
    rdfs:comment 'Unique serial number assigned by the registry to the specific offset credit.' ;
    rdfs:domain ind:CarbonOffset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retirementDate rdf:type rdf:Property ;
    rdfs:label 'Retirement Date' ;
    rdfs:comment 'Date on which the offset credits were officially retired or applied.' ;
    rdfs:domain ind:CarbonOffset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:retirementReason rdf:type rdf:Property ;
    rdfs:label 'Retirement Reason' ;
    rdfs:comment 'Reason why the offset credits were retired.' ;
    rdfs:domain ind:CarbonOffset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationBody rdf:type rdf:Property ;
    rdfs:label 'Verification Body' ;
    rdfs:comment 'Organization that performed the verification of the offset credit.' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vintageYear rdf:type rdf:Property ;
    rdfs:label 'Vintage Year' ;
    rdfs:comment 'Calendar year in which the offset project generated the credited emissions reductions.' ;
    rdfs:domain ind:CarbonOffset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:carbonReductionInitiativeId rdf:type rdf:Property ;
    rdfs:label 'Carbon Reduction Initiative Id' ;
    rdfs:comment 'System-generated unique identifier for each carbon reduction initiative.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CarbonReductionInitiative .

ind:actualCo2eSaving rdf:type rdf:Property ;
    rdfs:label 'Actual Co2e Saving' ;
    rdfs:comment 'Measured annual carbon dioxide equivalent reduction achieved, expressed in metric tonnes.' ;
    rdfs:domain ind:CarbonReductionInitiative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualCostCurrency rdf:type rdf:Property ;
    rdfs:label 'Actual Cost Currency' ;
    rdfs:comment 'Currency of the actual cost amount.' ;
    rdfs:domain ind:CarbonReductionInitiative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carbonReductionInitiativeDescription rdf:type rdf:Property ;
    rdfs:label 'Carbon Reduction Initiative Description' ;
    rdfs:comment 'Detailed free-text description of the initiative\'s objectives, scope, and approach.' ;
    rdfs:domain ind:CarbonReductionInitiative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carbonReductionInitiativeName rdf:type rdf:Property ;
    rdfs:label 'Carbon Reduction Initiative Name' ;
    rdfs:comment 'Descriptive name of the carbon reduction initiative.' ;
    rdfs:domain ind:CarbonReductionInitiative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carbonReductionInitiativeStatus rdf:type rdf:Property ;
    rdfs:label 'Carbon Reduction Initiative Status' ;
    rdfs:comment 'Current lifecycle status of the initiative.' ;
    rdfs:domain ind:CarbonReductionInitiative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carbonReductionMethodology rdf:type rdf:Property ;
    rdfs:label 'Carbon Reduction Methodology' ;
    rdfs:comment 'Methodology or standard used to calculate carbon reductions (e.g., PAS 2080, ISO 14064).' ;
    rdfs:domain ind:CarbonReductionInitiative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:climateRiskCategory rdf:type rdf:Property ;
    rdfs:label 'Climate Risk Category' ;
    rdfs:comment 'Categorisation of climate-related risk exposure for the initiative.' ;
    rdfs:domain ind:CarbonReductionInitiative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fundingAmount rdf:type rdf:Property ;
    rdfs:label 'Funding Amount' ;
    rdfs:comment 'Total amount of funding allocated to the initiative.' ;
    rdfs:domain ind:CarbonReductionInitiative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fundingCurrency rdf:type rdf:Property ;
    rdfs:label 'Funding Currency' ;
    rdfs:comment 'Currency of the funding amount.' ;
    rdfs:domain ind:CarbonReductionInitiative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:implementationCost rdf:type rdf:Property ;
    rdfs:label 'Implementation Cost' ;
    rdfs:comment 'Capital cost required to implement the initiative.' ;
    rdfs:domain ind:CarbonReductionInitiative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:initiativeType rdf:type rdf:Property ;
    rdfs:label 'Initiative Type' ;
    rdfs:comment 'Category of the initiative, e.g., fuel switching, electrification, renewable energy procurement, low-carbon concrete mix, modal shift in logistics, or building fabric improvement.' ;
    rdfs:domain ind:CarbonReductionInitiative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paybackPeriodYears rdf:type rdf:Property ;
    rdfs:label 'Payback Period Years' ;
    rdfs:comment 'Estimated number of years required for the initiative to recoup its implementation cost through carbon savings.' ;
    rdfs:domain ind:CarbonReductionInitiative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:projectedAnnualCo2eSaving rdf:type rdf:Property ;
    rdfs:label 'Projected Annual Co2e Saving' ;
    rdfs:comment 'Estimated annual carbon dioxide equivalent reduction expected from the initiative, expressed in metric tonnes.' ;
    rdfs:domain ind:CarbonReductionInitiative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sponsor rdf:type rdf:Property ;
    rdfs:label 'Sponsor' ;
    rdfs:comment 'Name of the internal business unit or executive champion sponsoring the initiative.' ;
    rdfs:domain ind:CarbonReductionInitiative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alignmentParisPathway rdf:type rdf:Property ;
    rdfs:label 'Alignment Paris Pathway' ;
    rdfs:comment 'Alignment of the target with the 1.5 °C, 2 °C, or Net-Zero pathways of the Paris Agreement.' ;
    rdfs:domain ind:CarbonTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baselineEmissionsTco2e rdf:type rdf:Property ;
    rdfs:label 'Baseline Emissions Tco2e' ;
    rdfs:comment 'Total greenhouse-gas emissions in metric tonnes CO₂-equivalent for the baseline year.' ;
    rdfs:domain ind:CarbonTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:baselineYear rdf:type rdf:Property ;
    rdfs:label 'Baseline Year' ;
    rdfs:comment 'Calendar year used as the reference point for emissions calculations.' ;
    rdfs:domain ind:CarbonTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:interimMilestones rdf:type rdf:Property ;
    rdfs:label 'Interim Milestones' ;
    rdfs:comment 'JSON-encoded list of intermediate milestones (year and reduction %) leading to the final target.' ;
    rdfs:domain ind:CarbonTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sbtiValidationStatus rdf:type rdf:Property ;
    rdfs:label 'Sbti Validation Status' ;
    rdfs:comment 'Status of validation by the Science-Based Targets initiative.' ;
    rdfs:domain ind:CarbonTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetCode rdf:type rdf:Property ;
    rdfs:label 'Target Code' ;
    rdfs:comment 'Human-readable code or number used to reference the carbon target in reports and contracts.' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetDescription rdf:type rdf:Property ;
    rdfs:label 'Target Description' ;
    rdfs:comment 'Narrative description of the carbon reduction commitment and its strategic context.' ;
    rdfs:domain ind:CarbonTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetIntensityUnit rdf:type rdf:Property ;
    rdfs:label 'Target Intensity Unit' ;
    rdfs:comment 'Unit of measure for the intensity-based target.' ;
    rdfs:domain ind:CarbonTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetIntensityValue rdf:type rdf:Property ;
    rdfs:label 'Target Intensity Value' ;
    rdfs:comment 'Emissions intensity target (e.g., tCO₂e per unit of production) for intensity-based targets.' ;
    rdfs:domain ind:CarbonTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetReductionPct rdf:type rdf:Property ;
    rdfs:label 'Target Reduction Pct' ;
    rdfs:comment 'Desired percentage reduction of emissions relative to the baseline.' ;
    rdfs:domain ind:CarbonTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetScope rdf:type rdf:Property ;
    rdfs:label 'Target Scope' ;
    rdfs:comment 'GHG accounting scope(s) covered by the target (Scope 1, 2, 3, or combinations).' ;
    rdfs:domain ind:CarbonTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetType rdf:type rdf:Property ;
    rdfs:label 'Target Type' ;
    rdfs:comment 'Category of the carbon reduction commitment (e.g., absolute reduction, intensity-based, net-zero, or Science-Based Target).' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetUnits rdf:type rdf:Property ;
    rdfs:label 'Target Units' ;
    rdfs:comment 'Unit of measure for the target value (e.g., tCO₂e).' ;
    rdfs:domain ind:CarbonTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetValueTco2e rdf:type rdf:Property ;
    rdfs:label 'Target Value Tco2e' ;
    rdfs:comment 'Absolute emissions level to be reached by the target year, expressed in metric tonnes CO₂-equivalent.' ;
    rdfs:domain ind:CarbonTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetYear rdf:type rdf:Property ;
    rdfs:label 'Target Year' ;
    rdfs:comment 'Calendar year by which the reduction target must be achieved.' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:adaptationMeasure rdf:type rdf:Property ;
    rdfs:label 'Adaptation Measure' ;
    rdfs:comment 'Planned actions to reduce exposure or vulnerability to the identified climate risk.' ;
    rdfs:domain ind:ClimateRiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentName rdf:type rdf:Property ;
    rdfs:label 'Assessment Name' ;
    rdfs:comment 'Human-readable name or title of the climate risk assessment.' ;
    rdfs:domain ind:ClimateRiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:climateRiskAssessmentStatus rdf:type rdf:Property ;
    rdfs:label 'Climate Risk Assessment Status' ;
    rdfs:comment 'Current workflow state of the assessment.' ;
    rdfs:domain ind:ClimateRiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:climateScenario rdf:type rdf:Property ;
    rdfs:label 'Climate Scenario' ;
    rdfs:comment 'Climate scenario applied in the assessment, based on IPCC RCP pathways or IEA Net-Zero Emissions scenario.' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confidenceLevel rdf:type rdf:Property ;
    rdfs:label 'Confidence Level' ;
    rdfs:comment 'Qualitative confidence in the underlying data and assumptions.' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emissionFactor rdf:type rdf:Property ;
    rdfs:label 'Emission Factor' ;
    rdfs:comment 'Estimated CO₂e emission factor (tCO₂e per unit) used in scenario calculations.' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isStrategicPriority rdf:type rdf:Property ;
    rdfs:label 'Is Strategic Priority' ;
    rdfs:comment 'True if the assessed risk is identified as a strategic priority for the organization.' ;
    rdfs:domain ind:ClimateRiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:likelihood rdf:type rdf:Property ;
    rdfs:label 'Likelihood' ;
    rdfs:comment 'Estimated probability of the risk materialising, expressed on a qualitative scale.' ;
    rdfs:domain ind:ClimateRiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mitigationAction rdf:type rdf:Property ;
    rdfs:label 'Mitigation Action' ;
    rdfs:comment 'Initiatives aimed at lowering greenhouse-gas emissions or aligning with transition pathways.' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portfolioCode rdf:type rdf:Property ;
    rdfs:label 'Portfolio Code' ;
    rdfs:comment 'Identifier of the portfolio grouping multiple projects for aggregated risk analysis.' ;
    rdfs:domain ind:ClimateRiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:regulatoryChangeIndicator rdf:type rdf:Property ;
    rdfs:label 'Regulatory Change Indicator' ;
    rdfs:comment 'Flag indicating whether emerging regulations materially affect the assessed risk.' ;
    rdfs:domain ind:ClimateRiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:riskSubcategory rdf:type rdf:Property ;
    rdfs:label 'Risk Subcategory' ;
    rdfs:comment 'More detailed classification within the main risk category (e.g., riverine flooding, coastal flooding).' ;
    rdfs:domain ind:ClimateRiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seaLevelRiseEstimate rdf:type rdf:Property ;
    rdfs:label 'Sea Level Rise Estimate' ;
    rdfs:comment 'Projected sea-level increase (meters) relevant to flood risk calculations.' ;
    rdfs:domain ind:ClimateRiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:temperatureIncreaseEstimate rdf:type rdf:Property ;
    rdfs:label 'Temperature Increase Estimate' ;
    rdfs:comment 'Projected average temperature rise (°C) over the selected time horizon.' ;
    rdfs:domain ind:ClimateRiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:timeHorizon rdf:type rdf:Property ;
    rdfs:label 'Time Horizon' ;
    rdfs:comment 'Planning horizon for the assessment: short (0-5 years), medium (5-15 years), or long term (15+ years).' ;
    rdfs:domain ind:ClimateRiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:climateRiskItemId rdf:type rdf:Property ;
    rdfs:label 'Climate Risk Item Id' ;
    rdfs:comment 'System-generated unique identifier for the climate risk or opportunity line item.' ;
    rdfs:domain ind:ClimateRiskItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:affectedAssetId rdf:type rdf:Property ;
    rdfs:label 'Affected Asset Id' ;
    rdfs:comment 'Identifier of the physical or digital asset impacted by the climate risk.' ;
    rdfs:domain ind:ClimateRiskItem ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Asset .

ind:climateRiskItemStatus rdf:type rdf:Property ;
    rdfs:label 'Climate Risk Item Status' ;
    rdfs:comment 'Overall lifecycle status of the climate risk item.' ;
    rdfs:domain ind:ClimateRiskItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:climateYear rdf:type rdf:Property ;
    rdfs:label 'Climate Year' ;
    rdfs:comment 'Target year for the climate scenario (e.g., 2025, 2030).' ;
    rdfs:domain ind:ClimateRiskItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:exposureLevel rdf:type rdf:Property ;
    rdfs:label 'Exposure Level' ;
    rdfs:comment 'Overall magnitude classification of the financial exposure.' ;
    rdfs:domain ind:ClimateRiskItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialExposureAmount rdf:type rdf:Property ;
    rdfs:label 'Financial Exposure Amount' ;
    rdfs:comment 'Monetary value of the potential loss or gain associated with the risk, in the specified currency.' ;
    rdfs:domain ind:ClimateRiskItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:financialExposureCurrency rdf:type rdf:Property ;
    rdfs:label 'Financial Exposure Currency' ;
    rdfs:comment 'Three-letter ISO 4217 code of the currency for the financial exposure amount. [ENUM-REF-CANDIDATE: USD|EUR|GBP|JPY|CAD|AUD|CHF|CNY|INR|BRL|ZAR|KRW — promote to reference product]' ;
    rdfs:domain ind:ClimateRiskItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mitigationStatus rdf:type rdf:Property ;
    rdfs:label 'Mitigation Status' ;
    rdfs:comment 'Current state of the mitigation effort.' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryReportingFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reporting Flag' ;
    rdfs:comment 'Indicates whether the risk must be disclosed in regulatory or ESG reports.' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:riskAssessmentMethodology rdf:type rdf:Property ;
    rdfs:label 'Risk Assessment Methodology' ;
    rdfs:comment 'Name or reference of the methodology used to assess the climate risk (e.g., TCFD, ISO 14064).' ;
    rdfs:domain ind:ClimateRiskItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskName rdf:type rdf:Property ;
    rdfs:label 'Risk Name' ;
    rdfs:comment 'Short descriptive name of the climate risk or opportunity.' ;
    rdfs:domain ind:ClimateRiskItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tcfdCategory rdf:type rdf:Property ;
    rdfs:label 'Tcfd Category' ;
    rdfs:comment 'TCFD classification of the risk: physical acute, physical chronic, transition policy, transition market, or transition technology.' ;
    rdfs:domain ind:ClimateRiskItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Assessment Approval Date' ;
    rdfs:comment 'Date on which the assessment was formally approved.' ;
    rdfs:domain ind:EmbodiedCarbonAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assessmentApprovedBy rdf:type rdf:Property ;
    rdfs:label 'Assessment Approved By' ;
    rdfs:comment 'Name of the person who approved the assessment results.' ;
    rdfs:domain ind:EmbodiedCarbonAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentAuthor rdf:type rdf:Property ;
    rdfs:label 'Assessment Author' ;
    rdfs:comment 'Name of the individual or team that performed the assessment.' ;
    rdfs:domain ind:EmbodiedCarbonAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentNotes rdf:type rdf:Property ;
    rdfs:label 'Assessment Notes' ;
    rdfs:comment 'Free-form comments or observations recorded by the assessor.' ;
    rdfs:domain ind:EmbodiedCarbonAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Assessment Timestamp' ;
    rdfs:comment 'Date and time when the embodied carbon assessment was performed.' ;
    rdfs:domain ind:EmbodiedCarbonAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:assessmentTool rdf:type rdf:Property ;
    rdfs:label 'Assessment Tool' ;
    rdfs:comment 'Software tool employed to calculate embodied carbon.' ;
    rdfs:domain ind:EmbodiedCarbonAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:benchmarkComparison rdf:type rdf:Property ;
    rdfs:label 'Benchmark Comparison' ;
    rdfs:comment 'Result of comparing the assessment\'s total carbon to the selected benchmark.' ;
    rdfs:domain ind:EmbodiedCarbonAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:benchmarkReference rdf:type rdf:Property ;
    rdfs:label 'Benchmark Reference' ;
    rdfs:comment 'Reference identifier for the benchmark against which the assessment is compared.' ;
    rdfs:domain ind:EmbodiedCarbonAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:biogenicCarbonTco2e rdf:type rdf:Property ;
    rdfs:label 'Biogenic Carbon Tco2e' ;
    rdfs:comment 'Carbon sequestered or emitted from biogenic materials, expressed in tCO2e.' ;
    rdfs:domain ind:EmbodiedCarbonAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:carbonBoundary rdf:type rdf:Property ;
    rdfs:label 'Carbon Boundary' ;
    rdfs:comment 'Scope of carbon accounting (e.g., cradle-to-gate).' ;
    rdfs:domain ind:EmbodiedCarbonAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carbonIntensityKgPerM3 rdf:type rdf:Property ;
    rdfs:label 'Carbon Intensity Kg Per M3' ;
    rdfs:comment 'Carbon intensity per cubic metre of material, expressed in kilograms CO2e.' ;
    rdfs:domain ind:EmbodiedCarbonAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:carbonOffsetUsed rdf:type rdf:Property ;
    rdfs:label 'Carbon Offset Used' ;
    rdfs:comment 'Indicates whether carbon offsets were applied to the assessment.' ;
    rdfs:domain ind:EmbodiedCarbonAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:endOfLifeCarbonTco2e rdf:type rdf:Property ;
    rdfs:label 'End Of Life Carbon Tco2e' ;
    rdfs:comment 'Embodied carbon for end-of-life stages (C1-C4) of the life-cycle.' ;
    rdfs:domain ind:EmbodiedCarbonAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isVerified rdf:type rdf:Property ;
    rdfs:label 'Is Verified' ;
    rdfs:comment 'Indicates whether the assessment has been independently verified.' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:methodology rdf:type rdf:Property ;
    rdfs:label 'Methodology' ;
    rdfs:comment 'Standard or custom methodology used for the carbon assessment.' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:offsetProvider rdf:type rdf:Property ;
    rdfs:label 'Offset Provider' ;
    rdfs:comment 'Name of the organization providing the carbon offsets.' ;
    rdfs:domain ind:EmbodiedCarbonAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:offsetQuantityTco2e rdf:type rdf:Property ;
    rdfs:label 'Offset Quantity Tco2e' ;
    rdfs:comment 'Quantity of carbon offsets purchased, expressed in tCO2e.' ;
    rdfs:domain ind:EmbodiedCarbonAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:operationalCarbonTco2e rdf:type rdf:Property ;
    rdfs:label 'Operational Carbon Tco2e' ;
    rdfs:comment 'Embodied carbon attributed to the operational phase (B6) of the life-cycle.' ;
    rdfs:domain ind:EmbodiedCarbonAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:relatedProjectPhase rdf:type rdf:Property ;
    rdfs:label 'Related Project Phase' ;
    rdfs:comment 'Project phase to which the assessment is most relevant.' ;
    rdfs:domain ind:EmbodiedCarbonAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewableMaterialPercentage rdf:type rdf:Property ;
    rdfs:label 'Renewable Material Percentage' ;
    rdfs:comment 'Proportion of materials sourced from renewable resources.' ;
    rdfs:domain ind:EmbodiedCarbonAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ribaStage rdf:type rdf:Property ;
    rdfs:label 'Riba Stage' ;
    rdfs:comment 'RIBA stage of the project at which the assessment was conducted.' ;
    rdfs:domain ind:EmbodiedCarbonAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalEmbodiedCarbonTco2e rdf:type rdf:Property ;
    rdfs:label 'Total Embodied Carbon Tco2e' ;
    rdfs:comment 'Aggregate embodied carbon for the project, expressed in metric tonnes of CO2 equivalent.' ;
    rdfs:domain ind:EmbodiedCarbonAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:upfrontCarbonTco2e rdf:type rdf:Property ;
    rdfs:label 'Upfront Carbon Tco2e' ;
    rdfs:comment 'Embodied carbon associated with product stage (A1-A5) of the life-cycle.' ;
    rdfs:domain ind:EmbodiedCarbonAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wasteDiversionRatePercent rdf:type rdf:Property ;
    rdfs:label 'Waste Diversion Rate Percent' ;
    rdfs:comment 'Percentage of construction waste diverted from landfill.' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:applicableFuelCategory rdf:type rdf:Property ;
    rdfs:label 'Applicable Fuel Category' ;
    rdfs:comment 'Category of fuel the factor applies to.' ;
    rdfs:domain ind:EmissionFactor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableSector rdf:type rdf:Property ;
    rdfs:label 'Applicable Sector' ;
    rdfs:comment 'Industry sector where the factor is relevant.' ;
    rdfs:domain ind:EmissionFactor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataQualityScore rdf:type rdf:Property ;
    rdfs:label 'Data Quality Score' ;
    rdfs:comment 'Score indicating confidence in factor data (0-100).' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:expirationReason rdf:type rdf:Property ;
