ind:originatingPartyId rdf:type rdf:Property ;
    rdfs:label 'Originating Party Id' ;
    rdfs:comment 'Identifier of the party that originated the communication.' ;
    rdfs:domain ind:Clarification ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:relatedDocumentDocumentRegisterId rdf:type rdf:Property ;
