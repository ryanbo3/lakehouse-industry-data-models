    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:goodsIssueStatus rdf:type rdf:Property ;
    rdfs:label 'Goods Issue Status' ;
    rdfs:comment 'Current processing state of the goods issue record.' ;
    rdfs:domain ind:GoodsIssue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazardClassification rdf:type rdf:Property ;
    rdfs:label 'Hazard Classification' ;
    rdfs:comment 'Safety classification of the material for handling and storage.' ;
    rdfs:domain ind:Material ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Inspection Timestamp' ;
    rdfs:comment 'Date and time when the inspection was performed.' ;
    rdfs:domain ind:GoodsIssue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:isReturned rdf:type rdf:Property ;
    rdfs:label 'Is Returned' ;
    rdfs:comment 'Indicates whether the issued material was later returned to inventory.' ;
    rdfs:domain ind:GoodsIssue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:issueNumber rdf:type rdf:Property ;
    rdfs:label 'Issue Number' ;
    rdfs:comment 'External reference number assigned to the goods issue for tracking and reconciliation.' ;
    rdfs:domain ind:GoodsIssue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issueReason rdf:type rdf:Property ;
    rdfs:label 'Issue Reason' ;
    rdfs:comment 'Business reason for issuing the material.' ;
    rdfs:domain ind:GoodsIssue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issueTimestamp rdf:type rdf:Property ;
    rdfs:label 'Issue Timestamp' ;
    rdfs:comment 'Date and time when the material was physically issued from inventory.' ;
    rdfs:domain ind:GoodsIssue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:receiptDate rdf:type rdf:Property ;
    rdfs:label 'Receipt Date' ;
    rdfs:comment 'Date the material was received into the warehouse before issuance.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:hazmatRegisterId rdf:type rdf:Property ;
    rdfs:label 'Hazmat Register Id' ;
    rdfs:comment 'System-generated unique identifier for each hazardous material register entry.' ;
    rdfs:domain ind:HazmatRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:casNumber rdf:type rdf:Property ;
    rdfs:label 'Cas Number' ;
    rdfs:comment 'Unique Chemical Abstracts Service identifier for the material.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dateReceived rdf:type rdf:Property ;
    rdfs:label 'Date Received' ;
    rdfs:comment 'Date the hazardous material was received on site.' ;
    rdfs:domain ind:HazmatRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:disposalRequirements rdf:type rdf:Property ;
    rdfs:label 'Disposal Requirements' ;
    rdfs:comment 'Procedures and regulatory requirements for disposing of the material.' ;
    rdfs:domain ind:HazmatRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emergencyContactName rdf:type rdf:Property ;
    rdfs:label 'Emergency Contact Name' ;
    rdfs:comment 'Name of the person to contact in case of an incident involving the material.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emergencyContactPhone rdf:type rdf:Property ;
    rdfs:label 'Emergency Contact Phone' ;
    rdfs:comment 'Phone number for the emergency contact.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazardDescription rdf:type rdf:Property ;
    rdfs:label 'Hazard Description' ;
    rdfs:comment 'Narrative description of the hazards associated with the material.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazmatRegisterStatus rdf:type rdf:Property ;
    rdfs:label 'Hazmat Register Status' ;
    rdfs:comment 'Current lifecycle status of the hazardous material record.' ;
    rdfs:domain ind:HazmatRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hseNotificationStatus rdf:type rdf:Property ;
    rdfs:label 'Hse Notification Status' ;
    rdfs:comment 'Current status of health, safety, and environment notification for the material.' ;
    rdfs:domain ind:HazmatRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCorrosive rdf:type rdf:Property ;
    rdfs:label 'Is Corrosive' ;
    rdfs:comment 'True if the material is corrosive.' ;
    rdfs:domain ind:HazmatRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isEnvironmentallyHazardous rdf:type rdf:Property ;
    rdfs:label 'Is Environmentally Hazardous' ;
    rdfs:comment 'True if the material poses environmental hazards.' ;
    rdfs:domain ind:HazmatRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isExplosive rdf:type rdf:Property ;
    rdfs:label 'Is Explosive' ;
    rdfs:comment 'True if the material is classified as explosive.' ;
    rdfs:domain ind:HazmatRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isFlammable rdf:type rdf:Property ;
    rdfs:label 'Is Flammable' ;
    rdfs:comment 'True if the material is classified as flammable.' ;
    rdfs:domain ind:HazmatRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRadioactive rdf:type rdf:Property ;
    rdfs:label 'Is Radioactive' ;
    rdfs:comment 'True if the material emits ionizing radiation.' ;
    rdfs:domain ind:HazmatRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isToxic rdf:type rdf:Property ;
    rdfs:label 'Is Toxic' ;
    rdfs:comment 'True if the material is toxic to humans or animals.' ;
    rdfs:domain ind:HazmatRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:materialCode rdf:type rdf:Property ;
    rdfs:label 'Material Code' ;
    rdfs:comment 'Internal code used to uniquely identify the hazardous material across systems.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextInspectionDue rdf:type rdf:Property ;
    rdfs:label 'Next Inspection Due' ;
    rdfs:comment 'Planned date for the next required safety inspection.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:quantityOnSite rdf:type rdf:Property ;
    rdfs:label 'Quantity On Site' ;
    rdfs:comment 'Current amount of the hazardous material physically present at the site.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sdsReference rdf:type rdf:Property ;
    rdfs:label 'Sds Reference' ;
    rdfs:comment 'Link or identifier to the Safety Data Sheet (SDS) for the material.' ;
    rdfs:domain ind:HazmatRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageTemperatureControlled rdf:type rdf:Property ;
    rdfs:label 'Storage Temperature Controlled' ;
    rdfs:comment 'Indicates whether the material requires temperature-controlled storage.' ;
    rdfs:domain ind:HazmatRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:temperatureMaxCelsius rdf:type rdf:Property ;
    rdfs:label 'Temperature Max Celsius' ;
    rdfs:comment 'Maximum allowable storage temperature in degrees Celsius.' ;
    rdfs:domain ind:HazmatRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:temperatureMinCelsius rdf:type rdf:Property ;
    rdfs:label 'Temperature Min Celsius' ;
    rdfs:comment 'Minimum allowable storage temperature in degrees Celsius.' ;
    rdfs:domain ind:HazmatRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unHazardClass rdf:type rdf:Property ;
    rdfs:label 'Un Hazard Class' ;
    rdfs:comment 'UN classification code indicating the type of hazard (e.g., 1 for explosives, 2 for gases). [ENUM-REF-CANDIDATE: 1|2|3|4|5|6|7|8|9 — promote to reference product]' ;
    rdfs:domain ind:HazmatRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialBoqLineId rdf:type rdf:Property ;
    rdfs:label 'Material Boq Line Id' ;
    rdfs:comment 'System-generated unique identifier for the BOQ line item.' ;
    rdfs:domain ind:MaterialBoqLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contractQuantity rdf:type rdf:Property ;
    rdfs:label 'Contract Quantity' ;
    rdfs:comment 'Quantity of the material that is contractually committed in the BOQ.' ;
    rdfs:domain ind:MaterialBoqLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isChangeOrder rdf:type rdf:Property ;
    rdfs:label 'Is Change Order' ;
    rdfs:comment 'Indicates whether this line originates from a change order (true) or the original BOQ (false).' ;
    rdfs:domain ind:MaterialBoqLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:materialBoqLineStatus rdf:type rdf:Property ;
    rdfs:label 'Material Boq Line Status' ;
    rdfs:comment 'Current lifecycle status of the BOQ line.' ;
    rdfs:domain ind:MaterialBoqLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradeDiscipline rdf:type rdf:Property ;
