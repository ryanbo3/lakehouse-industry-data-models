    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resourceCode rdf:type rdf:Property ;
    rdfs:label 'Resource Code' ;
    rdfs:comment 'External identifier or catalogue number for the resource.' ;
    rdfs:domain ind:Resource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resourceName rdf:type rdf:Property ;
    rdfs:label 'Resource Name' ;
    rdfs:comment 'Human-readable name of the resource as used in schedules.' ;
    rdfs:domain ind:Resource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resourceStatus rdf:type rdf:Property ;
    rdfs:label 'Resource Status' ;
    rdfs:comment 'Current lifecycle status of the resource.' ;
    rdfs:domain ind:Resource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyRating rdf:type rdf:Property ;
    rdfs:label 'Safety Rating' ;
