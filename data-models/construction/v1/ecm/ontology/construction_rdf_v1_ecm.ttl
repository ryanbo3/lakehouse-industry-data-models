    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guaranteePurpose rdf:type rdf:Property ;
    rdfs:label 'Guarantee Purpose' ;
    rdfs:comment 'Purpose of the bond guarantee within the contract.' ;
    rdfs:domain ind:BondGuarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:releaseDate rdf:type rdf:Property ;
    rdfs:label 'Release Date' ;
    rdfs:comment 'Date when the bond was released or returned to the issuer.' ;
