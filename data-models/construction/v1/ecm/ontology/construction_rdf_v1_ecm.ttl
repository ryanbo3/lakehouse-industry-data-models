    rdfs:range xsd:dateTime .

ind:validUntil rdf:type rdf:Property ;
    rdfs:label 'Valid Until' ;
    rdfs:comment 'Expiration date of the approval if not acted upon.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bondId rdf:type rdf:Property ;
    rdfs:label 'Bond Id' ;
    rdfs:comment 'Unique identifier for the bid bond record.' ;
