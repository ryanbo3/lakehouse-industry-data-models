ind:calendarCode rdf:type rdf:Property ;
    rdfs:label 'Calendar Code' ;
    rdfs:comment 'Business identifier or code assigned to the calendar (e.g., "CAL-US-NY").' ;
    rdfs:domain ind:ScheduleCalendar ;
    rdf:type owl:DatatypeProperty ;
