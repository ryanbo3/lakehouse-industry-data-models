    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:updateSource rdf:type rdf:Property ;
    rdfs:label 'Update Source' ;
    rdfs:comment 'Origin of the data for this progress update (e.g., field report, Primavera P6 import, HCSS HeavyJob).' ;
