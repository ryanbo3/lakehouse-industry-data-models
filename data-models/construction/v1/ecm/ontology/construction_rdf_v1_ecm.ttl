    rdfs:range xsd:integer .

ind:weatherImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Weather Impact Flag' ;
    rdfs:comment 'True if adverse weather conditions are expected to impact the lookahead activities.' ;
    rdfs:domain ind:LookaheadPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:zoneCode rdf:type rdf:Property ;
    rdfs:label 'Zone Code' ;
    rdfs:comment 'Alphanumeric code representing the specific site zone for the plan.' ;
