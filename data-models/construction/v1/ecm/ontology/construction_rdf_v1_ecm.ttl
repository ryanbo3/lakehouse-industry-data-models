ind:calendarCategory rdf:type rdf:Property ;
    rdfs:label 'Calendar Category' ;
    rdfs:comment 'Higher-level grouping of calendars for reporting (standard, custom, or regional).' ;
    rdfs:domain ind:ScheduleCalendar ;
    rdf:type owl:DatatypeProperty ;
