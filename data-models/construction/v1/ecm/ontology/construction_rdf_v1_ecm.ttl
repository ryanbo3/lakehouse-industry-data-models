    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractChangeOrderStatus rdf:type rdf:Property ;
    rdfs:label 'Contract Change Order Status' ;
    rdfs:comment 'Current lifecycle status of the change order.' ;
