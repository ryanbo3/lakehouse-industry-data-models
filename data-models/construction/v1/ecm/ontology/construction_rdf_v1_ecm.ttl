ind:grade rdf:type rdf:Property ;
    rdfs:label 'Grade' ;
    rdfs:comment 'Standard grade or specification level of the material (e.g., ASTM A36, C30/37).' ;
    rdfs:domain ind:ApprovedMaterialList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:handlingInstructions rdf:type rdf:Property ;
    rdfs:label 'Handling Instructions' ;
    rdfs:comment 'Operational guidance for safe handling and installation of the material.' ;
    rdfs:domain ind:Material ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazardousClassification rdf:type rdf:Property ;
    rdfs:label 'Hazardous Classification' ;
    rdfs:comment 'Regulatory classification of the hazardous material, if applicable.' ;
    rdfs:domain ind:ApprovedMaterialList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isHazardous rdf:type rdf:Property ;
    rdfs:label 'Is Hazardous' ;
    rdfs:comment 'Flag indicating whether the material is classified as hazardous.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPrimaryMaterial rdf:type rdf:Property ;
    rdfs:label 'Is Primary Material' ;
    rdfs:comment 'Indicates if the material is a primary (non-substitutable) component of the design.' ;
    rdfs:domain ind:ApprovedMaterialList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSubstituted rdf:type rdf:Property ;
    rdfs:label 'Is Substituted' ;
    rdfs:comment 'Flag showing whether this entry represents a substitution for another approved material.' ;
    rdfs:domain ind:ApprovedMaterialList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lotNumber rdf:type rdf:Property ;
    rdfs:label 'Lot Number' ;
    rdfs:comment 'Lot identifier used for quality and regulatory tracking.' ;
    rdfs:domain ind:Material ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manufacturer rdf:type rdf:Property ;
    rdfs:label 'Manufacturer' ;
    rdfs:comment 'Name of the company that produces the material.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialCategory rdf:type rdf:Property ;
    rdfs:label 'Material Category' ;
    rdfs:comment 'High-level classification of the material (e.g., concrete, structural steel, MEP component).' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialName rdf:type rdf:Property ;
    rdfs:label 'Material Name' ;
    rdfs:comment 'Descriptive name of the material as used in project documentation.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialOriginCountry rdf:type rdf:Property ;
    rdfs:label 'Material Origin Country' ;
    rdfs:comment 'ISO-3166-1 alpha-3 country code where the material was manufactured.' ;
    rdfs:domain ind:Material ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialOriginState rdf:type rdf:Property ;
    rdfs:label 'Material Origin State' ;
    rdfs:comment 'State or province of manufacture, if applicable.' ;
    rdfs:domain ind:ApprovedMaterialList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyDataSheetUrl rdf:type rdf:Property ;
    rdfs:label 'Safety Data Sheet Url' ;
    rdfs:comment 'Link to the electronic Safety Data Sheet (SDS) for the material.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specification rdf:type rdf:Property ;
    rdfs:label 'Specification' ;
    rdfs:comment 'Detailed technical specification or data sheet reference for the material.' ;
    rdfs:domain ind:ApprovedMaterialList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageRequirements rdf:type rdf:Property ;
    rdfs:label 'Storage Requirements' ;
    rdfs:comment 'Special storage conditions required for the material (e.g., temperature, humidity).' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:substitutionAllowed rdf:type rdf:Property ;
    rdfs:label 'Substitution Allowed' ;
    rdfs:comment 'Indicates whether the material may be substituted with an equivalent.' ;
    rdfs:domain ind:ApprovedMaterialList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:warrantyExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Warranty Expiry Date' ;
    rdfs:comment 'Date when the warranty coverage ends.' ;
    rdfs:domain ind:ApprovedMaterialList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:batchLotId rdf:type rdf:Property ;
    rdfs:label 'Batch Lot Id' ;
    rdfs:comment 'System-generated unique identifier for the batch or lot record.' ;
    rdfs:domain ind:Material ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BatchLot .

ind:warehouseId rdf:type rdf:Property ;
    rdfs:label 'Warehouse Id' ;
    rdfs:comment 'Unique identifier of the warehouse holding the material.' ;
    rdfs:domain ind:Material ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Warehouse .

ind:batchStatus rdf:type rdf:Property ;
    rdfs:label 'Batch Status' ;
    rdfs:comment 'Lifecycle status of the batch/lot.' ;
    rdfs:domain ind:BatchLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificateOfConformanceRef rdf:type rdf:Property ;
    rdfs:label 'Certificate Of Conformance Ref' ;
    rdfs:comment 'Reference number of the certificate confirming material meets specifications.' ;
    rdfs:domain ind:BatchLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionPassed rdf:type rdf:Property ;
    rdfs:label 'Inspection Passed' ;
    rdfs:comment 'Indicates whether the last inspection met acceptance criteria.' ;
    rdfs:domain ind:BatchLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lotTraceabilityFlag rdf:type rdf:Property ;
    rdfs:label 'Lot Traceability Flag' ;
    rdfs:comment 'Indicates whether the lot is subject to full chain-of-custody tracking.' ;
    rdfs:domain ind:BatchLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:materialDescription rdf:type rdf:Property ;
    rdfs:label 'Material Description' ;
    rdfs:comment 'Free-text description of the material, including grade or specification.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionDate rdf:type rdf:Property ;
    rdfs:label 'Production Date' ;
    rdfs:comment 'Date the material batch was manufactured.' ;
    rdfs:domain ind:BatchLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:quarantineStatus rdf:type rdf:Property ;
    rdfs:label 'Quarantine Status' ;
    rdfs:comment 'Current quarantine state of the batch/lot.' ;
    rdfs:domain ind:BatchLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receiptReference rdf:type rdf:Property ;
    rdfs:label 'Receipt Reference' ;
    rdfs:comment 'Reference number of the goods receipt document.' ;
    rdfs:domain ind:BatchLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyDataSheetRef rdf:type rdf:Property ;
    rdfs:label 'Safety Data Sheet Ref' ;
    rdfs:comment 'Reference to the SDS document for hazardous materials.' ;
    rdfs:domain ind:BatchLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplier rdf:type rdf:Property ;
    rdfs:label 'Supplier' ;
    rdfs:comment 'Name of the entity that supplied the material to the construction site.' ;
    rdfs:domain ind:BatchLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testPassed rdf:type rdf:Property ;
    rdfs:label 'Test Passed' ;
    rdfs:comment 'Indicates whether the material batch passed required quality tests.' ;
    rdfs:domain ind:BatchLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:testResultsDate rdf:type rdf:Property ;
    rdfs:label 'Test Results Date' ;
    rdfs:comment 'Date the material tests were performed.' ;
    rdfs:domain ind:BatchLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:testResultsSummary rdf:type rdf:Property ;
    rdfs:label 'Test Results Summary' ;
    rdfs:comment 'Brief summary of test outcomes for the batch (e.g., compressive strength).' ;
    rdfs:domain ind:BatchLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitVolume rdf:type rdf:Property ;
    rdfs:label 'Unit Volume' ;
    rdfs:comment 'Volume per unit of material (e.g., cubic meters per bag).' ;
    rdfs:domain ind:BatchLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unitWeight rdf:type rdf:Property ;
    rdfs:label 'Unit Weight' ;
    rdfs:comment 'Weight per unit of material (e.g., kg per piece).' ;
    rdfs:domain ind:BatchLot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:conformanceCertificateId rdf:type rdf:Property ;
    rdfs:label 'Conformance Certificate Id' ;
    rdfs:comment 'Primary key for conformance_certificate' ;
    rdfs:domain ind:ConformanceCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:certificateTitle rdf:type rdf:Property ;
    rdfs:label 'Certificate Title' ;
    rdfs:comment 'Human-readable title or description of the certificate (e.g., "Structural Steel Grade A Certification").' ;
    rdfs:domain ind:ConformanceCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificateVersion rdf:type rdf:Property ;
    rdfs:label 'Certificate Version' ;
    rdfs:comment 'Version identifier of the certificate document.' ;
    rdfs:domain ind:ConformanceCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conformanceCertificateStatus rdf:type rdf:Property ;
    rdfs:label 'Conformance Certificate Status' ;
    rdfs:comment 'Lifecycle status of the certificate.' ;
    rdfs:domain ind:ConformanceCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:humidityRecorded rdf:type rdf:Property ;
    rdfs:label 'Humidity Recorded' ;
    rdfs:comment 'Relative humidity during the material test (%).' ;
    rdfs:domain ind:ConformanceCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:issuingLab rdf:type rdf:Property ;
    rdfs:label 'Issuing Lab' ;
    rdfs:comment 'Name of the laboratory or authority that issued the certificate.' ;
    rdfs:domain ind:ConformanceCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measuredUnit rdf:type rdf:Property ;
    rdfs:label 'Measured Unit' ;
    rdfs:comment 'Unit of the measured value (e.g., MPa for strength).' ;
    rdfs:domain ind:ConformanceCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relatedDocumentRef rdf:type rdf:Property ;
    rdfs:label 'Related Document Ref' ;
    rdfs:comment 'Reference (e.g., file path or URL) to the digital copy of the certificate.' ;
    rdfs:domain ind:ConformanceCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resultDetails rdf:type rdf:Property ;
    rdfs:label 'Result Details' ;
    rdfs:comment 'Narrative description of test outcomes, observations, and any deviations.' ;
    rdfs:domain ind:ConformanceCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureRecorded rdf:type rdf:Property ;
    rdfs:label 'Temperature Recorded' ;
    rdfs:comment 'Temperature at which the material test was conducted (°C).' ;
    rdfs:domain ind:ConformanceCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:testDate rdf:type rdf:Property ;
    rdfs:label 'Test Date' ;
    rdfs:comment 'Date on which the material test was performed.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testMethod rdf:type rdf:Property ;
    rdfs:label 'Test Method' ;
    rdfs:comment 'Methodology used for the test (e.g., compression, tensile, chemical analysis).' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testResult rdf:type rdf:Property ;
    rdfs:label 'Test Result' ;
    rdfs:comment 'Outcome of the material test indicating pass or fail.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testStandard rdf:type rdf:Property ;
    rdfs:label 'Test Standard' ;
    rdfs:comment 'Standard used for testing (e.g., ASTM C39, ISO 9001).' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:goodsIssueId rdf:type rdf:Property ;
    rdfs:label 'Goods Issue Id' ;
    rdfs:comment 'System-generated unique identifier for the goods issue transaction.' ;
    rdfs:domain ind:GoodsIssue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryGoodsEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Goods Employee Id' ;
    rdfs:comment 'Identifier of the employee who requested the material issue.' ;
    rdfs:domain ind:GoodsIssue ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:returnIssueGoodsIssueId rdf:type rdf:Property ;
    rdfs:label 'Return Issue Goods Issue Id' ;
    rdfs:comment 'Identifier of the goods issue record that reverses this transaction, if any.' ;
    rdfs:domain ind:GoodsIssue ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GoodsIssue .

ind:deliveryNoteNumber rdf:type rdf:Property ;
    rdfs:label 'Delivery Note Number' ;
    rdfs:comment 'Reference number of the delivery note accompanying the material receipt.' ;
