    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:breakTimeMinutesPerDay rdf:type rdf:Property ;
    rdfs:label 'Break Time Minutes Per Day' ;
    rdfs:comment 'Total minutes of mandatory break time deducted from the workday.' ;
