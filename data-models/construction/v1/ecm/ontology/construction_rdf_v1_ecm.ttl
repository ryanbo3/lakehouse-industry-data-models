    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:wasteManagementStrategy rdf:type rdf:Property ;
    rdfs:label 'Waste Management Strategy' ;
    rdfs:comment 'Strategic approach selected for achieving the waste target.' ;
    rdfs:domain ind:WasteTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wasteTargetStatus rdf:type rdf:Property ;
    rdfs:label 'Waste Target Status' ;
    rdfs:comment 'Current lifecycle status of the waste target.' ;
    rdfs:domain ind:WasteTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waterConsumptionId rdf:type rdf:Property ;
    rdfs:label 'Water Consumption Id' ;
    rdfs:comment 'System-generated unique identifier for each water consumption record.' ;
    rdfs:domain ind:WaterConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:carbonFootprintKg rdf:type rdf:Property ;
    rdfs:label 'Carbon Footprint Kg' ;
    rdfs:comment 'Estimated greenhouse-gas emissions associated with the water consumption, expressed in kilograms of CO₂ equivalent.' ;
    rdfs:domain ind:WaterConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:consumptionVolumeM3 rdf:type rdf:Property ;
    rdfs:label 'Consumption Volume M3' ;
    rdfs:comment 'Total volume of water consumed during the reporting period, measured in cubic metres.' ;
    rdfs:domain ind:WaterConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dischargeDestination rdf:type rdf:Property ;
    rdfs:label 'Discharge Destination' ;
    rdfs:comment 'Where the discharged water is sent (e.g., municipal sewer, natural watercourse, on-site treatment, reuse).' ;
    rdfs:domain ind:WaterConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dischargeVolumeM3 rdf:type rdf:Property ;
    rdfs:label 'Discharge Volume M3' ;
    rdfs:comment 'Volume of water discharged from the site after use, measured in cubic metres.' ;
    rdfs:domain ind:WaterConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:meteringMethod rdf:type rdf:Property ;
    rdfs:label 'Metering Method' ;
    rdfs:comment 'Method used to capture the water consumption reading.' ;
    rdfs:domain ind:WaterConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waterSourceType rdf:type rdf:Property ;
    rdfs:label 'Water Source Type' ;
    rdfs:comment 'Classification of the water source used (e.g., mains supply, borehole, recycled/harvested rainwater, grey water reuse).' ;
    rdfs:domain ind:WaterConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waterStressAreaClassification rdf:type rdf:Property ;
    rdfs:label 'Water Stress Area Classification' ;
    rdfs:comment 'Classification of the geographic area based on water scarcity risk.' ;
    rdfs:domain ind:WaterConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agencyLaborOrderId rdf:type rdf:Property ;
    rdfs:label 'Agency Labor Order Id' ;
    rdfs:comment 'Unique identifier for the agency labor order record.' ;
    rdfs:domain ind:AgencyLaborOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:agencyId rdf:type rdf:Property ;
    rdfs:label 'Agency Id' ;
    rdfs:comment 'Identifier of the labor hire agency or staffing firm supplying the workers.' ;
    rdfs:domain ind:Workforce ;
