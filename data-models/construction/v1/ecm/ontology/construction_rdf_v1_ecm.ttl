ind:separationExitInterviewConductedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Separation Exit Interview Conducted By Employee Id' ;
    rdfs:comment 'Identifier of the HR representative who conducted the exit interview.' ;
