    rdfs:range ind:Agency .

ind:primaryAgencyEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Agency Employee Id' ;
    rdfs:comment 'Identifier of the user or project manager who requested the agency labor order.' ;
    rdfs:domain ind:AgencyLaborOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:skillTradeId rdf:type rdf:Property ;
    rdfs:label 'Skill Trade Id' ;
    rdfs:comment 'Foreign key linking to workforce.skill_trade. Business justification: Reference standardized skill_trade for trade classification, removing free-text trade_classification column.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SkillTrade .

ind:billRate rdf:type rdf:Property ;
    rdfs:label 'Bill Rate' ;
    rdfs:comment 'Hourly billing rate charged by the agency per worker.' ;
    rdfs:domain ind:AgencyLaborOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cancellationDate rdf:type rdf:Property ;
    rdfs:label 'Cancellation Date' ;
    rdfs:comment 'Date when the agency labor order was cancelled.' ;
    rdfs:domain ind:AgencyLaborOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:craftCode rdf:type rdf:Property ;
    rdfs:label 'Craft Code' ;
    rdfs:comment 'Standardized code representing the craft discipline requested.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedEndDate rdf:type rdf:Property ;
    rdfs:label 'Estimated End Date' ;
    rdfs:comment 'Estimated date when the agency workers assignment is expected to conclude.' ;
    rdfs:domain ind:AgencyLaborOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:hseOrientationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Hse Orientation Required Flag' ;
    rdfs:comment 'Indicates whether HSE site orientation is required for the agency workers before starting work.' ;
    rdfs:domain ind:AgencyLaborOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:markupPercentage rdf:type rdf:Property ;
    rdfs:label 'Markup Percentage' ;
    rdfs:comment 'Agency markup percentage applied on top of the pay rate to arrive at the bill rate.' ;
    rdfs:domain ind:AgencyLaborOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:orderDate rdf:type rdf:Property ;
    rdfs:label 'Order Date' ;
    rdfs:comment 'Date when the agency labor order was placed or submitted to the agency.' ;
    rdfs:domain ind:AgencyLaborOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:payRate rdf:type rdf:Property ;
    rdfs:label 'Pay Rate' ;
    rdfs:comment 'Hourly pay rate paid to the agency worker.' ;
    rdfs:domain ind:AgencyLaborOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:siteAccessClearanceRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Site Access Clearance Required Flag' ;
    rdfs:comment 'Indicates whether site access clearance or background check is required for the agency workers.' ;
    rdfs:domain ind:AgencyLaborOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:skillLevel rdf:type rdf:Property ;
    rdfs:label 'Skill Level' ;
    rdfs:comment 'Required skill or experience level for the requested workers.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unionAffiliationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Union Affiliation Required Flag' ;
    rdfs:comment 'Indicates whether the agency workers must be affiliated with a specific union or labor organization.' ;
    rdfs:domain ind:AgencyLaborOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:unionLocal rdf:type rdf:Property ;
    rdfs:label 'Union Local' ;
    rdfs:comment 'Union local chapter or jurisdiction required for the agency workers.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workersFulfilledQuantity rdf:type rdf:Property ;
    rdfs:label 'Workers Fulfilled Quantity' ;
    rdfs:comment 'Actual number of workers supplied by the agency to fulfill this order.' ;
    rdfs:domain ind:AgencyLaborOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:workersRequestedQuantity rdf:type rdf:Property ;
    rdfs:label 'Workers Requested Quantity' ;
    rdfs:comment 'Number of workers requested from the agency for this order.' ;
    rdfs:domain ind:AgencyLaborOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:apprenticeshipProgressionId rdf:type rdf:Property ;
    rdfs:label 'Apprenticeship Progression Id' ;
    rdfs:comment 'Unique surrogate key for each apprenticeship progression record.' ;
    rdfs:domain ind:ApprenticeshipProgression ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualJourneymanCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Actual Journeyman Completion Date' ;
    rdfs:comment 'Date the apprentice actually attained journeyman status, if applicable.' ;
    rdfs:domain ind:ApprenticeshipProgression ;
    rdf:type owl:DatatypeProperty ;
