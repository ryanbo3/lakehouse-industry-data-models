    rdfs:comment 'Construction trade or discipline (e.g., concrete, steel, MEP) associated with the line.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:masterId rdf:type rdf:Property ;
    rdfs:label 'Master Id' ;
    rdfs:comment 'Primary key for master' ;
    rdfs:domain ind:Master ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:substitutionMaterialMasterId rdf:type rdf:Property ;
    rdfs:label 'Substitution Material Master Id' ;
    rdfs:comment 'Identifier of an approved substitute material.' ;
    rdfs:domain ind:Master ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Master .

ind:conformanceCertificateDate rdf:type rdf:Property ;
    rdfs:label 'Conformance Certificate Date' ;
    rdfs:comment 'Date the compliance certificate was issued.' ;
