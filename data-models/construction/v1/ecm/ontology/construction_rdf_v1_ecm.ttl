    rdfs:range xsd:decimal .

ind:ppcTargetPercent rdf:type rdf:Property ;
    rdfs:label 'Ppc Target Percent' ;
    rdfs:comment 'Target Percent Plan Complete (PPC) for the lookahead period.' ;
    rdfs:domain ind:LookaheadPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:readinessStatus rdf:type rdf:Property ;
    rdfs:label 'Readiness Status' ;
    rdfs:comment 'Overall readiness status of the work front for execution.' ;
