    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:plannedStartDate rdf:type rdf:Property ;
    rdfs:label 'Planned Start Date' ;
    rdfs:comment 'Planned start date for execution of the scope.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:quantityUnit rdf:type rdf:Property ;
    rdfs:label 'Quantity Unit' ;
    rdfs:comment 'Unit of measure for the total quantity (e.g., cubic meters, kilograms).' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scopeCode rdf:type rdf:Property ;
    rdfs:label 'Scope Code' ;
    rdfs:comment 'Business identifier code for the scope of works.' ;
    rdfs:domain ind:ContractScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scopeName rdf:type rdf:Property ;
    rdfs:label 'Scope Name' ;
    rdfs:comment 'Human-readable name or title of the scope of works.' ;
    rdfs:domain ind:ContractScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scopeStatus rdf:type rdf:Property ;
    rdfs:label 'Scope Status' ;
    rdfs:comment 'Current lifecycle status of the scope.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scopeType rdf:type rdf:Property ;
    rdfs:label 'Scope Type' ;
    rdfs:comment 'Classification of the scope (e.g., design, construction, procurement).' ;
    rdfs:domain ind:ContractScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteAddress rdf:type rdf:Property ;
    rdfs:label 'Site Address' ;
    rdfs:comment 'Full postal address of the construction site.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractualNoticeId rdf:type rdf:Property ;
    rdfs:label 'Contractual Notice Id' ;
    rdfs:comment 'System-generated unique identifier for the contractual notice record.' ;
    rdfs:domain ind:ContractualNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryContractualIssuingPartyId rdf:type rdf:Property ;
    rdfs:label 'Primary Contractual Issuing Party Id' ;
    rdfs:comment 'Identifier of the party that issued the notice (e.g., contractor, client, subcontractor).' ;
    rdfs:domain ind:ContractualNotice ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:receivingPartyId rdf:type rdf:Property ;
    rdfs:label 'Receiving Party Id' ;
    rdfs:comment 'Identifier of the party that is the intended recipient of the notice.' ;
    rdfs:domain ind:ContractualNotice ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:acknowledgmentDate rdf:type rdf:Property ;
    rdfs:label 'Acknowledgment Date' ;
    rdfs:comment 'Date on which the receiving party acknowledged the notice.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:acknowledgmentStatus rdf:type rdf:Property ;
    rdfs:label 'Acknowledgment Status' ;
    rdfs:comment 'Current acknowledgment state of the receiving party.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clauseReference rdf:type rdf:Property ;
    rdfs:label 'Clause Reference' ;
    rdfs:comment 'Reference to the specific contract clause (e.g., FIDIC 20.1) that governs the notice.' ;
    rdfs:domain ind:ContractualNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractualDeadline rdf:type rdf:Property ;
    rdfs:label 'Contractual Deadline' ;
    rdfs:comment 'Statutory time-bar deadline by which the notice must be served to preserve rights.' ;
    rdfs:domain ind:ContractualNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contractualNoticeDescription rdf:type rdf:Property ;
    rdfs:label 'Contractual Notice Description' ;
    rdfs:comment 'Free-text description of the notice content and purpose.' ;
    rdfs:domain ind:ContractualNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryMethod rdf:type rdf:Property ;
    rdfs:label 'Delivery Method' ;
    rdfs:comment 'Means by which the notice was delivered to the receiving party.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:noticeStatus rdf:type rdf:Property ;
    rdfs:label 'Notice Status' ;
    rdfs:comment 'Overall lifecycle state of the notice.' ;
    rdfs:domain ind:ContractualNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseDueDate rdf:type rdf:Property ;
    rdfs:label 'Response Due Date' ;
    rdfs:comment 'Date by which the receiving party must respond to the notice.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dlpRegisterId rdf:type rdf:Property ;
    rdfs:label 'Dlp Register Id' ;
    rdfs:comment 'System generated unique identifier for each DLP register record.' ;
    rdfs:domain ind:DlpRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dlpOwnerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Dlp Owner Employee Id' ;
    rdfs:comment 'Foreign key linking to hr.employee. Business justification: Assigns an employee owner for each Defect Liability Period; used in DLP monitoring and responsibility reports.' ;
    rdfs:domain ind:DlpRegister ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:primaryDlpAgreementId rdf:type rdf:Property ;
    rdfs:label 'Primary Dlp Agreement Id' ;
    rdfs:comment 'Unique identifier of the contract to which this DLP register belongs.' ;
    rdfs:domain ind:DlpRegister ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Agreement .

ind:certificationIssuedDate rdf:type rdf:Property ;
    rdfs:label 'Certification Issued Date' ;
    rdfs:comment 'Date the DLP completion certificate was issued.' ;
    rdfs:domain ind:DlpRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contractorRectificationDeadline rdf:type rdf:Property ;
    rdfs:label 'Contractor Rectification Deadline' ;
    rdfs:comment 'Latest date by which the contractor must rectify the notified defect.' ;
    rdfs:domain ind:DlpRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:defectNotifiedDate rdf:type rdf:Property ;
    rdfs:label 'Defect Notified Date' ;
    rdfs:comment 'Date the employer formally notified a defect during the DLP.' ;
