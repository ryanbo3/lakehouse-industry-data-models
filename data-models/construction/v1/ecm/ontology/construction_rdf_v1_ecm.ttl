    rdfs:domain ind:Approval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decisionStage rdf:type rdf:Property ;
    rdfs:label 'Decision Stage' ;
    rdfs:comment 'Governance stage at which the decision was taken.' ;
    rdfs:domain ind:Approval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decisionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Decision Timestamp' ;
    rdfs:comment 'Exact date-time when the approval decision was recorded.' ;
    rdfs:domain ind:Bid ;
