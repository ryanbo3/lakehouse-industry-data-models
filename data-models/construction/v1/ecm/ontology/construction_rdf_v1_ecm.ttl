    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Activity .

ind:availabilityPercentage rdf:type rdf:Property ;
    rdfs:label 'Availability Percentage' ;
    rdfs:comment 'Planned availability of the resource expressed as a percent of total time.' ;
