    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:progressUpdateStatus rdf:type rdf:Property ;
    rdfs:label 'Progress Update Status' ;
    rdfs:comment 'Current lifecycle status of the progress update record.' ;
    rdfs:domain ind:ProgressUpdate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remainingDuration rdf:type rdf:Property ;
    rdfs:label 'Remaining Duration' ;
