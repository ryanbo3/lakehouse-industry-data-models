    rdfs:range xsd:string .

ind:eventTimestamp rdf:type rdf:Property ;
    rdfs:label 'Event Timestamp' ;
    rdfs:comment 'Date and time when the communication was originally issued.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:impactAmount rdf:type rdf:Property ;
    rdfs:label 'Impact Amount' ;
    rdfs:comment 'Estimated monetary impact of the clarification on the bid.' ;
