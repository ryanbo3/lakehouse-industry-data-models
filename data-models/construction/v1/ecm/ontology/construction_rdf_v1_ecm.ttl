    rdfs:comment 'True if the clarification alters the bid price.' ;
    rdfs:domain ind:Clarification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:impactFlagSchedule rdf:type rdf:Property ;
    rdfs:label 'Impact Flag Schedule' ;
    rdfs:comment 'True if the clarification changes the project schedule.' ;
    rdfs:domain ind:Clarification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:impactFlagScope rdf:type rdf:Property ;
    rdfs:label 'Impact Flag Scope' ;
    rdfs:comment 'True if the clarification modifies the project scope.' ;
    rdfs:domain ind:Clarification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:impactFlagSpecifications rdf:type rdf:Property ;
