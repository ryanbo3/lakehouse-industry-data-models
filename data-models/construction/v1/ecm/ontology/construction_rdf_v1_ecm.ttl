    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workFrontId rdf:type rdf:Property ;
    rdfs:label 'Work Front Id' ;
    rdfs:comment 'Foreign key linking to site.work_front. Business justification: Change orders frequently affect a particular work front; the link supports impact analysis per front.' ;
