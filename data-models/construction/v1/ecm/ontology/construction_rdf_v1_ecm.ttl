    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:workHoursPerDay rdf:type rdf:Property ;
    rdfs:label 'Work Hours Per Day' ;
    rdfs:comment 'Standard number of productive hours defined for a typical workday.' ;
    rdfs:domain ind:ScheduleCalendar ;
    rdf:type owl:DatatypeProperty ;
