ind:isCriticalPathChanged rdf:type rdf:Property ;
    rdfs:label 'Is Critical Path Changed' ;
    rdfs:comment 'Flag indicating whether the critical path has changed compared to the previous reporting period.' ;
    rdfs:domain ind:ProgressUpdate ;
    rdf:type owl:DatatypeProperty ;
