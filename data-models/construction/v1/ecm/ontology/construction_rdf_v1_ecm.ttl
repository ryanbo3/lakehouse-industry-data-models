ind:calendarType rdf:type rdf:Property ;
    rdfs:label 'Calendar Type' ;
    rdfs:comment 'Classification of the calendar: global (company-wide), project-specific, or resource-specific.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
