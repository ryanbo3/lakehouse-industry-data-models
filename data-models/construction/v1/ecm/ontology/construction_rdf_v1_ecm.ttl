ind:scheduleBaselineName rdf:type rdf:Property ;
    rdfs:label 'Schedule Baseline Name' ;
    rdfs:comment 'Human-readable name given to the schedule baseline (e.g., "Original Contract Baseline").' ;
    rdfs:domain ind:ScheduleBaseline ;
