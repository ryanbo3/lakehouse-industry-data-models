    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requisitionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Requisition Timestamp' ;
    rdfs:comment 'Date-time when the requisition was formally created or issued.' ;
    rdfs:domain ind:RecruitmentRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:skillSet rdf:type rdf:Property ;
    rdfs:label 'Skill Set' ;
    rdfs:comment 'Comma-separated list of key skills and competencies needed.' ;
