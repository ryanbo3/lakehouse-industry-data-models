    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dlpCertificationIssued rdf:type rdf:Property ;
    rdfs:label 'Dlp Certification Issued' ;
    rdfs:comment 'Flag indicating whether a DLP completion certificate has been issued.' ;
    rdfs:domain ind:DlpRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dlpClosureReason rdf:type rdf:Property ;
    rdfs:label 'Dlp Closure Reason' ;
    rdfs:comment 'Reason why the DLP was closed.' ;
    rdfs:domain ind:DlpRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dlpClosureReasonDetail rdf:type rdf:Property ;
    rdfs:label 'Dlp Closure Reason Detail' ;
    rdfs:comment 'Additional details explaining the closure reason.' ;
    rdfs:domain ind:DlpRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dlpComplianceStatus rdf:type rdf:Property ;
    rdfs:label 'Dlp Compliance Status' ;
    rdfs:comment 'Compliance assessment of the DLP against contractual and regulatory requirements.' ;
    rdfs:domain ind:DlpRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dlpDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Dlp Document Reference' ;
    rdfs:comment 'Reference identifier for the primary DLP documentation (e.g., file ID).' ;
    rdfs:domain ind:DlpRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dlpExtensionEndDate rdf:type rdf:Property ;
    rdfs:label 'Dlp Extension End Date' ;
    rdfs:comment 'New expiry date after an approved DLP extension.' ;
    rdfs:domain ind:DlpRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dlpExtensionGranted rdf:type rdf:Property ;
    rdfs:label 'Dlp Extension Granted' ;
    rdfs:comment 'Indicates whether an extension to the DLP has been approved.' ;
    rdfs:domain ind:DlpRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dlpInspectionDate rdf:type rdf:Property ;
    rdfs:label 'Dlp Inspection Date' ;
    rdfs:comment 'Date on which the required DLP inspection was performed.' ;
    rdfs:domain ind:DlpRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dlpInspectionRequired rdf:type rdf:Property ;
    rdfs:label 'Dlp Inspection Required' ;
