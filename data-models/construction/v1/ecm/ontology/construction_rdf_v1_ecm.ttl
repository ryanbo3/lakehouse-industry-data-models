# --- Attribute Properties ---
ind:approvalId rdf:type rdf:Property ;
    rdfs:label 'Approval Id' ;
    rdfs:comment 'Unique system-generated identifier for the bid approval record.' ;
    rdfs:domain ind:Approval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assessmentId rdf:type rdf:Property ;
    rdfs:label 'Assessment Id' ;
    rdfs:comment 'Foreign key linking to compliance.compliance_assessment. Business justification: Bid approval decisions incorporate results of a compliance assessment report to ensure regulatory fit.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Assessment .

ind:bidOpportunityId rdf:type rdf:Property ;
    rdfs:label 'Bid Opportunity Id' ;
    rdfs:comment 'Foreign key linking to bid.bid_opportunity. Business justification: Bid approval should be linked to the originating bid opportunity for traceability.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BidOpportunity .

ind:employeeId rdf:type rdf:Property ;
    rdfs:label 'Employee Id' ;
    rdfs:comment 'System identifier of the individual or role that made the approval decision.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:sustainabilityPlanId rdf:type rdf:Property ;
    rdfs:label 'Sustainability Plan Id' ;
    rdfs:comment 'Foreign key linking to sustainability.sustainability_plan. Business justification: Bid approval process validates alignment with the sustainability plan; the FK captures the specific plan reviewed.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
