    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceStatus rdf:type rdf:Property ;
    rdfs:label 'Service Status' ;
    rdfs:comment 'Current lifecycle status of the service.' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceType rdf:type rdf:Property ;
    rdfs:label 'Service Type' ;
    rdfs:comment 'Category of service provided.' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jvParticipantId rdf:type rdf:Property ;
    rdfs:label 'Jv Participant Id' ;
    rdfs:comment 'Primary key for the jv_participant association' ;
    rdfs:domain ind:JvParticipant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:committedCapitalAmount rdf:type rdf:Property ;
    rdfs:label 'Committed Capital Amount' ;
    rdfs:comment 'The total capital amount this account has committed to contribute to the JV, as defined in the JV agreement. Specific to each participant\'s obligation within the JV.' ;
    rdfs:domain ind:JvParticipant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:equityPercentage rdf:type rdf:Property ;
    rdfs:label 'Equity Percentage' ;
    rdfs:comment 'The percentage equity stake held by this account in the JV structure. Belongs to the participation record, not to the account or JV structure alone, as each participant holds a distinct share.' ;
    rdfs:domain ind:JvParticipant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exitDate rdf:type rdf:Property ;
    rdfs:label 'Exit Date' ;
    rdfs:comment 'The date on which this account exited or is contractually scheduled to exit the JV. Null if the participant remains active through JV dissolution.' ;
    rdfs:domain ind:JvParticipant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:joinDate rdf:type rdf:Property ;
    rdfs:label 'Join Date' ;
    rdfs:comment 'The date on which this account formally joined the JV as a participating entity, as executed in the JV agreement or a subsequent accession deed.' ;
    rdfs:domain ind:JvParticipant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:participationRole rdf:type rdf:Property ;
    rdfs:label 'Participation Role' ;
    rdfs:comment 'The governance and operational role this account holds within the JV structure. Determines voting rights, management responsibilities, and liability exposure.' ;
    rdfs:domain ind:JvParticipant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:obligationAssessmentResultId rdf:type rdf:Property ;
    rdfs:label 'Obligation Assessment Result Id' ;
    rdfs:comment 'Primary key for the obligation_assessment_result association' ;
    rdfs:domain ind:ObligationAssessmentResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:evaluatedDate rdf:type rdf:Property ;
    rdfs:label 'Evaluated Date' ;
    rdfs:comment 'Date on which this specific obligation was evaluated within the assessment. May differ from the overall assessment_date when assessments span multiple days or phases. Sourced from detection phase (obligation_assessment_date).' ;
    rdfs:domain ind:ObligationAssessmentResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:findings rdf:type rdf:Property ;
    rdfs:label 'Findings' ;
    rdfs:comment 'Specific audit findings or observations recorded for this obligation during this assessment. Belongs to the intersection, not to the assessment summary or the obligation master record.' ;
    rdfs:domain ind:ObligationAssessmentResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gapStatus rdf:type rdf:Property ;
    rdfs:label 'Gap Status' ;
    rdfs:comment 'Whether a compliance gap was identified for this specific obligation in this assessment. Sourced directly from detection phase relationship data.' ;
    rdfs:domain ind:ObligationAssessmentResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:obligationsAssessed rdf:type rdf:Property ;
    rdfs:label 'Obligations Assessed' ;
    rdfs:comment 'List or description of regulatory obligations evaluated during the assessment. [Moved from assessment: This STRING field is a denormalized, multi-value representation of the M:N relationship between assessment and regulatory_obligation. It must be removed and replaced by the obligation_assessment_result association table, which properly normalizes each obligation-assessment intersection as a discrete record.]' ;
    rdfs:domain ind:ObligationAssessmentResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradeStaffingRequirementId rdf:type rdf:Property ;
    rdfs:label 'Trade Staffing Requirement Id' ;
    rdfs:comment 'Primary key for the trade_staffing_requirement association' ;
    rdfs:domain ind:TradeStaffingRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:plannedHeadcount rdf:type rdf:Property ;
    rdfs:label 'Planned Headcount' ;
    rdfs:comment 'Number of workers of this trade planned for deployment within this staffing plan. Trade-specific value that cannot reside on the plan-level staffing_plan record.' ;
    rdfs:domain ind:TradeStaffingRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:plannedLaborHours rdf:type rdf:Property ;
    rdfs:label 'Planned Labor Hours' ;
    rdfs:comment 'Total planned labor hours for this trade within this staffing plan. Trade-specific value used for earned value management and labor cost forecasting.' ;
    rdfs:domain ind:TradeStaffingRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lookaheadActivityCommitmentId rdf:type rdf:Property ;
    rdfs:label 'Lookahead Activity Commitment Id' ;
    rdfs:comment 'Primary key for the lookahead_activity_commitment association' ;
    rdfs:domain ind:LookaheadActivityCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:commitmentStatus rdf:type rdf:Property ;
    rdfs:label 'Commitment Status' ;
    rdfs:comment 'Last Planner System commitment status for this activity in this window. Tracks whether the foreman/superintendent made a formal commitment to complete this activity and whether it was fulfilled — the basis for PPC calculation.' ;
    rdfs:domain ind:LookaheadActivityCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lookaheadFinishDate rdf:type rdf:Property ;
    rdfs:label 'Lookahead Finish Date' ;
    rdfs:comment 'Finish date used in the look-ahead planning window. [Moved from activity: Same reasoning as lookahead_start_date — this is a per-window planning date, not a fixed property of the activity. Storing it on the activity flattens the rolling-window model. It belongs to the association as planned_finish_date.]' ;
    rdfs:domain ind:LookaheadActivityCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lookaheadStartDate rdf:type rdf:Property ;
    rdfs:label 'Lookahead Start Date' ;
    rdfs:comment 'Start date used in the look-ahead planning window. [Moved from activity: This date is window-specific — the same activity has a different planned start date in each successive lookahead window as near-term planning is refined. Storing it on the activity record implies a single lookahead window per activity, which is incorrect for LPS. It belongs to the association as planned_start_date.]' ;
    rdfs:domain ind:LookaheadActivityCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reasonNotCompleted rdf:type rdf:Property ;
    rdfs:label 'Reason Not Completed' ;
    rdfs:comment 'If commitment_status is NOT_COMPLETED, captures the root cause reason. Used for LPS variance analysis and continuous improvement. Belongs to the association as it describes why a specific commitment in a specific window was not fulfilled.' ;
    rdfs:domain ind:LookaheadActivityCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:activityDelayImpactId rdf:type rdf:Property ;
    rdfs:label 'Activity Delay Impact Id' ;
    rdfs:comment 'Primary key for the activity_delay_impact association' ;
    rdfs:domain ind:ActivityDelayImpact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:activityIdsImpacted rdf:type rdf:Property ;
    rdfs:label 'Activity Ids Impacted' ;
    rdfs:comment 'Comma-separated list of activity identifiers that are affected by the delay. [Moved from delay_event: This comma-separated STRING field is a denormalized anti-pattern that was compensating for the missing association table. Once the activity_delay_impact association table exists, this field is redundant and should be retired.]' ;
    rdfs:domain ind:ActivityDelayImpact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .
