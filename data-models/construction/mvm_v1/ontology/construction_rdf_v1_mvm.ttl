    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sourceChannel rdf:type rdf:Property ;
    rdfs:label 'Source Channel' ;
    rdfs:comment 'Origin channel through which the opportunity was generated.' ;
    rdfs:domain ind:BidOpportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:winLossStatus rdf:type rdf:Property ;
