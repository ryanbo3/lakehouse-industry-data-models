    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lotNumber rdf:type rdf:Property ;
    rdfs:label 'Lot Number' ;
    rdfs:comment 'Lot identifier used for quality control and recall management.' ;
    rdfs:domain ind:Material ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manufacturerCountry rdf:type rdf:Property ;
    rdfs:label 'Manufacturer Country' ;
    rdfs:comment 'ISO 3166-1 alpha-3 code of the manufacturer’s country.' ;
