ind:bondType rdf:type rdf:Property ;
    rdfs:label 'Bond Type' ;
    rdfs:comment 'Classification of the bond instrument (e.g., bank guarantee, surety bond, insurance bond).' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expiryPlace rdf:type rdf:Property ;
    rdfs:label 'Expiry Place' ;
    rdfs:comment 'Geographic location where the bond is to be returned or expires.' ;
    rdfs:domain ind:Bond ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guaranteeExtensionAllowed rdf:type rdf:Property ;
    rdfs:label 'Guarantee Extension Allowed' ;
    rdfs:comment 'Indicates whether the bond terms permit extensions.' ;
    rdfs:domain ind:Bond ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:guaranteeExtensionReason rdf:type rdf:Property ;
    rdfs:label 'Guarantee Extension Reason' ;
    rdfs:comment 'Reason provided for the most recent bond extension.' ;
    rdfs:domain ind:Bond ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuePlace rdf:type rdf:Property ;
    rdfs:label 'Issue Place' ;
    rdfs:comment 'Geographic location (city/country) where the bond was issued.' ;
    rdfs:domain ind:Bond ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuerType rdf:type rdf:Property ;
    rdfs:label 'Issuer Type' ;
    rdfs:comment 'Category of the issuing entity: bank, surety, or insurance.' ;
    rdfs:domain ind:Bond ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingEntity rdf:type rdf:Property ;
    rdfs:label 'Issuing Entity' ;
    rdfs:comment 'Name of the bank, surety, or insurance company that issued the bid bond.' ;
    rdfs:domain ind:Bond ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastExtensionDate rdf:type rdf:Property ;
    rdfs:label 'Last Extension Date' ;
    rdfs:comment 'Date of the most recent expiry extension.' ;
    rdfs:domain ind:Bond ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastUpdatedBy rdf:type rdf:Property ;
    rdfs:label 'Last Updated By' ;
    rdfs:comment 'User identifier who performed the most recent update to the record.' ;
    rdfs:domain ind:Bond ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:percentage rdf:type rdf:Property ;
    rdfs:label 'Percentage' ;
    rdfs:comment 'Bond amount expressed as a percentage of the total tender value.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:statusDate rdf:type rdf:Property ;
    rdfs:label 'Status Date' ;
    rdfs:comment 'Date on which the current status became effective.' ;
    rdfs:domain ind:Bond ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:totalExtensionDays rdf:type rdf:Property ;
    rdfs:label 'Total Extension Days' ;
    rdfs:comment 'Cumulative number of days added to the original expiry date through extensions.' ;
    rdfs:domain ind:Bond ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:attachedDocuments rdf:type rdf:Property ;
    rdfs:label 'Attached Documents' ;
    rdfs:comment 'Comma-separated list of document identifiers linked to the risk.' ;
    rdfs:domain ind:Risk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bidRiskStatus rdf:type rdf:Property ;
    rdfs:label 'Bid Risk Status' ;
    rdfs:comment 'Current lifecycle state of the risk.' ;
    rdfs:domain ind:Risk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exposureCurrency rdf:type rdf:Property ;
    rdfs:label 'Exposure Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for monetary impact fields.' ;
    rdfs:domain ind:Risk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impactCost rdf:type rdf:Property ;
    rdfs:label 'Impact Cost' ;
    rdfs:comment 'Estimated monetary impact if the risk materialises, expressed in the project currency.' ;
    rdfs:domain ind:Risk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:impactQuality rdf:type rdf:Property ;
    rdfs:label 'Impact Quality' ;
    rdfs:comment 'Qualitative effect of the risk on project quality standards.' ;
    rdfs:domain ind:Risk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impactScheduleDays rdf:type rdf:Property ;
    rdfs:label 'Impact Schedule Days' ;
    rdfs:comment 'Estimated schedule delay in days caused by the risk.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isKeyRisk rdf:type rdf:Property ;
    rdfs:label 'Is Key Risk' ;
    rdfs:comment 'Flag indicating whether the risk is considered a key risk for the bid.' ;
    rdfs:domain ind:Risk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mitigationEndDate rdf:type rdf:Property ;
    rdfs:label 'Mitigation End Date' ;
    rdfs:comment 'Planned or actual completion date for mitigation.' ;
    rdfs:domain ind:Risk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mitigationStartDate rdf:type rdf:Property ;
    rdfs:label 'Mitigation Start Date' ;
    rdfs:comment 'Planned start date for mitigation activities.' ;
    rdfs:domain ind:Risk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:origin rdf:type rdf:Property ;
    rdfs:label 'Origin' ;
    rdfs:comment 'Origin of the risk, indicating whether it arises from internal processes or external factors.' ;
    rdfs:domain ind:Risk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:residualImpactCost rdf:type rdf:Property ;
    rdfs:label 'Residual Impact Cost' ;
    rdfs:comment 'Estimated monetary impact remaining after mitigation.' ;
    rdfs:domain ind:Risk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:residualProbability rdf:type rdf:Property ;
    rdfs:label 'Residual Probability' ;
    rdfs:comment 'Likelihood of the risk after mitigation actions are applied.' ;
    rdfs:domain ind:Risk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewFrequency rdf:type rdf:Property ;
    rdfs:label 'Review Frequency' ;
    rdfs:comment 'How often the risk is reviewed and re-assessed.' ;
    rdfs:domain ind:Risk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskCode rdf:type rdf:Property ;
    rdfs:label 'Risk Code' ;
    rdfs:comment 'External reference code used by project teams to identify the risk in reports and documents.' ;
    rdfs:domain ind:Risk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:score rdf:type rdf:Property ;
    rdfs:label 'Score' ;
    rdfs:comment 'Composite score derived from probability and impact, used for prioritisation.' ;
    rdfs:domain ind:Risk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvalId rdf:type rdf:Property ;
    rdfs:label 'Approval Id' ;
    rdfs:comment 'Unique system-generated identifier for the bid approval record.' ;
    rdfs:domain ind:Approval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assessmentId rdf:type rdf:Property ;
    rdfs:label 'Assessment Id' ;
    rdfs:comment 'Foreign key linking to compliance.compliance_assessment. Business justification: Bid approval decisions incorporate results of a compliance assessment report to ensure regulatory fit.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Assessment .

ind:approvalNumber rdf:type rdf:Property ;
    rdfs:label 'Approval Number' ;
    rdfs:comment 'Human-readable reference number assigned to the approval event per internal governance policy.' ;
    rdfs:domain ind:Approval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedBidPrice rdf:type rdf:Property ;
    rdfs:label 'Approved Bid Price' ;
    rdfs:comment 'Final approved monetary amount for the bid.' ;
    rdfs:domain ind:Approval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvedMarginPct rdf:type rdf:Property ;
    rdfs:label 'Approved Margin Pct' ;
    rdfs:comment 'Approved profit margin expressed as a percentage of the bid price.' ;
    rdfs:domain ind:Approval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bondingCapacityScore rdf:type rdf:Property ;
    rdfs:label 'Bonding Capacity Score' ;
    rdfs:comment 'Score reflecting the company\'s ability to provide required bid bonds.' ;
    rdfs:domain ind:Approval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:clientRelationshipScore rdf:type rdf:Property ;
    rdfs:label 'Client Relationship Score' ;
    rdfs:comment 'Score reflecting the strength of the relationship with the client.' ;
    rdfs:domain ind:Approval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:conditionsImposed rdf:type rdf:Property ;
    rdfs:label 'Conditions Imposed' ;
    rdfs:comment 'Any contractual or operational conditions attached to the approval.' ;
    rdfs:domain ind:Approval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decisionAuthorityName rdf:type rdf:Property ;
    rdfs:label 'Decision Authority Name' ;
    rdfs:comment 'Full name of the person or entity authorizing the decision.' ;
    rdfs:domain ind:Approval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decisionAuthorityRole rdf:type rdf:Property ;
    rdfs:label 'Decision Authority Role' ;
    rdfs:comment 'Organizational role or title of the decision authority.' ;
    rdfs:domain ind:Approval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decisionOutcome rdf:type rdf:Property ;
    rdfs:label 'Decision Outcome' ;
    rdfs:comment 'Result of the approval process (e.g., bid, no_bid, conditional_bid, approved, approved_with_conditions, rejected, deferred). [ENUM-REF-CANDIDATE: bid|no_bid|conditional_bid|approved|approved_with_conditions|rejected|deferred — promote to reference product]' ;
    rdfs:domain ind:Approval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decisionRationale rdf:type rdf:Property ;
    rdfs:label 'Decision Rationale' ;
    rdfs:comment 'Free-text explanation of the reasoning behind the decision.' ;
    rdfs:domain ind:Approval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decisionStage rdf:type rdf:Property ;
    rdfs:label 'Decision Stage' ;
    rdfs:comment 'Governance stage at which the decision was taken.' ;
    rdfs:domain ind:Approval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decisionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Decision Timestamp' ;
    rdfs:comment 'Exact date-time when the approval decision was recorded.' ;
    rdfs:domain ind:Approval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:delegationOfAuthorityLevel rdf:type rdf:Property ;
    rdfs:label 'Delegation Of Authority Level' ;
    rdfs:comment 'Authorized delegation tier that permitted the decision.' ;
    rdfs:domain ind:Approval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isConditional rdf:type rdf:Property ;
    rdfs:label 'Is Conditional' ;
    rdfs:comment 'Indicates whether the approval is subject to conditions.' ;
    rdfs:domain ind:Approval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:marginPotentialScore rdf:type rdf:Property ;
    rdfs:label 'Margin Potential Score' ;
    rdfs:comment 'Projected profitability score based on estimated margins.' ;
    rdfs:domain ind:Approval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pursuitInvestmentJustification rdf:type rdf:Property ;
    rdfs:label 'Pursuit Investment Justification' ;
    rdfs:comment 'Business case narrative justifying the investment of resources into the bid pursuit.' ;
    rdfs:domain ind:Approval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resourceAvailabilityScore rdf:type rdf:Property ;
    rdfs:label 'Resource Availability Score' ;
    rdfs:comment 'Score indicating the availability of required resources for the project.' ;
    rdfs:domain ind:Approval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:riskProfileScore rdf:type rdf:Property ;
    rdfs:label 'Risk Profile Score' ;
    rdfs:comment 'Score assessing the risk exposure of the bid.' ;
    rdfs:domain ind:Approval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:strategicFitScore rdf:type rdf:Property ;
    rdfs:label 'Strategic Fit Score' ;
    rdfs:comment 'Score measuring alignment of the bid with corporate strategy.' ;
    rdfs:domain ind:Approval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalGovernanceScore rdf:type rdf:Property ;
    rdfs:label 'Total Governance Score' ;
    rdfs:comment 'Aggregated score from all governance criteria used to evaluate the bid.' ;
    rdfs:domain ind:Approval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:masterId rdf:type rdf:Property ;
    rdfs:label 'Master Id' ;
    rdfs:comment 'Primary key for master' ;
    rdfs:domain ind:Master ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:substitutionMaterialMasterId rdf:type rdf:Property ;
    rdfs:label 'Substitution Material Master Id' ;
    rdfs:comment 'Identifier of an approved substitute material.' ;
    rdfs:domain ind:Master ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Master .

ind:conformanceCertificateDate rdf:type rdf:Property ;
    rdfs:label 'Conformance Certificate Date' ;
    rdfs:comment 'Date the compliance certificate was issued.' ;
