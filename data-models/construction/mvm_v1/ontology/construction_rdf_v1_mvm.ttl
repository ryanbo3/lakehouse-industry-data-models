    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:masterDescription rdf:type rdf:Property ;
    rdfs:label 'Master Description' ;
    rdfs:comment 'Detailed textual description of the material, including typical applications.' ;
