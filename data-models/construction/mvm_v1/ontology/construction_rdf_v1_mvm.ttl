# RDFS Schema for Business: Construction

@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix ind: <http://datamodel.lakehouse.org/business/construction#> .

# --- Root Business Class ---
ind:Business rdf:type rdfs:Class ;
    rdfs:label 'Business' ;
    rdfs:comment 'Root class for all business entities' .

# --- Specific Business: Construction ---
ind:Construction rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Business ;
    rdfs:label 'Construction' ;
    rdfs:comment 'Construction is a global engineering and building industry delivering large-scale infrastructure, energy, and commercial projects including highways, airports, bridges, power plants, and residential developments.' .

# --- Domain Classes ---
ind:Project rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Construction ;
    rdfs:label 'Project' ;
    rdfs:comment 'Core SSOT for all construction project lifecycle data from NTP through commissioning and handover. Owns project identity, WBS (Work Breakdown Structure), milestones, baseline scope, EVM metrics (CPI, SPI), deliverables, and project performance tracking. Central to EPC (Engineering Procurement Construction) execution and PMO (Project Management Office) governance across DB, DBB, and PPP delivery models.' .

ind:Client rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Construction ;
    rdfs:label 'Client' ;
    rdfs:comment 'Master client/owner data managing relationships with project owners, developers, and sponsors who commission construction work. Owns client profiles, account hierarchies, JV structures, stakeholder contacts, communication preferences, and relationship history. Supports CRM (Customer Relationship Management), opportunity pipeline management, and client segmentation across public-sector, private-sector, and PPP/BOT arrangements.' .

ind:Contract rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Construction ;
    rdfs:label 'Contract' ;
    rdfs:comment 'Authoritative contract repository governing all contractual agreements including FIDIC-based EPC, GMP (Guaranteed Maximum Price), lump-sum, and unit-rate contracts. Owns CO (Change Order) logs, LD (Liquidated Damages) provisions, DLP (Defects Liability Period) terms, EOT (Extension of Time) entitlements, payment schedules, and contract milestone administration.' .

ind:Site rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Construction ;
    rdfs:label 'Site' ;
    rdfs:comment 'Owns daily site execution data including daily logs, production tracking, work fronts, crew assignments, site logistics, mobilization/demobilization, concrete pours, earthworks volumes, and field progress measurements. Integrates with HCSS HeavyJob for cost coding and production tracking and Procore for daily logs and field management. Supports earned value computation feeding the project domain.' .

ind:Design rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Construction ;
    rdfs:label 'Design' ;
    rdfs:comment 'Engineering and design domain owning BIM models, CAD drawings, technical specifications, design packages, RFIs, submittals, clash detection, document control registers, transmittals, correspondence, workflow approvals, and handover documentation for construction projects' .

ind:Procurement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Construction ;
    rdfs:label 'Procurement' ;
    rdfs:comment 'Procurement and supply chain domain managing the full source-to-contract lifecycle including RFQ/RFP issuance, vendor evaluation, PO (Purchase Order) creation, MTO (Material Take-Off) data, supplier qualification records, and procurement lead times. Coordinates material delivery schedules with project timelines and manages vendor master data via SAP MM.' .

ind:Material rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Construction ;
    rdfs:label 'Material' ;
    rdfs:comment 'Materials management domain tracking inventory, stock levels, material receipts, consumption, transfers between sites, and material traceability (batch/lot tracking for concrete, steel, MEP components). Manages BOQ (Bill of Quantities) reconciliation, material specifications, FAT/SAT records, material conformance certificates, and warehouse operations for construction materials and consumables.' .

ind:Equipment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Construction ;
    rdfs:label 'Equipment' ;
    rdfs:comment 'Construction equipment and fleet management domain tracking heavy machinery (cranes, excavators, concrete pumps), tools, generators, and fleet vehicles. Owns asset master data, utilization tracking, maintenance schedules, equipment hours, mobilization/demobilization records, rental vs. owned classification, and asset lifecycle management via SAP PM and HCSS HeavyJob.' .

ind:Workforce rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Construction ;
    rdfs:label 'Workforce' ;
    rdfs:comment 'Construction workforce management domain tracking labor resources, crew assignments, time tracking, production rates, skill certifications, labor cost coding, field personnel deployment, and site access records. Manages craft labor, supervision, and project-based staffing distinct from corporate HR functions. Integrates with HCSS HeavyJob for timesheets and SAP SuccessFactors for HCM.' .

ind:Schedule rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Construction ;
    rdfs:label 'Schedule' ;
    rdfs:comment 'Project scheduling domain managing CPM (Critical Path Method) networks, activity sequencing, resource leveling, critical path analysis, progress tracking, baseline comparisons, look-ahead plans, and schedule performance metrics (SPI). Integrates with Oracle Primavera P6 for schedule exports and EVM (Earned Value Management) for project control.' .

ind:Quality rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Construction ;
    rdfs:label 'Quality' ;
    rdfs:comment 'QA/QC (Quality Assurance/Quality Control) domain managing ITP (Inspection and Test Plans), NCR (Non-Conformance Reports), inspection checklists, material test certificates, weld records, FAT (Factory Acceptance Test), SAT (Site Acceptance Test), and defect tracking through DLP. Ensures construction deliverables meet specifications and ISO 9001 standards.' .

ind:Safety rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Construction ;
    rdfs:label 'Safety' ;
    rdfs:comment 'HSE (Health Safety Environment) domain managing incident reports, LTI (Lost Time Injury), TRIR (Total Recordable Incident Rate), near-miss records, SWMS (Safe Work Method Statements), PTW (Permit to Work), TBM (Toolbox Meeting) records, safety audits, corrective actions, PPE compliance, and environmental compliance records. Integrates with Intelex for incident management and OSHA/ISO 45001 regulatory reporting.' .

ind:Finance rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Construction ;
    rdfs:label 'Finance' ;
    rdfs:comment 'SSOT for all project and corporate financial data including job costing, budget vs. actual, GL/AP/AR entries, progress billing, revenue recognition (percentage of completion), cost codes, cost centers, WBS-linked budgets, EVM financial outputs (CPI), cash flow forecasting, P&L (Profit and Loss), and EBITDA reporting. Integrates with SAP S/4HANA and Viewpoint Vista for construction accounting and IFRS/GAAP compliance.' .

ind:Bid rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Construction ;
    rdfs:label 'Bid' ;
    rdfs:comment 'Pre-award commercial pipeline domain owning RFP/RFQ responses, tender submissions, BOQ pricing, project estimation data, win/loss records, bid bond management, and GMP/lump-sum bid preparation. Integrates with Salesforce CRM for opportunity tracking and pipeline forecasting. Tracks bid-to-award conversion rates across market segments.' .

ind:Compliance rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Construction ;
    rdfs:label 'Compliance' ;
    rdfs:comment 'Regulatory compliance domain owning permit registers, environmental impact assessments, LEED certification tracking, building permit records, and regulatory reporting submissions to OSHA, EPA, and local authorities. Manages GDPR/privacy obligations for workforce and client data and PCI DSS controls for financial transactions. Distinct from safety (which owns incident data) and quality (which owns NCRs).' .

# --- Data Product Classes (Tables) ---
ind:Account rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Client ;
    rdfs:label 'Account' ;
    rdfs:comment 'Master record for each client/owner organization that commissions construction work. SSOT for client identity across public-sector agencies, private developers, government bodies, and corporate sponsors. Captures legal entity name, registration number, tax ID, industry sector, client tier, credit rating, preferred contract type (EPC, GMP, DBB, PPP, BOT), account status, CRM account owner, and segment assignments. Sourced from Salesforce CRM Account object. All other client domain products reference this entity.' .

ind:Contact rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Client ;
    rdfs:label 'Contact' ;
    rdfs:comment 'Individual stakeholder contact associated with a client account, including project owners, technical representatives, procurement officers, legal counsel, and executive sponsors. Captures full name, job title, department, email, phone, preferred communication channel, decision-making authority level, and relationship health indicator. Sourced from Salesforce CRM Contact object.' .

ind:JvStructure rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Client ;
    rdfs:label 'Jv Structure' ;
    rdfs:comment 'Defines Joint Venture (JV) arrangements where multiple client entities co-sponsor or co-own a construction project. Captures JV name, lead sponsor, participating entities, equity share percentages, JV agreement reference, governing law, JV type (PPP, BOT, consortium), formation date, dissolution date, and JV management structure. Critical for PPP and BOT project delivery models.' .

ind:Address rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Client ;
    rdfs:label 'Address' ;
    rdfs:comment 'Physical and mailing addresses associated with client accounts, including registered office, billing address, project site liaison office, and correspondence address. Captures address type, street, city, state/province, postal code, country, GIS coordinates, and address validation status. Supports multi-jurisdiction clients operating across regions.' .

ind:ClientOpportunity rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Client ;
    rdfs:label 'Client Opportunity' ;
    rdfs:comment 'Pre-award commercial opportunity record tracking potential construction projects in the BD pipeline. Captures opportunity name, client account, project type, estimated contract value, delivery model (EPC, GMP, DBB, PPP), bid/no-bid decision, probability of win, expected NTP date, pipeline stage, BD owner, and win/loss outcome. Sourced from Salesforce CRM Opportunity object. SSOT for pipeline forecasting.' .

ind:ProjectEngagement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Client ;
    rdfs:label 'Project Engagement' ;
    rdfs:comment 'Bridge record linking a client account to a specific construction project they commission, sponsor, or fund. Captures client role (owner, co-sponsor, JV lead, funding agency, end-user), engagement start and end dates, primary client representative, contract reference, engagement status, and satisfaction indicators. SSOT for which clients are involved in which projects from the client domain perspective. Does not duplicate project master data owned by the project domain.' .

ind:RfpIssuance rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Client ;
    rdfs:label 'Rfp Issuance' ;
    rdfs:comment 'Records RFP (Request for Proposal), RFQ (Request for Quotation), and ITT (Invitation to Tender) documents issued by clients, initiating the formal bid process. Captures RFP reference number, client account, project description, issue date, submission deadline, bond requirements (bid bond, performance bond), evaluation criteria weights, delivery model, pre-bid meeting dates, and linked opportunity. This is the client-side solicitation record; the firm\'s response is managed in the bid domain.' .

ind:AccountCreditProfile rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Client ;
    rdfs:label 'Account Credit Profile' ;
    rdfs:comment 'Financial creditworthiness and payment behavior profile for each client account, supporting contract terms negotiation and financial risk management. Captures credit limit, approved payment terms (net 30/60/90), average payment days (DSO), overdue balance, external credit rating (D&B, S&P), internal credit score, last credit review date, payment history rating, credit hold status, special payment arrangements (retention release schedules, milestone-based payments), and sovereign risk indicator for government clients. Updated periodically by finance with input from BD for relationship context.' .

ind:FrameworkAgreement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Client ;
    rdfs:label 'Framework Agreement' ;
    rdfs:comment 'Long-term framework agreements, master service agreements (MSA), or term contracts established with repeat clients, defining pre-agreed rates, scope categories, KPIs, and call-off procedures for multiple projects over a defined period. Captures agreement title, client account, agreement type (framework, MSA, term contract, blanket order), effective date, expiry date, total ceiling value, call-off mechanism, performance KPIs, renewal terms, and extension options. Common with public-sector clients (e.g., highways agencies, utilities) who procure repeat works under a single competitive framework.' .

ind:WorkFront rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Site ;
    rdfs:label 'Work Front' ;
    rdfs:comment 'Master record for each active work front (zone, area, or face) on a construction site where concurrent work activities are executed. Tracks work front identity, location coordinates (GPS/grid reference), zone classification, active/inactive status, assigned foreman, mobilization date, demobilization date, current phase, associated WBS element, and parent site reference. Serves as the primary spatial and organizational anchor for all site-level transactional records — every operational product in this domain holds a mandatory or optional FK to work_front. The work_front-centric topology enables spatial aggregation of production, cost, progress, and resource data by zone.' .

ind:DailyLog rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Site ;
    rdfs:label 'Daily Log' ;
    rdfs:comment 'Official daily site log (header + line-item structure) capturing all field activities for a given project site and date. The header records weather conditions (temperature, precipitation, wind), site access status, manpower headcount by trade, equipment on site, work performed narrative, superintendent sign-off, and overall site status. Embedded line-item events capture each notable occurrence including delay events, weather stoppages, utility strikes, design holds, access restrictions, and safety observations — each with event type, start/end time, duration, affected work fronts, root cause classification, responsible party, and EOT/cost impact flags. This is the SSOT for all site event data — no separate event entity exists. Sourced from Procore Daily Logs module. Serves as the legal and operational record of site activity and the primary evidence base for delay claims and EOT substantiation.' .

ind:ProductionEntry rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Site ;
    rdfs:label 'Production Entry' ;
    rdfs:comment 'Granular production tracking record capturing quantities of work completed per activity, cost code, and work front for a specific date. Sourced from HCSS HeavyJob production tracking module. Stores installed quantity, unit of measure, production rate (units/hour), budgeted quantity, percent complete, crew size, equipment hours consumed, and cost code. Feeds earned value computation and progress billing in the project and finance domains.' .

ind:CrewDeployment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Site ;
    rdfs:label 'Crew Deployment' ;
    rdfs:comment 'Daily assignment record linking a named crew or gang to a specific work front, activity, and cost code for a given date. Captures crew type (civil, MEP, concrete, steel erection), crew size, lead foreman, shift start/end times, overtime flag, productivity notes, and planned vs actual hours. Sourced from HCSS HeavyJob time tracking. Holds mandatory FK to work_front for spatial allocation. Distinct from workforce domain employee records — this entity tracks the operational deployment of crews to site activities, not individual labor records.' .

ind:FieldProgress rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Site ;
    rdfs:label 'Field Progress' ;
    rdfs:comment 'Periodic field progress measurement record capturing percent complete and installed quantities for a WBS activity or BOQ line item as physically measured in the field. Stores measurement date, measurement method (visual estimate, quantity survey, milestone completion, 3D scan comparison), reported percent complete, previous percent complete, incremental progress delta, field engineer name, and approval status. Feeds EVM (Earned Value Management) calculations including BCWP, CPI, and SPI in the project domain. Provides the ground-truth measurement that reconciles against schedule domain planned progress.' .

ind:SiteMobilization rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Site ;
    rdfs:label 'Site Mobilization' ;
    rdfs:comment 'Master record tracking the mobilization and demobilization lifecycle of a construction site or major work package. Captures planned mobilization date, actual mobilization date, NTP (Notice to Proceed) date, site establishment milestones (fencing, laydown area, site office, utilities), demobilization plan date, actual demobilization date, and site closure sign-off. Provides the temporal and logistical anchor for all site operations.' .

ind:EquipmentDeployment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Site ;
    rdfs:label 'Equipment Deployment' ;
    rdfs:comment 'Daily or period-based record of construction equipment deployed to a specific work front or activity on site. Captures equipment ID (FK to equipment domain), deployment date, release date, operating hours, idle hours, cost code, operator name, fuel consumption, and breakdown flag. Sourced from HCSS HeavyJob equipment hours module. Distinct from equipment domain master records — this entity tracks the operational utilization of equipment at the site level.' .

ind:MaterialDelivery rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Site ;
    rdfs:label 'Material Delivery' ;
    rdfs:comment 'Site-level record of material deliveries received at the construction site gate or designated laydown area. Captures delivery date, supplier name, PO reference (FK to procurement domain), delivery docket number, material description, quantity delivered, unit of measure, receiving location (laydown zone per site_logistics_plan), condition on receipt (accepted/rejected/partial), receiver name, temperature-sensitive storage flag, and discrepancy notes. Distinct from procurement domain PO records — this entity captures the physical receipt event at the site and triggers material domain stock updates.' .

ind:Instruction rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Site ;
    rdfs:label 'Instruction' ;
    rdfs:comment 'Formal site instruction issued by the engineer or client representative directing the contractor to carry out specific work, vary a method, or address a site condition. Captures instruction number, issue date, issuing authority, instruction description, affected work front, urgency classification, contractor acknowledgment date, and cost/time impact flag. Feeds the contract administration and change order process in the contract domain.' .

ind:ShiftReport rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Site ;
    rdfs:label 'Shift Report' ;
    rdfs:comment 'Shift-level operational report summarizing activities, headcount, production achieved, issues encountered, and safety observations for a specific shift (day/night/swing) on a work front. Captures shift type, shift supervisor, start/end time, total labor hours, production summary by cost code, equipment utilization summary, open issues count, and shift handover notes. Distinct from daily_log in that it provides finer temporal granularity for 24-hour continuous operations (e.g., tunnel boring, continuous concrete pours, night-shift earthworks) where a single daily log is insufficient. Multiple shift_reports may feed into one daily_log.' .

ind:ConstructionProject rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Project ;
    rdfs:label 'Construction Project' ;
    rdfs:comment 'Core master entity representing a construction project from NTP (Notice to Proceed) through commissioning and handover. Owns project identity, delivery model (EPC, DB, DBB, PPP, BOT), project type (infrastructure, commercial, residential, energy, industrial), contract value, project status, geographic location, client reference, PMO classification, project type classification (typical duration/value ranges, required certifications, sector), and key lifecycle dates. SSOT for all project-level identity, metadata, and classification across the enterprise.' .

ind:WbsElement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Project ;
    rdfs:label 'Wbs Element' ;
    rdfs:comment 'Work Breakdown Structure (WBS) node representing a decomposed scope element within a construction project. Captures WBS code, level, parent-child hierarchy, scope description, responsible discipline, budgeted cost, planned quantity, unit of measure, and WBS type (summary, work package, control account). Supports EVM (Earned Value Management) rollup and cost control at granular scope levels.' .

ind:ProjectMilestone rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Project ;
    rdfs:label 'Project Milestone' ;
    rdfs:comment 'Key contractual and internal milestones within a construction project lifecycle, including NTP, design completion, procurement completion, construction start, mechanical completion, commissioning, and handover. Tracks planned date, forecast date, actual date, milestone type, contractual obligation flag, LD (Liquidated Damages) trigger flag, and milestone owner. Supports schedule performance and contract administration.' .

ind:ProjectBaseline rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Project ;
    rdfs:label 'Project Baseline' ;
    rdfs:comment 'Approved project baseline and budget revision record maintaining the complete audit trail of authorized scope, schedule, and cost parameters throughout the project lifecycle. Each record captures a point-in-time snapshot: baseline type (original, revised, re-baseline, CO incorporation, re-forecast, management reserve release), revision number, revision date, approval date, approving authority, total baseline cost, baseline duration, baseline start and finish dates, budget amount before and after revision, cost account or WBS-level budget breakdown, and justification narrative. Supports EVM variance analysis (current performance vs approved baseline), change impact tracking, budget evolution audit trail at both project and cost-account level, and PMO governance and financial audit requirements.' .

ind:ProgressMeasurement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Project ;
    rdfs:label 'Progress Measurement' ;
    rdfs:comment 'Periodic physical progress measurement record at WBS element or activity level, capturing percent complete, earned quantity, installed quantity, measurement method (weighted steps, milestone, units complete), measurement date, reporting period, and verifying engineer. Feeds EVM calculations and progress billing. Sourced from HCSS HeavyJob production tracking and Procore field management.' .

ind:ProjectChangeOrder rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Project ;
    rdfs:label 'Project Change Order' ;
    rdfs:comment 'Formal change order (CO) record capturing approved scope, schedule, and cost changes to the project baseline. Tracks CO number, description, change type (scope addition, scope reduction, design change, unforeseen condition), cost impact, schedule impact (EOT — Extension of Time), originator, approval status, approval date, and contract reference. SSOT for all approved project changes. Sourced from Procore Change Orders module.' .

ind:CostAccount rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Project ;
    rdfs:label 'Cost Account' ;
    rdfs:comment 'Project cost account (control account) representing the intersection of WBS element and cost code for job costing and budget control. Captures cost account code, description, cost type (labor, material, equipment, subcontract, overhead), original budget, approved budget (including COs), committed cost, actual cost to date, forecast cost at completion, and variance. SSOT for project-level cost control. Sourced from SAP S/4HANA Project Systems and Viewpoint Vista Job Costing.' .

ind:Deliverable rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Project ;
    rdfs:label 'Deliverable' ;
    rdfs:comment 'Project deliverable record representing a contractually or technically required output (engineering deliverable, construction deliverable, commissioning package, handover document). Captures deliverable code, title, discipline, deliverable type, responsible party, planned issue date, forecast issue date, actual issue date, revision status, and acceptance status. Supports handover and DLP (Defects Liability Period) tracking.' .

ind:RiskRegister rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Project ;
    rdfs:label 'Risk Register' ;
    rdfs:comment 'Project risk register entry capturing identified risks and opportunities at project or WBS level. Tracks risk ID, description, risk category (technical, commercial, schedule, HSE, regulatory, force majeure), probability, impact (cost, schedule, quality), risk score, mitigation strategy, contingency plan, risk owner, status (open, mitigated, closed, realized), and residual risk assessment. Supports PMO governance and contingency management.' .

ind:Phase rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Project ;
    rdfs:label 'Phase' ;
    rdfs:comment 'Structured phase definition within a construction project lifecycle (feasibility, pre-construction, FEED, detailed engineering, procurement, construction, pre-commissioning, commissioning, handover, DLP). Captures phase code, name, sequence, planned and actual start/finish dates, phase status, phase weight for EVM rollup, gate review criteria, gate approval status, gate approval date, and phase deliverables checklist. Supports lifecycle governance, phase-gate approval workflows, and earned value rollup by phase across EPC, DB, DBB, and PPP delivery models.' .

ind:HandoverCertificate rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Project ;
    rdfs:label 'Handover Certificate' ;
    rdfs:comment 'Formal handover certificate record documenting the transfer of completed works or systems from contractor to client. Captures certificate number, handover type (partial, sectional, substantial completion, final), scope of handover, issue date, client acceptance date, outstanding punch list items count, DLP (Defects Liability Period) start date, DLP end date, and signatory details. SSOT for project completion and DLP tracking.' .

ind:Incident rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Safety ;
    rdfs:label 'Incident' ;
    rdfs:comment 'Core master record for ALL HSE safety events on construction sites, encompassing the full severity spectrum: Lost Time Injuries (LTI), medical treatment cases (including body part affected, treatment type, treating physician, return-to-work date, fitness-for-duty status), first aid cases, restricted work cases, near-misses, unsafe conditions, behavioral safety observations, property damage, dangerous occurrences, and environmental events. Captures incident classification/type, severity, location (project/site/area), date/time, injured party details, immediate cause, root cause category, OSHA recordability flag, TRIR contribution, days away/restricted/transferred (DART), regulatory notification status, environmental media affected, and workers compensation claim reference. Serves as the single unified safety event register supporting OSHA 300/300A log generation, TRIR/LTIFR/DART rate calculations, leading indicator trending, and ISO 45001 reporting. Sourced from Intelex incident management module.' .

ind:IncidentInvestigation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Safety ;
    rdfs:label 'Incident Investigation' ;
    rdfs:comment 'Detailed investigation record linked to a reported HSE incident. Captures investigation team members, root cause analysis methodology (5-Why, Fishbone), contributing factors, immediate causes, systemic causes, investigation findings, corrective action recommendations, and regulatory submission details. Tracks investigation status from open through closed. Sourced from Intelex.' .

ind:Swms rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Safety ;
    rdfs:label 'Swms' ;
    rdfs:comment 'Safe Work Method Statement (SWMS) master records defining step-by-step work procedures for high-risk construction activities. Captures activity description, identified hazards, risk rating (before and after controls), control measures, PPE requirements, responsible supervisor, approval status, review date, and applicable legislation. SSOT for SWMS documentation across all projects and sites.' .

ind:PermitToWork rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Safety ;
    rdfs:label 'Permit To Work' ;
    rdfs:comment 'Permit to Work (PTW) records authorizing high-risk construction activities such as hot work, confined space entry, working at heights, electrical isolation, and excavation. Captures permit type, issuing authority, work scope, hazard identification, control measures, validity period, site location, isolations required, and sign-off chain. Sourced from Intelex Permit to Work module.' .

ind:ToolboxMeeting rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Safety ;
    rdfs:label 'Toolbox Meeting' ;
    rdfs:comment 'Toolbox Meeting (TBM) records capturing pre-shift and pre-task safety briefings conducted on construction sites. Records meeting date, time, location, project/site, crew/trade group, topics discussed (linked to site hazards from risk_assessment), hazards highlighted, specific control measures communicated, attendee list with sign-off confirmation, facilitator name, and duration. Supports demonstration of safety communication compliance under OSHA and ISO 45001 clause 7.4 (Communication). Attendance records are embedded as line items within the meeting record. Sourced from Intelex.' .

ind:Audit rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Safety ;
    rdfs:label 'Audit' ;
    rdfs:comment 'Formal HSE audit records with embedded findings, conducted on construction sites or at corporate level. Covers compliance with OSHA regulations, ISO 45001, ISO 14001, site-specific HSE plans, and internal safety standards. Header captures audit type (internal/external/regulatory/surveillance), scope, audit team, audit date, site/project, overall compliance score, and close-out status. Finding details capture individual non-conformances, observations, and opportunities for improvement including finding type, severity, reference standard clause, responsible party, due date, and closure status. Findings link to corrective_action for formal CAPA tracking. Sourced from Intelex Audits module.' .

ind:HseInspection rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Safety ;
    rdfs:label 'Hse Inspection' ;
    rdfs:comment 'Routine, scheduled, and ad-hoc HSE site inspection records including emergency drill exercises and management safety walks. Captures field observations of safety conditions, housekeeping, PPE compliance, equipment safety, scaffolding/formwork integrity, excavation stability, crane setup, work practice compliance, and emergency preparedness. Records inspection type (routine/targeted/emergency drill/pre-task/management walk), inspector, site area, checklist template used, pass/fail items with photographic evidence references, deficiencies noted with severity classification, immediate actions taken, and drill-specific metrics (response time, evacuation completeness, muster accuracy). Distinct from formal audits — inspections are operational field checks and exercises performed by site safety officers and supervisors. Deficiencies link to corrective_action for remediation tracking. Sourced from Intelex Inspections module.' .

ind:HsePlan rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Safety ;
    rdfs:label 'Hse Plan' ;
    rdfs:comment 'Project-level HSE (Health Safety Environment) Plan master record defining the safety management framework for a specific construction project. Captures plan version, approval status, applicable regulations, site-specific hazards, emergency response procedures, HSE objectives and targets, organizational responsibilities, and review schedule. SSOT for project HSE governance documentation.' .

ind:RiskAssessment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Safety ;
    rdfs:label 'Risk Assessment' ;
    rdfs:comment 'Unified hazard and risk register serving as the single source of truth for all identified hazards and their risk evaluations across construction project sites. Captures hazard identification (type: fall, struck-by, caught-between, electrocution, excavation collapse, chemical exposure, environmental), activity/task scope, site location/zone, initial risk rating (likelihood x consequence matrix), control hierarchy applied (eliminate/substitute/engineer/admin/PPE), residual risk rating, control measures in place, responsible party, status (open/controlled/eliminated/closed), source (inspection/incident/design review/JHA), review date, and approver. Serves triple purpose: (1) formal risk assessment for specific activities supporting SWMS development and PTW issuance, (2) live site hazard inventory (hazard register) supporting daily pre-start briefings and toolbox meeting topic selection, and (3) Job Hazard Analysis (JHA) documentation for task-level risk evaluation. Maintains hazard register entries as living records updated through inspections, incidents, and periodic reviews. SSOT for all identified hazards, risk evaluations, and control effectiveness across the project portfolio.' .

ind:HazardRegister rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Safety ;
    rdfs:label 'Hazard Register' ;
    rdfs:comment 'Site-level hazard register maintaining a live inventory of identified hazards across construction project sites. Captures hazard type (fall, struck-by, caught-between, electrocution, excavation collapse, chemical exposure), location/zone, initial risk rating (likelihood x consequence), control measures in place, hierarchy of controls applied, responsible party, status (open/controlled/eliminated/closed), last review date, and source (risk assessment/inspection/incident). Serves as the operational SSOT for site hazard visibility, supports daily pre-start briefings, and feeds toolbox meeting topic selection.' .

ind:EnvironmentalMonitoring rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Safety ;
    rdfs:label 'Environmental Monitoring' ;
    rdfs:comment 'Environmental monitoring measurement records capturing periodic readings for air quality, noise levels, vibration, water quality, and soil contamination at construction sites. Captures monitoring parameter, measurement value, unit, threshold limit, exceedance flag, monitoring location, instrument used, and responsible party. Supports ISO 14001 environmental management and regulatory permit compliance.' .

ind:Training rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Safety ;
    rdfs:label 'Training' ;
    rdfs:comment 'Safety training and induction records for construction workers, capturing training type (site induction, OSHA 10/30, first aid, confined space, working at heights), delivery date, trainer, duration, competency assessment result, certification issued, expiry date, and compliance status. Distinct from general workforce training — this is the SSOT for HSE-specific training compliance. Sourced from Intelex and SAP SuccessFactors HSE training modules.' .

ind:TradePackage rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Bid ;
    rdfs:label 'Trade Package' ;
    rdfs:comment 'Defines a discrete scope-of-work package to be competitively bid and awarded to a subcontractor — e.g., structural steel erection, HVAC installation, electrical fit-out, piling works, or facade cladding. Captures trade discipline code, CSI MasterFormat/UniFormat classification, package reference number, associated WBS elements, scope narrative, estimated value, budget allowance, bid-out date, bid closing date, number of bidders invited, award date, and package status (draft, bid-out, evaluation, awarded, closed). The SSOT for trade package definitions that drive the subcontractor bidding and award process.' .

ind:Asset rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Equipment ;
    rdfs:label 'Asset' ;
    rdfs:comment 'Core master record for every piece of construction equipment and fleet vehicle owned, long-term leased, or rented by the company. Captures asset identity, classification (crane, excavator, concrete pump, generator, fleet vehicle, small tool), make, model, serial number, year of manufacture, acquisition date, acquisition cost, ownership type (owned/rented/leased), current status (active, idle, under maintenance, disposed), SAP PM equipment number, HCSS HeavyJob asset ID, regulatory compliance class, and asset lifecycle stage. For disposed assets: captures disposal method (sale, auction, scrap, write-off, trade-in), disposal date, disposal proceeds, buyer details, reason for disposal, and authorizing approver. This is the SSOT for all equipment identity and lifecycle data across the enterprise, from commissioning through disposal.' .

ind:AssetCategory rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Equipment ;
    rdfs:label 'Asset Category' ;
    rdfs:comment 'Reference classification hierarchy for construction equipment and fleet assets. Defines the taxonomy of equipment types used across the enterprise: major categories (heavy earthmoving, lifting, concrete, MEP, fleet, small tools, generators), sub-categories, and equipment class codes aligned with HCSS HeavyJob cost coding and SAP PM functional location structures. Drives cost coding, depreciation rules, maintenance strategy assignment, and utilization benchmarking.' .

ind:FleetAssignment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Equipment ;
    rdfs:label 'Fleet Assignment' ;
    rdfs:comment 'Transactional record capturing the assignment of a specific piece of equipment or fleet vehicle to a project, site, or work front for a defined period. Tracks assignment start and end dates, assigned project, site location, responsible operator or driver, mobilization status, cost allocation code (WBS element), and applicable internal hire rate (ownership rate, operating rate, standby rate per hour/day/week). Supports equipment utilization tracking, inter-project cost allocation, internal charge-back to projects, and site logistics planning. Sourced from HCSS HeavyJob and SAP PS project systems.' .

ind:Hours rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Equipment ;
    rdfs:label 'Hours' ;
    rdfs:comment 'Daily or shift-level transactional record of equipment operating hours, idle hours, standby hours, and downtime events captured from HCSS HeavyJob field time tracking. Includes cost code, operator ID, project and WBS reference, fuel consumption, meter reading (odometer or hour meter), shift date, production quantity achieved. For non-productive time: captures downtime start/end timestamps, duration, downtime category (breakdown, awaiting parts, awaiting operator, weather hold, scheduled maintenance), root cause code, resolution action, and impact assessment. Foundational for equipment utilization rate calculation, cost-per-hour analysis, MTTR (Mean Time To Repair), MTBF (Mean Time Between Failures), availability rate reporting, and CPI/SPI reporting under EVM. SSOT for all equipment time and downtime recording. Primary source: HCSS HeavyJob daily time entry.' .

ind:MaintenancePlan rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Equipment ;
    rdfs:label 'Maintenance Plan' ;
    rdfs:comment 'Master record defining the preventive maintenance strategy and schedule for a class of equipment or individual asset. Captures maintenance plan type (time-based, meter-based, condition-based), service intervals (e.g., every 250 engine hours, every 6 months), maintenance task list reference, responsible maintenance team, estimated duration, parts and materials required, and compliance requirements (e.g., crane certification intervals, OSHA inspection schedules). Sourced from SAP PM Maintenance Plan.' .

ind:MaintenanceOrder rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Equipment ;
    rdfs:label 'Maintenance Order' ;
    rdfs:comment 'Transactional work order record for a specific maintenance activity executed on an asset, generated from a maintenance plan (preventive) or raised as a corrective/breakdown order from a notification. Captures order type (preventive, corrective, breakdown, statutory inspection), priority, planned and actual start/end dates, assigned technician, labor hours, parts consumed (part number, quantity, unit cost per line item), total maintenance cost (labor + parts + external services), order status (created, released, in-progress, completed, technically complete, closed), and SAP PM order number. Supports maintenance cost tracking at labor and parts level, asset downtime analysis, warranty claim evidence, and compliance audit trails. Parts consumption data here serves as the equipment domain\'s record of materials used — material domain owns stock levels and replenishment.' .

ind:InspectionRecord rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Equipment ;
    rdfs:label 'Inspection Record' ;
    rdfs:comment 'Transactional record of a statutory, regulatory, or internal safety inspection performed on a piece of equipment, and the master register of all resulting compliance certificates issued. Captures inspection type (pre-start check, periodic statutory inspection, OSHA compliance check, crane load test, lifting gear inspection, pressure vessel test, FAT/SAT), inspection date, inspector name and certification, pass/fail outcome, defects identified, corrective actions required, next inspection due date. For certificates: captures certificate type (crane load test certificate, pressure vessel certificate, lifting gear certificate, OSHA compliance certificate, insurance certificate), certificate number, issuing authority, issue date, expiry date, and document storage reference. SSOT for all equipment inspection events AND asset-level compliance certificates. Supports OSHA compliance, insurance requirements, equipment fitness-for-use certification, pre-mobilization compliance checks, and regulatory audit trails. Distinct from quality ITP inspections (owned by quality domain) and operator certifications (which track people, not assets).' .

ind:RentalAgreement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Equipment ;
    rdfs:label 'Rental Agreement' ;
    rdfs:comment 'Master record governing the rental or hire of external equipment from a plant hire company or equipment supplier. Captures rental supplier, equipment description and type, rental start and end dates, agreed daily/weekly/monthly hire rate, minimum hire period, mobilization and demobilization charges, insurance requirements, operator-supplied flag, rental PO reference, and total committed rental cost. Distinct from procurement POs (owned by procurement domain) — this is the equipment-domain SSOT for rental fleet management and cost accrual.' .

ind:EquipmentMobilization rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Equipment ;
    rdfs:label 'Equipment Mobilization' ;
    rdfs:comment 'Transactional record capturing the mobilization or demobilization event of a piece of equipment to or from a project site. Tracks event type (mobilization, demobilization, inter-site transfer), planned and actual transport dates, origin and destination locations, transport contractor, transport cost, permits required (oversize load, road permits), equipment condition at dispatch and receipt, and sign-off by site manager. Supports site logistics planning, cost allocation, and equipment tracking across the fleet.' .

ind:FuelTransaction rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Equipment ;
    rdfs:label 'Fuel Transaction' ;
    rdfs:comment 'Transactional record of fuel issued to a piece of equipment or fleet vehicle. Captures fuel type (diesel, petrol, LPG), quantity issued (litres), unit cost, total cost, issuing fuel point or bowser, date and time of issue, hour meter or odometer reading at fueling, project and cost code allocation, and operator confirmation. Enables fuel consumption tracking, cost-per-hour analysis, carbon emissions reporting (ISO 14001), and detection of fuel wastage or theft.' .

ind:OperatorCertification rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Equipment ;
    rdfs:label 'Operator Certification' ;
    rdfs:comment 'Master record of an equipment operator\'s certification, licence, or competency qualification for a specific equipment type or class. Captures operator reference (linked to workforce domain), equipment category certified for (e.g., tower crane, mobile crane, excavator, forklift), certifying body, certificate number, issue date, expiry date, certification status (valid, expired, suspended), and renewal requirements. Supports OSHA compliance, HSE pre-start checks, and operator-to-equipment assignment validation. Owned by equipment domain as it governs equipment operation rights.' .

ind:CostCode rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Cost Code' ;
    rdfs:comment 'Reference master for the construction cost coding taxonomy used to classify all project expenditures into standardized categories. Defines the hierarchical cost breakdown structure (CBS) — typically 2-4 levels deep — covering labor, materials, equipment, subcontract, and overhead categories. Each cost code carries a unique identifier, description, parent code, level indicator, unit of measure for quantity tracking, standard rate (where applicable), and active/inactive status. Used across SAP S/4HANA Project Systems and Viewpoint Vista as the authoritative classification spine for budget allocation, actual cost posting, EVM reporting, and job cost analysis.' .

ind:CostCenter rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Cost Center' ;
    rdfs:comment 'Organizational unit master representing financial responsibility centers within the construction enterprise — project cost centers, regional offices, corporate overhead centers, and shared-service centers. Maps to SAP S/4HANA cost center accounting (CO-CCA) and serves as the primary dimension for internal P&L reporting, overhead allocation, and EBITDA decomposition. Each cost center has a responsible manager, validity period, and hierarchy assignment.' .

ind:GlAccount rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Gl Account' ;
    rdfs:comment 'General Ledger chart of accounts master defining every account used in the construction enterprise\'s financial statements — revenue accounts, cost-of-construction accounts, overhead, assets, liabilities, and equity. Sourced from SAP S/4HANA FI-GL and aligned to IFRS/GAAP chart of accounts. Provides the authoritative account classification for all journal entries, AP/AR postings, and financial consolidation.' .

ind:JournalEntry rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Journal Entry' ;
    rdfs:comment 'Core double-entry accounting document and its constituent debit/credit line items, capturing all financial postings in the construction enterprise\'s general ledger. Each document contains a header (document number, posting date, document type, reference, reversal indicator) and one or more lines specifying GL account, cost center, WBS element, cost code, debit/credit amount, currency, tax code, and assignment fields. Covers standard accruals, cost allocations, revenue recognition entries (percentage-of-completion per IFRS 15), intercompany eliminations, period-end adjustments, reclassifications, and FX revaluation entries. Sourced from SAP S/4HANA FI-GL and Viewpoint Vista. Provides full project-level financial traceability from trial balance to source transaction for audit and IFRS/GAAP compliance. Owns both header-level and line-level data as a single SSOT.' .

ind:JournalEntryLine rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Journal Entry Line' ;
    rdfs:comment 'Individual debit or credit line item within a journal entry, capturing the GL account, cost center, WBS element, amount, currency, and posting date for each leg of a double-entry transaction. Enables granular drill-down from trial balance to source transaction for audit and IFRS/GAAP compliance. Sourced from SAP S/4HANA FI-GL line item tables.' .

ind:ProjectBudget rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Project Budget' ;
    rdfs:comment 'Authoritative WBS-linked budget record for each construction project, capturing the approved contract budget, internal target cost, contingency reserves, and management reserve. Tracks original budget, approved change order (CO) adjustments, and current approved budget (CAB) at each WBS level. Integrates with Oracle Primavera P6 baseline data and SAP S/4HANA PS module. Serves as the baseline for EVM (Earned Value Management) calculations including BCWS (Budgeted Cost of Work Scheduled).' .

ind:JobCostTransaction rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Job Cost Transaction' ;
    rdfs:comment 'Granular cost transaction record capturing every actual cost posted against a construction project\'s WBS element and cost code — labor timesheets, material receipts, equipment usage charges, subcontractor invoices, and overhead allocations. The primary source for job costing and cost-to-complete analysis. Sourced from Viewpoint Vista job costing module and SAP S/4HANA CO-PA. Feeds EVM actual cost (ACWP) calculations and CPI (Cost Performance Index) reporting.' .

ind:ProgressBilling rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Progress Billing' ;
    rdfs:comment 'Construction progress billing, payment certification, and client AR invoice lifecycle record covering the full claim-to-collection cycle. Captures the payment application (AIA G702/G703 or FIDIC payment certificate) including scheduled value by WBS/BOQ line, percentage complete, amount earned to date, current period claim, retention withheld, and net amount due. Also owns the formal AR tax invoice raised after payment certificate approval — invoice number, client reference, contract reference, invoice date, due date, gross amount, VAT/GST, retention deducted, net receivable, payment status, aging bucket, and collection history. Sourced from Procore, SAP S/4HANA FI-AR, and Viewpoint Vista. The authoritative SSOT for all client-facing billing, accounts receivable invoices, and receivables management in construction.' .

ind:RevenueRecognitionEntry rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Revenue Recognition Entry' ;
    rdfs:comment 'Periodic revenue recognition record applying the percentage-of-completion (POC) method per IFRS 15 / ASC 606 to each construction contract. Captures the recognition period, contract value, cumulative costs incurred, estimated total costs, completion percentage (cost-to-cost method), revenue recognized to date, revenue recognized in period, and deferred/unbilled revenue balance. Sourced from SAP S/4HANA Revenue Accounting and Reporting (RAR) module. The authoritative SSOT for construction revenue recognition compliance.' .

ind:Invoice rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Invoice' ;
    rdfs:comment 'Vendor and subcontractor invoice record in the Accounts Payable (AP) ledger, capturing the full supplier billing lifecycle from receipt through approval to payment. Records invoice number, vendor/subcontractor reference, PO/subcontract reference, invoice date, due date, gross amount, tax/VAT amount, retention withheld, net payable, payment terms, approval workflow status, three-way match status (PO-GR-Invoice), and dispute/hold flags. Sourced from SAP S/4HANA FI-AP and Viewpoint Vista AP module. Covers supplier invoices for materials, equipment hire, professional services, and subcontractor progress claims. The authoritative SSOT for all accounts payable obligations in the construction enterprise.' .

ind:PaymentRecord rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Payment Record' ;
    rdfs:comment 'Financial payment transaction record capturing both outgoing payments to vendors/subcontractors (AP disbursements) and incoming receipts from clients (AR collections). Captures payment date, payment method (wire transfer, cheque, ACH, LC drawdown), bank account, amount paid/received, currency, exchange rate, invoice references cleared, bank clearing status, and remittance advice details. Supports multi-currency payment runs, partial payments, and bank reconciliation. Sourced from SAP S/4HANA FI payment runs and Viewpoint Vista.' .

ind:CashFlowForecast rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Cash Flow Forecast' ;
    rdfs:comment 'Forward-looking cash flow projection record for construction projects and the corporate entity, capturing forecast inflows (client milestone payments, retention releases, advance drawdowns) and outflows (subcontractor payments, material procurement, payroll, equipment hire, bond premiums) by period (weekly/monthly). Includes S-curve cash flow profile, cumulative cash position, peak funding requirement, working capital gap analysis, and variance to prior forecast. Supports both project-level forecasting for contract cash management and corporate-level treasury forecasting for bonding capacity and credit facility utilization.' .

ind:CraftWorker rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Workforce ;
    rdfs:label 'Craft Worker' ;
    rdfs:comment 'Master record for all craft labor personnel deployed on construction projects including hourly trade workers and working foremen/supervisors. Captures worker identity, trade classification (from skill_trade taxonomy), employment type (direct hire, agency, union referral), union affiliation and local, craft code, supervisory role flag, home project assignment, mobilization status, security clearance level, and field deployment history. SSOT for individual field worker identity in the workforce domain. Workers may hold multiple trade classifications and rotate between craft and supervisory roles across projects. Integrates with SAP SuccessFactors for HCM master data and HCSS HeavyJob for field time tracking.' .

ind:Crew rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Workforce ;
    rdfs:label 'Crew' ;
    rdfs:comment 'Master record for a named field crew or gang deployed on a construction project. Captures crew name, crew type (civil, MEP, structural, concrete, etc.), foreman assignment, home cost code, project assignment, crew size, and active status. A crew is the primary unit of field labor organization in construction operations. Distinct from individual worker records.' .

ind:CrewAssignment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Workforce ;
    rdfs:label 'Crew Assignment' ;
    rdfs:comment 'Transactional record linking individual craft workers to a specific crew for a defined period on a project. Captures worker role within the crew (laborer, operator, foreman, lead), assignment start and end dates, cost code, WBS element, shift, and assignment status. Enables tracking of crew composition changes over time and supports labor cost allocation.' .

ind:Timesheet rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Workforce ;
    rdfs:label 'Timesheet' ;
    rdfs:comment 'Daily field timesheet record capturing hours worked by a craft worker on a specific project, cost code, and WBS element. Sourced from HCSS HeavyJob. Captures regular hours, overtime hours, double-time hours, shift type, work classification, pay type, equipment operated, and approval status. Core transactional record for labor cost coding and payroll processing in field operations.' .

ind:TimesheetLine rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Workforce ;
    rdfs:label 'Timesheet Line' ;
    rdfs:comment 'Individual line item within a daily timesheet record, capturing granular labor allocation to a specific cost code, activity, WBS element, or equipment unit within a single shift. Supports split-coding of hours across multiple cost centers in a single day. Enables detailed job costing and EVM (Earned Value Management) labor tracking at the activity level.' .

ind:LaborCostCode rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Workforce ;
    rdfs:label 'Labor Cost Code' ;
    rdfs:comment 'Unified reference master for labor cost codes and trade/skill classifications used to classify and allocate field labor expenditure and define workforce competency categories. Captures cost code identifier, description, trade code, trade name, craft discipline (ironworker, pipefitter, electrician, carpenter, etc.), union jurisdiction, prevailing wage classification, required certification types, budget category, SAP PS (Project Systems) WBS mapping, and active status. Serves as the single source of truth for both cost allocation and trade/skill classification — the authoritative taxonomy of construction trades and their cost coding. Integrates with SAP S/4HANA Project Systems and HCSS HeavyJob cost coding structures. Referenced by timesheets, labor rates, agency orders, and staffing plans for consistent trade and cost classification.' .

ind:CraftCertification rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Workforce ;
    rdfs:label 'Craft Certification' ;
    rdfs:comment 'Master record for a specific trade certification, license, or qualification held by a craft worker. Captures certification type (OSHA 10/30, NCCER credentials, rigger, scaffolder, welder qualification, crane operator NCCCO, confined space, etc.), issuing body, issue date, expiry date, certification number, verification status, and renewal requirements. Supports site access control (workers cannot badge in without valid certs), workforce competency management, and compliance with project-specific qualification requirements. Distinct from apprenticeship_progression which tracks cumulative hours and level advancement — this product tracks discrete credentials already earned.' .

ind:SkillTrade rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Workforce ;
    rdfs:label 'Skill Trade' ;
    rdfs:comment 'Reference classification of construction trade skills and craft disciplines (e.g., ironworker, pipefitter, electrician, carpenter, concrete finisher, heavy equipment operator, rigger, welder). Captures trade code, trade name, union jurisdiction, prevailing wage classification, and required certification types. Used for workforce planning, crew composition, and labor rate determination.' .

ind:LaborMobilization rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Workforce ;
    rdfs:label 'Labor Mobilization' ;
    rdfs:comment 'Transactional record tracking the mobilization or demobilization of a craft worker or supervisor to/from a project site. Captures mobilization type (initial, transfer, demobilization), origin and destination project, travel arrangement details, per diem entitlement, mobilization date, demobilization date, and associated cost. Supports project staffing planning and labor cost forecasting.' .

ind:StaffingPlan rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Workforce ;
    rdfs:label 'Staffing Plan' ;
    rdfs:comment 'Master record for a project-level workforce staffing plan defining the planned headcount, trade mix, and labor hours required by project phase, WBS element, and time period. Captures planned vs. actual headcount, peak labor requirements, trade breakdown, source strategy (direct hire, subcontract, agency), ramp-up/ramp-down curves, and plan version. Supports workforce forecasting, labor procurement decisions, and project mobilization planning. Integrates with SAP SuccessFactors workforce planning.' .

ind:LaborRate rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Workforce ;
    rdfs:label 'Labor Rate' ;
    rdfs:comment 'Reference record defining the all-in labor rates (base wage, fringe benefits, burden, overhead) for each trade classification under a specific labor agreement or project. Captures trade classification, effective date range, straight-time rate, overtime rate, double-time rate, fringe benefit rate, payroll burden percentage, and total loaded rate. Used for project cost estimation, bid pricing (BOQ), and job cost control.' .

ind:Correspondence rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Design ;
    rdfs:label 'Correspondence' ;
    rdfs:comment 'Master register of all formal project correspondence including letters, emails, notices, and official communications managed through Aconex mail register. Tracks sender, recipient, subject, correspondence type (RFI, instruction, notice, claim), priority, response required flag, response due date, current status, response thread history with full response chain (response date, content, method, closure status), and parent-child threading. Serves as the authoritative SSOT for all project correspondence and response chains across contractors, clients, consultants, and authorities, providing the contractual audit trail required under FIDIC and NEC contract forms.' .

ind:Transmittal rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Design ;
    rdfs:label 'Transmittal' ;
    rdfs:comment 'Records the formal dispatch of documents, drawings, and submittals between project parties via Aconex transmittals. Captures transmittal number, issue date, sender organization, recipient organization, purpose of issue (for approval, for information, for construction, for record), document list, and acknowledgement status. Provides a legally defensible audit trail of document distribution throughout the project lifecycle.' .

ind:Rfi rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Design ;
    rdfs:label 'Rfi' ;
    rdfs:comment 'Request for Information records capturing formal queries raised by contractors seeking clarification on design intent, specifications, or contract documents. Tracks RFI number, subject, discipline, originator, addressee, date raised, response due date, actual response date, response content, cost/schedule impact assessment, linked drawing or specification reference, and closure status. High-volume transactional entity critical for design coordination and contractual record-keeping. Sourced from Procore RFI module and Aconex.' .

ind:DocumentRegister rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Design ;
    rdfs:label 'Document Register' ;
    rdfs:comment 'Central master register of all project documents beyond drawings — including specifications, reports, procedures, method statements, O&M manuals, certificates, and correspondence — managed in Aconex CDE (Common Data Environment). Captures document number, title, document type, discipline, revision, status, originator, issue date, confidentiality classification, retention period, and numbering convention. Provides the authoritative catalog of all project documentation per ISO 19650 information container requirements.' .

ind:Revision rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Design ;
    rdfs:label 'Revision' ;
    rdfs:comment 'Version control record for each document in the document register, capturing revision identifier, revision date, revision description, author, reviewer, approver, change summary, superseded revision reference, and file storage path. Maintains a complete and auditable version history for all project documents to support regulatory compliance, handover, and DLP (Defects Liability Period) obligations.' .

ind:WorkflowApproval rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Design ;
    rdfs:label 'Workflow Approval' ;
    rdfs:comment 'Formal document review and approval workflow instances tracking multi-step approval chains in Aconex and BIM 360 CDE. Captures workflow template, document under review, step sequence, assigned reviewer (role and individual), action taken (approved, rejected, commented, delegated, no objection), action date, reviewer comments, SLA target vs actual duration, and overall workflow outcome. Provides the legally required audit trail of all document approval decisions for ISO 9001 quality management, ISO 19650 information management, and contractual compliance under FIDIC/NEC.' .

ind:HandoverPackage rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Design ;
    rdfs:label 'Handover Package' ;
    rdfs:comment 'Master record for project handover and commissioning documentation packages compiled for client/owner delivery at practical completion per ISO 19650-3 operational phase requirements. Captures package number, title, scope of works covered, handover milestone, package type (O&M manuals, as-built drawings, certificates, warranties, test records), completeness percentage, client acceptance status, DLP (Defects Liability Period) start date, and legal hold flag for litigation support. Sourced from Aconex handover module.' .

ind:HandoverItem rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Design ;
    rdfs:label 'Handover Item' ;
    rdfs:comment 'Individual document or deliverable item within a handover package, tracking item type (O&M manual, as-built drawing, FAT certificate, SAT record, warranty certificate, commissioning record, spare parts list), item status, responsible party, planned submission date, actual submission date, client review status, and outstanding action notes. Enables granular tracking of handover completeness at item level.' .

ind:Itp rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Quality ;
    rdfs:label 'Itp' ;
    rdfs:comment 'Inspection and Test Plan (ITP) master record defining the structured quality control framework for a construction work package or activity. Captures the inspection scope, hold/witness/review points, applicable standards (ISO 9001, IBC, ACI), responsible parties, acceptance criteria, and linkage to the WBS. Serves as the authoritative QA/QC planning document governing all inspection activities on a project.' .

ind:ItpLine rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Quality ;
    rdfs:label 'Itp Line' ;
    rdfs:comment 'Individual inspection or test activity line item within an ITP. Defines a specific hold point, witness point, or review point with its activity description, inspection method, acceptance criteria, frequency, responsible discipline, and required documentation. Each line drives a discrete inspection event on site.' .

ind:Inspection rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Quality ;
    rdfs:label 'Inspection' ;
    rdfs:comment 'Transactional record of a physical quality inspection or checklist verification event conducted on site, at a factory, or workshop. Captures inspection date, location, inspector identity, ITP line reference, checklist template used, item-level verification results (pass/fail/N/A per check item with remarks), overall outcome (pass/fail/conditional), observations, non-conformances raised, digital sign-off, and attachments (photos, measurements). Covers all inspection types: hold-point inspections, witness-point inspections, pre-pour checks, structural inspections, MEP inspections, and any checklist-based quality verification. Each record serves as the auditable evidence trail for QA/QC compliance and may trigger NCR creation on failure.' .

ind:Ncr rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Quality ;
    rdfs:label 'Ncr' ;
    rdfs:comment 'Non-Conformance Report (NCR) and corrective action record capturing formal documentation of construction deliverables, materials, or workmanship that do not meet specified requirements. Tracks NCR number, description of non-conformance, affected work package, root cause analysis, disposition (accept-as-is, rework, reject, concession), corrective and preventive actions (CAPA) with responsible parties, target and actual completion dates, verification method, effectiveness review, and closure status. Supports hold/release workflow and the full CAPA cycle required under ISO 9001 clause 10.' .

ind:CorrectiveAction rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Quality ;
    rdfs:label 'Corrective Action' ;
    rdfs:comment 'Corrective and preventive action record linked to an NCR. Tracks the specific remediation steps assigned, responsible party, target completion date, actual completion date, verification method, and effectiveness review outcome. Supports the CAPA (Corrective Action / Preventive Action) cycle required under ISO 9001 clause 10.' .

ind:Checklist rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Quality ;
    rdfs:label 'Checklist' ;
    rdfs:comment 'Quality inspection checklist template defining the structured set of verification items for a specific construction activity type (e.g., concrete pour, rebar placement, waterproofing, structural steel erection). Captures checklist name, revision, activity type, applicable standard, approval status, and ordered check items with acceptance criteria and inspection method. Used as the governing template when conducting inspections — each inspection references a checklist to ensure consistent verification coverage.' .

ind:ChecklistExecution rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Quality ;
    rdfs:label 'Checklist Execution' ;
    rdfs:comment 'Completed instance of a quality inspection checklist executed on site for a specific work activity. Records the execution date, inspector, work location, WBS reference, each checklist item result (pass/fail/N/A), overall outcome, remarks, and digital sign-off. Provides the auditable evidence trail for QA/QC compliance.' .

ind:TestCertificate rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Quality ;
    rdfs:label 'Test Certificate' ;
    rdfs:comment 'Material test certificate and laboratory test result record capturing certified testing outcomes for construction materials (concrete, steel, aggregates, bitumen, soil, asphalt, geotextiles). Stores certificate number, sample ID, material type, batch/heat number, sampling date and location, test standard (ASTM, BS, EN, AASHTO), test parameters and measured values, pass/fail determination, issuing laboratory, laboratory accreditation number, and traceability to purchase order and delivery lot. Covers both third-party MTC documents received from suppliers and in-house/independent lab test results for site-sampled materials.' .

ind:Defect rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Quality ;
    rdfs:label 'Defect' ;
    rdfs:comment 'Defect record tracking a physical construction defect identified during inspection, commissioning, or the Defects Liability Period (DLP). Captures defect description, location (grid reference, level, zone), severity classification, responsible trade/subcontractor, date identified, target rectification date, rectification method, and closure status. Distinct from NCR in that defects may arise post-handover during DLP.' .

ind:PunchList rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Quality ;
    rdfs:label 'Punch List' ;
    rdfs:comment 'Punch list (snagging list) master record grouping outstanding defects, incomplete works, and commissioning items requiring resolution before a project milestone (mechanical completion, practical completion, or handover). Captures punch list number, associated milestone, project area/zone, creation date, total items count, open/closed item counts, target close-out date, responsible party, and overall status. Drives the close-out workflow that gates contractual handover.' .

ind:PunchItem rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Quality ;
    rdfs:label 'Punch Item' ;
    rdfs:comment 'Individual punch list item within a punch list record. Captures item number, description, location, category (structural, MEP, architectural, civil), responsible subcontractor, priority, target completion date, actual completion date, verification inspector, and closure status. Drives the close-out workflow for practical completion.' .

ind:Plan rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Quality ;
    rdfs:label 'Plan' ;
    rdfs:comment 'Project Quality Plan (PQP) master document defining the overall QA/QC strategy for a specific project. Captures organizational quality responsibilities, applicable standards and codes, inspection regime definitions, document control procedures, audit schedule, NCR procedures, training requirements, and continuous improvement mechanisms. Serves as the top-level quality governance document per ISO 9001 and contract requirements. All ITPs, checklists, and audit programs trace back to this plan.' .

ind:Vendor rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Procurement ;
    rdfs:label 'Vendor' ;
    rdfs:comment 'Master record for all approved and prospective suppliers, subcontractors, and material vendors managed via SAP MM Vendor Master. Captures vendor identity, classification (material supplier, equipment rental, specialist subcontractor), registration status, tax identifiers, payment terms, currency, bank details, geographic coverage, diversity classification (MBE/WBE/DBE), bonding capacity, insurance certificates, and SAP vendor account number. SSOT for vendor identity across the procurement domain.' .

ind:VendorQualification rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Procurement ;
    rdfs:label 'Vendor Qualification' ;
    rdfs:comment 'Supplier pre-qualification and approved vendor list (AVL) records capturing qualification status, financial health assessments, technical capability evaluations, HSE performance ratings, quality certifications (ISO 9001, ISO 14001, ISO 45001), bonding limits, insurance coverage verification, past performance scores, and qualification expiry dates. Tracks the full vendor onboarding and re-qualification lifecycle required before a vendor can receive a PO.' .

ind:MaterialCatalog rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Procurement ;
    rdfs:label 'Material Catalog' ;
    rdfs:comment 'Authoritative catalog of all procurable materials, equipment components, and consumables managed in SAP MM Material Master. Captures material number, description, material group, base unit of measure, weight, dimensions, hazardous material classification, storage conditions, lead time, minimum order quantity, standard cost, and BIM object reference. SSOT for material identity used across MTO, PO, and goods receipt processes.' .

ind:Rfq rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Procurement ;
    rdfs:label 'Rfq' ;
    rdfs:comment 'Request for Quotation records issued to vendors for pricing and availability of materials, equipment, or services, including header-level metadata and granular line-item detail. Captures RFQ number, issuing project, scope description, BOQ reference, submission deadline, bid bond requirement, evaluation criteria, invited vendor list, currency, RFQ status (draft, issued, closed, awarded, cancelled), and individual line items (line number, material/service description, quantity, UoM, required delivery date, site delivery location, technical specification reference, drawing/BIM reference). Sourced from SAP MM RFQ process and Procore bid management workflows. Enables granular vendor pricing comparison at the line-item level.' .

ind:VendorQuotation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Procurement ;
    rdfs:label 'Vendor Quotation' ;
    rdfs:comment 'Vendor-submitted quotation responses to RFQs capturing quoted unit price, total price, delivery lead time, validity period, payment terms offered, country of origin, warranty terms, exceptions or deviations from specification, quotation submission timestamp, and compliance with technical specifications. Supports commercial bid tabulation, vendor price comparison analysis, and historical lead time benchmarking for award decisions. Links to RFQ and vendor master.' .

ind:PurchaseOrder rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Procurement ;
    rdfs:label 'Purchase Order' ;
    rdfs:comment 'Legally binding purchase order issued to a vendor for supply of materials, equipment, or services, including full amendment and change order history as versioned records. Captures PO number, vendor, project and WBS element, delivery address, incoterms, payment terms, currency, total PO value, GMP flag, retention percentage, PO type (standard, blanket, framework, subcontract), approval status, NTP date, SAP document number, current version/revision number, and complete amendment audit trail (amendment number, amendment type — scope change, quantity change, price adjustment, delivery date change, CO, original value, amended value, value delta, reason, approval status, amendment date). Core transactional anchor of the procurement domain sourced from SAP MM. SSOT for all PO commercial state including historical changes and amendments.' .

ind:PoLine rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Procurement ;
    rdfs:label 'Po Line' ;
    rdfs:comment 'Individual line items within a purchase order capturing material or service description, ordered quantity, unit of measure, unit price, line total, delivery schedule date, WBS element, cost code, account assignment category, goods receipt indicator, invoice receipt indicator, and cumulative goods receipt quantity to date. Enables granular cost tracking and delivery monitoring at the PO line level.' .

ind:GoodsReceipt rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Procurement ;
    rdfs:label 'Goods Receipt' ;
    rdfs:comment 'Material goods receipt records capturing physical delivery of materials or equipment to site or warehouse against a PO. Records GR document number, delivery date, received quantity, unit of measure, storage location, batch number, delivery note reference, condition on receipt (accepted, rejected, partial), receiving inspector, and SAP material document number. Triggers inventory update and three-way match for invoice verification.' .

ind:SourcingPlan rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Procurement ;
    rdfs:label 'Sourcing Plan' ;
    rdfs:comment 'Project-level procurement execution plan defining the sourcing strategy, procurement milestones, long-lead item identification, packaging strategy, expediting requirements, and planned award dates for all major material and service categories. Captures plan version, project reference, procurement category, sourcing method (competitive bid, sole source, framework agreement), planned RFQ date, planned award date, planned delivery date, expediting frequency and method, responsible procurement manager, and critical path material flags. Integrates with Primavera P6 schedule milestones to ensure procurement activities align with construction sequencing.' .

ind:VendorEvaluation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Procurement ;
    rdfs:label 'Vendor Evaluation' ;
    rdfs:comment 'Unified vendor assessment records covering both pre-qualification (AVL entry, financial health, technical capability, HSE ratings, quality certifications, bonding limits, insurance verification) and ongoing periodic performance evaluation (on-time delivery rate, quality acceptance rate, NCR count, HSE incident count, responsiveness score, commercial compliance score, overall KPI rating). Captures qualification status, evaluation type (pre-qualification, periodic review, project-specific), evaluation period, evaluating manager, corrective action flags, and qualification expiry dates. Feeds vendor approval decisions, bid invitation eligibility, and continuous improvement programs. Sourced from Procore, SAP MM, and Intelex.' .

ind:PurchaseRequisition rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Procurement ;
    rdfs:label 'Purchase Requisition' ;
    rdfs:comment 'Internal purchase requisition raised by project or site teams to initiate procurement of materials, equipment, or services. Captures requisition number, requesting department, project and WBS element, material or service description, required quantity, unit of measure, required delivery date, estimated cost, budget availability flag, approval workflow status (pending, approved, rejected), approver, urgency classification, and conversion status (converted to RFQ or PO). Sourced from SAP MM PR process. Entry point for all formal procurement activity.' .

ind:VendorInvoice rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Procurement ;
    rdfs:label 'Vendor Invoice' ;
    rdfs:comment 'Vendor invoices received against purchase orders capturing invoice number, vendor, PO reference, invoice date, invoice amount, tax amount, currency, payment due date, three-way match status (PO-GR-Invoice), invoice verification status (blocked, approved, posted), SAP FI document number, and dispute flag. Distinct from client billing invoices owned by the finance domain — this is the SSOT for vendor payable documents in procurement.' .

ind:InspectionRelease rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Procurement ;
    rdfs:label 'Inspection Release' ;
    rdfs:comment 'Vendor quality compliance and documentation records encompassing Factory Acceptance Tests (FAT), pre-shipment inspections, and all vendor-submitted technical documents/submittals required under a PO or framework agreement. Captures inspection order number, vendor, material/equipment tag, inspection type (FAT, SAT, third-party inspection, dimensional check), inspection date, inspector name, inspection result (pass, conditional pass, fail), punch list items, release certificate number, and associated vendor documents (material data sheets, mill certificates, test reports, ITP submissions, O&M manuals, as-built drawings) with document number, revision, submission date, review status (under review, approved, approved with comments, rejected), document type, and Aconex transmittal reference. Required before goods are shipped to site. SSOT for vendor quality evidence and technical submittals in procurement.' .

ind:BimModel rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Design ;
    rdfs:label 'Bim Model' ;
    rdfs:comment 'Master record for each Building Information Model (BIM) asset managed in Autodesk BIM 360, Bentley ProjectWise, or equivalent platform. Captures model identity, discipline (architectural, structural, MEP, civil), authoring software and version, file format (RVT, IFC, NWD), project coordinate system, geolocation reference point, LOD (Level of Development) classification per AIA E202/BIMForum LOD Specification, model status (WIP, shared, published, archived), lifecycle stage, federation role (host/linked), and file size. SSOT for all 3D model metadata across the project portfolio, enabling federated model assembly, clash detection workflows, 4D/5D BIM integration, and ISO 19650 information management compliance.' .

ind:Drawing rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Design ;
    rdfs:label 'Drawing' ;
    rdfs:comment 'Master record for each engineering and construction drawing (CAD/BIM-derived) managed across the project. Tracks drawing number, title, discipline, sheet size, scale, revision number, current status (issued for construction, issued for review, superseded), originator, and approval state. Serves as the SSOT for the drawing register aligned with Autodesk BIM 360 document control.' .

ind:DrawingRevision rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Design ;
    rdfs:label 'Drawing Revision' ;
    rdfs:comment 'Transactional record capturing each revision event for a drawing. Stores revision code, revision date, description of changes, reason for revision (RFI-driven, design change, client instruction), issuing engineer, reviewer, approver, and distribution status. Enables full version-control audit trail for IFC/CAD drawing lifecycle.' .

ind:TechnicalSpecification rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Design ;
    rdfs:label 'Technical Specification' ;
    rdfs:comment 'Master record for each technical specification document governing materials, workmanship, and construction methods. Captures spec number, title, discipline, applicable standards (ACI, AISC, NFPA), revision status, approval state, and scope of work section reference. Linked to WBS elements and BOQ line items for design-build scope management.' .

ind:Package rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Design ;
    rdfs:label 'Package' ;
    rdfs:comment 'Master record representing a formal design deliverable package issued at a project milestone (30%, 60%, 90%, IFC, As-Built). Groups related drawings, specifications, calculations, and BIM models into a contractual issuance unit. Tracks package number, milestone stage, discipline, issue date, contractual due date, recipient distribution list, submission status, client acceptance status, and approval workflow state. Also serves as the contractual deliverable register (DDR), tracking each required deliverable item with its type (drawing, specification, report, model, calculation), responsible discipline, milestone linkage, planned vs. actual submission dates, and client acceptance status. SSOT for design deliverable scheduling, contractual compliance monitoring, and milestone gate readiness assessment.' .

ind:Submittal rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Design ;
    rdfs:label 'Submittal' ;
    rdfs:comment 'Transactional record for each design-phase submittal item tracking contractor-submitted shop drawings, material data sheets, product samples, and method statements through the review and approval lifecycle. Includes register-level metadata (specification section, required submission date, contractual obligation) and item-level tracking (submission date, review status, approval authority, disposition).' .

ind:Review rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Design ;
    rdfs:label 'Review' ;
    rdfs:comment 'Transactional record for each formal design review event including internal peer reviews, interdisciplinary checks (IDC), client milestone reviews, and third-party/authority reviews. Captures review type, review date, attendees, design package under review, review stage (30%/60%/90%/IFC), disposition (accepted, conditionally accepted, rejected), and sign-off authority. Contains individual review comments as child records with sequential comment number, category (major/minor/informational), comment text, marked-up reference location, design team response, disposition (accepted, rejected, partially accepted), action owner, and closure status. SSOT for all design review and comment resolution data, supporting design approval workflows, client milestone gate management, and regulatory submission readiness.' .

ind:ChangeNotice rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Design ;
    rdfs:label 'Change Notice' ;
    rdfs:comment 'Transactional record capturing each formal design change or engineering change notice (ECN) issued during the project. Tracks change number, originating cause (client instruction, site condition, regulatory requirement, value engineering), affected drawings and specifications, design disciplines impacted, cost and schedule impact assessment, approval authority, and implementation status. Feeds into the CO (Change Order) process.' .

ind:BidOpportunity rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Bid ;
    rdfs:label 'Bid Opportunity' ;
    rdfs:comment 'Master record for each pre-award commercial opportunity tracked in Salesforce CRM. Captures the full pipeline entry from initial lead through bid submission, representing a potential project the business is pursuing. Stores opportunity name, client reference, market segment, project type, estimated contract value, probability of win, bid/no-bid decision, opportunity stage, source channel, geographic region, and pipeline forecast category. SSOT for commercial opportunity identity in the bid domain.' .

ind:Tender rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Bid ;
    rdfs:label 'Tender' ;
    rdfs:comment 'Master record representing a formal tender submission package prepared in response to an RFP or RFQ. Captures tender reference number, project title, client/owner identity, tender type (lump-sum, GMP, unit-rate, EPC), submission deadline, tender validity period, submission status, bid bond requirement flag, prequalification status, and the lead estimator assigned. Links to the parent opportunity and the resulting contract upon award. SSOT for tender identity and submission lifecycle.' .

ind:Estimate rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Bid ;
    rdfs:label 'Estimate' ;
    rdfs:comment 'Master record for a project cost estimate prepared during the bid phase. Captures estimate number, estimate type (conceptual, schematic, detailed, definitive), base date of pricing, total estimated cost, contingency percentage, escalation allowance, overhead and profit margin, currency, estimate status, and the estimating method used (parametric, unit-rate, first-principles). Supports multiple estimate revisions per tender. SSOT for pre-award cost estimation data.' .

ind:Boq rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Bid ;
    rdfs:label 'Boq' ;
    rdfs:comment 'Bill of Quantities master record defining the structured pricing document attached to a tender. Captures BOQ reference, revision number, BOQ type (measured, provisional, approximate), total BOQ value, currency, preparation date, and the specification standard applied (NRM, POMI, CESMM). Each BOQ is linked to a tender and decomposed into BOQ line items. SSOT for BOQ document identity and header-level pricing data.' .

ind:BidBoqLine rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Bid ;
    rdfs:label 'Bid Boq Line' ;
    rdfs:comment 'Individual line item within a Bill of Quantities, representing a discrete work item priced during bid preparation. Captures item code, WBS reference, work section, item description, unit of measure, quantity, unit rate, total amount, labour component, plant component, material component, subcontract component, and overhead allocation. Supports MTO-driven quantity take-off and rate build-up analysis. Essential for bid-to-actual cost variance tracking post-award.' .

ind:EstimateLine rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Bid ;
    rdfs:label 'Estimate Line' ;
    rdfs:comment 'Detailed cost line item within a project estimate, capturing the granular cost build-up for a specific work package or activity. Stores cost code, WBS element, cost category (labour, material, plant, subcontract, indirect), resource description, quantity, unit, unit cost, total cost, productivity factor, waste factor, and source of rate (historical, vendor quote, published index). Enables detailed cost-to-complete analysis and estimate benchmarking.' .

ind:Submission rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Bid ;
    rdfs:label 'Submission' ;
    rdfs:comment 'Transactional record capturing the formal act of submitting a tender to a client or owner. Records submission timestamp, submission method (electronic portal, hard copy, email), submitted by (person), submission reference number, number of copies submitted, bid price at submission, technical score (if two-envelope), commercial score, submission acknowledgement reference, and late submission flag. Represents the definitive bid submission event for audit and compliance purposes.' .

ind:Clarification rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Bid ;
    rdfs:label 'Clarification' ;
    rdfs:comment 'Record of all formal tender-period communications and document modifications including RFIs (Requests for Information), clarifications, client-issued addenda, and amendments that modify the RFP/RFQ documents. Captures communication reference, type (RFI_issued, RFI_received, addendum, amendment, clarification), direction, addendum number (where applicable), issuing authority, subject, content, response, impact flags (bid price, schedule, scope, BOQ, specifications, drawings), revised submission deadline (if applicable), acknowledgement status, bid revision triggered, and status (open, answered, closed, incorporated). SSOT for all tender-period correspondence, addenda tracking, and document amendment audit trail ensuring tender compliance.' .

ind:Bond rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Bid ;
    rdfs:label 'Bond' ;
    rdfs:comment 'Master record for a bid bond (tender guarantee) instrument required as part of a tender submission. Captures bond reference number, issuing bank or surety, bond amount, bond currency, bond percentage of tender value, issue date, expiry date, bond type (bank guarantee, surety bond, insurance bond), beneficiary (client), bond status (issued, submitted, returned, forfeited, extended), and extension history. Tracks bond lifecycle from issuance through return or forfeiture.' .

ind:Risk rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Bid ;
    rdfs:label 'Risk' ;
    rdfs:comment 'Risk register entry specific to the bid phase, capturing identified risks and opportunities that influence bid pricing strategy and contingency allocation. Stores risk ID, risk category (commercial, technical, geotechnical, regulatory, supply chain, force majeure), risk description, probability rating, impact rating (cost, schedule, quality), risk score, mitigation strategy, contingency amount allocated, risk owner, and residual risk rating. Feeds bid pricing decisions and GMP contingency calculations.' .

ind:Approval rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Bid ;
    rdfs:label 'Approval' ;
    rdfs:comment 'Transactional record of a formal bid governance decision event within the internal authorization workflow, capturing the complete pursuit lifecycle from initial bid/no-bid decision through estimating review, commercial review, risk review, and executive sign-off. Stores approval stage (bid_no_bid, estimate_review, commercial_review, risk_review, executive_signoff), decision date, decision outcome (bid, no-bid, conditional_bid, approved, approved_with_conditions, rejected, deferred), decision authority (approver name and role), scoring against governance criteria (client relationship, risk profile, resource availability, margin potential, strategic fit, bonding capacity), total governance score, risk rating, approved bid price, approved margin percentage, conditions imposed, decision rationale narrative, delegation of authority level, and pursuit investment justification. SSOT for all bid governance decisions including pursuit authorization, resource allocation, and complete audit trail from opportunity pursuit through final submission authority.' .

ind:Master rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Material ;
    rdfs:label 'Master' ;
    rdfs:comment 'Authoritative master record for all construction materials and consumables used across projects. Captures material identity, detailed technical specifications (applicable standards — ASTM, BS, ISO, ACI, AISC — grade/class, minimum performance criteria, specification code, specification revision), classification (concrete, steel, MEP components, aggregates, timber, formwork, etc.), unit of measure, approved equivalent substitutes with engineering justification, LEED compliance flags, LEED credit applicability, hazardous material indicators, shelf life, storage requirements, and supplier cross-references. Manages specification lifecycle (draft, approved, superseded) and material qualification status. Records approved substitutions with reason, client/engineer approval reference, cost impact, and affected BOQ lines. This is the SSOT for material identity, technical specifications, and approved substitutes in the construction enterprise — all transactions reference this record.' .

ind:Warehouse rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Material ;
    rdfs:label 'Warehouse' ;
    rdfs:comment 'Master record for physical warehouse, laydown yard, and storage locations across construction sites and central depots. Tracks warehouse type (bonded, open yard, climate-controlled, hazmat-certified), capacity (area sqm, weight tonnes), GPS coordinates, site association, custodian, operating hours, hazardous material storage certification, and granular storage locations (rack positions, bin rows, open yard zones). Supports multi-site inventory management, material transfer logistics, and FIFO/FEFO stock management for batch-tracked materials.' .

ind:StockLevel rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Material ;
    rdfs:label 'Stock Level' ;
    rdfs:comment 'Current on-hand inventory position for each material at each warehouse/storage location. Captures unrestricted stock, quality-inspection stock, blocked stock, reserved stock, in-transit quantities, and committed (reserved-for-activity) quantities. Tracks reorder point, minimum/maximum stock levels, safety stock thresholds, and last movement date. Updated in real-time by stock movements (receipts, issues, transfers, returns). Critical for BOQ reconciliation, preventing site stoppages due to material shortages, and supporting procurement trigger automation.' .

ind:StockMovement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Material ;
    rdfs:label 'Stock Movement' ;
    rdfs:comment 'Transactional record of materials physically received at site or warehouse against a Purchase Order (PO). Captures GR date, PO reference, delivery note number, supplier, material, quantity received, unit of measure, batch/lot number, storage location, receiving inspector, and GR status (partial, complete, over-delivery). Triggers quality inspection workflow and updates stock levels. Aligns with SAP S/4HANA MIGO GR posting and Procore material delivery logs.' .

ind:GoodsIssue rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Material ;
    rdfs:label 'Goods Issue' ;
    rdfs:comment 'Transactional record of materials issued from warehouse/stock to a WBS element, cost center, or work front for construction consumption. Captures issue date, WBS/cost code, material, quantity issued, unit of measure, batch/lot, issuing warehouse, requestor, and issue reason. Drives material cost allocation to project activities and updates stock levels. Supports EVM cost tracking and BOQ consumption reconciliation.' .

ind:StockTransfer rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Material ;
    rdfs:label 'Stock Transfer' ;
    rdfs:comment 'Transactional record of material movements between warehouses, sites, or storage locations within the enterprise. Captures transfer date, source warehouse, destination warehouse, material, quantity, batch/lot, transfer reason (site reallocation, project closure, surplus return), transport reference, and transfer status (in-transit, completed, cancelled). Supports multi-site material balancing and inter-project material sharing.' .

ind:MaterialBoqLine rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Material ;
    rdfs:label 'Material Boq Line' ;
    rdfs:comment 'Bill of Quantities (BOQ) line item representing material and work quantities baselined for a project, used as the material domain\'s reference for take-off reconciliation, consumption tracking, and procurement planning. Captures BOQ item code, description, unit of measure, contract quantity, unit rate, total value, WBS element, trade/discipline, and revision history. While contractual BOQ ownership may reside in the contract domain, this product serves as the material domain\'s operational view for MTO reconciliation, material consumption variance analysis, and progress measurement against planned quantities.' .

ind:MtoLine rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Material ;
    rdfs:label 'Mto Line' ;
    rdfs:comment 'Material Take-Off (MTO) line item derived from engineering drawings and BIM models, representing the estimated material quantities required for construction. Captures MTO item, material master reference, design quantity, wastage factor, net required quantity, unit of measure, drawing/BIM model reference, discipline (civil, structural, MEP), revision number, and MTO status (draft, approved, issued-for-procurement). Bridges design domain and procurement/inventory planning.' .

ind:Requisition rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Material ;
    rdfs:label 'Requisition' ;
    rdfs:comment 'Site or project team request for materials to be issued from warehouse stock or procured. Captures requisition number, requesting WBS/work front, required material, quantity, required-by date, priority, justification, approval status (pending, approved, rejected), approver, and fulfilment status. Triggers either a goods issue (if stock available) or a purchase requisition in procurement. Supports site operations planning and material demand management.' .

ind:Specification rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Material ;
    rdfs:label 'Specification' ;
    rdfs:comment 'Technical specification master for construction materials defining approved material standards, grades, and performance requirements for a project or enterprise. Captures specification code, material category, applicable standard (ASTM, BS, ISO, ACI, AISC), grade/class, minimum performance criteria, approved equivalent substitutes, LEED credit applicability, and specification status (draft, approved, superseded). Links design requirements to procurement and QA/QC inspection criteria.' .

ind:Wastage rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Material ;
    rdfs:label 'Wastage' ;
    rdfs:comment 'Transactional record tracking material wastage and scrap generated during construction activities. Captures wastage date, WBS/work front, material, planned quantity, actual quantity consumed, wastage quantity, wastage percentage, wastage cause (cutting loss, breakage, over-pour, theft, weather damage), disposal method (recycled, landfill, returned), and cost impact. Supports waste reduction programs, LEED waste diversion tracking, and project cost control.' .

ind:Activity rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Schedule ;
    rdfs:label 'Activity' ;
    rdfs:comment 'Core CPM (Critical Path Method) schedule activity representing a discrete unit of work within a project WBS. Captures activity ID, name, WBS code, activity type (task-dependent, resource-dependent, level of effort, milestone), planned/actual start and finish dates, original duration, remaining duration, percent complete, calendar assignment, constraint types (start-no-earlier-than, finish-no-later-than, mandatory), float values (total float, free float), critical path flag, activity status (not started, in progress, completed, suspended), and activity code assignments for filtering and grouping. The foundational scheduling entity from which all schedule analysis, critical path calculation, and progress measurement derives.' .

ind:ActivityRelationship rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Schedule ;
    rdfs:label 'Activity Relationship' ;
    rdfs:comment 'Logical dependency links between schedule activities defining the CPM network logic. Captures predecessor and successor activity references, relationship type (Finish-to-Start, Start-to-Start, Finish-to-Finish, Start-to-Finish), lag/lead duration, lag time unit, driving relationship flag, and relationship source (scheduling tool export, manual entry). Enables critical path calculation, schedule network analysis, and what-if scenario modeling for delay impact assessment.' .

ind:ScheduleBaseline rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Schedule ;
    rdfs:label 'Schedule Baseline' ;
    rdfs:comment 'Approved project schedule baseline snapshot capturing the time-phased plan against which actual progress is measured. Stores baseline name, baseline type (original, current, supplemental), approval date, approved-by reference, baseline start and finish dates, total baseline duration, baseline data date, and scheduling tool baseline project reference. Supports EVM (Earned Value Management) calculations including BCWS (Budgeted Cost of Work Scheduled) and variance analysis. Multiple baselines per project are supported (original contract baseline, re-baselined approved revisions).' .

ind:BaselineActivity rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Schedule ;
    rdfs:label 'Baseline Activity' ;
    rdfs:comment 'Baseline-frozen snapshot of each activity\'s planned dates, durations, and resource assignments at the time a schedule baseline was approved. Stores baseline early start, baseline early finish, baseline late start, baseline late finish, baseline original duration, baseline remaining duration, baseline percent complete, and baseline total float for each activity within a specific baseline. Enables schedule variance analysis (SV = BCWP - BCWS) and start/finish variance reporting against the approved plan.' .

ind:Resource rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Schedule ;
    rdfs:label 'Resource' ;
    rdfs:comment 'Resource definitions assigned to schedule activities for resource-loaded scheduling and leveling. Captures resource name, resource type (labor, non-labor, material), unit of measure, max units per time period, default units per time, price per unit, resource calendar, overtime factor, and resource role. Sourced from the enterprise scheduling tool resource dictionary. Supports resource leveling, resource histograms, and cost-loaded schedule generation. Distinct from workforce employee records — this is the scheduling resource abstraction used for capacity planning and EVM cost loading.' .

ind:ActivityResourceAssignment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Schedule ;
    rdfs:label 'Activity Resource Assignment' ;
    rdfs:comment 'Assignment of a schedule resource to a specific activity, capturing the planned and actual resource consumption. Stores assigned resource reference, activity reference, budgeted units, actual units to date, remaining units, budgeted cost, actual cost, remaining cost, resource distribution curve (front-loaded, back-loaded, bell, linear), overtime units, and assignment status. Enables resource-loaded schedule analysis, cost-loaded CPM, and EVM BCWP (Budgeted Cost of Work Performed) calculations.' .

ind:WbsNode rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Schedule ;
    rdfs:label 'Wbs Node' ;
    rdfs:comment 'Work Breakdown Structure (WBS) hierarchy node defining the decomposition of project scope into manageable components. Captures WBS code, WBS name, WBS level, parent WBS reference, WBS type (project summary, WBS summary, work package), anticipated start and finish dates, earned value technique (fixed formula, percent complete, weighted milestones, level of effort), and WBS status. Provides the hierarchical framework for schedule organization, cost control, progress reporting, and EVM roll-up calculations.' .

ind:ScheduleCalendar rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Schedule ;
    rdfs:label 'Schedule Calendar' ;
    rdfs:comment 'Work calendars defining working and non-working time periods used in schedule calculations. Captures calendar name, calendar type (global, project, resource), standard work hours per day, work week definition (working days per week), holiday exceptions, shift patterns, and time zone. Imported from the enterprise scheduling tool calendar configuration. Determines activity duration calculations, float computations, and resource availability windows. Critical for multi-site international projects operating across different regional calendars and public holiday schedules.' .

ind:ProgressUpdate rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Schedule ;
    rdfs:label 'Progress Update' ;
    rdfs:comment 'Periodic schedule progress update record capturing actual performance data, EVM metrics, and critical path state at a specific data date. Stores actual start/finish dates, remaining duration, percent complete (duration, units, physical), actual/remaining units, update source (field report, P6 import, HCSS HeavyJob), reporting period definition (period number, dates, frequency, status), EVM metrics (BCWP, BCWS, SPI, SV, SV%, forecast completion date), and critical path snapshot (project completion date, total float, critical activity count, path drift indicator). Represents the single transactional record of schedule state per reporting period. Enables schedule performance trending, SPI reporting, and critical path monitoring over time.' .

ind:LookaheadPlan rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Schedule ;
    rdfs:label 'Lookahead Plan' ;
    rdfs:comment 'Short-interval look-ahead schedule (typically 3-week or 6-week rolling window) used for near-term construction planning and crew coordination. Captures look-ahead period dates, horizon (weeks), responsible superintendent/foreman, work front or zone, constraint identification, and readiness status (materials, permits, crew, equipment confirmed). Supports Last Planner System (LPS) and Percent Plan Complete (PPC) tracking. Bridges the gap between the master CPM schedule and daily site execution. The header record for lookahead_activity line items.' .

ind:ScheduleMilestone rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Schedule ;
    rdfs:label 'Schedule Milestone' ;
    rdfs:comment 'Key project milestone records representing contractually significant or internally critical schedule events with zero duration. Captures milestone name, milestone type (contract milestone, internal milestone, client milestone, regulatory milestone), planned date, forecast date, actual achieved date, milestone status (not started, at risk, achieved, missed), contract reference, liquidated damages (LD) exposure flag, LD rate per day, and milestone owner. Derived from contract schedule requirements and master CPM schedule milestone activities. Enables contract compliance tracking, LD exposure monitoring, and executive schedule reporting.' .

ind:DelayEvent rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Schedule ;
    rdfs:label 'Delay Event' ;
    rdfs:comment 'Discrete delay event record capturing a specific occurrence that caused or is causing schedule delay. Stores event name, event type (weather, design change, employer instruction, utility conflict, permit delay, labor dispute, material shortage, force majeure), event start date, event end date, impacted activities, delay duration (calendar days, working days), responsibility party (employer, contractor, third party, neutral), delay category (excusable compensable, excusable non-compensable, non-excusable), linked EOT claim reference, and mitigation measures taken. Supports delay analysis (as-planned vs as-built, time impact analysis, windows analysis).' .

ind:Permit rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Permit' ;
    rdfs:comment 'Master register of all construction permits across the full lifecycle from application through expiry, including building permits, excavation permits, environmental permits, utility connection permits, demolition permits, and occupancy permits. Tracks application submissions (applicant details, supporting documents, authority response, resubmissions, appeals), authority review and approval/rejection, issuance, individual conditions attached (each with due date, responsible party, fulfilment status, and compliance evidence), condition compliance monitoring, renewal, expiry, revocation, and suspension. Captures permit number, issuing authority, permit type, project association, submission date, issue date, expiry date, renewal requirements, and current status. Serves as the SSOT for permit identity, permit application history, and permit condition compliance across all project sites.' .

ind:PermitApplication rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Permit Application' ;
    rdfs:comment 'Transactional record of each permit application submitted to a regulatory or municipal authority, capturing application reference, submission date, applicant details, supporting documents submitted, application status, authority response, and approval or rejection outcome. Tracks the full lifecycle from initial submission through approval, including resubmissions and appeals.' .

ind:PermitCondition rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Permit Condition' ;
    rdfs:comment 'Records individual conditions, restrictions, and obligations attached to an issued permit by the regulatory authority. Each condition has its own compliance obligation, due date, responsible party, and fulfilment status. Enables tracking of permit condition compliance separately from the permit itself, supporting audit readiness and authority inspections.' .

ind:EnvImpactAssessment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Env Impact Assessment' ;
    rdfs:comment 'Master record for Environmental Impact Assessments (EIA), Environmental Management Plans (EMP), and ongoing environmental monitoring programs for construction projects. Captures assessment type, scope, environmental consultant, assessment date, findings summary, mitigation measures required, regulatory submission reference, approval status, and review cycle. Includes full environmental monitoring history: air quality measurements, noise level readings, water discharge sampling, soil contamination checks, dust suppression monitoring, with monitoring date, location, parameter measured, recorded value, regulatory threshold, exceedance flag, and corrective action triggered for each monitoring event. Supports EPA reporting, ISO 14001 surveillance, and demonstrates ongoing environmental compliance through continuous monitoring evidence.' .

ind:EnvMonitoring rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Env Monitoring' ;
    rdfs:comment 'Transactional records of environmental monitoring activities conducted on construction sites, including air quality measurements, noise level readings, water discharge sampling, soil contamination checks, and dust suppression monitoring. Captures monitoring date, location, parameter measured, recorded value, regulatory threshold, exceedance flag, and corrective action triggered. Supports EPA reporting and ISO 14001 surveillance.' .

ind:RegulatorySubmission rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Regulatory Submission' ;
    rdfs:comment 'Transactional record of formal regulatory submissions made to governing bodies including OSHA, EPA, local building authorities, and environmental agencies. Captures submission type (annual report, incident notification, permit renewal, compliance certificate), submission date, regulatory body, submission reference number, reporting period, submission method, acknowledgement received, and submission status. Serves as the SSOT for all outbound regulatory filings.' .

ind:RegulatoryObligation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Regulatory Obligation' ;
    rdfs:comment 'Master register of all regulatory obligations applicable to the organization and its construction projects, derived from applicable laws, standards, permits, and contractual requirements. Captures obligation source (OSHA 29 CFR, EPA Clean Water Act, IBC/IRC, ISO 45001, GDPR, PCI DSS, FIDIC, local building codes), obligation description, applicable jurisdiction, effective date, review frequency, responsible owner, compliance evidence required, current compliance status, and organizational scope mapping (projects, business units, jurisdictions). Serves as the single compliance obligation inventory underpinning all compliance activities, assessments, calendar deadlines, and regulatory change impact analysis.' .

ind:Assessment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Assessment' ;
    rdfs:comment 'Periodic compliance assessment records evaluating the organization\'s or a project\'s adherence to regulatory obligations, internal policies, and permit conditions. Captures assessment date, scope, assessor, obligations assessed, findings, compliance rating, gaps identified, and recommended actions. Distinct from quality NCRs (owned by quality domain) and safety audits (owned by safety domain) — this covers regulatory and legal compliance only.' .

ind:Action rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Action' ;
    rdfs:comment 'Corrective and preventive actions raised as a result of compliance assessments, regulatory findings, permit condition breaches, or authority notices. Tracks action description, root cause, responsible party, due date, priority, completion status, evidence of closure, and verification date. Distinct from safety corrective actions (owned by safety domain via Intelex) — this covers regulatory compliance remediation only.' .

ind:AuthorityNotice rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Authority Notice' ;
    rdfs:comment 'Records formal notices, orders, infringement notices, improvement notices, prohibition notices, stop-work orders, and directives received from regulatory authorities including OSHA, EPA, local councils, fire marshals, and building inspectors. Captures notice type, severity level, issuing authority, notice date, project or site affected, violation described, applicable regulation breached, required remediation, response deadline, response submitted, appeal lodged flag, and resolution outcome. Critical for legal risk management, regulatory relationship tracking, and insurance notification obligations.' .

ind:RegulatoryAuthority rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Regulatory Authority' ;
    rdfs:comment 'Reference master of regulatory and governing bodies with whom the organization interacts, including OSHA, EPA, local building departments, environmental agencies, fire marshals, and utility authorities. Captures authority name, jurisdiction type, geographic scope, contact details, applicable regulatory frameworks, portal or submission system reference, and relationship owner. Enables consistent authority identification across permit applications, submissions, and notices.' .

ind:Agreement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Contract ;
    rdfs:label 'Agreement' ;
    rdfs:comment 'Master contract record representing the authoritative SSOT for all contractual agreements in the construction domain. Captures FIDIC-based EPC, GMP (Guaranteed Maximum Price), lump-sum, unit-rate, DB (Design-Build), DBB (Design-Bid-Build), PPP (Public-Private Partnership), and BOT (Build-Operate-Transfer) contract types via a type classification attribute. Stores contract identity, scope narrative, detailed scope of works including WBS (Work Breakdown Structure) reference, deliverable descriptions, technical specifications reference, BOQ (Bill of Quantities) linkage, geographic boundaries, and exclusions. Records execution dates, NTP (Notice to Proceed) date, contract value, currency, governing law, dispute resolution mechanism, contract status lifecycle from award through close-out, and particular/special conditions that modify standard form terms. Maintains status transition history for audit and lifecycle analytics. Records all formal amendments including supplemental agreements, deed of variations, and novation agreements with amendment number, type, effective date, revised contract value, revised completion date, and execution status. Serves as the authoritative scope baseline against which change orders and EOT claims are evaluated.' .

ind:Party rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Contract ;
    rdfs:label 'Party' ;
    rdfs:comment 'Association entity capturing all parties bound to a contract agreement, including the employer/client, general contractor (GC), joint venture (JV) partners, engineer/consultant, and guarantors. Records party role, signatory authority, legal entity name, registration number, jurisdiction, and participation percentage for JV arrangements. Enables multi-party contract structures common in EPC and PPP delivery models.' .

ind:Scope rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Contract ;
    rdfs:label 'Scope' ;
    rdfs:comment 'Defines the detailed scope of works attached to a contract agreement, including WBS (Work Breakdown Structure) reference, deliverable descriptions, technical specifications reference, BOQ (Bill of Quantities) linkage, geographic boundaries, and exclusions. Serves as the authoritative scope baseline against which change orders and EOT (Extension of Time) claims are evaluated.' .

ind:ContractMilestone rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Contract ;
    rdfs:label 'Contract Milestone' ;
    rdfs:comment 'Tracks contractually obligated milestones, key dates, and DLP (Defects Liability Period) obligations within a contract. Covers NTP (Notice to Proceed), sectional completion dates, practical completion, DLP start/end dates, performance certificate issuance, and final certificate dates. Records planned date, forecast date, actual achieved date, milestone value (if linked to payment), milestone type, and milestone status. Manages the complete DLP register including defects notified by the employer, contractor rectification commitments, rectification deadlines, outstanding defects at DLP expiry, and the transition from practical completion through to final certificate issuance and retention release. Used for LD (Liquidated Damages) trigger assessment, payment certification, DLP management, and retention release scheduling.' .

ind:PaymentSchedule rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Contract ;
    rdfs:label 'Payment Schedule' ;
    rdfs:comment 'Defines the contractual payment schedule governing when and how much the employer is obligated to pay the contractor, including full advance payment (mobilization payment) lifecycle management. Captures payment terms, payment intervals, payment due dates, payment method, currency, and supports both milestone-based and time-based payment structures as defined under FIDIC and GMP contract forms. Manages the complete advance payment lifecycle: advance payment amount, percentage of contract value, disbursement date, repayment/recovery schedule, cumulative amount recovered through payment certificate deductions, outstanding advance balance, advance payment guarantee reference, and advance payment status from initial disbursement through full recovery. Serves as the authoritative SSOT for all payment scheduling and advance payment tracking, alongside progress payment and retention release scheduling.' .

ind:PaymentCertificate rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Contract ;
    rdfs:label 'Payment Certificate' ;
    rdfs:comment 'Transactional record of each interim payment certificate (IPC) and final payment certificate (FPC) issued under a main contract or subcontract. Captures certified amount, retention deducted, advance payment recovery, LD deductions, net amount due, certification date, certifier identity, payment due date, and actual payment date. Supports both main contract certification (FIDIC Clause 14) and subcontract payment certification via a contract-level discriminator distinguishing main contract from subcontract certificates. Records subcontract payment applications, certified amounts, and enables back-to-back payment flow management between main contract receipts and subcontractor disbursements. Supports cash flow forecasting, pay-when-paid clause administration, and unified payment reconciliation across the full contract hierarchy.' .

ind:ContractChangeOrder rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Contract ;
    rdfs:label 'Contract Change Order' ;
    rdfs:comment 'Authoritative log of all CO (Change Orders) and contract variations issued against a contract. Records variation instruction reference, scope description, reason code (employer-directed, unforeseen conditions, design change), cost impact (addition or omission), schedule impact in days, approval status, and executed value. Tracks the full variation lifecycle from instruction through valuation, negotiation, and formal execution. Links to EOT claims where schedule impact is asserted.' .

ind:EotClaim rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Contract ;
    rdfs:label 'Eot Claim' ;
    rdfs:comment 'Records EOT (Extension of Time) claims submitted by the contractor asserting entitlement to additional time due to employer risk events, force majeure, or other contractual grounds. Captures claim submission date, delay event description, days claimed, days assessed by engineer, grounds of entitlement (FIDIC Sub-Clause reference), supporting documentation references, and final determination outcome. Critical for managing LD (Liquidated Damages) exposure and revised completion date.' .

ind:LdAssessment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Contract ;
    rdfs:label 'Ld Assessment' ;
    rdfs:comment 'Tracks LD (Liquidated Damages) assessments applied or withheld against a contractor for failure to achieve contractual completion milestones. Records the milestone missed, LD rate per day (as defined in the contract appendix), number of days in delay, total LD amount assessed, any LD waiver or reduction granted, and the net LD deducted from payment certificates. Provides the authoritative LD register for financial reporting and dispute management.' .

ind:RetentionLedger rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Contract ;
    rdfs:label 'Retention Ledger' ;
    rdfs:comment 'Tracks the accumulation and release of retention monies held under a contract. Records retention percentage applied per payment certificate, cumulative retention balance, practical completion release amount (typically 50% of retention), DLP (Defects Liability Period) expiry release amount, retention bond substitution details, and any partial releases approved. Provides the authoritative retention balance for financial reconciliation.' .

ind:Amendment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Contract ;
    rdfs:label 'Amendment' ;
    rdfs:comment 'Records formal amendments to the original contract agreement, including supplemental agreements, deed of variations, and novation agreements. Captures amendment number, amendment type, effective date, description of changes to original terms, revised contract value, revised completion date, and execution status. Maintains a complete amendment history for each contract to support audit and dispute resolution.' .

ind:BondGuarantee rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Contract ;
    rdfs:label 'Bond Guarantee' ;
    rdfs:comment 'Tracks all performance bonds, advance payment guarantees, retention bonds, bid bonds, and parent company guarantees associated with a contract. Records bond type, issuing bank or surety, bond amount, bond currency, issue date, expiry date, call conditions, and current status (active, expired, called, released). Provides the authoritative bond register for contract administration and financial risk management.' .

ind:Subcontract rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Contract ;
    rdfs:label 'Subcontract' ;
    rdfs:comment 'Master record for subcontracts let by the main contractor to specialist trade and MEP (Mechanical Electrical Plumbing) subcontractors under the main contract. Captures subcontract type (domestic, nominated, specialist), subcontract value, scope summary, back-to-back terms with main contract, NTP date, completion date, and subcontract status. Distinct from the subcontractor domain master — this entity owns the contractual instrument, not the subcontractor party profile.' .

ind:SubcontractPayment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Contract ;
    rdfs:label 'Subcontract Payment' ;
    rdfs:comment 'Transactional record of payment applications and payment certificates issued under each subcontract. Captures application amount, certified amount, retention deducted, LD deductions, net payment due, payment due date, and actual payment date. Enables back-to-back payment flow management between main contract receipts and subcontractor disbursements, supporting cash flow forecasting and pay-when-paid clause administration.' .

ind:Closeout rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Contract ;
    rdfs:label 'Closeout' ;
    rdfs:comment 'Records the formal contract close-out process including practical completion declaration, final account agreement, performance certificate issuance, final payment certificate, retention release, bond release, and O&M (Operations and Maintenance) manual handover. Captures close-out checklist status, outstanding punch list items, final contract value versus original contract value, and lessons learned reference. Marks the definitive end of contractual obligations.' .

ind:ComplianceCalendar rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Compliance Calendar' ;
    rdfs:comment 'Operational calendar of compliance deadlines, renewal dates, submission due dates, permit expiry dates, ISO audit schedules, LEED submission windows, and regulatory filing deadlines. Aggregates key dates from permits, certifications, regulatory obligations, and authority notices into a single actionable timeline. Captures deadline date, deadline type, source obligation or permit reference, responsible owner, reminder lead time, escalation path, completion status, and overdue flag. The primary daily operational tool for construction compliance managers ensuring no regulatory deadline is missed across multiple project sites and jurisdictions.' .

ind:Site rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Site ;
    rdfs:label 'Site Site' ;
    rdfs:comment 'Master reference table for site. Referenced by current_location_site_id.' .

ind:ProfitCenter rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Profit Center' ;
    rdfs:comment 'Master reference table for profit_center. Referenced by profit_center_id.' .

ind:CompanyCode rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Company Code' ;
    rdfs:comment 'Master reference table for company_code. Referenced by company_code_id.' .

ind:ProjectSite rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Project ;
    rdfs:label 'Project Site' ;
    rdfs:comment 'Master reference table for site. Referenced by site_id.' .

ind:Service rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Procurement ;
    rdfs:label 'Service' ;
    rdfs:comment 'Master reference table for service. Referenced by service_id.' .

ind:JvParticipant rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Client ;
    rdfs:label 'Jv Participant' ;
    rdfs:comment 'This association product represents the Participation role between account and jv_structure. It captures each client entity\'s formal membership in a Joint Venture arrangement, including their equity stake, committed capital, governance role, and tenure dates. Each record links one account to one jv_structure with attributes that exist only in the context of that specific participation — data that cannot reside on either the account or the JV structure alone.. Existence Justification: In construction, Joint Ventures are co-ownership vehicles where multiple client entities (accounts) simultaneously participate as equity partners in a single JV structure. A single account (e.g., a large infrastructure developer) can participate in multiple JV structures across different projects, and a single JV structure by definition has multiple participating accounts. The current model only captures the lead sponsor via primary_jv_account_id on jv_structure, leaving all non-lead participants entirely unmodelled — a fundamental gap in the business model.' .

ind:ObligationAssessmentResult rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Obligation Assessment Result' ;
    rdfs:comment 'This association product represents the per-obligation outcome Event between assessment and regulatory_obligation. It captures the specific compliance result, findings, gap status, and remediation requirement for each regulatory obligation evaluated within a given compliance assessment. Each record links one assessment to one regulatory_obligation with attributes that exist only in the context of this intersection — a named operational concept used in ISO 14001, OSHA VPP, and EPA audit frameworks.. Existence Justification: In construction compliance management, a single assessment (e.g., an EPA audit or OSHA inspection) evaluates multiple regulatory obligations simultaneously, and each regulatory obligation is evaluated across multiple assessments over its lifecycle. This is not an analytical correlation — compliance teams actively create, manage, and report on per-obligation findings within each assessment as a named operational concept (\'obligation assessment result\'). The relationship carries its own data (per-obligation compliance rating, findings, gap status, remediation flag) that belongs to neither the assessment nor the obligation alone.' .

ind:TradeStaffingRequirement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Workforce ;
    rdfs:label 'Trade Staffing Requirement' ;
    rdfs:comment 'This association product represents the planned deployment of a specific construction trade within a specific staffing plan. It captures the trade-level workforce allocation — planned headcount, labor hours, ramp-up/ramp-down schedule, and peak demand — for each trade discipline required by a staffing plan. Each record links one staffing_plan to one skill_trade with attributes that exist only in the context of this trade-within-plan allocation. Recognized as a core workforce planning artifact in HCSS HeavyJob and SAP SuccessFactors.. Existence Justification: In construction workforce planning, a staffing plan is inherently a multi-trade document — a single project phase requires ironworkers, pipefitters, electricians, and carpenters simultaneously. The current model forces one staffing_plan record per trade (via a scalar skill_trade_id FK), which fragments what is operationally a single plan into multiple records. The correct model is a trade allocation record that captures planned headcount, labor hours, and schedule curves for each trade within a given staffing plan — a recognized artifact in HCSS HeavyJob and SAP SuccessFactors workforce planning.' .

ind:LookaheadActivityCommitment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Schedule ;
    rdfs:label 'Lookahead Activity Commitment' ;
    rdfs:comment 'This association product represents the Commitment between a CPM schedule activity and a short-interval lookahead plan within the Last Planner System (LPS). It captures the per-activity readiness state, constraint status, and commitment fulfillment for each activity as it appears in a specific rolling lookahead window. Each record links one activity to one lookahead_plan and carries readiness flags, constraint details, and window-specific planning dates that exist only in the context of this activity-plan pairing. This is the operational record that drives PPC (Percent Plan Complete) tracking and near-term crew coordination.. Existence Justification: In construction project controls, a CPM schedule activity can appear in multiple lookahead plans across successive rolling windows (e.g., an activity first appears in the 6-week window, then the 3-week window, then the 1-week window as it approaches execution). Conversely, each lookahead plan contains many activities. The Last Planner System explicitly models this as a commitment tracking mechanism where each activity-plan pairing carries its own readiness state (crew, materials, equipment confirmed), constraint status, and commitment fulfillment — data that belongs to neither the activity nor the plan alone.' .

ind:ActivityDelayImpact rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Schedule ;
    rdfs:label 'Activity Delay Impact' ;
    rdfs:comment 'This association product represents the formal impact record between a delay_event and an activity in construction project controls. It captures the specific quantum of delay, critical path effect, and EOT entitlement for each activity affected by each delay event. Each record links one delay_event to one activity and carries attributes that exist only in the context of that specific event-activity impact relationship, supporting delay analysis methodologies (as-planned vs as-built, time impact analysis, windows analysis) per SCL Protocol and AACE RP 29R-03.. Existence Justification: In construction project controls, a single delay event (e.g., a severe weather event or a design change instruction) routinely impacts multiple schedule activities simultaneously, and a single activity can be impacted by multiple distinct delay events over its lifecycle. This is a formally managed operational relationship in delay analysis disciplines (SCL Protocol, AACE RP 29R-03): project controls engineers actively create, update, and close individual delay impact records per activity per event, tracking quantum of delay, critical path effect, and EOT entitlement at the activity level. The relationship is not derivable from existing transactional joins — it requires its own records with per-activity impact data.' .

# --- Attribute Properties ---
ind:accountId rdf:type rdf:Property ;
    rdfs:label 'Account Id' ;
    rdfs:comment 'Unique surrogate identifier for the client/owner account record in the Silver Layer lakehouse. Primary key for the account master entity.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Account .

ind:parentAccountId rdf:type rdf:Property ;
    rdfs:label 'Parent Account Id' ;
    rdfs:comment 'Reference to the parent account record for clients that are subsidiaries or divisions within a larger corporate hierarchy. Enables account hierarchy traversal for consolidated reporting and group-level relationship management.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Account .

ind:primaryUltimateParentAccountId rdf:type rdf:Property ;
    rdfs:label 'Primary Ultimate Parent Account Id' ;
    rdfs:comment 'Reference to the top-level account in the corporate hierarchy (ultimate holding entity). Used for group-level exposure analysis, consolidated pipeline reporting, and enterprise relationship management.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Account .

ind:accountStatus rdf:type rdf:Property ;
    rdfs:label 'Account Status' ;
    rdfs:comment 'Current lifecycle status of the client account. Controls whether the account is eligible for new project bids, contract awards, and CRM pipeline activities.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountType rdf:type rdf:Property ;
    rdfs:label 'Account Type' ;
    rdfs:comment 'Classification of the client account by ownership and sector type. Drives contract template selection, compliance requirements, and reporting segmentation. [ENUM-REF-CANDIDATE: public_sector|private_sector|government_body|corporate_sponsor|jv_entity|ppp_authority — promote to reference product]' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:annualRevenue rdf:type rdf:Property ;
    rdfs:label 'Annual Revenue' ;
    rdfs:comment 'Reported or estimated annual revenue of the client organisation in the account\'s billing currency. Used for client segmentation, credit assessment, and strategic account prioritisation.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:billingAddress rdf:type rdf:Property ;
    rdfs:label 'Billing Address' ;
    rdfs:comment 'Address to which invoices and financial correspondence are directed for this client account. May differ from the registered address. Used in SAP S/4HANA accounts receivable and Viewpoint Vista job costing.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bimRequirementLevel rdf:type rdf:Property ;
    rdfs:label 'Bim Requirement Level' ;
    rdfs:comment 'Level of Building Information Modeling (BIM) mandated by the client for construction projects. Drives design collaboration tooling requirements (e.g., Autodesk BIM 360), data exchange standards, and project delivery methodology.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clientTier rdf:type rdf:Property ;
    rdfs:label 'Client Tier' ;
    rdfs:comment 'Strategic segmentation tier assigned to the client based on revenue potential, relationship depth, and strategic importance. Tier 1 represents the highest-value clients. Drives account management resource allocation and executive engagement levels.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countryCode rdf:type rdf:Property ;
    rdfs:label 'Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code representing the country of incorporation or primary operations for the client organisation. Used for jurisdictional compliance, tax treatment, and geographic segmentation.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:createdTimestamp rdf:type rdf:Property ;
    rdfs:label 'Created Timestamp' ;
    rdfs:comment 'Timestamp when the account record was first created in the source Salesforce CRM system. Represents the audit trail creation event for the master client record.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:creditLimit rdf:type rdf:Property ;
    rdfs:label 'Credit Limit' ;
    rdfs:comment 'Maximum outstanding receivable balance approved for this client account. Used by the finance team to manage exposure and payment risk on construction contracts. Expressed in the account\'s billing currency.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditRating rdf:type rdf:Property ;
    rdfs:label 'Credit Rating' ;
    rdfs:comment 'External credit rating assigned to the client organisation by a recognised credit rating agency (e.g., S&P, Moody\'s, Fitch) or internal credit assessment score. Used for financial risk evaluation, payment terms negotiation, and bonding/surety decisions.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crmAccountCode rdf:type rdf:Property ;
    rdfs:label 'Crm Account Code' ;
    rdfs:comment 'Source system identifier for the account as recorded in Salesforce CRM. Used for cross-system reconciliation and lineage tracing back to the operational system of record.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currencyCode rdf:type rdf:Property ;
    rdfs:label 'Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code representing the primary billing currency for this client account (e.g., USD, GBP, EUR, AED). Used for contract valuation, invoicing, and financial reporting.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:doNotContact rdf:type rdf:Property ;
    rdfs:label 'Do Not Contact' ;
    rdfs:comment 'Indicates whether outbound marketing and unsolicited commercial communications to this client account are restricted. Set to True when the client has opted out of communications or is subject to legal/regulatory restrictions. Supports GDPR compliance.' ;
    rdfs:domain ind:Client ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dunsNumber rdf:type rdf:Property ;
    rdfs:label 'Duns Number' ;
    rdfs:comment 'Nine-digit Dun & Bradstreet Data Universal Numbering System identifier for the client organisation. Used for credit assessment, supplier/client qualification, and global entity resolution.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employeeCount rdf:type rdf:Property ;
    rdfs:label 'Employee Count' ;
    rdfs:comment 'Approximate number of employees in the client organisation. Used as a proxy for organisational scale, procurement capacity, and client segmentation in CRM analytics.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:eotPolicy rdf:type rdf:Property ;
    rdfs:label 'Eot Policy' ;
    rdfs:comment 'Client\'s standard policy for granting Extension of Time (EOT) on construction contracts. Indicates whether the client follows standard FIDIC provisions, applies strict timelines, or allows flexible negotiation. Used in bid risk evaluation.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hseComplianceRequired rdf:type rdf:Property ;
    rdfs:label 'Hse Compliance Required' ;
    rdfs:comment 'Indicates whether this client mandates specific Health, Safety and Environment (HSE) compliance standards (e.g., ISO 45001, OSHA requirements, client-specific HSE plans) as a condition of contract. Drives HSE planning and prequalification requirements.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:industrySector rdf:type rdf:Property ;
    rdfs:label 'Industry Sector' ;
    rdfs:comment 'Primary industry sector of the client organisation (e.g., Infrastructure, Energy, Real Estate, Transportation, Healthcare, Government). Used for market segmentation and opportunity pipeline analytics in Salesforce CRM.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isJvEntity rdf:type rdf:Property ;
    rdfs:label 'Is Jv Entity' ;
    rdfs:comment 'Indicates whether this client account represents a Joint Venture (JV) entity formed specifically for a construction project or programme. JV entities require special contract administration, profit-sharing arrangements, and consolidated reporting.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastModifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Modified Timestamp' ;
    rdfs:comment 'Timestamp of the most recent update to the account record in the source Salesforce CRM system. Used for change data capture, incremental ETL processing, and audit trail maintenance.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lastProjectAwardDate rdf:type rdf:Property ;
    rdfs:label 'Last Project Award Date' ;
    rdfs:comment 'Date of the most recent contract or project award from this client. Used to identify dormant accounts, measure relationship recency, and prioritise re-engagement activities in the CRM pipeline.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ldClauseStandard rdf:type rdf:Property ;
    rdfs:label 'Ld Clause Standard' ;
    rdfs:comment 'Indicates whether this client typically enforces Liquidated Damages (LD) clauses in construction contracts, and whether the LD terms are standard or negotiable. Informs bid risk assessment and contract strategy.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leedCertificationRequired rdf:type rdf:Property ;
    rdfs:label 'Leed Certification Required' ;
    rdfs:comment 'Indicates whether this client requires LEED (Leadership in Energy and Environmental Design) certification for construction projects. Drives design, procurement, and construction methodology decisions to meet green building standards.' ;
    rdfs:domain ind:Client ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:legalName rdf:type rdf:Property ;
    rdfs:label 'Legal Name' ;
    rdfs:comment 'Full registered legal name of the client/owner organisation as it appears on contracts, invoices, and regulatory filings. This is the authoritative identity label for the account.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ntpAuthorityLevel rdf:type rdf:Property ;
    rdfs:label 'Ntp Authority Level' ;
    rdfs:comment 'Describes the client\'s internal authority level or approval threshold required to issue a Notice to Proceed (NTP) on construction contracts. Used in contract administration to understand client governance and approval workflows.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentTerms rdf:type rdf:Property ;
    rdfs:label 'Payment Terms' ;
    rdfs:comment 'Standard payment terms agreed with the client for construction contracts (e.g., Net 30, Net 60, milestone-based, progress payment). Drives accounts receivable management and cash flow forecasting in SAP S/4HANA.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredContractType rdf:type rdf:Property ;
    rdfs:label 'Preferred Contract Type' ;
    rdfs:comment 'Client\'s preferred contract delivery model for construction engagements. Options include Engineering Procurement and Construction (EPC), Guaranteed Maximum Price (GMP), Design-Bid-Build (DBB), Design-Build (DB), Public-Private Partnership (PPP), and Build-Operate-Transfer (BOT). Informs bid strategy and contract template selection. [ENUM-REF-CANDIDATE: EPC|GMP|DBB|DB|PPP|BOT|FIDIC — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prequalificationExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Prequalification Expiry Date' ;
    rdfs:comment 'Date on which the client\'s prequalification approval expires and requires renewal. Used to trigger re-assessment workflows and ensure compliance before new contract awards.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:prequalificationStatus rdf:type rdf:Property ;
    rdfs:label 'Prequalification Status' ;
    rdfs:comment 'Current prequalification status of the client as a commissioning entity. Indicates whether the client has been assessed and approved for contract award eligibility, is pending review, or has an expired/rejected qualification.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactEmail rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Email' ;
    rdfs:comment 'Email address of the primary contact at the client organisation. Used for RFI responses, RFP submissions, contract correspondence, and CRM communication tracking.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactName rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Name' ;
    rdfs:comment 'Full name of the primary point of contact at the client organisation for commercial and contractual matters. Typically the client\'s project director, procurement manager, or authorised representative.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactPhone rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Phone' ;
    rdfs:comment 'Direct telephone number for the primary contact at the client organisation. Used for urgent project communications, bid clarifications, and relationship management activities.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registeredAddress rdf:type rdf:Property ;
    rdfs:label 'Registered Address' ;
    rdfs:comment 'Full registered office address of the client organisation as recorded with the relevant business registry. Used for legal correspondence, contract execution, and regulatory filings.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationNumber rdf:type rdf:Property ;
    rdfs:label 'Registration Number' ;
    rdfs:comment 'Official company or entity registration number issued by the relevant national or state business registry authority. Used for legal entity verification and compliance due diligence.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipStartDate rdf:type rdf:Property ;
    rdfs:label 'Relationship Start Date' ;
    rdfs:comment 'Date on which the business relationship with this client was formally established (e.g., first contract award, first NTP issued, or CRM account creation date). Used for relationship tenure analysis and loyalty segmentation.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:taxNumber rdf:type rdf:Property ;
    rdfs:label 'Tax Number' ;
    rdfs:comment 'Government-issued tax identification number (e.g., EIN, VAT number, GST number) for the client entity. Required for invoicing, contract administration, and financial reporting under IFRS/GAAP.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradingName rdf:type rdf:Property ;
    rdfs:label 'Trading Name' ;
    rdfs:comment 'Operating or brand name used by the client organisation in day-to-day business, which may differ from the registered legal name. Used in CRM displays and correspondence.' ;
    rdfs:domain ind:Account ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:websiteUrl rdf:type rdf:Property ;
    rdfs:label 'Website Url' ;
    rdfs:comment 'Official website address of the client organisation. Used for due diligence, background research, and CRM account enrichment.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactId rdf:type rdf:Property ;
    rdfs:label 'Contact Id' ;
    rdfs:comment 'Unique surrogate identifier for the individual stakeholder contact record in the Databricks Silver Layer. Primary key for the contact data product.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Contact .

ind:mailingAddressId rdf:type rdf:Property ;
    rdfs:label 'Mailing Address Id' ;
    rdfs:comment 'Foreign key linking to client.address. Business justification: The contact table carries five denormalized mailing address fields (mailing_street, mailing_city, mailing_state, mailing_postal_code, mailing_country) that duplicate the address master table. The addr' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Address .

ind:reportsToContactId rdf:type rdf:Property ;
    rdfs:label 'Reports To Contact Id' ;
    rdfs:comment 'Self-referencing identifier pointing to the contact\'s direct manager or superior within the client organisation. Enables hierarchical stakeholder mapping and organisational chart modelling for large client accounts.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Contact .

ind:accountManager rdf:type rdf:Property ;
    rdfs:label 'Account Manager' ;
    rdfs:comment 'Full name of the internal account manager or business development representative responsible for managing the relationship with this contact. Used for ownership assignment and pipeline accountability in Salesforce CRM.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:birthdate rdf:type rdf:Property ;
    rdfs:label 'Birthdate' ;
    rdfs:comment 'Date of birth of the contact. Stored for relationship personalisation purposes (e.g., milestone acknowledgements) and identity verification in regulated markets. Handled under strict GDPR data minimisation principles.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:clientSegment rdf:type rdf:Property ;
    rdfs:label 'Client Segment' ;
    rdfs:comment 'Segment classification of the client organisation associated with this contact. Supports client segmentation analytics across public-sector, private-sector, Public-Private Partnership (PPP), Build-Operate-Transfer (BOT), and Joint Venture (JV) arrangements.' ;
    rdfs:domain ind:Client ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactStatus rdf:type rdf:Property ;
    rdfs:label 'Contact Status' ;
    rdfs:comment 'Current lifecycle status of the contact record within the CRM system. \'active\' indicates an engaged stakeholder; \'inactive\' indicates no recent engagement; \'archived\' indicates the contact has left the organisation; \'do_not_contact\' indicates a communication opt-out or legal restriction.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactType rdf:type rdf:Property ;
    rdfs:label 'Contact Type' ;
    rdfs:comment 'Classification of the contact\'s functional role in the client relationship (e.g., owner representative, technical representative, procurement officer, legal counsel, executive sponsor, financial approver). Drives stakeholder engagement strategy and communication routing. [ENUM-REF-CANDIDATE: owner|technical|procurement|legal|executive|financial|hse|commercial — promote to reference product]' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crmContactCode rdf:type rdf:Property ;
    rdfs:label 'Crm Contact Code' ;
    rdfs:comment 'External identifier for this contact as recorded in Salesforce CRM Contact object. Used for cross-system reconciliation and data lineage tracing back to the operational system of record.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataConsentDate rdf:type rdf:Property ;
    rdfs:label 'Data Consent Date' ;
    rdfs:comment 'Date on which the contact\'s data processing consent was last recorded or updated. Required for GDPR compliance audit trails to demonstrate lawful basis for processing personal data.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dataConsentStatus rdf:type rdf:Property ;
    rdfs:label 'Data Consent Status' ;
    rdfs:comment 'Current status of the contact\'s consent for personal data processing under applicable privacy regulations (GDPR, CCPA). Tracks whether consent has been granted, withdrawn, is pending confirmation, or is not required (e.g., legitimate interest basis).' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decisionAuthorityLevel rdf:type rdf:Property ;
    rdfs:label 'Decision Authority Level' ;
    rdfs:comment 'Indicates the contact\'s level of decision-making authority within the client organisation for construction project approvals, contract awards, and change order authorisations. Supports bid strategy and stakeholder influence mapping.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:department rdf:type rdf:Property ;
    rdfs:label 'Department' ;
    rdfs:comment 'Organisational department or business unit within the client organisation to which the contact belongs (e.g., Engineering, Procurement, Legal, Finance). Supports targeted stakeholder engagement and communication routing.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:email rdf:type rdf:Property ;
    rdfs:label 'Email' ;
    rdfs:comment 'Primary business email address of the contact used for official project correspondence, RFI responses, bid submissions, and CRM communication tracking. Sourced from Salesforce CRM.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emailOptOut rdf:type rdf:Property ;
    rdfs:label 'Email Opt Out' ;
    rdfs:comment 'Indicates whether the contact has opted out of email marketing communications specifically. Distinct from do_not_contact which covers all channels. Enforces GDPR consent management and CAN-SPAM compliance.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:firstName rdf:type rdf:Property ;
    rdfs:label 'First Name' ;
    rdfs:comment 'Given name of the individual stakeholder contact as recorded in Salesforce CRM. Used for personalised correspondence and formal communication in client relationship management.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fullName rdf:type rdf:Property ;
    rdfs:label 'Full Name' ;
    rdfs:comment 'Complete display name of the contact (e.g., salutation + first + last name) as stored in Salesforce CRM. Used in formal correspondence, bid submissions, and contract administration documents.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:influenceScore rdf:type rdf:Property ;
    rdfs:label 'Influence Score' ;
    rdfs:comment 'Numeric score (typically 1–10) representing the contact\'s level of influence over project award decisions, contract negotiations, and change order approvals. Used in bid strategy and stakeholder mapping for major infrastructure pursuits.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isDecisionMaker rdf:type rdf:Property ;
    rdfs:label 'Is Decision Maker' ;
    rdfs:comment 'Indicates whether this contact has final decision-making authority for contract awards, change orders (CO), or project approvals. Critical for bid management and opportunity pipeline qualification in Salesforce CRM.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isExecutiveSponsor rdf:type rdf:Property ;
    rdfs:label 'Is Executive Sponsor' ;
    rdfs:comment 'Indicates whether this contact holds the role of executive sponsor for the client relationship. Executive sponsors are senior client representatives who champion the construction partnership at the strategic level.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPrimaryContact rdf:type rdf:Property ;
    rdfs:label 'Is Primary Contact' ;
    rdfs:comment 'Indicates whether this contact is the designated primary point of contact for the client account. Only one contact per account should be flagged as primary. Used to route official correspondence and contract notifications.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jobTitle rdf:type rdf:Property ;
    rdfs:label 'Job Title' ;
    rdfs:comment 'Official job title or position of the contact within their organisation (e.g., Project Director, Procurement Manager, Chief Engineer). Used to identify the contact\'s functional role in client engagement and bid management.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastActivityDate rdf:type rdf:Property ;
    rdfs:label 'Last Activity Date' ;
    rdfs:comment 'Date of the most recent logged activity (call, email, meeting, site visit) with this contact in Salesforce CRM. Used to measure engagement recency and identify at-risk relationships in client retention analytics.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastMeetingDate rdf:type rdf:Property ;
    rdfs:label 'Last Meeting Date' ;
    rdfs:comment 'Date of the most recent in-person or virtual meeting held with this contact. Used by account managers to track face-to-face engagement frequency and support relationship health assessments.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastName rdf:type rdf:Property ;
    rdfs:label 'Last Name' ;
    rdfs:comment 'Family name or surname of the individual stakeholder contact. Combined with first_name to form the full display name used in client-facing communications and CRM reporting.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:linkedinUrl rdf:type rdf:Property ;
    rdfs:label 'Linkedin Url' ;
    rdfs:comment 'LinkedIn professional profile URL for the contact. Used by business development and account management teams for relationship intelligence, stakeholder research, and pre-bid engagement in Salesforce CRM.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mobilePhone rdf:type rdf:Property ;
    rdfs:label 'Mobile Phone' ;
    rdfs:comment 'Mobile or cell phone number for the contact. Used for urgent site communications, HSE notifications, and out-of-hours contact during critical project milestones.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notes rdf:type rdf:Property ;
    rdfs:label 'Notes' ;
    rdfs:comment 'Free-text field for account managers to record qualitative observations, relationship context, stakeholder preferences, and strategic notes about the contact. Supports informed client engagement and bid strategy preparation.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phone rdf:type rdf:Property ;
    rdfs:label 'Phone' ;
    rdfs:comment 'Primary business phone number for the contact, including country and area code. Used for direct communication during project execution, bid clarifications, and contract administration.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredCommunicationChannel rdf:type rdf:Property ;
    rdfs:label 'Preferred Communication Channel' ;
    rdfs:comment 'The contact\'s preferred method of communication for project correspondence, meeting invitations, and bid-related notifications. Sourced from Salesforce CRM and used to personalise outreach in opportunity pipeline management.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredLanguage rdf:type rdf:Property ;
    rdfs:label 'Preferred Language' ;
    rdfs:comment 'ISO 639-1 language code representing the contact\'s preferred language for written and verbal communication (e.g., \'en\', \'fr\', \'ar\', \'zh\'). Supports multilingual project environments common in global EPC and infrastructure projects.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipHealth rdf:type rdf:Property ;
    rdfs:label 'Relationship Health' ;
    rdfs:comment 'Qualitative assessment of the current health of the business relationship with this contact, as evaluated by the account manager or business development team. Used in CRM pipeline forecasting and client retention strategies.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salutation rdf:type rdf:Property ;
    rdfs:label 'Salutation' ;
    rdfs:comment 'Formal honorific or title prefix for the contact (e.g., Mr., Ms., Dr.) used in official correspondence, contract documents, and client communications.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:source rdf:type rdf:Property ;
    rdfs:label 'Source' ;
    rdfs:comment 'Origin channel through which this contact was acquired or first identified (e.g., CRM import, referral, industry conference, Request for Proposal (RFP) response, website enquiry, partner introduction). Supports lead source analytics in Salesforce CRM.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jvStructureId rdf:type rdf:Property ;
    rdfs:label 'Jv Structure Id' ;
    rdfs:comment 'Unique surrogate identifier for the Joint Venture (JV) structure record in the Databricks Silver Layer. Primary key for this entity.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:JvStructure .

ind:agreementId rdf:type rdf:Property ;
    rdfs:label 'Agreement Id' ;
    rdfs:comment 'Reference to the primary contract under which the JV is engaged. Links the JV structure to the contract administration domain for CO (Change Order), LD (Liquidated Damages), and EOT (Extension of Time) management.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Agreement .

ind:clientOpportunityId rdf:type rdf:Property ;
    rdfs:label 'Client Opportunity Id' ;
    rdfs:comment 'Identifier of the associated opportunity record in Salesforce CRM. Links the JV structure to the bid management and pipeline forecasting process, enabling traceability from opportunity to JV formation.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ClientOpportunity .

ind:constructionProjectId rdf:type rdf:Property ;
    rdfs:label 'Construction Project Id' ;
    rdfs:comment 'Reference to the primary construction project associated with this JV structure. Links the JV arrangement to the project entity for scheduling, cost control, and EVM (Earned Value Management) reporting.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ConstructionProject .

ind:tenderId rdf:type rdf:Property ;
    rdfs:label 'Tender Id' ;
    rdfs:comment 'Foreign key linking to bid.tender. Business justification: JV structures in construction are formed specifically to pursue a named tender. Linking jv_structure to the tender it was established for enables JV governance reporting, bid compliance tracking, and ' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Tender .

ind:aconexDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Aconex Document Reference' ;
    rdfs:comment 'Reference identifier for the JV agreement document as registered in the Aconex document management system. Enables direct traceability to the executed legal instrument and associated transmittals.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countryOfOperation rdf:type rdf:Property ;
    rdfs:label 'Country Of Operation' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the primary country where the JV\'s construction project is being executed. Used for regulatory compliance, HSE reporting, and geographic portfolio analysis.' ;
    rdfs:domain ind:JvStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeResolutionMechanism rdf:type rdf:Property ;
    rdfs:label 'Dispute Resolution Mechanism' ;
    rdfs:comment 'Contractually agreed mechanism for resolving disputes between JV partners. DAB refers to Dispute Adjudication Board as defined under FIDIC contracts. Drives legal strategy and contract administration.' ;
    rdfs:domain ind:Client ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dissolutionDate rdf:type rdf:Property ;
    rdfs:label 'Dissolution Date' ;
    rdfs:comment 'Calendar date on which the JV was or is scheduled to be dissolved and wound up. Null if the JV is ongoing. Used for financial reporting, DLP (Defects Liability Period) tracking, and regulatory compliance.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dlpEndDate rdf:type rdf:Property ;
    rdfs:label 'Dlp End Date' ;
    rdfs:comment 'Date on which the DLP (Defects Liability Period) for the JV\'s project obligations expires. After this date, the JV\'s liability for defects under the contract ceases. Critical for contract closeout and financial provisioning.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:formationDate rdf:type rdf:Property ;
    rdfs:label 'Formation Date' ;
    rdfs:comment 'Calendar date on which the JV was formally constituted and the JV agreement became effective. Marks the start of the JV\'s legal existence and is used for financial reporting under IFRS 11.' ;
    rdfs:domain ind:JvStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:governingLawCountry rdf:type rdf:Property ;
    rdfs:label 'Governing Law Country' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code representing the jurisdiction whose laws govern the JV agreement and dispute resolution. Critical for cross-border JV arrangements and PPP/BOT projects.' ;
    rdfs:domain ind:JvStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:governingLawJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Governing Law Jurisdiction' ;
    rdfs:comment 'Specific legal jurisdiction or state/province within the governing law country that applies to the JV agreement (e.g., \'New South Wales\', \'Dubai International Financial Centre\'). Supplements governing_law_country for sub-national jurisdictions.' ;
    rdfs:domain ind:JvStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isActive rdf:type rdf:Property ;
    rdfs:label 'Is Active' ;
    rdfs:comment 'Boolean flag indicating whether the JV structure record is currently active and operational. False indicates the JV has been dissolved, superseded, or administratively deactivated. Used for data filtering in reporting and CRM pipeline views.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isLeadSponsorInternal rdf:type rdf:Property ;
    rdfs:label 'Is Lead Sponsor Internal' ;
    rdfs:comment 'Boolean flag indicating whether the lead sponsor of the JV is an internal entity (i.e., Construction itself or one of its subsidiaries) as opposed to an external third-party organisation. Drives internal vs. external reporting segmentation.' ;
    rdfs:domain ind:JvStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jvAgreementReference rdf:type rdf:Property ;
    rdfs:label 'Jv Agreement Reference' ;
    rdfs:comment 'Document reference number or identifier for the executed JV agreement, as registered in Aconex document management or the contract administration system. Used to trace the legal instrument governing the JV.' ;
    rdfs:domain ind:JvStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jvManagerEmail rdf:type rdf:Property ;
    rdfs:label 'Jv Manager Email' ;
    rdfs:comment 'Business email address of the designated JV Manager. Used for official correspondence, notifications, and stakeholder communication management.' ;
    rdfs:domain ind:JvStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jvManagerName rdf:type rdf:Property ;
    rdfs:label 'Jv Manager Name' ;
    rdfs:comment 'Full name of the designated JV Manager or Managing Director responsible for day-to-day operations and governance of the JV. This is a role-level contact, not a personal identifier.' ;
    rdfs:domain ind:JvStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jvManagerPhone rdf:type rdf:Property ;
    rdfs:label 'Jv Manager Phone' ;
    rdfs:comment 'Business phone number of the designated JV Manager for direct contact. Used for urgent project communications and stakeholder engagement.' ;
    rdfs:domain ind:JvStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jvName rdf:type rdf:Property ;
    rdfs:label 'Jv Name' ;
    rdfs:comment 'Official registered or trading name of the Joint Venture entity as stated in the JV agreement and used in all project correspondence, bid submissions, and regulatory filings.' ;
    rdfs:domain ind:JvStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jvReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Jv Reference Number' ;
    rdfs:comment 'Externally-known unique business identifier assigned to the JV arrangement, used in contracts, correspondence, and regulatory filings. Sourced from Salesforce CRM or Aconex document management.' ;
    rdfs:domain ind:JvStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jvShortName rdf:type rdf:Property ;
    rdfs:label 'Jv Short Name' ;
    rdfs:comment 'Abbreviated or commonly used name for the JV, used in internal reporting, dashboards, and project management systems such as Oracle Primavera P6 and Procore.' ;
    rdfs:domain ind:JvStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jvStatus rdf:type rdf:Property ;
    rdfs:label 'Jv Status' ;
    rdfs:comment 'Current lifecycle status of the JV arrangement. \'formation\' indicates the JV is being constituted; \'pending\' indicates awaiting regulatory or client approval; \'active\' indicates fully operational; \'suspended\' indicates temporarily halted; \'dissolved\' indicates the JV has been wound up.' ;
    rdfs:domain ind:JvStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jvType rdf:type rdf:Property ;
    rdfs:label 'Jv Type' ;
    rdfs:comment 'Classification of the JV arrangement by delivery model or legal structure. PPP (Public-Private Partnership), BOT (Build-Operate-Transfer), Consortium, Incorporated JV, Unincorporated JV, or EPC (Engineering Procurement and Construction) joint venture. [ENUM-REF-CANDIDATE: PPP|BOT|Consortium|Incorporated|Unincorporated|EPC — promote to reference product if additional types are required]' ;
    rdfs:domain ind:JvStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leedCertificationTarget rdf:type rdf:Property ;
    rdfs:label 'Leed Certification Target' ;
    rdfs:comment 'Target LEED (Leadership in Energy and Environmental Design) certification level for the project associated with this JV. Used for sustainability reporting and client commitment tracking.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:liabilityStructure rdf:type rdf:Property ;
    rdfs:label 'Liability Structure' ;
    rdfs:comment 'Legal liability arrangement between JV partners as defined in the JV agreement. \'joint_and_several\' means each partner is fully liable; \'several_only\' means each partner is liable only for their share. Critical for risk management and contract administration.' ;
    rdfs:domain ind:JvStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:managementStructureType rdf:type rdf:Property ;
    rdfs:label 'Management Structure Type' ;
    rdfs:comment 'Type of governance and management structure adopted by the JV. \'board\' indicates a formal board of directors; \'management_committee\' indicates a joint committee; \'single_manager\' indicates one partner manages on behalf of all; \'co_management\' indicates shared management responsibilities.' ;
    rdfs:domain ind:JvStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ntpDate rdf:type rdf:Property ;
    rdfs:label 'Ntp Date' ;
    rdfs:comment 'Date on which the NTP (Notice to Proceed) was issued to the JV, authorising commencement of construction works. Marks the official start of the JV\'s contractual obligations and is used for schedule baseline management in Oracle Primavera P6.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:participantCount rdf:type rdf:Property ;
    rdfs:label 'Participant Count' ;
    rdfs:comment 'Total number of participating entities (partners or members) in the JV arrangement. Used for governance reporting and to validate completeness of the JV participant roster.' ;
    rdfs:domain ind:JvStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:profitSharingBasis rdf:type rdf:Property ;
    rdfs:label 'Profit Sharing Basis' ;
    rdfs:comment 'Basis on which profits and losses are distributed among JV participants. \'equity_proportional\' aligns P&L distribution with equity share percentages; \'negotiated\' indicates a bespoke arrangement defined in the JV agreement.' ;
    rdfs:domain ind:JvStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectSector rdf:type rdf:Property ;
    rdfs:label 'Project Sector' ;
    rdfs:comment 'Primary industry sector of the construction project(s) associated with this JV. Used for client segmentation, pipeline forecasting in Salesforce CRM, and portfolio analytics. [ENUM-REF-CANDIDATE: infrastructure|energy|commercial|residential|industrial|transport|water|healthcare|education — promote to reference product]' ;
    rdfs:domain ind:Client ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationCountry rdf:type rdf:Property ;
    rdfs:label 'Registration Country' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the country in which the JV entity is legally registered. May differ from the governing law country for cross-border projects.' ;
    rdfs:domain ind:JvStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystem rdf:type rdf:Property ;
    rdfs:label 'Source System' ;
    rdfs:comment 'Name of the operational system of record from which this JV structure record was sourced. Supports data lineage tracking and reconciliation across Salesforce CRM, Aconex, SAP S/4HANA, and Procore.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalCommittedCapital rdf:type rdf:Property ;
    rdfs:label 'Total Committed Capital' ;
    rdfs:comment 'Total capital committed by all JV participants as stated in the JV agreement, expressed in the JV\'s primary currency. Used for financial reporting, EBITDA analysis, and project cost control.' ;
    rdfs:domain ind:JvStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalEquityPct rdf:type rdf:Property ;
    rdfs:label 'Total Equity Pct' ;
    rdfs:comment 'Sum of all participating entities\' equity share percentages in the JV. Must equal 100.00% for a fully constituted JV. Used as a validation and audit control field.' ;
    rdfs:domain ind:JvStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:updatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Updated Timestamp' ;
    rdfs:comment 'Timestamp of the most recent update to the JV structure record, in ISO 8601 format (yyyy-MM-ddTHH:mm:ss.SSSXXX). Used for change tracking, data lineage, and incremental ETL processing in the Databricks Silver Layer.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:addressId rdf:type rdf:Property ;
    rdfs:label 'Address Id' ;
    rdfs:comment 'Unique surrogate identifier for each client address record in the Construction data platform. Serves as the primary key for the client_address entity.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:addressStatus rdf:type rdf:Property ;
    rdfs:label 'Address Status' ;
    rdfs:comment 'Current lifecycle status of the address record. Active indicates the address is in current use; inactive means it is no longer used; pending_validation awaits address verification; superseded means it has been replaced by a newer address; undeliverable indicates mail or correspondence has been returned.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressType rdf:type rdf:Property ;
    rdfs:label 'Address Type' ;
    rdfs:comment 'Classifies the functional purpose of the address. Registered office is the legal domicile; billing is used for invoice delivery; correspondence is the preferred mailing address; project_site_liaison is the on-site contact office for a specific project; head_office and branch_office denote organisational hierarchy locations. [ENUM-REF-CANDIDATE: registered_office|billing|correspondence|project_site_liaison|head_office|branch_office — promote to reference product]' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attentionTo rdf:type rdf:Property ;
    rdfs:label 'Attention To' ;
    rdfs:comment 'Name of the specific individual or department to whom correspondence should be directed at this address (e.g., \'Attn: Contracts Manager\' or \'Attn: Finance Department\'). Used in formal contract correspondence and RFI (Request for Information) transmittals.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:buildingName rdf:type rdf:Property ;
    rdfs:label 'Building Name' ;
    rdfs:comment 'Name of the building or complex at this address (e.g., \'Empire State Building\', \'One Canada Square\', \'Dubai World Trade Centre\'). Used for precise address identification in dense urban environments and for formal correspondence headers.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:city rdf:type rdf:Property ;
    rdfs:label 'City' ;
    rdfs:comment 'Name of the city, town, or municipality in which the address is located. Used for regional client segmentation, jurisdiction determination, and multi-city project coordination.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countryName rdf:type rdf:Property ;
    rdfs:label 'Country Name' ;
    rdfs:comment 'Full English name of the country corresponding to the country_code. Stored for display and reporting purposes to avoid repeated lookups against the ISO country reference table.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveFromDate rdf:type rdf:Property ;
    rdfs:label 'Effective From Date' ;
    rdfs:comment 'Date from which this address became or becomes effective for the client. Supports temporal address management, enabling historical address tracking for contract administration and legal notice purposes.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectiveToDate rdf:type rdf:Property ;
    rdfs:label 'Effective To Date' ;
    rdfs:comment 'Date on which this address ceases to be effective for the client. Null indicates the address is currently active with no planned end date. Used for temporal address history management and superseded address tracking.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:emailAddress rdf:type rdf:Property ;
    rdfs:label 'Email Address' ;
    rdfs:comment 'General email address associated with this address location (e.g., a departmental or office inbox). Used for electronic correspondence, transmittal delivery via Aconex, and formal notice under contract. Distinct from individual contact email addresses.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:faxNumber rdf:type rdf:Property ;
    rdfs:label 'Fax Number' ;
    rdfs:comment 'Fax number associated with this address location. Retained for clients and jurisdictions where fax remains a legally recognised method of formal notice delivery under FIDIC contract conditions.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:floorLevel rdf:type rdf:Property ;
    rdfs:label 'Floor Level' ;
    rdfs:comment 'Floor or level number within a building at this address (e.g., \'Level 12\', \'Ground Floor\', \'Basement 2\'). Used for precise delivery instructions and visitor access coordination for client site visits.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:formatType rdf:type rdf:Property ;
    rdfs:label 'Format Type' ;
    rdfs:comment 'Indicates the structural format of the address to support correct rendering and printing. Western follows street-city-state-postal conventions; eastern follows country-specific formats (e.g., Japan, China); po_box is a post office box address; free_form is an unstructured address entry.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isBillingAddress rdf:type rdf:Property ;
    rdfs:label 'Is Billing Address' ;
    rdfs:comment 'Indicates whether this address is designated as the billing address for invoice delivery and accounts receivable correspondence. Used by SAP S/4HANA AR (Accounts Receivable) module for invoice routing.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPrimary rdf:type rdf:Property ;
    rdfs:label 'Is Primary' ;
    rdfs:comment 'Indicates whether this address is the primary address for the client account. Only one address per client should be flagged as primary at any given time. Used to determine the default address for correspondence and contract documentation.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRegisteredOffice rdf:type rdf:Property ;
    rdfs:label 'Is Registered Office' ;
    rdfs:comment 'Indicates whether this address is the legally registered office address of the client entity. Required for contract execution, legal notices under FIDIC conditions, and regulatory compliance filings.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jurisdictionCode rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Code' ;
    rdfs:comment 'Legal and regulatory jurisdiction code applicable to this address, combining ISO 3166-1 country code and subdivision code (e.g., US-CA for California, AU-NSW for New South Wales). Used for tax jurisdiction mapping, OSHA/EPA regulatory compliance, and contract law determination.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:latitude rdf:type rdf:Property ;
    rdfs:label 'Latitude' ;
    rdfs:comment 'Geographic latitude coordinate of the address in decimal degrees (WGS 84 datum). Supports GIS (Geographic Information System) mapping, proximity analysis to active construction sites, and spatial analytics for project planning.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:line1 rdf:type rdf:Property ;
    rdfs:label 'Line 1' ;
    rdfs:comment 'Primary street address line including building number, street name, and suite or unit number. Represents the first line of the postal address as used in official correspondence and contract documentation.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:line2 rdf:type rdf:Property ;
    rdfs:label 'Line 2' ;
    rdfs:comment 'Secondary address line for additional location details such as floor number, building name, industrial estate, or campus identifier. Optional field used when the primary line is insufficient.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:line3 rdf:type rdf:Property ;
    rdfs:label 'Line 3' ;
    rdfs:comment 'Tertiary address line used for additional locality or district information, particularly relevant for international clients in regions where addresses require more than two street lines.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:longitude rdf:type rdf:Property ;
    rdfs:label 'Longitude' ;
    rdfs:comment 'Geographic longitude coordinate of the address in decimal degrees (WGS 84 datum). Used in conjunction with latitude for GIS (Geographic Information System) spatial analysis, site proximity calculations, and mapping of client office locations.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:phoneNumber rdf:type rdf:Property ;
    rdfs:label 'Phone Number' ;
    rdfs:comment 'Primary telephone number associated with this address location. Used for direct contact with the client office at this address for project coordination, site liaison, and contract administration purposes.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:poBoxNumber rdf:type rdf:Property ;
    rdfs:label 'Po Box Number' ;
    rdfs:comment 'Post Office (PO) Box number for clients who receive correspondence via a PO Box rather than a street address. Common for government agencies, public-sector clients, and clients in regions where PO Box delivery is standard.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postalCode rdf:type rdf:Property ;
    rdfs:label 'Postal Code' ;
    rdfs:comment 'Postal or ZIP code for the address. Used for mail routing, geographic clustering of clients, and regional analytics. Format varies by country (e.g., 5-digit US ZIP, alphanumeric UK postcode).' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredCorrespondenceLanguage rdf:type rdf:Property ;
    rdfs:label 'Preferred Correspondence Language' ;
    rdfs:comment 'ISO 639-1 or ISO 639-2 language code indicating the preferred language for correspondence sent to this address (e.g., \'en\' for English, \'fr\' for French, \'ar\' for Arabic). Supports multilingual client communication in international construction markets.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:region rdf:type rdf:Property ;
    rdfs:label 'Region' ;
    rdfs:comment 'Broad geographic region grouping for the address (e.g., North America, Middle East, Asia Pacific, Europe). Used for regional portfolio reporting, business development segmentation, and PMO (Project Management Office) territory alignment.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemAddressCode rdf:type rdf:Property ;
    rdfs:label 'Source System Address Code' ;
    rdfs:comment 'The native identifier of this address record in the originating operational system (e.g., Salesforce CRM Address ID, SAP S/4HANA partner address number). Used for data lineage, reconciliation, and cross-system deduplication.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stateProvince rdf:type rdf:Property ;
    rdfs:label 'State Province' ;
    rdfs:comment 'State, province, territory, or region within the country. Used for regulatory jurisdiction mapping, tax compliance, and regional reporting across multi-jurisdiction construction clients.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:suiteUnitNumber rdf:type rdf:Property ;
    rdfs:label 'Suite Unit Number' ;
    rdfs:comment 'Suite, unit, or office number within a building at this address. Provides the final level of address precision for multi-tenant buildings where multiple client offices may occupy the same floor.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxJurisdictionCode rdf:type rdf:Property ;
    rdfs:label 'Tax Jurisdiction Code' ;
    rdfs:comment 'Specific tax jurisdiction code for the address as used in SAP S/4HANA tax determination. May differ from the general jurisdiction code in federal/state/local tax overlay scenarios. Used for sales tax, VAT, and withholding tax calculations on client invoices.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timeZone rdf:type rdf:Property ;
    rdfs:label 'Time Zone' ;
    rdfs:comment 'IANA time zone identifier for the address location (e.g., America/New_York, Asia/Dubai, Australia/Sydney). Used for scheduling client communications, meeting coordination, and project milestone notifications across global construction operations.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationDate rdf:type rdf:Property ;
    rdfs:label 'Validation Date' ;
    rdfs:comment 'Date on which the address was last validated against a postal authority or address verification service. Used to schedule re-validation cycles and assess data quality freshness.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:validationSource rdf:type rdf:Property ;
    rdfs:label 'Validation Source' ;
    rdfs:comment 'Name of the service or system used to validate the address (e.g., USPS, Google Maps API, Loqate, SmartyStreets). Provides traceability for data quality audits and vendor management.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationStatus rdf:type rdf:Property ;
    rdfs:label 'Validation Status' ;
    rdfs:comment 'Result of the address validation process against a postal authority or third-party address verification service. Validated means the address has been confirmed as deliverable; not_validated means validation has not been attempted; failed means the address could not be verified; partial means only some components were verified.' ;
    rdfs:domain ind:Address ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bidOpportunityId rdf:type rdf:Property ;
    rdfs:label 'Bid Opportunity Id' ;
    rdfs:comment 'Foreign key linking to bid.bid_opportunity. Business justification: Required for Opportunity Alignment Report linking client opportunity to the corresponding bid opportunity to track win/loss and financial exposure.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BidOpportunity .

ind:actualAwardDate rdf:type rdf:Property ;
    rdfs:label 'Actual Award Date' ;
    rdfs:comment 'Date on which the contract was formally awarded. Populated upon win outcome. Used for win/loss analysis and BD cycle time measurement.' ;
    rdfs:domain ind:ClientOpportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:bidCostEstimate rdf:type rdf:Property ;
    rdfs:label 'Bid Cost Estimate' ;
    rdfs:comment 'Internal estimate of the cost to prepare and submit the bid (tendering cost), including estimating, engineering, and proposal resources. Used for bid cost tracking and ROI analysis on BD spend.' ;
    rdfs:domain ind:ClientOpportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bidNoBidDecision rdf:type rdf:Property ;
    rdfs:label 'Bid No Bid Decision' ;
    rdfs:comment 'Formal decision outcome from the bid/no-bid review process indicating whether the company will pursue this opportunity. Pending_review indicates the decision gate has not yet been completed.' ;
    rdfs:domain ind:ClientOpportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bidNoBidDecisionDate rdf:type rdf:Property ;
    rdfs:label 'Bid No Bid Decision Date' ;
    rdfs:comment 'Date on which the formal bid/no-bid decision was made and recorded. Used for governance audit trails and BD cycle time analysis.' ;
    rdfs:domain ind:ClientOpportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:bidSubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Bid Submission Date' ;
    rdfs:comment 'Actual or planned date on which the bid/tender/proposal was or is to be submitted to the client. Critical scheduling milestone for BD and estimating teams.' ;
    rdfs:domain ind:ClientOpportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:bimRequired rdf:type rdf:Property ;
    rdfs:label 'Bim Required' ;
    rdfs:comment 'Indicates whether the client mandates Building Information Modeling (BIM) as a project delivery requirement. True = BIM is contractually required. Drives technology and resource planning for the bid.' ;
    rdfs:domain ind:Client ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:boqAvailable rdf:type rdf:Property ;
    rdfs:label 'Boq Available' ;
    rdfs:comment 'Indicates whether a Bill of Quantities (BOQ) has been issued by the client as part of the tender package. True = BOQ provided; False = lump-sum or design-build without BOQ. Affects estimating approach and bid strategy.' ;
    rdfs:domain ind:ClientOpportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:clientOpportunityDescription rdf:type rdf:Property ;
    rdfs:label 'Client Opportunity Description' ;
    rdfs:comment 'Free-text narrative describing the scope, nature, and key characteristics of the construction opportunity. Provides context for BD team members reviewing the pipeline and supports AI/ML-based opportunity classification.' ;
    rdfs:domain ind:ClientOpportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competitorNames rdf:type rdf:Property ;
    rdfs:label 'Competitor Names' ;
    rdfs:comment 'Names of known competing firms bidding on the same opportunity. Free-text or comma-separated list. Confidential competitive intelligence used for bid strategy and market positioning analysis.' ;
    rdfs:domain ind:ClientOpportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryModel rdf:type rdf:Property ;
    rdfs:label 'Delivery Model' ;
    rdfs:comment 'Contract delivery model under which the construction project will be executed. EPC = Engineering Procurement and Construction; GMP = Guaranteed Maximum Price; DBB = Design-Bid-Build; DB = Design-Build; PPP = Public-Private Partnership; BOT = Build-Operate-Transfer; FIDIC = FIDIC-based contract. Drives risk allocation and commercial strategy. [ENUM-REF-CANDIDATE: EPC|GMP|DBB|DB|PPP|BOT|FIDIC — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:esgRequirements rdf:type rdf:Property ;
    rdfs:label 'Esg Requirements' ;
    rdfs:comment 'Description of any Environmental, Social, and Governance (ESG) requirements specified by the client for this opportunity (e.g., carbon targets, local content requirements, diversity commitments). Free-text field for BD qualification notes.' ;
    rdfs:domain ind:ClientOpportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedContractValue rdf:type rdf:Property ;
    rdfs:label 'Estimated Contract Value' ;
    rdfs:comment 'Estimated total contract value of the opportunity in the reporting currency. Used for pipeline forecasting, revenue planning, and bid/no-bid decision thresholds. Raw commercial estimate; not a committed figure.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:expectedAwardDate rdf:type rdf:Property ;
    rdfs:label 'Expected Award Date' ;
    rdfs:comment 'Anticipated date on which the contract is expected to be formally awarded to the company. Used for pipeline close-date forecasting and resource mobilization planning.' ;
    rdfs:domain ind:ClientOpportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:expectedNtpDate rdf:type rdf:Property ;
    rdfs:label 'Expected Ntp Date' ;
    rdfs:comment 'Anticipated date on which the client will issue the Notice to Proceed (NTP), authorizing the start of construction work. Used for resource planning and revenue recognition scheduling.' ;
    rdfs:domain ind:ClientOpportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isJvBid rdf:type rdf:Property ;
    rdfs:label 'Is Jv Bid' ;
    rdfs:comment 'Indicates whether this opportunity is being pursued as a Joint Venture (JV) arrangement. True = JV bid; False = sole-entity bid. Drives JV governance and risk review processes.' ;
    rdfs:domain ind:ClientOpportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jvPartnerNames rdf:type rdf:Property ;
    rdfs:label 'Jv Partner Names' ;
    rdfs:comment 'Names of Joint Venture (JV) partners with whom the company intends to bid on this opportunity. Relevant for JV-structured bids common in large infrastructure and EPC projects. Confidential commercial information.' ;
    rdfs:domain ind:ClientOpportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lossReason rdf:type rdf:Property ;
    rdfs:label 'Loss Reason' ;
    rdfs:comment 'Reason code or description explaining why the opportunity was lost or withdrawn (e.g., price, technical score, client relationship, competitor strength, scope mismatch). Populated when win_loss_outcome is \'lost\' or \'withdrawn\'. Used for BD lessons-learned and competitive intelligence. [ENUM-REF-CANDIDATE: price|technical_score|client_relationship|competitor_strength|scope_mismatch|capacity|no_bid_decision|other — promote to reference product]' ;
    rdfs:domain ind:ClientOpportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextAction rdf:type rdf:Property ;
    rdfs:label 'Next Action' ;
    rdfs:comment 'Description of the next planned business development action required to advance this opportunity (e.g., \'Submit EOI by 15-Mar\', \'Attend client briefing\', \'Complete bid/no-bid review\'). Operational field used by BD team for pipeline management.' ;
    rdfs:domain ind:ClientOpportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextActionDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Action Due Date' ;
    rdfs:comment 'Target date by which the next business development action must be completed. Used for BD pipeline hygiene, follow-up scheduling, and opportunity stagnation alerts.' ;
    rdfs:domain ind:ClientOpportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:opportunityName rdf:type rdf:Property ;
    rdfs:label 'Opportunity Name' ;
    rdfs:comment 'Descriptive name of the construction opportunity, typically including the project name and client name (e.g., \'Greenfield Highway Extension – ADOT\'). Used for identification in pipeline reports and BD dashboards.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:opportunityNumber rdf:type rdf:Property ;
    rdfs:label 'Opportunity Number' ;
    rdfs:comment 'Externally-known unique alphanumeric identifier for the opportunity as assigned in Salesforce CRM. Used for cross-system reference and client-facing communications.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:opportunityStatus rdf:type rdf:Property ;
    rdfs:label 'Opportunity Status' ;
    rdfs:comment 'Lifecycle status of the opportunity record indicating whether it is actively pursued, won, lost, on hold, or cancelled. Distinct from pipeline_stage which tracks the BD workflow step.' ;
    rdfs:domain ind:ClientOpportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pipelineStage rdf:type rdf:Property ;
    rdfs:label 'Pipeline Stage' ;
    rdfs:comment 'Current stage of the opportunity in the business development pipeline. Drives pipeline forecasting and BD reporting. [ENUM-REF-CANDIDATE: prospect|qualification|bid_preparation|submitted|negotiation|awarded|lost|no_bid — promote to reference product]' ;
    rdfs:domain ind:ClientOpportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:probabilityOfWinPct rdf:type rdf:Property ;
    rdfs:label 'Probability Of Win Pct' ;
    rdfs:comment 'Estimated probability (0–100%) that the company will be awarded this contract. Used to calculate weighted pipeline value for revenue forecasting. Assigned by the BD owner and reviewed at stage gates.' ;
    rdfs:domain ind:ClientOpportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:projectDurationMonths rdf:type rdf:Property ;
    rdfs:label 'Project Duration Months' ;
    rdfs:comment 'Estimated duration of the construction project in months from NTP to practical completion. Used for resource planning, revenue phasing, and schedule risk assessment.' ;
    rdfs:domain ind:ClientOpportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:projectLocationCountry rdf:type rdf:Property ;
    rdfs:label 'Project Location Country' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code for the country where the construction project will be executed (e.g., USA, ARE, GBR). Used for geographic pipeline analysis and regulatory compliance scoping.' ;
    rdfs:domain ind:ClientOpportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectLocationRegion rdf:type rdf:Property ;
    rdfs:label 'Project Location Region' ;
    rdfs:comment 'State, province, or region where the construction project will be executed. Used for regional pipeline reporting, resource planning, and jurisdictional compliance (e.g., OSHA state plans, local building codes).' ;
    rdfs:domain ind:ClientOpportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectType rdf:type rdf:Property ;
    rdfs:label 'Project Type' ;
    rdfs:comment 'Classification of the construction project type (e.g., highway, airport, bridge, power plant, residential, commercial, industrial). Used for market segmentation and capability matching. [ENUM-REF-CANDIDATE: highway|airport|bridge|power_plant|residential|commercial|industrial|water_treatment|rail|data_center — promote to reference product]' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rfpIssueDate rdf:type rdf:Property ;
    rdfs:label 'Rfp Issue Date' ;
    rdfs:comment 'Date on which the client issued the Request for Proposal (RFP) or Invitation to Tender (ITT). Marks the formal start of the bid preparation phase.' ;
    rdfs:domain ind:ClientOpportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rfqNumber rdf:type rdf:Property ;
    rdfs:label 'Rfq Number' ;
    rdfs:comment 'Client-issued Request for Quotation (RFQ) or Request for Proposal (RFP) reference number. Used for cross-referencing with client procurement documents and Aconex correspondence.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sector rdf:type rdf:Property ;
    rdfs:label 'Sector' ;
    rdfs:comment 'Sector classification of the client commissioning the work: public-sector (government/municipal), private-sector (developer/corporate), or PPP/BOT (public-private partnership or build-operate-transfer arrangement). Used for client segmentation and reporting.' ;
    rdfs:domain ind:Client ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceCrmOpportunityCode rdf:type rdf:Property ;
    rdfs:label 'Source Crm Opportunity Code' ;
    rdfs:comment 'Original opportunity identifier from the Salesforce CRM system of record. Used for data lineage, cross-system reconciliation, and traceability back to the operational source.' ;
    rdfs:domain ind:ClientOpportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strategicPriority rdf:type rdf:Property ;
    rdfs:label 'Strategic Priority' ;
    rdfs:comment 'Internal strategic priority classification assigned to this opportunity by BD leadership. Tier 1 = highest strategic importance (must-win); Tier 2 = important but not critical; Tier 3 = opportunistic. Drives resource allocation for bid preparation.' ;
    rdfs:domain ind:ClientOpportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:weightedPipelineValue rdf:type rdf:Property ;
    rdfs:label 'Weighted Pipeline Value' ;
    rdfs:comment 'Estimated contract value multiplied by the probability of win percentage, representing the risk-adjusted contribution of this opportunity to the revenue forecast. Key metric for executive pipeline reporting.' ;
    rdfs:domain ind:ClientOpportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:winLossOutcome rdf:type rdf:Property ;
    rdfs:label 'Win Loss Outcome' ;
    rdfs:comment 'Final outcome of the opportunity after the bid process concludes. Won = contract awarded to company; Lost = awarded to competitor; Withdrawn = company withdrew bid; No_award = client cancelled procurement. Drives win rate analytics and BD performance reporting.' ;
    rdfs:domain ind:ClientOpportunity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectEngagementId rdf:type rdf:Property ;
    rdfs:label 'Project Engagement Id' ;
    rdfs:comment 'Unique surrogate identifier for the client project engagement record. Primary key for this bridge entity linking a client account to a specific construction project.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProjectEngagement .

ind:frameworkAgreementId rdf:type rdf:Property ;
    rdfs:label 'Framework Agreement Id' ;
    rdfs:comment 'Foreign key linking to client.client_framework_agreement. Business justification: Project engagements in construction are frequently executed as call-offs under a framework agreement or MSA. Linking project_engagement directly to client_framework_agreement enables reporting on fram' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FrameworkAgreement .

ind:rfpIssuanceId rdf:type rdf:Property ;
    rdfs:label 'Rfp Issuance Id' ;
    rdfs:comment 'Foreign key linking to client.rfp_issuance. Business justification: A project engagement (the awarded contract relationship) originates from an RFP/ITT issuance. Linking project_engagement to rfp_issuance closes the BD pipeline loop: opportunity → RFP issuance → proje' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RfpIssuance .

ind:advancePaymentAmount rdf:type rdf:Property ;
    rdfs:label 'Advance Payment Amount' ;
    rdfs:comment 'The value of any advance payment made by the client to the contractor at the commencement of this engagement, typically secured by an advance payment guarantee. Expressed in the contract currency.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvedVariationValue rdf:type rdf:Property ;
    rdfs:label 'Approved Variation Value' ;
    rdfs:comment 'The cumulative value of all approved Change Orders (CO) / variations issued by the client on this engagement to date. Reflects the net adjustment to the original contract value due to scope changes.' ;
    rdfs:domain ind:ProjectEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bidReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Bid Reference Number' ;
    rdfs:comment 'The reference number assigned to the original bid or tender submission (RFP/RFQ response) that led to this engagement being awarded. Links the engagement back to the opportunity pipeline in the CRM.' ;
    rdfs:domain ind:ProjectEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clientRole rdf:type rdf:Property ;
    rdfs:label 'Client Role' ;
    rdfs:comment 'The functional role the client plays in this project engagement. Distinguishes between the primary owner, co-sponsor in a joint venture (JV), lead JV partner, funding agency (e.g., government body), end-user of the completed asset, or developer. [ENUM-REF-CANDIDATE: owner|co_sponsor|jv_lead|funding_agency|end_user|developer|ppp_authority|bot_concessionaire — promote to reference product if additional roles are needed]' ;
    rdfs:domain ind:ProjectEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:communicationPreference rdf:type rdf:Property ;
    rdfs:label 'Communication Preference' ;
    rdfs:comment 'The client\'s preferred channel for formal project communications and correspondence on this engagement. Determines how RFIs, submittals, transmittals, and official notices are delivered.' ;
    rdfs:domain ind:ProjectEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractCurrency rdf:type rdf:Property ;
    rdfs:label 'Contract Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the contract value and financial commitments in this engagement (e.g., USD, EUR, GBP, AED). Required for multi-currency project reporting and IFRS/GAAP compliance.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Contract Reference Number' ;
    rdfs:comment 'The externally-known contract number or agreement reference assigned to the governing contract for this engagement. Used for cross-referencing with contract administration systems and client correspondence.' ;
    rdfs:domain ind:ProjectEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractValue rdf:type rdf:Property ;
    rdfs:label 'Contract Value' ;
    rdfs:comment 'The total awarded contract value for this client-project engagement as agreed at contract execution. Represents the baseline financial commitment from the client. Expressed in the contract currency.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:disputeStatus rdf:type rdf:Property ;
    rdfs:label 'Dispute Status' ;
    rdfs:comment 'Current status of any formal contractual dispute between the client and the contractor on this engagement. Tracks the dispute resolution lifecycle from initial notice through negotiation, adjudication, or arbitration to resolution.' ;
    rdfs:domain ind:ProjectEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engagementEndDate rdf:type rdf:Property ;
    rdfs:label 'Engagement End Date' ;
    rdfs:comment 'The date on which the client\'s formal involvement in the project is expected to conclude or has concluded. Typically aligned with project handover, Defects Liability Period (DLP) expiry, or BOT concession end date. Nullable for open-ended engagements.' ;
    rdfs:domain ind:ProjectEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:engagementNotes rdf:type rdf:Property ;
    rdfs:label 'Engagement Notes' ;
    rdfs:comment 'Free-text field for capturing qualitative notes, special conditions, or contextual information relevant to this client-project engagement that are not captured in structured fields. Used by account managers and project directors.' ;
    rdfs:domain ind:ProjectEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engagementReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Engagement Reference Number' ;
    rdfs:comment 'Externally-known alphanumeric reference code assigned to this client-project engagement. Used in correspondence, transmittals, and CRM tracking to uniquely identify the engagement across systems.' ;
    rdfs:domain ind:ProjectEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engagementStartDate rdf:type rdf:Property ;
    rdfs:label 'Engagement Start Date' ;
    rdfs:comment 'The date on which the client\'s formal involvement in the project commenced. Typically aligned with the Notice to Proceed (NTP) date or the contract execution date.' ;
    rdfs:domain ind:ProjectEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:engagementStatus rdf:type rdf:Property ;
    rdfs:label 'Engagement Status' ;
    rdfs:comment 'Current lifecycle state of the client-project engagement. Tracks whether the engagement is actively ongoing, pending formal commencement (awaiting NTP), on hold, completed at project handover, terminated early, or cancelled prior to commencement.' ;
    rdfs:domain ind:ProjectEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engagementType rdf:type rdf:Property ;
    rdfs:label 'Engagement Type' ;
    rdfs:comment 'Classification of the contractual or commercial arrangement type governing this engagement. Reflects the delivery model: EPC (Engineering Procurement and Construction), Design-Build (DB), Design-Bid-Build (DBB), Public-Private Partnership (PPP), Build-Operate-Transfer (BOT), Guaranteed Maximum Price (GMP), framework agreement, or direct award. [ENUM-REF-CANDIDATE: epc|design_build|design_bid_build|ppp|bot|gmp|framework|direct_award — promote to reference product]' ;
    rdfs:domain ind:ProjectEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eotDaysGranted rdf:type rdf:Property ;
    rdfs:label 'Eot Days Granted' ;
    rdfs:comment 'The total number of calendar days of Extension of Time (EOT) formally granted by the client to the contractor on this engagement to date. Adjusts the contractual completion date and affects LD exposure.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fundingSource rdf:type rdf:Property ;
    rdfs:label 'Funding Source' ;
    rdfs:comment 'Classification of the primary funding mechanism used by the client to finance this project engagement. Supports financial risk assessment and reporting. [ENUM-REF-CANDIDATE: government_grant|private_equity|bank_loan|bond_issuance|multilateral|internal_budget|mixed|ppp_concession — promote to reference product]' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:handoverDate rdf:type rdf:Property ;
    rdfs:label 'Handover Date' ;
    rdfs:comment 'The actual or planned date on which the completed project asset was or is expected to be handed over to the client. Marks the transition from construction to the Defects Liability Period (DLP) or Operations and Maintenance (O&M) phase.' ;
    rdfs:domain ind:ProjectEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:hseRequirementsClassification rdf:type rdf:Property ;
    rdfs:label 'Hse Requirements Classification' ;
    rdfs:comment 'Classification of the HSE (Health, Safety and Environment) requirements imposed by the client for this engagement. Reflects the risk profile and regulatory environment: standard (baseline OSHA/ISO 45001), enhanced (client-specific elevated requirements), or critical (high-hazard environments such as nuclear, offshore, or major infrastructure).' ;
    rdfs:domain ind:ProjectEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceComplianceVerified rdf:type rdf:Property ;
    rdfs:label 'Insurance Compliance Verified' ;
    rdfs:comment 'Indicates whether the contractor\'s required insurance policies (e.g., professional indemnity, public liability, contractor\'s all-risk) have been verified as compliant with the client\'s contractual requirements for this engagement.' ;
    rdfs:domain ind:ProjectEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jvParticipationPercentage rdf:type rdf:Property ;
    rdfs:label 'Jv Participation Percentage' ;
    rdfs:comment 'The client\'s ownership or participation share percentage in a Joint Venture (JV) arrangement for this project. Applicable when the client role is co-sponsor or JV lead. Null for sole-owner engagements.' ;
    rdfs:domain ind:ProjectEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Updated Timestamp' ;
    rdfs:comment 'The timestamp at which this client-project engagement record was most recently modified. Supports change tracking, data freshness monitoring, and incremental data pipeline processing in the Databricks Silver layer.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:liquidatedDamagesRate rdf:type rdf:Property ;
    rdfs:label 'Liquidated Damages Rate' ;
    rdfs:comment 'The contractually agreed daily or weekly Liquidated Damages (LD) rate payable by the contractor to the client in the event of project delay beyond the agreed completion date. Expressed in the contract currency per day.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:performanceBondRequired rdf:type rdf:Property ;
    rdfs:label 'Performance Bond Required' ;
    rdfs:comment 'Indicates whether the client has required the contractor to provide a performance bond as a financial security instrument for this engagement. Affects contract financial structuring and risk management.' ;
    rdfs:domain ind:Client ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:procurementMethod rdf:type rdf:Property ;
    rdfs:label 'Procurement Method' ;
    rdfs:comment 'The procurement route used by the client to award this engagement. Indicates whether the contract was awarded through open tender, selective tender, direct negotiation, Request for Proposal (RFP), Request for Quotation (RFQ), or a framework call-off.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipTier rdf:type rdf:Property ;
    rdfs:label 'Relationship Tier' ;
    rdfs:comment 'Segmentation tier assigned to this client engagement based on strategic importance, revenue contribution, and long-term relationship value. Drives account management priority and resource allocation.' ;
    rdfs:domain ind:ProjectEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:repeatClient rdf:type rdf:Property ;
    rdfs:label 'Repeat Client' ;
    rdfs:comment 'Indicates whether this client has previously engaged the construction company on one or more prior projects. Supports client relationship analytics, win-rate reporting, and strategic account management.' ;
    rdfs:domain ind:ProjectEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reportingFrequency rdf:type rdf:Property ;
    rdfs:label 'Reporting Frequency' ;
    rdfs:comment 'The agreed frequency at which formal project progress reports are submitted to the client for this engagement. Governs the reporting cadence for schedule, cost, and HSE performance updates.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retentionPercentage rdf:type rdf:Property ;
    rdfs:label 'Retention Percentage' ;
    rdfs:comment 'The contractually agreed retention percentage withheld by the client from each progress payment as a performance security. Typically released in two tranches: at practical completion and at DLP expiry.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:satisfactionScore rdf:type rdf:Property ;
    rdfs:label 'Satisfaction Score' ;
    rdfs:comment 'Numeric score representing the client\'s satisfaction with the construction company\'s performance on this engagement, typically captured through formal client satisfaction surveys. Scored on a standardized scale (e.g., 1.00–5.00 or 0.00–10.00).' ;
    rdfs:domain ind:ProjectEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:satisfactionSurveyDate rdf:type rdf:Property ;
    rdfs:label 'Satisfaction Survey Date' ;
    rdfs:comment 'The date on which the most recent client satisfaction survey was conducted for this engagement. Used to track the currency of satisfaction data and schedule follow-up surveys.' ;
    rdfs:domain ind:ProjectEngagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:clientAccountId rdf:type rdf:Property ;
    rdfs:label 'Client Account Id' ;
    rdfs:comment 'Reference to the client/owner account that issued this solicitation. Links to the master client account record in the CRM. Sourced from Salesforce CRM Account Management.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Account .

ind:addendumCount rdf:type rdf:Property ;
    rdfs:label 'Addendum Count' ;
    rdfs:comment 'The total number of addenda (amendments) issued by the client against this RFP since original issuance. Each addendum modifies the original RFP terms, scope, or schedule. Used to track document version history.' ;
    rdfs:domain ind:RfpIssuance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:anticipatedAwardDate rdf:type rdf:Property ;
    rdfs:label 'Anticipated Award Date' ;
    rdfs:comment 'The client\'s indicative target date for issuing the Notice to Proceed (NTP) or contract award, as stated in the RFP. Used for resource planning, bid team scheduling, and pipeline forecasting in Salesforce CRM.' ;
    rdfs:domain ind:RfpIssuance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:anticipatedCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Anticipated Completion Date' ;
    rdfs:comment 'The client\'s required or indicative project completion date as stated in the RFP. Defines the overall programme duration and is a key input to CPM (Critical Path Method) scheduling and resource planning.' ;
    rdfs:domain ind:RfpIssuance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:anticipatedStartDate rdf:type rdf:Property ;
    rdfs:label 'Anticipated Start Date' ;
    rdfs:comment 'The client\'s indicative target date for project commencement (Notice to Proceed / NTP) as stated in the RFP. Used for resource mobilisation planning and schedule baseline development in Oracle Primavera P6.' ;
    rdfs:domain ind:RfpIssuance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:bidBondPercentage rdf:type rdf:Property ;
    rdfs:label 'Bid Bond Percentage' ;
    rdfs:comment 'The bid bond (tender guarantee) value expressed as a percentage of the estimated contract value, as required by the client in the RFP. Typically ranges from 1% to 5% of contract value. Null if bid bond is not required.' ;
    rdfs:domain ind:RfpIssuance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bidBondRequired rdf:type rdf:Property ;
    rdfs:label 'Bid Bond Required' ;
    rdfs:comment 'Indicates whether the client requires a bid bond (tender guarantee) to be submitted with the proposal (True) or not (False). Bid bonds protect the client against bidder withdrawal after award.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:bidValidityDays rdf:type rdf:Property ;
    rdfs:label 'Bid Validity Days' ;
    rdfs:comment 'The number of calendar days from the submission deadline during which the bidder\'s proposal must remain valid and binding, as specified in the RFP. Typically 60 to 180 days. Impacts financial exposure and resource commitment.' ;
    rdfs:domain ind:RfpIssuance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bimLevel rdf:type rdf:Property ;
    rdfs:label 'Bim Level' ;
    rdfs:comment 'The BIM maturity level required by the client in the RFP: level_1 (CAD-based), level_2 (collaborative BIM with federated models), or level_3 (fully integrated open BIM). Null if BIM is not required.' ;
    rdfs:domain ind:RfpIssuance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clientSector rdf:type rdf:Property ;
    rdfs:label 'Client Sector' ;
    rdfs:comment 'Classification of the client/owner by sector: public (government/public authority), private (private developer/corporation), ppp (Public-Private Partnership arrangement), or jv (Joint Venture client entity). Drives compliance, reporting, and bid strategy.' ;
    rdfs:domain ind:RfpIssuance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commercialScoreWeight rdf:type rdf:Property ;
    rdfs:label 'Commercial Score Weight' ;
    rdfs:comment 'The percentage weighting assigned to the commercial/price component of the bid evaluation, as specified in the RFP (e.g., 40.00 for 40%). Combined with technical_score_weight to total 100%. Null for quality-only evaluations.' ;
    rdfs:domain ind:RfpIssuance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contractType rdf:type rdf:Property ;
    rdfs:label 'Contract Type' ;
    rdfs:comment 'The pricing and risk-sharing mechanism for the contract as specified in the RFP: lump_sum (fixed price), unit_rate (BOQ-based), cost_plus (reimbursable), target_cost (incentivised), or framework (call-off arrangement). Directly influences bid strategy and cost estimation.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defectsLiabilityPeriodDays rdf:type rdf:Property ;
    rdfs:label 'Defects Liability Period Days' ;
    rdfs:comment 'The duration of the Defects Liability Period (DLP) in calendar days as specified in the RFP, commencing from the date of practical completion. Typically 365 or 730 days. Impacts warranty provisioning and post-completion resource planning.' ;
    rdfs:domain ind:RfpIssuance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:evaluationCriteria rdf:type rdf:Property ;
    rdfs:label 'Evaluation Criteria' ;
    rdfs:comment 'The overall evaluation methodology specified in the RFP for assessing and ranking bids: price_only (lowest price wins), price_quality (weighted price and technical), quality_only (technical merit), best_value (whole-life cost), or pass_fail (compliance-based). Drives bid strategy.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issueDate rdf:type rdf:Property ;
    rdfs:label 'Issue Date' ;
    rdfs:comment 'The date on which the RFP/RFQ/ITT was formally issued and released to prospective bidders by the client. Represents the principal business event date for this solicitation record.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:issuedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Issued Timestamp' ;
    rdfs:comment 'The system timestamp when this RFP issuance record was first created in the data platform. Represents the audit creation time, distinct from the business issue_date. Used for data lineage and audit trail.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:latestAddendumDate rdf:type rdf:Property ;
    rdfs:label 'Latest Addendum Date' ;
    rdfs:comment 'The date of the most recent addendum issued by the client against this RFP. Null if no addenda have been issued. Used to ensure bidders are working from the latest version of the solicitation document.' ;
    rdfs:domain ind:RfpIssuance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:leedCertificationLevel rdf:type rdf:Property ;
    rdfs:label 'Leed Certification Level' ;
    rdfs:comment 'The minimum LEED certification level required by the client as stated in the RFP: certified, silver, gold, or platinum. Null if LEED certification is not required.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:liquidatedDamagesApplicable rdf:type rdf:Property ;
    rdfs:label 'Liquidated Damages Applicable' ;
    rdfs:comment 'Indicates whether the RFP specifies that Liquidated Damages (LD) will apply for delays or non-performance (True) or not (False). LD clauses are a key risk factor in bid pricing and schedule planning.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:localContentRequirementPct rdf:type rdf:Property ;
    rdfs:label 'Local Content Requirement Pct' ;
    rdfs:comment 'Minimum percentage of local workforce, materials, or subcontractors required by the client as specified in the RFP. Common in public-sector and government-funded projects. Impacts procurement and subcontractor strategy.' ;
    rdfs:domain ind:RfpIssuance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:performanceBondPercentage rdf:type rdf:Property ;
    rdfs:label 'Performance Bond Percentage' ;
    rdfs:comment 'The performance bond value expressed as a percentage of the contract value, as specified in the RFP. Typically ranges from 5% to 10% of contract value. Null if performance bond is not required.' ;
    rdfs:domain ind:RfpIssuance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:preBidMeetingDate rdf:type rdf:Property ;
    rdfs:label 'Pre Bid Meeting Date' ;
    rdfs:comment 'Scheduled date and time of the mandatory or optional pre-bid conference/site visit where the client clarifies scope and answers bidder questions. Attendance may be a prerequisite for bid eligibility.' ;
    rdfs:domain ind:RfpIssuance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:preBidMeetingMandatory rdf:type rdf:Property ;
    rdfs:label 'Pre Bid Meeting Mandatory' ;
    rdfs:comment 'Indicates whether attendance at the pre-bid meeting is mandatory for bid eligibility (True) or optional (False). Mandatory attendance is a common client requirement for complex infrastructure projects.' ;
    rdfs:domain ind:RfpIssuance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:projectDescription rdf:type rdf:Property ;
    rdfs:label 'Project Description' ;
    rdfs:comment 'Detailed narrative description of the project scope, works, and deliverables as outlined in the RFP. Includes key scope elements such as civil works, MEP systems, infrastructure type, and geographic extent.' ;
    rdfs:domain ind:RfpIssuance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectLocation rdf:type rdf:Property ;
    rdfs:label 'Project Location' ;
    rdfs:comment 'Geographic location or address of the proposed project site as stated in the RFP. Used for site visit planning, logistics assessment, and regional market analysis.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectTitle rdf:type rdf:Property ;
    rdfs:label 'Project Title' ;
    rdfs:comment 'The official name or title of the project as stated in the RFP document. Provides the primary human-readable description of the work being solicited (e.g., \'Highway 45 Expansion Phase 2\', \'Airport Terminal C Construction\').' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rfpDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Rfp Document Reference' ;
    rdfs:comment 'The document control reference number or URL/path to the official RFP package in the document management system (Aconex or Autodesk BIM 360). Enables direct retrieval of the source solicitation document.' ;
    rdfs:domain ind:RfpIssuance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rfpNumber rdf:type rdf:Property ;
    rdfs:label 'Rfp Number' ;
    rdfs:comment 'Externally-known reference number assigned by the client to uniquely identify this solicitation document (RFP, RFQ, or ITT). Used in all correspondence and bid submissions. Sourced from Salesforce CRM Bid Management or Aconex Document Management.' ;
    rdfs:domain ind:RfpIssuance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rfpStatus rdf:type rdf:Property ;
    rdfs:label 'Rfp Status' ;
    rdfs:comment 'Current lifecycle status of the RFP issuance: draft (being prepared), issued (released to market), amended (addendum issued), closed (submission deadline passed), cancelled (withdrawn by client), or awarded (contract awarded). Drives workflow and reporting.' ;
    rdfs:domain ind:RfpIssuance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:solicitationType rdf:type rdf:Property ;
    rdfs:label 'Solicitation Type' ;
    rdfs:comment 'Classification of the solicitation document type: RFP (Request for Proposal), RFQ (Request for Quotation), ITT (Invitation to Tender), EOI (Expression of Interest), or RFI (Request for Information). Determines the formality and evaluation process applied.' ;
    rdfs:domain ind:RfpIssuance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionDeadline rdf:type rdf:Property ;
    rdfs:label 'Submission Deadline' ;
    rdfs:comment 'The exact date and time by which all bid/proposal submissions must be received by the client. Late submissions are typically disqualified. Critical for bid planning and scheduling in Oracle Primavera P6.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technicalScoreWeight rdf:type rdf:Property ;
    rdfs:label 'Technical Score Weight' ;
    rdfs:comment 'The percentage weighting assigned to the technical/quality component of the bid evaluation, as specified in the RFP (e.g., 60.00 for 60%). Combined with commercial_score_weight to total 100%. Null for price-only evaluations.' ;
    rdfs:domain ind:RfpIssuance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:accountCreditProfileId rdf:type rdf:Property ;
    rdfs:label 'Account Credit Profile Id' ;
    rdfs:comment 'Unique surrogate identifier for the account credit profile record in the Databricks Silver Layer. Primary key for this entity.' ;
    rdfs:domain ind:AccountCreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approvedPaymentTerms rdf:type rdf:Property ;
    rdfs:label 'Approved Payment Terms' ;
    rdfs:comment 'Contractually approved payment terms for this client account, governing the number of days within which invoices must be settled or the basis on which payments are triggered. Milestone-based and retention-release terms are common in EPC and FIDIC contracts. [ENUM-REF-CANDIDATE: net_30|net_45|net_60|net_90|milestone_based|retention_release|advance_payment|progress_claim — promote to reference product]' ;
    rdfs:domain ind:AccountCreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bdRelationshipContext rdf:type rdf:Property ;
    rdfs:label 'Bd Relationship Context' ;
    rdfs:comment 'Business Development (BD) team\'s qualitative assessment of the strategic importance and relationship health of this client account, used as input to the internal credit scoring process. Strategic key accounts may receive more favourable credit terms.' ;
    rdfs:domain ind:AccountCreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditApprovedDate rdf:type rdf:Property ;
    rdfs:label 'Credit Approved Date' ;
    rdfs:comment 'Date on which the current credit limit and payment terms were formally approved by the authorised finance approver.' ;
    rdfs:domain ind:AccountCreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:creditHoldDate rdf:type rdf:Property ;
    rdfs:label 'Credit Hold Date' ;
    rdfs:comment 'Date on which the credit hold was applied to this client account. Null if no credit hold is currently active.' ;
    rdfs:domain ind:AccountCreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:creditHoldFlag rdf:type rdf:Property ;
    rdfs:label 'Credit Hold Flag' ;
    rdfs:comment 'Indicates whether this client account is currently placed on credit hold, blocking the issuance of new contracts, purchase orders, or progress claims until the hold is resolved. True = credit hold active; False = normal trading.' ;
    rdfs:domain ind:AccountCreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:creditHoldReason rdf:type rdf:Property ;
    rdfs:label 'Credit Hold Reason' ;
    rdfs:comment 'Reason code explaining why the credit hold was applied to this client account. Populated only when credit_hold_flag is True. Supports root-cause analysis and escalation workflows.' ;
    rdfs:domain ind:AccountCreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditInsuranceFlag rdf:type rdf:Property ;
    rdfs:label 'Credit Insurance Flag' ;
    rdfs:comment 'Indicates whether trade credit insurance has been obtained to cover the financial exposure to this client account. True = credit insurance in place; False = no credit insurance.' ;
    rdfs:domain ind:AccountCreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:creditInsuranceLimitAmount rdf:type rdf:Property ;
    rdfs:label 'Credit Insurance Limit Amount' ;
    rdfs:comment 'Maximum insured amount covered by the trade credit insurance policy for this client account. Populated only when credit_insurance_flag is True.' ;
    rdfs:domain ind:AccountCreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditInsuranceProvider rdf:type rdf:Property ;
    rdfs:label 'Credit Insurance Provider' ;
    rdfs:comment 'Name of the trade credit insurance provider covering the exposure to this client account (e.g., Euler Hermes, Coface, Atradius). Populated only when credit_insurance_flag is True.' ;
    rdfs:domain ind:AccountCreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditLimitAmount rdf:type rdf:Property ;
    rdfs:label 'Credit Limit Amount' ;
    rdfs:comment 'Maximum approved credit exposure the business is willing to extend to this client account at any point in time, expressed in the profile currency. Used in contract terms negotiation and financial risk management.' ;
    rdfs:domain ind:AccountCreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditLimitChangeReason rdf:type rdf:Property ;
    rdfs:label 'Credit Limit Change Reason' ;
    rdfs:comment 'Free-text explanation of the reason for the most recent change to the credit limit, such as improved payment history, new contract award, rating upgrade, or financial distress. Supports audit trail and governance requirements.' ;
    rdfs:domain ind:AccountCreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditReviewFrequency rdf:type rdf:Property ;
    rdfs:label 'Credit Review Frequency' ;
    rdfs:comment 'Frequency at which this client account\'s credit profile is formally reviewed. \'triggered\' indicates review is event-driven (e.g., new contract award, overdue threshold breach) rather than calendar-based.' ;
    rdfs:domain ind:AccountCreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentExposureAmount rdf:type rdf:Property ;
    rdfs:label 'Current Exposure Amount' ;
    rdfs:comment 'Total current financial exposure to this client account, comprising all open invoices (billed but unpaid), unbilled certified work, and retention receivables. Used to assess utilisation against the approved credit limit.' ;
    rdfs:domain ind:AccountCreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dsoDays rdf:type rdf:Property ;
    rdfs:label 'Dso Days' ;
    rdfs:comment 'Average number of days this client account takes to pay invoices, calculated over the trailing review period. DSO (Days Sales Outstanding) is a key accounts receivable metric used to assess payment behaviour and cash flow risk. Sourced from SAP S/4HANA AR aging analysis.' ;
    rdfs:domain ind:AccountCreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:effectiveUntilDate rdf:type rdf:Property ;
    rdfs:label 'Effective Until Date' ;
    rdfs:comment 'Date until which the current credit profile terms are valid. Null for open-ended profiles. Triggers a review workflow when the current date approaches this date.' ;
    rdfs:domain ind:AccountCreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:externalCreditRating rdf:type rdf:Property ;
    rdfs:label 'External Credit Rating' ;
    rdfs:comment 'Credit rating assigned to the client by an external credit rating agency such as Dun & Bradstreet (D&B), Standard & Poor\'s (S&P), Moody\'s, or Fitch. Examples: AAA, AA+, BBB-, Ba1, 5A1 (D&B PAYDEX). Null if no external rating is available.' ;
    rdfs:domain ind:AccountCreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalRatingAgency rdf:type rdf:Property ;
    rdfs:label 'External Rating Agency' ;
    rdfs:comment 'Name of the external credit rating agency that issued the external_credit_rating for this client account. Enables multi-agency comparison and source traceability.' ;
    rdfs:domain ind:AccountCreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalRatingDate rdf:type rdf:Property ;
    rdfs:label 'External Rating Date' ;
    rdfs:comment 'Date on which the external credit rating was issued or last confirmed by the rating agency. Used to assess the currency and relevance of the external rating.' ;
    rdfs:domain ind:AccountCreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:internalCreditScore rdf:type rdf:Property ;
    rdfs:label 'Internal Credit Score' ;
    rdfs:comment 'Internally calculated credit score assigned to this client account by the finance team, typically on a scale of 0–100 or 0–1000, reflecting payment history, financial strength, project delivery track record, and relationship context provided by Business Development (BD). Higher scores indicate lower credit risk.' ;
    rdfs:domain ind:AccountCreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastCreditReviewDate rdf:type rdf:Property ;
    rdfs:label 'Last Credit Review Date' ;
    rdfs:comment 'Date on which the most recent formal credit review was completed by the finance team. Triggers periodic reassessment workflows and ensures credit profiles remain current.' ;
    rdfs:domain ind:AccountCreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:liquidatedDamagesExposureAmount rdf:type rdf:Property ;
    rdfs:label 'Liquidated Damages Exposure Amount' ;
    rdfs:comment 'Maximum financial exposure to Liquidated Damages (LD) that the client could apply against the business under active contracts, based on contractual LD rates and project delay risk. Informs credit risk and P&L exposure assessments.' ;
    rdfs:domain ind:AccountCreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nextCreditReviewDate rdf:type rdf:Property ;
    rdfs:label 'Next Credit Review Date' ;
    rdfs:comment 'Scheduled date for the next periodic credit review of this client account. Supports proactive credit management and ensures timely reassessment before contract renewals or new bid submissions.' ;
    rdfs:domain ind:AccountCreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:overdueBalanceAmount rdf:type rdf:Property ;
    rdfs:label 'Overdue Balance Amount' ;
    rdfs:comment 'Total outstanding invoice balance that has exceeded the approved payment terms due date as of the last credit review or system refresh. A key indicator for credit hold decisions and risk escalation.' ;
    rdfs:domain ind:AccountCreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentHistoryRating rdf:type rdf:Property ;
    rdfs:label 'Payment History Rating' ;
    rdfs:comment 'Qualitative rating of the client\'s historical payment behaviour based on analysis of invoice settlement patterns, frequency of late payments, and dispute history. Derived from AR aging data in SAP S/4HANA and Viewpoint Vista.' ;
    rdfs:domain ind:AccountCreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentTermsDays rdf:type rdf:Property ;
    rdfs:label 'Payment Terms Days' ;
    rdfs:comment 'Numeric representation of the approved payment terms expressed as the number of calendar days from invoice date to due date (e.g., 30 for net-30, 60 for net-60). Complements the approved_payment_terms field for precise DSO calculation and aging analysis.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:previousCreditLimitAmount rdf:type rdf:Property ;
    rdfs:label 'Previous Credit Limit Amount' ;
    rdfs:comment 'Credit limit that was in effect prior to the most recent credit review. Enables trend analysis and audit trail of credit limit changes over time.' ;
    rdfs:domain ind:AccountCreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:profileReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Profile Reference Number' ;
    rdfs:comment 'Externally-known alphanumeric reference code assigned to this credit profile, used in correspondence with finance teams and credit agencies. Format: CP- followed by 6-12 alphanumeric characters.' ;
    rdfs:domain ind:AccountCreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profileStatus rdf:type rdf:Property ;
    rdfs:label 'Profile Status' ;
    rdfs:comment 'Current lifecycle status of the credit profile. \'active\' indicates normal trading terms apply; \'credit_hold\' indicates all new work or invoicing is blocked pending resolution of overdue balances or risk concerns; \'under_review\' indicates a periodic or triggered reassessment is in progress.' ;
    rdfs:domain ind:AccountCreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retentionReleaseTerms rdf:type rdf:Property ;
    rdfs:label 'Retention Release Terms' ;
    rdfs:comment 'Terms governing when withheld retention money is released by the client. Common construction arrangements include 50% on practical completion and 50% on Defects Liability Period (DLP) expiry, or full release on a specific milestone.' ;
    rdfs:domain ind:AccountCreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sovereignCountryCode rdf:type rdf:Property ;
    rdfs:label 'Sovereign Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the sovereign government entity when sovereign_risk_flag is True. Used for country-level risk aggregation and geopolitical exposure reporting.' ;
    rdfs:domain ind:AccountCreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sovereignRiskFlag rdf:type rdf:Property ;
    rdfs:label 'Sovereign Risk Flag' ;
    rdfs:comment 'Indicates whether this client account is a government entity or state-owned enterprise subject to sovereign risk considerations, including political risk, currency controls, and delayed payment due to public procurement cycles. True = sovereign/government client; False = private sector client.' ;
    rdfs:domain ind:AccountCreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:specialPaymentArrangementFlag rdf:type rdf:Property ;
    rdfs:label 'Special Payment Arrangement Flag' ;
    rdfs:comment 'Indicates whether a special payment arrangement has been agreed with this client account, such as a retention release schedule, milestone-based payment plan, advance payment structure, or deferred payment agreement. True = special arrangement in place; False = standard terms apply.' ;
    rdfs:domain ind:AccountCreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:specialPaymentArrangementNotes rdf:type rdf:Property ;
    rdfs:label 'Special Payment Arrangement Notes' ;
    rdfs:comment 'Free-text description of the specific terms of the special payment arrangement, including key milestones, retention percentages, release conditions, or deferred payment schedules agreed with the client.' ;
    rdfs:domain ind:AccountCreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialPaymentArrangementType rdf:type rdf:Property ;
    rdfs:label 'Special Payment Arrangement Type' ;
    rdfs:comment 'Type of special payment arrangement in place for this client account. Populated only when special_payment_arrangement_flag is True. Retention release schedules and milestone-based payments are standard in FIDIC and EPC contracts.' ;
    rdfs:domain ind:AccountCreditProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentAgreementClientFrameworkAgreementId rdf:type rdf:Property ;
    rdfs:label 'Parent Agreement Client Framework Agreement Id' ;
    rdfs:comment 'Self-referencing identifier linking a call-off contract or lot-level agreement to its parent framework agreement. Supports hierarchical agreement structures where individual call-offs are children of a master framework.' ;
    rdfs:domain ind:FrameworkAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FrameworkAgreement .

ind:agreementNumber rdf:type rdf:Property ;
    rdfs:label 'Agreement Number' ;
    rdfs:comment 'Externally-known unique reference number assigned to the framework agreement, used in correspondence, call-off orders, and contract administration. Typically issued by the client or procurement authority (e.g., FA-2024-HWY-001).' ;
    rdfs:domain ind:FrameworkAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agreementType rdf:type rdf:Property ;
    rdfs:label 'Agreement Type' ;
    rdfs:comment 'Classification of the long-term agreement structure. \'framework\' = competitive framework with multiple call-offs; \'master_service_agreement\' (MSA) = pre-agreed terms for repeat services; \'term_contract\' = fixed-duration works contract; \'blanket_order\' = open purchase order for repeat supply; \'call_off_contract\' = individual release under a parent framework.' ;
    rdfs:domain ind:FrameworkAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ceilingValue rdf:type rdf:Property ;
    rdfs:label 'Ceiling Value' ;
    rdfs:comment 'Maximum total monetary value of all call-off orders that may be placed under this framework agreement over its full term. Acts as the Guaranteed Maximum Price (GMP) envelope for the framework. Expressed in the agreement currency.' ;
    rdfs:domain ind:FrameworkAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:clientFrameworkAgreementStatus rdf:type rdf:Property ;
    rdfs:label 'Client Framework Agreement Status' ;
    rdfs:comment 'Current lifecycle state of the framework agreement. \'draft\' = being negotiated; \'active\' = in force and accepting call-offs; \'suspended\' = temporarily halted; \'expired\' = past expiry date with no renewal; \'terminated\' = ended early; \'under_renewal\' = renewal process initiated.' ;
    rdfs:domain ind:FrameworkAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:committedValue rdf:type rdf:Property ;
    rdfs:label 'Committed Value' ;
    rdfs:comment 'Total value of all call-off orders formally issued against this framework agreement to date. Used to track utilisation against the ceiling value and support financial forecasting.' ;
    rdfs:domain ind:FrameworkAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:durationMonths rdf:type rdf:Property ;
    rdfs:label 'Duration Months' ;
    rdfs:comment 'Total planned duration of the framework agreement in calendar months from effective date to expiry date. Used for scheduling, resource planning, and renewal forecasting.' ;
    rdfs:domain ind:FrameworkAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:effectiveDate rdf:type rdf:Property ;
    rdfs:label 'Effective Date' ;
    rdfs:comment 'Date on which the framework agreement becomes legally binding and call-offs may commence. Equivalent to the Notice to Proceed (NTP) date for the framework.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:expiryDate rdf:type rdf:Property ;
    rdfs:label 'Expiry Date' ;
    rdfs:comment 'Date on which the framework agreement is scheduled to expire and no further call-offs may be issued, unless an extension option is exercised.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:extensionDurationMonths rdf:type rdf:Property ;
    rdfs:label 'Extension Duration Months' ;
    rdfs:comment 'Duration in calendar months of each individual extension option. Combined with extension_options to determine the maximum possible agreement term.' ;
    rdfs:domain ind:FrameworkAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:extensionOptions rdf:type rdf:Property ;
    rdfs:label 'Extension Options' ;
    rdfs:comment 'Number of contractual extension options available to the client to extend the framework agreement beyond the original expiry date (e.g., 2 options of 12 months each).' ;
    rdfs:domain ind:FrameworkAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:frameworkLot rdf:type rdf:Property ;
    rdfs:label 'Framework Lot' ;
    rdfs:comment 'Lot or package designation within a multi-lot framework agreement (e.g., \'Lot 1 – Civils\', \'Lot 2 – MEP\', \'Lot 3 – Highways\'). Applicable where the client has structured the framework into distinct work categories.' ;
    rdfs:domain ind:FrameworkAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicRegion rdf:type rdf:Property ;
    rdfs:label 'Geographic Region' ;
    rdfs:comment 'Geographic region or territory within which works under this framework agreement are to be executed (e.g., \'Northern England\', \'Gulf Region\', \'Southeast Asia\'). Used for resource planning and regional P&L reporting.' ;
    rdfs:domain ind:FrameworkAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:governingLaw rdf:type rdf:Property ;
    rdfs:label 'Governing Law' ;
    rdfs:comment 'Legal jurisdiction and governing law under which the framework agreement is interpreted and enforced (e.g., \'English Law\', \'New York State Law\', \'UAE Federal Law\'). Critical for dispute resolution and contract administration.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hseRequirements rdf:type rdf:Property ;
    rdfs:label 'Hse Requirements' ;
    rdfs:comment 'Summary of Health, Safety and Environment (HSE) obligations and standards mandated under the framework agreement, such as OSHA compliance, ISO 45001 certification, SWMS submission, and minimum PPE standards.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incentiveMechanism rdf:type rdf:Property ;
    rdfs:label 'Incentive Mechanism' ;
    rdfs:comment 'Description of any pain/gain share, bonus, or incentive fee mechanism embedded in the framework agreement to reward performance above KPI thresholds or penalise underperformance.' ;
    rdfs:domain ind:FrameworkAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceRequired rdf:type rdf:Property ;
    rdfs:label 'Insurance Required' ;
    rdfs:comment 'Indicates whether specific insurance requirements (e.g., professional indemnity, public liability, contractor\'s all-risk) are mandated under the framework agreement terms.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:kpiDescription rdf:type rdf:Property ;
    rdfs:label 'Kpi Description' ;
    rdfs:comment 'Narrative description of the performance KPIs defined in the framework agreement against which the contractor\'s performance will be measured across call-off orders (e.g., on-time delivery rate, defect rate, TRIR, CPI thresholds).' ;
    rdfs:domain ind:FrameworkAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxCalloffValue rdf:type rdf:Property ;
    rdfs:label 'Max Calloff Value' ;
    rdfs:comment 'Maximum monetary value of a single call-off order permitted under this framework agreement without triggering a mini-competition or additional approval. Supports procurement governance.' ;
    rdfs:domain ind:FrameworkAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minCalloffValue rdf:type rdf:Property ;
    rdfs:label 'Min Calloff Value' ;
    rdfs:comment 'Minimum monetary value of an individual call-off order that may be placed under this framework agreement. Ensures commercial viability of individual work packages.' ;
    rdfs:domain ind:FrameworkAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:procurementRoute rdf:type rdf:Property ;
    rdfs:label 'Procurement Route' ;
    rdfs:comment 'Mechanism by which individual call-off orders are awarded under the framework. \'direct_award\' = awarded without further competition; \'mini_competition\' = secondary competition among framework members; \'competitive_tender\' = full re-tender; \'negotiated\' = negotiated with incumbent.' ;
    rdfs:domain ind:FrameworkAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityStandard rdf:type rdf:Property ;
    rdfs:label 'Quality Standard' ;
    rdfs:comment 'Quality management standard or certification required of the contractor under the framework agreement (e.g., ISO 9001:2015, LEED Gold, ITP compliance). Supports QA/QC governance.' ;
    rdfs:domain ind:FrameworkAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalNoticeDays rdf:type rdf:Property ;
    rdfs:label 'Renewal Notice Days' ;
    rdfs:comment 'Number of calendar days prior to expiry by which either party must serve notice of intent to renew or extend the framework agreement. Triggers CRM pipeline renewal workflow.' ;
    rdfs:domain ind:FrameworkAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:scopeDescription rdf:type rdf:Property ;
    rdfs:label 'Scope Description' ;
    rdfs:comment 'Narrative description of the categories of works, services, or supply covered by the framework agreement (e.g., \'Highway maintenance, resurfacing, and drainage works across the Northern Region\').' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signedDate rdf:type rdf:Property ;
    rdfs:label 'Signed Date' ;
    rdfs:comment 'Date on which the framework agreement was formally executed (signed by all parties). May precede the effective date if there is a mobilisation period.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:terminationDate rdf:type rdf:Property ;
    rdfs:label 'Termination Date' ;
    rdfs:comment 'Actual date on which the framework agreement was terminated early, if applicable. Null if the agreement expired naturally or is still active.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:terminationReason rdf:type rdf:Property ;
    rdfs:label 'Termination Reason' ;
    rdfs:comment 'Reason for early termination of the framework agreement. \'client_default\' = client failed to meet obligations; \'contractor_default\' = contractor breach; \'mutual_agreement\' = both parties agreed; \'force_majeure\' = unforeseeable event; \'regulatory\' = regulatory or legal requirement; \'convenience\' = termination for convenience by client.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:title rdf:type rdf:Property ;
    rdfs:label 'Title' ;
    rdfs:comment 'Full descriptive title of the framework agreement as stated in the executed contract document (e.g., \'National Highways Maintenance Framework 2024–2028\').' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workFrontId rdf:type rdf:Property ;
    rdfs:label 'Work Front Id' ;
    rdfs:comment 'Unique surrogate identifier for the work front record. Primary key for the work_front master entity in the site domain.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WorkFront .

ind:bimModelId rdf:type rdf:Property ;
    rdfs:label 'Bim Model Id' ;
    rdfs:comment 'Foreign key linking to design.bim_model. Business justification: BIM models define the 3D spatial scope and constructability of each work front. Clash detection reports and 4D scheduling link BIM models to work fronts. \'bim_model_reference\' is a plain-text denormal' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BimModel .

ind:crewId rdf:type rdf:Property ;
    rdfs:label 'Crew Id' ;
    rdfs:comment 'Foreign key linking to workforce.crew. Business justification: Work front planning and daily productivity reporting require knowing which crew is assigned to each work front. Project engineers use this link for crew productivity analysis, work front scheduling, a' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Crew .

ind:drawingId rdf:type rdf:Property ;
    rdfs:label 'Drawing Id' ;
    rdfs:comment 'Foreign key linking to design.drawing. Business justification: Work fronts are governed by specific construction drawings defining scope, limits, and method. Site engineers use this link for IFC drawing control, ensuring the correct revision is active before work' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Drawing .

ind:financeCostCodeId rdf:type rdf:Property ;
    rdfs:label 'Finance Cost Code Id' ;
    rdfs:comment 'Foreign key linking to finance.cost_code. Business justification: Cost allocation reports require each work front to reference the central cost code for budgeting and variance analysis.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostCode .

ind:hsePlanId rdf:type rdf:Property ;
    rdfs:label 'Hse Plan Id' ;
    rdfs:comment 'Foreign key linking to safety.hse_plan. Business justification: The HSE plan governs all safety requirements for a work front including PTW requirements, SWMS obligations, and induction standards. Site supervisors reference the applicable HSE plan when establishin' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:HsePlan .

ind:packageId rdf:type rdf:Property ;
    rdfs:label 'Package Id' ;
    rdfs:comment 'Foreign key linking to design.package. Business justification: Design packages (IFC packages) define the scope of work issued to a work front. Document control and earned value reporting require tracing which design package governs each work front to confirm all ' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Package .

ind:partyId rdf:type rdf:Property ;
    rdfs:label 'Party Id' ;
    rdfs:comment 'Foreign key linking to contract.contract_party. Business justification: Each work front is assigned a primary contract party (sub-contractor or client) for responsibility, invoicing and performance tracking.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:permitId rdf:type rdf:Property ;
    rdfs:label 'Permit Id' ;
    rdfs:comment 'Foreign key linking to compliance.compliance_permit. Business justification: Work fronts in environmentally or regulatorily sensitive zones require a specific compliance permit before work commences. Site engineers and compliance officers use this link to verify permit coverag' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Permit .

ind:phaseId rdf:type rdf:Property ;
    rdfs:label 'Phase Id' ;
    rdfs:comment 'Foreign key linking to project.phase. Business justification: Work fronts are executed within project phases. work_front.current_phase is a denormalized plain-text field. Linking to phase enables phase-level work front reporting, mobilization planning per phase,' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Phase .

ind:primaryWorkConstructionProjectId rdf:type rdf:Property ;
    rdfs:label 'Primary Work Construction Project Id' ;
    rdfs:comment 'Reference to the parent project under which this work front is executed. Enables roll-up of work front data to project-level reporting and earned value computation.' ;
    rdfs:domain ind:WorkFront ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ConstructionProject .

ind:projectMilestoneId rdf:type rdf:Property ;
    rdfs:label 'Project Milestone Id' ;
    rdfs:comment 'Foreign key linking to project.project_milestone. Business justification: Work fronts are tied to contractual milestones (e.g., \'Front 3 concrete complete\' triggers payment milestone). Linking work_front to project_milestone enables milestone-driven work front management, L' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProjectMilestone .

ind:purchaseRequisitionId rdf:type rdf:Property ;
    rdfs:label 'Purchase Requisition Id' ;
    rdfs:comment 'Foreign key linking to procurement.purchase_requisition. Business justification: REQUIRED: Work Front material requisition process creates a purchase requisition per front for tracking material needs; experts expect a direct FK.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PurchaseRequisition .

ind:riskAssessmentId rdf:type rdf:Property ;
    rdfs:label 'Risk Assessment Id' ;
    rdfs:comment 'Foreign key linking to safety.risk_assessment. Business justification: HSE plans and project safety management require a risk assessment to be completed and approved before each work front is activated. Construction HSE managers link risk assessments to work fronts for p' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RiskAssessment .

ind:siteId rdf:type rdf:Property ;
    rdfs:label 'Site Id' ;
    rdfs:comment 'Foreign key linking to site.site. Business justification: A work front belongs to a single construction site; adding work_front.site_id creates the required parent relationship and eliminates site isolation.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Site .

ind:subcontractId rdf:type rdf:Property ;
    rdfs:label 'Subcontract Id' ;
    rdfs:comment 'Foreign key linking to contract.subcontract. Business justification: Work fronts are executed under specific subcontract contracts; linking enables schedule, cost and risk integration.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Subcontract .

ind:swmsId rdf:type rdf:Property ;
    rdfs:label 'Swms Id' ;
    rdfs:comment 'Foreign key linking to safety.swms. Business justification: A SWMS must be in place before any work front commences — this is a mandatory HSE gate in construction. work_front.swms_reference is a denormalized text reference to the SWMS record; replacing it with' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Swms .

ind:technicalSpecificationId rdf:type rdf:Property ;
    rdfs:label 'Technical Specification Id' ;
    rdfs:comment 'Foreign key linking to design.technical_specification. Business justification: Each work front executes work governed by a technical specification (e.g., concrete placement spec, earthworks compaction spec). Quality ITPs and hold points on a work front are defined by the governi' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TechnicalSpecification .

ind:wbsElementId rdf:type rdf:Property ;
    rdfs:label 'Wbs Element Id' ;
    rdfs:comment 'Reference to the Work Breakdown Structure (WBS) element that governs the scope of work executed at this work front. Aligns spatial execution with the project schedule hierarchy.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WbsElement .

ind:wbsNodeId rdf:type rdf:Property ;
    rdfs:label 'Wbs Node Id' ;
    rdfs:comment 'Foreign key linking to schedule.wbs_node. Business justification: Work fronts are physically mapped to schedule WBS nodes for 3-week lookahead planning and earned value reporting. Construction schedulers assign work fronts to WBS nodes to track production against th' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WbsNode .

ind:accessRestriction rdf:type rdf:Property ;
    rdfs:label 'Access Restriction' ;
    rdfs:comment 'The access control classification for this work front. \'permit_required\' indicates a Permit to Work (PTW) is mandatory before entry; \'restricted_zone\' limits access to authorised personnel; \'exclusion_zone\' prohibits all non-essential access. Supports HSE compliance.' ;
    rdfs:domain ind:WorkFront ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualCrewSize rdf:type rdf:Property ;
    rdfs:label 'Actual Crew Size' ;
    rdfs:comment 'The actual number of direct labour workers present at this work front on the most recent reporting day. Compared against planned_crew_size to identify under-manning and productivity risks.' ;
    rdfs:domain ind:WorkFront ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualProductionQty rdf:type rdf:Property ;
    rdfs:label 'Actual Production Qty' ;
    rdfs:comment 'Cumulative actual production quantity achieved at this work front to date, expressed in the production_unit. Sourced from HCSS HeavyJob production tracking and field measurements. Used to compute earned value.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualStartDate rdf:type rdf:Property ;
    rdfs:label 'Actual Start Date' ;
    rdfs:comment 'The actual date on which work commenced at this work front. Compared against planned_start_date to compute schedule variance. Sourced from Procore daily logs or HCSS HeavyJob time tracking.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:areaSqm rdf:type rdf:Property ;
    rdfs:label 'Area Sqm' ;
    rdfs:comment 'Total plan area of the work front in square metres. Used as the principal quantitative measure of the resource for production rate calculations, crew density planning, and progress measurement.' ;
    rdfs:domain ind:WorkFront ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:demobilizationDate rdf:type rdf:Property ;
    rdfs:label 'Demobilization Date' ;
    rdfs:comment 'The date on which all resources were demobilized from this work front and active work ceased. Null if the work front is still active. Used to calculate work front duration and close out cost codes.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:elevationM rdf:type rdf:Property ;
    rdfs:label 'Elevation M' ;
    rdfs:comment 'Reference elevation of the work front above mean sea level in metres. Critical for earthworks volume calculations, drainage design, and structural level control.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:environmentalSensitivity rdf:type rdf:Property ;
    rdfs:label 'Environmental Sensitivity' ;
    rdfs:comment 'Classification of the environmental sensitivity of the work front location. \'sensitive\' and \'protected\' areas require additional environmental controls and monitoring per ISO 14001 and EPA requirements. \'remediation_required\' indicates contaminated ground conditions.' ;
    rdfs:domain ind:WorkFront ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forecastFinishDate rdf:type rdf:Property ;
    rdfs:label 'Forecast Finish Date' ;
    rdfs:comment 'Current forecast date for completion of all work at this work front, updated based on actual progress and remaining work. Supports look-ahead scheduling and early warning of delays.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:frontCode rdf:type rdf:Property ;
    rdfs:label 'Front Code' ;
    rdfs:comment 'Externally-known alphanumeric code that uniquely identifies the work front within the project or site. Used in daily logs, production reports, and cost coding in HCSS HeavyJob and Procore.' ;
    rdfs:domain ind:WorkFront ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:frontName rdf:type rdf:Property ;
    rdfs:label 'Front Name' ;
    rdfs:comment 'Human-readable descriptive name of the work front (e.g., \'Zone A – Pile Cap Excavation\', \'North Abutment Face\'). Used in daily logs, progress reports, and field management interfaces.' ;
    rdfs:domain ind:WorkFront ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:frontStatus rdf:type rdf:Property ;
    rdfs:label 'Front Status' ;
    rdfs:comment 'Current lifecycle status of the work front. \'mobilizing\' indicates resources are being deployed; \'active\' indicates concurrent work is in progress; \'suspended\' indicates a temporary hold; \'demobilized\' indicates resources have been withdrawn; \'completed\' indicates all planned work is finished.' ;
    rdfs:domain ind:WorkFront ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:frontType rdf:type rdf:Property ;
    rdfs:label 'Front Type' ;
    rdfs:comment 'Classification of the spatial unit represented by this work front. Distinguishes between zone (broad area), area (defined boundary), face (excavation or structural face), sector, corridor, level (floor/elevation), or bay. [ENUM-REF-CANDIDATE: zone|area|face|sector|corridor|level|bay — promote to reference product if additional types are required]' ;
    rdfs:domain ind:WorkFront ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gridReference rdf:type rdf:Property ;
    rdfs:label 'Grid Reference' ;
    rdfs:comment 'Site-specific grid reference or chainage notation (e.g., \'Grid E5-F6\', \'CH 1+200 to CH 1+450\') used in engineering drawings and BIM models to locate the work front. Complements GPS coordinates for internal site navigation.' ;
    rdfs:domain ind:WorkFront ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:heavyjobCostCenter rdf:type rdf:Property ;
    rdfs:label 'Heavyjob Cost Center' ;
    rdfs:comment 'The cost center identifier in HCSS HeavyJob associated with this work front. Used for field-level cost allocation, equipment hour tracking, and production rate reporting.' ;
    rdfs:domain ind:WorkFront ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hseRiskLevel rdf:type rdf:Property ;
    rdfs:label 'Hse Risk Level' ;
    rdfs:comment 'The assessed HSE risk level for this work front based on the activities being performed, proximity to hazards, and environmental conditions. Drives frequency of safety inspections and toolbox meetings (TBM) requirements.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCriticalPath rdf:type rdf:Property ;
    rdfs:label 'Is Critical Path' ;
    rdfs:comment 'Indicates whether this work front contains activities on the project critical path as determined by the CPM schedule in Oracle Primavera P6. Critical path work fronts receive priority resource allocation and daily progress monitoring.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSubcontracted rdf:type rdf:Property ;
    rdfs:label 'Is Subcontracted' ;
    rdfs:comment 'Indicates whether the work at this work front is executed by a subcontractor rather than the general contractor\'s own workforce. Drives subcontractor management workflows and contract administration processes.' ;
    rdfs:domain ind:WorkFront ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mobilizationDate rdf:type rdf:Property ;
    rdfs:label 'Mobilization Date' ;
    rdfs:comment 'The date on which resources (crew, equipment, materials) were first mobilized to this work front and active work commenced. Marks the start of the work front lifecycle for scheduling and cost tracking.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:percentComplete rdf:type rdf:Property ;
    rdfs:label 'Percent Complete' ;
    rdfs:comment 'Current physical percent complete of all planned work at this work front, expressed as a value between 0.00 and 100.00. Sourced from field progress measurements and used as input to earned value computation in the project domain.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedCrewSize rdf:type rdf:Property ;
    rdfs:label 'Planned Crew Size' ;
    rdfs:comment 'The planned number of direct labour workers assigned to this work front per shift as defined in the resource-loaded schedule. Used for crew density analysis and productivity benchmarking.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:plannedFinishDate rdf:type rdf:Property ;
    rdfs:label 'Planned Finish Date' ;
    rdfs:comment 'Baseline-scheduled finish date for all work activities at this work front as defined in the project schedule. Used for schedule performance index (SPI) calculation and look-ahead planning.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:plannedProductionQty rdf:type rdf:Property ;
    rdfs:label 'Planned Production Qty' ;
    rdfs:comment 'Total planned production quantity for this work front expressed in the production_unit. Derived from the Bill of Quantities (BOQ) and used as the budget quantity for earned value computation.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedStartDate rdf:type rdf:Property ;
    rdfs:label 'Planned Start Date' ;
    rdfs:comment 'Baseline-scheduled start date for work activities at this work front as defined in the project schedule (Oracle Primavera P6). Used for schedule variance analysis and earned value computation.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:procoreLocationReference rdf:type rdf:Property ;
    rdfs:label 'Procore Location Reference' ;
    rdfs:comment 'The location identifier assigned to this work front in the Procore construction management system. Used to link daily logs, RFIs, submittals, and change orders to the correct spatial location.' ;
    rdfs:domain ind:WorkFront ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionUnit rdf:type rdf:Property ;
    rdfs:label 'Production Unit' ;
    rdfs:comment 'The primary unit of measure used to track production output at this work front (e.g., \'m3\' for earthworks, \'LM\' for piling, \'m2\' for formwork, \'tonnes\' for steel erection). Aligns with the Bill of Quantities (BOQ) unit for earned value computation.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shiftPattern rdf:type rdf:Property ;
    rdfs:label 'Shift Pattern' ;
    rdfs:comment 'The shift working pattern applied at this work front. Determines daily productive hours available for scheduling and cost rate calculations.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:weatherSensitivity rdf:type rdf:Property ;
    rdfs:label 'Weather Sensitivity' ;
    rdfs:comment 'Classification of how sensitive the work activities at this work front are to adverse weather conditions. \'high\' sensitivity work fronts (e.g., concrete pours, earthworks) require weather monitoring and contingency planning.' ;
    rdfs:domain ind:WorkFront ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:zoneClassification rdf:type rdf:Property ;
    rdfs:label 'Zone Classification' ;
    rdfs:comment 'Discipline-based classification of the work front zone indicating the primary trade or engineering discipline active at this location. Supports resource planning and subcontractor assignment. [ENUM-REF-CANDIDATE: civil|structural|mep|architectural|earthworks|piling|finishing|commissioning — promote to reference product]' ;
    rdfs:domain ind:WorkFront ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dailyLogId rdf:type rdf:Property ;
    rdfs:label 'Daily Log Id' ;
    rdfs:comment 'Unique surrogate identifier for the daily site log record. Primary key for the daily_log data product in the Databricks Silver Layer.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DailyLog .

ind:activityId rdf:type rdf:Property ;
    rdfs:label 'Activity Id' ;
    rdfs:comment 'Foreign key linking to schedule.activity. Business justification: Daily Log records activities performed each day; linking to schedule.activity enables daily progress reports and variance analysis.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Activity .

ind:primaryDailyConstructionProjectId rdf:type rdf:Property ;
    rdfs:label 'Primary Daily Construction Project Id' ;
    rdfs:comment 'Reference to the project this daily log belongs to. Links the site log to the master project record for earned value and cost control reporting.' ;
    rdfs:domain ind:DailyLog ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ConstructionProject .

ind:approvedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Approved Timestamp' ;
    rdfs:comment 'Date and time when the daily log was formally approved by the project manager or designated reviewer. Marks the transition from submitted to approved status in the log lifecycle.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:concreteVolumeM3 rdf:type rdf:Property ;
    rdfs:label 'Concrete Volume M3' ;
    rdfs:comment 'Total volume of concrete poured on site for the log date in cubic metres. Critical production metric for structural progress tracking, QA/QC compliance (ITP), and earned value computation. Sourced from Procore and HCSS HeavyJob.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costCode rdf:type rdf:Property ;
    rdfs:label 'Cost Code' ;
    rdfs:comment 'HCSS HeavyJob cost code assigned to the primary work activity recorded in this daily log. Enables direct integration between field production data and job costing in Viewpoint Vista and SAP S/4HANA Project Systems.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Cost Impact Flag' ;
    rdfs:comment 'Indicates whether any event recorded in this daily log has been flagged as having a potential cost impact requiring a Change Order (CO) or variation claim. True triggers cost impact assessment and contract administration workflow.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:directLabourCount rdf:type rdf:Property ;
    rdfs:label 'Direct Labour Count' ;
    rdfs:comment 'Number of direct (GC-employed) workers on site for the log date, excluding subcontractor personnel. Used for workforce planning, payroll reconciliation, and labour productivity benchmarking.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:earthworksVolumeM3 rdf:type rdf:Property ;
    rdfs:label 'Earthworks Volume M3' ;
    rdfs:comment 'Total volume of earthworks (cut, fill, or excavation) completed on site for the log date in cubic metres. Key production quantity for earned value computation, BOQ progress measurement, and HCSS HeavyJob production tracking.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:eotImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Eot Impact Flag' ;
    rdfs:comment 'Indicates whether any event recorded in this daily log has been flagged as having a potential Extension of Time (EOT) impact on the project programme. True initiates EOT substantiation documentation under FIDIC Clause 8.4 or applicable contract conditions.' ;
    rdfs:domain ind:DailyLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:equipmentCount rdf:type rdf:Property ;
    rdfs:label 'Equipment Count' ;
    rdfs:comment 'Total number of major equipment units (plant and machinery) present and operational on site for the log date. Used for equipment utilisation tracking, cost coding in HCSS HeavyJob, and mobilisation/demobilisation records.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:eventCount rdf:type rdf:Property ;
    rdfs:label 'Event Count' ;
    rdfs:comment 'Total number of embedded line-item events (delay events, weather stoppages, utility strikes, design holds, access restrictions, safety observations) recorded within this daily log header. Supports event density analytics and claim complexity assessment.' ;
    rdfs:domain ind:DailyLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hasDelayEvent rdf:type rdf:Property ;
    rdfs:label 'Has Delay Event' ;
    rdfs:comment 'Indicates whether one or more delay events were recorded in the embedded line-item events for this daily log. True triggers downstream delay analysis workflows and EOT claim tracking. Key filter for delay analytics.' ;
    rdfs:domain ind:DailyLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hasSafetyObservation rdf:type rdf:Property ;
    rdfs:label 'Has Safety Observation' ;
    rdfs:comment 'Indicates whether one or more HSE safety observations or incidents were recorded in the embedded line-item events for this daily log. True triggers integration with Intelex HSE management for incident reporting and corrective action workflows.' ;
    rdfs:domain ind:DailyLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hcssLogReference rdf:type rdf:Property ;
    rdfs:label 'Hcss Log Reference' ;
    rdfs:comment 'Reference identifier linking this daily log to the corresponding field operations record in HCSS HeavyJob. Supports production tracking reconciliation and cost code validation between Procore and HCSS.' ;
    rdfs:domain ind:DailyLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:logDate rdf:type rdf:Property ;
    rdfs:label 'Log Date' ;
    rdfs:comment 'The calendar date for which this daily site log records field activities. The principal business event date — one log per project site per calendar day. Drives schedule performance and delay analysis.' ;
    rdfs:domain ind:DailyLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:logNumber rdf:type rdf:Property ;
    rdfs:label 'Log Number' ;
    rdfs:comment 'Externally-known sequential log number assigned by the construction management system (Procore) for this daily log. Used as the human-readable business identifier in correspondence, delay claims, and EOT substantiation. Format: DL-{ProjectCode}-{Year}-{Sequence}.' ;
    rdfs:domain ind:DailyLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:logStatus rdf:type rdf:Property ;
    rdfs:label 'Log Status' ;
    rdfs:comment 'Current workflow state of the daily log record. Draft indicates in-progress field entry; submitted indicates superintendent sign-off pending review; approved indicates accepted by project management; rejected indicates returned for correction; void indicates cancelled/superseded entry.' ;
    rdfs:domain ind:DailyLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ltiOccurredFlag rdf:type rdf:Property ;
    rdfs:label 'Lti Occurred Flag' ;
    rdfs:comment 'Indicates whether a Lost Time Injury (LTI) occurred on site on this log date. True triggers mandatory incident reporting to Intelex HSE system, regulatory notification under OSHA, and TRIR (Total Recordable Incident Rate) calculation update.' ;
    rdfs:domain ind:DailyLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ncrRaisedFlag rdf:type rdf:Property ;
    rdfs:label 'Ncr Raised Flag' ;
    rdfs:comment 'Indicates whether a Non-Conformance Report (NCR) was raised on this log date. True triggers integration with the QA/QC management workflow and requires corrective action documentation per ISO 9001.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:overallSiteStatus rdf:type rdf:Property ;
    rdfs:label 'Overall Site Status' ;
    rdfs:comment 'High-level classification of site productivity for the log date. Productive indicates full operations; partially_productive indicates reduced output due to delays or restrictions; non_productive indicates no billable work performed; shutdown indicates planned or emergency site closure.' ;
    rdfs:domain ind:DailyLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:permitToWorkCount rdf:type rdf:Property ;
    rdfs:label 'Permit To Work Count' ;
    rdfs:comment 'Number of active Permits to Work (PTW) issued and in force on site for the log date. Supports HSE compliance monitoring, Intelex PTW tracking, and regulatory audit evidence for high-risk work activities.' ;
    rdfs:domain ind:DailyLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:plannedActivitiesNarrative rdf:type rdf:Property ;
    rdfs:label 'Planned Activities Narrative' ;
    rdfs:comment 'Free-text description of the construction activities that were planned for the log date per the project schedule. Compared against work_performed_narrative to identify schedule variances and support look-ahead planning.' ;
    rdfs:domain ind:DailyLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:precipitationMm rdf:type rdf:Property ;
    rdfs:label 'Precipitation Mm' ;
    rdfs:comment 'Total rainfall or precipitation recorded at the site in millimetres for the log date. Key metric for weather delay claims, earthworks productivity assessment, and EOT substantiation under FIDIC Clause 8.4.' ;
    rdfs:domain ind:DailyLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:procoreLogReference rdf:type rdf:Property ;
    rdfs:label 'Procore Log Reference' ;
    rdfs:comment 'Source system identifier for this daily log record in the Procore Construction Management platform. Enables traceability and reconciliation between the Silver Layer data product and the operational system of record.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remarks rdf:type rdf:Property ;
    rdfs:label 'Remarks' ;
    rdfs:comment 'Additional free-text remarks or notes entered by the superintendent for items not captured in structured fields or the work performed narrative. Provides supplementary context for project management review and legal record completeness.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shiftType rdf:type rdf:Property ;
    rdfs:label 'Shift Type' ;
    rdfs:comment 'Type of work shift recorded in this daily log. Distinguishes day, night, double-shift, or split-shift operations. Relevant for overtime cost tracking, HSE fatigue management, and productivity benchmarking.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteAccessStatus rdf:type rdf:Property ;
    rdfs:label 'Site Access Status' ;
    rdfs:comment 'Operational access status of the construction site for the log date. Closed or restricted access directly impacts productivity and supports delay claim documentation. Partial indicates some work fronts accessible.' ;
    rdfs:domain ind:DailyLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subcontractorCount rdf:type rdf:Property ;
    rdfs:label 'Subcontractor Count' ;
    rdfs:comment 'Number of subcontractor personnel on site for the log date. Supports subcontractor performance monitoring, site coordination, and contract administration.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:superintendentSignOffTimestamp rdf:type rdf:Property ;
    rdfs:label 'Superintendent Sign Off Timestamp' ;
    rdfs:comment 'Date and time when the site superintendent formally signed off and submitted the daily log. Establishes the legal record timestamp for the site activity log. Critical for delay claim and EOT substantiation timelines.' ;
    rdfs:domain ind:DailyLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:tbmConductedFlag rdf:type rdf:Property ;
    rdfs:label 'Tbm Conducted Flag' ;
    rdfs:comment 'Indicates whether a Toolbox Meeting (TBM) was conducted on site for the log date. Mandatory HSE compliance indicator. True confirms daily safety briefing was held per SWMS (Safe Work Method Statement) requirements.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:temperatureHighC rdf:type rdf:Property ;
    rdfs:label 'Temperature High C' ;
    rdfs:comment 'Highest recorded ambient temperature at the site in degrees Celsius for the log date. Used for concrete pour suitability assessment, HSE heat stress monitoring, and weather delay substantiation.' ;
    rdfs:domain ind:DailyLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:temperatureLowC rdf:type rdf:Property ;
    rdfs:label 'Temperature Low C' ;
    rdfs:comment 'Lowest recorded ambient temperature at the site in degrees Celsius for the log date. Used for cold weather concreting assessment, frost protection requirements, and weather delay substantiation.' ;
    rdfs:domain ind:DailyLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalDelayDurationHrs rdf:type rdf:Property ;
    rdfs:label 'Total Delay Duration Hrs' ;
    rdfs:comment 'Aggregate duration in hours of all delay events recorded in the embedded line-item events for this daily log. Used for schedule impact quantification, EOT claim substantiation, and SPI (Schedule Performance Index) computation.' ;
    rdfs:domain ind:DailyLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalManpowerCount rdf:type rdf:Property ;
    rdfs:label 'Total Manpower Count' ;
    rdfs:comment 'Total number of workers (all trades combined) present on site for the log date. Includes direct labour and subcontractor personnel. Key input for productivity analysis, earned value computation, and labour cost reconciliation against HCSS HeavyJob cost codes.' ;
    rdfs:domain ind:DailyLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:visitorCount rdf:type rdf:Property ;
    rdfs:label 'Visitor Count' ;
    rdfs:comment 'Number of authorised visitors (client representatives, inspectors, auditors, regulatory officials) on site for the log date. Supports site access management, HSE induction compliance, and client engagement tracking.' ;
    rdfs:domain ind:DailyLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:weatherCondition rdf:type rdf:Property ;
    rdfs:label 'Weather Condition' ;
    rdfs:comment 'Observed general weather condition at the site for the log date. Used to substantiate weather-related delay claims, EOT applications, and force majeure events under FIDIC contract provisions. [ENUM-REF-CANDIDATE: clear|partly_cloudy|overcast|rain|heavy_rain|snow|fog|storm|extreme_heat — promote to reference product]' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:windSpeedKmh rdf:type rdf:Property ;
    rdfs:label 'Wind Speed Kmh' ;
    rdfs:comment 'Recorded wind speed at the site in kilometres per hour for the log date. Used to assess crane and elevated work restrictions, HSE compliance, and weather-related work stoppages.' ;
    rdfs:domain ind:DailyLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:workPerformedNarrative rdf:type rdf:Property ;
    rdfs:label 'Work Performed Narrative' ;
    rdfs:comment 'Free-text superintendent narrative describing all construction activities performed on site during the log date. Serves as the primary operational record and legal evidence base for progress claims, delay substantiation, and EOT applications. Sourced from Procore Daily Logs.' ;
    rdfs:domain ind:DailyLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionEntryId rdf:type rdf:Property ;
    rdfs:label 'Production Entry Id' ;
    rdfs:comment 'Unique surrogate identifier for each granular production tracking record in the silver layer lakehouse. Primary key for the production_entry data product.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProductionEntry .

ind:assetId rdf:type rdf:Property ;
    rdfs:label 'Asset Id' ;
    rdfs:comment 'Foreign key linking to equipment.asset. Business justification: Production reports require linking installed quantities to the specific equipment used for cost allocation and utilization analysis.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Asset .

ind:costCodeId rdf:type rdf:Property ;
    rdfs:label 'Cost Code Id' ;
    rdfs:comment 'Reference to the cost code used to classify and track the financial dimension of this production entry. Sourced from HCSS HeavyJob cost coding module and aligned with SAP S/4HANA job costing.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostCode .

ind:estimateLineId rdf:type rdf:Property ;
    rdfs:label 'Estimate Line Id' ;
    rdfs:comment 'Foreign key linking to bid.estimate_line. Business justification: Production entries record actual quantities and unit costs. Linking to estimate_line enables actual-vs-estimate variance analysis at the line-item level — a core construction cost control and earned-v' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EstimateLine .

ind:goodsIssueId rdf:type rdf:Property ;
    rdfs:label 'Goods Issue Id' ;
    rdfs:comment 'Foreign key linking to material.goods_issue. Business justification: Material consumption reconciliation: production_entry records installed quantities; goods_issue records materials issued for that installation. Linking them enables EVM cost-at-completion analysis and' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GoodsIssue .

ind:hoursId rdf:type rdf:Property ;
    rdfs:label 'Hours Id' ;
    rdfs:comment 'Foreign key linking to equipment.hours. Business justification: Production entries record equipment hours consumed per activity. These must reconcile against the authoritative equipment hours log for earned value and cost-per-unit reporting. Construction cost engi' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Hours .

ind:jobCostTransactionId rdf:type rdf:Property ;
    rdfs:label 'Job Cost Transaction Id' ;
    rdfs:comment 'Foreign key linking to finance.job_cost_transaction. Business justification: Production entries (installed quantities, labor/equipment hours) are the source records that generate job cost transactions in construction cost ledgers (HCSS HeavyJob, JD Edwards). Cost engineers use' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:JobCostTransaction .

ind:materialCatalogId rdf:type rdf:Property ;
    rdfs:label 'Material Catalog Id' ;
    rdfs:comment 'Foreign key linking to procurement.material_catalog. Business justification: Production tracking against approved material catalog: installed quantities must reference the approved material catalog item for specification compliance, cost-code alignment, and QA/ITP traceability' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MaterialCatalog .

ind:purchaseOrderId rdf:type rdf:Property ;
    rdfs:label 'Purchase Order Id' ;
    rdfs:comment 'Foreign key linking to procurement.purchase_order. Business justification: REQUIRED: Production entries consume materials tied to specific purchase orders, enabling material cost verification on site.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PurchaseOrder .

ind:shiftReportId rdf:type rdf:Property ;
    rdfs:label 'Shift Report Id' ;
    rdfs:comment 'Foreign key linking to site.shift_report. Business justification: Production entries are granular records of work completed during a shift. Linking production_entry to shift_report enables shift-level aggregation of production quantities and supports reconciliation ' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ShiftReport .

ind:approvedBy rdf:type rdf:Property ;
    rdfs:label 'Approved By' ;
    rdfs:comment 'Name or identifier of the site engineer, superintendent, or project manager who approved this production entry. Required for audit trail and progress billing authorization.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetedProductionRate rdf:type rdf:Property ;
    rdfs:label 'Budgeted Production Rate' ;
    rdfs:comment 'The planned or budgeted production rate for this activity and cost code expressed as units per labor-hour. Sourced from the project estimate and HCSS HeavyJob budget. Used to compute production efficiency variance against actual production_rate.' ;
    rdfs:domain ind:ProductionEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetedQuantity rdf:type rdf:Property ;
    rdfs:label 'Budgeted Quantity' ;
    rdfs:comment 'The total budgeted or planned quantity for this activity and cost code as established in the project budget and BOQ (Bill of Quantities). Used as the denominator for percent complete calculation and EVM (Earned Value Management) analysis.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:changeOrderReference rdf:type rdf:Property ;
    rdfs:label 'Change Order Reference' ;
    rdfs:comment 'Reference number of the approved Change Order (CO) that authorized a scope or quantity revision reflected in this production entry. Links production tracking to contract administration for cost and schedule impact analysis.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crewSize rdf:type rdf:Property ;
    rdfs:label 'Crew Size' ;
    rdfs:comment 'The number of workers (headcount) assigned to this production activity on the entry date. Used for labor productivity analysis, crew efficiency benchmarking, and workforce planning.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cumulativeQuantity rdf:type rdf:Property ;
    rdfs:label 'Cumulative Quantity' ;
    rdfs:comment 'The total quantity of work installed to date for this activity and cost code, inclusive of the current entry. Represents the running total used for percent complete and progress billing milestone verification.' ;
    rdfs:domain ind:ProductionEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:entryDate rdf:type rdf:Property ;
    rdfs:label 'Entry Date' ;
    rdfs:comment 'The calendar date on which the production quantities were recorded. Represents the actual field execution date, not the data entry date. Core dimension for daily progress reporting and schedule performance analysis.' ;
    rdfs:domain ind:ProductionEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:entryNumber rdf:type rdf:Property ;
    rdfs:label 'Entry Number' ;
    rdfs:comment 'Externally-known alphanumeric identifier for this production entry as assigned by the source system (HCSS HeavyJob). Used for cross-system traceability and field reference. Format: PE-[YYYYMMDD]-[SEQ].' ;
    rdfs:domain ind:ProductionEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entryStatus rdf:type rdf:Property ;
    rdfs:label 'Entry Status' ;
    rdfs:comment 'Current workflow lifecycle state of the production entry record. Drives approval routing and determines whether quantities are included in earned value and progress billing computations.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equipmentHours rdf:type rdf:Property ;
    rdfs:label 'Equipment Hours' ;
    rdfs:comment 'Total equipment operating hours consumed on this production activity for the entry date. Aggregated across all equipment units deployed. Used for equipment cost allocation, utilization analysis, and maintenance scheduling.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:installedQuantity rdf:type rdf:Property ;
    rdfs:label 'Installed Quantity' ;
    rdfs:comment 'The actual quantity of work physically installed or completed during the entry date for this activity and cost code. This is the primary production measurement used to compute earned value and progress billing. Expressed in the unit of measure defined by unit_of_measure.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isBaselineRevision rdf:type rdf:Property ;
    rdfs:label 'Is Baseline Revision' ;
    rdfs:comment 'Indicates whether this production entry reflects a revision to the baseline budgeted quantity due to an approved Change Order (CO) or scope change. When true, the budgeted_quantity reflects the revised baseline.' ;
    rdfs:domain ind:ProductionEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRework rdf:type rdf:Property ;
    rdfs:label 'Is Rework' ;
    rdfs:comment 'Indicates whether this production entry represents rework (corrective re-execution of previously completed work) rather than new production. Rework quantities are tracked separately for quality cost analysis and NCR (Non-Conformance Report) linkage.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:itpReference rdf:type rdf:Property ;
    rdfs:label 'Itp Reference' ;
    rdfs:comment 'Reference to the Inspection and Test Plan (ITP) checkpoint associated with this production entry. Confirms that quality hold points or witness points have been satisfied before production quantities are accepted for earned value credit.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:laborHours rdf:type rdf:Property ;
    rdfs:label 'Labor Hours' ;
    rdfs:comment 'Total labor hours expended by the crew on this production activity for the entry date. Includes all direct labor hours charged to this cost code. Used as the denominator for production rate calculation and labor cost analysis.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ncrReference rdf:type rdf:Property ;
    rdfs:label 'Ncr Reference' ;
    rdfs:comment 'Reference number of the Non-Conformance Report (NCR) associated with this production entry when is_rework is true. Enables traceability between rework production and quality non-conformances for QA/QC reporting.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionRate rdf:type rdf:Property ;
    rdfs:label 'Production Rate' ;
    rdfs:comment 'The measured production rate for this entry expressed as units of work completed per labor-hour (e.g., CY/hr, LF/hr). Calculated from installed_quantity divided by total labor hours. Used for productivity benchmarking, crew efficiency analysis, and future bid estimation.' ;
    rdfs:domain ind:ProductionEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:productionType rdf:type rdf:Property ;
    rdfs:label 'Production Type' ;
    rdfs:comment 'Classification of the type of construction production activity being tracked. Enables domain-specific productivity benchmarking and reporting across earthworks, concrete, structural, MEP (Mechanical Electrical and Plumbing), and other work categories. [ENUM-REF-CANDIDATE: earthworks|concrete|structural_steel|paving|MEP|formwork|rebar|masonry|finishing|demolition|other — promote to reference product]' ;
    rdfs:domain ind:ProductionEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceRecordReference rdf:type rdf:Property ;
    rdfs:label 'Source Record Reference' ;
    rdfs:comment 'The native primary key or record identifier of this production entry in the originating source system (e.g., HCSS HeavyJob internal ID). Enables reverse traceability from the lakehouse silver layer back to the operational system of record.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submittedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Submitted Timestamp' ;
    rdfs:comment 'The date and time when this production entry was submitted for approval by the field team. Used for workflow SLA tracking and audit trail.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:temperatureC rdf:type rdf:Property ;
    rdfs:label 'Temperature C' ;
    rdfs:comment 'Recorded ambient temperature in degrees Celsius at the work front on the entry date. Used to assess weather-related productivity impacts, validate concrete pour conditions per ACI standards, and support EOT (Extension of Time) claims.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Unit Of Measure' ;
    rdfs:comment 'The unit of measure applicable to the installed_quantity and budgeted_quantity fields (e.g., CY for cubic yards, LF for linear feet, SF for square feet, EA for each, TON, M3, M2). Sourced from the BOQ (Bill of Quantities) and HCSS HeavyJob. [ENUM-REF-CANDIDATE: CY|LF|SF|EA|TON|M3|M2|LM|KG|HR — promote to reference product]' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workFrontLocation rdf:type rdf:Property ;
    rdfs:label 'Work Front Location' ;
    rdfs:comment 'Descriptive location identifier for the work front or zone where production was executed (e.g., \'Zone A — Grid 1-5\', \'Pier 3 Foundation\', \'Runway 2 Subbase\'). Supports spatial analysis and site logistics planning.' ;
    rdfs:domain ind:ProductionEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workItemDescription rdf:type rdf:Property ;
    rdfs:label 'Work Item Description' ;
    rdfs:comment 'Human-readable description of the specific work item or scope of work being tracked in this production entry (e.g., \'Concrete pour — Column Grid A1-A5\', \'Earthworks cut — Zone 3\'). Sourced from BOQ (Bill of Quantities) or activity description.' ;
    rdfs:domain ind:ProductionEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crewDeploymentId rdf:type rdf:Property ;
    rdfs:label 'Crew Deployment Id' ;
    rdfs:comment 'Unique surrogate identifier for each daily crew deployment record. Primary key for the crew_deployment data product in the site domain Silver layer.' ;
    rdfs:domain ind:CrewDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:leadForemanCraftWorkerId rdf:type rdf:Property ;
    rdfs:label 'Lead Foreman Craft Worker Id' ;
    rdfs:comment 'Foreign key linking to workforce.craft_worker. Business justification: Lead foreman accountability is a core construction site management requirement — HSE toolbox meetings, permit-to-work sign-offs, and productivity records are tied to the named foreman. lead_foreman_na' ;
    rdfs:domain ind:CrewDeployment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CraftWorker .

ind:permitToWorkId rdf:type rdf:Property ;
    rdfs:label 'Permit To Work Id' ;
    rdfs:comment 'Foreign key linking to safety.permit_to_work. Business justification: Crew cannot legally be deployed to a work area without a valid PTW — this is a regulatory and contractual requirement. crew_deployment.permit_to_work_number is a denormalized text reference; a proper ' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PermitToWork .

ind:toolboxMeetingId rdf:type rdf:Property ;
    rdfs:label 'Toolbox Meeting Id' ;
    rdfs:comment 'Foreign key linking to safety.toolbox_meeting. Business justification: A toolbox meeting is conducted at the start of each crew deployment shift. Linking crew_deployment to the specific toolbox_meeting record provides an audit trail of which TBM covered which crew deploy' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ToolboxMeeting .

ind:tradePackageId rdf:type rdf:Property ;
    rdfs:label 'Trade Package Id' ;
    rdfs:comment 'Foreign key linking to bid.trade_package. Business justification: Crew deployments are executed under trade packages. Linking enables trade-package-level labour cost tracking and productivity benchmarking against bid labour assumptions — essential for subcontract pe' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TradePackage .

ind:vendorId rdf:type rdf:Property ;
    rdfs:label 'Vendor Id' ;
    rdfs:comment 'Foreign key linking to procurement.vendor. Business justification: Subcontractor vendor performance management: crew deployments from subcontractor vendors must be linked to the vendor record for HSE performance tracking, KPI reporting, and vendor evaluation. Constru' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vendor .

ind:actualHours rdf:type rdf:Property ;
    rdfs:label 'Actual Hours' ;
    rdfs:comment 'Total man-hours actually worked by the crew on this deployment date, as recorded in HCSS HeavyJob time tracking. Compared against planned_hours to compute productivity variance and feed EVM calculations.' ;
    rdfs:domain ind:CrewDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:crewType rdf:type rdf:Property ;
    rdfs:label 'Crew Type' ;
    rdfs:comment 'Classification of the crew by trade discipline. Drives resource planning, productivity benchmarking, and cost code allocation. [ENUM-REF-CANDIDATE: civil|mep|concrete|steel_erection|earthworks|finishing|specialist|formwork|rebar|waterproofing — promote to reference product]' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:delayReasonCode rdf:type rdf:Property ;
    rdfs:label 'Delay Reason Code' ;
    rdfs:comment 'Standardised code identifying the primary reason for any production delay or underperformance on this deployment (e.g., WEATHER, MATERIAL_SHORTAGE, EQUIPMENT_BREAKDOWN, DESIGN_CHANGE, PERMIT_DELAY). Supports delay analysis and EOT claims. [ENUM-REF-CANDIDATE: WEATHER|MATERIAL_SHORTAGE|EQUIPMENT_BREAKDOWN|DESIGN_CHANGE|PERMIT_DELAY|LABOUR_SHORTAGE|REWORK|SAFETY_STOP — promote to reference product]' ;
    rdfs:domain ind:CrewDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deploymentDate rdf:type rdf:Property ;
    rdfs:label 'Deployment Date' ;
    rdfs:comment 'Calendar date on which the crew is deployed to the work front. The principal business event date for this daily deployment record. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:deploymentNumber rdf:type rdf:Property ;
    rdfs:label 'Deployment Number' ;
    rdfs:comment 'Externally-known business identifier for this crew deployment record, typically generated by HCSS HeavyJob (e.g., CD-2024-00123). Used for cross-system referencing and field reporting.' ;
    rdfs:domain ind:CrewDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deploymentStatus rdf:type rdf:Property ;
    rdfs:label 'Deployment Status' ;
    rdfs:comment 'Current lifecycle state of the crew deployment record. Tracks whether the deployment is planned, actively in progress, completed, cancelled, or suspended due to site conditions.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hseToolboxMeetingHeld rdf:type rdf:Property ;
    rdfs:label 'Hse Toolbox Meeting Held' ;
    rdfs:comment 'Indicates whether a Toolbox Meeting (TBM) was conducted with this crew prior to commencing work on this deployment date (True) or not (False). Mandatory HSE compliance check per OSHA and ISO 45001 requirements.' ;
    rdfs:domain ind:CrewDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isOvertime rdf:type rdf:Property ;
    rdfs:label 'Is Overtime' ;
    rdfs:comment 'Indicates whether this crew deployment involved overtime work (True) or was a standard shift (False). Sourced from HCSS HeavyJob. Used for payroll flagging and cost escalation alerts.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSubcontractorCrew rdf:type rdf:Property ;
    rdfs:label 'Is Subcontractor Crew' ;
    rdfs:comment 'Indicates whether this crew is supplied by a subcontractor (True) or is part of the general contractor\'s direct workforce (False). Drives cost segregation between self-performed and subcontracted labour.' ;
    rdfs:domain ind:CrewDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isWeatherImpacted rdf:type rdf:Property ;
    rdfs:label 'Is Weather Impacted' ;
    rdfs:comment 'Indicates whether adverse weather conditions materially impacted crew productivity or caused a work stoppage on this deployment date (True) or not (False). Supports Extension of Time (EOT) and delay claim substantiation.' ;
    rdfs:domain ind:CrewDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mobilizationStatus rdf:type rdf:Property ;
    rdfs:label 'Mobilization Status' ;
    rdfs:comment 'Indicates the mobilization lifecycle stage of the crew relative to the project site. Tracks whether the crew is in the process of mobilizing, fully on site, demobilizing, or has fully demobilized. Supports site logistics planning.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overtimeHours rdf:type rdf:Property ;
    rdfs:label 'Overtime Hours' ;
    rdfs:comment 'Number of overtime hours worked by the crew beyond the standard shift duration on this deployment date. Sourced from HCSS HeavyJob payroll records. Feeds Viewpoint Vista payroll and job costing.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedHours rdf:type rdf:Property ;
    rdfs:label 'Planned Hours' ;
    rdfs:comment 'Total man-hours planned for this crew deployment on the given date, as scheduled in Oracle Primavera P6. Used as the baseline for earned value computation and productivity variance analysis.' ;
    rdfs:domain ind:CrewDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ppeCompliance rdf:type rdf:Property ;
    rdfs:label 'Ppe Compliance' ;
    rdfs:comment 'Indicates whether all crew members were observed to be wearing required Personal Protective Equipment (PPE) at the start of this deployment (True) or a non-compliance was recorded (False). Sourced from Procore or Intelex field inspection.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Production Unit Of Measure' ;
    rdfs:comment 'Unit of measure for the planned and actual production quantities (e.g., m3, LM, tonne, m2, EA). Sourced from the HCSS HeavyJob cost code definition and aligned with the Bill of Quantities (BOQ).' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productivityNotes rdf:type rdf:Property ;
    rdfs:label 'Productivity Notes' ;
    rdfs:comment 'Free-text field capturing foreman or site supervisor observations about crew productivity, constraints, delays, or notable events during this deployment. Sourced from HCSS HeavyJob or Procore daily log narrative.' ;
    rdfs:domain ind:CrewDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productivityRate rdf:type rdf:Property ;
    rdfs:label 'Productivity Rate' ;
    rdfs:comment 'Actual production output per man-hour achieved by this crew on this deployment date (actual_production_qty / actual_hours). Sourced from HCSS HeavyJob production tracking. Used for benchmarking and Schedule Performance Index (SPI) analysis.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shiftEndTime rdf:type rdf:Property ;
    rdfs:label 'Shift End Time' ;
    rdfs:comment 'Actual date and time the crew shift ended on site. Sourced from HCSS HeavyJob time tracking. Used in conjunction with shift_start_time to compute actual hours worked. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:shiftStartTime rdf:type rdf:Property ;
    rdfs:label 'Shift Start Time' ;
    rdfs:comment 'Actual date and time the crew shift commenced on site. Sourced from HCSS HeavyJob time tracking. Used for hours calculation, overtime determination, and HSE compliance. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:fieldProgressId rdf:type rdf:Property ;
    rdfs:label 'Field Progress Id' ;
    rdfs:comment 'Unique surrogate identifier for each field progress measurement record in the silver layer lakehouse. Primary key for the field_progress data product.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FieldProgress .

ind:bidBoqLineId rdf:type rdf:Property ;
    rdfs:label 'Bid Boq Line Id' ;
    rdfs:comment 'Reference to the BOQ line item from the contract or estimate against which installed quantities are measured. Enables reconciliation of field-installed quantities against contracted scope.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BidBoqLine .

ind:itpLineId rdf:type rdf:Property ;
    rdfs:label 'Itp Line Id' ;
    rdfs:comment 'Reference to the ITP (Inspection and Test Plan) checkpoint that must be satisfied before this progress measurement can be approved. Ensures QA/QC hold points are cleared prior to progress being recognised in EVM.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ItpLine .

ind:procoreDailyLogId rdf:type rdf:Property ;
    rdfs:label 'Procore Daily Log Id' ;
    rdfs:comment 'The source system identifier of the Procore daily log entry from which this field progress measurement was derived or linked. Enables traceability back to the originating daily log record in Procore for audit and reconciliation purposes.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DailyLog .

ind:scheduleBaselineId rdf:type rdf:Property ;
    rdfs:label 'Schedule Baseline Id' ;
    rdfs:comment 'Foreign key linking to schedule.schedule_baseline. Business justification: Field progress measurements (BCWP, budget_at_completion) must reference the schedule baseline against which they are measured for earned value management reporting. Construction project controls engin' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ScheduleBaseline .

ind:wbsActivityId rdf:type rdf:Property ;
    rdfs:label 'Wbs Activity Id' ;
    rdfs:comment 'Reference to the WBS activity or schedule activity in Oracle Primavera P6 against which this field progress measurement is recorded. Links field measurement to the schedule domain for EVM computation.' ;
    rdfs:domain ind:FieldProgress ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Activity .

ind:activityType rdf:type rdf:Property ;
    rdfs:label 'Activity Type' ;
    rdfs:comment 'The construction discipline or work type category of the WBS activity being measured (e.g., earthworks, concrete, structural steel, MEP). Enables discipline-level progress aggregation and resource productivity benchmarking. [ENUM-REF-CANDIDATE: earthworks|concrete|structural_steel|mep|civil|finishing|commissioning|piling|roofing|other — promote to reference product]' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalStatus rdf:type rdf:Property ;
    rdfs:label 'Approval Status' ;
    rdfs:comment 'Current workflow state of the field progress measurement record. Controls whether the measurement is eligible to feed EVM (Earned Value Management) calculations in the project domain. Draft and rejected records are excluded from BCWP computation.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approverName rdf:type rdf:Property ;
    rdfs:label 'Approver Name' ;
    rdfs:comment 'Full name of the supervisor, project engineer, or quantity surveyor who reviewed and approved the field progress measurement. Required for audit trail and QA/QC compliance.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bcwp rdf:type rdf:Property ;
    rdfs:label 'Bcwp' ;
    rdfs:comment 'The Budgeted Cost of Work Performed (BCWP), also known as Earned Value, computed as reported_percent_complete multiplied by the budget at completion for the activity. Expressed in project currency. Feeds CPI and SPI calculations in the project domain EVM module.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetAtCompletion rdf:type rdf:Property ;
    rdfs:label 'Budget At Completion' ;
    rdfs:comment 'The total approved budget allocated to the WBS activity or BOQ line item as of this measurement date. Used as the basis for BCWP computation. Classified as confidential as it contains project financial data.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dataDate rdf:type rdf:Property ;
    rdfs:label 'Data Date' ;
    rdfs:comment 'The official schedule data date or progress cut-off date as defined in Oracle Primavera P6 for the reporting period in which this measurement falls. Aligns field measurements with the schedule baseline for SPI computation.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fieldEngineerName rdf:type rdf:Property ;
    rdfs:label 'Field Engineer Name' ;
    rdfs:comment 'Full name of the field engineer or site engineer who physically performed and recorded the progress measurement. Provides accountability and traceability for the measurement. Classified as confidential PII as it identifies an individual employee.' ;
    rdfs:domain ind:FieldProgress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isMilestone rdf:type rdf:Property ;
    rdfs:label 'Is Milestone' ;
    rdfs:comment 'Indicates whether the WBS activity associated with this progress measurement is a contract or schedule milestone (True) or a regular work activity (False). Milestone completion triggers contractual notifications and potential payment events.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:measurementDate rdf:type rdf:Property ;
    rdfs:label 'Measurement Date' ;
    rdfs:comment 'The calendar date on which the physical field progress measurement was taken by the field engineer or surveyor. This is the principal real-world event date used for EVM period calculations and schedule reconciliation.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:measurementMethod rdf:type rdf:Property ;
    rdfs:label 'Measurement Method' ;
    rdfs:comment 'The technique used to determine the percent complete or installed quantity in the field. Drives confidence weighting in EVM calculations. [ENUM-REF-CANDIDATE: visual_estimate|quantity_survey|milestone_completion|3d_scan_comparison|weighted_steps|engineering_estimate — promote to reference product if additional methods are added]' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementNotes rdf:type rdf:Property ;
    rdfs:label 'Measurement Notes' ;
    rdfs:comment 'Free-text field for the field engineer to record observations, constraints, or qualifications relevant to the progress measurement (e.g., partial pour due to rain, access restriction, rework in progress). Supports contextual interpretation of progress data.' ;
    rdfs:domain ind:FieldProgress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementNumber rdf:type rdf:Property ;
    rdfs:label 'Measurement Number' ;
    rdfs:comment 'Externally-known unique business identifier for this progress measurement record, typically formatted as a sequential reference number (e.g., FPM-2024-00123) used in Procore daily logs and field management reports.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementPeriodType rdf:type rdf:Property ;
    rdfs:label 'Measurement Period Type' ;
    rdfs:comment 'The reporting frequency or period type for this progress measurement (e.g., daily, weekly, monthly). Determines how the measurement aligns with project reporting cycles and EVM period cut-offs in Oracle Primavera P6.' ;
    rdfs:domain ind:FieldProgress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:periodInstalledQuantity rdf:type rdf:Property ;
    rdfs:label 'Period Installed Quantity' ;
    rdfs:comment 'The incremental quantity of work physically installed during the current measurement period only (not cumulative). Used for production rate tracking and period-over-period productivity analysis in HCSS HeavyJob.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedQuantity rdf:type rdf:Property ;
    rdfs:label 'Planned Quantity' ;
    rdfs:comment 'The total planned or budgeted quantity for the WBS activity or BOQ line item as per the approved schedule and BOQ. Used as the denominator for quantity-based percent complete calculations and production rate analysis.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:previousPercentComplete rdf:type rdf:Property ;
    rdfs:label 'Previous Percent Complete' ;
    rdfs:comment 'The cumulative percent complete recorded in the immediately preceding measurement period for the same WBS activity or BOQ line item. Used to compute the incremental progress delta and validate that progress is monotonically increasing.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:progressDelta rdf:type rdf:Property ;
    rdfs:label 'Progress Delta' ;
    rdfs:comment 'The incremental percent complete gained in this measurement period, calculated as reported_percent_complete minus previous_percent_complete. Represents the period productivity for the activity and is used in period-based EVM reporting.' ;
    rdfs:domain ind:FieldProgress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Quantity Unit Of Measure' ;
    rdfs:comment 'The unit of measure applicable to the installed_quantity field (e.g., m3 for concrete, lm for linear metres of pipe, tonne for structural steel). Must align with the BOQ line item unit of measure. [ENUM-REF-CANDIDATE: m3|m2|lm|tonne|kg|nr|ls|hr|m — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rejectionReason rdf:type rdf:Property ;
    rdfs:label 'Rejection Reason' ;
    rdfs:comment 'Free-text explanation provided by the approver when a field progress measurement is rejected (approval_status = rejected). Documents the basis for rejection to guide the field engineer in correcting and resubmitting the measurement.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportedPercentComplete rdf:type rdf:Property ;
    rdfs:label 'Reported Percent Complete' ;
    rdfs:comment 'The cumulative percent complete for the WBS activity or BOQ line item as physically measured and reported by the field engineer at the time of this measurement. Expressed as a percentage (0.00–100.00). This is the ground-truth value used to compute BCWP in EVM.' ;
    rdfs:domain ind:FieldProgress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revisionNumber rdf:type rdf:Property ;
    rdfs:label 'Revision Number' ;
    rdfs:comment 'Sequential revision counter for this field progress measurement record. Increments each time the measurement is revised and resubmitted after rejection. Enables version tracking and audit trail of measurement history.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Submission Timestamp' ;
    rdfs:comment 'The date and time at which the field engineer submitted the progress measurement record for review and approval. Used to track measurement reporting timeliness and workflow cycle time.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:siteMobilizationId rdf:type rdf:Property ;
    rdfs:label 'Site Mobilization Id' ;
    rdfs:comment 'Unique surrogate identifier for the site mobilization record. Primary key for the site_mobilization data product in the Databricks Silver Layer.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SiteMobilization .

ind:clientContactId rdf:type rdf:Property ;
    rdfs:label 'Client Contact Id' ;
    rdfs:comment 'Foreign key linking to client.contact. Business justification: Site mobilization authorization in construction requires a named client contact (project manager, owner\'s representative) who approves NTP, site access, and mobilization sign-off. This FK enables mobi' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Contact .

ind:contractMilestoneId rdf:type rdf:Property ;
    rdfs:label 'Contract Milestone Id' ;
    rdfs:comment 'Foreign key linking to contract.contract_milestone. Business justification: Site mobilization is triggered by and must satisfy a specific contract milestone (NTP milestone, mobilization completion milestone). Linking enables milestone-driven mobilization tracking, advance pay' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ContractMilestone .

ind:envImpactAssessmentId rdf:type rdf:Property ;
    rdfs:label 'Env Impact Assessment Id' ;
    rdfs:comment 'Foreign key linking to compliance.env_impact_assessment. Business justification: Site mobilization is contingent on EIA approval — a named regulatory prerequisite in construction. Project managers and compliance teams track which approved EIA authorises each mobilization event. No' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EnvImpactAssessment .

ind:equipmentMobilizationId rdf:type rdf:Property ;
    rdfs:label 'Equipment Mobilization Id' ;
    rdfs:comment 'Foreign key linking to equipment.equipment_mobilization. Business justification: Site mobilization events trigger equipment mobilization events. Linking them enables coordinated mobilization scheduling, transport cost tracking, and NTP compliance reporting. Construction project ma' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EquipmentMobilization .

ind:planId rdf:type rdf:Property ;
    rdfs:label 'Plan Id' ;
    rdfs:comment 'Foreign key linking to quality.quality_plan. Business justification: Site Mobilization QA Gate: A quality plan must be approved before site mobilization proceeds. Project QA managers verify the governing quality plan is in place as a mobilization prerequisite — a stand' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Plan .

ind:primaveraActivityId rdf:type rdf:Property ;
    rdfs:label 'Primavera Activity Id' ;
    rdfs:comment 'Activity identifier from Oracle Primavera P6 corresponding to the mobilization WBS activity. Enables direct traceability between this mobilization record and the project schedule baseline.' ;
    rdfs:domain ind:SiteMobilization ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Activity .

ind:projectBudgetId rdf:type rdf:Property ;
    rdfs:label 'Project Budget Id' ;
    rdfs:comment 'Foreign key linking to finance.project_budget. Business justification: Mobilization is a distinct budget line item in construction project budgets. The site_mobilization.cost_budget references the authorized project budget allocation for mobilization expenditure. Constru' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProjectBudget .

ind:submissionId rdf:type rdf:Property ;
    rdfs:label 'Submission Id' ;
    rdfs:comment 'Foreign key linking to bid.bid_submission. Business justification: Mobilization plans are executed only after a bid is awarded; linking to the winning bid_submission enables cost tracking and audit of mobilization against the awarded contract.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Submission .

ind:accessRoadEstablished rdf:type rdf:Property ;
    rdfs:label 'Access Road Established' ;
    rdfs:comment 'Indicates whether the primary site access road and entry/exit gates have been constructed and are operational for heavy vehicle and workforce ingress/egress.' ;
    rdfs:domain ind:SiteMobilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:actualDemobilizationDate rdf:type rdf:Property ;
    rdfs:label 'Actual Demobilization Date' ;
    rdfs:comment 'Date on which site demobilization was physically completed and the site was vacated. Compared against planned_demobilization_date to assess demobilization schedule performance.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actualMobilizationDate rdf:type rdf:Property ;
    rdfs:label 'Actual Mobilization Date' ;
    rdfs:comment 'Date on which site mobilization physically commenced (first crew or equipment on site). Compared against planned_mobilization_date to compute mobilization schedule variance.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:buildingPermitNumber rdf:type rdf:Property ;
    rdfs:label 'Building Permit Number' ;
    rdfs:comment 'Reference number of the building or construction permit issued by the local authority. Required before commencement of structural works and tracked for regulatory compliance.' ;
    rdfs:domain ind:SiteMobilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costActual rdf:type rdf:Property ;
    rdfs:label 'Cost Actual' ;
    rdfs:comment 'Actual costs incurred for site mobilization activities as recorded in the job costing system (Viewpoint Vista / SAP S/4HANA). Used for cost variance analysis against mobilization_cost_budget.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costBudget rdf:type rdf:Property ;
    rdfs:label 'Cost Budget' ;
    rdfs:comment 'Approved budget allocated for site mobilization activities including site establishment, temporary facilities, equipment transport, and initial workforce deployment. Expressed in the project currency.' ;
    rdfs:domain ind:SiteMobilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:environmentalPermitNumber rdf:type rdf:Property ;
    rdfs:label 'Environmental Permit Number' ;
    rdfs:comment 'Reference number of the primary environmental permit issued by the regulatory authority (e.g., EPA NPDES permit number). Required for regulatory compliance tracking and audit.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:environmentalPermitObtained rdf:type rdf:Property ;
    rdfs:label 'Environmental Permit Obtained' ;
    rdfs:comment 'Indicates whether all required environmental permits and approvals (e.g., EPA stormwater NPDES permit, land disturbance permit) have been obtained prior to ground disturbance.' ;
    rdfs:domain ind:SiteMobilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hsePlanApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Hse Plan Approval Date' ;
    rdfs:comment 'Date on which the site HSE plan was formally approved by the HSE Manager and client representative. Required for regulatory compliance and Intelex HSE management system records.' ;
    rdfs:domain ind:SiteMobilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:hsePlanApproved rdf:type rdf:Property ;
    rdfs:label 'Hse Plan Approved' ;
    rdfs:comment 'Indicates whether the site-specific HSE plan has been reviewed and approved prior to mobilization commencement. Mandatory pre-mobilization gate per ISO 45001 and OSHA requirements.' ;
    rdfs:domain ind:SiteMobilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:laydownAreaEstablished rdf:type rdf:Property ;
    rdfs:label 'Laydown Area Established' ;
    rdfs:comment 'Indicates whether the designated materials laydown and storage area has been prepared, demarcated, and made operational for receiving deliveries and storing equipment.' ;
    rdfs:domain ind:SiteMobilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mobilizationNumber rdf:type rdf:Property ;
    rdfs:label 'Mobilization Number' ;
    rdfs:comment 'Externally-known business identifier for this mobilization record, used in correspondence, Procore daily logs, and Aconex transmittals. Follows the enterprise MOB-XXXXXX numbering convention.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mobilizationType rdf:type rdf:Property ;
    rdfs:label 'Mobilization Type' ;
    rdfs:comment 'Classification of the mobilization scope: full_site (complete site establishment), work_package (specific WBS package), temporary_camp (workforce accommodation), equipment_only (plant and machinery deployment), or partial (phased mobilization). [ENUM-REF-CANDIDATE: full_site|work_package|temporary_camp|equipment_only|partial|phased — promote to reference product]' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:peakWorkforceActual rdf:type rdf:Property ;
    rdfs:label 'Peak Workforce Actual' ;
    rdfs:comment 'Maximum number of workers (direct and subcontractor) actually recorded on site simultaneously during the mobilization period, as tracked in HCSS HeavyJob time records.' ;
    rdfs:domain ind:SiteMobilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:peakWorkforcePlanned rdf:type rdf:Property ;
    rdfs:label 'Peak Workforce Planned' ;
    rdfs:comment 'Maximum number of workers (direct and subcontractor) planned to be on site simultaneously at peak mobilization, as per the resource-loaded schedule in Oracle Primavera P6.' ;
    rdfs:domain ind:SiteMobilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:plannedDemobilizationDate rdf:type rdf:Property ;
    rdfs:label 'Planned Demobilization Date' ;
    rdfs:comment 'Baseline-scheduled date on which site demobilization was planned to be completed, as per the approved project schedule. Used for resource release planning and contract completion forecasting.' ;
    rdfs:domain ind:SiteMobilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:plannedMobilizationDate rdf:type rdf:Property ;
    rdfs:label 'Planned Mobilization Date' ;
    rdfs:comment 'Baseline-scheduled date on which site mobilization activities were planned to commence, as recorded in Oracle Primavera P6. Used for schedule variance analysis and earned value management (EVM).' ;
    rdfs:domain ind:SiteMobilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:procoreProjectReference rdf:type rdf:Property ;
    rdfs:label 'Procore Project Reference' ;
    rdfs:comment 'External system identifier for this site in Procore Construction Management platform. Used for cross-system reconciliation of daily logs, RFIs, and field management records.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleVarianceDays rdf:type rdf:Property ;
    rdfs:label 'Schedule Variance Days' ;
    rdfs:comment 'Number of calendar days difference between actual_mobilization_date and planned_mobilization_date. Positive value indicates delay; negative value indicates early mobilization. Used for schedule performance reporting.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:siteAddress rdf:type rdf:Property ;
    rdfs:label 'Site Address' ;
    rdfs:comment 'Physical street address or location description of the construction site. Used for logistics coordination, regulatory notifications, and emergency response planning.' ;
    rdfs:domain ind:SiteMobilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteAreaSqm rdf:type rdf:Property ;
    rdfs:label 'Site Area Sqm' ;
    rdfs:comment 'Total area of the construction site in square metres as defined in the site establishment plan. Used for site logistics planning, laydown area allocation, and HSE zone management.' ;
    rdfs:domain ind:SiteMobilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:siteClosureSignoffDate rdf:type rdf:Property ;
    rdfs:label 'Site Closure Signoff Date' ;
    rdfs:comment 'Date on which the formal site closure sign-off was completed by the client, engineer, and contractor, confirming all demobilization obligations have been fulfilled and the site has been restored.' ;
    rdfs:domain ind:SiteMobilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:siteFencingComplete rdf:type rdf:Property ;
    rdfs:label 'Site Fencing Complete' ;
    rdfs:comment 'Indicates whether site perimeter fencing and hoarding have been fully erected as part of site establishment. Key safety milestone required before workforce deployment.' ;
    rdfs:domain ind:SiteMobilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:siteLatitude rdf:type rdf:Property ;
    rdfs:label 'Site Latitude' ;
    rdfs:comment 'Geographic latitude coordinate of the construction site centroid in decimal degrees (WGS84). Supports GIS-based site mapping, logistics routing, and spatial analytics.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:siteLongitude rdf:type rdf:Property ;
    rdfs:label 'Site Longitude' ;
    rdfs:comment 'Geographic longitude coordinate of the construction site centroid in decimal degrees (WGS84). Supports GIS-based site mapping, logistics routing, and spatial analytics.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:siteOfficeEstablished rdf:type rdf:Property ;
    rdfs:label 'Site Office Established' ;
    rdfs:comment 'Indicates whether the temporary site office (including communications, IT infrastructure, and welfare facilities) has been established and is operational.' ;
    rdfs:domain ind:SiteMobilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:temporaryUtilitiesConnected rdf:type rdf:Property ;
    rdfs:label 'Temporary Utilities Connected' ;
    rdfs:comment 'Indicates whether temporary site utilities (power, water, telecommunications, sewage) have been connected and are operational. Prerequisite for sustained site operations.' ;
    rdfs:domain ind:SiteMobilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:equipmentDeploymentId rdf:type rdf:Property ;
    rdfs:label 'Equipment Deployment Id' ;
    rdfs:comment 'Unique surrogate identifier for each equipment deployment record in the site domain. Primary key for the equipment_deployment data product.' ;
    rdfs:domain ind:EquipmentDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fleetAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Fleet Assignment Id' ;
    rdfs:comment 'Foreign key linking to equipment.fleet_assignment. Business justification: Daily equipment deployment records must reference the governing fleet assignment to apply correct cost rates (owned/rental/standby), validate deployment is within assignment period, and produce equipm' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FleetAssignment .

ind:hcssEquipmentHoursId rdf:type rdf:Property ;
    rdfs:label 'Hcss Equipment Hours Id' ;
    rdfs:comment 'The source system record identifier from HCSS HeavyJob equipment hours module. Used for data lineage, reconciliation, and incremental load processing from the operational system of record.' ;
    rdfs:domain ind:EquipmentDeployment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Hours .

ind:maintenanceOrderId rdf:type rdf:Property ;
    rdfs:label 'Maintenance Order Id' ;
    rdfs:comment 'Foreign key linking to equipment.maintenance_order. Business justification: When equipment breaks down on site, a maintenance order is raised and linked to the deployment record for breakdown cost attribution, downtime tracking, and equipment availability reporting. maintenan' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MaintenanceOrder .

ind:operatorCertificationId rdf:type rdf:Property ;
    rdfs:label 'Operator Certification Id' ;
    rdfs:comment 'Foreign key linking to equipment.operator_certification. Business justification: WHS/OSHA regulations require construction sites to verify operator certifications before deploying equipment. Linking deployment to operator_certification enables compliance audit trails, licence expi' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OperatorCertification .

ind:operatorCraftWorkerId rdf:type rdf:Property ;
    rdfs:label 'Operator Craft Worker Id' ;
    rdfs:comment 'Foreign key linking to workforce.craft_worker. Business justification: Equipment operator certification compliance (license verification, OSHA requirements) and incident investigation require linking each equipment deployment to the specific craft_worker operator. operat' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CraftWorker .

ind:preStartInspectionRecordId rdf:type rdf:Property ;
    rdfs:label 'Pre Start Inspection Record Id' ;
    rdfs:comment 'Foreign key linking to equipment.inspection_record. Business justification: Construction regulations (WHS/OSHA) mandate pre-start equipment inspections before each shift deployment. Linking equipment_deployment to the specific inspection_record for that shift\'s pre-start chec' ;
    rdfs:domain ind:EquipmentDeployment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InspectionRecord .

ind:breakdownDescription rdf:type rdf:Property ;
    rdfs:label 'Breakdown Description' ;
    rdfs:comment 'Free-text description of the nature of the equipment breakdown or mechanical failure, as recorded by the site supervisor or equipment operator. Populated only when breakdown_flag is True.' ;
    rdfs:domain ind:EquipmentDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:breakdownFlag rdf:type rdf:Property ;
    rdfs:label 'Breakdown Flag' ;
    rdfs:comment 'Indicates whether the equipment experienced a mechanical breakdown or unplanned failure during this deployment period. True = breakdown occurred; False = no breakdown. Triggers maintenance workflow in SAP S/4HANA Plant Maintenance.' ;
    rdfs:domain ind:EquipmentDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:breakdownHours rdf:type rdf:Property ;
    rdfs:label 'Breakdown Hours' ;
    rdfs:comment 'Total number of hours the equipment was unavailable due to mechanical breakdown or unplanned maintenance during the shift or reporting period. Feeds into equipment reliability and maintenance KPI reporting.' ;
    rdfs:domain ind:EquipmentDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deploymentReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Deployment Reference Number' ;
    rdfs:comment 'Externally-known alphanumeric identifier for this equipment deployment record, as assigned in HCSS HeavyJob or the site daily log system. Used for cross-system traceability and field reporting.' ;
    rdfs:domain ind:EquipmentDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equipmentType rdf:type rdf:Property ;
    rdfs:label 'Equipment Type' ;
    rdfs:comment 'Classification of the equipment by functional category (e.g., Excavator, Bulldozer, Crane, Compactor, Concrete Pump, Dump Truck, Grader). Sourced from the equipment master but denormalized here for site-level reporting. [ENUM-REF-CANDIDATE: excavator|bulldozer|crane|compactor|concrete_pump|dump_truck|grader|loader|paver|roller|generator|pump|forklift|drill_rig — promote to reference product]' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fuelConsumptionLiters rdf:type rdf:Property ;
    rdfs:label 'Fuel Consumption Liters' ;
    rdfs:comment 'Total fuel consumed by the equipment during the shift or reporting period, measured in liters. Used for cost tracking, environmental reporting, and fuel efficiency benchmarking.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fuelType rdf:type rdf:Property ;
    rdfs:label 'Fuel Type' ;
    rdfs:comment 'Type of fuel consumed by the equipment. Used for environmental emissions reporting and fuel cost categorization.' ;
    rdfs:domain ind:EquipmentDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hourlyRate rdf:type rdf:Property ;
    rdfs:label 'Hourly Rate' ;
    rdfs:comment 'The contracted or internal charge rate for the equipment per operating hour, in the project currency. Used for job costing and cost-to-complete calculations. Confidential as it reflects commercial pricing.' ;
    rdfs:domain ind:EquipmentDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:idleHours rdf:type rdf:Property ;
    rdfs:label 'Idle Hours' ;
    rdfs:comment 'Total number of hours the equipment was on-site but not in productive operation (e.g., waiting for materials, weather delays, operator breaks). Idle hours are tracked separately from operating hours for utilization analysis.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:operatingHours rdf:type rdf:Property ;
    rdfs:label 'Operating Hours' ;
    rdfs:comment 'Total number of hours the equipment was in productive operation during the shift or reporting period. Used for earned value computation, equipment cost allocation, and maintenance scheduling.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownershipType rdf:type rdf:Property ;
    rdfs:label 'Ownership Type' ;
    rdfs:comment 'Indicates whether the deployed equipment is company-owned, rented from an external supplier, leased under a finance or operating lease, or provided by a subcontractor. Affects cost coding and financial treatment.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedProductionQuantity rdf:type rdf:Property ;
    rdfs:label 'Planned Production Quantity' ;
    rdfs:comment 'The target or budgeted production quantity for the equipment during this shift or reporting period, as derived from the project schedule and production plan. Enables variance analysis against actual production.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:preStartCheckFlag rdf:type rdf:Property ;
    rdfs:label 'Pre Start Check Flag' ;
    rdfs:comment 'Indicates whether a pre-start safety inspection was completed for the equipment prior to commencement of operations on this shift. True = pre-start check completed; False = not completed. Required for ISO 45001 and OSHA compliance.' ;
    rdfs:domain ind:EquipmentDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:productionQuantity rdf:type rdf:Property ;
    rdfs:label 'Production Quantity' ;
    rdfs:comment 'The measured quantity of work produced by the equipment during the shift or reporting period (e.g., cubic meters of earth moved, linear meters of paving laid, cubic meters of concrete poured). The unit is defined by production_unit_of_measure.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recordCreatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Record Created Timestamp' ;
    rdfs:comment 'The date and time when this equipment deployment record was first created in the system, in ISO 8601 format with timezone offset. Supports audit trail and data lineage requirements.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:recordUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Record Updated Timestamp' ;
    rdfs:comment 'The date and time when this equipment deployment record was last modified, in ISO 8601 format with timezone offset. Supports incremental data processing and audit trail requirements in the Databricks Silver Layer.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:releaseDate rdf:type rdf:Property ;
    rdfs:label 'Release Date' ;
    rdfs:comment 'The calendar date on which the equipment was released from the work front or activity and demobilized or reassigned. Null if the equipment is still actively deployed.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rentalOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Rental Order Number' ;
    rdfs:comment 'The Purchase Order (PO) or rental agreement reference number for externally rented or leased equipment. Links the deployment record to the procurement and accounts payable process.' ;
    rdfs:domain ind:EquipmentDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shiftDate rdf:type rdf:Property ;
    rdfs:label 'Shift Date' ;
    rdfs:comment 'The specific working date (shift date) for which this equipment utilization record is reported. Enables daily granularity within a multi-day deployment period.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:siteLocationDescription rdf:type rdf:Property ;
    rdfs:label 'Site Location Description' ;
    rdfs:comment 'Descriptive reference to the physical location on site where the equipment is deployed (e.g., \'Zone A — North Embankment\', \'Pier 3 Foundation\', \'Runway 2 Subbase\'). Supports spatial tracking and site logistics management.' ;
    rdfs:domain ind:EquipmentDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standbyHours rdf:type rdf:Property ;
    rdfs:label 'Standby Hours' ;
    rdfs:comment 'Total number of hours the equipment was on standby — available and ready but not assigned to active work. Relevant for contract billing where standby rates differ from operating rates.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:materialDeliveryId rdf:type rdf:Property ;
    rdfs:label 'Material Delivery Id' ;
    rdfs:comment 'Unique surrogate identifier for each material delivery receipt event recorded at the construction site. Primary key for this entity. Role: TRANSACTION_HEADER.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MaterialDelivery .

ind:goodsReceiptId rdf:type rdf:Property ;
    rdfs:label 'Goods Receipt Id' ;
    rdfs:comment 'Foreign key linking to procurement.goods_receipt. Business justification: Site delivery to procurement GR reconciliation: the site material_delivery record must be matched to the procurement goods_receipt for three-way match (PO→GR→site delivery), payment certification, and' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GoodsReceipt .

ind:goodsReceiptJobCostTransactionId rdf:type rdf:Property ;
    rdfs:label 'Goods Receipt Job Cost Transaction Id' ;
    rdfs:comment 'Foreign key linking to finance.job_cost_transaction. Business justification: Material deliveries (goods receipts) generate material cost transactions in the job cost ledger. The delivery_value and unit_rate on material_delivery are the basis for material cost postings. Role-pr' ;
    rdfs:domain ind:MaterialDelivery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:JobCostTransaction .

ind:materialMasterId rdf:type rdf:Property ;
    rdfs:label 'Material Master Id' ;
    rdfs:comment 'Foreign key linking to material.master. Business justification: Material delivery conformance and traceability process: site delivery dockets must be reconciled against approved material master records (conformance certificates, specification grade, shelf life). C' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Master .

ind:poLineId rdf:type rdf:Property ;
    rdfs:label 'Po Line Id' ;
    rdfs:comment 'Foreign key linking to procurement.po_line. Business justification: Delivery-to-PO-line quantity reconciliation: po_line_number is a denormalized plain-text field. A FK to po_line enables precise quantity matching (ordered vs. delivered vs. accepted) at line-item leve' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PoLine .

ind:primaryMaterialConstructionProjectId rdf:type rdf:Property ;
    rdfs:label 'Primary Material Construction Project Id' ;
    rdfs:comment 'Reference to the construction project to which this material delivery belongs. Links the physical receipt event to the project context for cost coding and earned value computation.' ;
    rdfs:domain ind:MaterialDelivery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ConstructionProject .

ind:primaryMaterialVendorId rdf:type rdf:Property ;
    rdfs:label 'Primary Material Vendor Id' ;
    rdfs:comment 'Reference to the supplier or vendor who delivered the materials. Links to the procurement domain supplier master for vendor performance tracking.' ;
    rdfs:domain ind:MaterialDelivery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vendor .

ind:receivingInspectorCraftWorkerId rdf:type rdf:Property ;
    rdfs:label 'Receiving Inspector Craft Worker Id' ;
    rdfs:comment 'Foreign key linking to workforce.craft_worker. Business justification: Material delivery ITP compliance and NCR traceability require identifying the named craft_worker who inspected and accepted/rejected each delivery. receiving_inspector is a denormalized text reference' ;
    rdfs:domain ind:MaterialDelivery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CraftWorker .

ind:batchNumber rdf:type rdf:Property ;
    rdfs:label 'Batch Number' ;
    rdfs:comment 'The manufacturer\'s batch or lot number for the delivered material. Critical for quality traceability, enabling recall or investigation of specific production batches if non-conformance is identified post-installation.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryDate rdf:type rdf:Property ;
    rdfs:label 'Delivery Date' ;
    rdfs:comment 'The calendar date on which the material physically arrived at the site gate or designated laydown area. This is the principal real-world event date for the delivery transaction, distinct from the PO expected delivery date.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:deliveryStatus rdf:type rdf:Property ;
    rdfs:label 'Delivery Status' ;
    rdfs:comment 'Current lifecycle status of the material delivery receipt event. Indicates whether the delivery was fully accepted, rejected at the gate, partially accepted, pending quality inspection, or placed on hold pending resolution of a discrepancy.' ;
    rdfs:domain ind:MaterialDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Delivery Timestamp' ;
    rdfs:comment 'The precise date and time at which the delivery vehicle arrived at the site gate or laydown area. Supports site logistics scheduling, gate management, and time-stamped audit trails.' ;
    rdfs:domain ind:MaterialDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:deliveryValue rdf:type rdf:Property ;
    rdfs:label 'Delivery Value' ;
    rdfs:comment 'The total monetary value of the accepted delivery, calculated as quantity_accepted multiplied by unit_rate. Used for goods receipt posting, cost accrual, and three-way matching against the supplier invoice. Expressed in the project currency.' ;
    rdfs:domain ind:MaterialDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:discrepancyNotes rdf:type rdf:Property ;
    rdfs:label 'Discrepancy Notes' ;
    rdfs:comment 'Free-text field capturing details of any discrepancy identified at the point of receipt, including quantity shortfalls, damage descriptions, specification mismatches, or incorrect materials. Used to support NCR (Non-Conformance Report) creation and supplier claims.' ;
    rdfs:domain ind:MaterialDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:docketNumber rdf:type rdf:Property ;
    rdfs:label 'Docket Number' ;
    rdfs:comment 'The externally-issued delivery docket or delivery note number provided by the supplier on the physical delivery documentation. Used as the primary business identifier for the delivery event and for three-way matching against the PO and invoice.' ;
    rdfs:domain ind:MaterialDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:driverName rdf:type rdf:Property ;
    rdfs:label 'Driver Name' ;
    rdfs:comment 'The name of the delivery driver as recorded on the delivery docket or site gate register. Captured for site security, access control, and delivery audit trail purposes.' ;
    rdfs:domain ind:MaterialDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Expected Delivery Date' ;
    rdfs:comment 'The date on which the delivery was originally scheduled or expected to arrive at site as per the Purchase Order (PO) or procurement schedule. Used to calculate delivery schedule variance and supplier on-time delivery performance.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:hazardousMaterial rdf:type rdf:Property ;
    rdfs:label 'Hazardous Material' ;
    rdfs:comment 'Indicates whether the delivered material is classified as hazardous under applicable regulations (e.g., chemicals, solvents, fuels, asbestos-containing materials). When True, triggers HSE compliance protocols including MSDS verification and segregated storage.' ;
    rdfs:domain ind:MaterialDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:laydownZone rdf:type rdf:Property ;
    rdfs:label 'Laydown Zone' ;
    rdfs:comment 'The designated receiving location or laydown area on the site logistics plan where the delivered material was stored upon receipt (e.g., \'Zone A - Steel Yard\', \'Zone C - Concrete Batching Area\'). Supports site logistics management and material traceability.' ;
    rdfs:domain ind:MaterialDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:msdsVerified rdf:type rdf:Property ;
    rdfs:label 'Msds Verified' ;
    rdfs:comment 'Indicates whether the Material Safety Data Sheet (MSDS) or Safety Data Sheet (SDS) was verified and on file at the time of receipt for hazardous materials. Required for OSHA HazCom compliance and site HSE management.' ;
    rdfs:domain ind:MaterialDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:quantityAccepted rdf:type rdf:Property ;
    rdfs:label 'Quantity Accepted' ;
    rdfs:comment 'The quantity of material formally accepted after inspection at the point of receipt. May be less than quantity_delivered in cases of partial acceptance due to damage, non-conformance, or specification mismatch. Triggers stock update in the materials domain.' ;
    rdfs:domain ind:MaterialDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityDelivered rdf:type rdf:Property ;
    rdfs:label 'Quantity Delivered' ;
    rdfs:comment 'The actual quantity of material physically received at the site as measured or counted at the point of receipt. This is the principal quantitative fact for the delivery event and is used to update material stock records and reconcile against the PO quantity.' ;
    rdfs:domain ind:MaterialDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityOrdered rdf:type rdf:Property ;
    rdfs:label 'Quantity Ordered' ;
    rdfs:comment 'The quantity of material that was ordered on the associated Purchase Order (PO) line for this delivery. Enables immediate over/under delivery variance calculation at the point of receipt without requiring a join to the procurement domain.' ;
    rdfs:domain ind:MaterialDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityRejected rdf:type rdf:Property ;
    rdfs:label 'Quantity Rejected' ;
    rdfs:comment 'The quantity of material rejected at the point of receipt due to damage, non-conformance with specification, or incorrect material. Triggers a Non-Conformance Report (NCR) and return-to-supplier process.' ;
    rdfs:domain ind:MaterialDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:receiptCondition rdf:type rdf:Property ;
    rdfs:label 'Receipt Condition' ;
    rdfs:comment 'The physical condition of the material as assessed at the point of receipt. Drives the acceptance/rejection decision and informs quality control processes. [ENUM-REF-CANDIDATE: good|damaged|wet|contaminated|incorrect_spec|short_delivered — promote to reference product]' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureSensitive rdf:type rdf:Property ;
    rdfs:label 'Temperature Sensitive' ;
    rdfs:comment 'Indicates whether the delivered material requires temperature-controlled storage conditions (e.g., epoxy resins, certain adhesives, bituminous products, or cold-chain materials). When True, triggers special handling and storage protocols on site.' ;
    rdfs:domain ind:MaterialDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:testCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Test Certificate Number' ;
    rdfs:comment 'The reference number of the material test certificate or mill certificate provided by the supplier with the delivery. Confirms that the material meets the specified engineering standards and is required for quality assurance sign-off.' ;
    rdfs:domain ind:MaterialDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitRate rdf:type rdf:Property ;
    rdfs:label 'Unit Rate' ;
    rdfs:comment 'The agreed unit price for the material as per the Purchase Order (PO), expressed in the project currency. Used to calculate the value of the delivery for goods receipt posting and cost accrual in the project financial management system.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vehicleRegistration rdf:type rdf:Property ;
    rdfs:label 'Vehicle Registration' ;
    rdfs:comment 'The registration plate number of the delivery vehicle. Recorded at the site gate for security, access control, and logistics tracking purposes.' ;
    rdfs:domain ind:MaterialDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:instructionId rdf:type rdf:Property ;
    rdfs:label 'Instruction Id' ;
    rdfs:comment 'Unique surrogate identifier for the site instruction record in the silver layer lakehouse. Primary key for this entity.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Instruction .

ind:authorityNoticeId rdf:type rdf:Property ;
    rdfs:label 'Authority Notice Id' ;
    rdfs:comment 'Foreign key linking to compliance.authority_notice. Business justification: A site instruction is formally issued in direct response to a regulatory authority notice (e.g., stop-work notice, EPA direction). Construction compliance registers require traceability from authority' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AuthorityNotice .

ind:changeNoticeId rdf:type rdf:Property ;
    rdfs:label 'Change Notice Id' ;
    rdfs:comment 'Foreign key linking to design.change_notice. Business justification: Site instructions often stem from formal change notices; linking tracks the originating change for audit.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ChangeNotice .

ind:ncrId rdf:type rdf:Property ;
    rdfs:label 'Ncr Id' ;
    rdfs:comment 'Foreign key linking to quality.ncr. Business justification: NCR-Triggered Instructions: Site instructions are formally issued in response to NCRs directing corrective work. Contract administrators and QA managers use this link to track instruction-to-NCR trace' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Ncr .

ind:projectChangeOrderId rdf:type rdf:Property ;
    rdfs:label 'Project Change Order Id' ;
    rdfs:comment 'Foreign key linking to project.project_change_order. Business justification: Site instructions frequently originate or result in change orders. Instruction-to-change-order traceability is a core contract administration process. instruction has cost_impact_flag and estimated_co' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProjectChangeOrder .

ind:regulatoryObligationId rdf:type rdf:Property ;
    rdfs:label 'Regulatory Obligation Id' ;
    rdfs:comment 'Foreign key linking to compliance.regulatory_obligation. Business justification: Site instructions are formally issued to implement or respond to specific regulatory obligations (e.g., heritage buffer compliance, noise mitigation). Compliance managers need this link to trace which' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RegulatoryObligation .

ind:rfiId rdf:type rdf:Property ;
    rdfs:label 'Rfi Id' ;
    rdfs:comment 'Foreign key linking to design.rfi. Business justification: Site instructions are frequently issued in direct response to RFIs (the engineer\'s formal response triggers an instruction to proceed). Contract administration workflows require tracing instruction→RF' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Rfi .

ind:aconexMailReference rdf:type rdf:Property ;
    rdfs:label 'Aconex Mail Reference' ;
    rdfs:comment 'Reference number of the formal correspondence or transmittal in the Aconex Document Management system through which this site instruction was officially transmitted to the contractor.' ;
    rdfs:domain ind:Instruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedWbsCode rdf:type rdf:Property ;
    rdfs:label 'Affected Wbs Code' ;
    rdfs:comment 'Work Breakdown Structure (WBS) code identifying the specific work package or activity affected by this site instruction. Enables cost and schedule impact traceability within the project control framework.' ;
    rdfs:domain ind:Instruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractorAcknowledgmentDate rdf:type rdf:Property ;
    rdfs:label 'Contractor Acknowledgment Date' ;
    rdfs:comment 'Date on which the contractor formally acknowledged receipt of the site instruction. Contractually significant as it starts the clock for contractor response obligations and EOT notice periods under FIDIC.' ;
    rdfs:domain ind:Instruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contractorDisputeFlag rdf:type rdf:Property ;
    rdfs:label 'Contractor Dispute Flag' ;
    rdfs:comment 'Indicates whether the contractor has formally disputed the validity, scope, or commercial basis of this site instruction, triggering the contract dispute resolution process.' ;
    rdfs:domain ind:Instruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contractorResponseDate rdf:type rdf:Property ;
    rdfs:label 'Contractor Response Date' ;
    rdfs:comment 'Actual date on which the contractor submitted their formal response or cost/time claim in relation to this site instruction. Used to assess compliance with contractual response obligations.' ;
    rdfs:domain ind:Instruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contractorResponseDueDate rdf:type rdf:Property ;
    rdfs:label 'Contractor Response Due Date' ;
    rdfs:comment 'Contractually required date by which the contractor must submit a formal response, cost estimate, or notice of claim in relation to this site instruction, calculated from the acknowledgment date per contract conditions.' ;
    rdfs:domain ind:Instruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:disputeReason rdf:type rdf:Property ;
    rdfs:label 'Dispute Reason' ;
    rdfs:comment 'Narrative description of the contractor\'s stated grounds for disputing this site instruction, captured for contract administration and potential adjudication or arbitration proceedings.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentRevision rdf:type rdf:Property ;
    rdfs:label 'Document Revision' ;
    rdfs:comment 'Revision identifier of the site instruction document, tracking amendments or superseding versions issued after the original. Supports document control and audit trail requirements.' ;
    rdfs:domain ind:Instruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedCostImpactAmount rdf:type rdf:Property ;
    rdfs:label 'Estimated Cost Impact Amount' ;
    rdfs:comment 'Preliminary estimated monetary value of the cost variation associated with this site instruction, expressed in the contract currency. Used for budget forecasting and change order (CO) initiation prior to formal valuation.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedTimeImpactDays rdf:type rdf:Property ;
    rdfs:label 'Estimated Time Impact Days' ;
    rdfs:comment 'Preliminary estimate of the number of calendar days by which this site instruction may extend the contract completion date, used for Extension of Time (EOT) assessment and CPM schedule analysis.' ;
    rdfs:domain ind:Instruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hseImplicationFlag rdf:type rdf:Property ;
    rdfs:label 'Hse Implication Flag' ;
    rdfs:comment 'Indicates whether this site instruction has Health, Safety, and Environment (HSE) implications requiring a Safe Work Method Statement (SWMS) update, permit to work review, or HSE authority notification before execution.' ;
    rdfs:domain ind:Instruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:implementationCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Implementation Completion Date' ;
    rdfs:comment 'Date on which the contractor completed execution of all work directed by the site instruction, enabling closure of the instruction and final cost/time impact confirmation.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:implementationStartDate rdf:type rdf:Property ;
    rdfs:label 'Implementation Start Date' ;
    rdfs:comment 'Date on which the contractor commenced execution of the work directed by the site instruction. Used for progress tracking and earned value computation.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:instructionDescription rdf:type rdf:Property ;
    rdfs:label 'Instruction Description' ;
    rdfs:comment 'Full narrative description of the work, method change, or site condition to be addressed as directed by the issuing authority. This is the primary contractual content of the instruction.' ;
    rdfs:domain ind:Instruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:instructionNumber rdf:type rdf:Property ;
    rdfs:label 'Instruction Number' ;
    rdfs:comment 'Externally-known alphanumeric reference number assigned to the site instruction by the issuing authority. Used for correspondence, filing, and cross-referencing with contract documents and RFIs. Format: SI-[ProjectCode]-[SequenceNumber].' ;
    rdfs:domain ind:Instruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:instructionStatus rdf:type rdf:Property ;
    rdfs:label 'Instruction Status' ;
    rdfs:comment 'Current workflow lifecycle status of the site instruction from issuance through contractor acknowledgment to implementation and closure. [ENUM-REF-CANDIDATE: draft|issued|acknowledged|under_review|implemented|closed|disputed|cancelled — promote to reference product]' ;
    rdfs:domain ind:Instruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:instructionType rdf:type rdf:Property ;
    rdfs:label 'Instruction Type' ;
    rdfs:comment 'Classification of the nature and purpose of the site instruction, determining the downstream contractual and commercial treatment. [ENUM-REF-CANDIDATE: variation_order|method_change|safety_directive|quality_directive|access_instruction|suspension|acceleration|remedial_work — promote to reference product]' ;
    rdfs:domain ind:Instruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingAuthorityRole rdf:type rdf:Property ;
    rdfs:label 'Issuing Authority Role' ;
    rdfs:comment 'Contractual role or designation of the person who issued the site instruction, determining the authority level and contractual validity of the instruction under the applicable contract conditions.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:physicalLocationDescription rdf:type rdf:Property ;
    rdfs:label 'Physical Location Description' ;
    rdfs:comment 'Textual description of the specific physical location, chainage, grid reference, or site zone where the instructed work is to be carried out, supporting field crew navigation and site logistics.' ;
    rdfs:domain ind:Instruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:procoreInstructionReference rdf:type rdf:Property ;
    rdfs:label 'Procore Instruction Reference' ;
    rdfs:comment 'Native identifier of this site instruction record in the Procore Construction Management system, used for data lineage, reconciliation, and integration with the source system of record.' ;
    rdfs:domain ind:Instruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityHoldRequired rdf:type rdf:Property ;
    rdfs:label 'Quality Hold Required' ;
    rdfs:comment 'Indicates whether a quality hold point or inspection is required before or after execution of the work directed by this site instruction, triggering an Inspection and Test Plan (ITP) checkpoint.' ;
    rdfs:domain ind:Instruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supersededByInstructionNumber rdf:type rdf:Property ;
    rdfs:label 'Superseded By Instruction Number' ;
    rdfs:comment 'Instruction number of the subsequent site instruction that supersedes or replaces this one, enabling version chain traceability in the instruction register.' ;
    rdfs:domain ind:Instruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timeImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Time Impact Flag' ;
    rdfs:comment 'Indicates whether the site instruction is expected to result in a schedule delay or Extension of Time (EOT) claim. When true, triggers schedule impact assessment in the project domain.' ;
    rdfs:domain ind:Instruction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:urgencyClassification rdf:type rdf:Property ;
    rdfs:label 'Urgency Classification' ;
    rdfs:comment 'Priority level assigned to the site instruction indicating the required response timeframe. Emergency instructions may require immediate contractor action to address safety or critical path impacts.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentId rdf:type rdf:Property ;
    rdfs:label 'Incident Id' ;
    rdfs:comment 'Foreign key linking to safety.incident. Business justification: REQUIRED: Shift reports record incidents during the shift; linking provides direct reference to the incident record.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Incident .

ind:primaryShiftConstructionProjectId rdf:type rdf:Property ;
    rdfs:label 'Primary Shift Construction Project Id' ;
    rdfs:comment 'Reference to the construction project this shift report belongs to. Links shift-level operational data to the parent project for earned value and cost control reporting.' ;
    rdfs:domain ind:ShiftReport ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ConstructionProject .

ind:supervisorCraftWorkerId rdf:type rdf:Property ;
    rdfs:label 'Supervisor Craft Worker Id' ;
    rdfs:comment 'Foreign key linking to workforce.craft_worker. Business justification: Shift reports require a named supervisor sign-off for contractual and HSE regulatory compliance. The supervisor_sign_off_timestamp exists but no FK identifies the signing craft_worker. Auditors and in' ;
    rdfs:domain ind:ShiftReport ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CraftWorker .

ind:activitiesNarrative rdf:type rdf:Property ;
    rdfs:label 'Activities Narrative' ;
    rdfs:comment 'Free-text description of the principal work activities performed during the shift, including scope completed, methods used, and notable observations. Sourced from HCSS HeavyJob field notes and Procore daily log entries.' ;
    rdfs:domain ind:ShiftReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:delayCause rdf:type rdf:Property ;
    rdfs:label 'Delay Cause' ;
    rdfs:comment 'Primary cause category for any delay experienced during the shift. Supports EOT claim substantiation, delay analysis, and root cause reporting. [ENUM-REF-CANDIDATE: weather|equipment_breakdown|material_shortage|access_restriction|design_change|labour_shortage|utility_conflict|other — promote to reference product]' ;
    rdfs:domain ind:ShiftReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:delayDurationHrs rdf:type rdf:Property ;
    rdfs:label 'Delay Duration Hrs' ;
    rdfs:comment 'Total hours of productive time lost during the shift due to delays (weather, equipment breakdown, material shortage, access restrictions, etc.). Used for Extension of Time (EOT) claims, Liquidated Damages (LD) assessment, and schedule impact analysis.' ;
    rdfs:domain ind:ShiftReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:equipmentUtilisationPct rdf:type rdf:Property ;
    rdfs:label 'Equipment Utilisation Pct' ;
    rdfs:comment 'Percentage of deployed equipment that was actively productive during the shift, calculated as productive equipment hours divided by total available equipment hours multiplied by 100. Key indicator for plant efficiency and idle cost identification.' ;
    rdfs:domain ind:ShiftReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:handoverNotes rdf:type rdf:Property ;
    rdfs:label 'Handover Notes' ;
    rdfs:comment 'Free-text notes prepared by the outgoing shift supervisor for the incoming shift team. Covers outstanding work, active risks, equipment status, pending permits, and critical instructions. Essential for 24-hour continuous operations continuity.' ;
    rdfs:domain ind:ShiftReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hcssShiftReference rdf:type rdf:Property ;
    rdfs:label 'Hcss Shift Reference' ;
    rdfs:comment 'Source system reference identifier from HCSS HeavyJob for this shift record. Enables bi-directional traceability between the lakehouse silver layer and the operational field management system for reconciliation and audit.' ;
    rdfs:domain ind:ShiftReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentCount rdf:type rdf:Property ;
    rdfs:label 'Incident Count' ;
    rdfs:comment 'Number of safety incidents (near misses, first aid, recordable, or Lost Time Injuries) that occurred during the shift. Distinct from safety observations. Triggers mandatory reporting to Intelex and regulatory notification under OSHA/ISO 45001.' ;
    rdfs:domain ind:ShiftReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:issuesCount rdf:type rdf:Property ;
    rdfs:label 'Issues Count' ;
    rdfs:comment 'Total number of open issues, constraints, or blockers identified during the shift that require resolution before or during the next shift. Drives issue escalation workflows and handover briefings.' ;
    rdfs:domain ind:ShiftReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ltiFlag rdf:type rdf:Property ;
    rdfs:label 'Lti Flag' ;
    rdfs:comment 'Indicates whether a Lost Time Injury (LTI) occurred during this shift. An LTI is a work-related injury or illness resulting in the worker being unable to return to work on the next scheduled shift. Triggers mandatory regulatory reporting and executive escalation.' ;
    rdfs:domain ind:ShiftReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:plannedEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Planned End Timestamp' ;
    rdfs:comment 'Scheduled end time for the shift as defined in the project schedule. Compared against shift_end_timestamp to measure shift overrun and overtime exposure.' ;
    rdfs:domain ind:ShiftReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:plannedStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Planned Start Timestamp' ;
    rdfs:comment 'Scheduled start time for the shift as defined in the project schedule. Compared against shift_start_timestamp to measure schedule adherence and identify mobilization delays.' ;
    rdfs:domain ind:ShiftReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:reportNumber rdf:type rdf:Property ;
    rdfs:label 'Report Number' ;
    rdfs:comment 'Externally-known alphanumeric identifier for the shift report, typically formatted as SR-[ProjectCode]-[Year]-[Sequence]. Used for document control, correspondence, and cross-system referencing in Procore and Aconex.' ;
    rdfs:domain ind:ShiftReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportStatus rdf:type rdf:Property ;
    rdfs:label 'Report Status' ;
    rdfs:comment 'Current workflow lifecycle state of the shift report. Tracks progression from field data entry (draft) through supervisor submission, review, and formal approval. Drives downstream integration with daily log consolidation.' ;
    rdfs:domain ind:ShiftReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyObservationCount rdf:type rdf:Property ;
    rdfs:label 'Safety Observation Count' ;
    rdfs:comment 'Number of HSE safety observations (positive or negative) recorded during the shift. Feeds into TRIR (Total Recordable Incident Rate) trending and Intelex HSE management reporting.' ;
    rdfs:domain ind:ShiftReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:shiftEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Shift End Timestamp' ;
    rdfs:comment 'Actual date and time when the shift concluded on site. Combined with shift_start_timestamp to derive total shift duration and labor hours. Null if shift is still in progress.' ;
    rdfs:domain ind:ShiftReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:shiftStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Shift Start Timestamp' ;
    rdfs:comment 'Actual date and time when the shift commenced on site. Principal business event timestamp for the shift lifecycle. Used for labor hour calculation, schedule adherence, and overtime analysis.' ;
    rdfs:domain ind:ShiftReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:supervisorSignOffTimestamp rdf:type rdf:Property ;
    rdfs:label 'Supervisor Sign Off Timestamp' ;
    rdfs:comment 'Date and time when the shift supervisor formally signed off and submitted the shift report. Marks the transition from draft to submitted status and initiates the review and approval workflow.' ;
    rdfs:domain ind:ShiftReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:totalHeadcount rdf:type rdf:Property ;
    rdfs:label 'Total Headcount' ;
    rdfs:comment 'Total number of all personnel on site during the shift, including direct labour, subcontractors, supervisors, and visitors. Used for site access control, emergency muster, and HSE compliance reporting.' ;
    rdfs:domain ind:ShiftReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalLabourHours rdf:type rdf:Property ;
    rdfs:label 'Total Labour Hours' ;
    rdfs:comment 'Total man-hours worked across all crew members during the shift, including direct labour and subcontractor labour. Core input for earned value management (EVM) cost performance index (CPI) calculations and labour productivity analysis.' ;
    rdfs:domain ind:ShiftReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:companyCodeId rdf:type rdf:Property ;
    rdfs:label 'Company Code Id' ;
    rdfs:comment 'Foreign key linking to finance.company_code. Business justification: Every construction project is executed under a specific legal entity (company code) for contract execution, tax reporting, and financial consolidation. This is a fundamental SAP PS relationship. Enabl' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CompanyCode .

ind:mainContractorVendorId rdf:type rdf:Property ;
    rdfs:label 'Main Contractor Vendor Id' ;
    rdfs:comment 'Foreign key linking to procurement.vendor. Business justification: Main EPC contractor assignment for each project; required for contract management, reporting, and regulatory compliance.' ;
    rdfs:domain ind:ConstructionProject ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vendor .

ind:primaryContactId rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Id' ;
    rdfs:comment 'Foreign key linking to client.contact. Business justification: Required for Project Communication Plan to identify primary client contact for status reports and issue escalation.' ;
    rdfs:domain ind:ConstructionProject ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Contact .

ind:actualCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Actual Completion Date' ;
    rdfs:comment 'Date on which the project achieved practical completion and was formally handed over to the client. Triggers the start of the DLP (Defects Liability Period) and final account settlement.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:approvedBudget rdf:type rdf:Property ;
    rdfs:label 'Approved Budget' ;
    rdfs:comment 'Total approved project budget including all cost codes, contingency, and approved change orders (CO). Used as the control budget for EVM (Earned Value Management) and cost performance index (CPI) calculations in SAP S/4HANA Project Systems.' ;
    rdfs:domain ind:ConstructionProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bidNumber rdf:type rdf:Property ;
    rdfs:label 'Bid Number' ;
    rdfs:comment 'Reference number of the original bid or tender submission (RFP/RFQ) from which this project was awarded. Links project execution back to the pre-award opportunity in Salesforce CRM for win/loss analytics.' ;
    rdfs:domain ind:ConstructionProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractNumber rdf:type rdf:Property ;
    rdfs:label 'Contract Number' ;
    rdfs:comment 'Formal contract reference number as issued by the client or legal department. Used for contract administration, correspondence tracking in Aconex, and legal reference in all formal project documentation.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cpi rdf:type rdf:Property ;
    rdfs:label 'Cpi' ;
    rdfs:comment 'EVM (Earned Value Management) Cost Performance Index (CPI) calculated as Earned Value divided by Actual Cost. A CPI below 1.0 indicates cost overrun. Updated monthly from SAP S/4HANA Project Systems and Oracle Primavera P6 progress data.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:forecastCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Forecast Completion Date' ;
    rdfs:comment 'Current forecast date for project completion based on latest schedule update and progress data from Oracle Primavera P6. Reflects approved EOT (Extension of Time) claims and current schedule performance.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isJointVenture rdf:type rdf:Property ;
    rdfs:label 'Is Joint Venture' ;
    rdfs:comment 'Indicates whether this project is being executed under a Joint Venture (JV) arrangement with one or more partner organisations. Affects financial consolidation, risk sharing, and governance reporting.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jvPartnerSharePct rdf:type rdf:Property ;
    rdfs:label 'Jv Partner Share Pct' ;
    rdfs:comment 'The company\'s ownership or participation percentage in the Joint Venture (JV) arrangement for this project. Used for financial consolidation, P&L (Profit and Loss) attribution, and EBITDA reporting. Null when is_joint_venture is False.' ;
    rdfs:domain ind:ConstructionProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:physicalProgressPct rdf:type rdf:Property ;
    rdfs:label 'Physical Progress Pct' ;
    rdfs:comment 'Overall physical percentage completion of the project as reported in the latest progress update from Oracle Primavera P6 and HCSS HeavyJob. Used for earned value calculations, client progress billing, and PMO dashboard reporting.' ;
    rdfs:domain ind:ConstructionProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Planned Completion Date' ;
    rdfs:comment 'Baseline planned completion date for the project as defined in the contract and approved schedule. Used for schedule variance analysis, LD (Liquidated Damages) exposure calculation, and EOT (Extension of Time) claim management.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pmoClassification rdf:type rdf:Property ;
    rdfs:label 'Pmo Classification' ;
    rdfs:comment 'PMO (Project Management Office) tier classification that determines the level of governance, reporting frequency, and executive oversight applied to the project. Tier 1 projects receive the highest level of PMO scrutiny.' ;
    rdfs:domain ind:ConstructionProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaveraProjectReference rdf:type rdf:Property ;
    rdfs:label 'Primavera Project Reference' ;
    rdfs:comment 'Native project identifier in Oracle Primavera P6 scheduling system. Used for cross-system data integration between the enterprise data platform and the scheduling system of record for activity, resource, and baseline data.' ;
    rdfs:domain ind:ConstructionProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectCode rdf:type rdf:Property ;
    rdfs:label 'Project Code' ;
    rdfs:comment 'Externally-known alphanumeric project identifier used across Oracle Primavera P6, SAP S/4HANA Project Systems, and Procore. Serves as the cross-system business key for project identification in all operational and financial systems.' ;
    rdfs:domain ind:ConstructionProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectName rdf:type rdf:Property ;
    rdfs:label 'Project Name' ;
    rdfs:comment 'Full descriptive name of the construction project as agreed with the client and used in all formal correspondence, contracts, and reporting.' ;
    rdfs:domain ind:ConstructionProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectStatus rdf:type rdf:Property ;
    rdfs:label 'Project Status' ;
    rdfs:comment 'Current lifecycle state of the construction project from prospect through to completion or cancellation. Drives PMO governance workflows and financial reporting eligibility.' ;
    rdfs:domain ind:ConstructionProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retentionPct rdf:type rdf:Property ;
    rdfs:label 'Retention Pct' ;
    rdfs:comment 'Contractual retention percentage withheld by the client from each progress payment certificate. Typically released in two tranches: at practical completion and at DLP (Defects Liability Period) expiry. Used in cash flow forecasting.' ;
    rdfs:domain ind:ConstructionProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sapProjectDefinition rdf:type rdf:Property ;
    rdfs:label 'Sap Project Definition' ;
    rdfs:comment 'SAP S/4HANA Project Systems project definition code (PS-DEF) that serves as the root WBS element for all cost postings, purchase orders, and financial transactions related to this project in the ERP system.' ;
    rdfs:domain ind:ConstructionProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:spi rdf:type rdf:Property ;
    rdfs:label 'Spi' ;
    rdfs:comment 'EVM (Earned Value Management) Schedule Performance Index (SPI) calculated as Earned Value divided by Planned Value. An SPI below 1.0 indicates schedule delay. Updated monthly from Oracle Primavera P6 progress reporting.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wbsCode rdf:type rdf:Property ;
    rdfs:label 'Wbs Code' ;
    rdfs:comment 'Top-level WBS (Work Breakdown Structure) code assigned to this project in Oracle Primavera P6 and SAP S/4HANA Project Systems. Serves as the hierarchical cost and schedule control framework root for all project activities.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignedWarehouseId rdf:type rdf:Property ;
    rdfs:label 'Assigned Warehouse Id' ;
    rdfs:comment 'Foreign key linking to material.warehouse. Business justification: Supports Site Staging Plan linking each WBS element to its dedicated staging warehouse.' ;
    rdfs:domain ind:WbsElement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Warehouse .

ind:parentWbsElementId rdf:type rdf:Property ;
    rdfs:label 'Parent Wbs Element Id' ;
    rdfs:comment 'Self-referencing identifier pointing to the immediate parent WBS node, enabling hierarchical decomposition of project scope. Null for root-level WBS elements.' ;
    rdfs:domain ind:WbsElement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WbsElement .

ind:actualCost rdf:type rdf:Property ;
    rdfs:label 'Actual Cost' ;
    rdfs:comment 'Total actual costs incurred to date for this WBS element, sourced from SAP S/4HANA job costing and Viewpoint Vista. Used as the ACWP input in EVM calculations.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualFinishDate rdf:type rdf:Property ;
    rdfs:label 'Actual Finish Date' ;
    rdfs:comment 'Date on which work on this WBS element was physically completed, as recorded in Oracle Primavera P6. Null if work is still in progress. Used for schedule performance reporting and DLP (Defects Liability Period) trigger.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actualQuantity rdf:type rdf:Property ;
    rdfs:label 'Actual Quantity' ;
    rdfs:comment 'Actual quantity of work completed and installed to date for this WBS element, as recorded in HCSS HeavyJob field production tracking. Compared against planned_quantity for production performance analysis.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvedBudgetChanges rdf:type rdf:Property ;
    rdfs:label 'Approved Budget Changes' ;
    rdfs:comment 'Cumulative value of approved Change Orders (CO) that have modified the original budget for this WBS element. Reconciles original_budget_cost to budgeted_cost.' ;
    rdfs:domain ind:WbsElement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:boqItemReference rdf:type rdf:Property ;
    rdfs:label 'Boq Item Reference' ;
    rdfs:comment 'Reference number or code linking this WBS element to the corresponding Bill of Quantities (BOQ) line item in the contract. Enables traceability between scope decomposition and contract pricing.' ;
    rdfs:domain ind:WbsElement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetedCost rdf:type rdf:Property ;
    rdfs:label 'Budgeted Cost' ;
    rdfs:comment 'Total approved budget allocated to this WBS element, representing the Budget at Completion (BAC) for EVM purposes. Expressed in the project currency. Forms the baseline for CPI and SPI calculations.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:chargeType rdf:type rdf:Property ;
    rdfs:label 'Charge Type' ;
    rdfs:comment 'Classification of costs associated with this WBS element: direct (billable to project scope), indirect (overhead allocation), overhead, contingency (risk reserve), or provisional (BOQ provisional sum). Affects cost reporting and contract billing.' ;
    rdfs:domain ind:WbsElement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costAccountCode rdf:type rdf:Property ;
    rdfs:label 'Cost Account Code' ;
    rdfs:comment 'Cost account or cost code assigned to this WBS element for job costing and financial reporting in SAP S/4HANA and Viewpoint Vista. Maps WBS scope to the chart of accounts for P&L reporting.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:csiDivisionCode rdf:type rdf:Property ;
    rdfs:label 'Csi Division Code' ;
    rdfs:comment 'CSI MasterFormat division code classifying the type of construction work for this WBS element (e.g., 03 = Concrete, 05 = Metals, 26 = Electrical). Enables industry-standard scope classification and benchmarking.' ;
    rdfs:domain ind:WbsElement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:earnedValue rdf:type rdf:Property ;
    rdfs:label 'Earned Value' ;
    rdfs:comment 'Budgeted cost of work actually performed to date for this WBS element (BCWP). Calculated as percent_complete multiplied by budgeted_cost. Core EVM metric used to derive CPI and SPI at the WBS level.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:evmEnabled rdf:type rdf:Property ;
    rdfs:label 'Evm Enabled' ;
    rdfs:comment 'Flag indicating whether this WBS element is included in the project\'s EVM (Earned Value Management) performance measurement baseline. Summary and planning package nodes may be excluded from direct EVM measurement.' ;
    rdfs:domain ind:WbsElement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isLumpSum rdf:type rdf:Property ;
    rdfs:label 'Is Lump Sum' ;
    rdfs:comment 'Flag indicating whether this WBS element is priced as a lump sum (fixed price) rather than a re-measurable unit-rate item. Affects billing, change order valuation, and BOQ reconciliation.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:originalBudgetCost rdf:type rdf:Property ;
    rdfs:label 'Original Budget Cost' ;
    rdfs:comment 'The initial approved budget for this WBS element at project baseline, before any approved change orders or budget transfers. Enables variance analysis between original and current budget.' ;
    rdfs:domain ind:WbsElement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:percentCompleteMethod rdf:type rdf:Property ;
    rdfs:label 'Percent Complete Method' ;
    rdfs:comment 'Method used to calculate percent complete for EVM purposes: physical (field measurement), units_complete (quantity-based), duration (time-proportional), weighted_milestone, level_of_effort, or fixed_formula (e.g., 0/100, 50/50). Configured in Oracle Primavera P6.' ;
    rdfs:domain ind:WbsElement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedValue rdf:type rdf:Property ;
    rdfs:label 'Planned Value' ;
    rdfs:comment 'Budgeted cost of work scheduled to be completed by the data date for this WBS element (BCWS). Derived from the time-phased budget baseline in Primavera P6. Used to compute Schedule Variance (SV) in EVM.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:responsibleDiscipline rdf:type rdf:Property ;
    rdfs:label 'Responsible Discipline' ;
    rdfs:comment 'Engineering or construction discipline accountable for executing this WBS element (e.g., Civil, Structural, MEP, Electrical, Mechanical, Instrumentation). Used for resource planning and discipline-level cost reporting.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sortOrder rdf:type rdf:Property ;
    rdfs:label 'Sort Order' ;
    rdfs:comment 'Numeric sequence defining the display order of this WBS element among its siblings within the same parent node. Used for consistent rendering in schedules, reports, and BOQ documents.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sourceSystemWbsReference rdf:type rdf:Property ;
    rdfs:label 'Source System Wbs Reference' ;
    rdfs:comment 'Native identifier of this WBS element in the originating operational system (e.g., Primavera P6 WBS Object ID, SAP PS WBS Element internal number). Supports data lineage and reconciliation between the lakehouse and source systems.' ;
    rdfs:domain ind:WbsElement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wbsLevel rdf:type rdf:Property ;
    rdfs:label 'Wbs Level' ;
    rdfs:comment 'Integer depth of the WBS node within the project hierarchy (Level 1 = project root, Level 2 = major deliverable, Level 3+ = sub-deliverable or work package). Used for hierarchical filtering, rollup aggregation, and reporting drill-down.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:wbsName rdf:type rdf:Property ;
    rdfs:label 'Wbs Name' ;
    rdfs:comment 'Human-readable name or title of the WBS element describing the scope deliverable or work package (e.g., \'Substructure Works\', \'Electrical Installation – Level 3\'). Used in reports, dashboards, and EVM analysis.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wbsStatus rdf:type rdf:Property ;
    rdfs:label 'Wbs Status' ;
    rdfs:comment 'Current lifecycle status of the WBS element indicating whether work is active, not yet started, on hold, completed, or cancelled. Drives EVM eligibility and cost control reporting.' ;
    rdfs:domain ind:WbsElement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wbsType rdf:type rdf:Property ;
    rdfs:label 'Wbs Type' ;
    rdfs:comment 'Classification of the WBS node by its role in the hierarchy: \'summary\' (rollup node), \'work_package\' (lowest deliverable-level node), \'control_account\' (EVM measurement point), or \'planning_package\' (future scope not yet detailed). Drives EVM rollup logic and cost control granularity.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownerContactId rdf:type rdf:Property ;
    rdfs:label 'Owner Contact Id' ;
    rdfs:comment 'Foreign key linking to client.contact. Business justification: Milestone owner contact needed for client notifications and acceptance sign-off per Milestone Management process.' ;
    rdfs:domain ind:ProjectMilestone ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Contact .

ind:predecessorMilestoneProjectMilestoneId rdf:type rdf:Property ;
    rdfs:label 'Predecessor Milestone Project Milestone Id' ;
    rdfs:comment 'Reference to the immediately preceding milestone in the project schedule logic chain. Supports Critical Path Method (CPM) analysis and schedule dependency tracking within the milestone network.' ;
    rdfs:domain ind:ProjectMilestone ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProjectMilestone .

ind:projectBaselineId rdf:type rdf:Property ;
    rdfs:label 'Project Baseline Id' ;
    rdfs:comment 'Foreign key linking to project.project_baseline. Business justification: Project milestones are defined against an approved baseline (baseline_date on milestone corresponds to a specific project_baseline revision). Adding project_baseline_id FK anchors each milestone to th' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProjectBaseline .

ind:acceptanceCriteria rdf:type rdf:Property ;
    rdfs:label 'Acceptance Criteria' ;
    rdfs:comment 'Formal criteria that must be satisfied for the milestone to be considered achieved and accepted by the client or engineer. May reference ITP (Inspection and Test Plan) requirements, regulatory sign-offs, or contractual deliverable submissions.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualDate rdf:type rdf:Property ;
    rdfs:label 'Actual Date' ;
    rdfs:comment 'The date on which the milestone was formally achieved and accepted. Populated only upon milestone completion and sign-off. Used for schedule variance calculation, contract administration, and LD (Liquidated Damages) trigger assessment.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:baselineDate rdf:type rdf:Property ;
    rdfs:label 'Baseline Date' ;
    rdfs:comment 'Approved contract baseline date for the milestone, which may differ from the original planned date if a formal baseline revision or approved EOT (Extension of Time) has been incorporated. Used as the contractual reference for LD (Liquidated Damages) exposure calculation.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:completionPercentage rdf:type rdf:Property ;
    rdfs:label 'Completion Percentage' ;
    rdfs:comment 'Percentage of work completed toward achieving this milestone, expressed as a value between 0.00 and 100.00. Updated during progress reporting cycles. Used for EVM (Earned Value Management) percent-complete calculations and schedule performance tracking.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:eotDaysApproved rdf:type rdf:Property ;
    rdfs:label 'Eot Days Approved' ;
    rdfs:comment 'Total number of calendar days of approved Extension of Time (EOT) granted for this milestone under the contract. Reflects cumulative approved EOT claims that have adjusted the baseline date. Zero if no EOT has been granted.' ;
    rdfs:domain ind:ProjectMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:eotReference rdf:type rdf:Property ;
    rdfs:label 'Eot Reference' ;
    rdfs:comment 'Reference number of the approved EOT (Extension of Time) claim or contract amendment that adjusted the baseline date for this milestone. Used for contract administration audit trail and dispute resolution.' ;
    rdfs:domain ind:ProjectMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forecastDate rdf:type rdf:Property ;
    rdfs:label 'Forecast Date' ;
    rdfs:comment 'Current best estimate of the date on which the milestone will be achieved, updated during schedule reviews and progress reporting cycles. Reflects schedule recovery plans, approved EOT (Extension of Time) claims, and current site conditions.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:hseClearanceRequired rdf:type rdf:Property ;
    rdfs:label 'Hse Clearance Required' ;
    rdfs:comment 'Indicates whether HSE (Health, Safety and Environment) regulatory clearance or permit is a prerequisite for achieving this milestone (e.g., commissioning milestones requiring OSHA or EPA sign-off). True = HSE clearance must be obtained before milestone can be marked complete.' ;
    rdfs:domain ind:ProjectMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isContractual rdf:type rdf:Property ;
    rdfs:label 'Is Contractual' ;
    rdfs:comment 'Indicates whether this milestone is a contractually obligated key date as defined in the project contract (FIDIC, GMP, or bespoke agreement). True = contractual obligation with potential LD (Liquidated Damages) or payment consequences; False = internal PMO or programme milestone.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isLdTrigger rdf:type rdf:Property ;
    rdfs:label 'Is Ld Trigger' ;
    rdfs:comment 'Indicates whether missing this milestone triggers Liquidated Damages (LD) as specified in the contract. True = LD clause applies upon delay; False = no LD exposure for this milestone. Critical for contract risk management and financial exposure reporting.' ;
    rdfs:domain ind:ProjectMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPaymentTrigger rdf:type rdf:Property ;
    rdfs:label 'Is Payment Trigger' ;
    rdfs:comment 'Indicates whether achievement of this milestone triggers a contractual payment event or progress payment certificate under the contract payment schedule. True = milestone completion initiates a payment claim or invoice; False = no direct payment linkage.' ;
    rdfs:domain ind:ProjectMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ldCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Ld Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the Liquidated Damages (LD) daily rate (e.g., USD, EUR, GBP, AED). Ensures correct financial exposure reporting in multi-currency international EPC projects.' ;
    rdfs:domain ind:ProjectMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ldRatePerDay rdf:type rdf:Property ;
    rdfs:label 'Ld Rate Per Day' ;
    rdfs:comment 'The contractually agreed daily monetary rate of Liquidated Damages (LD) applicable if this milestone is not achieved by the baseline date. Expressed in the project contract currency. Populated only when is_ld_trigger = True. Sensitive commercial data.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:leedRelated rdf:type rdf:Property ;
    rdfs:label 'Leed Related' ;
    rdfs:comment 'Indicates whether this milestone is associated with LEED (Leadership in Energy and Environmental Design) certification requirements or green building compliance deliverables. True = milestone contributes to LEED certification pathway.' ;
    rdfs:domain ind:ProjectMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:milestoneCategory rdf:type rdf:Property ;
    rdfs:label 'Milestone Category' ;
    rdfs:comment 'Functional category grouping the milestone within the EPC (Engineering, Procurement, and Construction) project lifecycle phase. Supports schedule performance analysis by phase and PMO reporting. [ENUM-REF-CANDIDATE: design|procurement|construction|commissioning|handover|safety|financial|administrative — promote to reference product]' ;
    rdfs:domain ind:ProjectMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:milestoneCode rdf:type rdf:Property ;
    rdfs:label 'Milestone Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying the milestone within the project schedule, as assigned in Oracle Primavera P6 (e.g., MS-NTP001, MS-MC001). Used for cross-system referencing and contract administration.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:milestoneName rdf:type rdf:Property ;
    rdfs:label 'Milestone Name' ;
    rdfs:comment 'Human-readable name of the milestone describing the key project event or deliverable (e.g., \'Notice to Proceed (NTP)\', \'Mechanical Completion\', \'Substantial Completion\', \'Final Handover\'). Used in schedule reports and contract documents.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:milestoneStatus rdf:type rdf:Property ;
    rdfs:label 'Milestone Status' ;
    rdfs:comment 'Current lifecycle state of the milestone tracking its progress toward completion. \'not_started\' = work not yet begun; \'in_progress\' = activities underway; \'completed\' = milestone achieved; \'overdue\' = past planned date without completion; \'waived\' = formally waived by contract amendment; \'deferred\' = postponed with approved EOT (Extension of Time).' ;
    rdfs:domain ind:ProjectMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:milestoneType rdf:type rdf:Property ;
    rdfs:label 'Milestone Type' ;
    rdfs:comment 'Classification of the milestone by its origin and obligation level. \'contractual\' = bound by contract terms (FIDIC/GMP); \'internal\' = PMO governance milestone; \'regulatory\' = required by OSHA/EPA/IBC; \'client\' = client-driven key date; \'financial\' = triggers payment or LD exposure.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationAdvanceDays rdf:type rdf:Property ;
    rdfs:label 'Notification Advance Days' ;
    rdfs:comment 'Number of calendar days in advance of the milestone date that formal notification must be issued to the client or engineer, as required by the contract. Applicable when notification_required = True. Supports contract compliance monitoring.' ;
    rdfs:domain ind:ProjectMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:notificationRequired rdf:type rdf:Property ;
    rdfs:label 'Notification Required' ;
    rdfs:comment 'Indicates whether formal written notification to the client or engineer is contractually required prior to or upon achievement of this milestone. True = notification obligation exists per contract; False = no formal notification required.' ;
    rdfs:domain ind:ProjectMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:paymentAmount rdf:type rdf:Property ;
    rdfs:label 'Payment Amount' ;
    rdfs:comment 'Contractual payment amount due upon achievement of this milestone, expressed in the project contract currency. Applicable only when is_payment_trigger = True. Used for cash flow forecasting and contract financial management.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedDate rdf:type rdf:Property ;
    rdfs:label 'Planned Date' ;
    rdfs:comment 'Original baseline date on which the milestone was scheduled to be achieved, as established at project kick-off or NTP (Notice to Proceed). Serves as the schedule baseline reference for variance analysis and SPI (Schedule Performance Index) calculation.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:procoreMilestoneReference rdf:type rdf:Property ;
    rdfs:label 'Procore Milestone Reference' ;
    rdfs:comment 'The corresponding milestone or schedule item identifier in Procore Construction Management platform. Supports cross-system reconciliation between the scheduling system of record (Primavera P6) and the construction management platform (Procore).' ;
    rdfs:domain ind:ProjectMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectMilestoneDescription rdf:type rdf:Property ;
    rdfs:label 'Project Milestone Description' ;
    rdfs:comment 'Detailed narrative description of the milestone, including the scope of work, acceptance criteria, and deliverables required to formally achieve the milestone. Sourced from the contract schedule or project execution plan.' ;
    rdfs:domain ind:ProjectMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsibleParty rdf:type rdf:Property ;
    rdfs:label 'Responsible Party' ;
    rdfs:comment 'The contracting party primarily responsible for achieving this milestone. Distinguishes between the General Contractor (GC), client, subcontractor, engineer/designer, Joint Venture (JV) partner, or regulatory authority. Critical for contract administration and risk allocation.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signOffDocumentRef rdf:type rdf:Property ;
    rdfs:label 'Sign Off Document Ref' ;
    rdfs:comment 'Reference number of the formal sign-off document, completion certificate, or taking-over certificate issued upon milestone achievement (e.g., Aconex document number, Procore submittal reference). Provides audit trail for contract administration and handover documentation.' ;
    rdfs:domain ind:ProjectMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalFloatDays rdf:type rdf:Property ;
    rdfs:label 'Total Float Days' ;
    rdfs:comment 'Total schedule float in calendar days available for this milestone before it impacts the project completion date, as calculated by the CPM (Critical Path Method) schedule engine in Oracle Primavera P6. Zero or negative float indicates critical or super-critical status.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:clientApproverContactId rdf:type rdf:Property ;
    rdfs:label 'Client Approver Contact Id' ;
    rdfs:comment 'Foreign key linking to client.contact. Business justification: Client baseline approval is a contractually binding event in construction. is_client_approved exists but no FK identifies which client contact approved it. Contract administration and audit processes ' ;
    rdfs:domain ind:Project ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Contact .

ind:approvalDate rdf:type rdf:Property ;
    rdfs:label 'Approval Date' ;
    rdfs:comment 'Calendar date on which the baseline was formally approved by the designated approving authority. Marks the effective start of the approved baseline for EVM measurement and PMO reporting.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalLevel rdf:type rdf:Property ;
    rdfs:label 'Approval Level' ;
    rdfs:comment 'Governance tier at which this baseline was approved, reflecting the authorization hierarchy. Higher-value or re-baseline revisions typically require elevated approval levels per PMO governance policy.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baselineNumber rdf:type rdf:Property ;
    rdfs:label 'Baseline Number' ;
    rdfs:comment 'Externally-known alphanumeric identifier for the baseline record, used in PMO reporting, EVM analysis, and audit documentation. Format: BL-{ProjectCode}-{SequenceNumber}.' ;
    rdfs:domain ind:ProjectBaseline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baselineStatus rdf:type rdf:Property ;
    rdfs:label 'Baseline Status' ;
    rdfs:comment 'Current lifecycle state of the baseline record within the PMO approval workflow. Draft baselines are under preparation; pending_approval awaits sign-off; approved is the active authorized baseline; superseded indicates a newer revision has replaced it; cancelled denotes a withdrawn baseline.' ;
    rdfs:domain ind:ProjectBaseline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baselineType rdf:type rdf:Property ;
    rdfs:label 'Baseline Type' ;
    rdfs:comment 'Classification of the baseline record indicating the nature of the snapshot: original (initial approved baseline), revised (minor scope/cost adjustment), re_baseline (full project re-baselining), co_incorporation (Change Order incorporated), re_forecast (updated forecast adopted as new baseline), management_reserve_release (management reserve funds released into budget).' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetAfterRevision rdf:type rdf:Property ;
    rdfs:label 'Budget After Revision' ;
    rdfs:comment 'Total approved budget amount immediately following this baseline revision. Together with budget_before_revision, provides the complete budget delta audit trail for PMO governance and financial audit requirements.' ;
    rdfs:domain ind:ProjectBaseline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetBeforeRevision rdf:type rdf:Property ;
    rdfs:label 'Budget Before Revision' ;
    rdfs:comment 'Total approved budget amount immediately prior to this baseline revision. Enables audit trail tracking of budget evolution and quantification of the budget delta introduced by each revision.' ;
    rdfs:domain ind:ProjectBaseline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coValueIncorporated rdf:type rdf:Property ;
    rdfs:label 'Co Value Incorporated' ;
    rdfs:comment 'Total monetary value of Change Orders (COs) incorporated into this baseline revision. Quantifies the cumulative scope change impact on the approved budget for audit trail and contract administration purposes.' ;
    rdfs:domain ind:ProjectBaseline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contingencyAmount rdf:type rdf:Property ;
    rdfs:label 'Contingency Amount' ;
    rdfs:comment 'Approved contingency reserve budget included within this baseline, allocated to cover identified project risks and uncertainties. Distinct from management reserve which is held outside the project baseline.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:durationDays rdf:type rdf:Property ;
    rdfs:label 'Duration Days' ;
    rdfs:comment 'Approved total duration of the project or WBS element in calendar days as captured in this baseline snapshot. Derived from baseline start and finish dates; stored explicitly for EVM schedule variance analysis and reporting.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:effectiveEndDate rdf:type rdf:Property ;
    rdfs:label 'Effective End Date' ;
    rdfs:comment 'Date on which this baseline was superseded by a subsequent revision or closed. Null if this is the currently active approved baseline. Supports audit trail and historical EVM analysis.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectiveStartDate rdf:type rdf:Property ;
    rdfs:label 'Effective Start Date' ;
    rdfs:comment 'Date from which this approved baseline becomes the active reference for EVM variance analysis and project performance measurement. Typically aligns with approval_date or the NTP (Notice to Proceed) date for original baselines.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:finishDate rdf:type rdf:Property ;
    rdfs:label 'Finish Date' ;
    rdfs:comment 'Approved planned finish date for the project or WBS element as captured in this baseline snapshot. Used as the schedule reference for SPI (Schedule Performance Index) calculation and milestone tracking.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isClientApproved rdf:type rdf:Property ;
    rdfs:label 'Is Client Approved' ;
    rdfs:comment 'Boolean flag indicating whether the client or owner has formally approved this baseline revision. Relevant for contract-driven baselines under FIDIC, GMP (Guaranteed Maximum Price), or EPC delivery models where client sign-off is contractually required.' ;
    rdfs:domain ind:ProjectBaseline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isCurrentBaseline rdf:type rdf:Property ;
    rdfs:label 'Is Current Baseline' ;
    rdfs:comment 'Boolean flag indicating whether this record represents the currently active approved baseline for the project or WBS element. Only one baseline per project/WBS should have this flag set to True at any point in time.' ;
    rdfs:domain ind:ProjectBaseline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:managementReserveAmount rdf:type rdf:Property ;
    rdfs:label 'Management Reserve Amount' ;
    rdfs:comment 'Management reserve budget held outside the project baseline for unknown unknowns, as authorized by senior management. Tracked separately from contingency reserve per EVM methodology. Populated when baseline_type is management_reserve_release.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:primaveraBaselineReference rdf:type rdf:Property ;
    rdfs:label 'Primavera Baseline Reference' ;
    rdfs:comment 'Source system identifier for this baseline record as assigned by Oracle Primavera P6. Enables traceability and reconciliation between the lakehouse Silver Layer and the operational scheduling system.' ;
    rdfs:domain ind:ProjectBaseline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revisionDate rdf:type rdf:Property ;
    rdfs:label 'Revision Date' ;
    rdfs:comment 'Calendar date on which the baseline revision was formally prepared and submitted for approval. Represents the point-in-time snapshot date for scope, schedule, and cost parameters.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:revisionJustification rdf:type rdf:Property ;
    rdfs:label 'Revision Justification' ;
    rdfs:comment 'Narrative explanation of the business reason for this baseline revision, including the drivers of scope, schedule, or cost changes. Required for PMO governance approval and financial audit documentation.' ;
    rdfs:domain ind:ProjectBaseline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapProjectVersion rdf:type rdf:Property ;
    rdfs:label 'Sap Project Version' ;
    rdfs:comment 'SAP S/4HANA Project Systems version identifier corresponding to this baseline snapshot. Used for reconciliation between the ERP project budget version and the Primavera schedule baseline.' ;
    rdfs:domain ind:ProjectBaseline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleDataDate rdf:type rdf:Property ;
    rdfs:label 'Schedule Data Date' ;
    rdfs:comment 'The data date (status date) of the Oracle Primavera P6 schedule from which this baseline snapshot was extracted. Defines the point-in-time reference for all schedule parameters captured in this record.' ;
    rdfs:domain ind:ProjectBaseline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:startDate rdf:type rdf:Property ;
    rdfs:label 'Start Date' ;
    rdfs:comment 'Approved planned start date for the project or WBS element as captured in this baseline snapshot. Used as the schedule reference for SPI (Schedule Performance Index) calculation and CPM (Critical Path Method) analysis.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:varianceAtCompletion rdf:type rdf:Property ;
    rdfs:label 'Variance At Completion' ;
    rdfs:comment 'Variance at Completion (VAC) — the difference between the Budget at Completion (BAC) and the Estimate at Completion (EAC) at the time this baseline was established. Provides a forward-looking cost performance indicator for PMO reporting.' ;
    rdfs:domain ind:ProjectBaseline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:progressMeasurementId rdf:type rdf:Property ;
    rdfs:label 'Progress Measurement Id' ;
    rdfs:comment 'Unique surrogate identifier for each periodic physical progress measurement record. Primary key for the progress_measurement data product in the project domain Silver layer.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProgressMeasurement .

ind:costAccountId rdf:type rdf:Property ;
    rdfs:label 'Cost Account Id' ;
    rdfs:comment 'Foreign key linking to project.cost_account. Business justification: Progress measurements capture physical progress at WBS/activity level, while cost accounts represent the control account intersection of WBS and cost code. Linking progress_measurement to cost_account' ;
    rdfs:domain ind:Project ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostAccount .

ind:progressUpdateId rdf:type rdf:Property ;
    rdfs:label 'Progress Update Id' ;
    rdfs:comment 'Foreign key linking to schedule.progress_update. Business justification: Monthly reporting in construction reconciles field-measured physical progress (progress_measurement) against schedule-tool-reported progress (progress_update). Linking them enables SPI variance analys' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProgressUpdate .

ind:billingPeriodReference rdf:type rdf:Property ;
    rdfs:label 'Billing Period Reference' ;
    rdfs:comment 'Reference identifier of the progress billing certificate or payment application period to which this measurement contributes (e.g., IPC-007, PA-2024-03). Links measurement data to the contract administration billing cycle.' ;
    rdfs:domain ind:ProgressMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costVariance rdf:type rdf:Property ;
    rdfs:label 'Cost Variance' ;
    rdfs:comment 'Difference between earned value and actual cost (EV minus AC) for this WBS element as of the measurement date. Negative value indicates cost overrun. Stored as a raw EVM (Earned Value Management) field, not a derived KPI.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:discipline rdf:type rdf:Property ;
    rdfs:label 'Discipline' ;
    rdfs:comment 'Engineering or construction discipline to which this WBS element or activity belongs (e.g., Civil, Structural, MEP (Mechanical Electrical Plumbing), Piping, Electrical, Instrumentation). Used for discipline-level progress roll-up reporting.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isBillingEligible rdf:type rdf:Property ;
    rdfs:label 'Is Billing Eligible' ;
    rdfs:comment 'Indicates whether this approved progress measurement qualifies for inclusion in a progress billing certificate or payment application (True/False). Controlled by measurement_status and contract billing terms.' ;
    rdfs:domain ind:ProgressMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:measurementSource rdf:type rdf:Property ;
    rdfs:label 'Measurement Source' ;
    rdfs:comment 'Originating operational system from which this progress measurement was sourced. Supports data lineage traceability across HCSS HeavyJob production tracking, Procore field management, and Oracle Primavera P6.' ;
    rdfs:domain ind:ProgressMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementStatus rdf:type rdf:Property ;
    rdfs:label 'Measurement Status' ;
    rdfs:comment 'Current workflow lifecycle state of the progress measurement record, from initial field capture through engineer verification to client approval. Controls eligibility for progress billing.' ;
    rdfs:domain ind:ProgressMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementType rdf:type rdf:Property ;
    rdfs:label 'Measurement Type' ;
    rdfs:comment 'Classifies whether this measurement record captures physical progress only, financial progress (cost-based), or a combined physical and financial assessment. Determines which EVM fields are populated.' ;
    rdfs:domain ind:ProgressMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedPercentComplete rdf:type rdf:Property ;
    rdfs:label 'Planned Percent Complete' ;
    rdfs:comment 'Baseline-scheduled percent complete for this WBS element or activity as of the measurement date, derived from the approved project baseline in Primavera P6. Used to compute SPI (Schedule Performance Index) variance.' ;
    rdfs:domain ind:ProgressMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reportingPeriodCode rdf:type rdf:Property ;
    rdfs:label 'Reporting Period Code' ;
    rdfs:comment 'Reference to the defined reporting period (weekly, monthly, or milestone-based) within which this progress measurement falls. Used for period-over-period EVM (Earned Value Management) analysis.' ;
    rdfs:domain ind:ProgressMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reportingPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Reporting Period End Date' ;
    rdfs:comment 'End date of the reporting period to which this progress measurement belongs. Defines the data cut-off for period progress billing and EVM (Earned Value Management) calculations.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reportingPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Reporting Period Start Date' ;
    rdfs:comment 'Start date of the reporting period to which this progress measurement belongs. Used to align measurements with EVM (Earned Value Management) data cut-off cycles.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scheduleVariance rdf:type rdf:Property ;
    rdfs:label 'Schedule Variance' ;
    rdfs:comment 'Difference between earned value and planned value (EV minus PV) for this WBS element as of the measurement date. Negative value indicates schedule delay. Stored as a raw EVM (Earned Value Management) field, not a derived KPI.' ;
    rdfs:domain ind:ProgressMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:verificationDate rdf:type rdf:Property ;
    rdfs:label 'Verification Date' ;
    rdfs:comment 'Date on which the verifying engineer formally approved and signed off this progress measurement record. Distinct from measurement_date (when field observation occurred) and created_timestamp (when record was entered).' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:verifierName rdf:type rdf:Property ;
    rdfs:label 'Verifier Name' ;
    rdfs:comment 'Full name of the engineer or site supervisor who physically verified and signed off this progress measurement. Retained for audit trail and contractual accountability under FIDIC and ISO 9001 requirements.' ;
    rdfs:domain ind:ProgressMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workArea rdf:type rdf:Property ;
    rdfs:label 'Work Area' ;
    rdfs:comment 'Physical site area, zone, or work front where the measured work is being performed (e.g., Zone A, Block 3, Pier 7). Aligns with site work front definitions used in HCSS HeavyJob and Procore daily logs.' ;
    rdfs:domain ind:ProgressMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractChangeOrderId rdf:type rdf:Property ;
    rdfs:label 'Contract Change Order Id' ;
    rdfs:comment 'Foreign key linking to contract.contract_change_order. Business justification: Required for the Change Order Management process: each project change order must reference the contract change order that amends the agreement, enabling cost/schedule impact tracking.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ContractChangeOrder .

ind:aconexMailRef rdf:type rdf:Property ;
    rdfs:label 'Aconex Mail Ref' ;
    rdfs:comment 'Aconex correspondence or transmittal reference number for the formal change order submission and approval correspondence. Provides document management traceability.' ;
    rdfs:domain ind:ProjectChangeOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetLineItemRef rdf:type rdf:Property ;
    rdfs:label 'Budget Line Item Ref' ;
    rdfs:comment 'Reference to the project budget line item or BOQ (Bill of Quantities) item that this change order modifies. Enables budget impact tracking at line-item level.' ;
    rdfs:domain ind:ProjectChangeOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeType rdf:type rdf:Property ;
    rdfs:label 'Change Type' ;
    rdfs:comment 'Classification of the nature of the change. Drives cost and schedule impact analysis and reporting. [ENUM-REF-CANDIDATE: scope_addition|scope_reduction|design_change|unforeseen_condition|client_directive|regulatory_change — promote to reference product]' ;
    rdfs:domain ind:ProjectChangeOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coNumber rdf:type rdf:Property ;
    rdfs:label 'Co Number' ;
    rdfs:comment 'Externally-visible sequential identifier for the change order as issued on the project (e.g., CO-00042). Used in all formal correspondence, contract administration, and client reporting.' ;
    rdfs:domain ind:ProjectChangeOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contingencyDrawnAmount rdf:type rdf:Property ;
    rdfs:label 'Contingency Drawn Amount' ;
    rdfs:comment 'Amount drawn from the project contingency reserve to fund this change order, if applicable. Tracks contingency consumption at the CO level for project financial management.' ;
    rdfs:domain ind:ProjectChangeOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contractClauseReference rdf:type rdf:Property ;
    rdfs:label 'Contract Clause Reference' ;
    rdfs:comment 'Specific contract clause or FIDIC sub-clause under which the change order is raised (e.g., \'FIDIC Clause 13.1 — Right to Vary\'). Establishes contractual entitlement.' ;
    rdfs:domain ind:Project ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costImpactAmount rdf:type rdf:Property ;
    rdfs:label 'Cost Impact Amount' ;
    rdfs:comment 'Net monetary value of the change order representing the increase (positive) or decrease (negative) to the contract sum. Expressed in the contract currency. Core component of the MONETARY_TRIPLET for this transaction.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costImpactCurrency rdf:type rdf:Property ;
    rdfs:label 'Cost Impact Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the cost impact amount (e.g., USD, EUR, GBP). Required for multi-currency project environments.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:directCostAmount rdf:type rdf:Property ;
    rdfs:label 'Direct Cost Amount' ;
    rdfs:comment 'Direct labour, material, and equipment cost component of the change order before overhead and profit mark-up. Used for cost breakdown analysis and BOQ reconciliation.' ;
    rdfs:domain ind:ProjectChangeOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:drawingRevision rdf:type rdf:Property ;
    rdfs:label 'Drawing Revision' ;
    rdfs:comment 'Drawing revision number or BIM (Building Information Modeling) model version that forms the basis of the change order scope. Ensures design traceability.' ;
    rdfs:domain ind:ProjectChangeOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eotGrantedDays rdf:type rdf:Property ;
    rdfs:label 'Eot Granted Days' ;
    rdfs:comment 'Number of calendar days of Extension of Time formally approved and granted by the engineer or owner in response to this change order. May differ from the claimed schedule impact.' ;
    rdfs:domain ind:ProjectChangeOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isDisputed rdf:type rdf:Property ;
    rdfs:label 'Is Disputed' ;
    rdfs:comment 'Indicates whether the change order is subject to a formal dispute or claim between the contractor and the client/owner. True if disputed; False if agreed.' ;
    rdfs:domain ind:ProjectChangeOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isLdApplicable rdf:type rdf:Property ;
    rdfs:label 'Is Ld Applicable' ;
    rdfs:comment 'Indicates whether Liquidated Damages (LD) provisions are applicable to this change order in the event of delay. Relevant for schedule-impacting COs.' ;
    rdfs:domain ind:ProjectChangeOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:originator rdf:type rdf:Property ;
    rdfs:label 'Originator' ;
    rdfs:comment 'Party who initiated or originated the change order request. Determines contractual entitlement and responsibility for cost and schedule impacts.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overheadAndProfitAmount rdf:type rdf:Property ;
    rdfs:label 'Overhead And Profit Amount' ;
    rdfs:comment 'Overhead and profit mark-up applied to the direct cost to arrive at the total cost impact. Expressed in the contract currency.' ;
    rdfs:domain ind:ProjectChangeOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priority rdf:type rdf:Property ;
    rdfs:label 'Priority' ;
    rdfs:comment 'Business priority assigned to the change order indicating urgency of processing and approval. Critical COs may be on the critical path and require expedited approval.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:procoreCoReference rdf:type rdf:Property ;
    rdfs:label 'Procore Co Reference' ;
    rdfs:comment 'Native change order identifier from the Procore Construction Management system. Used for data lineage, source system traceability, and reconciliation between the lakehouse and Procore.' ;
    rdfs:domain ind:ProjectChangeOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectChangeOrderDescription rdf:type rdf:Property ;
    rdfs:label 'Project Change Order Description' ;
    rdfs:comment 'Detailed narrative describing the scope of work added, reduced, or modified by this change order. Captures the full business justification and technical scope.' ;
    rdfs:domain ind:ProjectChangeOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reasonCode rdf:type rdf:Property ;
    rdfs:label 'Reason Code' ;
    rdfs:comment 'Standardised reason code categorising the root cause of the change (e.g., design error, owner-directed, differing site conditions, regulatory). Supports trend analysis and lessons learned. [ENUM-REF-CANDIDATE: design_error|owner_directed|differing_site_conditions|regulatory|scope_gap|value_engineering|force_majeure — promote to reference product]' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapCoDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Co Document Number' ;
    rdfs:comment 'SAP S/4HANA project system document number generated when the approved change order is posted to the financial ledger. Enables reconciliation between project management and ERP.' ;
    rdfs:domain ind:ProjectChangeOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleImpactDays rdf:type rdf:Property ;
    rdfs:label 'Schedule Impact Days' ;
    rdfs:comment 'Number of calendar days of Extension of Time (EOT) claimed or granted as a result of this change order. Positive value indicates delay; negative indicates acceleration. Zero if no schedule impact.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:scopeOfWorkSummary rdf:type rdf:Property ;
    rdfs:label 'Scope Of Work Summary' ;
    rdfs:comment 'Concise summary of the physical scope of work added, removed, or modified by this change order. Complements the detailed description for executive reporting and CO registers.' ;
    rdfs:domain ind:ProjectChangeOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submittedDate rdf:type rdf:Property ;
    rdfs:label 'Submitted Date' ;
    rdfs:comment 'Calendar date on which the change order was formally submitted to the client or owner for review and approval. Triggers contractual response timelines per FIDIC.' ;
    rdfs:domain ind:ProjectChangeOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:glAccountId rdf:type rdf:Property ;
    rdfs:label 'Gl Account Id' ;
    rdfs:comment 'Foreign key linking to finance.gl_account. Business justification: Construction ERP systems (SAP PS) require cost accounts to map directly to GL accounts for actual cost posting and financial close. The cost_account.gl_account_code is a denormalized reference. A prop' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GlAccount .

ind:accountDescription rdf:type rdf:Property ;
    rdfs:label 'Account Description' ;
    rdfs:comment 'Human-readable description of the cost account scope, such as \'Structural Concrete — Foundation Works\' or \'MEP Subcontract — Electrical Rough-In\'. Used in cost reports, BOQ reconciliation, and EVM reporting.' ;
    rdfs:domain ind:CostAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualCostAmount rdf:type rdf:Property ;
    rdfs:label 'Actual Cost Amount' ;
    rdfs:comment 'Total actual cost incurred and posted to this cost account to date, including paid invoices, posted labor timesheets, and equipment charges. Equivalent to Actual Cost of Work Performed (ACWP) in EVM. Sourced from SAP S/4HANA FI/CO and Viewpoint Vista job cost ledger.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvedBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Approved Budget Amount' ;
    rdfs:comment 'Current approved budget for this cost account inclusive of all approved Change Orders (COs). Equivalent to Budget at Completion (BAC) in EVM terminology. Updated each time a CO is approved and posted to the cost account. The primary budget control figure used by project cost controllers.' ;
    rdfs:domain ind:CostAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:baselineFinishDate rdf:type rdf:Property ;
    rdfs:label 'Baseline Finish Date' ;
    rdfs:comment 'Planned completion date for the scope of work associated with this cost account as established in the approved project baseline schedule. Used for schedule performance tracking and Earned Value Management (EVM) analysis.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:baselineStartDate rdf:type rdf:Property ;
    rdfs:label 'Baseline Start Date' ;
    rdfs:comment 'Planned start date for the scope of work associated with this cost account as established in the approved project baseline schedule. Used for Planned Value (PV) calculation and schedule variance analysis in EVM reporting.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:budgetUnitRate rdf:type rdf:Property ;
    rdfs:label 'Budget Unit Rate' ;
    rdfs:comment 'Budgeted cost per unit of measure for this cost account (Approved Budget divided by Budgeted Quantity). Used for unit rate benchmarking, bid analysis, and productivity monitoring. Expressed in the cost account currency per unit of measure.' ;
    rdfs:domain ind:CostAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:changeOrderAmount rdf:type rdf:Property ;
    rdfs:label 'Change Order Amount' ;
    rdfs:comment 'Cumulative value of all approved Change Orders (COs) posted to this cost account. Represents the delta between the original budget and the current approved budget. Tracked separately to support contract administration and CO impact analysis.' ;
    rdfs:domain ind:CostAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:committedCostAmount rdf:type rdf:Property ;
    rdfs:label 'Committed Cost Amount' ;
    rdfs:comment 'Total value of contractual commitments against this cost account, including issued Purchase Orders (POs) and subcontract awards not yet invoiced. Represents financial obligations that will become actual costs. Critical for cash flow forecasting and cost-to-complete analysis.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costCenterCode rdf:type rdf:Property ;
    rdfs:label 'Cost Center Code' ;
    rdfs:comment 'SAP Cost Center code associated with this cost account, representing the organizational unit responsible for the costs. Used for overhead allocation, departmental P&L reporting, and internal charge-back processes.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costToCompleteAmount rdf:type rdf:Property ;
    rdfs:label 'Cost To Complete Amount' ;
    rdfs:comment 'Estimated remaining cost required to complete the scope of work for this cost account. Calculated as Forecast Cost at Completion minus Actual Cost to Date. Used by cost controllers to project future cash requirements and update project financial forecasts.' ;
    rdfs:domain ind:CostAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costType rdf:type rdf:Property ;
    rdfs:label 'Cost Type' ;
    rdfs:comment 'Primary classification of the cost account by resource type: labor (direct workforce), material (permanent and consumable materials), equipment (plant and machinery), subcontract (third-party subcontractor scope), or overhead (indirect project costs). Drives cost segregation in EVM and P&L reporting.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costVarianceAmount rdf:type rdf:Property ;
    rdfs:label 'Cost Variance Amount' ;
    rdfs:comment 'Variance between the approved budget and the forecast cost at completion for this cost account (Approved Budget minus Forecast Cost at Completion). A negative value indicates a cost overrun; positive indicates an underspend. Key metric for project cost control reporting and PMO governance.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:earnedValueAmount rdf:type rdf:Property ;
    rdfs:label 'Earned Value Amount' ;
    rdfs:comment 'Budgeted cost of work performed (BCWP) for this cost account, representing the value of completed work expressed in budget terms. Core EVM metric used to calculate Cost Performance Index (CPI) and Schedule Performance Index (SPI) at the cost account level.' ;
    rdfs:domain ind:CostAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:forecastCostAtCompletion rdf:type rdf:Property ;
    rdfs:label 'Forecast Cost At Completion' ;
    rdfs:comment 'Project cost controller\'s current best estimate of the total cost to complete this cost account, including actual costs to date plus estimated cost to complete (ETC). Equivalent to Estimate at Completion (EAC) in EVM. Updated periodically during project cost reviews.' ;
    rdfs:domain ind:CostAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:forecastStartDate rdf:type rdf:Property ;
    rdfs:label 'Forecast Start Date' ;
    rdfs:comment 'Current forecast start date for the scope of work associated with this cost account, updated during project schedule reviews. Compared against the baseline start date to identify schedule slippage and its cost impact.' ;
    rdfs:domain ind:CostAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isSubcontractScope rdf:type rdf:Property ;
    rdfs:label 'Is Subcontract Scope' ;
    rdfs:comment 'Indicates whether the scope of work for this cost account is executed by a subcontractor (True) or by the General Contractor\'s (GC) own forces (False). Drives subcontract management workflows, retention tracking, and payment certification processes.' ;
    rdfs:domain ind:CostAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:originalBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Original Budget Amount' ;
    rdfs:comment 'The baseline budget amount for this cost account as established at project sanction or Notice to Proceed (NTP). Represents the original authorized cost plan before any Change Orders (COs). Immutable once the baseline is locked. Used as the denominator for variance analysis and EVM performance measurement.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedValueAmount rdf:type rdf:Property ;
    rdfs:label 'Planned Value Amount' ;
    rdfs:comment 'Budgeted cost of work scheduled (BCWS) for this cost account as of the reporting data date. Represents the cumulative planned spend per the project baseline schedule. Used with Earned Value to compute Schedule Variance (SV) and SPI.' ;
    rdfs:domain ind:CostAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityActual rdf:type rdf:Property ;
    rdfs:label 'Quantity Actual' ;
    rdfs:comment 'Actual quantity of work completed and posted against this cost account to date. Compared against budgeted quantity to assess production efficiency and unit cost performance. Sourced from HCSS HeavyJob production entries and field daily logs.' ;
    rdfs:domain ind:CostAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityBudgeted rdf:type rdf:Property ;
    rdfs:label 'Quantity Budgeted' ;
    rdfs:comment 'Original budgeted quantity of work for this cost account as derived from the Bill of Quantities (BOQ) or Material Take-Off (MTO). Expressed in the unit of measure applicable to the cost type (e.g., m3 for concrete, tonnes for steel, hours for labor). Enables unit rate analysis and productivity benchmarking.' ;
    rdfs:domain ind:CostAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reportingPeriodDate rdf:type rdf:Property ;
    rdfs:label 'Reporting Period Date' ;
    rdfs:comment 'The data date or cut-off date as of which the cost account financial figures (actual cost, earned value, planned value, forecast) are reported. Aligns with the project monthly cost report cycle and EVM data date in Oracle Primavera P6.' ;
    rdfs:domain ind:CostAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:deliverableId rdf:type rdf:Property ;
    rdfs:label 'Deliverable Id' ;
    rdfs:comment 'Unique surrogate identifier for the project deliverable record in the silver layer lakehouse. Primary key for this entity.' ;
    rdfs:domain ind:Deliverable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:itpId rdf:type rdf:Property ;
    rdfs:label 'Itp Id' ;
    rdfs:comment 'Foreign key linking to quality.itp. Business justification: Deliverable acceptance is gated on ITP completion in construction. The existing itp_reference is a plain-text denormalization of the ITP entity; replacing it with a proper FK enforces 3NF and enables ' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Itp .

ind:responsibleContactId rdf:type rdf:Property ;
    rdfs:label 'Responsible Contact Id' ;
    rdfs:comment 'Foreign key linking to client.contact. Business justification: Deliverable responsibility is assigned to a client contact to manage approvals and handover per Deliverable Acceptance process.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Contact .

ind:submittalId rdf:type rdf:Property ;
    rdfs:label 'Submittal Id' ;
    rdfs:comment 'Foreign key linking to design.design_submittal. Business justification: Project deliverables are formally submitted for client approval via design submittals. A construction document controller tracks which submittal fulfills each contractual deliverable for contract clos' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Submittal .

ind:transmittalId rdf:type rdf:Property ;
    rdfs:label 'Transmittal Id' ;
    rdfs:comment 'Foreign key linking to design.transmittal. Business justification: Deliverables are formally issued to clients via transmittals. A document controller tracks which transmittal formally submitted each deliverable for contract compliance and audit. deliverable.transmit' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Transmittal .

ind:acceptanceDate rdf:type rdf:Property ;
    rdfs:label 'Acceptance Date' ;
    rdfs:comment 'Date on which the deliverable was formally accepted by the client or approving authority. Used for handover milestone tracking and DLP commencement.' ;
    rdfs:domain ind:Deliverable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:acceptanceStatus rdf:type rdf:Property ;
    rdfs:label 'Acceptance Status' ;
    rdfs:comment 'Client or reviewer acceptance status of the deliverable following formal review. Indicates whether the deliverable has been accepted, accepted with comments, or rejected and requires resubmission.' ;
    rdfs:domain ind:Deliverable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualIssueDate rdf:type rdf:Property ;
    rdfs:label 'Actual Issue Date' ;
    rdfs:comment 'Date on which the deliverable was actually issued or transmitted. Populated upon completion and used to calculate schedule variance and support DLP (Defects Liability Period) tracking.' ;
    rdfs:domain ind:Deliverable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:comments rdf:type rdf:Property ;
    rdfs:label 'Comments' ;
    rdfs:comment 'Free-text field capturing reviewer comments, rejection reasons, or clarification notes associated with the deliverable review cycle. Supports QA/QC tracking and resubmission guidance.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliverableCategory rdf:type rdf:Property ;
    rdfs:label 'Deliverable Category' ;
    rdfs:comment 'High-level category grouping the deliverable within the EPC (Engineering, Procurement, and Construction) project phases. Supports phase-based reporting and PMO governance. [ENUM-REF-CANDIDATE: engineering|procurement|construction|commissioning|handover|safety|quality — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Deliverable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliverableCode rdf:type rdf:Property ;
    rdfs:label 'Deliverable Code' ;
    rdfs:comment 'Unique alphanumeric code identifying the deliverable within the project document control system. Typically assigned by the document management system (e.g., Aconex or Procore) and used for transmittal and correspondence tracking.' ;
    rdfs:domain ind:Deliverable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliverableStatus rdf:type rdf:Property ;
    rdfs:label 'Deliverable Status' ;
    rdfs:comment 'Current lifecycle status of the deliverable within the review and approval workflow. Tracks progression from initiation through approval or rejection in the document control system. [ENUM-REF-CANDIDATE: not_started|in_progress|under_review|approved|rejected|superseded|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Deliverable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliverableType rdf:type rdf:Property ;
    rdfs:label 'Deliverable Type' ;
    rdfs:comment 'Classification of the deliverable by its output category. Distinguishes engineering drawings, specifications, reports, calculations, procedures, commissioning packages, handover documents, and Inspection and Test Plans (ITPs). [ENUM-REF-CANDIDATE: engineering_drawing|specification|report|calculation|procedure|commissioning_package|handover_document|inspection_test_plan|method_statement|data_sheet — promote to reference product]' ;
    rdfs:domain ind:Deliverable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eotApplicable rdf:type rdf:Property ;
    rdfs:label 'Eot Applicable' ;
    rdfs:comment 'Indicates whether an Extension of Time (EOT) claim has been applied to the planned issue date of this deliverable. Supports contract administration and schedule delay analysis.' ;
    rdfs:domain ind:Deliverable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:forecastIssueDate rdf:type rdf:Property ;
    rdfs:label 'Forecast Issue Date' ;
    rdfs:comment 'Current forecast date for issuing the deliverable, updated during project progress reviews. Reflects schedule changes and is compared against the planned issue date to identify delays.' ;
    rdfs:domain ind:Deliverable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isDlpApplicable rdf:type rdf:Property ;
    rdfs:label 'Is Dlp Applicable' ;
    rdfs:comment 'Indicates whether this deliverable is subject to the Defects Liability Period (DLP) obligations under the contract. Enables DLP tracking and defect notification management.' ;
    rdfs:domain ind:Deliverable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isHandoverRequired rdf:type rdf:Property ;
    rdfs:label 'Is Handover Required' ;
    rdfs:comment 'Indicates whether this deliverable must be included in the project handover package to the client. Supports commissioning and handover completeness tracking.' ;
    rdfs:domain ind:Deliverable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nativeFileFormat rdf:type rdf:Property ;
    rdfs:label 'Native File Format' ;
    rdfs:comment 'File format of the deliverable document (e.g., PDF, DWG, DXF, REVIT, IFC, XLSX). Supports document management, BIM coordination, and digital handover requirements. [ENUM-REF-CANDIDATE: PDF|DWG|DXF|REVIT|IFC|XLSX|DOCX|XML|CSV — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Deliverable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedIssueDate rdf:type rdf:Property ;
    rdfs:label 'Planned Issue Date' ;
    rdfs:comment 'Baseline planned date on which the deliverable is scheduled to be issued to the client or for construction use. Established at project baseline and used for schedule performance tracking (SPI).' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:priorityLevel rdf:type rdf:Property ;
    rdfs:label 'Priority Level' ;
    rdfs:comment 'Business priority assigned to the deliverable indicating its criticality to the project schedule and construction activities. Critical deliverables are on the Critical Path Method (CPM) schedule.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewDueDate rdf:type rdf:Property ;
    rdfs:label 'Review Due Date' ;
    rdfs:comment 'Contractually or procedurally defined date by which the reviewer must return comments or approval. Supports contract administration and review cycle management.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reviewReturnDate rdf:type rdf:Property ;
    rdfs:label 'Review Return Date' ;
    rdfs:comment 'Actual date on which the reviewer returned comments or approval decision. Compared against review due date to track reviewer compliance and contract obligations.' ;
    rdfs:domain ind:Deliverable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:revisionStatusCode rdf:type rdf:Property ;
    rdfs:label 'Revision Status Code' ;
    rdfs:comment 'Industry-standard document issue purpose code indicating the intent of the current revision: IFR (Issued for Review), IFC (Issued for Construction), IFI (Issued for Information), IFB (Issued for Bid), AFC (Approved for Construction), AFD (Approved for Design), ASB (As-Built). Critical for construction document control. [ENUM-REF-CANDIDATE: IFR|IFC|IFI|IFB|AFC|AFD|ASB — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Deliverable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageLocationUrl rdf:type rdf:Property ;
    rdfs:label 'Storage Location Url' ;
    rdfs:comment 'URL or path to the deliverable file stored in the document management system (e.g., Aconex, Autodesk BIM 360, or SharePoint). Provides direct access to the source document.' ;
    rdfs:domain ind:Deliverable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:weightFactor rdf:type rdf:Property ;
    rdfs:label 'Weight Factor' ;
    rdfs:comment 'Relative weighting of this deliverable within the project progress measurement system. Used to calculate weighted progress and Earned Value (EV) contributions at the project or WBS level.' ;
    rdfs:domain ind:Deliverable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:riskRegisterId rdf:type rdf:Property ;
    rdfs:label 'Risk Register Id' ;
    rdfs:comment 'Unique surrogate identifier for each risk register entry in the project risk register. Primary key for the risk_register data product.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hazardRegisterId rdf:type rdf:Property ;
    rdfs:label 'Hazard Register Id' ;
    rdfs:comment 'Foreign key linking to safety.hazard_register. Business justification: Project risks with hse_risk_flag=true are formally registered as site hazards in the hazard register. This traceability — from project risk identification to formal hazard registration — is required f' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:HazardRegister .

ind:riskId rdf:type rdf:Property ;
    rdfs:label 'Risk Id' ;
    rdfs:comment 'Foreign key linking to bid.bid_risk. Business justification: Bid risks that materialize during project execution become project risks. Construction risk managers require traceability from the project risk register back to the originating bid risk for risk reali' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Risk .

ind:affectedDiscipline rdf:type rdf:Property ;
    rdfs:label 'Affected Discipline' ;
    rdfs:comment 'Construction or engineering discipline most affected by this risk (e.g., Civil, Structural, MEP, Geotechnical, Electrical, Procurement). Supports discipline-level risk reporting and resource allocation for mitigation.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closureDate rdf:type rdf:Property ;
    rdfs:label 'Closure Date' ;
    rdfs:comment 'Calendar date on which the risk entry was formally closed, either because the risk window has passed, the risk was fully mitigated, or the risk was realized and the contingency plan executed.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contingencyCostAmount rdf:type rdf:Property ;
    rdfs:label 'Contingency Cost Amount' ;
    rdfs:comment 'Monetary contingency reserve allocated to this risk entry, expressed in the project currency. Feeds into the project contingency budget managed through SAP S/4HANA Project Systems and PMO cost control.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contingencyPlan rdf:type rdf:Property ;
    rdfs:label 'Contingency Plan' ;
    rdfs:comment 'Description of the fallback actions to be executed if the risk event is realized despite mitigation efforts. Defines trigger conditions, response steps, and responsible parties for contingency activation.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costImpactRating rdf:type rdf:Property ;
    rdfs:label 'Cost Impact Rating' ;
    rdfs:comment 'Qualitative rating of the potential cost impact if the risk event is realized, using the standard five-point PMO scale. Used in risk matrix scoring and contingency reserve determination.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationFlag rdf:type rdf:Property ;
    rdfs:label 'Escalation Flag' ;
    rdfs:comment 'Indicates whether this risk has been escalated to senior management or the PMO for executive attention due to its high risk score, proximity, or strategic significance to the project.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hseRiskFlag rdf:type rdf:Property ;
    rdfs:label 'Hse Risk Flag' ;
    rdfs:comment 'Indicates whether this risk has a Health, Safety, and Environment (HSE) dimension requiring notification to the HSE team and potential entry into the Intelex HSE management system for regulatory compliance.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:identifiedDate rdf:type rdf:Property ;
    rdfs:label 'Identified Date' ;
    rdfs:comment 'Calendar date on which the risk or opportunity was first identified and entered into the project risk register. BUSINESS_EVENT_TIMESTAMP (date precision) for this entity. Used for risk ageing analysis and PMO reporting.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:insuranceCoverageFlag rdf:type rdf:Property ;
    rdfs:label 'Insurance Coverage Flag' ;
    rdfs:comment 'Indicates whether this risk is covered by an existing insurance policy (e.g., Contractors All Risk, Professional Indemnity, Public Liability). Supports risk transfer tracking and insurance portfolio management.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastReviewedDate rdf:type rdf:Property ;
    rdfs:label 'Last Reviewed Date' ;
    rdfs:comment 'Calendar date on which this risk entry was most recently reviewed and updated by the risk owner or PMO. Used to identify overdue reviews and stale risk entries.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mitigationResponseType rdf:type rdf:Property ;
    rdfs:label 'Mitigation Response Type' ;
    rdfs:comment 'Standard risk response strategy type applied to this risk: avoid (eliminate the risk), transfer (shift to another party via contract/insurance), mitigate (reduce probability/impact), accept (acknowledge and monitor), exploit (maximise opportunity), or enhance (increase opportunity probability/impact).' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mitigationStrategy rdf:type rdf:Property ;
    rdfs:label 'Mitigation Strategy' ;
    rdfs:comment 'Detailed description of the planned or implemented actions to reduce the probability or impact of the risk event. Includes engineering controls, contractual protections, procurement strategies, and HSE measures.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:probabilityRating rdf:type rdf:Property ;
    rdfs:label 'Probability Rating' ;
    rdfs:comment 'Qualitative probability rating of the risk event occurring, using the standard five-point PMO scale. Complements the quantitative probability score for risk matrix visualisation and executive reporting.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:probabilityScore rdf:type rdf:Property ;
    rdfs:label 'Probability Score' ;
    rdfs:comment 'Quantitative probability of the risk event occurring, expressed as a decimal between 0.0000 and 1.0000 (e.g., 0.3500 = 35%). Used in risk scoring calculations and Monte Carlo simulation inputs for contingency management.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualityImpactRating rdf:type rdf:Property ;
    rdfs:label 'Quality Impact Rating' ;
    rdfs:comment 'Qualitative rating of the potential quality impact if the risk event is realized. Supports QA/QC risk assessment and Non-Conformance Report (NCR) prevention planning.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryRiskFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Risk Flag' ;
    rdfs:comment 'Indicates whether this risk involves a regulatory or permitting dimension (e.g., EPA environmental permits, OSHA compliance, IBC building code, LEED certification requirements). Triggers regulatory compliance review.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:residualProbabilityScore rdf:type rdf:Property ;
    rdfs:label 'Residual Probability Score' ;
    rdfs:comment 'Quantitative probability of the risk event occurring after mitigation actions have been applied, expressed as a decimal between 0.0000 and 1.0000. Measures the effectiveness of the risk response strategy.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:residualRiskScore rdf:type rdf:Property ;
    rdfs:label 'Residual Risk Score' ;
    rdfs:comment 'Composite risk score remaining after mitigation actions have been applied. Compared against the pre-mitigation risk score to demonstrate risk reduction effectiveness and support PMO governance reporting.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewDate rdf:type rdf:Property ;
    rdfs:label 'Review Date' ;
    rdfs:comment 'Scheduled date for the next formal review of this risk entry by the risk owner and PMO. Ensures risks are regularly reassessed and not left stale in the register.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:riskCategory rdf:type rdf:Property ;
    rdfs:label 'Risk Category' ;
    rdfs:comment 'Classification of the risk into a standard PMO risk category: technical (design, engineering, construction method), commercial (cost, contract, financial), schedule (programme, critical path), hse (Health Safety and Environment), regulatory (permits, compliance), or force_majeure (natural events, geopolitical). Drives risk reporting by category.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskDescription rdf:type rdf:Property ;
    rdfs:label 'Risk Description' ;
    rdfs:comment 'Detailed narrative describing the risk or opportunity event, its cause, and potential consequence. Captures the full context required for risk assessment and mitigation planning.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskProximity rdf:type rdf:Property ;
    rdfs:label 'Risk Proximity' ;
    rdfs:comment 'Indicates the time horizon within which the risk event is expected to occur: immediate (within 30 days), near_term (30–90 days), medium_term (90–180 days), or long_term (beyond 180 days). Supports prioritisation of risk response actions.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskScore rdf:type rdf:Property ;
    rdfs:label 'Risk Score' ;
    rdfs:comment 'Composite risk score calculated as the product of probability and impact ratings, typically on a 1–25 scale (5x5 risk matrix). Used to prioritise risks in the PMO risk register and determine escalation thresholds.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:riskStatus rdf:type rdf:Property ;
    rdfs:label 'Risk Status' ;
    rdfs:comment 'Current lifecycle status of the risk register entry: open (active, being monitored), mitigated (response actions applied), closed (no longer applicable), realized (risk event has occurred), or transferred (risk transferred to another party via contract/insurance). LIFECYCLE_STATUS for this entity.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskTitle rdf:type rdf:Property ;
    rdfs:label 'Risk Title' ;
    rdfs:comment 'Short, human-readable title summarising the risk or opportunity. Used as the primary display label in PMO dashboards, risk reports, and executive summaries. IDENTITY_LABEL for this entity.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskTrigger rdf:type rdf:Property ;
    rdfs:label 'Risk Trigger' ;
    rdfs:comment 'Description of the early warning indicators or conditions that signal the risk event is about to occur or has been triggered. Used to activate contingency plans and alert the risk owner.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskType rdf:type rdf:Property ;
    rdfs:label 'Risk Type' ;
    rdfs:comment 'Indicates whether the register entry represents a threat (negative impact) or an opportunity (positive impact) to the project. Supports balanced risk and opportunity management per PMO governance.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleImpactRating rdf:type rdf:Property ;
    rdfs:label 'Schedule Impact Rating' ;
    rdfs:comment 'Qualitative rating of the potential schedule impact if the risk event is realized, using the standard five-point PMO scale. Informs Extension of Time (EOT) exposure analysis and Critical Path Method (CPM) schedule risk assessment.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemRef rdf:type rdf:Property ;
    rdfs:label 'Source System Ref' ;
    rdfs:comment 'The native identifier of this risk record in the originating operational system (e.g., Procore risk ID, Primavera P6 risk code). Enables traceability from the silver layer back to the source system for reconciliation and audit.' ;
    rdfs:domain ind:RiskRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterId rdf:type rdf:Property ;
    rdfs:label 'Cost Center Id' ;
    rdfs:comment 'Foreign key linking to finance.cost_center. Business justification: Construction project phases (design, procurement, construction, commissioning) are mapped to dedicated cost centers for phase-level budget control and financial reporting. This enables phase-level P&L' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostCenter .

ind:gateApproverContactId rdf:type rdf:Property ;
    rdfs:label 'Gate Approver Contact Id' ;
    rdfs:comment 'Foreign key linking to client.contact. Business justification: Phase gate approvals in construction are contractually significant client sign-offs. gate_approver_name is a denormalized client contact field. Replacing it with a proper FK enables governance reporti' ;
    rdfs:domain ind:Phase ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Contact .

ind:baselineDurationDays rdf:type rdf:Property ;
    rdfs:label 'Baseline Duration Days' ;
    rdfs:comment 'Approved baseline duration of the phase in calendar days, derived from the original project schedule. Used as the denominator for schedule performance measurement and variance reporting.' ;
    rdfs:domain ind:Phase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contingencyBudget rdf:type rdf:Property ;
    rdfs:label 'Contingency Budget' ;
    rdfs:comment 'Contingency reserve allocated to this phase to cover identified and unidentified risks. Managed separately from the base budget in SAP S/4HANA Project Systems and released upon formal risk event occurrence.' ;
    rdfs:domain ind:Phase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deliverablesChecklist rdf:type rdf:Property ;
    rdfs:label 'Deliverables Checklist' ;
    rdfs:comment 'Structured list or description of mandatory deliverables required for phase completion (e.g., IFC drawings, BOQ, ITP, commissioning dossier). Stored as a delimited string or JSON-serialized list. Supports phase-gate governance and QA/QC compliance.' ;
    rdfs:domain ind:Phase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliverablesCompletionPct rdf:type rdf:Property ;
    rdfs:label 'Deliverables Completion Pct' ;
    rdfs:comment 'Percentage of mandatory phase deliverables that have been completed and accepted as of the latest update (0.00–100.00). Supports phase gate readiness assessment and PMO reporting.' ;
    rdfs:domain ind:Phase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:evmWeightPct rdf:type rdf:Property ;
    rdfs:label 'Evm Weight Pct' ;
    rdfs:comment 'Weighting factor assigned to this phase for EVM (Earned Value Management) rollup to the project level, expressed as a percentage of total project value (0.00–100.00). All phase weights must sum to 100 per project. Drives CPI and SPI calculations.' ;
    rdfs:domain ind:Phase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:floatDays rdf:type rdf:Property ;
    rdfs:label 'Float Days' ;
    rdfs:comment 'Total float (slack) available for this phase in calendar days, as calculated by CPM (Critical Path Method) analysis in Oracle Primavera P6. Negative float indicates a schedule overrun. Used for schedule risk assessment and EOT (Extension of Time) claims.' ;
    rdfs:domain ind:Phase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:gateApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Gate Approval Date' ;
    rdfs:comment 'The date on which the phase gate was formally approved by the authorized approver, permitting progression to the next project phase. Recorded in the PMO governance register and Aconex document management system.' ;
    rdfs:domain ind:Phase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:gateApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Gate Approval Status' ;
    rdfs:comment 'Current approval status of the phase gate review. Controls authorization to proceed to the next phase. Managed through PMO governance workflows and documented in Aconex or Procore approval workflows.' ;
    rdfs:domain ind:Phase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gateReviewCriteria rdf:type rdf:Property ;
    rdfs:label 'Gate Review Criteria' ;
    rdfs:comment 'Textual description of the mandatory completion criteria and deliverables that must be satisfied before the phase gate can be approved and the next phase authorized. Aligned with PMO governance and FIDIC contract requirements.' ;
    rdfs:domain ind:Phase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ldExposureAmount rdf:type rdf:Property ;
    rdfs:label 'Ld Exposure Amount' ;
    rdfs:comment 'Calculated financial exposure to Liquidated Damages (LD) for this phase based on contractual LD rate and current schedule delay. Used for financial risk reporting and contract administration. Expressed in the phase currency.' ;
    rdfs:domain ind:Phase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:leedApplicable rdf:type rdf:Property ;
    rdfs:label 'Leed Applicable' ;
    rdfs:comment 'Indicates whether LEED (Leadership in Energy and Environmental Design) sustainability requirements apply to this phase. When true, phase deliverables and activities must comply with USGBC LEED certification criteria.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:milestoneCount rdf:type rdf:Property ;
    rdfs:label 'Milestone Count' ;
    rdfs:comment 'Total number of contractual or PMO-defined milestones associated with this phase. Provides a summary indicator of phase complexity and governance checkpoint density for PMO reporting.' ;
    rdfs:domain ind:Phase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:phaseCode rdf:type rdf:Property ;
    rdfs:label 'Phase Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying the phase within the project (e.g., FEED, PROC, CONST, COMM). Used as the business identifier in Oracle Primavera P6 and SAP PS phase structures.' ;
    rdfs:domain ind:Phase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phaseDescription rdf:type rdf:Property ;
    rdfs:label 'Phase Description' ;
    rdfs:comment 'Detailed narrative description of the scope of work, objectives, and key activities encompassed within this project phase. Used in project documentation, client reporting, and PMO governance records.' ;
    rdfs:domain ind:Phase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phaseName rdf:type rdf:Property ;
    rdfs:label 'Phase Name' ;
    rdfs:comment 'Human-readable name of the construction project lifecycle phase (e.g., Front-End Engineering Design, Procurement, Construction, Commissioning). Used in reporting, dashboards, and PMO governance documents.' ;
    rdfs:domain ind:Phase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phaseStatus rdf:type rdf:Property ;
    rdfs:label 'Phase Status' ;
    rdfs:comment 'Current lifecycle state of the construction project phase. Drives PMO governance workflows, EVM reporting eligibility, and phase-gate approval triggers. Sourced from Oracle Primavera P6 activity status.' ;
    rdfs:domain ind:Phase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phaseType rdf:type rdf:Property ;
    rdfs:label 'Phase Type' ;
    rdfs:comment 'Standardized classification of the phase within the EPC/DB/DBB/PPP project lifecycle. Drives phase-gate governance rules, EVM rollup logic, and reporting hierarchies. [ENUM-REF-CANDIDATE: feasibility|pre_construction|feed|detailed_engineering|procurement|construction|pre_commissioning|commissioning|handover|dlp — promote to reference product]' ;
    rdfs:domain ind:Phase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityPlanApproved rdf:type rdf:Property ;
    rdfs:label 'Quality Plan Approved' ;
    rdfs:comment 'Indicates whether the Quality Management Plan (including ITP - Inspection and Test Plan) for this phase has been formally approved. Required under ISO 9001 and contract QA/QC requirements before phase work commences.' ;
    rdfs:domain ind:Phase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sapWbsElement rdf:type rdf:Property ;
    rdfs:label 'Sap Wbs Element' ;
    rdfs:comment 'The SAP S/4HANA Project Systems WBS element code corresponding to this phase. Enables cost and budget data reconciliation between the lakehouse and SAP PS for financial reporting and EVM analysis.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Sequence Number' ;
    rdfs:comment 'Integer ordering of the phase within the project lifecycle. Determines the execution sequence for scheduling, phase-gate progression, and earned value rollup. Lower numbers execute first.' ;
    rdfs:domain ind:Phase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:handoverCertificateId rdf:type rdf:Property ;
    rdfs:label 'Handover Certificate Id' ;
    rdfs:comment 'Unique system-generated identifier for the handover certificate record. Primary key for the handover_certificate data product within the project domain.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:HandoverCertificate .

ind:clientSignatoryContactId rdf:type rdf:Property ;
    rdfs:label 'Client Signatory Contact Id' ;
    rdfs:comment 'Foreign key linking to client.contact. Business justification: Handover certificate requires linking to the client signatory contact for legal sign-off tracking and audit compliance.' ;
    rdfs:domain ind:HandoverCertificate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Contact .

ind:inspectionReleaseId rdf:type rdf:Property ;
    rdfs:label 'Inspection Release Id' ;
    rdfs:comment 'Foreign key linking to procurement.inspection_release. Business justification: In construction, handover certificates require completed inspection releases (IRs) as mandatory prerequisites — the handover package must reference the IR confirming materials/equipment passed inspect' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InspectionRelease .

ind:scheduleMilestoneId rdf:type rdf:Property ;
    rdfs:label 'Schedule Milestone Id' ;
    rdfs:comment 'Foreign key linking to schedule.schedule_milestone. Business justification: Handover certificates are issued upon achievement of contractual schedule milestones (Mechanical Completion, Practical Completion). Linking them enables DLP start-date calculation, LD liability end-da' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ScheduleMilestone .

ind:asBuiltDrawingReference rdf:type rdf:Property ;
    rdfs:label 'As Built Drawing Reference' ;
    rdfs:comment 'Document transmittal or register reference for the as-built drawings submitted as part of the handover package. Confirms that record drawings have been delivered to the client.' ;
    rdfs:domain ind:HandoverCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bimModelReference rdf:type rdf:Property ;
    rdfs:label 'Bim Model Reference' ;
    rdfs:comment 'Reference identifier or document number of the as-built Building Information Modeling (BIM) model associated with the handed-over works. Links the certificate to the digital asset record in Autodesk BIM 360 for O&M (Operations and Maintenance) purposes.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificateNumber rdf:type rdf:Property ;
    rdfs:label 'Certificate Number' ;
    rdfs:comment 'Externally-known, human-readable unique reference number for the handover certificate as issued and registered in the document management system (e.g., Aconex). Used in correspondence, transmittals, and contractual communications.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificateStatus rdf:type rdf:Property ;
    rdfs:label 'Certificate Status' ;
    rdfs:comment 'Current lifecycle status of the handover certificate. Draft: under preparation; Issued: formally submitted to client; Accepted: client has signed acceptance; Rejected: client has declined acceptance; Superseded: replaced by a revised certificate.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clientAcceptanceDate rdf:type rdf:Property ;
    rdfs:label 'Client Acceptance Date' ;
    rdfs:comment 'The date on which the client formally accepted and signed the handover certificate, confirming transfer of care, custody, and control of the works. Triggers the start of the Defects Liability Period (DLP).' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:clientSignatoryTitle rdf:type rdf:Property ;
    rdfs:label 'Client Signatory Title' ;
    rdfs:comment 'Job title or designation of the client representative who signed the handover certificate (e.g., Client Project Manager, Engineer\'s Representative, Owner\'s Representative). Validates the authority level of the acceptance.' ;
    rdfs:domain ind:HandoverCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commissioningCompleted rdf:type rdf:Property ;
    rdfs:label 'Commissioning Completed' ;
    rdfs:comment 'Indicates whether commissioning activities have been fully completed for the works included in the handover scope. Commissioning completion is a mandatory prerequisite for final handover in EPC and infrastructure projects.' ;
    rdfs:domain ind:HandoverCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contractorSignatoryName rdf:type rdf:Property ;
    rdfs:label 'Contractor Signatory Name' ;
    rdfs:comment 'Full name of the authorized contractor representative who signed the handover certificate on behalf of the contractor organization. Required for contractual validity of the certificate.' ;
    rdfs:domain ind:HandoverCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractorSignatoryTitle rdf:type rdf:Property ;
    rdfs:label 'Contractor Signatory Title' ;
    rdfs:comment 'Job title or designation of the contractor representative who signed the handover certificate (e.g., Project Director, Site Manager, Construction Manager). Validates the authority level of the signatory.' ;
    rdfs:domain ind:HandoverCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dlpDurationDays rdf:type rdf:Property ;
    rdfs:label 'Dlp Duration Days' ;
    rdfs:comment 'The contractually agreed duration of the Defects Liability Period (DLP) expressed in calendar days. Typically 365 days (12 months) for standard construction contracts but may vary by contract type and jurisdiction.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dlpStartDate rdf:type rdf:Property ;
    rdfs:label 'Dlp Start Date' ;
    rdfs:comment 'The date on which the Defects Liability Period (DLP) commences, typically aligned with the client acceptance date. Marks the beginning of the contractor\'s obligation to remedy defects at no additional cost.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:engineerSignatoryName rdf:type rdf:Property ;
    rdfs:label 'Engineer Signatory Name' ;
    rdfs:comment 'Full name of the Engineer (or Engineer\'s Representative) under FIDIC contracts who countersigns the handover certificate. Applicable under FIDIC Red/Yellow/Silver Book delivery models where an independent Engineer administers the contract.' ;
    rdfs:domain ind:HandoverCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eotDaysApplied rdf:type rdf:Property ;
    rdfs:label 'Eot Days Applied' ;
    rdfs:comment 'Total number of Extension of Time (EOT) days granted and applied to the contractual completion date for the scope covered by this handover certificate. Affects LD liability calculation and schedule performance reporting.' ;
    rdfs:domain ind:HandoverCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fatCompleted rdf:type rdf:Property ;
    rdfs:label 'Fat Completed' ;
    rdfs:comment 'Indicates whether Factory Acceptance Testing (FAT) has been completed for all equipment and systems included in the handover scope. FAT is a prerequisite for handover in EPC and MEP-intensive projects.' ;
    rdfs:domain ind:HandoverCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:handoverType rdf:type rdf:Property ;
    rdfs:label 'Handover Type' ;
    rdfs:comment 'Classification of the handover certificate indicating the nature and extent of the transfer of works. Partial: a defined portion of works; Sectional: a contractually defined section; Substantial Completion: works are practically complete with minor outstanding items; Final: all works including punch list resolved; Provisional: conditional acceptance pending outstanding items.' ;
    rdfs:domain ind:HandoverCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hseClearanceObtained rdf:type rdf:Property ;
    rdfs:label 'Hse Clearance Obtained' ;
    rdfs:comment 'Indicates whether all required Health, Safety, and Environment (HSE) clearances and regulatory approvals have been obtained prior to handover. Includes OSHA compliance, environmental permits, and occupancy certificates.' ;
    rdfs:domain ind:HandoverCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:itpCompleted rdf:type rdf:Property ;
    rdfs:label 'Itp Completed' ;
    rdfs:comment 'Indicates whether all Inspection and Test Plan (ITP) hold points and witness points for the works scope have been completed and signed off prior to handover. ITP completion is a mandatory QA/QC prerequisite for handover.' ;
    rdfs:domain ind:HandoverCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ldLiabilityEndDate rdf:type rdf:Property ;
    rdfs:label 'Ld Liability End Date' ;
    rdfs:comment 'The date on which the contractor\'s exposure to Liquidated Damages (LD) for delay ceases, typically aligned with the handover acceptance date. Critical for financial exposure tracking and contract administration.' ;
    rdfs:domain ind:HandoverCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ncrCount rdf:type rdf:Property ;
    rdfs:label 'Ncr Count' ;
    rdfs:comment 'Total number of open Non-Conformance Reports (NCRs) against the works scope at the time of handover certificate issuance. Open NCRs may be a condition precedent to client acceptance under QA/QC requirements.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:omManualReference rdf:type rdf:Property ;
    rdfs:label 'Om Manual Reference' ;
    rdfs:comment 'Document reference number for the Operations and Maintenance (O&M) manual submitted as part of the handover package. Confirms that O&M documentation has been provided to the client as a condition of handover.' ;
    rdfs:domain ind:HandoverCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:procoreSubmittalReference rdf:type rdf:Property ;
    rdfs:label 'Procore Submittal Reference' ;
    rdfs:comment 'The submittal identifier assigned to the handover certificate package in Procore Construction Management. Enables cross-system traceability between the data lakehouse and the operational construction management platform.' ;
    rdfs:domain ind:HandoverCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:punchListCloseDate rdf:type rdf:Property ;
    rdfs:label 'Punch List Close Date' ;
    rdfs:comment 'The date by which all outstanding punch list items are contractually required to be resolved and closed. Agreed between contractor and client at the time of handover.' ;
    rdfs:domain ind:HandoverCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:punchListCriticalCount rdf:type rdf:Property ;
    rdfs:label 'Punch List Critical Count' ;
    rdfs:comment 'Number of punch list items classified as critical or Category A at the time of handover, representing items that must be resolved before or immediately after handover. Distinct from total punch list count.' ;
    rdfs:domain ind:HandoverCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:punchListItemCount rdf:type rdf:Property ;
    rdfs:label 'Punch List Item Count' ;
    rdfs:comment 'Total number of outstanding punch list items (minor defects, incomplete works, or non-conformances) recorded at the time of handover certificate issuance. A key indicator of completion quality at handover.' ;
    rdfs:domain ind:HandoverCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:retentionReleaseEligible rdf:type rdf:Property ;
    rdfs:label 'Retention Release Eligible' ;
    rdfs:comment 'Indicates whether the issuance of this handover certificate triggers eligibility for release of contractual retention monies held by the client. Typically, substantial completion or final handover certificates trigger partial or full retention release.' ;
    rdfs:domain ind:HandoverCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:satCompleted rdf:type rdf:Property ;
    rdfs:label 'Sat Completed' ;
    rdfs:comment 'Indicates whether Site Acceptance Testing (SAT) has been completed for all systems and equipment included in the handover scope. SAT confirms that systems function correctly in their installed environment prior to handover.' ;
    rdfs:domain ind:HandoverCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sparePartsDelivered rdf:type rdf:Property ;
    rdfs:label 'Spare Parts Delivered' ;
    rdfs:comment 'Indicates whether all contractually required spare parts and consumables have been delivered to the client as part of the handover package. Spare parts delivery is a standard handover condition in EPC and infrastructure contracts.' ;
    rdfs:domain ind:HandoverCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:trainingCompleted rdf:type rdf:Property ;
    rdfs:label 'Training Completed' ;
    rdfs:comment 'Indicates whether the contractor has completed all contractually required training for the client\'s operations and maintenance personnel on the handed-over systems and equipment.' ;
    rdfs:domain ind:HandoverCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:craftWorkerId rdf:type rdf:Property ;
    rdfs:label 'Craft Worker Id' ;
    rdfs:comment 'Reference to the injured or involved party (employee, subcontractor worker, or visitor) from the workforce master. Supports PARTY_REFERENCE requirement for TRANSACTION_HEADER role.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CraftWorker .

ind:permitConditionId rdf:type rdf:Property ;
    rdfs:label 'Permit Condition Id' ;
    rdfs:comment 'Foreign key linking to compliance.permit_condition. Business justification: Permit Condition Violation Tracking: incidents are linked to the specific permit condition that was breached.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PermitCondition .

ind:projectSiteId rdf:type rdf:Property ;
    rdfs:label 'Project Site Id' ;
    rdfs:comment 'Foreign key linking to project.site. Business justification: Incident reporting requires the physical site where the incident occurred. Site-level safety KPIs (TRIR, LTI frequency) are reported per site in construction. incident already links to construction_pr' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProjectSite .

ind:reporterContactId rdf:type rdf:Property ;
    rdfs:label 'Reporter Contact Id' ;
    rdfs:comment 'Foreign key linking to client.contact. Business justification: Incident logging captures the client contact who reported the event, enabling audit trails and follow-up communication.' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Contact .

ind:bodyPartAffected rdf:type rdf:Property ;
    rdfs:label 'Body Part Affected' ;
    rdfs:comment 'Specific body part injured (e.g., right hand, lower back, left eye, head). Required field for OSHA 300 log and BLS injury classification. Supports ergonomic and PPE gap analysis. [ENUM-REF-CANDIDATE: head|eye|neck|back|shoulder|arm|hand|finger|leg|knee|foot|toe|multiple|other — promote to reference product]' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionCount rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Count' ;
    rdfs:comment 'Number of corrective actions raised against this incident. Provides a quick indicator of investigation depth and systemic response. Detailed corrective actions are tracked in the corrective_action product linked to this incident.' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:createdAt rdf:type rdf:Property ;
    rdfs:label 'Created At' ;
    rdfs:comment 'System audit timestamp recording when the incident record was first created in the data platform. Supports data lineage and Silver layer audit trail requirements.' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:daysAwayFromWork rdf:type rdf:Property ;
    rdfs:label 'Days Away From Work' ;
    rdfs:comment 'Number of calendar days the injured worker was away from work due to the incident, excluding the day of injury. Core component of the DART (Days Away, Restricted, or Transferred) rate calculation and OSHA 300 log column G.' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:daysRestrictedOrTransferred rdf:type rdf:Property ;
    rdfs:label 'Days Restricted Or Transferred' ;
    rdfs:comment 'Number of calendar days the injured worker was on restricted work duty or transferred to another job due to the incident. Combined with days_away_from_work to compute the DART (Days Away, Restricted, or Transferred) rate. Maps to OSHA 300 log column H.' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:environmentalMediaAffected rdf:type rdf:Property ;
    rdfs:label 'Environmental Media Affected' ;
    rdfs:comment 'Environmental media impacted by the incident (soil, groundwater, surface water, air). Populated only when is_environmental_event is true. Required for EPA reportable quantity determination and ISO 14001 environmental incident reporting.' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:immediateCause rdf:type rdf:Property ;
    rdfs:label 'Immediate Cause' ;
    rdfs:comment 'Direct, proximate cause of the incident as determined during initial investigation (e.g., struck by falling object, slip on wet surface, equipment malfunction, electrical contact). Supports causal pattern analysis.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentDescription rdf:type rdf:Property ;
    rdfs:label 'Incident Description' ;
    rdfs:comment 'Detailed narrative description of the incident including what happened, the sequence of events, conditions at the time, and any immediate actions taken. Core field for OSHA 300 log column F and investigation reports.' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentNumber rdf:type rdf:Property ;
    rdfs:label 'Incident Number' ;
    rdfs:comment 'Externally-known, human-readable reference number assigned to the incident at the time of reporting (e.g., INC-2024-000123). Used in correspondence, regulatory submissions, and OSHA 300 log entries.' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentStatus rdf:type rdf:Property ;
    rdfs:label 'Incident Status' ;
    rdfs:comment 'Current lifecycle state of the incident record within the Intelex workflow. Drives investigation assignment, corrective action tracking, and regulatory notification obligations.' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentType rdf:type rdf:Property ;
    rdfs:label 'Incident Type' ;
    rdfs:comment 'Primary classification of the safety event (e.g., injury, near_miss, unsafe_condition, property_damage, environmental_event, dangerous_occurrence, behavioral_observation). Drives OSHA recordability determination and TRIR contribution. [ENUM-REF-CANDIDATE: injury|near_miss|unsafe_condition|property_damage|environmental_event|dangerous_occurrence|behavioral_observation — promote to reference product]' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:injuredPartyJobTitle rdf:type rdf:Property ;
    rdfs:label 'Injured Party Job Title' ;
    rdfs:comment 'Job title or trade classification of the injured party at the time of the incident (e.g., Ironworker, Electrician, Crane Operator). Used for occupational injury pattern analysis and targeted safety training.' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:injuredPartyName rdf:type rdf:Property ;
    rdfs:label 'Injured Party Name' ;
    rdfs:comment 'Full name of the person injured or involved in the incident. Required for OSHA 300 log, workers compensation claim, and medical case management. Classified as restricted PII.' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:injuredPartyType rdf:type rdf:Property ;
    rdfs:label 'Injured Party Type' ;
    rdfs:comment 'Classification of the person involved in the incident. Determines OSHA recordability scope (employees and supervised workers are recordable; visitors may not be). Affects workers compensation claim eligibility.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:injuryNature rdf:type rdf:Property ;
    rdfs:label 'Injury Nature' ;
    rdfs:comment 'Nature or type of the injury or illness sustained (e.g., laceration, fracture, sprain, burn, crush injury, chemical exposure, heat stress). Required for OSHA 300 log and BLS OIICS coding. [ENUM-REF-CANDIDATE: laceration|fracture|sprain_strain|burn|crush|chemical_exposure|heat_stress|contusion|amputation|other — promote to reference product]' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:intelexRecordReference rdf:type rdf:Property ;
    rdfs:label 'Intelex Record Reference' ;
    rdfs:comment 'Native record identifier from the Intelex HSE Management system from which this incident record was sourced. Enables bi-directional traceability between the Silver layer data product and the operational system of record for reconciliation and audit purposes.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationCompletedDate rdf:type rdf:Property ;
    rdfs:label 'Investigation Completed Date' ;
    rdfs:comment 'Date on which the formal incident investigation was completed and root cause analysis finalized. Used to measure investigation cycle time compliance (typically 5–10 business days per HSE policy) and trigger corrective action issuance.' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:investigationLead rdf:type rdf:Property ;
    rdfs:label 'Investigation Lead' ;
    rdfs:comment 'Name or identifier of the HSE officer or supervisor assigned as lead investigator for the incident. Supports investigation accountability tracking and workload management within the HSE team.' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isEnvironmentalEvent rdf:type rdf:Property ;
    rdfs:label 'Is Environmental Event' ;
    rdfs:comment 'Indicates whether the incident involved an environmental impact such as a spill, release, or contamination event. Triggers EPA reporting obligations and ISO 14001 environmental management corrective action workflows.' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isFitForDuty rdf:type rdf:Property ;
    rdfs:label 'Is Fit For Duty' ;
    rdfs:comment 'Indicates whether the injured worker has been medically cleared for full unrestricted duty upon return to work. Prevents premature return to hazardous tasks and supports site access control decisions.' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isLti rdf:type rdf:Property ;
    rdfs:label 'Is Lti' ;
    rdfs:comment 'Indicates whether the incident resulted in at least one full calendar day away from work beyond the day of injury. LTI (Lost Time Injury) flag is the primary driver of LTIFR (Lost Time Injury Frequency Rate) calculations and executive safety KPI dashboards.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isOshaRecordable rdf:type rdf:Property ;
    rdfs:label 'Is Osha Recordable' ;
    rdfs:comment 'Indicates whether the incident meets OSHA recordability criteria under 29 CFR 1904.7 (medical treatment beyond first aid, days away, restricted work, job transfer, loss of consciousness, or diagnosis of a significant injury). Drives OSHA 300 log inclusion and TRIR calculation.' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:occurredAt rdf:type rdf:Property ;
    rdfs:label 'Occurred At' ;
    rdfs:comment 'The precise date and time the safety event occurred on site. Principal business event timestamp used for OSHA 300 log date, TRIR period attribution, and trend analysis. Distinct from the report creation timestamp.' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:propertyDamageAmount rdf:type rdf:Property ;
    rdfs:label 'Property Damage Amount' ;
    rdfs:comment 'Estimated monetary value of property, plant, or equipment damage resulting from the incident in USD. Used for insurance claim valuation, project cost impact reporting, and safety cost of poor quality (COPQ) analysis.' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatoryNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Regulatory Notification Date' ;
    rdfs:comment 'Date on which the regulatory authority (OSHA, EPA, or other) was formally notified of the incident. Used to verify compliance with mandatory notification timeframes and document regulatory correspondence.' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryNotificationStatus rdf:type rdf:Property ;
    rdfs:label 'Regulatory Notification Status' ;
    rdfs:comment 'Status of mandatory regulatory notification to OSHA or other governing bodies. OSHA requires fatality notification within 8 hours and inpatient hospitalization within 24 hours. Tracks compliance with notification deadlines.' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportedAt rdf:type rdf:Property ;
    rdfs:label 'Reported At' ;
    rdfs:comment 'Date and time the incident was formally reported and entered into the Intelex system. Used to measure reporting lag compliance (OSHA requires reporting of fatalities within 8 hours and hospitalizations within 24 hours).' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:returnToWorkDate rdf:type rdf:Property ;
    rdfs:label 'Return To Work Date' ;
    rdfs:comment 'Date the injured worker returned to full or modified duty following the incident. Used to calculate actual days away from work, close the LTI case, and update DART rate calculations. Triggers fitness-for-duty clearance workflow.' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rootCauseCategory rdf:type rdf:Property ;
    rdfs:label 'Root Cause Category' ;
    rdfs:comment 'High-level root cause category identified through formal investigation (e.g., inadequate_procedure, equipment_failure, human_error, environmental_condition, inadequate_supervision, training_deficiency). Drives systemic corrective action programs. [ENUM-REF-CANDIDATE: inadequate_procedure|equipment_failure|human_error|environmental_condition|inadequate_supervision|training_deficiency|design_deficiency — promote to reference product]' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:severity rdf:type rdf:Property ;
    rdfs:label 'Severity' ;
    rdfs:comment 'Severity level of the incident aligned to the OSHA recordability hierarchy and HSE severity matrix. LTI (Lost Time Injury) and fatality cases trigger mandatory regulatory notifications. Drives DART rate and TRIR calculations. [ENUM-REF-CANDIDATE: fatality|lti|medical_treatment|restricted_work|first_aid|near_miss|property_damage|environmental — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shift rdf:type rdf:Property ;
    rdfs:label 'Shift' ;
    rdfs:comment 'Work shift during which the incident occurred (day, night, swing). Shift-based incident analysis identifies fatigue-related patterns and informs shift rotation and supervision scheduling decisions.' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteArea rdf:type rdf:Property ;
    rdfs:label 'Site Area' ;
    rdfs:comment 'Specific area, zone, or work front within the project site where the incident occurred (e.g., Zone A – Excavation, Level 3 Formwork, Laydown Yard). Supports spatial incident density analysis and targeted safety interventions.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:treatingPhysician rdf:type rdf:Property ;
    rdfs:label 'Treating Physician' ;
    rdfs:comment 'Name of the physician or medical professional who provided treatment to the injured party. Required for OSHA 300 log and workers compensation case management. Classified as confidential due to medical case sensitivity.' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:treatmentType rdf:type rdf:Property ;
    rdfs:label 'Treatment Type' ;
    rdfs:comment 'Type of medical treatment provided to the injured party. Distinguishes first aid cases (non-recordable) from medical treatment cases (OSHA recordable). Drives case management workflow and workers compensation claim initiation.' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:updatedAt rdf:type rdf:Property ;
    rdfs:label 'Updated At' ;
    rdfs:comment 'System audit timestamp recording the most recent modification to the incident record. Used to detect stale investigations and track investigation progress velocity.' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:weatherConditions rdf:type rdf:Property ;
    rdfs:label 'Weather Conditions' ;
    rdfs:comment 'Prevailing weather conditions at the site at the time of the incident. Environmental factors such as rain, high winds, or extreme heat are frequently contributing causes in construction incidents and are required for thorough root cause analysis. [ENUM-REF-CANDIDATE: clear|rain|wind|fog|extreme_heat|extreme_cold|not_applicable — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workersCompClaimRef rdf:type rdf:Property ;
    rdfs:label 'Workers Comp Claim Ref' ;
    rdfs:comment 'Reference number of the workers compensation insurance claim associated with this incident. Links the safety event record to the financial claims management system for cost tracking and insurance reporting.' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentInvestigationId rdf:type rdf:Property ;
    rdfs:label 'Incident Investigation Id' ;
    rdfs:comment 'Unique system-generated identifier for the incident investigation record. Primary key for this entity in the Databricks Silver Layer.' ;
    rdfs:domain ind:IncidentInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actionId rdf:type rdf:Property ;
    rdfs:label 'Action Id' ;
    rdfs:comment 'Foreign key linking to compliance.compliance_action. Business justification: Investigation findings in construction generate specific compliance corrective actions (systemic fixes, regulatory corrective measures). Construction HSE managers track which compliance action was rai' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Action .

ind:regulatorySubmissionId rdf:type rdf:Property ;
    rdfs:label 'Regulatory Submission Id' ;
    rdfs:comment 'Foreign key linking to compliance.regulatory_submission. Business justification: Construction incident investigations produce mandatory regulatory submissions (RIDDOR, WorkSafe investigation reports, EPA notifications). Investigation findings directly drive submission content. Con' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RegulatorySubmission .

ind:contributingFactors rdf:type rdf:Property ;
    rdfs:label 'Contributing Factors' ;
    rdfs:comment 'Narrative description of secondary factors that contributed to the incident, such as environmental conditions, equipment state, worker fatigue, or inadequate supervision. Supports multi-causal analysis.' ;
    rdfs:domain ind:IncidentInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionDueDate rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Due Date' ;
    rdfs:comment 'Target completion date by which all corrective actions arising from the investigation must be implemented and verified. Used for tracking overdue actions and management escalation.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:correctiveActionStatus rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Status' ;
    rdfs:comment 'Aggregate status of corrective actions arising from this investigation, indicating whether actions have been initiated, completed, or verified as effective.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionSummary rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Summary' ;
    rdfs:comment 'Summary description of the corrective and preventive actions recommended by the investigation team to address root causes and prevent recurrence. Detailed individual actions are tracked in the corrective action register.' ;
    rdfs:domain ind:IncidentInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentCategory rdf:type rdf:Property ;
    rdfs:label 'Incident Category' ;
    rdfs:comment 'High-level category of the incident type such as fall from height, struck-by, caught-in/between, electrical, chemical exposure, vehicle collision, or fire. Used for trend analysis and targeted safety interventions. [ENUM-REF-CANDIDATE: fall_from_height|struck_by|caught_in_between|electrical|chemical_exposure|vehicle|fire|ergonomic|other — promote to reference product]' ;
    rdfs:domain ind:IncidentInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentClassification rdf:type rdf:Property ;
    rdfs:label 'Incident Classification' ;
    rdfs:comment 'Severity classification of the incident under investigation per OSHA and ISO 45001 reporting categories. Lost Time Injury (LTI) and fatality classifications trigger mandatory regulatory reporting. [ENUM-REF-CANDIDATE: fatality|lti|medical_treatment|first_aid|near_miss|property_damage|environmental — promote to reference product]' ;
    rdfs:domain ind:IncidentInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentDate rdf:type rdf:Property ;
    rdfs:label 'Incident Date' ;
    rdfs:comment 'Calendar date on which the original Health Safety and Environment (HSE) incident occurred. Used as the principal business event date for regulatory reporting and trend analysis.' ;
    rdfs:domain ind:IncidentInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:investigationCloseDate rdf:type rdf:Property ;
    rdfs:label 'Investigation Close Date' ;
    rdfs:comment 'Date on which the investigation was formally closed following completion of root cause analysis, corrective action assignment, and management sign-off. Nullable until closure.' ;
    rdfs:domain ind:IncidentInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:investigationFindings rdf:type rdf:Property ;
    rdfs:label 'Investigation Findings' ;
    rdfs:comment 'Comprehensive narrative summary of all findings from the investigation, including evidence gathered, witness statements reviewed, site conditions observed, and conclusions drawn by the investigation team.' ;
    rdfs:domain ind:IncidentInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationMethodology rdf:type rdf:Property ;
    rdfs:label 'Investigation Methodology' ;
    rdfs:comment 'Root cause analysis methodology applied during the investigation. Common methods include 5-Why analysis, Fishbone (Ishikawa) diagram, Bowtie analysis, Fault Tree Analysis, and TapRooT. [ENUM-REF-CANDIDATE: 5_why|fishbone|bowtie|fault_tree|taproot|other — promote to reference product]' ;
    rdfs:domain ind:IncidentInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationNumber rdf:type rdf:Property ;
    rdfs:label 'Investigation Number' ;
    rdfs:comment 'Externally-known unique alphanumeric reference code assigned to the investigation, used in correspondence, regulatory submissions, and audit trails. Format: INV-YYYY-NNNNNN.' ;
    rdfs:domain ind:IncidentInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationStartDate rdf:type rdf:Property ;
    rdfs:label 'Investigation Start Date' ;
    rdfs:comment 'Date on which the formal investigation was initiated. Used to measure investigation response time and compliance with regulatory timelines for incident investigation commencement.' ;
    rdfs:domain ind:IncidentInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:investigationStatus rdf:type rdf:Property ;
    rdfs:label 'Investigation Status' ;
    rdfs:comment 'Current lifecycle state of the incident investigation workflow, tracking progress from initial opening through root cause analysis, review, and formal closure.' ;
    rdfs:domain ind:IncidentInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationTeamMembers rdf:type rdf:Property ;
    rdfs:label 'Investigation Team Members' ;
    rdfs:comment 'Names and roles of all personnel who participated in the investigation team, including the lead investigator, HSE representative, site supervisor, and any subject matter experts. Stored as a structured text list.' ;
    rdfs:domain ind:IncidentInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationType rdf:type rdf:Property ;
    rdfs:label 'Investigation Type' ;
    rdfs:comment 'Classification of the investigation scope and formality level. Formal investigations are conducted for Lost Time Injuries (LTI), fatalities, and high-potential incidents. Informal investigations cover minor incidents and near-misses.' ;
    rdfs:domain ind:IncidentInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isRecordable rdf:type rdf:Property ;
    rdfs:label 'Is Recordable' ;
    rdfs:comment 'Indicates whether the incident meets OSHA recordability criteria and must be entered on the OSHA 300 Log. Recordable incidents include work-related fatalities, injuries, and illnesses meeting specific severity thresholds.' ;
    rdfs:domain ind:IncidentInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRegulatoryReportable rdf:type rdf:Property ;
    rdfs:label 'Is Regulatory Reportable' ;
    rdfs:comment 'Indicates whether the incident requires mandatory notification to a regulatory authority such as OSHA, EPA, or local government within a prescribed timeframe (e.g., OSHA requires fatality reporting within 8 hours).' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lessonsLearned rdf:type rdf:Property ;
    rdfs:label 'Lessons Learned' ;
    rdfs:comment 'Key lessons identified from the investigation that should be communicated across the organisation and other project sites to prevent similar incidents. Used in Toolbox Meeting (TBM) communications and safety alerts.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lostTimeDays rdf:type rdf:Property ;
    rdfs:label 'Lost Time Days' ;
    rdfs:comment 'Number of calendar days lost due to the incident as determined by the investigation. Used in calculating Lost Time Injury (LTI) frequency rates and Total Recordable Incident Rate (TRIR) for OSHA regulatory reporting.' ;
    rdfs:domain ind:IncidentInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:managementReviewDate rdf:type rdf:Property ;
    rdfs:label 'Management Review Date' ;
    rdfs:comment 'Date on which senior management formally reviewed and accepted the investigation report and corrective action plan. Required for ISO 45001 management review compliance.' ;
    rdfs:domain ind:IncidentInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ppeComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Ppe Compliance Flag' ;
    rdfs:comment 'Indicates whether the injured party was wearing the required Personal Protective Equipment (PPE) at the time of the incident. Non-compliance is a key contributing factor captured in the investigation.' ;
    rdfs:domain ind:IncidentInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recurrencePreventionMeasures rdf:type rdf:Property ;
    rdfs:label 'Recurrence Prevention Measures' ;
    rdfs:comment 'Narrative description of specific engineering controls, administrative controls, or procedural changes recommended to prevent recurrence of the incident type. Aligned with the hierarchy of controls.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reference Number' ;
    rdfs:comment 'Reference or case number assigned by the regulatory authority (e.g., OSHA case number) upon submission of the incident report. Used for tracking regulatory correspondence and compliance status.' ;
    rdfs:domain ind:IncidentInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatorySubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Regulatory Submission Date' ;
    rdfs:comment 'Date on which the incident investigation report or notification was formally submitted to the relevant regulatory authority (e.g., OSHA, EPA). Nullable for non-reportable incidents.' ;
    rdfs:domain ind:IncidentInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rootCauseDescription rdf:type rdf:Property ;
    rdfs:label 'Root Cause Description' ;
    rdfs:comment 'Detailed narrative of the fundamental systemic root cause(s) identified through the investigation methodology (e.g., 5-Why, Fishbone). Represents the deepest causal factor that, if corrected, would prevent recurrence.' ;
    rdfs:domain ind:IncidentInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:swmsInPlaceFlag rdf:type rdf:Property ;
    rdfs:label 'Swms In Place Flag' ;
    rdfs:comment 'Indicates whether a valid Safe Work Method Statement (SWMS) was in place and accessible for the work activity being performed at the time of the incident. Absence of SWMS is a key systemic cause indicator.' ;
    rdfs:domain ind:IncidentInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:systemicCause rdf:type rdf:Property ;
    rdfs:label 'Systemic Cause' ;
    rdfs:comment 'Organisational or management system failure that allowed the immediate and root causes to exist, such as inadequate procedures, insufficient training, or failed management controls. Distinct from immediate and root causes.' ;
    rdfs:domain ind:IncidentInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:witnessCount rdf:type rdf:Property ;
    rdfs:label 'Witness Count' ;
    rdfs:comment 'Number of witnesses interviewed during the investigation. Indicates the breadth of evidence gathering and supports completeness assessment of the investigation.' ;
    rdfs:domain ind:IncidentInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:workAreaDescription rdf:type rdf:Property ;
    rdfs:label 'Work Area Description' ;
    rdfs:comment 'Specific work area, zone, or location within the construction site where the incident occurred, such as excavation zone, scaffolding level, electrical room, or crane operating radius.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:skillTradeId rdf:type rdf:Property ;
    rdfs:label 'Skill Trade Id' ;
    rdfs:comment 'Foreign key linking to workforce.skill_trade. Business justification: SWMS are authored for specific trade activities (steel erection, concreting, electrical). Linking to skill_trade enables trade-specific SWMS retrieval, ensures correct SWMS is applied per trade crew, ' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SkillTrade .

ind:activityDescription rdf:type rdf:Property ;
    rdfs:label 'Activity Description' ;
    rdfs:comment 'Detailed narrative description of the high-risk construction activity covered by this SWMS, including scope, location, and method of work. Provides the foundational context for all hazard and control entries.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableLegislation rdf:type rdf:Property ;
    rdfs:label 'Applicable Legislation' ;
    rdfs:comment 'List of applicable legislation, regulations, codes of practice, and industry standards that govern the high-risk activity described in this SWMS (e.g., OSHA 29 CFR 1926, IBC, NFPA, AISC, ACI). Required for regulatory compliance documentation.' ;
    rdfs:domain ind:Swms ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competencyRequirements rdf:type rdf:Property ;
    rdfs:label 'Competency Requirements' ;
    rdfs:comment 'Description of mandatory competency, certification, and licence requirements for workers performing the activity (e.g., Working at Heights certificate, Confined Space Entry certificate, Crane Operator licence). Supports workforce compliance verification.' ;
    rdfs:domain ind:Swms ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlMeasures rdf:type rdf:Property ;
    rdfs:label 'Control Measures' ;
    rdfs:comment 'Detailed description of all control measures to be implemented to eliminate or minimise the identified hazards, following the hierarchy of controls (elimination, substitution, engineering, administrative, PPE). Core content of the SWMS.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentUrl rdf:type rdf:Property ;
    rdfs:label 'Document Url' ;
    rdfs:comment 'URL or file path reference to the full SWMS document stored in the document management system (Aconex or Autodesk BIM 360). Provides direct access to the source document for audit and compliance purposes.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emergencyProcedures rdf:type rdf:Property ;
    rdfs:label 'Emergency Procedures' ;
    rdfs:comment 'Description of emergency response procedures specific to the high-risk activity, including evacuation routes, first aid requirements, emergency contacts, and incident notification protocols.' ;
    rdfs:domain ind:Swms ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:environmentalControls rdf:type rdf:Property ;
    rdfs:label 'Environmental Controls' ;
    rdfs:comment 'Description of environmental control measures required during the activity to prevent environmental harm, including spill containment, dust suppression, noise management, and waste disposal procedures.' ;
    rdfs:domain ind:Swms ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazardDescription rdf:type rdf:Property ;
    rdfs:label 'Hazard Description' ;
    rdfs:comment 'Narrative description of all identified hazards associated with the high-risk activity, including physical, chemical, biological, ergonomic, and environmental hazards. Captured as a consolidated summary at the SWMS header level.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initialRiskConsequence rdf:type rdf:Property ;
    rdfs:label 'Initial Risk Consequence' ;
    rdfs:comment 'Consequence severity rating of the identified hazard before any control measures are applied (inherent risk). Combined with initial_risk_likelihood to produce the initial risk rating score.' ;
    rdfs:domain ind:Swms ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initialRiskLikelihood rdf:type rdf:Property ;
    rdfs:label 'Initial Risk Likelihood' ;
    rdfs:comment 'Likelihood rating of the identified hazard materialising before any control measures are applied (inherent risk). Used in conjunction with initial_risk_consequence to derive the initial risk rating per the risk matrix.' ;
    rdfs:domain ind:Swms ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initialRiskRating rdf:type rdf:Property ;
    rdfs:label 'Initial Risk Rating' ;
    rdfs:comment 'Overall risk rating derived from the combination of initial_risk_likelihood and initial_risk_consequence before any control measures are applied. Represents the inherent risk level of the activity.' ;
    rdfs:domain ind:Swms ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plantEquipmentRequired rdf:type rdf:Property ;
    rdfs:label 'Plant Equipment Required' ;
    rdfs:comment 'List of plant, equipment, and tools required to perform the high-risk activity safely as described in this SWMS (e.g., EWP, crane, excavator, scaffolding, welding equipment). Supports equipment deployment planning.' ;
    rdfs:domain ind:Swms ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ppeRequirements rdf:type rdf:Property ;
    rdfs:label 'Ppe Requirements' ;
    rdfs:comment 'Enumerated list of mandatory Personal Protective Equipment (PPE) items required for personnel performing the activity covered by this SWMS (e.g., hard hat, safety harness, respirator, face shield, cut-resistant gloves). Aligns with PPE compliance tracking in Intelex.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ptwRequired rdf:type rdf:Property ;
    rdfs:label 'Ptw Required' ;
    rdfs:comment 'Indicates whether a Permit to Work (PTW) must be issued and active before the activity described in this SWMS can commence. True for activities such as confined space entry, hot works, and electrical isolation.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ptwType rdf:type rdf:Property ;
    rdfs:label 'Ptw Type' ;
    rdfs:comment 'Type of Permit to Work (PTW) required in conjunction with this SWMS. Populated only when ptw_required is True. Drives the PTW issuance workflow in Intelex.' ;
    rdfs:domain ind:Swms ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:residualRiskConsequence rdf:type rdf:Property ;
    rdfs:label 'Residual Risk Consequence' ;
    rdfs:comment 'Consequence severity rating after all control measures have been applied. Combined with residual_risk_likelihood to produce the residual risk rating.' ;
    rdfs:domain ind:Swms ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:residualRiskLikelihood rdf:type rdf:Property ;
    rdfs:label 'Residual Risk Likelihood' ;
    rdfs:comment 'Likelihood rating of the hazard materialising after all control measures have been applied. Used to assess the effectiveness of controls and determine if the residual risk is acceptable.' ;
    rdfs:domain ind:Swms ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:residualRiskRating rdf:type rdf:Property ;
    rdfs:label 'Residual Risk Rating' ;
    rdfs:comment 'Overall risk rating after all control measures have been applied. Represents the residual risk level that must be accepted or further mitigated before work can proceed. Extreme residual risk requires escalation to HSE Manager.' ;
    rdfs:domain ind:Swms ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:swmsNumber rdf:type rdf:Property ;
    rdfs:label 'Swms Number' ;
    rdfs:comment 'Externally-known unique document reference number for the SWMS, used for document control, transmittals, and regulatory submissions. Typically formatted as SWMS-[ProjectCode]-[Sequence]. Sourced from Intelex or Aconex document management.' ;
    rdfs:domain ind:Swms ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tbmRequired rdf:type rdf:Property ;
    rdfs:label 'Tbm Required' ;
    rdfs:comment 'Indicates whether a Toolbox Meeting (TBM) must be conducted with all workers before commencing the activity. TBMs are used to communicate SWMS content and obtain worker acknowledgement.' ;
    rdfs:domain ind:Swms ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:workSteps rdf:type rdf:Property ;
    rdfs:label 'Work Steps' ;
    rdfs:comment 'Sequential step-by-step description of the work procedure for the high-risk activity, detailing the specific actions workers must follow to complete the task safely. Core operational content of the SWMS.' ;
    rdfs:domain ind:Swms ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workerAcknowledgementRequired rdf:type rdf:Property ;
    rdfs:label 'Worker Acknowledgement Required' ;
    rdfs:comment 'Indicates whether all workers performing the activity must sign the SWMS to confirm they have read, understood, and agree to comply with the documented procedures and controls.' ;
    rdfs:domain ind:Swms ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:vendorQualificationId rdf:type rdf:Property ;
    rdfs:label 'Vendor Qualification Id' ;
    rdfs:comment 'Foreign key linking to procurement.vendor_qualification. Business justification: Before issuing a PTW to a subcontractor crew, site HSE must verify the vendor\'s current qualification status including ISO 45001 certification, TRIR rate, and HSE performance rating. This vendor quali' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VendorQualification .

ind:closedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Closed Timestamp' ;
    rdfs:comment 'Date and time at which the permit was formally closed upon completion or cancellation of the permitted work. Triggers site reinstatement and isolation removal procedures.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:concurrentPermitFlag rdf:type rdf:Property ;
    rdfs:label 'Concurrent Permit Flag' ;
    rdfs:comment 'Indicates whether this permit is being executed concurrently with other active permits in the same work area. Triggers additional interface risk assessment requirements.' ;
    rdfs:domain ind:PermitToWork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:emergencyRescuePlan rdf:type rdf:Property ;
    rdfs:label 'Emergency Rescue Plan' ;
    rdfs:comment 'Reference to or description of the emergency rescue and evacuation plan applicable to the permitted work. Mandatory for confined space entry and working at heights permits.' ;
    rdfs:domain ind:PermitToWork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:environmentalImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Environmental Impact Flag' ;
    rdfs:comment 'Indicates whether the permitted work has potential environmental impacts requiring additional controls or regulatory notifications (e.g., soil disturbance, chemical handling, noise).' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:extensionCount rdf:type rdf:Property ;
    rdfs:label 'Extension Count' ;
    rdfs:comment 'Number of times the permit validity period has been extended beyond the original valid_until timestamp. Tracks permit lifecycle management and potential compliance risk.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:gasTestRequired rdf:type rdf:Property ;
    rdfs:label 'Gas Test Required' ;
    rdfs:comment 'Indicates whether atmospheric gas testing is required prior to and during the permitted work (mandatory for confined space entry and hot work near flammable materials).' ;
    rdfs:domain ind:PermitToWork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gasTestResult rdf:type rdf:Property ;
    rdfs:label 'Gas Test Result' ;
    rdfs:comment 'Result of the atmospheric gas test conducted prior to commencing the permitted work. Must be \'pass\' before work can proceed when gas_test_required is True.' ;
    rdfs:domain ind:PermitToWork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isolationDetails rdf:type rdf:Property ;
    rdfs:label 'Isolation Details' ;
    rdfs:comment 'Description of the specific isolation points, energy sources, and lockout/tagout procedures required for the permitted work. Populated when isolation_required is True.' ;
    rdfs:domain ind:PermitToWork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isolationRequired rdf:type rdf:Property ;
    rdfs:label 'Isolation Required' ;
    rdfs:comment 'Indicates whether energy isolation (lockout/tagout) is required before commencing the permitted work. Mandatory for electrical, mechanical, and process isolation scenarios.' ;
    rdfs:domain ind:PermitToWork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:issuingAuthorityName rdf:type rdf:Property ;
    rdfs:label 'Issuing Authority Name' ;
    rdfs:comment 'Full name of the qualified person (typically HSE Manager, Area Authority, or Responsible Engineer) who issued and authorized the permit. Required for regulatory audit and sign-off chain documentation.' ;
    rdfs:domain ind:PermitToWork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastExtendedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Extended Timestamp' ;
    rdfs:comment 'Date and time of the most recent extension of the permit validity period. Populated when extension_count is greater than zero.' ;
    rdfs:domain ind:PermitToWork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:performingAuthorityRole rdf:type rdf:Property ;
    rdfs:label 'Performing Authority Role' ;
    rdfs:comment 'Job title or role of the person accepting and executing the permitted work (e.g., Foreman, Tradesperson, Subcontractor Supervisor). Validates competency for the work type.' ;
    rdfs:domain ind:PermitToWork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:permitStatus rdf:type rdf:Property ;
    rdfs:label 'Permit Status' ;
    rdfs:comment 'Current lifecycle state of the permit within the approval and execution workflow. Drives field access control and compliance dashboards. [ENUM-REF-CANDIDATE: draft|pending_approval|approved|active|suspended|closed|cancelled — promote to reference product]' ;
    rdfs:domain ind:PermitToWork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:permitType rdf:type rdf:Property ;
    rdfs:label 'Permit Type' ;
    rdfs:comment 'Classification of the permit based on the category of high-risk work being authorized. Drives the applicable hazard controls, sign-off chain, and regulatory requirements. [ENUM-REF-CANDIDATE: hot_work|confined_space|working_at_heights|electrical_isolation|excavation|radiography|lifting_operations|general_work — promote to reference product]' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reinstatementDetails rdf:type rdf:Property ;
    rdfs:label 'Reinstatement Details' ;
    rdfs:comment 'Description of site reinstatement actions completed upon permit closure, including removal of isolations, restoration of services, and area clearance confirmation.' ;
    rdfs:domain ind:PermitToWork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskLevel rdf:type rdf:Property ;
    rdfs:label 'Risk Level' ;
    rdfs:comment 'Overall risk rating assigned to the permitted work activity based on the hazard identification and risk assessment process. Determines the approval authority level required.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:suspensionReason rdf:type rdf:Property ;
    rdfs:label 'Suspension Reason' ;
    rdfs:comment 'Narrative reason for suspending the permit mid-execution (e.g., weather change, equipment failure, emergency evacuation). Populated when permit_status is \'suspended\'.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validUntil rdf:type rdf:Property ;
    rdfs:label 'Valid Until' ;
    rdfs:comment 'The date and time at which the permit expires and work must cease unless renewed. Critical for field enforcement and compliance auditing.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workLocationDescription rdf:type rdf:Property ;
    rdfs:label 'Work Location Description' ;
    rdfs:comment 'Specific location within the site where the permitted work is to be performed, including zone, level, grid reference, or equipment tag. Supplements the site_id with granular location detail.' ;
    rdfs:domain ind:PermitToWork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workScope rdf:type rdf:Property ;
    rdfs:label 'Work Scope' ;
    rdfs:comment 'Detailed narrative description of the specific work activities authorized under this permit, including methods, equipment, and materials involved. Sourced from Intelex PTW work description field.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workerCount rdf:type rdf:Property ;
    rdfs:label 'Worker Count' ;
    rdfs:comment 'Number of workers authorized to perform work under this permit. Used for site headcount control, emergency muster, and HSE exposure tracking.' ;
    rdfs:domain ind:PermitToWork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:validFrom rdf:type rdf:Property ;
    rdfs:label 'Valid From' ;
    rdfs:comment 'The date and time from which the permit is valid and work may commence. Must not precede the issued_timestamp. Used to enforce temporal access controls on site.' ;
    rdfs:domain ind:PermitToWork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualAttendeeCount rdf:type rdf:Property ;
    rdfs:label 'Actual Attendee Count' ;
    rdfs:comment 'Actual number of workers who attended and signed off on the Toolbox Meeting. Used to compute attendance rate and demonstrate safety communication compliance under OSHA and ISO 45001.' ;
    rdfs:domain ind:ToolboxMeeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:attendanceRatePct rdf:type rdf:Property ;
    rdfs:label 'Attendance Rate Pct' ;
    rdfs:comment 'Percentage of planned attendees who actually attended and signed off on the Toolbox Meeting (actual_attendee_count / planned_attendee_count × 100). Key HSE KPI for safety communication coverage reporting.' ;
    rdfs:domain ind:ToolboxMeeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:controlMeasuresCommunicated rdf:type rdf:Property ;
    rdfs:label 'Control Measures Communicated' ;
    rdfs:comment 'Description of the specific hazard control measures (elimination, substitution, engineering controls, administrative controls, PPE) communicated to attendees. Demonstrates hierarchy-of-controls compliance per ISO 45001 Clause 8.1.2.' ;
    rdfs:domain ind:ToolboxMeeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionRaised rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Raised' ;
    rdfs:comment 'Indicates whether any corrective actions or follow-up items were raised as a result of the Toolbox Meeting (e.g., identified hazards requiring remediation, equipment defects reported). Triggers workflow in Intelex for corrective action tracking.' ;
    rdfs:domain ind:ToolboxMeeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:correctiveActionReference rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Reference' ;
    rdfs:comment 'Reference number of the corrective action record raised in Intelex as a result of issues identified during the Toolbox Meeting. Enables traceability between TBM findings and corrective action closure.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentAttachmentReference rdf:type rdf:Property ;
    rdfs:label 'Document Attachment Reference' ;
    rdfs:comment 'Reference identifier or URL to supporting documents attached to the Toolbox Meeting record in Intelex or Aconex (e.g., signed attendance sheet, topic handout, SWMS extract). Supports document control under ISO 45001 Clause 7.5.' ;
    rdfs:domain ind:ToolboxMeeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:durationMinutes rdf:type rdf:Property ;
    rdfs:label 'Duration Minutes' ;
    rdfs:comment 'Actual duration of the Toolbox Meeting in minutes as recorded by the facilitator. Supports quality assurance checks to ensure meetings meet minimum required duration thresholds.' ;
    rdfs:domain ind:ToolboxMeeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:emergencyProceduresReviewed rdf:type rdf:Property ;
    rdfs:label 'Emergency Procedures Reviewed' ;
    rdfs:comment 'Indicates whether emergency response procedures (evacuation routes, muster points, emergency contacts) were reviewed with attendees during the Toolbox Meeting.' ;
    rdfs:domain ind:ToolboxMeeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:endTime rdf:type rdf:Property ;
    rdfs:label 'End Time' ;
    rdfs:comment 'Date and timestamp when the Toolbox Meeting concluded. Used in conjunction with start_time to compute actual meeting duration for compliance and quality reporting.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:facilitatorName rdf:type rdf:Property ;
    rdfs:label 'Facilitator Name' ;
    rdfs:comment 'Full name of the person who facilitated the Toolbox Meeting (supervisor, HSE officer, or foreman). Retained for accountability and regulatory audit purposes. Classified as confidential as it identifies an employee.' ;
    rdfs:domain ind:ToolboxMeeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilitatorQualification rdf:type rdf:Property ;
    rdfs:label 'Facilitator Qualification' ;
    rdfs:comment 'HSE qualification or certification held by the meeting facilitator (e.g., OSHA 30-Hour, ISO 45001 Lead Auditor, First Aid). Supports competency verification requirements under ISO 45001 Clause 7.2.' ;
    rdfs:domain ind:ToolboxMeeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazardsHighlighted rdf:type rdf:Property ;
    rdfs:label 'Hazards Highlighted' ;
    rdfs:comment 'Description of the specific site hazards communicated to attendees during the Toolbox Meeting, drawn from the linked risk assessment or SWMS (Safe Work Method Statement). Supports evidence of hazard communication under OSHA and ISO 45001.' ;
    rdfs:domain ind:ToolboxMeeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hseTopicCategory rdf:type rdf:Property ;
    rdfs:label 'Hse Topic Category' ;
    rdfs:comment 'Primary HSE topic category covered in the Toolbox Meeting (e.g., Working at Heights, Confined Space, Electrical Safety, Manual Handling, Environmental Compliance). Used for topic frequency analysis and gap identification. [ENUM-REF-CANDIDATE: working_at_heights|confined_space|electrical_safety|manual_handling|environmental|fire_prevention|excavation|crane_lifting|ppe_compliance|chemical_handling — promote to reference product]' ;
    rdfs:domain ind:ToolboxMeeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentReviewIncluded rdf:type rdf:Property ;
    rdfs:label 'Incident Review Included' ;
    rdfs:comment 'Indicates whether a review of recent incidents, near-misses, or LTI (Lost Time Injury) events was included in the Toolbox Meeting agenda. Supports learning-from-incidents culture and ISO 45001 Clause 10.2 requirements.' ;
    rdfs:domain ind:ToolboxMeeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:interpreterRequired rdf:type rdf:Property ;
    rdfs:label 'Interpreter Required' ;
    rdfs:comment 'Indicates whether an interpreter or translator was required and used during the Toolbox Meeting to communicate safety information to non-English-speaking workers.' ;
    rdfs:domain ind:ToolboxMeeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:languageConducted rdf:type rdf:Property ;
    rdfs:label 'Language Conducted' ;
    rdfs:comment 'ISO 639-2 three-letter language code for the primary language in which the Toolbox Meeting was conducted. Supports multilingual workforce compliance and OSHA Hazard Communication requirements for non-English-speaking workers.' ;
    rdfs:domain ind:ToolboxMeeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:meetingDate rdf:type rdf:Property ;
    rdfs:label 'Meeting Date' ;
    rdfs:comment 'Calendar date on which the Toolbox Meeting was conducted. Used for scheduling compliance checks, frequency reporting, and OSHA recordkeeping.' ;
    rdfs:domain ind:ToolboxMeeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:meetingLocation rdf:type rdf:Property ;
    rdfs:label 'Meeting Location' ;
    rdfs:comment 'Physical location or area on the construction site where the Toolbox Meeting was held (e.g., site office, work front, laydown area, specific grid reference). Supports site-level HSE reporting.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:meetingReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Meeting Reference Number' ;
    rdfs:comment 'Externally-known unique business identifier for the Toolbox Meeting as assigned by the HSE management system (Intelex). Used for cross-referencing in safety registers, audit trails, and regulatory submissions.' ;
    rdfs:domain ind:ToolboxMeeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:meetingStatus rdf:type rdf:Property ;
    rdfs:label 'Meeting Status' ;
    rdfs:comment 'Current lifecycle status of the Toolbox Meeting record. Drives workflow in Intelex and determines whether the meeting counts toward HSE compliance metrics.' ;
    rdfs:domain ind:ToolboxMeeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:meetingType rdf:type rdf:Property ;
    rdfs:label 'Meeting Type' ;
    rdfs:comment 'Classification of the Toolbox Meeting by its operational purpose. Pre-shift meetings occur at the start of each work shift; pre-task meetings are conducted immediately before a specific high-risk activity begins.' ;
    rdfs:domain ind:ToolboxMeeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedAttendeeCount rdf:type rdf:Property ;
    rdfs:label 'Planned Attendee Count' ;
    rdfs:comment 'Number of workers expected to attend the Toolbox Meeting based on the crew deployment plan. Used to calculate attendance rate and identify gaps in safety communication coverage.' ;
    rdfs:domain ind:ToolboxMeeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ppeRequirementsCommunicated rdf:type rdf:Property ;
    rdfs:label 'Ppe Requirements Communicated' ;
    rdfs:comment 'Indicates whether PPE (Personal Protective Equipment) requirements specific to the work activity were communicated to attendees during the Toolbox Meeting. Supports PPE compliance tracking under OSHA PPE standards.' ;
    rdfs:domain ind:ToolboxMeeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ptwReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Ptw Reference Number' ;
    rdfs:comment 'Reference number of the Permit to Work (PTW) associated with this Toolbox Meeting, where the meeting was conducted as part of the PTW pre-work briefing process.' ;
    rdfs:domain ind:ToolboxMeeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signOffMethod rdf:type rdf:Property ;
    rdfs:label 'Sign Off Method' ;
    rdfs:comment 'Method used to capture attendee acknowledgement and sign-off for the Toolbox Meeting. Determines the evidentiary value of the attendance record for regulatory compliance purposes.' ;
    rdfs:domain ind:ToolboxMeeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:startTime rdf:type rdf:Property ;
    rdfs:label 'Start Time' ;
    rdfs:comment 'Date and timestamp when the Toolbox Meeting commenced. Used to verify pre-shift or pre-task timing compliance and to calculate meeting duration.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:topicsDiscussed rdf:type rdf:Property ;
    rdfs:label 'Topics Discussed' ;
    rdfs:comment 'Free-text or structured summary of the safety topics covered during the Toolbox Meeting, including hazard types, regulatory requirements, and site-specific risks communicated to the crew. Sourced from Intelex TBM topic fields.' ;
    rdfs:domain ind:ToolboxMeeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wbsElementCode rdf:type rdf:Property ;
    rdfs:label 'Wbs Element Code' ;
    rdfs:comment 'WBS (Work Breakdown Structure) element code from Oracle Primavera P6 identifying the specific work package or activity for which this Toolbox Meeting was conducted. Enables linkage of HSE communication to project schedule activities.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditId rdf:type rdf:Property ;
    rdfs:label 'Audit Id' ;
    rdfs:comment 'Unique system-generated identifier for the safety audit record. Primary key for the safety_audit data product. Entity role: TRANSACTION_HEADER — represents a discrete formal HSE audit event with its own lifecycle, scope, team, findings, and close-out status.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:clientRepresentativeContactId rdf:type rdf:Property ;
    rdfs:label 'Client Representative Contact Id' ;
    rdfs:comment 'Foreign key linking to client.contact. Business justification: Client HSE representatives participate in or witness safety audits as a contractual requirement. Audit reports are formally submitted to the named client contact. Replaces denormalized auditee_name/au' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Contact .

ind:correctiveActionId rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Id' ;
    rdfs:comment 'Foreign key linking to quality.corrective_action. Business justification: Safety audit findings generate corrective actions tracked in the quality management system. Direct link from safety_audit to corrective_action enables audit close-out tracking without requiring an int' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CorrectiveAction .

ind:aconexDocumentRef rdf:type rdf:Property ;
    rdfs:label 'Aconex Document Ref' ;
    rdfs:comment 'Document reference number in the Aconex document management system for the formal audit report. Enables direct retrieval of the audit report from the document control system.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditCategory rdf:type rdf:Property ;
    rdfs:label 'Audit Category' ;
    rdfs:comment 'Functional category of the audit defining the primary subject matter: HSE management system, site safety operations, environmental compliance, fire safety, process safety, or contractor/subcontractor compliance. [ENUM-REF-CANDIDATE: hse_management_system|site_safety|environmental|fire_safety|process_safety|contractor_compliance — promote to reference product]' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditDate rdf:type rdf:Property ;
    rdfs:label 'Audit Date' ;
    rdfs:comment 'The principal date on which the audit was conducted (or the start date for multi-day audits). This is the primary business event date used for regulatory reporting and trend analysis.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:auditNumber rdf:type rdf:Property ;
    rdfs:label 'Audit Number' ;
    rdfs:comment 'Externally-known unique reference number assigned to the audit, used in correspondence, regulatory submissions, and Intelex Audits module. Format: AUD-YYYY-NNNNN.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditScope rdf:type rdf:Property ;
    rdfs:label 'Audit Scope' ;
    rdfs:comment 'Narrative description of the boundaries and subject matter of the audit, including work areas, activities, processes, and standards covered. Sourced from the Intelex audit scope field.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditStatus rdf:type rdf:Property ;
    rdfs:label 'Audit Status' ;
    rdfs:comment 'Current lifecycle state of the audit record: planned (scheduled but not started), in_progress (audit underway), completed (fieldwork done, report pending), closed (all findings resolved and signed off), or cancelled.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditType rdf:type rdf:Property ;
    rdfs:label 'Audit Type' ;
    rdfs:comment 'Classification of the audit by its origin and authority: internal (conducted by company HSE team), external (third-party), regulatory (OSHA/EPA enforcement), surveillance (ISO certification body), or certification (initial ISO certification audit).' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closeoutDate rdf:type rdf:Property ;
    rdfs:label 'Closeout Date' ;
    rdfs:comment 'Date on which all audit findings were resolved, verified, and the audit was formally closed. Null if the audit has not yet been closed. Key metric for HSE management system effectiveness.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:complianceRating rdf:type rdf:Property ;
    rdfs:label 'Compliance Rating' ;
    rdfs:comment 'Qualitative rating derived from the compliance score, providing a standardised categorical assessment of overall audit performance: satisfactory (≥90%), acceptable (75–89%), marginal (60–74%), unsatisfactory (40–59%), critical (<40%).' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceScore rdf:type rdf:Property ;
    rdfs:label 'Compliance Score' ;
    rdfs:comment 'Overall compliance score expressed as a percentage (0.00–100.00) calculated from the ratio of compliant audit criteria to total criteria assessed. The principal quantitative result of the audit. Used for trend analysis and HSE KPI dashboards.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:criteriaCompliant rdf:type rdf:Property ;
    rdfs:label 'Criteria Compliant' ;
    rdfs:comment 'Number of audit criteria assessed as fully compliant. Together with total_criteria_assessed, provides the raw data for compliance score calculation and trend reporting.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:endDate rdf:type rdf:Property ;
    rdfs:label 'End Date' ;
    rdfs:comment 'The date on which fieldwork for the audit was completed. Populated for multi-day audits to capture the full audit duration. Null for single-day audits.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:findingDetail rdf:type rdf:Property ;
    rdfs:label 'Finding Detail' ;
    rdfs:comment 'Embedded narrative summary of key audit findings captured at the header level for quick reference. Full individual finding records with severity, standard clause, responsible party, and due date are managed in the linked audit_finding child entity.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:immediateActionRequired rdf:type rdf:Property ;
    rdfs:label 'Immediate Action Required' ;
    rdfs:comment 'Indicates whether the audit identified at least one finding requiring immediate corrective action due to imminent risk to worker safety or regulatory non-compliance. Triggers escalation workflow in Intelex.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:intelexAuditReference rdf:type rdf:Property ;
    rdfs:label 'Intelex Audit Reference' ;
    rdfs:comment 'Source system identifier for this audit record in the Intelex HSE Management platform. Used for data lineage, reconciliation, and drill-back to the operational system of record.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leadAuditorName rdf:type rdf:Property ;
    rdfs:label 'Lead Auditor Name' ;
    rdfs:comment 'Full name of the lead auditor responsible for planning, conducting, and reporting the audit. Retained for accountability and regulatory traceability. Classified confidential as it identifies a named individual in a professional capacity.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:locationDescription rdf:type rdf:Property ;
    rdfs:label 'Location Description' ;
    rdfs:comment 'Free-text description of the specific location(s) within the site where the audit was conducted (e.g., \'North excavation zone, concrete batching plant, welfare facilities\'). Supplements the site_id reference.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:majorNcCount rdf:type rdf:Property ;
    rdfs:label 'Major Nc Count' ;
    rdfs:comment 'Number of major non-conformances (NCRs) identified during the audit. Major NCs represent significant failures against a standard clause that could result in regulatory action or certification suspension.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minorNcCount rdf:type rdf:Property ;
    rdfs:label 'Minor Nc Count' ;
    rdfs:comment 'Number of minor non-conformances identified during the audit. Minor NCs represent isolated or partial failures against a standard clause that do not immediately threaten system integrity.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nextAuditDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Audit Due Date' ;
    rdfs:comment 'Scheduled date for the next audit of the same scope and auditee, derived from the audit frequency plan. Used to drive the audit schedule and ensure compliance with ISO 45001 internal audit programme requirements.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:observationCount rdf:type rdf:Property ;
    rdfs:label 'Observation Count' ;
    rdfs:comment 'Number of observations raised during the audit. Observations are potential risks or areas of concern that do not yet constitute non-conformances but warrant monitoring.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ofiCount rdf:type rdf:Property ;
    rdfs:label 'Ofi Count' ;
    rdfs:comment 'Number of opportunities for improvement (OFIs) identified during the audit. OFIs are positive suggestions for enhancing HSE performance beyond current compliance requirements.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:openFindingsCount rdf:type rdf:Property ;
    rdfs:label 'Open Findings Count' ;
    rdfs:comment 'Number of audit findings that remain open (not yet resolved and verified) at the time of the last record update. Key metric for audit close-out tracking and corrective action management.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:programmeRef rdf:type rdf:Property ;
    rdfs:label 'Programme Ref' ;
    rdfs:comment 'Reference to the annual or project-level audit programme under which this audit was scheduled. Enables tracking of audit programme completion and coverage across the organisation.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryNotificationRequired rdf:type rdf:Property ;
    rdfs:label 'Regulatory Notification Required' ;
    rdfs:comment 'Indicates whether findings from this audit require formal notification to a regulatory authority (e.g., OSHA, EPA). Drives compliance reporting obligations and legal review workflows.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryStandard rdf:type rdf:Property ;
    rdfs:label 'Regulatory Standard' ;
    rdfs:comment 'Primary regulatory or management system standard against which the audit was conducted (e.g., OSHA 29 CFR 1926, ISO 45001:2018, ISO 14001:2015, site-specific HSE plan). Multiple standards may be listed separated by semicolons.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportIssueDate rdf:type rdf:Property ;
    rdfs:label 'Report Issue Date' ;
    rdfs:comment 'Date on which the formal audit report was issued to the auditee and relevant stakeholders. Used to track reporting timeliness and trigger finding response deadlines.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:stopWorkIssued rdf:type rdf:Property ;
    rdfs:label 'Stop Work Issued' ;
    rdfs:comment 'Indicates whether a stop-work order was issued as a result of critical findings identified during the audit. Triggers mandatory escalation to project management and HSE leadership.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:teamMembers rdf:type rdf:Property ;
    rdfs:label 'Team Members' ;
    rdfs:comment 'Comma-separated list of names or employee IDs of additional audit team members who participated in the audit. Stored as a denormalised string for reporting convenience; detailed team composition is managed in Intelex.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalCriteriaAssessed rdf:type rdf:Property ;
    rdfs:label 'Total Criteria Assessed' ;
    rdfs:comment 'Total number of audit criteria or checklist items evaluated during the audit. Used as the denominator for compliance score calculation and for comparing audit rigour across audits.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalFindings rdf:type rdf:Property ;
    rdfs:label 'Total Findings' ;
    rdfs:comment 'Total number of audit findings raised across all severity levels (non-conformances, observations, and opportunities for improvement). Provides a headline count for executive reporting.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hseInspectionId rdf:type rdf:Property ;
    rdfs:label 'Hse Inspection Id' ;
    rdfs:comment 'Unique system-generated identifier for each HSE inspection record. Primary key for the hse_inspection data product. Entity role: TRANSACTION_HEADER — represents a discrete field inspection event with a defined lifecycle.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:HseInspection .

ind:checklistId rdf:type rdf:Property ;
    rdfs:label 'Checklist Id' ;
    rdfs:comment 'Reference to the standardised checklist template used to conduct the inspection. Templates are aligned to inspection scope and regulatory requirements (e.g., OSHA scaffold checklist, excavation safety checklist).' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Checklist .

ind:correctiveActionRequired rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Required' ;
    rdfs:comment 'Indicates whether one or more formal corrective actions have been raised as a result of deficiencies identified during this inspection. When True, corrective action records are linked via the corrective_action product.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:criticalDeficiencyCount rdf:type rdf:Property ;
    rdfs:label 'Critical Deficiency Count' ;
    rdfs:comment 'Number of deficiencies classified as critical or high severity — those posing immediate risk to life, health, or structural integrity. Triggers mandatory stop-work authority and escalation protocols.' ;
    rdfs:domain ind:HseInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deficiencyCount rdf:type rdf:Property ;
    rdfs:label 'Deficiency Count' ;
    rdfs:comment 'Total number of distinct deficiencies or non-conformances identified during the inspection. Each deficiency may link to a corrective action record for remediation tracking.' ;
    rdfs:domain ind:HseInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:drillEvacuationComplete rdf:type rdf:Property ;
    rdfs:label 'Drill Evacuation Complete' ;
    rdfs:comment 'Indicates whether all personnel in the drill area were successfully evacuated and accounted for at the muster point during an emergency drill. Null for non-drill inspection types.' ;
    rdfs:domain ind:HseInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:drillMusterAccuracyPct rdf:type rdf:Property ;
    rdfs:label 'Drill Muster Accuracy Pct' ;
    rdfs:comment 'Percentage of expected personnel correctly accounted for at the designated muster point during an emergency drill. Expressed as a decimal percentage (e.g., 98.00 = 98%). Null for non-drill inspection types.' ;
    rdfs:domain ind:HseInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:drillResponseTimeSeconds rdf:type rdf:Property ;
    rdfs:label 'Drill Response Time Seconds' ;
    rdfs:comment 'Measured response time in seconds from drill initiation to full muster point assembly during an emergency drill exercise. Used to assess emergency preparedness against target response time benchmarks.' ;
    rdfs:domain ind:HseInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:drillType rdf:type rdf:Property ;
    rdfs:label 'Drill Type' ;
    rdfs:comment 'For inspections of type \'emergency_drill\', specifies the category of drill exercise conducted. Null for non-drill inspection types.' ;
    rdfs:domain ind:HseInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:generalObservations rdf:type rdf:Property ;
    rdfs:label 'General Observations' ;
    rdfs:comment 'Free-text field capturing the inspector\'s overall field observations, positive findings, and contextual notes not captured by structured checklist items. Supports qualitative safety culture assessment.' ;
    rdfs:domain ind:HseInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:highestDeficiencySeverity rdf:type rdf:Property ;
    rdfs:label 'Highest Deficiency Severity' ;
    rdfs:comment 'The most severe deficiency classification recorded during the inspection. Used for risk prioritisation, escalation routing, and executive safety dashboards.' ;
    rdfs:domain ind:HseInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:immediateActionDescription rdf:type rdf:Property ;
    rdfs:label 'Immediate Action Description' ;
    rdfs:comment 'Narrative description of any immediate corrective actions taken on site during the inspection to mitigate identified hazards or deficiencies before formal remediation.' ;
    rdfs:domain ind:HseInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:immediateActionTaken rdf:type rdf:Property ;
    rdfs:label 'Immediate Action Taken' ;
    rdfs:comment 'Indicates whether immediate corrective action was taken on site at the time of inspection to address identified deficiencies, prior to formal corrective action workflow initiation.' ;
    rdfs:domain ind:HseInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inspectionDate rdf:type rdf:Property ;
    rdfs:label 'Inspection Date' ;
    rdfs:comment 'Calendar date on which the HSE inspection was conducted in the field. Principal real-world event date for scheduling, trending, and regulatory reporting. BUSINESS_EVENT_TIMESTAMP category.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:inspectionEndTime rdf:type rdf:Property ;
    rdfs:label 'Inspection End Time' ;
    rdfs:comment 'Precise date and time when the inspection was concluded on site. Combined with start time to derive inspection duration for workload and thoroughness analytics.' ;
    rdfs:domain ind:HseInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:inspectionNumber rdf:type rdf:Property ;
    rdfs:label 'Inspection Number' ;
    rdfs:comment 'Externally-known alphanumeric reference number assigned to the inspection, used in correspondence, corrective action linkage, and regulatory submissions. Sourced from Intelex Inspections module. BUSINESS_IDENTIFIER category.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionScope rdf:type rdf:Property ;
    rdfs:label 'Inspection Scope' ;
    rdfs:comment 'Primary subject area or hazard category that the inspection focused on. Drives checklist template selection and enables trend analysis by hazard type. [ENUM-REF-CANDIDATE: housekeeping|ppe_compliance|scaffolding_formwork|excavation|crane_rigging|electrical|fire_prevention|emergency_preparedness|work_practice — promote to reference product]' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionStartTime rdf:type rdf:Property ;
    rdfs:label 'Inspection Start Time' ;
    rdfs:comment 'Precise date and time when the inspection commenced on site. Used for duration calculation and scheduling compliance verification.' ;
    rdfs:domain ind:HseInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:inspectionStatus rdf:type rdf:Property ;
    rdfs:label 'Inspection Status' ;
    rdfs:comment 'Current lifecycle state of the inspection record. Tracks workflow progression from field data capture through review and closure. LIFECYCLE_STATUS category.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionType rdf:type rdf:Property ;
    rdfs:label 'Inspection Type' ;
    rdfs:comment 'Classification of the inspection by its purpose and trigger. Routine = scheduled periodic check; Targeted = focused on a specific hazard or area; Pre-task = conducted before high-risk work commences; Emergency drill = evacuation or emergency response exercise; Management walk = senior leadership safety observation. CLASSIFICATION_OR_TYPE category.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:intelexInspectionRef rdf:type rdf:Property ;
    rdfs:label 'Intelex Inspection Ref' ;
    rdfs:comment 'Source system reference identifier from the Intelex HSE Management platform Inspections module. Enables traceability back to the operational system of record for audit and reconciliation purposes.' ;
    rdfs:domain ind:HseInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isScheduled rdf:type rdf:Property ;
    rdfs:label 'Is Scheduled' ;
    rdfs:comment 'Indicates whether the inspection was pre-planned and scheduled (True) or conducted on an ad-hoc/unannounced basis (False). Supports analysis of proactive vs reactive inspection activity.' ;
    rdfs:domain ind:HseInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:itemsFailed rdf:type rdf:Property ;
    rdfs:label 'Items Failed' ;
    rdfs:comment 'Number of checklist items found to be non-compliant or deficient during the inspection. Drives corrective action generation and severity classification.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:itemsNotApplicable rdf:type rdf:Property ;
    rdfs:label 'Items Not Applicable' ;
    rdfs:comment 'Number of checklist items marked as not applicable for the specific site conditions or work scope at the time of inspection. Ensures accurate compliance rate calculation.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:itemsPassed rdf:type rdf:Property ;
    rdfs:label 'Items Passed' ;
    rdfs:comment 'Number of checklist items that were found to be compliant or satisfactory during the inspection. Used with total_items_checked to derive pass rate for trend reporting.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:overallResult rdf:type rdf:Property ;
    rdfs:label 'Overall Result' ;
    rdfs:comment 'Summary outcome of the inspection based on the aggregate of checklist item results and deficiency severity. Determines whether immediate stop-work or corrective action is required.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:photoEvidenceCount rdf:type rdf:Property ;
    rdfs:label 'Photo Evidence Count' ;
    rdfs:comment 'Number of photographs attached to the inspection record as evidence of conditions observed, deficiencies identified, or positive practices noted. Supports dispute resolution and regulatory submissions.' ;
    rdfs:domain ind:HseInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:photoEvidenceReference rdf:type rdf:Property ;
    rdfs:label 'Photo Evidence Reference' ;
    rdfs:comment 'Document management system reference or folder path pointing to photographic evidence files associated with this inspection. Typically links to Aconex or Intelex document store.' ;
    rdfs:domain ind:HseInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ppeComplianceRate rdf:type rdf:Property ;
    rdfs:label 'Ppe Compliance Rate' ;
    rdfs:comment 'Percentage of workers observed wearing required Personal Protective Equipment (PPE) correctly at the time of inspection. Expressed as a decimal percentage (e.g., 95.50 = 95.5%). Key leading indicator for HSE performance dashboards.' ;
    rdfs:domain ind:HseInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scheduledDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Date' ;
    rdfs:comment 'The originally planned date for the inspection as per the HSE inspection schedule. Compared against inspection_date to identify overdue or rescheduled inspections.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:totalItemsChecked rdf:type rdf:Property ;
    rdfs:label 'Total Items Checked' ;
    rdfs:comment 'Total number of checklist line items assessed during the inspection. Used as the denominator for compliance rate calculations and inspection thoroughness metrics.' ;
    rdfs:domain ind:HseInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:workerCountObserved rdf:type rdf:Property ;
    rdfs:label 'Worker Count Observed' ;
    rdfs:comment 'Number of workers present in the inspected area at the time of the inspection. Used to contextualise exposure levels and normalise deficiency rates per worker.' ;
    rdfs:domain ind:HseInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:clientHseContactId rdf:type rdf:Property ;
    rdfs:label 'Client Hse Contact Id' ;
    rdfs:comment 'Foreign key linking to client.contact. Business justification: Clients contractually designate a named HSE representative who approves and receives the project HSE plan. Construction contracts require identification of the client HSE contact for plan submission, ' ;
    rdfs:domain ind:HsePlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Contact .

ind:applicableRegulations rdf:type rdf:Property ;
    rdfs:label 'Applicable Regulations' ;
    rdfs:comment 'Comma-separated list of regulatory frameworks, standards, and governing body requirements applicable to this HSE Plan (e.g., OSHA 29 CFR 1926, ISO 45001:2018, ISO 14001:2015, NFPA 70E, local jurisdiction building codes). Drives compliance obligation tracking.' ;
    rdfs:domain ind:HsePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditFrequencyMonths rdf:type rdf:Property ;
    rdfs:label 'Audit Frequency Months' ;
    rdfs:comment 'Frequency in months at which formal HSE audits must be conducted on the project as specified in the HSE Plan. Drives the audit schedule in Intelex and ensures compliance with ISO 45001 internal audit requirements.' ;
    rdfs:domain ind:HsePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:clientHseRequirements rdf:type rdf:Property ;
    rdfs:label 'Client Hse Requirements' ;
    rdfs:comment 'Summary of client-specific HSE requirements and standards that must be incorporated into the project HSE Plan, beyond the contractor\'s standard requirements. Sourced from the contract HSE specification or client HSE management system.' ;
    rdfs:domain ind:HsePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentReference rdf:type rdf:Property ;
    rdfs:label 'Document Reference' ;
    rdfs:comment 'Document management system reference or URL pointing to the full HSE Plan document stored in Aconex or the project document management system. Provides traceability to the source document.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emergencyContactName rdf:type rdf:Property ;
    rdfs:label 'Emergency Contact Name' ;
    rdfs:comment 'Name of the primary emergency response coordinator or HSE emergency contact for the project site. Referenced during incident response and emergency drills.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emergencyContactPhone rdf:type rdf:Property ;
    rdfs:label 'Emergency Contact Phone' ;
    rdfs:comment 'Primary phone number for the site emergency response coordinator. Must be accessible 24/7 during active construction phases for incident notification and emergency mobilisation.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:environmentalAspects rdf:type rdf:Property ;
    rdfs:label 'Environmental Aspects' ;
    rdfs:comment 'Description of the significant environmental aspects and impacts identified for the project (e.g., noise, dust, stormwater runoff, waste management, soil contamination, protected species). Informs the environmental management controls within the HSE Plan.' ;
    rdfs:domain ind:HsePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hseObjectiveDescription rdf:type rdf:Property ;
    rdfs:label 'Hse Objective Description' ;
    rdfs:comment 'Narrative description of the project-level HSE objectives and targets established for this plan period (e.g., zero LTI, TRIR below 0.5, 100% PPE compliance, zero environmental non-conformances). Aligns with corporate HSE KPI framework.' ;
    rdfs:domain ind:HsePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentReportingProcedure rdf:type rdf:Property ;
    rdfs:label 'Incident Reporting Procedure' ;
    rdfs:comment 'Description or document reference number for the incident reporting and investigation procedure defined in the HSE Plan. Specifies notification timelines, investigation requirements, and regulatory reporting obligations (e.g., OSHA 300 log, fatality notification within 8 hours).' ;
    rdfs:domain ind:HsePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inductionRequired rdf:type rdf:Property ;
    rdfs:label 'Induction Required' ;
    rdfs:comment 'Indicates whether all personnel must complete a formal site HSE induction before commencing work on the project, as mandated by the HSE Plan. When true, no worker may access the site without a valid induction record.' ;
    rdfs:domain ind:HsePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ltiTarget rdf:type rdf:Property ;
    rdfs:label 'Lti Target' ;
    rdfs:comment 'Target number of Lost Time Injuries (LTI) for the project duration as defined in the HSE Plan. Typically set to zero for major construction projects. Used as a benchmark for HSE performance reporting.' ;
    rdfs:domain ind:HsePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:musterPointDescription rdf:type rdf:Property ;
    rdfs:label 'Muster Point Description' ;
    rdfs:comment 'Description and location of the designated emergency assembly/muster point(s) for the construction site. Critical for emergency evacuation procedures and headcount verification.' ;
    rdfs:domain ind:HsePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nearestHospital rdf:type rdf:Property ;
    rdfs:label 'Nearest Hospital' ;
    rdfs:comment 'Name and address of the nearest hospital or medical facility to the construction site. Mandatory field for emergency response planning and first aid procedures documentation.' ;
    rdfs:domain ind:HsePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextReviewDate rdf:type rdf:Property ;
    rdfs:label 'Next Review Date' ;
    rdfs:comment 'Scheduled date for the next formal review of the HSE Plan. Drives the review calendar and ensures the plan remains current with site conditions, regulatory changes, and project phase transitions.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planNumber rdf:type rdf:Property ;
    rdfs:label 'Plan Number' ;
    rdfs:comment 'Externally-known unique document control number assigned to the HSE Plan, used for referencing in correspondence, audits, and regulatory submissions. Typically follows the project document numbering convention (e.g., HSE-PRJ001-2024-001).' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planStatus rdf:type rdf:Property ;
    rdfs:label 'Plan Status' ;
    rdfs:comment 'Current lifecycle status of the HSE Plan document. Controls whether the plan is the active governing document for site operations. \'approved\' indicates the plan is the current SSOT for project HSE governance.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planTitle rdf:type rdf:Property ;
    rdfs:label 'Plan Title' ;
    rdfs:comment 'Official title of the HSE Plan document as it appears on the cover page and in the document register (e.g., \'Project HSE Management Plan — Highway 7 Extension\').' ;
    rdfs:domain ind:HsePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planType rdf:type rdf:Property ;
    rdfs:label 'Plan Type' ;
    rdfs:comment 'Classification of the HSE Plan by scope and purpose. Distinguishes between overarching project-level plans, site-specific plans, environmental management plans, emergency response plans, and construction phase plans. [ENUM-REF-CANDIDATE: project_hse_plan|site_specific_hse_plan|environmental_management_plan|emergency_response_plan|construction_phase_plan|occupational_health_plan — promote to reference product]' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planVersion rdf:type rdf:Property ;
    rdfs:label 'Plan Version' ;
    rdfs:comment 'Document version number of the HSE Plan following the project document control versioning convention (e.g., 1.0, 2.1, 3.0). Incremented upon each approved revision.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preparedBy rdf:type rdf:Property ;
    rdfs:label 'Prepared By' ;
    rdfs:comment 'Name or employee identifier of the HSE professional who authored and prepared this version of the HSE Plan. Typically the Project HSE Manager or HSE Coordinator.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectPhase rdf:type rdf:Property ;
    rdfs:label 'Project Phase' ;
    rdfs:comment 'Construction project phase to which this HSE Plan version primarily applies. HSE requirements and hazard profiles differ significantly across project phases.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewFrequencyMonths rdf:type rdf:Property ;
    rdfs:label 'Review Frequency Months' ;
    rdfs:comment 'Frequency in months at which the HSE Plan must be formally reviewed and updated. Typically 6 or 12 months, or triggered by significant project phase changes, incidents, or regulatory updates.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:riskRating rdf:type rdf:Property ;
    rdfs:label 'Risk Rating' ;
    rdfs:comment 'Overall HSE risk rating assigned to the project based on the site hazard assessment. Drives the level of HSE oversight, inspection frequency, and resource allocation required.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteLocation rdf:type rdf:Property ;
    rdfs:label 'Site Location' ;
    rdfs:comment 'Physical address or geographic description of the primary construction site covered by this HSE Plan. Used for emergency response coordination and regulatory jurisdiction determination.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteSpecificHazards rdf:type rdf:Property ;
    rdfs:label 'Site Specific Hazards' ;
    rdfs:comment 'Narrative description of the key site-specific hazards identified for this project (e.g., working at height, confined spaces, high-voltage proximity, ground contamination, extreme weather, traffic management). Informs the risk control hierarchy documented in the plan.' ;
    rdfs:domain ind:HsePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subcontractorHseRequirements rdf:type rdf:Property ;
    rdfs:label 'Subcontractor Hse Requirements' ;
    rdfs:comment 'Description of the HSE requirements imposed on subcontractors working under this project HSE Plan, including pre-qualification criteria, SWMS submission requirements, induction obligations, and compliance monitoring expectations.' ;
    rdfs:domain ind:HsePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:swmsRequired rdf:type rdf:Property ;
    rdfs:label 'Swms Required' ;
    rdfs:comment 'Indicates whether Safe Work Method Statements (SWMS) are mandated for high-risk construction work activities on this project as per the HSE Plan. When true, SWMS must be prepared and approved before commencing designated high-risk activities.' ;
    rdfs:domain ind:HsePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tbmFrequency rdf:type rdf:Property ;
    rdfs:label 'Tbm Frequency' ;
    rdfs:comment 'Required frequency of Toolbox Meetings (TBM) as mandated by the HSE Plan. TBMs are pre-work safety briefings conducted with the workforce to communicate hazards, controls, and daily work instructions.' ;
    rdfs:domain ind:HsePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trirTarget rdf:type rdf:Property ;
    rdfs:label 'Trir Target' ;
    rdfs:comment 'Target Total Recordable Incident Rate (TRIR) for the project as defined in the HSE Plan. Expressed per 200,000 man-hours worked. Used as the primary lagging indicator for HSE performance benchmarking.' ;
    rdfs:domain ind:HsePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assessedBy rdf:type rdf:Property ;
    rdfs:label 'Assessed By' ;
    rdfs:comment 'Name of the HSE professional, engineer, or competent person who conducted and documented this risk assessment.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentDate rdf:type rdf:Property ;
    rdfs:label 'Assessment Date' ;
    rdfs:comment 'The date on which this risk assessment was formally conducted and documented. Represents the principal business event date for this record.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assessmentNumber rdf:type rdf:Property ;
    rdfs:label 'Assessment Number' ;
    rdfs:comment 'Externally-known unique alphanumeric reference number assigned to this risk assessment record, used in SWMS, PTW, and HSE correspondence. Format: RA-{ProjectCode}-{Sequence}.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentStatus rdf:type rdf:Property ;
    rdfs:label 'Assessment Status' ;
    rdfs:comment 'Current lifecycle status of the risk assessment record: Open (hazard identified, controls not yet fully implemented), Controlled (controls in place, residual risk tolerable), Eliminated (hazard fully removed), Closed (no longer applicable), or Under Review (being reassessed).' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentType rdf:type rdf:Property ;
    rdfs:label 'Assessment Type' ;
    rdfs:comment 'Classification of the purpose and context of this risk assessment: Job Hazard Analysis (JHA) for task-level evaluation, SWMS support, PTW issuance support, design review, field inspection, or derived from an incident investigation.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlHierarchy rdf:type rdf:Property ;
    rdfs:label 'Control Hierarchy' ;
    rdfs:comment 'Highest level of the Hierarchy of Controls applied to this hazard: Eliminate, Substitute, Engineering controls, Administrative controls, or Personal Protective Equipment (PPE). Reflects the most effective control measure in place.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:environmentalAspect rdf:type rdf:Property ;
    rdfs:label 'Environmental Aspect' ;
    rdfs:comment 'Indicates whether this risk assessment includes an environmental aspect or impact in addition to occupational health and safety considerations (True = environmental component present). Supports ISO 14001 compliance.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:environmentalImpactDescription rdf:type rdf:Property ;
    rdfs:label 'Environmental Impact Description' ;
    rdfs:comment 'Description of the environmental impact or aspect associated with this hazard, where applicable (e.g., soil contamination from chemical spill, noise pollution, stormwater runoff). Populated when environmental_aspect is True.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazardType rdf:type rdf:Property ;
    rdfs:label 'Hazard Type' ;
    rdfs:comment 'Classification of the hazard category identified in this assessment. [ENUM-REF-CANDIDATE: fall|struck_by|caught_between|electrocution|excavation_collapse|chemical_exposure|environmental|fire_explosion|manual_handling|noise_vibration|biological|radiation — promote to reference product]' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initialConsequence rdf:type rdf:Property ;
    rdfs:label 'Initial Consequence' ;
    rdfs:comment 'Consequence/severity score assigned before control measures are applied, rated on the project risk matrix scale (typically 1–5: 1=Insignificant, 2=Minor, 3=Moderate, 4=Major, 5=Catastrophic).' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:initialLikelihood rdf:type rdf:Property ;
    rdfs:label 'Initial Likelihood' ;
    rdfs:comment 'Likelihood score assigned before control measures are applied, rated on the project risk matrix scale (typically 1–5: 1=Rare, 2=Unlikely, 3=Possible, 4=Likely, 5=Almost Certain).' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:initialRiskLevel rdf:type rdf:Property ;
    rdfs:label 'Initial Risk Level' ;
    rdfs:comment 'Qualitative risk band derived from the initial risk score using the project risk matrix (e.g., Low, Medium, High, Extreme). Used for prioritisation and reporting before controls are applied.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initialRiskScore rdf:type rdf:Property ;
    rdfs:label 'Initial Risk Score' ;
    rdfs:comment 'Pre-control risk score calculated as the product of initial likelihood and initial consequence ratings (Likelihood × Consequence). Represents the inherent risk level before any controls are applied.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:residualConsequence rdf:type rdf:Property ;
    rdfs:label 'Residual Consequence' ;
    rdfs:comment 'Consequence/severity score after all control measures have been applied, rated on the project risk matrix scale (typically 1–5). Reflects the remaining severity of harm post-control.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:residualLikelihood rdf:type rdf:Property ;
    rdfs:label 'Residual Likelihood' ;
    rdfs:comment 'Likelihood score after all control measures have been applied, rated on the project risk matrix scale (typically 1–5). Reflects the remaining probability of the hazard being realised post-control.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:residualRiskLevel rdf:type rdf:Property ;
    rdfs:label 'Residual Risk Level' ;
    rdfs:comment 'Qualitative risk band derived from the residual risk score using the project risk matrix (e.g., Low, Medium, High, Extreme). Determines whether the risk is tolerable and whether additional controls are required.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsiblePartyRole rdf:type rdf:Property ;
    rdfs:label 'Responsible Party Role' ;
    rdfs:comment 'Job role or organisational function of the person responsible for implementing and monitoring the control measures associated with this risk assessment.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskMatrixVersion rdf:type rdf:Property ;
    rdfs:label 'Risk Matrix Version' ;
    rdfs:comment 'Version identifier of the project or corporate risk matrix used to score likelihood and consequence for this assessment. Ensures consistent interpretation of risk scores across assessments and over time.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteZone rdf:type rdf:Property ;
    rdfs:label 'Site Zone' ;
    rdfs:comment 'Specific site area, zone, level, or grid reference where the hazard exists or the activity is performed (e.g., Zone A, Level 3, Grid B4, Excavation Area 2).' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceType rdf:type rdf:Property ;
    rdfs:label 'Source Type' ;
    rdfs:comment 'Origin or trigger that led to the identification and recording of this hazard — e.g., field inspection, incident investigation, design review, JHA session, HSE audit, near-miss report, or Toolbox Meeting (TBM). [ENUM-REF-CANDIDATE: inspection|incident|design_review|jha|audit|near_miss|toolbox_meeting — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualClosureDate rdf:type rdf:Property ;
    rdfs:label 'Actual Closure Date' ;
    rdfs:comment 'Date on which the hazard was verified as eliminated or controlled to an acceptable residual risk level and the record was formally closed. Null if the hazard remains open or controlled.' ;
    rdfs:domain ind:HazardRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:affectedWorkersCount rdf:type rdf:Property ;
    rdfs:label 'Affected Workers Count' ;
    rdfs:comment 'Estimated number of workers potentially exposed to this hazard during normal site operations. Used for exposure assessment, risk prioritisation, and OSHA regulatory reporting.' ;
    rdfs:domain ind:HazardRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:controlMeasuresDescription rdf:type rdf:Property ;
    rdfs:label 'Control Measures Description' ;
    rdfs:comment 'Narrative description of all control measures currently in place to manage the hazard, including engineering controls, administrative procedures, PPE requirements, and permit conditions. Sourced from Intelex corrective actions and SWMS documentation.' ;
    rdfs:domain ind:HazardRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazardCategory rdf:type rdf:Property ;
    rdfs:label 'Hazard Category' ;
    rdfs:comment 'Broad category grouping the hazard by agent type for aggregate HSE reporting and trend analysis. Supports ISO 45001 hazard identification and risk assessment processes.' ;
    rdfs:domain ind:HazardRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazardReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Hazard Reference Number' ;
    rdfs:comment 'Externally-known alphanumeric identifier assigned to the hazard record, used in HSE correspondence, toolbox meeting (TBM) briefings, and regulatory submissions. Sourced from Intelex HSE Management system.' ;
    rdfs:domain ind:HazardRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazardStatus rdf:type rdf:Property ;
    rdfs:label 'Hazard Status' ;
    rdfs:comment 'Current lifecycle status of the hazard record. open = identified but controls not yet fully implemented; controlled = controls in place and residual risk is tolerable; eliminated = hazard has been fully removed; closed = record closed after verification. Drives the live hazard inventory for site visibility.' ;
    rdfs:domain ind:HazardRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazardTitle rdf:type rdf:Property ;
    rdfs:label 'Hazard Title' ;
    rdfs:comment 'Short, human-readable title describing the hazard (e.g., \'Unguarded floor opening — Level 3\', \'Overhead power line proximity — Zone B\'). Used in pre-start briefings and toolbox meeting topic selection.' ;
    rdfs:domain ind:HazardRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hierarchyOfControls rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Of Controls' ;
    rdfs:comment 'Highest level of the hierarchy of controls applied to manage this hazard, per ISO 45001 and OSHA guidance. Values: elimination (remove hazard), substitution (replace with lesser hazard), engineering (physical barriers/guards), administrative (procedures/training), ppe (Personal Protective Equipment). Drives control effectiveness assessment.' ;
    rdfs:domain ind:HazardRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:identificationSource rdf:type rdf:Property ;
    rdfs:label 'Identification Source' ;
    rdfs:comment 'The originating activity or process through which the hazard was identified. Supports root-cause analysis and evaluation of hazard identification program effectiveness. Values: risk_assessment, inspection, incident, audit, near_miss, worker_report.' ;
    rdfs:domain ind:HazardRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initialConsequenceRating rdf:type rdf:Property ;
    rdfs:label 'Initial Consequence Rating' ;
    rdfs:comment 'Numeric consequence/severity score assigned during initial risk assessment before controls are applied, typically on a 1–5 scale (1=Insignificant, 5=Catastrophic). Component of the initial risk rating matrix (likelihood × consequence).' ;
    rdfs:domain ind:HazardRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:initialLikelihoodRating rdf:type rdf:Property ;
    rdfs:label 'Initial Likelihood Rating' ;
    rdfs:comment 'Numeric likelihood score assigned during initial risk assessment before controls are applied, typically on a 1–5 scale (1=Rare, 5=Almost Certain). Component of the initial risk rating matrix (likelihood × consequence).' ;
    rdfs:domain ind:HazardRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastReviewDate rdf:type rdf:Property ;
    rdfs:label 'Last Review Date' ;
    rdfs:comment 'Date on which the hazard record was most recently reviewed and updated by the responsible HSE officer or site supervisor. Supports periodic review compliance requirements under ISO 45001 and regulatory obligations.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:permitToWorkRequired rdf:type rdf:Property ;
    rdfs:label 'Permit To Work Required' ;
    rdfs:comment 'Indicates whether a Permit to Work (PTW) is mandatory before any work activity associated with this hazard can commence. True = PTW required (e.g., confined space entry, hot work, electrical isolation). Integrates with Intelex Permit to Work module.' ;
    rdfs:domain ind:HazardRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:residualConsequenceRating rdf:type rdf:Property ;
    rdfs:label 'Residual Consequence Rating' ;
    rdfs:comment 'Numeric consequence/severity score after all control measures have been applied, on the same 1–5 scale as initial_consequence_rating. Reflects the effectiveness of controls in reducing severity of potential harm.' ;
    rdfs:domain ind:HazardRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:residualLikelihoodRating rdf:type rdf:Property ;
    rdfs:label 'Residual Likelihood Rating' ;
    rdfs:comment 'Numeric likelihood score after all control measures have been applied, on the same 1–5 scale as initial_likelihood_rating. Reflects the effectiveness of controls in reducing probability of harm.' ;
    rdfs:domain ind:HazardRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:swmsReference rdf:type rdf:Property ;
    rdfs:label 'Swms Reference' ;
    rdfs:comment 'Document reference number of the Safe Work Method Statement (SWMS) that addresses this hazard and its control measures. Links the hazard register to the SWMS document library in Aconex or Procore.' ;
    rdfs:domain ind:HazardRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetClosureDate rdf:type rdf:Property ;
    rdfs:label 'Target Closure Date' ;
    rdfs:comment 'Target date by which the hazard is expected to be eliminated or reduced to a tolerable residual risk level. Used for corrective action scheduling and overdue hazard reporting.' ;
    rdfs:domain ind:HazardRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:tbmTopicFlag rdf:type rdf:Property ;
    rdfs:label 'Tbm Topic Flag' ;
    rdfs:comment 'Indicates whether this hazard has been selected or is recommended as a topic for an upcoming Toolbox Meeting (TBM). True = flagged for TBM discussion. Supports automated TBM topic selection from the live hazard register.' ;
    rdfs:domain ind:HazardRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:environmentalMonitoringId rdf:type rdf:Property ;
    rdfs:label 'Environmental Monitoring Id' ;
    rdfs:comment 'Primary key for environmental_monitoring' ;
    rdfs:domain ind:EnvironmentalMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dataQualityFlag rdf:type rdf:Property ;
    rdfs:label 'Data Quality Flag' ;
    rdfs:comment 'Quality assurance flag indicating the reliability and validity of the measurement value. \'Suspect\' indicates potential instrument malfunction or anomalous conditions; \'Below Detection Limit\' indicates the parameter was not detectable at the instrument\'s minimum detection level. Used in QA/QC review.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:detectionLimit rdf:type rdf:Property ;
    rdfs:label 'Detection Limit' ;
    rdfs:comment 'The minimum detection limit (MDL) of the instrument or analytical method for this parameter, expressed in the same unit as measurement_value. Used to contextualise results flagged as \'below_detection_limit\' and for regulatory reporting of non-detects.' ;
    rdfs:domain ind:EnvironmentalMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exceedanceFlag rdf:type rdf:Property ;
    rdfs:label 'Exceedance Flag' ;
    rdfs:comment 'Indicates whether the recorded measurement value has exceeded (or fallen below, for minimum thresholds) the applicable regulatory or permit threshold limit. True = exceedance detected; False = within acceptable limits. Triggers corrective action workflow in Intelex.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:exceedanceMagnitude rdf:type rdf:Property ;
    rdfs:label 'Exceedance Magnitude' ;
    rdfs:comment 'The absolute difference between the measured value and the threshold limit when an exceedance is detected. Null when exceedance_flag is False. Used to prioritise severity of environmental non-compliance and escalation response.' ;
    rdfs:domain ind:EnvironmentalMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:instrumentCalibrationDate rdf:type rdf:Property ;
    rdfs:label 'Instrument Calibration Date' ;
    rdfs:comment 'The date on which the monitoring instrument was last calibrated prior to this measurement. Used to verify that measurements were taken with a calibrated instrument within the required calibration interval, supporting regulatory defensibility.' ;
    rdfs:domain ind:EnvironmentalMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:instrumentCalibrationDueDate rdf:type rdf:Property ;
    rdfs:label 'Instrument Calibration Due Date' ;
    rdfs:comment 'The date by which the monitoring instrument must next be calibrated to remain within its valid calibration period. Measurements taken after this date may be flagged as non-compliant for regulatory reporting purposes.' ;
    rdfs:domain ind:EnvironmentalMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:instrumentCode rdf:type rdf:Property ;
    rdfs:label 'Instrument Code' ;
    rdfs:comment 'Unique identifier or asset tag of the instrument, sensor, or analyser used to take the measurement (e.g., dust monitor serial number, noise meter ID, water quality probe ID). Supports instrument calibration traceability and equipment maintenance records.' ;
    rdfs:domain ind:EnvironmentalMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:instrumentType rdf:type rdf:Property ;
    rdfs:label 'Instrument Type' ;
    rdfs:comment 'Classification of the instrument or sensor type used for the measurement (e.g., \'Dust Monitor\', \'Sound Level Meter\', \'Vibration Meter\', \'Multi-parameter Water Quality Probe\', \'Gas Analyser\'). Used for equipment management and calibration scheduling. [ENUM-REF-CANDIDATE: dust_monitor|sound_level_meter|vibration_meter|water_quality_probe|gas_analyser|turbidimeter|pH_meter|portable_gas_detector — promote to reference product]' ;
    rdfs:domain ind:EnvironmentalMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:laboratoryName rdf:type rdf:Property ;
    rdfs:label 'Laboratory Name' ;
    rdfs:comment 'Name of the accredited analytical laboratory that performed sample analysis, where applicable (e.g., for water quality, soil contamination, or chemical air quality samples sent for laboratory analysis). Null for field-measured parameters.' ;
    rdfs:domain ind:EnvironmentalMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:laboratoryReportNumber rdf:type rdf:Property ;
    rdfs:label 'Laboratory Report Number' ;
    rdfs:comment 'The unique report or chain-of-custody number issued by the analytical laboratory for the sample analysis. Provides traceability from the field sample to the laboratory result and supports regulatory audit documentation.' ;
    rdfs:domain ind:EnvironmentalMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementTimestamp rdf:type rdf:Property ;
    rdfs:label 'Measurement Timestamp' ;
    rdfs:comment 'The exact date and time at which the environmental measurement or reading was taken in the field. This is the principal real-world event time, distinct from record creation audit timestamps. Stored in ISO 8601 format with timezone offset.' ;
    rdfs:domain ind:EnvironmentalMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:measurementUnit rdf:type rdf:Property ;
    rdfs:label 'Measurement Unit' ;
    rdfs:comment 'The unit of measure for the recorded measurement value (e.g., µg/m³, mg/L, dB(A), mm/s, NTU, pH, ppm, mg/kg). Must align with the unit specified in the applicable environmental permit or regulatory standard for the parameter. [ENUM-REF-CANDIDATE: µg/m³|mg/L|dB(A)|mm/s|NTU|pH|ppm|mg/kg|µS/cm|°C — promote to reference product]' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementValue rdf:type rdf:Property ;
    rdfs:label 'Measurement Value' ;
    rdfs:comment 'The numeric reading or measured value recorded for the environmental parameter at the monitoring location and timestamp. This is the principal quantitative observation for this record. Precision to 6 decimal places to accommodate trace-level contaminant readings.' ;
    rdfs:domain ind:EnvironmentalMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:monitoringFrequency rdf:type rdf:Property ;
    rdfs:label 'Monitoring Frequency' ;
    rdfs:comment 'The required or actual frequency at which measurements are taken at this monitoring location for this parameter, as specified in the environmental monitoring plan or regulatory permit. Used to verify compliance with permit monitoring schedules. [ENUM-REF-CANDIDATE: continuous|hourly|daily|weekly|monthly|quarterly|event_triggered — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monitoringLocationCode rdf:type rdf:Property ;
    rdfs:label 'Monitoring Location Code' ;
    rdfs:comment 'Unique alphanumeric code identifying the designated monitoring point or station as defined in the environmental monitoring plan or permit. Used as the externally-known identifier in regulatory submissions and Intelex records.' ;
    rdfs:domain ind:EnvironmentalMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monitoringLocationName rdf:type rdf:Property ;
    rdfs:label 'Monitoring Location Name' ;
    rdfs:comment 'Descriptive name or label of the specific monitoring point or station where the measurement was taken (e.g., \'North Perimeter Fence Line\', \'Discharge Point DP-01\', \'Borehole BH-03\'). Used in permit compliance reports and environmental monitoring plans.' ;
    rdfs:domain ind:EnvironmentalMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monitoringMethod rdf:type rdf:Property ;
    rdfs:label 'Monitoring Method' ;
    rdfs:comment 'The analytical or measurement method used to obtain the reading (e.g., EPA Method 40 CFR Part 50, ISO 10523 for pH, AS/NZS 4360 for noise). Ensures traceability and regulatory defensibility of measurement results.' ;
    rdfs:domain ind:EnvironmentalMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monitoringParameter rdf:type rdf:Property ;
    rdfs:label 'Monitoring Parameter' ;
    rdfs:comment 'The specific environmental parameter being measured at this monitoring point (e.g., PM10, PM2.5, NO2, SO2, noise level dB(A), vibration velocity, pH, turbidity, TSS, BOD, lead, arsenic). Aligned with EPA and ISO 14001 environmental monitoring parameter classifications. [ENUM-REF-CANDIDATE: PM10|PM2.5|NO2|SO2|CO|noise_dba|vibration_velocity|pH|turbidity|TSS|BOD|COD|lead|arsenic|benzene|TPH — promote to reference product]' ;
    rdfs:domain ind:EnvironmentalMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monitoringRecordStatus rdf:type rdf:Property ;
    rdfs:label 'Monitoring Record Status' ;
    rdfs:comment 'Current workflow status of the environmental monitoring record within the Intelex HSE management system. Tracks the record through data entry, verification by the environmental manager, regulatory submission, and closure.' ;
    rdfs:domain ind:EnvironmentalMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monitoringReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Monitoring Reference Number' ;
    rdfs:comment 'Externally-known unique alphanumeric reference number assigned to this monitoring record, used in regulatory submissions, permit compliance reports, and Intelex HSE management system. Format: ENV-{SITE_CODE}-{SEQUENCE}.' ;
    rdfs:domain ind:EnvironmentalMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parameterCategory rdf:type rdf:Property ;
    rdfs:label 'Parameter Category' ;
    rdfs:comment 'High-level classification of the environmental monitoring parameter into the primary environmental media or impact category. Used for domain-level reporting and ISO 14001 environmental aspect categorisation.' ;
    rdfs:domain ind:EnvironmentalMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatorNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Regulator Notification Date' ;
    rdfs:comment 'The date on which the exceedance or monitoring result was formally notified to the relevant regulatory authority. Null if reported_to_regulator is False. Used to verify compliance with permit notification timeframes.' ;
    rdfs:domain ind:EnvironmentalMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reportedToRegulator rdf:type rdf:Property ;
    rdfs:label 'Reported To Regulator' ;
    rdfs:comment 'Indicates whether this monitoring result (particularly exceedances) has been formally reported to the relevant regulatory authority (e.g., EPA, state environmental agency) as required by the environmental permit or applicable legislation.' ;
    rdfs:domain ind:EnvironmentalMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sampleDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Sample Duration Minutes' ;
    rdfs:comment 'The duration in minutes over which the sample or measurement was collected or averaged. Relevant for time-averaged parameters such as noise (LAeq), air quality (24-hour PM10), and vibration. Null for instantaneous grab samples.' ;
    rdfs:domain ind:EnvironmentalMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sampleType rdf:type rdf:Property ;
    rdfs:label 'Sample Type' ;
    rdfs:comment 'Indicates the sampling methodology used to obtain the measurement — whether it is a grab sample (instantaneous), composite sample (time-averaged), continuous real-time reading, passive diffusion sample, or integrated sample over a defined period. Affects interpretation of results.' ;
    rdfs:domain ind:EnvironmentalMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thresholdLimit rdf:type rdf:Property ;
    rdfs:label 'Threshold Limit' ;
    rdfs:comment 'The maximum permissible value (or minimum, for parameters like pH) for the monitored parameter as defined by the applicable environmental permit, regulatory standard, or project-specific environmental management plan. Used to determine exceedance status.' ;
    rdfs:domain ind:EnvironmentalMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:thresholdType rdf:type rdf:Property ;
    rdfs:label 'Threshold Type' ;
    rdfs:comment 'Indicates whether the threshold limit represents a maximum permissible value, minimum required value, action level trigger, or alert level for the monitored parameter. Determines the logic used to evaluate exceedance.' ;
    rdfs:domain ind:EnvironmentalMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:windDirection rdf:type rdf:Property ;
    rdfs:label 'Wind Direction' ;
    rdfs:comment 'Cardinal or intercardinal wind direction at the time of measurement. Used in conjunction with wind speed for air quality dispersion analysis and to determine whether site activities are the source of elevated readings at downwind monitoring points. [ENUM-REF-CANDIDATE: N|NE|E|SE|S|SW|W|NW — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:EnvironmentalMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:windSpeedMs rdf:type rdf:Property ;
    rdfs:label 'Wind Speed Ms' ;
    rdfs:comment 'Wind speed in metres per second recorded at or near the monitoring location at the time of measurement. Critical contextual data for air quality and dust dispersion modelling and for assessing whether exceedances are attributable to site activities.' ;
    rdfs:domain ind:EnvironmentalMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trainingId rdf:type rdf:Property ;
    rdfs:label 'Training Id' ;
    rdfs:comment 'Unique identifier for the safety training record. Primary key.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Training .

ind:invoiceId rdf:type rdf:Property ;
    rdfs:label 'Invoice Id' ;
    rdfs:comment 'Foreign key linking to finance.invoice. Business justification: External training providers issue invoices for safety training delivery. Construction finance teams process these invoices against training records for three-way matching (PO, training completion, inv' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Invoice .

ind:assessmentMethod rdf:type rdf:Property ;
    rdfs:label 'Assessment Method' ;
    rdfs:comment 'Method used to assess the worker\'s competency after training: written examination, practical hands-on test, direct observation, verbal interview, or no formal assessment.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentResult rdf:type rdf:Property ;
    rdfs:label 'Assessment Result' ;
    rdfs:comment 'Overall result of the competency assessment: pass (met requirements), fail (did not meet requirements), conditional_pass (passed with conditions or retraining required), or not_assessed (no formal assessment conducted).' ;
    rdfs:domain ind:Training ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentScore rdf:type rdf:Property ;
    rdfs:label 'Assessment Score' ;
    rdfs:comment 'Numerical score achieved by the worker in the competency assessment (e.g., 85.50 out of 100). Null if no assessment was conducted.' ;
    rdfs:domain ind:Training ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:attendanceStatus rdf:type rdf:Property ;
    rdfs:label 'Attendance Status' ;
    rdfs:comment 'Worker\'s attendance status for the training session: attended (full participation), absent (did not attend), partial (attended part of the session), or excused (authorized absence).' ;
    rdfs:domain ind:Training ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificateExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Certificate Expiry Date' ;
    rdfs:comment 'Date on which the training certification expires and requires renewal or refresher training. Format: yyyy-MM-dd. Null if certification does not expire or was not issued.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:certificateIssueDate rdf:type rdf:Property ;
    rdfs:label 'Certificate Issue Date' ;
    rdfs:comment 'Date on which the training certificate was officially issued to the worker. Format: yyyy-MM-dd. Null if no certificate was issued.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:certificationIssued rdf:type rdf:Property ;
    rdfs:label 'Certification Issued' ;
    rdfs:comment 'Indicates whether a formal certificate or card was issued to the worker upon successful completion of the training. True if issued, False if not.' ;
    rdfs:domain ind:Training ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:complianceStatus rdf:type rdf:Property ;
    rdfs:label 'Compliance Status' ;
    rdfs:comment 'Current compliance status of the worker\'s training record: compliant (training valid and up-to-date), non_compliant (required training not completed or failed), expired (certification has expired), pending_renewal (approaching expiry, renewal in progress), or waived (exempted by authorized personnel).' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cost rdf:type rdf:Property ;
    rdfs:label 'Cost' ;
    rdfs:comment 'Total cost incurred for the training session, including instructor fees, materials, facility rental, and travel expenses. Null if cost tracking is not applicable.' ;
    rdfs:domain ind:Training ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:currency rdf:type rdf:Property ;
    rdfs:label 'Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the training cost (e.g., USD, EUR, GBP). Null if cost is not tracked.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryMethod rdf:type rdf:Property ;
    rdfs:label 'Delivery Method' ;
    rdfs:comment 'Method by which the training was delivered: classroom instruction, online e-learning, on-site field training, blended (combination), simulator-based, or hands-on practical demonstration.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:durationHours rdf:type rdf:Property ;
    rdfs:label 'Duration Hours' ;
    rdfs:comment 'Total duration of the training session in hours (e.g., 8.00 for an 8-hour OSHA course, 0.50 for a 30-minute toolbox talk).' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:languageOfInstruction rdf:type rdf:Property ;
    rdfs:label 'Language Of Instruction' ;
    rdfs:comment 'Primary language in which the training was delivered (e.g., English, Spanish, Mandarin). Important for multilingual workforce compliance.' ;
    rdfs:domain ind:Training ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:location rdf:type rdf:Property ;
    rdfs:label 'Location' ;
    rdfs:comment 'Physical or virtual location where the training was conducted (e.g., site office, training center address, online platform name).' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mandatoryFlag rdf:type rdf:Property ;
    rdfs:label 'Mandatory Flag' ;
    rdfs:comment 'Indicates whether this training is mandatory for the worker\'s role or project assignment. True if mandatory, False if optional or voluntary.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:materialsProvided rdf:type rdf:Property ;
    rdfs:label 'Materials Provided' ;
    rdfs:comment 'Description of training materials provided to the worker (e.g., \'OSHA handbook, safety manual, PPE (Personal Protective Equipment) checklist, online access credentials\').' ;
    rdfs:domain ind:Training ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextRefresherDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Refresher Due Date' ;
    rdfs:comment 'Date by which the worker must complete refresher training to maintain compliance. Format: yyyy-MM-dd. Null if no refresher is required.' ;
    rdfs:domain ind:Training ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:refresherFrequencyMonths rdf:type rdf:Property ;
    rdfs:label 'Refresher Frequency Months' ;
    rdfs:comment 'Number of months between required refresher training sessions (e.g., 12 for annual refresher, 36 for three-year renewal). Null if no refresher is required.' ;
    rdfs:domain ind:Training ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:refresherRequired rdf:type rdf:Property ;
    rdfs:label 'Refresher Required' ;
    rdfs:comment 'Indicates whether periodic refresher training is required to maintain competency and compliance. True if refresher is required, False if one-time training is sufficient.' ;
    rdfs:domain ind:Training ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:trainerCertificationNumber rdf:type rdf:Property ;
    rdfs:label 'Trainer Certification Number' ;
    rdfs:comment 'Certification or accreditation number of the trainer, verifying their authorization to deliver the specific training (e.g., OSHA Outreach Trainer ID).' ;
    rdfs:domain ind:Training ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingCode rdf:type rdf:Property ;
    rdfs:label 'Training Code' ;
    rdfs:comment 'Unique alphanumeric code identifying the specific training course or module (e.g., OSHA10, OSHA30, INDUCT01, HEIGHTS01).' ;
    rdfs:domain ind:Training ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingDate rdf:type rdf:Property ;
    rdfs:label 'Training Date' ;
    rdfs:comment 'Date on which the training session was conducted or completed. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:Training ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:trainingType rdf:type rdf:Property ;
    rdfs:label 'Training Type' ;
    rdfs:comment 'Category of Health Safety and Environment (HSE) training provided. Includes site induction, OSHA (Occupational Safety and Health Administration) 10/30 hour certifications, first aid, confined space entry, working at heights, scaffolding, excavation safety, fall protection, electrical safety, hot work permits, rigging and lifting, hazardous materials handling, PPE (Personal Protective Equipment) usage, emergency response, fire safety, and TBM (Toolbox Meeting) sessions. [ENUM-REF-CANDIDATE: site_induction|osha_10|osha_30|first_aid|confined_space|working_at_heights|scaffolding|excavation|fall_protection|electrical_safety|hot_work|rigging_lifting|hazmat|ppe_usage|emergency_response|fire_safety|toolbox_meeting — 17 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Training ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:awardDate rdf:type rdf:Property ;
    rdfs:label 'Award Date' ;
    rdfs:comment 'Date when the trade package was formally awarded to the selected subcontractor.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:awardedValue rdf:type rdf:Property ;
    rdfs:label 'Awarded Value' ;
    rdfs:comment 'Final contract value at which the trade package was awarded to the subcontractor.' ;
    rdfs:domain ind:TradePackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bidClosingDate rdf:type rdf:Property ;
    rdfs:label 'Bid Closing Date' ;
    rdfs:comment 'Deadline date by which subcontractors must submit their bids for this trade package.' ;
    rdfs:domain ind:TradePackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:bidOutDate rdf:type rdf:Property ;
    rdfs:label 'Bid Out Date' ;
    rdfs:comment 'Date when the trade package was issued to subcontractors for competitive bidding.' ;
    rdfs:domain ind:TradePackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:bondingRequired rdf:type rdf:Property ;
    rdfs:label 'Bonding Required' ;
    rdfs:comment 'Indicates whether performance and payment bonds are required from the subcontractor for this trade package.' ;
    rdfs:domain ind:TradePackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:budgetAllowance rdf:type rdf:Property ;
    rdfs:label 'Budget Allowance' ;
    rdfs:comment 'Budget allocation reserved for this trade package in the project cost plan.' ;
    rdfs:domain ind:TradePackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:csiMasterformatCode rdf:type rdf:Property ;
    rdfs:label 'Csi Masterformat Code' ;
    rdfs:comment 'CSI MasterFormat classification code for the scope of work (e.g., 03 30 00 for Cast-in-Place Concrete).' ;
    rdfs:domain ind:TradePackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedValue rdf:type rdf:Property ;
    rdfs:label 'Estimated Value' ;
    rdfs:comment 'Pre-bid estimated value of the trade package based on quantity take-offs and market rates.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:insuranceRequirements rdf:type rdf:Property ;
    rdfs:label 'Insurance Requirements' ;
    rdfs:comment 'Summary of insurance coverage requirements that the awarded subcontractor must maintain (e.g., general liability, professional indemnity, workers compensation).' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:numberOfBiddersInvited rdf:type rdf:Property ;
    rdfs:label 'Number Of Bidders Invited' ;
    rdfs:comment 'Count of subcontractors invited to submit bids for this trade package.' ;
    rdfs:domain ind:TradePackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:numberOfBidsReceived rdf:type rdf:Property ;
    rdfs:label 'Number Of Bids Received' ;
    rdfs:comment 'Count of valid bids received from subcontractors by the bid closing date.' ;
    rdfs:domain ind:TradePackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:packagePriority rdf:type rdf:Property ;
    rdfs:label 'Package Priority' ;
    rdfs:comment 'Priority level of this trade package relative to other packages in the project (Critical, High, Medium, Low).' ;
    rdfs:domain ind:TradePackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packageReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Package Reference Number' ;
    rdfs:comment 'Externally-known unique reference number for the trade package used in bidding and contract documents.' ;
    rdfs:domain ind:TradePackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packageStatus rdf:type rdf:Property ;
    rdfs:label 'Package Status' ;
    rdfs:comment 'Current lifecycle status of the trade package in the bidding and award process.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prequalificationRequired rdf:type rdf:Property ;
    rdfs:label 'Prequalification Required' ;
    rdfs:comment 'Indicates whether subcontractors must be prequalified before being invited to bid on this trade package.' ;
    rdfs:domain ind:TradePackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scopeNarrative rdf:type rdf:Property ;
    rdfs:label 'Scope Narrative' ;
    rdfs:comment 'Detailed textual description of the scope of work included in this trade package, including deliverables, exclusions, and boundaries.' ;
    rdfs:domain ind:TradePackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:uniformatCode rdf:type rdf:Property ;
    rdfs:label 'Uniformat Code' ;
    rdfs:comment 'UniFormat II classification code for elemental cost planning (e.g., B2010 for Exterior Walls).' ;
    rdfs:domain ind:TradePackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:warrantyPeriodMonths rdf:type rdf:Property ;
    rdfs:label 'Warranty Period Months' ;
    rdfs:comment 'Duration in months of the defects liability period (DLP) or warranty period after completion.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assetCategoryId rdf:type rdf:Property ;
    rdfs:label 'Asset Category Id' ;
    rdfs:comment 'Foreign key linking to equipment.asset_category. Business justification: Asset belongs to an asset category; replace free-text category with FK to asset_category for proper hierarchy and eliminate redundancy.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AssetCategory .

ind:assetConstructionProjectId rdf:type rdf:Property ;
    rdfs:label 'Asset Construction Project Id' ;
    rdfs:comment 'Identifier of the construction project to which the asset is currently assigned. Null when asset is idle or in yard storage.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ConstructionProject .

ind:assetCurrentLocationSiteConstructionProjectId rdf:type rdf:Property ;
    rdfs:label 'Asset Current Location Site Construction Project Id' ;
    rdfs:comment 'Identifier of the construction site or yard where the asset is currently located. Updated during mobilization and demobilization events.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ConstructionProject .

ind:fuelMaterialMaterialMasterId rdf:type rdf:Property ;
    rdfs:label 'Fuel Material Material Master Id' ;
    rdfs:comment 'Foreign key linking to material.material_master. Business justification: Associates each asset with its primary fuel material, enabling accurate fuel consumption tracking and environmental compliance.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Master .

ind:profitCenterId rdf:type rdf:Property ;
    rdfs:label 'Profit Center Id' ;
    rdfs:comment 'Foreign key linking to finance.profit_center. Business justification: Assets in multi-division construction companies are assigned to profit centers for internal P&L attribution, divisional asset reporting, and return-on-assets analysis. Construction finance teams requi' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProfitCenter .

ind:acquisitionCost rdf:type rdf:Property ;
    rdfs:label 'Acquisition Cost' ;
    rdfs:comment 'Total cost to acquire the asset including purchase price, delivery, installation, and initial setup. Basis for depreciation calculations and capital asset reporting.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:acquisitionCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Acquisition Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the acquisition cost (e.g., USD, EUR, GBP). Required for multi-currency fleet management.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acquisitionDate rdf:type rdf:Property ;
    rdfs:label 'Acquisition Date' ;
    rdfs:comment 'Date the asset was acquired by the company through purchase, lease commencement, or rental agreement start. Used for depreciation start date and asset age calculations.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assetStatus rdf:type rdf:Property ;
    rdfs:label 'Asset Status' ;
    rdfs:comment 'Current operational status of the asset. Determines availability for project assignment and utilization reporting. [ENUM-REF-CANDIDATE: active|idle|under_maintenance|in_transit|disposed|retired|reserved — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capacityRating rdf:type rdf:Property ;
    rdfs:label 'Capacity Rating' ;
    rdfs:comment 'Maximum rated capacity of the equipment in appropriate units (tons for cranes, cubic yards for excavators, kilowatts for generators). Critical for safe operation and project planning.' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capacityUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Capacity Unit Of Measure' ;
    rdfs:comment 'Unit of measure for the capacity rating. Varies by equipment type and regional standards.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:classification rdf:type rdf:Property ;
    rdfs:label 'Classification' ;
    rdfs:comment 'Primary equipment type classification. Determines maintenance requirements, operator certification needs, and utilization tracking methods. [ENUM-REF-CANDIDATE: crane|excavator|concrete_pump|generator|fleet_vehicle|small_tool|bulldozer|loader|grader|compactor|paver|drill_rig — 12 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentBookValue rdf:type rdf:Property ;
    rdfs:label 'Current Book Value' ;
    rdfs:comment 'Net book value of the asset after accumulated depreciation. Updated periodically based on depreciation schedule and impairment assessments.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:disposalApproverName rdf:type rdf:Property ;
    rdfs:label 'Disposal Approver Name' ;
    rdfs:comment 'Name of the manager or executive who authorized the asset disposal. Required for governance and audit compliance.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disposalBuyerName rdf:type rdf:Property ;
    rdfs:label 'Disposal Buyer Name' ;
    rdfs:comment 'Name of the party who purchased or received the disposed asset. Required for audit trail and warranty transfer documentation.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disposalDate rdf:type rdf:Property ;
    rdfs:label 'Disposal Date' ;
    rdfs:comment 'Date the asset was disposed of or removed from active fleet. Triggers final depreciation calculation and asset retirement accounting entries.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:disposalMethod rdf:type rdf:Property ;
    rdfs:label 'Disposal Method' ;
    rdfs:comment 'Method used to dispose of the asset at end of life. Populated only for disposed assets. Impacts accounting treatment and tax reporting.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disposalProceeds rdf:type rdf:Property ;
    rdfs:label 'Disposal Proceeds' ;
    rdfs:comment 'Amount received from disposal of the asset through sale, auction, or trade-in. Used to calculate gain or loss on disposal for financial reporting.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:disposalReason rdf:type rdf:Property ;
    rdfs:label 'Disposal Reason' ;
    rdfs:comment 'Business justification for disposing of the asset (e.g., end of useful life, excessive maintenance costs, fleet optimization, project completion, regulatory non-compliance).' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emissionsTier rdf:type rdf:Property ;
    rdfs:label 'Emissions Tier' ;
    rdfs:comment 'EPA emissions tier classification (e.g., Tier 4 Final, Tier 3). Determines regulatory compliance for site operations and environmental permitting.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hcssHeavyjobAssetCode rdf:type rdf:Property ;
    rdfs:label 'Hcss Heavyjob Asset Code' ;
    rdfs:comment 'Asset identifier in HCSS HeavyJob field operations system. Used for time tracking, production tracking, and equipment hour logging.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:homeYardLocation rdf:type rdf:Property ;
    rdfs:label 'Home Yard Location' ;
    rdfs:comment 'Primary equipment yard or depot where the asset is based when not deployed to a project site. Used for logistics planning and idle asset management.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Insurance Expiry Date' ;
    rdfs:comment 'Expiration date of current insurance coverage. Equipment cannot operate without valid insurance.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:insurancePolicyNumber rdf:type rdf:Property ;
    rdfs:label 'Insurance Policy Number' ;
    rdfs:comment 'Policy number for equipment insurance coverage. Required for risk management and claims processing.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastInspectionDate rdf:type rdf:Property ;
    rdfs:label 'Last Inspection Date' ;
    rdfs:comment 'Date of the most recent regulatory or safety inspection. Required for OSHA compliance and equipment certification tracking.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastMeterReadingDate rdf:type rdf:Property ;
    rdfs:label 'Last Meter Reading Date' ;
    rdfs:comment 'Date of the most recent operating hours meter reading. Used to validate meter reading frequency and detect anomalies.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lifecycleStage rdf:type rdf:Property ;
    rdfs:label 'Lifecycle Stage' ;
    rdfs:comment 'Current stage in the asset lifecycle from acquisition through disposal. Used for lifecycle cost analysis and replacement planning.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:make rdf:type rdf:Property ;
    rdfs:label 'Make' ;
    rdfs:comment 'Manufacturer or brand name of the equipment (e.g., Caterpillar, Komatsu, Liebherr, Volvo, John Deere).' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:model rdf:type rdf:Property ;
    rdfs:label 'Model' ;
    rdfs:comment 'Manufacturer model designation for the equipment. Used for parts compatibility, operator training, and maintenance procedure lookup.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextInspectionDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Inspection Due Date' ;
    rdfs:comment 'Date by which the next regulatory inspection must be completed. Equipment cannot operate on site after this date without recertification.' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextScheduledMaintenanceDate rdf:type rdf:Property ;
    rdfs:label 'Next Scheduled Maintenance Date' ;
    rdfs:comment 'Date of the next planned preventive maintenance service. Calculated based on operating hours, calendar time, or manufacturer recommendations.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:operatingWeightKg rdf:type rdf:Property ;
    rdfs:label 'Operating Weight Kg' ;
    rdfs:comment 'Total operating weight of the equipment in kilograms. Used for transportation planning, site access evaluation, and ground bearing pressure calculations.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatoryComplianceClass rdf:type rdf:Property ;
    rdfs:label 'Regulatory Compliance Class' ;
    rdfs:comment 'Regulatory classification determining inspection frequency, operator certification requirements, and safety standards (e.g., OSHA crane certification class, EPA emissions tier).' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapPmEquipmentNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Pm Equipment Number' ;
    rdfs:comment 'Equipment master record number in SAP S/4HANA Plant Maintenance module. System of record identifier for maintenance planning and execution.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serialNumber rdf:type rdf:Property ;
    rdfs:label 'Serial Number' ;
    rdfs:comment 'Manufacturer-assigned serial number for the equipment unit. Critical for warranty claims, parts ordering, and regulatory compliance.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tagNumber rdf:type rdf:Property ;
    rdfs:label 'Tag Number' ;
    rdfs:comment 'Externally visible unique identifier physically affixed to the equipment. Used for field identification and tracking across sites.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalOperatingHours rdf:type rdf:Property ;
    rdfs:label 'Total Operating Hours' ;
    rdfs:comment 'Cumulative operating hours recorded on the equipment meter. Used for maintenance scheduling, utilization analysis, and residual value estimation.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:yearOfManufacture rdf:type rdf:Property ;
    rdfs:label 'Year Of Manufacture' ;
    rdfs:comment 'Calendar year the equipment was manufactured. Used for depreciation calculations, regulatory compliance age limits, and resale value estimation.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:parentCategoryAssetCategoryId rdf:type rdf:Property ;
    rdfs:label 'Parent Category Asset Category Id' ;
    rdfs:comment 'Reference to the parent category in the asset classification hierarchy. Enables multi-level taxonomy (e.g., Heavy Equipment > Earthmoving > Excavators). Null for top-level categories.' ;
    rdfs:domain ind:AssetCategory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AssetCategory .

ind:assetCategoryStatus rdf:type rdf:Property ;
    rdfs:label 'Asset Category Status' ;
    rdfs:comment 'Current lifecycle status of the asset category in the master taxonomy: active (in use for classification), inactive (no longer used but retained for historical data), deprecated (being phased out), pending (awaiting approval for activation).' ;
    rdfs:domain ind:AssetCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetClassSap rdf:type rdf:Property ;
    rdfs:label 'Asset Class Sap' ;
    rdfs:comment 'SAP S/4HANA Asset Accounting asset class code for assets in this category. Determines account determination, depreciation keys, and asset master data screen layout in SAP FI-AA module.' ;
    rdfs:domain ind:AssetCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:benchmarkUtilizationRate rdf:type rdf:Property ;
    rdfs:label 'Benchmark Utilization Rate' ;
    rdfs:comment 'Target utilization rate percentage for assets in this category, used for fleet optimization and equipment productivity benchmarking. Represents industry-standard or company target for equipment hours versus available hours.' ;
    rdfs:domain ind:AssetCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capitalizationThreshold rdf:type rdf:Property ;
    rdfs:label 'Capitalization Threshold' ;
    rdfs:comment 'Minimum acquisition cost threshold for capitalizing assets in this category as fixed assets versus expensing as consumables. Aligns with company capitalization policy and GAAP/IFRS materiality thresholds.' ;
    rdfs:domain ind:AssetCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:categoryCode rdf:type rdf:Property ;
    rdfs:label 'Category Code' ;
    rdfs:comment 'Unique alphanumeric code identifying the asset category. Aligned with HCSS HeavyJob cost coding structure and SAP PM functional location classification. Used for cost allocation, reporting, and system integration.' ;
    rdfs:domain ind:AssetCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:categoryDescription rdf:type rdf:Property ;
    rdfs:label 'Category Description' ;
    rdfs:comment 'Detailed description of the asset category scope, typical equipment types included, and business purpose. Provides context for classification decisions and user guidance.' ;
    rdfs:domain ind:AssetCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:categoryLevel rdf:type rdf:Property ;
    rdfs:label 'Category Level' ;
    rdfs:comment 'Numeric level in the asset category hierarchy. Level 1 represents top-level categories (e.g., Heavy Equipment), Level 2 represents sub-categories (e.g., Earthmoving), Level 3 represents equipment classes (e.g., Excavators).' ;
    rdfs:domain ind:AssetCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:categoryName rdf:type rdf:Property ;
    rdfs:label 'Category Name' ;
    rdfs:comment 'Full business name of the asset category (e.g., Heavy Earthmoving Equipment, Lifting and Hoisting, Concrete Placement, MEP Tools, Fleet Vehicles, Small Tools, Generators and Power).' ;
    rdfs:domain ind:AssetCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:categoryType rdf:type rdf:Property ;
    rdfs:label 'Category Type' ;
    rdfs:comment 'Classification of the category node type within the taxonomy: major (top-level grouping), sub (intermediate grouping), class (equipment class), specialty (niche/specialized equipment).' ;
    rdfs:domain ind:AssetCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:depreciationMethod rdf:type rdf:Property ;
    rdfs:label 'Depreciation Method' ;
    rdfs:comment 'Standard depreciation method applied to owned assets in this category for financial reporting: straight_line (equal annual depreciation), declining_balance (accelerated depreciation), units_of_production (usage-based depreciation for heavy equipment), none (non-depreciable or rental assets).' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:environmentalComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Environmental Compliance Flag' ;
    rdfs:comment 'Indicates whether assets in this category are subject to environmental compliance tracking (emissions monitoring, fuel consumption reporting, EPA regulations). True for generators, diesel equipment, and vehicles; False for non-powered tools.' ;
    rdfs:domain ind:AssetCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hcssEquipmentType rdf:type rdf:Property ;
    rdfs:label 'Hcss Equipment Type' ;
    rdfs:comment 'HCSS HeavyJob equipment type classification for field operations time tracking and production reporting. Maps asset category to HeavyJob cost coding and equipment hour tracking structure.' ;
    rdfs:domain ind:AssetCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionFrequencyDays rdf:type rdf:Property ;
    rdfs:label 'Inspection Frequency Days' ;
    rdfs:comment 'Standard inspection interval in days for assets in this category, aligned with manufacturer recommendations and regulatory requirements. Used to generate preventive maintenance schedules in SAP PM. Null for categories not requiring periodic inspection.' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maintenanceStrategyCode rdf:type rdf:Property ;
    rdfs:label 'Maintenance Strategy Code' ;
    rdfs:comment 'Default maintenance strategy code assigned to assets in this category, aligned with SAP PM maintenance strategy master data. Defines preventive maintenance frequency, inspection intervals, and service requirements (e.g., HVYEQ for heavy equipment, LTTOOL for light tools).' ;
    rdfs:domain ind:AssetCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mobilizationRequired rdf:type rdf:Property ;
    rdfs:label 'Mobilization Required' ;
    rdfs:comment 'Indicates whether assets in this category require formal mobilization and demobilization tracking when deployed to project sites. True for heavy equipment requiring transport logistics; False for small portable tools.' ;
    rdfs:domain ind:AssetCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:modifiedByUser rdf:type rdf:Property ;
    rdfs:label 'Modified By User' ;
    rdfs:comment 'User ID or system account that last modified this asset category record. Supports accountability and audit trail for master data governance.' ;
    rdfs:domain ind:AssetCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatorCertificationRequired rdf:type rdf:Property ;
    rdfs:label 'Operator Certification Required' ;
    rdfs:comment 'Indicates whether operation of assets in this category requires certified/licensed operators per OSHA regulations and company HSE policy. True for cranes, forklifts, and heavy machinery; False for hand tools and general equipment.' ;
    rdfs:domain ind:AssetCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ownershipClassification rdf:type rdf:Property ;
    rdfs:label 'Ownership Classification' ;
    rdfs:comment 'Default ownership model for assets in this category: owned (company-owned assets), rented (short-term rental), leased (long-term lease), mixed (category contains both owned and rented assets). Drives depreciation and cost allocation rules.' ;
    rdfs:domain ind:AssetCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usefulLifeYears rdf:type rdf:Property ;
    rdfs:label 'Useful Life Years' ;
    rdfs:comment 'Standard useful life in years for assets in this category, used for depreciation calculation and lifecycle planning. Null for rental/leased assets or categories with variable lifespans.' ;
    rdfs:domain ind:AssetCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:utilizationTrackingRequired rdf:type rdf:Property ;
    rdfs:label 'Utilization Tracking Required' ;
    rdfs:comment 'Indicates whether assets in this category require detailed utilization tracking (equipment hours, production tracking) via HCSS HeavyJob or SAP PM. True for high-value equipment requiring cost recovery and productivity analysis; False for low-value consumable tools.' ;
    rdfs:domain ind:AssetCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rentalAgreementId rdf:type rdf:Property ;
    rdfs:label 'Rental Agreement Id' ;
    rdfs:comment 'Foreign key linking to equipment.rental_agreement. Business justification: A fleet assignment for rented equipment is governed by a rental agreement. fleet_assignment already has rental_contract_number (a free-text string) and rental_vendor_id, which are denormalized referen' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RentalAgreement .

ind:rentalVendorId rdf:type rdf:Property ;
    rdfs:label 'Rental Vendor Id' ;
    rdfs:comment 'Reference to the rental company or vendor supplying the equipment, if applicable. Null for owned equipment.' ;
    rdfs:domain ind:FleetAssignment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vendor .

ind:actualUtilizationHours rdf:type rdf:Property ;
    rdfs:label 'Actual Utilization Hours' ;
    rdfs:comment 'Actual cumulative equipment operating hours recorded during this assignment. Updated from daily logs and equipment hour meters.' ;
    rdfs:domain ind:FleetAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assignmentEndDate rdf:type rdf:Property ;
    rdfs:label 'Assignment End Date' ;
    rdfs:comment 'The date when the equipment assignment ends or is planned to end. Nullable for open-ended assignments. Marks the end of cost allocation for this assignment.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assignmentNotes rdf:type rdf:Property ;
    rdfs:label 'Assignment Notes' ;
    rdfs:comment 'Free-text notes and comments related to this equipment assignment. Captures special instructions, constraints, or operational considerations.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentNumber rdf:type rdf:Property ;
    rdfs:label 'Assignment Number' ;
    rdfs:comment 'Business identifier for the fleet assignment. Externally visible reference number used in mobilization documents and site logistics planning.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentPriority rdf:type rdf:Property ;
    rdfs:label 'Assignment Priority' ;
    rdfs:comment 'Business priority level of this equipment assignment. Used for resource allocation decisions and conflict resolution when equipment is in high demand.' ;
    rdfs:domain ind:FleetAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentPurpose rdf:type rdf:Property ;
    rdfs:label 'Assignment Purpose' ;
    rdfs:comment 'Business description of the purpose or scope of work for this equipment assignment. Describes the specific activities or tasks the equipment will perform.' ;
    rdfs:domain ind:FleetAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentStartDate rdf:type rdf:Property ;
    rdfs:label 'Assignment Start Date' ;
    rdfs:comment 'The date when the equipment assignment begins. Marks the start of cost allocation and utilization tracking for this assignment.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assignmentStatus rdf:type rdf:Property ;
    rdfs:label 'Assignment Status' ;
    rdfs:comment 'Current lifecycle status of the equipment assignment. Tracks progression from planning through mobilization, active use, and demobilization. [ENUM-REF-CANDIDATE: planned|mobilizing|active|standby|demobilizing|completed|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentType rdf:type rdf:Property ;
    rdfs:label 'Assignment Type' ;
    rdfs:comment 'Classification of the equipment ownership or procurement method for this assignment. Determines applicable cost rates and billing rules.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dailyRate rdf:type rdf:Property ;
    rdfs:label 'Daily Rate' ;
    rdfs:comment 'Internal daily cost rate for equipment assignment. Alternative to hourly rates for equipment charged on a daily basis.' ;
    rdfs:domain ind:FleetAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:demobilizationCost rdf:type rdf:Property ;
    rdfs:label 'Demobilization Cost' ;
    rdfs:comment 'Actual or estimated cost of demobilizing the equipment from the site, including transportation, cleaning, and inspection. One-time cost allocated to the project.' ;
    rdfs:domain ind:FleetAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mobilizationCost rdf:type rdf:Property ;
    rdfs:label 'Mobilization Cost' ;
    rdfs:comment 'Actual or estimated cost of mobilizing the equipment to the site, including transportation, permits, and setup. One-time cost allocated to the project.' ;
    rdfs:domain ind:FleetAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:modifiedBy rdf:type rdf:Property ;
    rdfs:label 'Modified By' ;
    rdfs:comment 'Username or identifier of the user who last modified this assignment record in the source system.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Modified Timestamp' ;
    rdfs:comment 'Timestamp when this assignment record was last modified in the source system. Audit trail for record updates.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:operatingRatePerHour rdf:type rdf:Property ;
    rdfs:label 'Operating Rate Per Hour' ;
    rdfs:comment 'Internal hourly operating cost rate including fuel, maintenance, and operator costs. Used for project cost allocation when equipment is actively operating.' ;
    rdfs:domain ind:FleetAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ownershipRatePerHour rdf:type rdf:Property ;
    rdfs:label 'Ownership Rate Per Hour' ;
    rdfs:comment 'Internal hourly ownership cost rate for owned equipment. Used for project cost allocation and internal charge-back calculations.' ;
    rdfs:domain ind:FleetAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:permitNumber rdf:type rdf:Property ;
    rdfs:label 'Permit Number' ;
    rdfs:comment 'Regulatory permit or authorization number required for operating this equipment on the site. Applicable for cranes, heavy lifts, and specialized machinery.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedUtilizationHours rdf:type rdf:Property ;
    rdfs:label 'Planned Utilization Hours' ;
    rdfs:comment 'Planned or estimated total equipment operating hours for this assignment. Used for capacity planning and utilization forecasting.' ;
    rdfs:domain ind:FleetAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rateCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Rate Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for all rate amounts in this assignment record.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemCode rdf:type rdf:Property ;
    rdfs:label 'Source System Code' ;
    rdfs:comment 'Unique identifier of this assignment record in the source system. Used for data lineage, reconciliation, and incremental updates.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standbyRatePerHour rdf:type rdf:Property ;
    rdfs:label 'Standby Rate Per Hour' ;
    rdfs:comment 'Internal hourly standby cost rate when equipment is on site but not actively operating. Lower rate than operating rate, used for idle time cost allocation.' ;
    rdfs:domain ind:FleetAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:weeklyRate rdf:type rdf:Property ;
    rdfs:label 'Weekly Rate' ;
    rdfs:comment 'Internal weekly cost rate for equipment assignment. Alternative to hourly or daily rates for equipment charged on a weekly basis.' ;
    rdfs:domain ind:FleetAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:createdBy rdf:type rdf:Property ;
    rdfs:label 'Created By' ;
    rdfs:comment 'Username or identifier of the user who created this assignment record in the source system.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costPerHour rdf:type rdf:Property ;
    rdfs:label 'Cost Per Hour' ;
    rdfs:comment 'Calculated or allocated cost per operating hour for this equipment during the shift. Includes ownership cost, fuel, operator labor, and maintenance allocation. Used for job costing and CPI calculation.' ;
    rdfs:domain ind:Hours ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:downtimeCategory rdf:type rdf:Property ;
    rdfs:label 'Downtime Category' ;
    rdfs:comment 'High-level classification of the downtime event cause (breakdown, awaiting parts, awaiting operator, weather hold, scheduled maintenance, unscheduled repair). Used for downtime root cause analysis.' ;
    rdfs:domain ind:Hours ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:downtimeEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Downtime End Timestamp' ;
    rdfs:comment 'Precise date and time when equipment downtime event ended and equipment returned to service. Used for MTTR and downtime duration calculation.' ;
    rdfs:domain ind:Hours ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:downtimeHours rdf:type rdf:Property ;
    rdfs:label 'Downtime Hours' ;
    rdfs:comment 'Total hours the equipment was unavailable due to breakdown, maintenance, repair, or other non-productive events. Sum of all downtime event durations for the shift.' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:downtimeImpactAssessment rdf:type rdf:Property ;
    rdfs:label 'Downtime Impact Assessment' ;
    rdfs:comment 'Business assessment of the downtime events impact on project schedule, cost, and critical path activities. Used for prioritizing maintenance and resource allocation.' ;
    rdfs:domain ind:Hours ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:downtimeResolutionAction rdf:type rdf:Property ;
    rdfs:label 'Downtime Resolution Action' ;
    rdfs:comment 'Free-text description of the corrective action taken to resolve the downtime event and return equipment to service. Includes repair details, parts replaced, or workaround applied.' ;
    rdfs:domain ind:Hours ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:downtimeRootCauseCode rdf:type rdf:Property ;
    rdfs:label 'Downtime Root Cause Code' ;
    rdfs:comment 'Detailed alphanumeric code identifying the specific root cause of the downtime event (e.g., hydraulic failure, tire puncture, electrical fault). Used for MTBF and failure pattern analysis.' ;
    rdfs:domain ind:Hours ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:downtimeStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Downtime Start Timestamp' ;
    rdfs:comment 'Precise date and time when equipment downtime event began. Used for MTTR (Mean Time To Repair) and availability rate calculations.' ;
    rdfs:domain ind:Hours ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:equipmentAvailabilityRate rdf:type rdf:Property ;
    rdfs:label 'Equipment Availability Rate' ;
    rdfs:comment 'Calculated percentage of scheduled time that equipment was available for use (not in downtime). Formula: ((total_hours - downtime_hours) / total_hours) * 100. Used for maintenance effectiveness and reliability analysis.' ;
    rdfs:domain ind:Hours ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:equipmentUtilizationRate rdf:type rdf:Property ;
    rdfs:label 'Equipment Utilization Rate' ;
    rdfs:comment 'Calculated percentage of available time that equipment was productively operating. Formula: (operating_hours / (operating_hours + idle_hours + standby_hours + downtime_hours)) * 100. Key performance indicator for fleet management.' ;
    rdfs:domain ind:Hours ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isBillable rdf:type rdf:Property ;
    rdfs:label 'Is Billable' ;
    rdfs:comment 'Flag indicating whether these equipment hours are billable to the client under the contract terms. Used for revenue recognition and client invoicing.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:meterReadingEnd rdf:type rdf:Property ;
    rdfs:label 'Meter Reading End' ;
    rdfs:comment 'Equipment hour meter or odometer reading at the end of the shift. Used to validate reported hours and track cumulative equipment usage for maintenance scheduling.' ;
    rdfs:domain ind:Hours ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:meterReadingStart rdf:type rdf:Property ;
    rdfs:label 'Meter Reading Start' ;
    rdfs:comment 'Equipment hour meter or odometer reading at the start of the shift. Used to validate reported hours and track cumulative equipment usage for maintenance scheduling.' ;
    rdfs:domain ind:Hours ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recordModifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Record Modified Timestamp' ;
    rdfs:comment 'Date and time when this equipment hours record was last modified in the source system. Audit field for change tracking and data quality monitoring.' ;
    rdfs:domain ind:Hours ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:totalEquipmentCost rdf:type rdf:Property ;
    rdfs:label 'Total Equipment Cost' ;
    rdfs:comment 'Total cost charged to the project for this equipment hours record. Calculated as operating_hours * cost_per_hour plus any additional charges. Used for project cost control and EVM.' ;
    rdfs:domain ind:Hours ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maintenancePlanId rdf:type rdf:Property ;
    rdfs:label 'Maintenance Plan Id' ;
    rdfs:comment 'Unique identifier for the maintenance plan record. Primary key.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MaintenancePlan .

ind:certificationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Certification Required Flag' ;
    rdfs:comment 'Indicates whether completion of this maintenance plan requires formal certification or inspection sign-off by a qualified authority.' ;
    rdfs:domain ind:MaintenancePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:downtimeRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Downtime Required Flag' ;
    rdfs:comment 'Indicates whether the equipment must be taken out of service to perform the maintenance activities in this plan.' ;
    rdfs:domain ind:MaintenancePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:estimatedDowntimeHours rdf:type rdf:Property ;
    rdfs:label 'Estimated Downtime Hours' ;
    rdfs:comment 'Estimated duration in hours that the equipment will be unavailable during maintenance execution.' ;
    rdfs:domain ind:MaintenancePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedDurationHours rdf:type rdf:Property ;
    rdfs:label 'Estimated Duration Hours' ;
    rdfs:comment 'Estimated time in hours required to complete the maintenance activities defined in this plan.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedLaborCost rdf:type rdf:Property ;
    rdfs:label 'Estimated Labor Cost' ;
    rdfs:comment 'Estimated labor cost in base currency for executing one cycle of this maintenance plan.' ;
    rdfs:domain ind:MaintenancePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedMaterialCost rdf:type rdf:Property ;
    rdfs:label 'Estimated Material Cost' ;
    rdfs:comment 'Estimated cost of parts, materials, and consumables required for one maintenance cycle.' ;
    rdfs:domain ind:MaintenancePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:intervalUnit rdf:type rdf:Property ;
    rdfs:label 'Interval Unit' ;
    rdfs:comment 'Unit of measure for the maintenance interval (hours, days, weeks, months, years, kilometers, cycles). [ENUM-REF-CANDIDATE: hours|days|weeks|months|years|kilometers|cycles — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:MaintenancePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:intervalValue rdf:type rdf:Property ;
    rdfs:label 'Interval Value' ;
    rdfs:comment 'Numeric value defining the service interval (e.g., 250 for every 250 engine hours, 6 for every 6 months).' ;
    rdfs:domain ind:MaintenancePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastExecutionDate rdf:type rdf:Property ;
    rdfs:label 'Last Execution Date' ;
    rdfs:comment 'Date when the maintenance plan was last executed, used to calculate the next scheduled maintenance date.' ;
    rdfs:domain ind:MaintenancePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:leadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Lead Time Days' ;
    rdfs:comment 'Number of days advance notice required before the scheduled maintenance date to allow for planning, parts procurement, and resource allocation.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:manufacturerRecommendationFlag rdf:type rdf:Property ;
    rdfs:label 'Manufacturer Recommendation Flag' ;
    rdfs:comment 'Indicates whether this maintenance plan follows the equipment manufacturer\'s recommended service schedule.' ;
    rdfs:domain ind:MaintenancePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nextScheduledDate rdf:type rdf:Property ;
    rdfs:label 'Next Scheduled Date' ;
    rdfs:comment 'Calculated date for the next scheduled maintenance activity based on the interval and last execution date.' ;
    rdfs:domain ind:MaintenancePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:partsListReference rdf:type rdf:Property ;
    rdfs:label 'Parts List Reference' ;
    rdfs:comment 'Reference to the bill of materials (BOM) or parts list defining the spare parts and materials required for this maintenance plan.' ;
    rdfs:domain ind:MaintenancePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planName rdf:type rdf:Property ;
    rdfs:label 'Plan Name' ;
    rdfs:comment 'Descriptive name of the maintenance plan for human identification and reporting purposes.' ;
    rdfs:domain ind:MaintenancePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyCriticalFlag rdf:type rdf:Property ;
    rdfs:label 'Safety Critical Flag' ;
    rdfs:comment 'Indicates whether this maintenance plan addresses safety-critical equipment or systems where failure could result in injury or fatality.' ;
    rdfs:domain ind:MaintenancePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:schedulingStrategy rdf:type rdf:Property ;
    rdfs:label 'Scheduling Strategy' ;
    rdfs:comment 'Defines how maintenance tasks are scheduled: fixed schedule (specific calendar dates), floating schedule (relative to last completion), or on-demand (triggered by condition).' ;
    rdfs:domain ind:MaintenancePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteLocationCode rdf:type rdf:Property ;
    rdfs:label 'Site Location Code' ;
    rdfs:comment 'Code identifying the construction site, yard, or facility where the equipment is located and maintenance will be performed.' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taskListReference rdf:type rdf:Property ;
    rdfs:label 'Task List Reference' ;
    rdfs:comment 'Reference code to the detailed maintenance task list or work instruction document that defines the specific activities, steps, and procedures to be performed.' ;
    rdfs:domain ind:MaintenancePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:toleranceAfterDays rdf:type rdf:Property ;
    rdfs:label 'Tolerance After Days' ;
    rdfs:comment 'Number of days after the scheduled date that maintenance can be delayed without triggering an overdue alert.' ;
    rdfs:domain ind:MaintenancePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:toleranceBeforeDays rdf:type rdf:Property ;
    rdfs:label 'Tolerance Before Days' ;
    rdfs:comment 'Number of days before the scheduled date that maintenance can be performed early without resetting the interval counter.' ;
    rdfs:domain ind:MaintenancePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:warrantyImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Warranty Impact Flag' ;
    rdfs:comment 'Indicates whether adherence to this maintenance plan is required to maintain equipment warranty coverage.' ;
    rdfs:domain ind:MaintenancePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:workOrderType rdf:type rdf:Property ;
    rdfs:label 'Work Order Type' ;
    rdfs:comment 'Classification of the work orders generated by this maintenance plan (preventive maintenance, inspection, calibration, overhaul, statutory compliance).' ;
    rdfs:domain ind:MaintenancePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignedCraftWorkerId rdf:type rdf:Property ;
    rdfs:label 'Assigned Craft Worker Id' ;
    rdfs:comment 'Foreign key linking to workforce.craft_worker. Business justification: Work order execution tracking: maintenance orders are assigned to specific technicians/mechanics for execution. SAP PM and HCSS both require identifying the assigned craft worker on each work order fo' ;
    rdfs:domain ind:MaintenanceOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CraftWorker .

ind:assignedCrewId rdf:type rdf:Property ;
    rdfs:label 'Assigned Crew Id' ;
    rdfs:comment 'Foreign key linking to workforce.crew. Business justification: Multi-technician maintenance execution: large equipment maintenance orders (engine overhauls, crane inspections) require a full crew. Tracking the executing crew on the order enables crew productivity' ;
    rdfs:domain ind:MaintenanceOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Crew .

ind:inspectionRecordId rdf:type rdf:Property ;
    rdfs:label 'Inspection Record Id' ;
    rdfs:comment 'Foreign key linking to equipment.inspection_record. Business justification: A maintenance order is frequently triggered by a failed or defective inspection finding. maintenance_order already has compliance_inspection_flag and inspection_certificate_number (string), but no str' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InspectionRecord .

ind:verificationInspectionId rdf:type rdf:Property ;
    rdfs:label 'Verification Inspection Id' ;
    rdfs:comment 'Foreign key linking to quality.inspection. Business justification: Post-maintenance quality inspections verify that maintenance work meets acceptance criteria before equipment is returned to service. Construction QA requires linking the maintenance order to the verif' ;
    rdfs:domain ind:MaintenanceOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Inspection .

ind:actualEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual End Timestamp' ;
    rdfs:comment 'Actual date and time when the maintenance work was completed. Used to calculate actual downtime and compare against planned duration.' ;
    rdfs:domain ind:MaintenanceOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Start Timestamp' ;
    rdfs:comment 'Actual date and time when the maintenance work commenced. Captured from field logs or technician time entry systems.' ;
    rdfs:domain ind:MaintenanceOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:complianceInspectionFlag rdf:type rdf:Property ;
    rdfs:label 'Compliance Inspection Flag' ;
    rdfs:comment 'Indicates whether this maintenance order includes a statutory or regulatory compliance inspection (e.g., OSHA crane inspection, pressure vessel certification). True if compliance inspection performed.' ;
    rdfs:domain ind:MaintenanceOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:externalServicesCost rdf:type rdf:Property ;
    rdfs:label 'External Services Cost' ;
    rdfs:comment 'Cost of external contractor services or specialized vendor support procured for this maintenance order (e.g., OEM technician, crane inspection service).' ;
    rdfs:domain ind:MaintenanceOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:failureCode rdf:type rdf:Property ;
    rdfs:label 'Failure Code' ;
    rdfs:comment 'Standardized code identifying the type of failure or defect addressed by this maintenance order (e.g., hydraulic leak, engine overheating, electrical fault). Used for failure pattern analysis.' ;
    rdfs:domain ind:MaintenanceOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failureDescription rdf:type rdf:Property ;
    rdfs:label 'Failure Description' ;
    rdfs:comment 'Detailed narrative description of the failure, defect, or maintenance requirement that this order addresses. Captured from technician notes or notification text.' ;
    rdfs:domain ind:MaintenanceOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Inspection Certificate Number' ;
    rdfs:comment 'Certificate or permit number issued upon successful completion of a statutory inspection, if applicable. Required for regulatory audit trails.' ;
    rdfs:domain ind:MaintenanceOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:laborCost rdf:type rdf:Property ;
    rdfs:label 'Labor Cost' ;
    rdfs:comment 'Total labor cost for this maintenance order, calculated from labor hours and technician rates. Excludes parts and external services.' ;
    rdfs:domain ind:MaintenanceOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:meterReadingAtMaintenance rdf:type rdf:Property ;
    rdfs:label 'Meter Reading At Maintenance' ;
    rdfs:comment 'Equipment hour meter or odometer reading captured at the time of maintenance. Used for usage-based maintenance scheduling and lifecycle tracking.' ;
    rdfs:domain ind:MaintenanceOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:orderNumber rdf:type rdf:Property ;
    rdfs:label 'Order Number' ;
    rdfs:comment 'Business identifier for the maintenance order, typically the SAP PM order number or HCSS work order reference used for tracking and reporting.' ;
    rdfs:domain ind:MaintenanceOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderStatus rdf:type rdf:Property ;
    rdfs:label 'Order Status' ;
    rdfs:comment 'Current lifecycle status of the maintenance order. Tracks progression from creation through execution to closure. [ENUM-REF-CANDIDATE: created|released|in_progress|completed|technically_complete|closed|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:MaintenanceOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderType rdf:type rdf:Property ;
    rdfs:label 'Order Type' ;
    rdfs:comment 'Classification of the maintenance activity: preventive (scheduled), corrective (planned repair), breakdown (emergency), statutory inspection (regulatory), calibration, or overhaul.' ;
    rdfs:domain ind:MaintenanceOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partsCost rdf:type rdf:Property ;
    rdfs:label 'Parts Cost' ;
    rdfs:comment 'Total cost of parts and materials consumed during this maintenance activity, aggregated from all parts line items.' ;
    rdfs:domain ind:MaintenanceOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedEndDate rdf:type rdf:Property ;
    rdfs:label 'Planned End Date' ;
    rdfs:comment 'Scheduled date when the maintenance activity is planned to be completed. Used for equipment downtime planning and project scheduling.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:purchaseOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Purchase Order Number' ;
    rdfs:comment 'Purchase order number for external services or parts procured for this maintenance order, if applicable. Links to procurement records.' ;
    rdfs:domain ind:Equipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalMaintenanceCost rdf:type rdf:Property ;
    rdfs:label 'Total Maintenance Cost' ;
    rdfs:comment 'Total cost of the maintenance order, summing labor, parts, and external services. Used for asset lifecycle costing and budget tracking.' ;
    rdfs:domain ind:MaintenanceOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:warrantyClaimFlag rdf:type rdf:Property ;
    rdfs:label 'Warranty Claim Flag' ;
    rdfs:comment 'Indicates whether this maintenance order is associated with a warranty claim against the equipment manufacturer or supplier. True if warranty claim was filed.' ;
    rdfs:domain ind:MaintenanceOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:warrantyClaimNumber rdf:type rdf:Property ;
    rdfs:label 'Warranty Claim Number' ;
    rdfs:comment 'External warranty claim reference number provided by the equipment manufacturer or supplier, if applicable. Null if no warranty claim.' ;
    rdfs:domain ind:MaintenanceOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workCenterCode rdf:type rdf:Property ;
    rdfs:label 'Work Center Code' ;
    rdfs:comment 'Code identifying the maintenance work center or shop responsible for executing this order (e.g., heavy equipment shop, electrical shop, hydraulics shop).' ;
    rdfs:domain ind:MaintenanceOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workPerformedDescription rdf:type rdf:Property ;
    rdfs:label 'Work Performed Description' ;
    rdfs:comment 'Detailed narrative of the maintenance work actually performed, including repairs, replacements, adjustments, and inspections. Serves as technical record and warranty evidence.' ;
    rdfs:domain ind:MaintenanceOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectorCraftWorkerId rdf:type rdf:Property ;
    rdfs:label 'Inspector Craft Worker Id' ;
    rdfs:comment 'Foreign key linking to workforce.craft_worker. Business justification: Regulatory compliance requirement: OSHA and jurisdictional regulations mandate identifying the qualified inspector who performed each equipment inspection. Certificate issuance and corrective action a' ;
    rdfs:domain ind:InspectionRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CraftWorker .

ind:certificateDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Certificate Document Reference' ;
    rdfs:comment 'File path, document management system reference, or URL pointing to the stored digital copy of the compliance certificate. Used for audit retrieval and regulatory verification. Null if no certificate was issued.' ;
    rdfs:domain ind:InspectionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificateIssuedFlag rdf:type rdf:Property ;
    rdfs:label 'Certificate Issued Flag' ;
    rdfs:comment 'Boolean indicator of whether a formal compliance certificate was issued as a result of this inspection. True indicates a certificate was generated and is on file. False indicates no certificate was issued (typical for routine pre-start checks or failed inspections).' ;
    rdfs:domain ind:InspectionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:certificateIssuingAuthority rdf:type rdf:Property ;
    rdfs:label 'Certificate Issuing Authority' ;
    rdfs:comment 'Name of the organization or regulatory body that issued the compliance certificate. Examples include OSHA, ASME authorized inspector, insurance company, third-party certification body, or internal HSE department. Null if no certificate was issued.' ;
    rdfs:domain ind:InspectionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificateType rdf:type rdf:Property ;
    rdfs:label 'Certificate Type' ;
    rdfs:comment 'Classification of the compliance certificate issued. Crane load test certificate: structural capacity verification. Pressure vessel certificate: boiler and pressure equipment certification. Lifting gear certificate: rigging and lifting equipment certification. OSHA compliance certificate: regulatory safety certification. Insurance certificate: insurer-required equipment certification. FAT: Factory Acceptance Test certificate. SAT: Site Acceptance Test certificate. Fitness for use: general equipment fitness certification. Null if no certificate was issued. [ENUM-REF-CANDIDATE: crane_load_test|pressure_vessel|lifting_gear|osha_compliance|insurance|fat|sat|fitness_for_use — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionsRequired rdf:type rdf:Property ;
    rdfs:label 'Corrective Actions Required' ;
    rdfs:comment 'Detailed description of corrective actions, repairs, or remediation work required to address identified defects and restore equipment to compliant, fit-for-use condition.' ;
    rdfs:domain ind:InspectionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defectsDescription rdf:type rdf:Property ;
    rdfs:label 'Defects Description' ;
    rdfs:comment 'Detailed narrative description of all defects, non-conformances, observations, or safety concerns identified during the inspection. Includes location, severity, and nature of each finding.' ;
    rdfs:domain ind:InspectionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defectsIdentifiedCount rdf:type rdf:Property ;
    rdfs:label 'Defects Identified Count' ;
    rdfs:comment 'Total number of defects, non-conformances, or observations identified during the inspection. Zero indicates no issues found.' ;
    rdfs:domain ind:InspectionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:equipmentHoursAtInspection rdf:type rdf:Property ;
    rdfs:label 'Equipment Hours At Inspection' ;
    rdfs:comment 'Total accumulated operating hours recorded on the equipment hour meter at the time of inspection. Used for usage-based maintenance scheduling and lifecycle tracking.' ;
    rdfs:domain ind:InspectionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inspectionCost rdf:type rdf:Property ;
    rdfs:label 'Inspection Cost' ;
    rdfs:comment 'Total cost incurred for this inspection event, including inspector fees, third-party inspection charges, testing costs, and administrative overhead. Null if cost not tracked.' ;
    rdfs:domain ind:InspectionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inspectionCostCurrency rdf:type rdf:Property ;
    rdfs:label 'Inspection Cost Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the inspection cost. Examples: USD, EUR, GBP. Null if cost not tracked.' ;
    rdfs:domain ind:InspectionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Inspection End Timestamp' ;
    rdfs:comment 'Precise date and time when the inspection activity was completed and findings were recorded.' ;
    rdfs:domain ind:InspectionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:inspectionLocation rdf:type rdf:Property ;
    rdfs:label 'Inspection Location' ;
    rdfs:comment 'Physical location where the inspection was performed. May be a construction site name, yard location, workshop, factory, or field location identifier.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionNotes rdf:type rdf:Property ;
    rdfs:label 'Inspection Notes' ;
    rdfs:comment 'Free-form text field for additional observations, comments, recommendations, or contextual information recorded by the inspector that does not fit into structured fields.' ;
    rdfs:domain ind:InspectionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionOutcome rdf:type rdf:Property ;
    rdfs:label 'Inspection Outcome' ;
    rdfs:comment 'Final pass/fail determination of the inspection. Pass: equipment meets all requirements and is fit for use. Fail: equipment does not meet requirements and must not be used until corrective action is completed. Conditional pass: equipment passed with minor observations or time-limited approval. Not applicable: inspection was not completed or outcome not yet determined.' ;
    rdfs:domain ind:InspectionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Inspection Start Timestamp' ;
    rdfs:comment 'Precise date and time when the inspection activity commenced on site or in the facility.' ;
    rdfs:domain ind:InspectionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:estimateId rdf:type rdf:Property ;
    rdfs:label 'Estimate Id' ;
    rdfs:comment 'Foreign key linking to bid.estimate. Business justification: Post-award cost variance analysis: actual rental agreements are reconciled against the originating bid estimate to measure equipment cost performance. Construction cost controllers routinely compare e' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Estimate .

ind:billingFrequency rdf:type rdf:Property ;
    rdfs:label 'Billing Frequency' ;
    rdfs:comment 'Frequency at which rental charges are invoiced by the supplier (daily, weekly, monthly, or milestone-based).' ;
    rdfs:domain ind:RentalAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Contract Document Reference' ;
    rdfs:comment 'Reference to the physical or digital contract document stored in the document management system (e.g., Aconex document ID).' ;
    rdfs:domain ind:RentalAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dailyHireRate rdf:type rdf:Property ;
    rdfs:label 'Daily Hire Rate' ;
    rdfs:comment 'Agreed daily rental rate for the equipment in the contract currency. Used when billing is on a daily basis.' ;
    rdfs:domain ind:RentalAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:damageWaiverAmount rdf:type rdf:Property ;
    rdfs:label 'Damage Waiver Amount' ;
    rdfs:comment 'Optional damage waiver fee paid to limit contractor liability for equipment damage during the rental period.' ;
    rdfs:domain ind:RentalAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:demobilizationCharge rdf:type rdf:Property ;
    rdfs:label 'Demobilization Charge' ;
    rdfs:comment 'One-time charge for dismantling and removing the equipment from the project site. Invoiced at rental completion.' ;
    rdfs:domain ind:RentalAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:equipmentDescription rdf:type rdf:Property ;
    rdfs:label 'Equipment Description' ;
    rdfs:comment 'Detailed description of the rented equipment including make, model, capacity, and specifications (e.g., \'Liebherr LTM 1200-5.1 Mobile Crane, 200-ton capacity\').' ;
    rdfs:domain ind:RentalAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fuelIncludedFlag rdf:type rdf:Property ;
    rdfs:label 'Fuel Included Flag' ;
    rdfs:comment 'Indicates whether fuel costs are included in the hire rate (True) or billed separately (False).' ;
    rdfs:domain ind:RentalAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:insuranceCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Insurance Certificate Number' ;
    rdfs:comment 'Reference number of the insurance certificate covering the rented equipment. Used for compliance verification.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceRequirement rdf:type rdf:Property ;
    rdfs:label 'Insurance Requirement' ;
    rdfs:comment 'Description of insurance coverage requirements for the rented equipment, including liability limits and coverage types.' ;
    rdfs:domain ind:RentalAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lateReturnPenaltyRate rdf:type rdf:Property ;
    rdfs:label 'Late Return Penalty Rate' ;
    rdfs:comment 'Daily penalty rate charged by the supplier if equipment is returned after the agreed rental end date.' ;
    rdfs:domain ind:RentalAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maintenanceResponsibility rdf:type rdf:Property ;
    rdfs:label 'Maintenance Responsibility' ;
    rdfs:comment 'Party responsible for routine maintenance and repairs during the rental period (supplier, contractor, or shared).' ;
    rdfs:domain ind:RentalAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumHirePeriodDays rdf:type rdf:Property ;
    rdfs:label 'Minimum Hire Period Days' ;
    rdfs:comment 'Minimum number of days the equipment must be hired as stipulated in the rental agreement. Used for cost commitment calculation.' ;
    rdfs:domain ind:RentalAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:mobilizationCharge rdf:type rdf:Property ;
    rdfs:label 'Mobilization Charge' ;
    rdfs:comment 'One-time charge for transporting and setting up the equipment at the project site. Invoiced at rental commencement.' ;
    rdfs:domain ind:RentalAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:monthlyHireRate rdf:type rdf:Property ;
    rdfs:label 'Monthly Hire Rate' ;
    rdfs:comment 'Agreed monthly rental rate for the equipment in the contract currency. Used when billing is on a monthly basis.' ;
    rdfs:domain ind:RentalAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:operatorSuppliedFlag rdf:type rdf:Property ;
    rdfs:label 'Operator Supplied Flag' ;
    rdfs:comment 'Indicates whether the rental supplier provides a qualified operator with the equipment (True) or if the contractor provides their own operator (False).' ;
    rdfs:domain ind:RentalAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rentalAgreementNumber rdf:type rdf:Property ;
    rdfs:label 'Rental Agreement Number' ;
    rdfs:comment 'Business-facing unique identifier for the rental agreement, typically used in contracts and invoices. Format: RA-NNNNNN.' ;
    rdfs:domain ind:RentalAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rentalEndDate rdf:type rdf:Property ;
    rdfs:label 'Rental End Date' ;
    rdfs:comment 'Planned or actual date when the rental period ends and equipment is demobilized. Nullable for open-ended rentals.' ;
    rdfs:domain ind:RentalAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rentalPoNumber rdf:type rdf:Property ;
    rdfs:label 'Rental Po Number' ;
    rdfs:comment 'Purchase order number issued to the supplier for this rental agreement. Links the rental agreement to the procurement transaction.' ;
    rdfs:domain ind:RentalAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rentalStartDate rdf:type rdf:Property ;
    rdfs:label 'Rental Start Date' ;
    rdfs:comment 'Date when the rental period begins and hire charges commence. Typically aligned with equipment mobilization date.' ;
    rdfs:domain ind:RentalAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rentalStatus rdf:type rdf:Property ;
    rdfs:label 'Rental Status' ;
    rdfs:comment 'Current lifecycle status of the rental agreement. Tracks the agreement from draft through completion or cancellation. [ENUM-REF-CANDIDATE: draft|approved|active|on_hire|demobilized|completed|cancelled|disputed — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:RentalAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:securityDepositAmount rdf:type rdf:Property ;
    rdfs:label 'Security Deposit Amount' ;
    rdfs:comment 'Refundable security deposit held by the supplier to cover potential damage or late return penalties.' ;
    rdfs:domain ind:RentalAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalCommittedCost rdf:type rdf:Property ;
    rdfs:label 'Total Committed Cost' ;
    rdfs:comment 'Total committed cost for the rental agreement including minimum hire period charges, mobilization, and demobilization. Used for budget commitment and accrual.' ;
    rdfs:domain ind:RentalAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:weeklyHireRate rdf:type rdf:Property ;
    rdfs:label 'Weekly Hire Rate' ;
    rdfs:comment 'Agreed weekly rental rate for the equipment in the contract currency. Used when billing is on a weekly basis.' ;
    rdfs:domain ind:RentalAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transportOperatorCraftWorkerId rdf:type rdf:Property ;
    rdfs:label 'Transport Operator Craft Worker Id' ;
    rdfs:comment 'Foreign key linking to workforce.craft_worker. Business justification: Transport compliance and insurance documentation: equipment mobilizations require identifying the licensed operator responsible for the move. Oversize/overweight permit compliance, insurance coverage ' ;
    rdfs:domain ind:EquipmentMobilization ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CraftWorker .

ind:actualArrivalDate rdf:type rdf:Property ;
    rdfs:label 'Actual Arrival Date' ;
    rdfs:comment 'Actual date when the equipment arrived at the destination location.' ;
    rdfs:domain ind:EquipmentMobilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actualDispatchDate rdf:type rdf:Property ;
    rdfs:label 'Actual Dispatch Date' ;
    rdfs:comment 'Actual date when the equipment departed from the origin location.' ;
    rdfs:domain ind:EquipmentMobilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actualTransitHours rdf:type rdf:Property ;
    rdfs:label 'Actual Transit Hours' ;
    rdfs:comment 'Actual duration in hours that the equipment was in transit from origin to destination.' ;
    rdfs:domain ind:EquipmentMobilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:destinationLocation rdf:type rdf:Property ;
    rdfs:label 'Destination Location' ;
    rdfs:comment 'Name or identifier of the location to which the equipment is being mobilized (project site, yard, storage facility).' ;
    rdfs:domain ind:EquipmentMobilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationSiteCode rdf:type rdf:Property ;
    rdfs:label 'Destination Site Code' ;
    rdfs:comment 'Standardized code identifying the destination site or facility.' ;
    rdfs:domain ind:EquipmentMobilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispatchCondition rdf:type rdf:Property ;
    rdfs:label 'Dispatch Condition' ;
    rdfs:comment 'Assessed physical and operational condition of the equipment at the time of dispatch from the origin location.' ;
    rdfs:domain ind:EquipmentMobilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispatchConditionNotes rdf:type rdf:Property ;
    rdfs:label 'Dispatch Condition Notes' ;
    rdfs:comment 'Detailed notes or observations regarding the equipment condition at dispatch, including any pre-existing damage or defects.' ;
    rdfs:domain ind:EquipmentMobilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispatchSignatureTimestamp rdf:type rdf:Property ;
    rdfs:label 'Dispatch Signature Timestamp' ;
    rdfs:comment 'Date and time when the dispatch sign-off was completed.' ;
    rdfs:domain ind:EquipmentMobilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:distanceKm rdf:type rdf:Property ;
    rdfs:label 'Distance Km' ;
    rdfs:comment 'Total distance in kilometers between the origin and destination locations.' ;
    rdfs:domain ind:EquipmentMobilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedTransitHours rdf:type rdf:Property ;
    rdfs:label 'Estimated Transit Hours' ;
    rdfs:comment 'Estimated duration in hours for the equipment to be transported from origin to destination.' ;
    rdfs:domain ind:EquipmentMobilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:eventType rdf:type rdf:Property ;
    rdfs:label 'Event Type' ;
    rdfs:comment 'Type of equipment movement event: mobilization (to site), demobilization (from site), inter-site transfer, or relocation.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originLocation rdf:type rdf:Property ;
    rdfs:label 'Origin Location' ;
    rdfs:comment 'Name or identifier of the location from which the equipment is being mobilized (yard, warehouse, previous site).' ;
    rdfs:domain ind:EquipmentMobilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originSiteCode rdf:type rdf:Property ;
    rdfs:label 'Origin Site Code' ;
    rdfs:comment 'Standardized code identifying the origin site or facility.' ;
    rdfs:domain ind:EquipmentMobilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:permitRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Permit Required Flag' ;
    rdfs:comment 'Indicates whether special permits (oversize load, road permits, environmental permits) are required for this mobilization.' ;
    rdfs:domain ind:EquipmentMobilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:plannedArrivalDate rdf:type rdf:Property ;
    rdfs:label 'Planned Arrival Date' ;
    rdfs:comment 'Scheduled date when the equipment is expected to arrive at the destination location.' ;
    rdfs:domain ind:EquipmentMobilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:plannedDispatchDate rdf:type rdf:Property ;
    rdfs:label 'Planned Dispatch Date' ;
    rdfs:comment 'Scheduled date when the equipment is planned to depart from the origin location.' ;
    rdfs:domain ind:EquipmentMobilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reason rdf:type rdf:Property ;
    rdfs:label 'Reason' ;
    rdfs:comment 'Business justification or reason for the mobilization event, such as project start, equipment replacement, or maintenance requirement.' ;
    rdfs:domain ind:EquipmentMobilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receiptConditionNotes rdf:type rdf:Property ;
    rdfs:label 'Receipt Condition Notes' ;
    rdfs:comment 'Detailed notes or observations regarding the equipment condition at receipt, including any damage incurred during transport.' ;
    rdfs:domain ind:EquipmentMobilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receiptSignatureTimestamp rdf:type rdf:Property ;
    rdfs:label 'Receipt Signature Timestamp' ;
    rdfs:comment 'Date and time when the receipt sign-off was completed.' ;
    rdfs:domain ind:EquipmentMobilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:receiptSignedBy rdf:type rdf:Property ;
    rdfs:label 'Receipt Signed By' ;
    rdfs:comment 'Name of the site manager or authorized personnel who signed off on the equipment receipt at the destination.' ;
    rdfs:domain ind:EquipmentMobilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transportCost rdf:type rdf:Property ;
    rdfs:label 'Transport Cost' ;
    rdfs:comment 'Total cost incurred for transporting the equipment, including freight, permits, and handling charges.' ;
    rdfs:domain ind:EquipmentMobilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transportCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Transport Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the transport cost.' ;
    rdfs:domain ind:EquipmentMobilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transportMethod rdf:type rdf:Property ;
    rdfs:label 'Transport Method' ;
    rdfs:comment 'Method or mode of transportation used to move the equipment.' ;
    rdfs:domain ind:EquipmentMobilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fuelTransactionId rdf:type rdf:Property ;
    rdfs:label 'Fuel Transaction Id' ;
    rdfs:comment 'Unique identifier for the fuel transaction record. Primary key.' ;
    rdfs:domain ind:FuelTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approvalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Approval Timestamp' ;
    rdfs:comment 'Date and time when the fuel transaction was approved. Null if not yet approved.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:carbonEmissionKg rdf:type rdf:Property ;
    rdfs:label 'Carbon Emission Kg' ;
    rdfs:comment 'Estimated carbon dioxide emissions in kilograms resulting from the fuel consumed. Calculated based on fuel type and quantity for ISO 14001 environmental reporting.' ;
    rdfs:domain ind:FuelTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fuelCardNumber rdf:type rdf:Property ;
    rdfs:label 'Fuel Card Number' ;
    rdfs:comment 'Fuel card or fleet card number used for the transaction. Masked or tokenized for security. Used for reconciliation with vendor invoices.' ;
    rdfs:domain ind:FuelTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fuelPointName rdf:type rdf:Property ;
    rdfs:label 'Fuel Point Name' ;
    rdfs:comment 'Name or description of the fuel point or bowser where the fuel was issued.' ;
    rdfs:domain ind:FuelTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hourMeterReading rdf:type rdf:Property ;
    rdfs:label 'Hour Meter Reading' ;
    rdfs:comment 'Hour meter reading of the equipment at the time of fueling. Used to calculate fuel consumption per operating hour and detect anomalies.' ;
    rdfs:domain ind:FuelTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:invoiceNumber rdf:type rdf:Property ;
    rdfs:label 'Invoice Number' ;
    rdfs:comment 'Vendor invoice number associated with the fuel transaction. Used for accounts payable reconciliation.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isEmergencyRefuel rdf:type rdf:Property ;
    rdfs:label 'Is Emergency Refuel' ;
    rdfs:comment 'Flag indicating whether this was an emergency or unplanned refueling event. True indicates emergency; False indicates scheduled refueling.' ;
    rdfs:domain ind:FuelTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isTheftSuspected rdf:type rdf:Property ;
    rdfs:label 'Is Theft Suspected' ;
    rdfs:comment 'Flag indicating whether fuel theft or wastage is suspected based on consumption patterns or anomaly detection. True indicates suspected theft; False indicates normal transaction.' ;
    rdfs:domain ind:FuelTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:odometerReading rdf:type rdf:Property ;
    rdfs:label 'Odometer Reading' ;
    rdfs:comment 'Odometer reading of the fleet vehicle at the time of fueling. Used for mileage-based fuel consumption analysis. Applicable to vehicles with odometers.' ;
    rdfs:domain ind:FuelTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityIssued rdf:type rdf:Property ;
    rdfs:label 'Quantity Issued' ;
    rdfs:comment 'Quantity of fuel issued to the equipment in the specified unit of measure. Typically measured in litres or gallons.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tankCapacityPercentage rdf:type rdf:Property ;
    rdfs:label 'Tank Capacity Percentage' ;
    rdfs:comment 'Percentage of the equipment fuel tank capacity filled during this transaction. Used to detect partial fills and optimize refueling schedules.' ;
    rdfs:domain ind:FuelTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalCost rdf:type rdf:Property ;
    rdfs:label 'Total Cost' ;
    rdfs:comment 'Total cost of the fuel transaction calculated as quantity issued multiplied by unit cost. Expressed in the transaction currency.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transactionNotes rdf:type rdf:Property ;
    rdfs:label 'Transaction Notes' ;
    rdfs:comment 'Free-text notes or comments about the fuel transaction. May include reasons for emergency refueling, discrepancies, or special circumstances.' ;
    rdfs:domain ind:FuelTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionNumber rdf:type rdf:Property ;
    rdfs:label 'Transaction Number' ;
    rdfs:comment 'Business-facing unique transaction number or receipt number issued at the time of fueling. Used for audit trail and reconciliation.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionStatus rdf:type rdf:Property ;
    rdfs:label 'Transaction Status' ;
    rdfs:comment 'Current status of the fuel transaction in its lifecycle. Completed indicates finalized and posted; pending indicates awaiting approval; cancelled indicates voided; disputed indicates under review.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Transaction Timestamp' ;
    rdfs:comment 'Date and time when the fuel was issued to the equipment. Represents the actual business event time of fueling.' ;
    rdfs:domain ind:FuelTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:unitCost rdf:type rdf:Property ;
    rdfs:label 'Unit Cost' ;
    rdfs:comment 'Cost per unit of fuel at the time of transaction. Expressed in the transaction currency.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:documentRegisterId rdf:type rdf:Property ;
    rdfs:label 'Document Register Id' ;
    rdfs:comment 'Reference to the digital document or scanned copy of the physical certification document stored in the document management system. Links to Aconex or BIM 360 document repository.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DocumentRegister .

ind:assessorName rdf:type rdf:Property ;
    rdfs:label 'Assessor Name' ;
    rdfs:comment 'Name of the qualified assessor or examiner who conducted the certification assessment and validated the operators competency.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationLevel rdf:type rdf:Property ;
    rdfs:label 'Certification Level' ;
    rdfs:comment 'The proficiency or skill level represented by the certification, such as basic, intermediate, advanced, or master operator. Indicates the complexity of equipment and operations the operator is qualified to perform. [ENUM-REF-CANDIDATE: basic|intermediate|advanced|master|trainee|journeyman|supervisor — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationStatus rdf:type rdf:Property ;
    rdfs:label 'Certification Status' ;
    rdfs:comment 'Current lifecycle status of the certification. Indicates whether the certification is valid and active, expired, suspended, revoked, or pending renewal. Critical for HSE pre-start checks and operator assignment validation.' ;
    rdfs:domain ind:OperatorCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationType rdf:type rdf:Property ;
    rdfs:label 'Certification Type' ;
    rdfs:comment 'The type or nature of the certification, such as operator license, competency card, safety certification, or manufacturer-specific certification.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certifyingBody rdf:type rdf:Property ;
    rdfs:label 'Certifying Body' ;
    rdfs:comment 'Name of the organization, authority, or institution that issued the certification. Examples include NCCCO, OSHA-approved training providers, manufacturer training centers, or government licensing authorities.' ;
    rdfs:domain ind:OperatorCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certifyingBodyAccreditationNumber rdf:type rdf:Property ;
    rdfs:label 'Certifying Body Accreditation Number' ;
    rdfs:comment 'Accreditation or registration number of the certifying body, validating that the issuing organization is authorized to provide certifications.' ;
    rdfs:domain ind:OperatorCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costAmount rdf:type rdf:Property ;
    rdfs:label 'Cost Amount' ;
    rdfs:comment 'The total cost incurred to obtain or renew this certification, including training fees, examination fees, and administrative charges. Used for workforce development cost tracking.' ;
    rdfs:domain ind:OperatorCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Cost Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the certification cost amount. Enables multi-currency cost tracking for international operations.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endorsements rdf:type rdf:Property ;
    rdfs:label 'Endorsements' ;
    rdfs:comment 'Additional endorsements, specializations, or restrictions associated with the certification, such as night operations, confined spaces, or specific attachment types. Comma-separated list of endorsement codes or descriptions.' ;
    rdfs:domain ind:OperatorCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingCountryCode rdf:type rdf:Property ;
    rdfs:label 'Issuing Country Code' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code representing the country in which the certification was issued. Important for cross-border projects and international operator mobility.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingStateProvince rdf:type rdf:Property ;
    rdfs:label 'Issuing State Province' ;
    rdfs:comment 'State, province, or regional jurisdiction within the issuing country where the certification was granted. Relevant for jurisdictions with state-level licensing requirements.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastRenewalDate rdf:type rdf:Property ;
    rdfs:label 'Last Renewal Date' ;
    rdfs:comment 'The most recent date on which the certification was renewed or recertified. Tracks the certification maintenance history.' ;
    rdfs:domain ind:OperatorCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:medicalClearanceDate rdf:type rdf:Property ;
    rdfs:label 'Medical Clearance Date' ;
    rdfs:comment 'The date on which the operator received medical clearance or passed the required health examination for this certification. Nullable if medical clearance is not required.' ;
    rdfs:domain ind:OperatorCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:medicalClearanceExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Medical Clearance Expiry Date' ;
    rdfs:comment 'The date on which the medical clearance expires and must be renewed. Nullable if medical clearance is not required or does not expire.' ;
    rdfs:domain ind:OperatorCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:medicalClearanceRequired rdf:type rdf:Property ;
    rdfs:label 'Medical Clearance Required' ;
    rdfs:comment 'Indicates whether a medical examination or health clearance is required as part of the certification or renewal process. True if medical clearance is mandatory, false otherwise.' ;
    rdfs:domain ind:OperatorCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nextRenewalDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Renewal Due Date' ;
    rdfs:comment 'The date by which the operator must complete renewal requirements to maintain continuous certification. Used for proactive renewal planning and compliance tracking.' ;
    rdfs:domain ind:OperatorCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:practicalAssessmentScore rdf:type rdf:Property ;
    rdfs:label 'Practical Assessment Score' ;
    rdfs:comment 'Score or grade achieved by the operator in the practical hands-on assessment component of the certification. Typically expressed as a percentage or numeric score.' ;
    rdfs:domain ind:OperatorCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reciprocityAgreements rdf:type rdf:Property ;
    rdfs:label 'Reciprocity Agreements' ;
    rdfs:comment 'List of countries, states, or jurisdictions where this certification is recognized under reciprocity or mutual recognition agreements. Enables cross-jurisdictional operator deployment.' ;
    rdfs:domain ind:OperatorCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalRequirement rdf:type rdf:Property ;
    rdfs:label 'Renewal Requirement' ;
    rdfs:comment 'Description of the requirements the operator must fulfill to renew the certification, such as refresher training hours, re-assessment, continuing education credits, or medical examination.' ;
    rdfs:domain ind:OperatorCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restrictions rdf:type rdf:Property ;
    rdfs:label 'Restrictions' ;
    rdfs:comment 'Any limitations or restrictions placed on the certification, such as daylight operations only, supervised operation required, or specific site conditions. Defines operational boundaries for the operator.' ;
    rdfs:domain ind:OperatorCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sponsorOrganization rdf:type rdf:Property ;
    rdfs:label 'Sponsor Organization' ;
    rdfs:comment 'Name of the organization that sponsored or paid for the operators certification training and examination. May be the construction company, a subcontractor, or the operator themselves.' ;
    rdfs:domain ind:OperatorCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:theoryAssessmentScore rdf:type rdf:Property ;
    rdfs:label 'Theory Assessment Score' ;
    rdfs:comment 'Score or grade achieved by the operator in the theoretical or written examination component of the certification. Typically expressed as a percentage or numeric score.' ;
    rdfs:domain ind:OperatorCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trainingHoursCompleted rdf:type rdf:Property ;
    rdfs:label 'Training Hours Completed' ;
    rdfs:comment 'Total number of training hours completed by the operator to achieve this certification. Demonstrates the depth of training and preparation.' ;
    rdfs:domain ind:OperatorCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:verificationStatus rdf:type rdf:Property ;
    rdfs:label 'Verification Status' ;
    rdfs:comment 'Status of the certification verification process, indicating whether the certification has been independently verified with the issuing body. Critical for compliance and audit purposes.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verifiedBy rdf:type rdf:Property ;
    rdfs:label 'Verified By' ;
    rdfs:comment 'Name or identifier of the person, system, or organization that performed the certification verification. Provides audit trail for verification activities.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Approval Required Flag' ;
    rdfs:comment 'Boolean indicator (True/False) specifying whether cost postings to this code require additional approval workflow beyond standard posting authorization. Used for high-risk or high-value cost categories.' ;
    rdfs:domain ind:CostCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:budgetAllocationFlag rdf:type rdf:Property ;
    rdfs:label 'Budget Allocation Flag' ;
    rdfs:comment 'Boolean indicator (True/False) specifying whether this cost code can have budget allocated to it. Typically True for leaf-level codes and False for parent/rollup codes.' ;
    rdfs:domain ind:CostCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:capitalizationFlag rdf:type rdf:Property ;
    rdfs:label 'Capitalization Flag' ;
    rdfs:comment 'Boolean indicator (True/False) specifying whether costs posted to this code should be capitalized as assets on the balance sheet rather than expensed. Critical for Engineering Procurement and Construction (EPC) projects and asset-intensive developments.' ;
    rdfs:domain ind:CostCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:costCategory rdf:type rdf:Property ;
    rdfs:label 'Cost Category' ;
    rdfs:comment 'The primary classification of the cost code into major expenditure categories. Used for high-level financial reporting and Profit and Loss (P&L) analysis.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCodeDescription rdf:type rdf:Property ;
    rdfs:label 'Cost Code Description' ;
    rdfs:comment 'Detailed description of the cost code explaining the scope of work, materials, or services covered by this classification. Provides additional context beyond the name for proper cost allocation.' ;
    rdfs:domain ind:CostCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCodeLevel rdf:type rdf:Property ;
    rdfs:label 'Cost Code Level' ;
    rdfs:comment 'The hierarchical level of this cost code within the Cost Breakdown Structure (CBS). Typically ranges from 1 (top-level category) to 4 (detailed line item). Level 1 might be \'Labor\', Level 2 \'Structural Labor\', Level 3 \'Steel Erection Labor\'.' ;
    rdfs:domain ind:CostCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:costCodeName rdf:type rdf:Property ;
    rdfs:label 'Cost Code Name' ;
    rdfs:comment 'The full descriptive name of the cost code providing human-readable identification of the cost category (e.g., \'Structural Steel Erection\', \'Concrete Formwork Labor\', \'Electrical Conduit Installation\').' ;
    rdfs:domain ind:CostCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCodeStatus rdf:type rdf:Property ;
    rdfs:label 'Cost Code Status' ;
    rdfs:comment 'Current lifecycle status of the cost code. Active codes are available for budget allocation and cost posting. Inactive codes are retained for historical reporting but cannot be used for new transactions. Deprecated codes have been superseded by newer classifications.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costPostingFlag rdf:type rdf:Property ;
    rdfs:label 'Cost Posting Flag' ;
    rdfs:comment 'Boolean indicator (True/False) specifying whether actual costs can be posted directly to this cost code. Typically True for detailed codes and False for summary/rollup codes.' ;
    rdfs:domain ind:CostCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:csiDivision rdf:type rdf:Property ;
    rdfs:label 'Csi Division' ;
    rdfs:comment 'The two-digit CSI MasterFormat division number (00-49) that this cost code maps to. Provides standardized alignment with construction specifications and Bill of Quantities (BOQ) structures.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disciplineCode rdf:type rdf:Property ;
    rdfs:label 'Discipline Code' ;
    rdfs:comment 'The engineering or construction discipline associated with this cost code (e.g., \'CIVIL\', \'STRUCT\', \'MECH\', \'ELEC\', \'INST\' for Mechanical Electrical Plumbing (MEP) disciplines). Used for discipline-specific cost tracking and resource planning.' ;
    rdfs:domain ind:CostCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evmEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Evm Eligible Flag' ;
    rdfs:comment 'Boolean indicator (True/False) specifying whether costs posted to this code are included in Earned Value Management (EVM) calculations including Cost Performance Index (CPI) and Schedule Performance Index (SPI) metrics.' ;
    rdfs:domain ind:CostCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:externalReferenceCode rdf:type rdf:Property ;
    rdfs:label 'External Reference Code' ;
    rdfs:comment 'The unique identifier for this cost code in the source system (e.g., SAP S/4HANA Cost Element number, Viewpoint Vista Cost Code ID). Used for cross-system reconciliation and integration.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:glAccountCode rdf:type rdf:Property ;
    rdfs:label 'Gl Account Code' ;
    rdfs:comment 'The General Ledger (GL) account code in SAP S/4HANA Finance that this cost code maps to for financial statement reporting. Enables integration between project costing and corporate accounting.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastModifiedBy rdf:type rdf:Property ;
    rdfs:label 'Last Modified By' ;
    rdfs:comment 'The user ID or name of the person who last modified this cost code record. Used for change tracking and data governance.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentCostCode rdf:type rdf:Property ;
    rdfs:label 'Parent Cost Code' ;
    rdfs:comment 'The cost code of the parent category in the hierarchical Cost Breakdown Structure (CBS). Null for top-level cost codes. Enables roll-up reporting and hierarchical budget analysis.' ;
    rdfs:domain ind:CostCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueRecognitionMethod rdf:type rdf:Property ;
    rdfs:label 'Revenue Recognition Method' ;
    rdfs:comment 'The accounting method used for revenue recognition associated with this cost code. Percentage of completion is the most common method for construction projects under IFRS 15 and ASC 606.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardRate rdf:type rdf:Property ;
    rdfs:label 'Standard Rate' ;
    rdfs:comment 'The standard cost rate per unit of measure for this cost code. Used for budget estimation, variance analysis, and Earned Value Management (EVM) calculations. May represent labor rate per hour, material cost per unit, or equipment rate per day.' ;
    rdfs:domain ind:CostCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taxTreatmentCode rdf:type rdf:Property ;
    rdfs:label 'Tax Treatment Code' ;
    rdfs:comment 'Code indicating the tax treatment for costs posted to this cost code (e.g., \'TAXABLE\', \'EXEMPT\', \'ZERO_RATED\'). Used for Value Added Tax (VAT) and sales tax compliance in multi-jurisdiction projects.' ;
    rdfs:domain ind:CostCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wbsCompatibleFlag rdf:type rdf:Property ;
    rdfs:label 'Wbs Compatible Flag' ;
    rdfs:comment 'Boolean indicator (True/False) specifying whether this cost code can be directly linked to Work Breakdown Structure (WBS) elements in Oracle Primavera P6 and SAP S/4HANA Project Systems for integrated schedule and cost management.' ;
    rdfs:domain ind:CostCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:parentCostCenterId rdf:type rdf:Property ;
    rdfs:label 'Parent Cost Center Id' ;
    rdfs:comment 'Identifier of the parent cost center in the organizational hierarchy. Enables roll-up reporting for regional, divisional, and corporate-level P&L (Profit and Loss) and EBITDA (Earnings Before Interest Taxes Depreciation and Amortization) analysis. Nullable for top-level cost centers.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostCenter .

ind:allocationMethod rdf:type rdf:Property ;
    rdfs:label 'Allocation Method' ;
    rdfs:comment 'The methodology used to allocate or distribute costs from this cost center to other cost objects (projects, WBS (Work Breakdown Structure) elements, or profit centers). Direct charge posts costs explicitly; activity-based uses cost drivers; headcount and square footage are common overhead allocation bases; revenue-based allocates proportionally to project revenue; none indicates no allocation (terminal cost center).' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetAmount rdf:type rdf:Property ;
    rdfs:label 'Budget Amount' ;
    rdfs:comment 'The approved annual or period budget allocated to this cost center. Used for budget vs. actual variance reporting, CPI (Cost Performance Index) calculation in EVM (Earned Value Management), and financial forecasting.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetPeriod rdf:type rdf:Property ;
    rdfs:label 'Budget Period' ;
    rdfs:comment 'The time horizon for which the budget amount is defined. Annual budgets align with fiscal year planning; quarterly and monthly budgets support rolling forecasts; project lifecycle budgets span the duration of a construction project from NTP (Notice to Proceed) to handover.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessArea rdf:type rdf:Property ;
    rdfs:label 'Business Area' ;
    rdfs:comment 'The business segment or division to which this cost center is assigned (e.g., Infrastructure, Energy, Commercial, Residential). Used for segment reporting under IFRS 8 and internal divisional P&L (Profit and Loss) analysis.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controllingArea rdf:type rdf:Property ;
    rdfs:label 'Controlling Area' ;
    rdfs:comment 'The SAP S/4HANA Controlling (CO) area to which this cost center belongs. Controlling areas represent organizational units for internal management accounting and can span multiple company codes. Used for cross-company cost center reporting and consolidation.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterCategory rdf:type rdf:Property ;
    rdfs:label 'Cost Center Category' ;
    rdfs:comment 'Accounting classification of the cost center for financial treatment. Direct centers charge costs to specific projects or WBS (Work Breakdown Structure) elements; indirect centers allocate costs via overhead rates; overhead centers represent corporate G&A (General and Administrative); capitalized centers accumulate costs for asset creation; expensed centers flow directly to P&L (Profit and Loss).' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterDescription rdf:type rdf:Property ;
    rdfs:label 'Cost Center Description' ;
    rdfs:comment 'Extended free-text description providing additional context about the cost center\'s purpose, scope, and responsibilities. Used for documentation, audit trails, and onboarding new finance team members.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterGroup rdf:type rdf:Property ;
    rdfs:label 'Cost Center Group' ;
    rdfs:comment 'A user-defined grouping or classification for aggregating related cost centers in reports (e.g., all regional offices, all project cost centers for a specific client, all MEP (Mechanical Electrical and Plumbing) cost centers). Used for flexible reporting hierarchies beyond the standard organizational structure.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterName rdf:type rdf:Property ;
    rdfs:label 'Cost Center Name' ;
    rdfs:comment 'The full descriptive name of the cost center, used for human-readable identification in financial reports, dashboards, and P&L (Profit and Loss) statements.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterStatus rdf:type rdf:Property ;
    rdfs:label 'Cost Center Status' ;
    rdfs:comment 'Current lifecycle status of the cost center. Active centers accept postings; inactive centers are temporarily disabled; planned centers are approved but not yet operational; closed centers are archived and no longer accept transactions; suspended centers are on hold pending review or restructuring.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterType rdf:type rdf:Property ;
    rdfs:label 'Cost Center Type' ;
    rdfs:comment 'Classification of the cost center by its primary business function. Project cost centers track job-specific costs; regional offices track geographic operations; corporate overhead captures non-project administrative costs; shared services represent centralized functions (IT, HR, Finance); support functions include PMO (Project Management Office), procurement, and QA/QC (Quality Assurance/Quality Control); operational centers track site-level or equipment-based activities.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costElementGroup rdf:type rdf:Property ;
    rdfs:label 'Cost Element Group' ;
    rdfs:comment 'The primary cost element group or cost category that this cost center typically incurs (e.g., labor, materials, equipment, subcontractor, overhead). Used for cost structure analysis and variance reporting by cost type.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:createdByUser rdf:type rdf:Property ;
    rdfs:label 'Created By User' ;
    rdfs:comment 'The username or identifier of the system user who created this cost center record. Used for accountability, audit trails, and access control reviews.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:functionalArea rdf:type rdf:Property ;
    rdfs:label 'Functional Area' ;
    rdfs:comment 'The primary functional discipline or department this cost center supports. Used for cross-project functional cost analysis, overhead allocation, and shared-service chargeback models. [ENUM-REF-CANDIDATE: engineering|procurement|construction|quality|safety|finance|hr|it|legal|admin — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hierarchyLevel rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Level' ;
    rdfs:comment 'The depth of this cost center in the organizational hierarchy tree. Level 1 represents corporate or top-level centers; higher numbers represent nested project, site, or functional centers. Used for drill-down reporting and aggregation logic.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastModifiedByUser rdf:type rdf:Property ;
    rdfs:label 'Last Modified By User' ;
    rdfs:comment 'The username or identifier of the system user who last modified this cost center record. Used for change accountability, audit trails, and data quality investigations.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lockIndicator rdf:type rdf:Property ;
    rdfs:label 'Lock Indicator' ;
    rdfs:comment 'Indicates whether this cost center is locked for new postings. True when the cost center is under audit, pending closure, or frozen for period-end reporting. Used to enforce financial controls and prevent unauthorized transactions.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:overheadRatePercentage rdf:type rdf:Property ;
    rdfs:label 'Overhead Rate Percentage' ;
    rdfs:comment 'The standard overhead rate (as a percentage) applied to direct costs posted to this cost center. Used for indirect cost allocation, GMP (Guaranteed Maximum Price) contract pricing, and full absorption costing. Nullable for cost centers that do not apply overhead rates.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regionCode rdf:type rdf:Property ;
    rdfs:label 'Region Code' ;
    rdfs:comment 'Three-letter code representing the geographic region or country where this cost center operates (e.g., USA, GBR, ARE). Used for regional P&L (Profit and Loss) reporting, tax jurisdiction mapping, and geographic segment analysis.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validFromDate rdf:type rdf:Property ;
    rdfs:label 'Valid From Date' ;
    rdfs:comment 'The date from which this cost center becomes effective and can accept financial postings. Used for time-dependent cost center master data and period-based reporting.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:validToDate rdf:type rdf:Property ;
    rdfs:label 'Valid To Date' ;
    rdfs:comment 'The date until which this cost center remains effective. Nullable for open-ended cost centers. Used to manage cost center lifecycle, project closeout, and organizational restructuring.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:accountClass rdf:type rdf:Property ;
    rdfs:label 'Account Class' ;
    rdfs:comment 'High-level classification indicating whether the account appears on the balance sheet, Profit and Loss (P&L) statement, or is a statistical (non-financial) account.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountGroup rdf:type rdf:Property ;
    rdfs:label 'Account Group' ;
    rdfs:comment 'Grouping code used to aggregate accounts for reporting and analysis (e.g., \'Direct Construction Costs\', \'Overhead\', \'Operating Expenses\', \'Current Assets\').' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountName rdf:type rdf:Property ;
    rdfs:label 'Account Name' ;
    rdfs:comment 'The full descriptive name of the account (e.g., \'Construction Materials - Direct Costs\', \'Accounts Payable - Trade\', \'Revenue - EPC Contracts\').' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountNumber rdf:type rdf:Property ;
    rdfs:label 'Account Number' ;
    rdfs:comment 'The externally-known unique account number in the chart of accounts. Typically a 4-10 digit numeric code used in all financial postings and reports.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountShortName rdf:type rdf:Property ;
    rdfs:label 'Account Short Name' ;
    rdfs:comment 'Abbreviated name or label for the account used in condensed reports and user interfaces.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alternativeAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Alternative Account Number' ;
    rdfs:comment 'Alternative or legacy account number used for cross-reference, migration mapping, or external reporting (e.g., statutory chart of accounts).' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:balanceSheetClassification rdf:type rdf:Property ;
    rdfs:label 'Balance Sheet Classification' ;
    rdfs:comment 'Detailed balance sheet line item classification (e.g., \'Current Assets - Cash\', \'Non-Current Liabilities - Long-Term Debt\', \'Equity - Retained Earnings\'). Null for P&L accounts.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cashFlowClassification rdf:type rdf:Property ;
    rdfs:label 'Cash Flow Classification' ;
    rdfs:comment 'Classification for cash flow statement reporting: operating activities, investing activities, financing activities, or not applicable for non-cash accounts.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consolidationAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Consolidation Account Number' ;
    rdfs:comment 'The corresponding account number in the group consolidation chart of accounts. Used for mapping local entity accounts to group reporting structure.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterRequiredIndicator rdf:type rdf:Property ;
    rdfs:label 'Cost Center Required Indicator' ;
    rdfs:comment 'Flag indicating whether a cost center must be specified when posting to this account. Enforces cost allocation discipline.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:costElementCategory rdf:type rdf:Property ;
    rdfs:label 'Cost Element Category' ;
    rdfs:comment 'Classification of the cost element: primary (direct posting from FI), secondary (internal allocation), revenue, or not applicable if not a cost element.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costElementIndicator rdf:type rdf:Property ;
    rdfs:label 'Cost Element Indicator' ;
    rdfs:comment 'Flag indicating whether this account is also a cost element in the controlling (CO) module, enabling integration with project costing and Work Breakdown Structure (WBS) budgets.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:currencyType rdf:type rdf:Property ;
    rdfs:label 'Currency Type' ;
    rdfs:comment 'Indicates the currency perspective for this account: local (entity currency), group (consolidation currency), transaction (original currency), or project (project-specific currency).' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fieldStatusGroup rdf:type rdf:Property ;
    rdfs:label 'Field Status Group' ;
    rdfs:comment 'Configuration key that controls which fields are required, optional, or suppressed when posting to this account (e.g., cost center, WBS, profit center).' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineItemDisplayIndicator rdf:type rdf:Property ;
    rdfs:label 'Line Item Display Indicator' ;
    rdfs:comment 'Flag indicating whether individual line items (journal entries) are stored and can be displayed for this account. Required for detailed transaction analysis.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:openItemManagementIndicator rdf:type rdf:Property ;
    rdfs:label 'Open Item Management Indicator' ;
    rdfs:comment 'Flag indicating whether open item management is active for this account (e.g., for clearing transactions like AP/AR, advances, or accruals).' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:planningLevel rdf:type rdf:Property ;
    rdfs:label 'Planning Level' ;
    rdfs:comment 'Indicates the level at which budgeting and planning are performed for this account (e.g., \'Corporate\', \'Division\', \'Project\', \'Cost Center\').' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postingAllowedIndicator rdf:type rdf:Property ;
    rdfs:label 'Posting Allowed Indicator' ;
    rdfs:comment 'Flag indicating whether direct postings are allowed to this account. False for summary/control accounts that only receive automatic postings.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:profitAndLossClassification rdf:type rdf:Property ;
    rdfs:label 'Profit And Loss Classification' ;
    rdfs:comment 'Detailed Profit and Loss (P&L) line item classification (e.g., \'Revenue - Construction Contracts\', \'Cost of Sales - Direct Labor\', \'Operating Expenses - General & Administrative\'). Null for balance sheet accounts.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profitCenterRequiredIndicator rdf:type rdf:Property ;
    rdfs:label 'Profit Center Required Indicator' ;
    rdfs:comment 'Flag indicating whether a profit center must be specified when posting to this account. Supports segment profitability analysis.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reconciliationAccountIndicator rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Account Indicator' ;
    rdfs:comment 'Flag indicating whether this is a reconciliation account (subledger control account) for Accounts Payable (AP), Accounts Receivable (AR), or asset accounting.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:retainedEarningsAccountIndicator rdf:type rdf:Property ;
    rdfs:label 'Retained Earnings Account Indicator' ;
    rdfs:comment 'Flag indicating whether this is the retained earnings account used for year-end profit/loss transfer and equity rollforward.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sortKey rdf:type rdf:Property ;
    rdfs:label 'Sort Key' ;
    rdfs:comment 'Default sort key used for line item display and reporting (e.g., posting date, document number, reference). Controls how transactions are ordered.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxCategory rdf:type rdf:Property ;
    rdfs:label 'Tax Category' ;
    rdfs:comment 'Tax classification code indicating how this account is treated for tax purposes (e.g., \'Input Tax\', \'Output Tax\', \'Non-Taxable\', \'Exempt\'). Used for VAT/GST reporting.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:toleranceGroup rdf:type rdf:Property ;
    rdfs:label 'Tolerance Group' ;
    rdfs:comment 'Tolerance group code that defines permissible payment differences, exchange rate variances, and rounding tolerances for this account.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradingPartnerRequiredIndicator rdf:type rdf:Property ;
    rdfs:label 'Trading Partner Required Indicator' ;
    rdfs:comment 'Flag indicating whether a trading partner (intercompany entity) must be specified when posting to this account. Used for intercompany eliminations.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:wbsElementRequiredIndicator rdf:type rdf:Property ;
    rdfs:label 'Wbs Element Required Indicator' ;
    rdfs:comment 'Flag indicating whether a Work Breakdown Structure (WBS) element must be specified when posting to this account. Ensures project-level cost tracking.' ;
    rdfs:domain ind:GlAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:journalEntryId rdf:type rdf:Property ;
    rdfs:label 'Journal Entry Id' ;
    rdfs:comment 'Unique identifier for the journal entry document. Primary key for the journal entry record.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:JournalEntry .

ind:closeoutId rdf:type rdf:Property ;
    rdfs:label 'Closeout Id' ;
    rdfs:comment 'Foreign key linking to contract.closeout. Business justification: Contract closeout triggers final accounting entries: retention release, final revenue recognition true-up, bond release accruals, and warranty provision. Finance posts JEs referencing the closeout rec' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Closeout .

ind:ldAssessmentId rdf:type rdf:Property ;
    rdfs:label 'Ld Assessment Id' ;
    rdfs:comment 'Foreign key linking to contract.ld_assessment. Business justification: Liquidated damages assessments trigger GL journal entries (LD revenue recognition or contractor payable deduction). Finance teams post JEs referencing the LD assessment for audit trail, dispute resolu' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LdAssessment .

ind:retentionLedgerId rdf:type rdf:Property ;
    rdfs:label 'Retention Ledger Id' ;
    rdfs:comment 'Foreign key linking to contract.contract_retention_ledger. Business justification: Each retention movement (withholding or release) in the contract retention ledger generates a GL journal entry. Finance teams post JEs for retention events and must reference the retention ledger entr' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RetentionLedger .

ind:vendorInvoiceId rdf:type rdf:Property ;
    rdfs:label 'Vendor Invoice Id' ;
    rdfs:comment 'Foreign key linking to procurement.vendor_invoice. Business justification: AP invoice processing in construction generates GL journal entries (debit expense/asset, credit AP). Auditors and finance teams must trace journal entries back to source vendor invoices for three-way ' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VendorInvoice .

ind:assignmentField rdf:type rdf:Property ;
    rdfs:label 'Assignment Field' ;
    rdfs:comment 'Free-form assignment field used for additional sorting, grouping, or reconciliation purposes (e.g., invoice number, payment reference).' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessAreaCode rdf:type rdf:Property ;
    rdfs:label 'Business Area Code' ;
    rdfs:comment 'The business area or division for cross-company code reporting and segment analysis.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditAmount rdf:type rdf:Property ;
    rdfs:label 'Credit Amount' ;
    rdfs:comment 'The credit amount for this journal entry line in the document currency. Zero if this is a debit entry.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:debitAmount rdf:type rdf:Property ;
    rdfs:label 'Debit Amount' ;
    rdfs:comment 'The debit amount for this journal entry line in the document currency. Zero if this is a credit entry.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:documentDate rdf:type rdf:Property ;
    rdfs:label 'Document Date' ;
    rdfs:comment 'The date on the source document or invoice that originated this journal entry. May differ from posting date for period-end adjustments.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:documentNumber rdf:type rdf:Property ;
    rdfs:label 'Document Number' ;
    rdfs:comment 'The externally-known unique document number assigned to this journal entry in the general ledger system. Used for audit trail and reference in financial reports.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentType rdf:type rdf:Property ;
    rdfs:label 'Document Type' ;
    rdfs:comment 'Classification of the journal entry document type. SA=Standard Accrual, AA=Asset Accounting, KR=Vendor Invoice, DR=Customer Invoice, AB=Accounting Document, RV=Reversal Document.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exchangeRate rdf:type rdf:Property ;
    rdfs:label 'Exchange Rate' ;
    rdfs:comment 'The foreign exchange rate used to convert document currency amounts to local currency. Applicable for multi-currency transactions.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exchangeRateType rdf:type rdf:Property ;
    rdfs:label 'Exchange Rate Type' ;
    rdfs:comment 'The type of exchange rate used for currency conversion. Spot=transaction date rate, Average=period average, Budget=budgeted rate, Closing=period-end rate.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fiscalPeriod rdf:type rdf:Property ;
    rdfs:label 'Fiscal Period' ;
    rdfs:comment 'The fiscal period (month) within the fiscal year to which this journal entry is assigned. Typically 1-12 for monthly periods, or 13-16 for special closing periods.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fiscalYear rdf:type rdf:Property ;
    rdfs:label 'Fiscal Year' ;
    rdfs:comment 'The fiscal year to which this journal entry is assigned for financial reporting purposes.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:headerText rdf:type rdf:Property ;
    rdfs:label 'Header Text' ;
    rdfs:comment 'Free-form descriptive text at the document header level explaining the purpose or context of the journal entry.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:intercompanyIndicator rdf:type rdf:Property ;
    rdfs:label 'Intercompany Indicator' ;
    rdfs:comment 'Flag indicating whether this journal entry represents an intercompany transaction requiring elimination during consolidation.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lineItemText rdf:type rdf:Property ;
    rdfs:label 'Line Item Text' ;
    rdfs:comment 'Free-form descriptive text at the line item level providing additional context for this specific posting.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:localCurrencyCreditAmount rdf:type rdf:Property ;
    rdfs:label 'Local Currency Credit Amount' ;
    rdfs:comment 'The credit amount converted to the local currency of the company code for statutory reporting.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:localCurrencyDebitAmount rdf:type rdf:Property ;
    rdfs:label 'Local Currency Debit Amount' ;
    rdfs:comment 'The debit amount converted to the local currency of the company code for statutory reporting.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:percentageOfCompletion rdf:type rdf:Property ;
    rdfs:label 'Percentage Of Completion' ;
    rdfs:comment 'The percentage of completion used for revenue recognition entries under IFRS 15. Represents the stage of project completion at the time of this journal entry.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:postedBy rdf:type rdf:Property ;
    rdfs:label 'Posted By' ;
    rdfs:comment 'The user ID or name of the person who posted this journal entry to the general ledger, finalizing the transaction.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Posted Timestamp' ;
    rdfs:comment 'The date and time when this journal entry was posted to the general ledger. Represents the moment the entry became final and immutable.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:postingDate rdf:type rdf:Property ;
    rdfs:label 'Posting Date' ;
    rdfs:comment 'The date on which the journal entry is posted to the general ledger. This is the principal business event timestamp for financial period assignment and reporting.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:postingKey rdf:type rdf:Property ;
    rdfs:label 'Posting Key' ;
    rdfs:comment 'Two-digit code that controls the type of posting (debit or credit) and the account type (GL, customer, vendor, asset). Standard SAP posting keys include 40=GL Debit, 50=GL Credit.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referenceDocument rdf:type rdf:Property ;
    rdfs:label 'Reference Document' ;
    rdfs:comment 'External reference number or identifier linking this journal entry to source documents such as invoices, purchase orders, or contracts.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversalIndicator rdf:type rdf:Property ;
    rdfs:label 'Reversal Indicator' ;
    rdfs:comment 'Flag indicating whether this journal entry is a reversal of a previous entry. True if this is a reversal document.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reversalReasonCode rdf:type rdf:Property ;
    rdfs:label 'Reversal Reason Code' ;
    rdfs:comment 'Code indicating the reason for reversal. 01=Error Correction, 02=Period-End Adjustment, 03=Accrual Reversal, 04=Reclassification, 05=Other.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversedDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Reversed Document Number' ;
    rdfs:comment 'The document number of the original journal entry that this entry reverses. Populated only when reversal_indicator is true.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxAmount rdf:type rdf:Property ;
    rdfs:label 'Tax Amount' ;
    rdfs:comment 'The calculated tax amount for this journal entry line in the document currency.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taxCode rdf:type rdf:Property ;
    rdfs:label 'Tax Code' ;
    rdfs:comment 'The tax code applied to this journal entry line, determining the tax rate and tax account for automatic tax calculation.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradingPartnerCode rdf:type rdf:Property ;
    rdfs:label 'Trading Partner Code' ;
    rdfs:comment 'The trading partner company code for intercompany transactions, used for consolidation and elimination entries.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:journalEntryLineId rdf:type rdf:Property ;
    rdfs:label 'Journal Entry Line Id' ;
    rdfs:comment 'Unique identifier for the journal entry line item. Primary key for this entity representing one leg of a double-entry accounting transaction.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:amountLocalCurrency rdf:type rdf:Property ;
    rdfs:label 'Amount Local Currency' ;
    rdfs:comment 'The monetary amount of this journal entry line in the local reporting currency of the entity. Used for financial statement preparation and local statutory reporting.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:amountTransactionCurrency rdf:type rdf:Property ;
    rdfs:label 'Amount Transaction Currency' ;
    rdfs:comment 'The monetary amount of this journal entry line in the original transaction currency, before any currency conversion. Enables multi-currency accounting and foreign exchange analysis.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assignmentReference rdf:type rdf:Property ;
    rdfs:label 'Assignment Reference' ;
    rdfs:comment 'Additional reference field used for payment allocation, clearing, and reconciliation. Often contains check numbers, wire transfer references, or clearing document numbers.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baselineAmount rdf:type rdf:Property ;
    rdfs:label 'Baseline Amount' ;
    rdfs:comment 'The base amount before tax and adjustments, used for payment terms calculation and cash discount determination.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:clearingDate rdf:type rdf:Property ;
    rdfs:label 'Clearing Date' ;
    rdfs:comment 'The date on which this line item was cleared (matched with a payment or offsetting entry). Null if the item remains open.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:clearingDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Clearing Document Number' ;
    rdfs:comment 'The document number of the clearing transaction that closed this line item. Used for payment reconciliation and audit trail.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:debitCreditIndicator rdf:type rdf:Property ;
    rdfs:label 'Debit Credit Indicator' ;
    rdfs:comment 'Indicates whether this line is a debit (D) or credit (C) entry in the double-entry accounting system.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dueDate rdf:type rdf:Property ;
    rdfs:label 'Due Date' ;
    rdfs:comment 'The payment due date for this line item, calculated based on payment terms and document date. Critical for cash flow management and aging reports.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:entryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Entry Timestamp' ;
    rdfs:comment 'The system timestamp when this journal entry line was created in the ERP system. Used for audit trail and transaction sequencing.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lineNumber rdf:type rdf:Property ;
    rdfs:label 'Line Number' ;
    rdfs:comment 'Sequential line number within the journal entry, establishing the order of debit and credit legs within the transaction.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:localCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Local Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the local reporting currency (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentTermsCode rdf:type rdf:Property ;
    rdfs:label 'Payment Terms Code' ;
    rdfs:comment 'The payment terms code applicable to this line item, defining due dates and cash discount conditions. Used for cash flow forecasting and AP/AR aging.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referenceDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Reference Document Number' ;
    rdfs:comment 'The source document number (invoice number, PO number, payment reference) that originated this journal entry line. Provides audit trail to source transaction.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referenceDocumentType rdf:type rdf:Property ;
    rdfs:label 'Reference Document Type' ;
    rdfs:comment 'The type of source document that originated this journal entry line. Classifies the transaction origin for audit and reconciliation purposes. [ENUM-REF-CANDIDATE: invoice|purchase_order|payment|receipt|adjustment|accrual|reversal — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Transaction Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the original transaction currency.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:previousBudgetProjectBudgetId rdf:type rdf:Property ;
    rdfs:label 'Previous Budget Project Budget Id' ;
    rdfs:comment 'Reference to the prior version of this budget record if this is a revision. Enables historical tracking and variance analysis across budget versions.' ;
    rdfs:domain ind:ProjectBudget ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProjectBudget .

ind:approvedChangeOrderAmount rdf:type rdf:Property ;
    rdfs:label 'Approved Change Order Amount' ;
    rdfs:comment 'Cumulative sum of all approved change order adjustments to the budget. Includes client-approved scope changes and contract modifications.' ;
    rdfs:domain ind:ProjectBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetCode rdf:type rdf:Property ;
    rdfs:label 'Budget Code' ;
    rdfs:comment 'Unique business identifier for the budget record. Used for external reporting and cross-system reference.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetName rdf:type rdf:Property ;
    rdfs:label 'Budget Name' ;
    rdfs:comment 'Descriptive name of the budget line item or WBS budget element. Human-readable identifier for reporting.' ;
    rdfs:domain ind:ProjectBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetNotes rdf:type rdf:Property ;
    rdfs:label 'Budget Notes' ;
    rdfs:comment 'Free-text notes and comments about this budget record. Captures assumptions, constraints, change justifications, and other contextual information.' ;
    rdfs:domain ind:ProjectBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetOwner rdf:type rdf:Property ;
    rdfs:label 'Budget Owner' ;
    rdfs:comment 'Name or identifier of the project manager or cost manager responsible for managing this budget. Accountable for budget performance.' ;
    rdfs:domain ind:ProjectBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Budget Period End Date' ;
    rdfs:comment 'End date of the budget period this record applies to. Defines the time window for budget consumption and variance analysis.' ;
    rdfs:domain ind:ProjectBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:budgetPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Budget Period Start Date' ;
    rdfs:comment 'Start date of the budget period this record applies to. Used for time-phased budget tracking and cash flow forecasting.' ;
    rdfs:domain ind:ProjectBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:budgetStatus rdf:type rdf:Property ;
    rdfs:label 'Budget Status' ;
    rdfs:comment 'Current lifecycle status of the budget record. Approved budgets are baselined; active budgets are in use; frozen budgets are locked for change control.' ;
    rdfs:domain ind:ProjectBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetType rdf:type rdf:Property ;
    rdfs:label 'Budget Type' ;
    rdfs:comment 'Classification of the budget record. Contract budget represents client-approved amounts; internal budget represents target cost; contingency and management reserve represent risk buffers.' ;
    rdfs:domain ind:ProjectBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Budget Unit Of Measure' ;
    rdfs:comment 'Unit of measure for quantity-based budgets (e.g., cubic meters for concrete, linear meters for piping, hours for labor). Used for unit rate calculations.' ;
    rdfs:domain ind:ProjectBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetVarianceAmount rdf:type rdf:Property ;
    rdfs:label 'Budget Variance Amount' ;
    rdfs:comment 'Difference between current approved budget and actual costs. Positive values indicate under-budget; negative values indicate over-budget.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contingencyReserveAmount rdf:type rdf:Property ;
    rdfs:label 'Contingency Reserve Amount' ;
    rdfs:comment 'Budget allocation for identified risks and known-unknowns. Managed by the project manager and released through change control process.' ;
    rdfs:domain ind:ProjectBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contractLineItemReference rdf:type rdf:Property ;
    rdfs:label 'Contract Line Item Reference' ;
    rdfs:comment 'Reference to the specific contract line item or BOQ item this budget corresponds to. Links budget to contractual scope and payment terms.' ;
    rdfs:domain ind:ProjectBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentApprovedBudget rdf:type rdf:Property ;
    rdfs:label 'Current Approved Budget' ;
    rdfs:comment 'The current total approved budget including original budget plus all approved change orders. This is the active baseline for Earned Value Management (EVM) calculations.' ;
    rdfs:domain ind:ProjectBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:forecastAtCompletion rdf:type rdf:Property ;
    rdfs:label 'Forecast At Completion' ;
    rdfs:comment 'Projected total cost at project completion based on current performance trends. Used for variance analysis and early warning of budget overruns.' ;
    rdfs:domain ind:ProjectBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isBaselineBudget rdf:type rdf:Property ;
    rdfs:label 'Is Baseline Budget' ;
    rdfs:comment 'Indicates whether this budget record represents the approved performance measurement baseline for EVM. True for baseline budgets used in BCWS calculations.' ;
    rdfs:domain ind:ProjectBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reversedTransactionJobCostTransactionId rdf:type rdf:Property ;
    rdfs:label 'Reversed Transaction Job Cost Transaction Id' ;
    rdfs:comment 'Reference to the original job cost transaction that this record reverses or corrects. Null for original transactions.' ;
    rdfs:domain ind:JobCostTransaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:JobCostTransaction .

ind:baseCurrencyCost rdf:type rdf:Property ;
    rdfs:label 'Base Currency Cost' ;
    rdfs:comment 'The total cost converted to the project or corporate base currency for consolidated financial reporting and P&L analysis.' ;
    rdfs:domain ind:JobCostTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:billableFlag rdf:type rdf:Property ;
    rdfs:label 'Billable Flag' ;
    rdfs:comment 'Indicates whether this cost is billable to the client (true) or non-billable internal cost (false). Used for progress billing and revenue recognition.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:billedFlag rdf:type rdf:Property ;
    rdfs:label 'Billed Flag' ;
    rdfs:comment 'Indicates whether this cost has been included in a client invoice (true) or remains unbilled (false). Used for work-in-progress and revenue recognition tracking.' ;
    rdfs:domain ind:JobCostTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jobCostTransactionDescription rdf:type rdf:Property ;
    rdfs:label 'Job Cost Transaction Description' ;
    rdfs:comment 'Free-text description of the cost transaction providing additional context about the work performed, materials used, or services rendered.' ;
    rdfs:domain ind:JobCostTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantity rdf:type rdf:Property ;
    rdfs:label 'Quantity' ;
    rdfs:comment 'The quantity of the resource consumed or work performed (e.g., labor hours, material units, equipment hours). Used for unit cost analysis.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reversalFlag rdf:type rdf:Property ;
    rdfs:label 'Reversal Flag' ;
    rdfs:comment 'Indicates whether this transaction is a reversal or correction of a previously posted cost (true) or an original transaction (false).' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sourceTransactionReference rdf:type rdf:Property ;
    rdfs:label 'Source Transaction Reference' ;
    rdfs:comment 'The unique transaction identifier in the source system. Enables traceability back to the originating record for audit and reconciliation.' ;
    rdfs:domain ind:JobCostTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionDate rdf:type rdf:Property ;
    rdfs:label 'Transaction Date' ;
    rdfs:comment 'The business date when the cost was incurred or the work was performed. Used for period-based cost reporting and EVM actual cost (ACWP) calculations.' ;
    rdfs:domain ind:JobCostTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:progressBillingId rdf:type rdf:Property ;
    rdfs:label 'Progress Billing Id' ;
    rdfs:comment 'Unique identifier for the progress billing record. Primary key for the progress billing entity.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProgressBilling .

ind:certifyingContactId rdf:type rdf:Property ;
    rdfs:label 'Certifying Contact Id' ;
    rdfs:comment 'Foreign key linking to client.contact. Business justification: Under FIDIC/NEC contracts, a named client contact (Engineer or Employer\'s Representative) certifies each payment application. Linking to client.contact enables certification audit trails and contact-l' ;
    rdfs:domain ind:ProgressBilling ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Contact .

ind:paymentCertificateId rdf:type rdf:Property ;
    rdfs:label 'Payment Certificate Id' ;
    rdfs:comment 'Foreign key linking to contract.payment_certificate. Business justification: Progress billing (client-facing invoice) is directly derived from the engineer\'s payment certificate. Finance teams must link each progress billing to the certifying payment certificate for revenue re' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PaymentCertificate .

ind:agingBucket rdf:type rdf:Property ;
    rdfs:label 'Aging Bucket' ;
    rdfs:comment 'Accounts receivable aging classification based on days past due: current (not yet due), 1-30 days, 31-60 days, 61-90 days, over 90 days.' ;
    rdfs:domain ind:ProgressBilling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amountReceived rdf:type rdf:Property ;
    rdfs:label 'Amount Received' ;
    rdfs:comment 'Total amount received from the client against this invoice, including partial payments.' ;
    rdfs:domain ind:ProgressBilling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:billingPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Billing Period End Date' ;
    rdfs:comment 'End date of the billing period covered by this progress billing claim.' ;
    rdfs:domain ind:ProgressBilling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:billingPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Billing Period Start Date' ;
    rdfs:comment 'Start date of the billing period covered by this progress billing claim.' ;
    rdfs:domain ind:ProgressBilling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:certificationDate rdf:type rdf:Property ;
    rdfs:label 'Certification Date' ;
    rdfs:comment 'Date when the payment certificate was certified or approved by the engineer or client representative.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clientReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Client Reference Number' ;
    rdfs:comment 'Client-provided reference number or purchase order number associated with this payment application.' ;
    rdfs:domain ind:ProgressBilling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentPeriodClaim rdf:type rdf:Property ;
    rdfs:label 'Current Period Claim' ;
    rdfs:comment 'Amount claimed in the current billing period, calculated as work_completed_to_date minus previous_amount_billed.' ;
    rdfs:domain ind:ProgressBilling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cutoffDate rdf:type rdf:Property ;
    rdfs:label 'Cutoff Date' ;
    rdfs:comment 'The measurement cutoff date for work completed and eligible for billing in this payment application.' ;
    rdfs:domain ind:ProgressBilling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:grossAmountDue rdf:type rdf:Property ;
    rdfs:label 'Gross Amount Due' ;
    rdfs:comment 'Gross amount due before retention and taxes, equal to current_period_claim.' ;
    rdfs:domain ind:ProgressBilling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:invoiceDate rdf:type rdf:Property ;
    rdfs:label 'Invoice Date' ;
    rdfs:comment 'Date when the formal AR invoice was issued to the client.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:invoiceDueDate rdf:type rdf:Property ;
    rdfs:label 'Invoice Due Date' ;
    rdfs:comment 'Payment due date for the invoice, typically calculated as invoice_date plus contract payment terms (e.g., Net 30, Net 60).' ;
    rdfs:domain ind:ProgressBilling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:materialsStoredOnSite rdf:type rdf:Property ;
    rdfs:label 'Materials Stored On Site' ;
    rdfs:comment 'Value of materials delivered and stored on-site but not yet incorporated into the work, eligible for billing per contract terms.' ;
    rdfs:domain ind:ProgressBilling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netAmountDue rdf:type rdf:Property ;
    rdfs:label 'Net Amount Due' ;
    rdfs:comment 'Net amount due after deducting retention, calculated as gross_amount_due minus retention_amount.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:outstandingBalance rdf:type rdf:Property ;
    rdfs:label 'Outstanding Balance' ;
    rdfs:comment 'Remaining unpaid balance on this invoice, calculated as net_amount_due plus tax_amount minus amount_received.' ;
    rdfs:domain ind:ProgressBilling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentApplicationNumber rdf:type rdf:Property ;
    rdfs:label 'Payment Application Number' ;
    rdfs:comment 'Unique business identifier for the payment application (e.g., AIA G702 application number or FIDIC payment certificate number).' ;
    rdfs:domain ind:ProgressBilling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentCertificateType rdf:type rdf:Property ;
    rdfs:label 'Payment Certificate Type' ;
    rdfs:comment 'Type of payment certificate being issued: interim (monthly progress), final (project completion), advance (mobilization), milestone (specific deliverable), retention_release (DLP completion), or variation (change order).' ;
    rdfs:domain ind:ProgressBilling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentReceivedDate rdf:type rdf:Property ;
    rdfs:label 'Payment Received Date' ;
    rdfs:comment 'Date when payment was received from the client for this invoice.' ;
    rdfs:domain ind:ProgressBilling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentStatus rdf:type rdf:Property ;
    rdfs:label 'Payment Status' ;
    rdfs:comment 'Current lifecycle status of the progress billing: draft (being prepared), submitted (sent to client), under_review (client reviewing), certified (approved by engineer), invoiced (AR invoice raised), partially_paid (partial payment received), paid (fully paid), overdue (past due date), disputed (under dispute), cancelled (voided). [ENUM-REF-CANDIDATE: draft|submitted|under_review|certified|invoiced|partially_paid|paid|overdue|disputed|cancelled — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:percentageComplete rdf:type rdf:Property ;
    rdfs:label 'Percentage Complete' ;
    rdfs:comment 'Percentage of work completed for the billing line item as of the cutoff date, used for percentage-of-completion revenue recognition.' ;
    rdfs:domain ind:ProgressBilling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:previousAmountBilled rdf:type rdf:Property ;
    rdfs:label 'Previous Amount Billed' ;
    rdfs:comment 'Cumulative amount billed in all prior payment applications, used to calculate the current period claim.' ;
    rdfs:domain ind:ProgressBilling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:retentionAmount rdf:type rdf:Property ;
    rdfs:label 'Retention Amount' ;
    rdfs:comment 'Monetary value of retention withheld from the current period claim, calculated as current_period_claim multiplied by retention_percentage.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scheduledValue rdf:type rdf:Property ;
    rdfs:label 'Scheduled Value' ;
    rdfs:comment 'Total contract value or scheduled value for the work scope covered by this billing line (from BOQ or contract schedule).' ;
    rdfs:domain ind:ProgressBilling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:submissionDate rdf:type rdf:Property ;
    rdfs:label 'Submission Date' ;
    rdfs:comment 'Date when the payment application was submitted to the client or engineer for review and certification.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxRate rdf:type rdf:Property ;
    rdfs:label 'Tax Rate' ;
    rdfs:comment 'Tax rate percentage applied to calculate the tax amount (e.g., VAT or GST rate).' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:workCompletedToDate rdf:type rdf:Property ;
    rdfs:label 'Work Completed To Date' ;
    rdfs:comment 'Cumulative value of work completed from project start through the current billing period cutoff date.' ;
    rdfs:domain ind:ProgressBilling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revenueRecognitionEntryId rdf:type rdf:Property ;
    rdfs:label 'Revenue Recognition Entry Id' ;
    rdfs:comment 'Unique identifier for the revenue recognition entry record.' ;
    rdfs:domain ind:RevenueRecognitionEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:adjustmentReason rdf:type rdf:Property ;
    rdfs:label 'Adjustment Reason' ;
    rdfs:comment 'Explanation for any adjustment made to a previously posted revenue recognition entry, including changes to cost estimates, contract modifications, or error corrections.' ;
    rdfs:domain ind:RevenueRecognitionEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditorReviewedFlag rdf:type rdf:Property ;
    rdfs:label 'Auditor Reviewed Flag' ;
    rdfs:comment 'Indicates whether this revenue recognition entry has been reviewed and validated by internal or external auditors as part of financial statement audit procedures.' ;
    rdfs:domain ind:RevenueRecognitionEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:billedToDate rdf:type rdf:Property ;
    rdfs:label 'Billed To Date' ;
    rdfs:comment 'Cumulative amount billed to the client from contract inception through the end of the current recognition period, based on progress billing milestones or payment schedules.' ;
    rdfs:domain ind:RevenueRecognitionEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:changeOrderValueIncluded rdf:type rdf:Property ;
    rdfs:label 'Change Order Value Included' ;
    rdfs:comment 'Cumulative value of approved change orders included in the contract value for this recognition period. Change orders modify the transaction price and must be accounted for under IFRS 15 / ASC 606 contract modification guidance.' ;
    rdfs:domain ind:RevenueRecognitionEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contractCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Contract Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the contract value and all monetary amounts in this entry.' ;
    rdfs:domain ind:RevenueRecognitionEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cumulativeCostsIncurred rdf:type rdf:Property ;
    rdfs:label 'Cumulative Costs Incurred' ;
    rdfs:comment 'Total costs incurred to date on the contract, including direct labor, materials, equipment, subcontractor costs, and allocable indirect costs. Used as the numerator in the cost-to-cost percentage-of-completion calculation.' ;
    rdfs:domain ind:RevenueRecognitionEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deferredRevenue rdf:type rdf:Property ;
    rdfs:label 'Deferred Revenue' ;
    rdfs:comment 'Amount billed to the client but not yet recognized as revenue (contract liability), representing advance payments or over-billing relative to work performed. Calculated as billed to date minus revenue recognized to date when billed exceeds recognized revenue.' ;
    rdfs:domain ind:RevenueRecognitionEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedGrossProfitAtCompletion rdf:type rdf:Property ;
    rdfs:label 'Estimated Gross Profit At Completion' ;
    rdfs:comment 'Forecasted total gross profit for the contract at completion, calculated as contract value minus estimated total costs. Used for forward-looking profitability analysis and loss recognition.' ;
    rdfs:domain ind:RevenueRecognitionEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedTotalCosts rdf:type rdf:Property ;
    rdfs:label 'Estimated Total Costs' ;
    rdfs:comment 'The current estimate of total costs expected to complete the contract, including all direct and indirect costs. Used as the denominator in the cost-to-cost percentage-of-completion calculation. Updated periodically based on project forecasts.' ;
    rdfs:domain ind:RevenueRecognitionEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:grossProfitPercentage rdf:type rdf:Property ;
    rdfs:label 'Gross Profit Percentage' ;
    rdfs:comment 'Gross profit margin to date expressed as a percentage of revenue recognized to date, calculated as (gross profit to date / revenue recognized to date) * 100.' ;
    rdfs:domain ind:RevenueRecognitionEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:grossProfitToDate rdf:type rdf:Property ;
    rdfs:label 'Gross Profit To Date' ;
    rdfs:comment 'Cumulative gross profit recognized on the contract to date, calculated as revenue recognized to date minus cumulative costs incurred.' ;
    rdfs:domain ind:RevenueRecognitionEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lossProvision rdf:type rdf:Property ;
    rdfs:label 'Loss Provision' ;
    rdfs:comment 'Provision for anticipated loss on the contract if estimated total costs exceed contract value. Under IFRS 15 / ASC 606, losses on onerous contracts must be recognized immediately in full.' ;
    rdfs:domain ind:RevenueRecognitionEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:performanceObligationDescription rdf:type rdf:Property ;
    rdfs:label 'Performance Obligation Description' ;
    rdfs:comment 'Description of the distinct performance obligation(s) within the contract for which revenue is being recognized, as defined under IFRS 15 / ASC 606.' ;
    rdfs:domain ind:RevenueRecognitionEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorPeriodAdjustmentFlag rdf:type rdf:Property ;
    rdfs:label 'Prior Period Adjustment Flag' ;
    rdfs:comment 'Indicates whether this entry represents a correction or adjustment to revenue recognized in a prior accounting period, requiring disclosure under IFRS / GAAP.' ;
    rdfs:domain ind:RevenueRecognitionEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recognitionDate rdf:type rdf:Property ;
    rdfs:label 'Recognition Date' ;
    rdfs:comment 'The specific date on which the revenue recognition entry was recorded in the financial system.' ;
    rdfs:domain ind:RevenueRecognitionEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:recognitionMethod rdf:type rdf:Property ;
    rdfs:label 'Recognition Method' ;
    rdfs:comment 'The method used to measure progress toward complete satisfaction of the performance obligation. Cost-to-cost is the primary method for construction contracts, but other methods may be used when appropriate.' ;
    rdfs:domain ind:RevenueRecognitionEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recognitionPeriod rdf:type rdf:Property ;
    rdfs:label 'Recognition Period' ;
    rdfs:comment 'The accounting period (YYYY-MM format) for which revenue is being recognized under the percentage-of-completion method.' ;
    rdfs:domain ind:RevenueRecognitionEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retentionHeldByClient rdf:type rdf:Property ;
    rdfs:label 'Retention Held By Client' ;
    rdfs:comment 'Cumulative retention amount withheld by the client from progress billings, typically released upon contract completion or after the Defects Liability Period (DLP). Represents a contract asset under IFRS 15.' ;
    rdfs:domain ind:RevenueRecognitionEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revenueRecognitionStatus rdf:type rdf:Property ;
    rdfs:label 'Revenue Recognition Status' ;
    rdfs:comment 'Current status of the revenue recognition entry in the financial workflow. Draft entries are pending review; posted entries are committed to the GL; adjusted entries have been modified; reversed entries have been backed out; final entries are locked after contract completion.' ;
    rdfs:domain ind:RevenueRecognitionEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueRecognizedInPeriod rdf:type rdf:Property ;
    rdfs:label 'Revenue Recognized In Period' ;
    rdfs:comment 'Revenue recognized in the current accounting period, calculated as the difference between revenue recognized to date and revenue recognized in all prior periods. This is the amount posted to the General Ledger (GL) for the period.' ;
    rdfs:domain ind:RevenueRecognitionEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revenueRecognizedToDate rdf:type rdf:Property ;
    rdfs:label 'Revenue Recognized To Date' ;
    rdfs:comment 'Cumulative revenue recognized from contract inception through the end of the current recognition period, calculated as contract value multiplied by completion percentage.' ;
    rdfs:domain ind:RevenueRecognitionEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sourceDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Source Document Number' ;
    rdfs:comment 'The document number or reference identifier in the source system (e.g., SAP RAR document number) that generated this revenue recognition entry.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unbilledRevenue rdf:type rdf:Property ;
    rdfs:label 'Unbilled Revenue' ;
    rdfs:comment 'Revenue recognized but not yet billed to the client (contract asset), calculated as revenue recognized to date minus billed to date. A positive value indicates work performed ahead of billing; a negative value indicates over-billing (contract liability).' ;
    rdfs:domain ind:RevenueRecognitionEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvedDate rdf:type rdf:Property ;
    rdfs:label 'Approved Date' ;
    rdfs:comment 'The date the invoice was approved for payment. Used for workflow metrics and audit trail.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:discountAmount rdf:type rdf:Property ;
    rdfs:label 'Discount Amount' ;
    rdfs:comment 'Any early payment discount or negotiated discount applied to the invoice. Reduces the net payable amount.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:disputeFlag rdf:type rdf:Property ;
    rdfs:label 'Dispute Flag' ;
    rdfs:comment 'Boolean indicator of whether the invoice is currently under dispute. True if there is a disagreement on invoice accuracy, pricing, or delivery that must be resolved before payment.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:grossAmount rdf:type rdf:Property ;
    rdfs:label 'Gross Amount' ;
    rdfs:comment 'The total invoice amount before tax, retention, and other adjustments. Represents the base value of goods or services invoiced.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:holdFlag rdf:type rdf:Property ;
    rdfs:label 'Hold Flag' ;
    rdfs:comment 'Boolean indicator of whether the invoice is on hold pending additional information or resolution of issues. True if payment is temporarily suspended.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:holdReason rdf:type rdf:Property ;
    rdfs:label 'Hold Reason' ;
    rdfs:comment 'Free-text description of the reason the invoice is on hold. May include missing documentation, pending approvals, or compliance issues.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceDescription rdf:type rdf:Property ;
    rdfs:label 'Invoice Description' ;
    rdfs:comment 'Free-text description of the goods or services covered by this invoice. Provides context for the invoice line items and supports audit and review processes.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceStatus rdf:type rdf:Property ;
    rdfs:label 'Invoice Status' ;
    rdfs:comment 'Current lifecycle status of the invoice in the accounts payable workflow. Tracks progression from receipt through approval to payment or dispute resolution. [ENUM-REF-CANDIDATE: received|pending_approval|approved|disputed|on_hold|paid|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceType rdf:type rdf:Property ;
    rdfs:label 'Invoice Type' ;
    rdfs:comment 'Classification of the invoice type. Standard invoices are for completed deliveries; progress claims are for work-in-progress per percentage of completion; credit/debit notes are adjustments; prepayments are advance payments; final invoices close out a contract.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netPayableAmount rdf:type rdf:Property ;
    rdfs:label 'Net Payable Amount' ;
    rdfs:comment 'The final amount payable to the vendor after applying tax, retention, discounts, and other adjustments. This is the amount that will be paid or has been paid.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentDate rdf:type rdf:Property ;
    rdfs:label 'Payment Date' ;
    rdfs:comment 'The actual date payment was made to the vendor or subcontractor. Null if invoice is unpaid. Used for cash flow analysis and Days Payable Outstanding (DPO) calculation.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentMethod rdf:type rdf:Property ;
    rdfs:label 'Payment Method' ;
    rdfs:comment 'The payment instrument or method used to pay this invoice (e.g., wire transfer, check, ACH, credit card, letter of credit). Used for cash management and reconciliation.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Payment Reference Number' ;
    rdfs:comment 'The unique reference number or transaction ID for the payment made against this invoice. Used for bank reconciliation and audit trail.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivedDate rdf:type rdf:Property ;
    rdfs:label 'Received Date' ;
    rdfs:comment 'The date the invoice was received and recorded in the accounts payable system. Used for internal processing metrics and aging analysis.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:threeWayMatchStatus rdf:type rdf:Property ;
    rdfs:label 'Three Way Match Status' ;
    rdfs:comment 'Status of the three-way match validation between Purchase Order (PO), Goods Receipt (GR), and Invoice. Ensures invoice accuracy and prevents overpayment.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentRecordId rdf:type rdf:Property ;
    rdfs:label 'Payment Record Id' ;
    rdfs:comment 'Unique identifier for the payment transaction record. Primary key for the payment_record product.' ;
    rdfs:domain ind:PaymentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bondGuaranteeId rdf:type rdf:Property ;
    rdfs:label 'Bond Guarantee Id' ;
    rdfs:comment 'Foreign key linking to contract.bond_guarantee. Business justification: Bond premium payments and guarantee fee disbursements are recorded as payment records in finance. Finance teams link payment records to the bond/guarantee instrument for bond cost tracking, expiry man' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BondGuarantee .

ind:invoiceAccountsPayableInvoiceId rdf:type rdf:Property ;
    rdfs:label 'Invoice Accounts Payable Invoice Id' ;
    rdfs:comment 'Foreign key linking to finance.invoice. Business justification: Payments are applied to a specific AP invoice; FK provides direct linkage for reconciliation.' ;
    rdfs:domain ind:PaymentRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Invoice .

ind:subcontractPaymentId rdf:type rdf:Property ;
    rdfs:label 'Subcontract Payment Id' ;
    rdfs:comment 'Foreign key linking to contract.subcontract_payment. Business justification: Subcontractor payment reconciliation requires linking the finance payment_record (actual bank disbursement) to the contractual subcontract_payment event. Finance teams use this for subcontractor AP cl' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SubcontractPayment .

ind:advancePaymentFlag rdf:type rdf:Property ;
    rdfs:label 'Advance Payment Flag' ;
    rdfs:comment 'Indicates whether this payment is an advance payment made before work completion or goods delivery.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:bankCharges rdf:type rdf:Property ;
    rdfs:label 'Bank Charges' ;
    rdfs:comment 'Bank fees and transaction charges incurred for processing the payment, may be borne by payer or payee.' ;
    rdfs:domain ind:PaymentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bankReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Bank Reference Number' ;
    rdfs:comment 'Unique reference number assigned by the bank for the payment transaction, used for bank reconciliation and clearing.' ;
    rdfs:domain ind:PaymentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clearingStatus rdf:type rdf:Property ;
    rdfs:label 'Clearing Status' ;
    rdfs:comment 'Status of the payment in the bank clearing process, indicating whether funds have been successfully transferred.' ;
    rdfs:domain ind:PaymentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:functionalCurrencyAmount rdf:type rdf:Property ;
    rdfs:label 'Functional Currency Amount' ;
    rdfs:comment 'Payment amount converted to the company\'s functional currency using the exchange rate, for consolidated financial reporting.' ;
    rdfs:domain ind:PaymentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:invoiceReferences rdf:type rdf:Property ;
    rdfs:label 'Invoice References' ;
    rdfs:comment 'Comma-separated list of invoice document numbers that are cleared or partially cleared by this payment transaction.' ;
    rdfs:domain ind:PaymentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netPaymentAmount rdf:type rdf:Property ;
    rdfs:label 'Net Payment Amount' ;
    rdfs:comment 'The final net amount paid or received after all adjustments, discounts, withholding taxes, and bank charges.' ;
    rdfs:domain ind:PaymentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:partialPaymentFlag rdf:type rdf:Property ;
    rdfs:label 'Partial Payment Flag' ;
    rdfs:comment 'Indicates whether this is a partial payment that does not fully settle the referenced invoices or obligations.' ;
    rdfs:domain ind:PaymentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:paymentApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Payment Approval Status' ;
    rdfs:comment 'Approval workflow status for the payment, indicating whether it has been authorized by the appropriate authority levels.' ;
    rdfs:domain ind:PaymentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentChannel rdf:type rdf:Property ;
    rdfs:label 'Payment Channel' ;
    rdfs:comment 'The interface or system channel through which the payment was initiated or received (e.g., ERP system, banking portal, manual entry).' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Payment Document Number' ;
    rdfs:comment 'Externally-known unique payment document number assigned by the ERP system (SAP S/4HANA or Viewpoint Vista). Used for reconciliation and audit trail.' ;
    rdfs:domain ind:PaymentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentNotes rdf:type rdf:Property ;
    rdfs:label 'Payment Notes' ;
    rdfs:comment 'Free-text notes or comments related to the payment transaction, capturing special instructions or contextual information.' ;
    rdfs:domain ind:PaymentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentPriority rdf:type rdf:Property ;
    rdfs:label 'Payment Priority' ;
    rdfs:comment 'Priority level assigned to the payment for processing sequence and cash flow management.' ;
    rdfs:domain ind:PaymentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentPurpose rdf:type rdf:Property ;
    rdfs:label 'Payment Purpose' ;
    rdfs:comment 'Business purpose or reason for the payment (e.g., material supply, subcontractor labor, equipment rental, progress billing).' ;
    rdfs:domain ind:PaymentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentType rdf:type rdf:Property ;
    rdfs:label 'Payment Type' ;
    rdfs:comment 'Classification of payment direction: outgoing payments to vendors/subcontractors (AP disbursements) or incoming receipts from clients (AR collections).' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:poNumber rdf:type rdf:Property ;
    rdfs:label 'Po Number' ;
    rdfs:comment 'Purchase order number associated with the payment, typically for vendor payments linked to procurement transactions.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reconciliationDate rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Date' ;
    rdfs:comment 'Date when the payment was successfully reconciled with the bank statement during the bank reconciliation process.' ;
    rdfs:domain ind:PaymentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reconciliationStatus rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Status' ;
    rdfs:comment 'Status of bank reconciliation for this payment, indicating whether it has been matched with bank statement entries.' ;
    rdfs:domain ind:PaymentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remittanceAdvice rdf:type rdf:Property ;
    rdfs:label 'Remittance Advice' ;
    rdfs:comment 'Detailed remittance information sent to the payee explaining which invoices or obligations are being settled by this payment.' ;
    rdfs:domain ind:PaymentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valueDate rdf:type rdf:Property ;
    rdfs:label 'Value Date' ;
    rdfs:comment 'The effective date when funds are available or debited in the bank account, used for cash flow and liquidity management.' ;
    rdfs:domain ind:PaymentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:withholdingTaxAmount rdf:type rdf:Property ;
    rdfs:label 'Withholding Tax Amount' ;
    rdfs:comment 'Tax amount withheld at source as per local tax regulations, deducted from the gross payment amount.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cashFlowForecastId rdf:type rdf:Property ;
    rdfs:label 'Cash Flow Forecast Id' ;
    rdfs:comment 'Unique identifier for the cash flow forecast record.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CashFlowForecast .

ind:paymentScheduleId rdf:type rdf:Property ;
    rdfs:label 'Payment Schedule Id' ;
    rdfs:comment 'Foreign key linking to contract.payment_schedule. Business justification: Contractual payment schedules are the primary input to cash flow forecasting. Finance teams build period-level cash flow forecasts from payment schedule installments. Linking forecast entries to speci' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PaymentSchedule .

ind:advanceDrawdownAmount rdf:type rdf:Property ;
    rdfs:label 'Advance Drawdown Amount' ;
    rdfs:comment 'Forecasted drawdown of advance payments or mobilization advances from the client, typically secured by advance payment guarantees.' ;
    rdfs:domain ind:CashFlowForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bondPremiumAmount rdf:type rdf:Property ;
    rdfs:label 'Bond Premium Amount' ;
    rdfs:comment 'Forecasted payments for performance bonds, advance payment guarantees, and other surety instruments required by the contract.' ;
    rdfs:domain ind:CashFlowForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bondingCapacityUtilization rdf:type rdf:Property ;
    rdfs:label 'Bonding Capacity Utilization' ;
    rdfs:comment 'Percentage of total bonding capacity utilized by this forecast, relevant for corporate-level forecasts to monitor surety capacity constraints.' ;
    rdfs:domain ind:CashFlowForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:closingCashBalance rdf:type rdf:Property ;
    rdfs:label 'Closing Cash Balance' ;
    rdfs:comment 'Projected cash balance at the end of the forecast period, calculated as opening balance plus net cash flow.' ;
    rdfs:domain ind:CashFlowForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditFacilityUtilization rdf:type rdf:Property ;
    rdfs:label 'Credit Facility Utilization' ;
    rdfs:comment 'Percentage of available credit facility or working capital line utilized to meet the peak funding requirement, relevant for corporate treasury management.' ;
    rdfs:domain ind:CashFlowForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cumulativeCashPosition rdf:type rdf:Property ;
    rdfs:label 'Cumulative Cash Position' ;
    rdfs:comment 'Cumulative cash position at the end of the forecast period, representing the running total of net cash flows from project inception or corporate fiscal year start.' ;
    rdfs:domain ind:CashFlowForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:equipmentHireAmount rdf:type rdf:Property ;
    rdfs:label 'Equipment Hire Amount' ;
    rdfs:comment 'Forecasted payments for equipment rental and hire charges, including plant, machinery, and temporary facilities.' ;
    rdfs:domain ind:CashFlowForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:forecastAssumptions rdf:type rdf:Property ;
    rdfs:label 'Forecast Assumptions' ;
    rdfs:comment 'Key assumptions underlying the forecast, including payment term assumptions, progress rate assumptions, inflation factors, and risk contingencies.' ;
    rdfs:domain ind:CashFlowForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forecastGranularity rdf:type rdf:Property ;
    rdfs:label 'Forecast Granularity' ;
    rdfs:comment 'The time interval granularity at which cash flows are forecasted: daily for short-term liquidity management, weekly for near-term project cash planning, monthly for standard project forecasting, or quarterly for long-term corporate planning.' ;
    rdfs:domain ind:CashFlowForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forecastIdentifier rdf:type rdf:Property ;
    rdfs:label 'Forecast Identifier' ;
    rdfs:comment 'Business-readable identifier for the forecast, typically combining project code, forecast period, and version (e.g., PRJ-2024-001-V3).' ;
    rdfs:domain ind:CashFlowForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forecastPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Forecast Period End Date' ;
    rdfs:comment 'The end date of the period covered by this cash flow forecast.' ;
    rdfs:domain ind:CashFlowForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:forecastPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Forecast Period Start Date' ;
    rdfs:comment 'The start date of the period covered by this cash flow forecast.' ;
    rdfs:domain ind:CashFlowForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:forecastStatus rdf:type rdf:Property ;
    rdfs:label 'Forecast Status' ;
    rdfs:comment 'Current lifecycle status of the forecast: draft for work-in-progress, submitted for review, approved for active use, superseded when replaced by a newer version, or archived for historical reference.' ;
    rdfs:domain ind:CashFlowForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forecastType rdf:type rdf:Property ;
    rdfs:label 'Forecast Type' ;
    rdfs:comment 'Classification of the forecast scope: project-level for individual construction projects, corporate-level for enterprise-wide treasury forecasting, WBS-level for granular work package forecasts, or contract-level for specific contract cash management.' ;
    rdfs:domain ind:CashFlowForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forecastVersion rdf:type rdf:Property ;
    rdfs:label 'Forecast Version' ;
    rdfs:comment 'Version number of the forecast, incremented with each revision to track forecast evolution and variance analysis over time.' ;
    rdfs:domain ind:CashFlowForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:forecastedInflowAmount rdf:type rdf:Property ;
    rdfs:label 'Forecasted Inflow Amount' ;
    rdfs:comment 'Total projected cash inflows for the forecast period, including client milestone payments, retention releases, advance drawdowns, and other receipts.' ;
    rdfs:domain ind:CashFlowForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:forecastedOutflowAmount rdf:type rdf:Property ;
    rdfs:label 'Forecasted Outflow Amount' ;
    rdfs:comment 'Total projected cash outflows for the forecast period, including subcontractor payments, material procurement, payroll, equipment hire, bond premiums, and other disbursements.' ;
    rdfs:domain ind:CashFlowForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:materialProcurementAmount rdf:type rdf:Property ;
    rdfs:label 'Material Procurement Amount' ;
    rdfs:comment 'Forecasted payments for material purchases and procurement, based on Purchase Orders (PO) and supplier payment terms.' ;
    rdfs:domain ind:CashFlowForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:milestonePaymentAmount rdf:type rdf:Property ;
    rdfs:label 'Milestone Payment Amount' ;
    rdfs:comment 'Forecasted client milestone payments expected during the period, based on contract payment schedules and progress billing milestones.' ;
    rdfs:domain ind:CashFlowForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netCashFlowAmount rdf:type rdf:Property ;
    rdfs:label 'Net Cash Flow Amount' ;
    rdfs:comment 'Net cash flow for the forecast period, calculated as forecasted inflows minus forecasted outflows, indicating the expected cash position change.' ;
    rdfs:domain ind:CashFlowForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:openingCashBalance rdf:type rdf:Property ;
    rdfs:label 'Opening Cash Balance' ;
    rdfs:comment 'Cash balance at the beginning of the forecast period, serving as the starting point for the period\'s cash flow projection.' ;
    rdfs:domain ind:CashFlowForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:payrollAmount rdf:type rdf:Property ;
    rdfs:label 'Payroll Amount' ;
    rdfs:comment 'Forecasted payroll disbursements for direct labor and site personnel, including wages, benefits, and statutory contributions.' ;
    rdfs:domain ind:CashFlowForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:peakFundingRequirement rdf:type rdf:Property ;
    rdfs:label 'Peak Funding Requirement' ;
    rdfs:comment 'Maximum negative cash position expected during the forecast period, indicating the highest working capital or credit facility draw required.' ;
    rdfs:domain ind:CashFlowForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:retentionReleaseAmount rdf:type rdf:Property ;
    rdfs:label 'Retention Release Amount' ;
    rdfs:comment 'Forecasted release of retention amounts held by the client, typically released upon project completion or after the Defects Liability Period (DLP).' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sCurveProfileIndicator rdf:type rdf:Property ;
    rdfs:label 'S Curve Profile Indicator' ;
    rdfs:comment 'Classification of the cash flow profile shape: front-loaded for projects with high early expenditure, linear for steady cash flow, back-loaded for projects with late-stage heavy spending, or custom for non-standard profiles.' ;
    rdfs:domain ind:CashFlowForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subcontractorPaymentAmount rdf:type rdf:Property ;
    rdfs:label 'Subcontractor Payment Amount' ;
    rdfs:comment 'Forecasted payments to subcontractors for work performed, based on subcontract payment terms and progress certificates.' ;
    rdfs:domain ind:CashFlowForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:variancePercentage rdf:type rdf:Property ;
    rdfs:label 'Variance Percentage' ;
    rdfs:comment 'Percentage variance between current and prior forecast, calculated as (current - prior) / prior * 100, indicating forecast volatility.' ;
    rdfs:domain ind:CashFlowForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceToPriorForecast rdf:type rdf:Property ;
    rdfs:label 'Variance To Prior Forecast' ;
    rdfs:comment 'Difference between the current forecast net cash flow and the previous forecast version for the same period, used for forecast accuracy tracking and trend analysis.' ;
    rdfs:domain ind:CashFlowForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:workingCapitalGap rdf:type rdf:Property ;
    rdfs:label 'Working Capital Gap' ;
    rdfs:comment 'Difference between forecasted outflows and inflows timing, representing the working capital financing need to bridge payment obligations before receipt of client payments.' ;
    rdfs:domain ind:CashFlowForecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:laborCostCodeId rdf:type rdf:Property ;
    rdfs:label 'Labor Cost Code Id' ;
    rdfs:comment 'Foreign key linking to workforce.labor_cost_code. Business justification: A craft worker is classified under a specific labor cost code that defines their trade, skill level, wage classification, and burden rates. Adding labor_cost_code_id normalizes the craft_code string i' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LaborCostCode .

ind:emergencyContactRelationship rdf:type rdf:Property ;
    rdfs:label 'Emergency Contact Relationship' ;
    rdfs:comment 'Relationship of the emergency contact to the craft worker (e.g., spouse, parent, sibling, friend).' ;
    rdfs:domain ind:CraftWorker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employmentType rdf:type rdf:Property ;
    rdfs:label 'Employment Type' ;
    rdfs:comment 'Classification of the worker\'s employment relationship with the organization: direct hire (permanent employee), agency (temporary staffing), union referral (union hall dispatch), or subcontractor (independent contractor).' ;
    rdfs:domain ind:CraftWorker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hireDate rdf:type rdf:Property ;
    rdfs:label 'Hire Date' ;
    rdfs:comment 'Date the craft worker was hired or first engaged by the organization.' ;
    rdfs:domain ind:CraftWorker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:hourlyBaseRate rdf:type rdf:Property ;
    rdfs:label 'Hourly Base Rate' ;
    rdfs:comment 'Standard hourly wage rate for the craft worker in their primary trade classification, excluding overtime premiums and benefits.' ;
    rdfs:domain ind:CraftWorker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:middleName rdf:type rdf:Property ;
    rdfs:label 'Middle Name' ;
    rdfs:comment 'Middle name or initial of the craft worker, if applicable.' ;
    rdfs:domain ind:CraftWorker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oshaCertificationExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Osha Certification Expiry Date' ;
    rdfs:comment 'Expiration date of the craft worker\'s OSHA safety certification, if applicable.' ;
    rdfs:domain ind:CraftWorker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:oshaCertificationFlag rdf:type rdf:Property ;
    rdfs:label 'Osha Certification Flag' ;
    rdfs:comment 'Indicates whether the craft worker holds valid OSHA safety training certification (e.g., OSHA 10-hour or 30-hour).' ;
    rdfs:domain ind:CraftWorker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:overtimeRateMultiplier rdf:type rdf:Property ;
    rdfs:label 'Overtime Rate Multiplier' ;
    rdfs:comment 'Multiplier applied to base hourly rate for overtime hours (e.g., 1.5 for time-and-a-half, 2.0 for double-time).' ;
    rdfs:domain ind:CraftWorker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ppeSizeBoots rdf:type rdf:Property ;
    rdfs:label 'Ppe Size Boots' ;
    rdfs:comment 'Boot size for issuing Personal Protective Equipment (PPE) such as steel-toed safety boots.' ;
    rdfs:domain ind:CraftWorker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ppeSizePants rdf:type rdf:Property ;
    rdfs:label 'Ppe Size Pants' ;
    rdfs:comment 'Pants size for issuing Personal Protective Equipment (PPE) such as work pants and coveralls.' ;
    rdfs:domain ind:CraftWorker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ppeSizeShirt rdf:type rdf:Property ;
    rdfs:label 'Ppe Size Shirt' ;
    rdfs:comment 'Shirt size for issuing Personal Protective Equipment (PPE) such as high-visibility vests and work shirts. [ENUM-REF-CANDIDATE: XS|S|M|L|XL|XXL|XXXL — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CraftWorker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:securityClearanceLevel rdf:type rdf:Property ;
    rdfs:label 'Security Clearance Level' ;
    rdfs:comment 'Security clearance level held by the craft worker for access to restricted project sites (e.g., government, defense, critical infrastructure projects).' ;
    rdfs:domain ind:CraftWorker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteAccessBadgeNumber rdf:type rdf:Property ;
    rdfs:label 'Site Access Badge Number' ;
    rdfs:comment 'Unique badge or access card number issued to the craft worker for site entry and time tracking at construction sites.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:skillLevel rdf:type rdf:Property ;
    rdfs:label 'Skill Level' ;
    rdfs:comment 'Proficiency level of the craft worker in their primary trade: apprentice (in training), journeyman (certified tradesperson), master (advanced certification), or foreman (supervisory level).' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supervisoryRoleFlag rdf:type rdf:Property ;
    rdfs:label 'Supervisory Role Flag' ;
    rdfs:comment 'Indicates whether the craft worker currently holds a supervisory role such as working foreman or crew lead (True) or is a non-supervisory hourly worker (False).' ;
    rdfs:domain ind:CraftWorker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supervisoryTitle rdf:type rdf:Property ;
    rdfs:label 'Supervisory Title' ;
    rdfs:comment 'Job title for supervisory role if applicable (e.g., Working Foreman, Crew Lead, General Foreman).' ;
    rdfs:domain ind:CraftWorker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unionAffiliationFlag rdf:type rdf:Property ;
    rdfs:label 'Union Affiliation Flag' ;
    rdfs:comment 'Indicates whether the craft worker is affiliated with a labor union (True) or non-union (False).' ;
    rdfs:domain ind:CraftWorker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:unionLocalNumber rdf:type rdf:Property ;
    rdfs:label 'Union Local Number' ;
    rdfs:comment 'Local union chapter number the worker belongs to, if union-affiliated.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unionName rdf:type rdf:Property ;
    rdfs:label 'Union Name' ;
    rdfs:comment 'Name of the labor union the worker is affiliated with, if applicable (e.g., International Brotherhood of Electrical Workers, United Association of Plumbers).' ;
    rdfs:domain ind:CraftWorker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workerStatus rdf:type rdf:Property ;
    rdfs:label 'Worker Status' ;
    rdfs:comment 'Current lifecycle status of the craft worker record: active (currently employed and available), inactive (temporarily not working), suspended (disciplinary or safety hold), or terminated (employment ended).' ;
    rdfs:domain ind:CraftWorker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:yearsOfExperience rdf:type rdf:Property ;
    rdfs:label 'Years Of Experience' ;
    rdfs:comment 'Total number of years of experience the craft worker has in their primary trade.' ;
    rdfs:domain ind:CraftWorker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:averageHourlyRate rdf:type rdf:Property ;
    rdfs:label 'Average Hourly Rate' ;
    rdfs:comment 'Blended average hourly labor rate for the crew, calculated across all crew members. Used for cost estimation and Earned Value Management (EVM) calculations. Currency is USD unless otherwise specified in project configuration.' ;
    rdfs:domain ind:Crew ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:crewCode rdf:type rdf:Property ;
    rdfs:label 'Crew Code' ;
    rdfs:comment 'Business identifier code for the crew used in field operations and timekeeping systems. Typically alphanumeric and unique within a project or division.' ;
    rdfs:domain ind:Crew ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crewName rdf:type rdf:Property ;
    rdfs:label 'Crew Name' ;
    rdfs:comment 'Human-readable name of the crew, often reflecting the crew type, foreman name, or project assignment (e.g., \'Smith Concrete Gang\', \'MEP Crew A\').' ;
    rdfs:domain ind:Crew ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crewStatus rdf:type rdf:Property ;
    rdfs:label 'Crew Status' ;
    rdfs:comment 'Current operational status of the crew in its lifecycle. Active crews are deployed and working; inactive crews are not currently assigned; mobilizing/demobilizing crews are in transition; standby crews are available but not deployed; disbanded crews are permanently closed.' ;
    rdfs:domain ind:Crew ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:daysSinceLastIncident rdf:type rdf:Property ;
    rdfs:label 'Days Since Last Incident' ;
    rdfs:comment 'Number of calendar days since the last recordable safety incident for this crew. Used for safety milestone recognition and Total Recordable Incident Rate (TRIR) tracking. Null if no incidents have occurred.' ;
    rdfs:domain ind:Crew ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:homeLocation rdf:type rdf:Property ;
    rdfs:label 'Home Location' ;
    rdfs:comment 'Primary site, yard, or facility where this crew is based or reports to. May be a project site, equipment yard, or regional office.' ;
    rdfs:domain ind:Crew ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isUnionCrew rdf:type rdf:Property ;
    rdfs:label 'Is Union Crew' ;
    rdfs:comment 'Flag indicating whether this is a union crew subject to collective bargaining agreements and union work rules. True if union, false if non-union or open shop.' ;
    rdfs:domain ind:Crew ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastSafetyIncidentDate rdf:type rdf:Property ;
    rdfs:label 'Last Safety Incident Date' ;
    rdfs:comment 'Date of the most recent recordable safety incident involving this crew. Used for safety performance tracking and Lost Time Injury (LTI) frequency calculations. Null if no incidents have occurred.' ;
    rdfs:domain ind:Crew ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:productivityUom rdf:type rdf:Property ;
    rdfs:label 'Productivity Uom' ;
    rdfs:comment 'Unit of measure for the productivity rate (e.g., CY/HR for cubic yards per hour, LF/HR for linear feet per hour, EA/HR for each per hour). Aligns with Bill of Quantities (BOQ) units.' ;
    rdfs:domain ind:Crew ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityRating rdf:type rdf:Property ;
    rdfs:label 'Quality Rating' ;
    rdfs:comment 'Current quality performance rating for the crew based on Quality Assurance/Quality Control (QA/QC) inspections, Non-Conformance Reports (NCR), and rework rates. Used for crew selection and quality incentive programs.' ;
    rdfs:domain ind:Crew ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiredCertifications rdf:type rdf:Property ;
    rdfs:label 'Required Certifications' ;
    rdfs:comment 'Comma-separated list of skill certifications or licenses required for crew members (e.g., \'OSHA 30, Confined Space, Rigging Level II\'). Used for crew qualification verification and compliance with Inspection and Test Plans (ITP).' ;
    rdfs:domain ind:Crew ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyRating rdf:type rdf:Property ;
    rdfs:label 'Safety Rating' ;
    rdfs:comment 'Current safety performance rating for the crew based on Health Safety and Environment (HSE) inspections, incident history, and compliance with Safe Work Method Statements (SWMS). Used for crew selection and safety incentive programs.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:size rdf:type rdf:Property ;
    rdfs:label 'Size' ;
    rdfs:comment 'Current number of workers assigned to this crew, including the foreman. Used for resource planning and productivity rate calculations.' ;
    rdfs:domain ind:Crew ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:unionAffiliation rdf:type rdf:Property ;
    rdfs:label 'Union Affiliation' ;
    rdfs:comment 'Name of the labor union or trade association to which the majority of crew members belong, if applicable. Null for non-union crews. Relevant for labor relations, collective bargaining agreements, and jurisdictional work rules.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crewAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Crew Assignment Id' ;
    rdfs:comment 'Primary key for crew_assignment' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CrewAssignment .

ind:laborRateId rdf:type rdf:Property ;
    rdfs:label 'Labor Rate Id' ;
    rdfs:comment 'Foreign key linking to workforce.labor_rate. Business justification: crew_assignment currently stores labor_rate as a DECIMAL(15,2) scalar value and labor_rate_currency as a string — both are denormalized copies of data that belongs in the labor_rate reference table. A' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LaborRate .

ind:lookaheadPlanId rdf:type rdf:Property ;
    rdfs:label 'Lookahead Plan Id' ;
    rdfs:comment 'Foreign key linking to schedule.lookahead_plan. Business justification: Crew assignments are the formal commitments that fulfill lookahead plan work packages in LPS construction scheduling. Linking crew_assignment to lookahead_plan enables calculation of Percent Plan Comp' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LookaheadPlan .

ind:assignmentReason rdf:type rdf:Property ;
    rdfs:label 'Assignment Reason' ;
    rdfs:comment 'Business reason or justification for the crew assignment. May include project need, skill requirement, backfill, or resource leveling.' ;
    rdfs:domain ind:CrewAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:craftType rdf:type rdf:Property ;
    rdfs:label 'Craft Type' ;
    rdfs:comment 'Craft or trade classification of the worker for this assignment (e.g., carpenter, electrician, pipefitter, ironworker, concrete finisher). Aligns with union classifications and skill requirements.' ;
    rdfs:domain ind:CrewAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crewRole rdf:type rdf:Property ;
    rdfs:label 'Crew Role' ;
    rdfs:comment 'Role of the worker within the crew. Defines the worker\'s responsibility level and function within the crew structure.' ;
    rdfs:domain ind:CrewAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hseOrientationCompletedFlag rdf:type rdf:Property ;
    rdfs:label 'Hse Orientation Completed Flag' ;
    rdfs:comment 'Indicates whether the worker has completed mandatory HSE orientation for this crew assignment. Required before site access is granted.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hseOrientationDate rdf:type rdf:Property ;
    rdfs:label 'Hse Orientation Date' ;
    rdfs:comment 'Date when the worker completed HSE orientation for this crew assignment. Used for compliance tracking and re-certification scheduling.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:overtimeEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Overtime Eligible Flag' ;
    rdfs:comment 'Indicates whether the worker is eligible for overtime pay in this crew assignment. Driven by labor agreements, regulations, and contract terms.' ;
    rdfs:domain ind:CrewAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:perDiemEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Per Diem Eligible Flag' ;
    rdfs:comment 'Indicates whether the worker is eligible for per diem allowances during this crew assignment. Typically applies to workers assigned away from their home location.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:perDiemRate rdf:type rdf:Property ;
    rdfs:label 'Per Diem Rate' ;
    rdfs:comment 'Daily per diem allowance rate for the worker in this crew assignment. Covers meals, lodging, and incidental expenses for remote assignments.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ppeIssuedFlag rdf:type rdf:Property ;
    rdfs:label 'Ppe Issued Flag' ;
    rdfs:comment 'Indicates whether required PPE has been issued to the worker for this crew assignment. Tracks compliance with safety equipment requirements.' ;
    rdfs:domain ind:CrewAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:timesheetId rdf:type rdf:Property ;
    rdfs:label 'Timesheet Id' ;
    rdfs:comment 'Unique identifier for the timesheet record. Primary key for the timesheet entity.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Timesheet .

ind:craftClassification rdf:type rdf:Property ;
    rdfs:label 'Craft Classification' ;
    rdfs:comment 'The trade or craft classification of the worker for this timesheet entry. Determines applicable pay rates and union rules.' ;
    rdfs:domain ind:Timesheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:doubleTimeHours rdf:type rdf:Property ;
    rdfs:label 'Double Time Hours' ;
    rdfs:comment 'Number of double-time hours worked, typically on holidays or after extended overtime. Paid at 2x the regular rate.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:equipmentOperated rdf:type rdf:Property ;
    rdfs:label 'Equipment Operated' ;
    rdfs:comment 'Description or identifier of equipment operated by the worker during this timesheet period. Used for equipment utilization tracking and operator certification validation.' ;
    rdfs:domain ind:Timesheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:laborCostAmount rdf:type rdf:Property ;
    rdfs:label 'Labor Cost Amount' ;
    rdfs:comment 'Total labor cost for this timesheet entry, calculated from hours worked and applicable pay rates. Core metric for job costing and project financial management.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:locationCode rdf:type rdf:Property ;
    rdfs:label 'Location Code' ;
    rdfs:comment 'Code identifying the specific site location or work area where the labor was performed. Enables location-based cost tracking and site access control.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payType rdf:type rdf:Property ;
    rdfs:label 'Pay Type' ;
    rdfs:comment 'The compensation method applied to this timesheet entry. Determines how labor costs are calculated.' ;
    rdfs:domain ind:Timesheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payrollPeriod rdf:type rdf:Property ;
    rdfs:label 'Payroll Period' ;
    rdfs:comment 'Identifier of the payroll period to which this timesheet belongs. Used for grouping timesheets for payroll processing.' ;
    rdfs:domain ind:Timesheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regularHours rdf:type rdf:Property ;
    rdfs:label 'Regular Hours' ;
    rdfs:comment 'Number of regular hours worked during the standard work period. Typically up to 8 hours per day or 40 hours per week.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalHours rdf:type rdf:Property ;
    rdfs:label 'Total Hours' ;
    rdfs:comment 'Total hours worked across all categories (regular, overtime, double-time). Sum of all hour types for the timesheet entry.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unionLocal rdf:type rdf:Property ;
    rdfs:label 'Union Local' ;
    rdfs:comment 'Union local chapter number to which the worker belongs. Required for union reporting and compliance with collective bargaining agreements.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workClassification rdf:type rdf:Property ;
    rdfs:label 'Work Classification' ;
    rdfs:comment 'Classification of the work activity type. Distinguishes between productive work, non-productive time, rework, standby, and travel time for productivity analysis.' ;
    rdfs:domain ind:Timesheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workDate rdf:type rdf:Property ;
    rdfs:label 'Work Date' ;
    rdfs:comment 'The calendar date on which the work was performed. Core business event timestamp for labor tracking.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:workOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Work Order Number' ;
    rdfs:comment 'Reference number of the work order or task assignment associated with this timesheet. Links labor hours to specific work packages.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timesheetLineId rdf:type rdf:Property ;
    rdfs:label 'Timesheet Line Id' ;
    rdfs:comment 'Unique identifier for the timesheet line item. Primary key for granular labor allocation tracking within a daily timesheet.' ;
    rdfs:domain ind:TimesheetLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inspectionId rdf:type rdf:Property ;
    rdfs:label 'Inspection Id' ;
    rdfs:comment 'Foreign key linking to quality.inspection. Business justification: Inspection labor cost reporting: when an inspector or crew logs time performing an inspection, the timesheet line should reference the inspection record. Construction project controls require cost-per' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Inspection .

ind:craftCode rdf:type rdf:Property ;
    rdfs:label 'Craft Code' ;
    rdfs:comment 'Standardized code identifying the labor craft or trade performed (e.g., carpenter, electrician, heavy equipment operator, concrete finisher). Used for skill-based labor cost analysis and union reporting.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postedToJobCostFlag rdf:type rdf:Property ;
    rdfs:label 'Posted To Job Cost Flag' ;
    rdfs:comment 'Indicates whether this timesheet line has been posted to the job costing system for project financial tracking. Ensures labor costs are captured in project actuals.' ;
    rdfs:domain ind:TimesheetLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:postedToPayrollFlag rdf:type rdf:Property ;
    rdfs:label 'Posted To Payroll Flag' ;
    rdfs:comment 'Indicates whether this timesheet line has been posted to the payroll system for worker compensation. Prevents duplicate payment processing.' ;
    rdfs:domain ind:TimesheetLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:shiftCode rdf:type rdf:Property ;
    rdfs:label 'Shift Code' ;
    rdfs:comment 'Identifies the work shift during which labor was performed. Supports shift-differential pay calculations and 24-hour site operations tracking.' ;
    rdfs:domain ind:TimesheetLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unionLocalCode rdf:type rdf:Property ;
    rdfs:label 'Union Local Code' ;
    rdfs:comment 'Code identifying the labor union local chapter for this worker. Required for union labor reporting, fringe benefit calculations, and collective bargaining agreement compliance.' ;
    rdfs:domain ind:TimesheetLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workLocationCode rdf:type rdf:Property ;
    rdfs:label 'Work Location Code' ;
    rdfs:comment 'Site-specific location code where labor was performed (e.g., building zone, elevation level, grid coordinate). Supports spatial tracking and site logistics management.' ;
    rdfs:domain ind:TimesheetLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetCategory rdf:type rdf:Property ;
    rdfs:label 'Budget Category' ;
    rdfs:comment 'High-level budget classification for financial planning and cost control. Determines how labor costs are aggregated in project budgets and Earned Value Management (EVM) reporting.' ;
    rdfs:domain ind:LaborCostCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:burdenRatePercentage rdf:type rdf:Property ;
    rdfs:label 'Burden Rate Percentage' ;
    rdfs:comment 'The percentage markup applied to base hourly rate to account for payroll taxes, workers compensation insurance, benefits, and other indirect labor costs. Expressed as a percentage (e.g., 45.50 for 45.5%).' ;
    rdfs:domain ind:LaborCostCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:craftDiscipline rdf:type rdf:Property ;
    rdfs:label 'Craft Discipline' ;
    rdfs:comment 'Standardized craft discipline category for workforce competency classification. Defines the primary skill domain for this labor cost code. [ENUM-REF-CANDIDATE: ironworker|pipefitter|electrician|carpenter|heavy_equipment_operator|concrete_finisher|welder|plumber|hvac_technician|mason|roofer|painter|laborer|foreman|superintendent — promote to reference product]' ;
    rdfs:domain ind:LaborCostCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hcssCostCodeMapping rdf:type rdf:Property ;
    rdfs:label 'Hcss Cost Code Mapping' ;
    rdfs:comment 'The corresponding cost code identifier in HCSS HeavyJob field operations system. Used for timesheet integration and production tracking synchronization.' ;
    rdfs:domain ind:LaborCostCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hourlyRateBase rdf:type rdf:Property ;
    rdfs:label 'Hourly Rate Base' ;
    rdfs:comment 'Standard base hourly wage rate for this labor cost code in the organization\'s default currency. Excludes burden, benefits, and premium time multipliers. Used for budget estimation and cost forecasting.' ;
    rdfs:domain ind:LaborCostCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isPrevailingWageApplicable rdf:type rdf:Property ;
    rdfs:label 'Is Prevailing Wage Applicable' ;
    rdfs:comment 'Indicates whether this cost code is subject to prevailing wage requirements on government-funded projects (Davis-Bacon Act, state prevailing wage laws).' ;
    rdfs:domain ind:LaborCostCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isUnionClassification rdf:type rdf:Property ;
    rdfs:label 'Is Union Classification' ;
    rdfs:comment 'Indicates whether this labor cost code represents a union-covered trade classification subject to collective bargaining agreements and union work rules.' ;
    rdfs:domain ind:LaborCostCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:overtimeMultiplier rdf:type rdf:Property ;
    rdfs:label 'Overtime Multiplier' ;
    rdfs:comment 'The multiplier applied to base hourly rate for overtime hours (e.g., 1.5 for time-and-a-half, 2.0 for double-time). Null if overtime is not applicable to this cost code.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:prevailingWageClassification rdf:type rdf:Property ;
    rdfs:label 'Prevailing Wage Classification' ;
    rdfs:comment 'The official prevailing wage classification code as defined by federal or state labor departments (e.g., Davis-Bacon Act classifications). Used to determine minimum wage rates for government-funded projects.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productivityUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Productivity Unit Of Measure' ;
    rdfs:comment 'The standard unit of measure used to track production rates for this labor classification (e.g., cubic yards of concrete, linear feet of pipe, square feet of formwork, tons of steel erected).' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiredCertificationTypes rdf:type rdf:Property ;
    rdfs:label 'Required Certification Types' ;
    rdfs:comment 'Comma-separated list of mandatory certifications, licenses, or qualifications required for workers assigned to this cost code (e.g., OSHA 30-Hour, Journeyman License, Crane Operator Certification, Confined Space Entry).' ;
    rdfs:domain ind:LaborCostCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiresSiteAccessClearance rdf:type rdf:Property ;
    rdfs:label 'Requires Site Access Clearance' ;
    rdfs:comment 'Indicates whether workers assigned to this cost code require special site access clearance, background checks, or security credentials (common for energy, defense, or critical infrastructure projects).' ;
    rdfs:domain ind:LaborCostCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:standardCrewSize rdf:type rdf:Property ;
    rdfs:label 'Standard Crew Size' ;
    rdfs:comment 'The typical number of workers in a standard crew for this trade classification. Used for resource planning and crew assignment optimization.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:unionJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Union Jurisdiction' ;
    rdfs:comment 'The labor union or trade association that holds jurisdiction over this craft discipline (e.g., International Brotherhood of Electrical Workers, United Association of Plumbers and Pipefitters). Null for non-union classifications.' ;
    rdfs:domain ind:LaborCostCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:craftCertificationId rdf:type rdf:Property ;
    rdfs:label 'Craft Certification Id' ;
    rdfs:comment 'Unique identifier for the craft certification record. Primary key.' ;
    rdfs:domain ind:CraftCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:certificationName rdf:type rdf:Property ;
    rdfs:label 'Certification Name' ;
    rdfs:comment 'The full descriptive name of the certification as issued by the certifying body. Provides human-readable detail beyond the type code.' ;
    rdfs:domain ind:CraftCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationNumber rdf:type rdf:Property ;
    rdfs:label 'Certification Number' ;
    rdfs:comment 'The unique certificate or credential number issued by the certifying body. Used for verification and audit purposes.' ;
    rdfs:domain ind:CraftCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingBody rdf:type rdf:Property ;
    rdfs:label 'Issuing Body' ;
    rdfs:comment 'The organization or authority that issued the certification. Examples include OSHA (Occupational Safety and Health Administration), NCCER (National Center for Construction Education and Research), NCCCO (National Commission for the Certification of Crane Operators), AWS (American Welding Society), or state licensing boards.' ;
    rdfs:domain ind:CraftCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextRenewalDate rdf:type rdf:Property ;
    rdfs:label 'Next Renewal Date' ;
    rdfs:comment 'The date by which the certification must be renewed to remain valid. Used for proactive workforce planning and compliance alerts.' ;
    rdfs:domain ind:CraftCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:projectRequirementFlag rdf:type rdf:Property ;
    rdfs:label 'Project Requirement Flag' ;
    rdfs:comment 'Indicates whether this certification is required by specific project contracts or client specifications. True if the certification is a project-specific qualification requirement, False if it is a general workforce credential.' ;
    rdfs:domain ind:CraftCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Compliance Flag' ;
    rdfs:comment 'Indicates whether this certification is required to meet federal, state, or local regulatory requirements. True if the certification is mandated by law or regulation, False if it is voluntary or company-specific.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalFrequencyMonths rdf:type rdf:Property ;
    rdfs:label 'Renewal Frequency Months' ;
    rdfs:comment 'The number of months between required renewals for this certification. Nullable if renewal is not required.' ;
    rdfs:domain ind:CraftCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:renewalRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Renewal Required Flag' ;
    rdfs:comment 'Indicates whether this certification requires periodic renewal. True if renewal is required, False if the certification is permanent or does not expire.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:siteAccessRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Site Access Required Flag' ;
    rdfs:comment 'Indicates whether this certification is mandatory for site access control. True if workers cannot badge in without a valid certification of this type, False otherwise. Supports HSE (Health Safety and Environment) compliance and access control integration.' ;
    rdfs:domain ind:CraftCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:trainingCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Training Completion Date' ;
    rdfs:comment 'The date on which the worker completed the training program associated with this certification.' ;
    rdfs:domain ind:CraftCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:trainingHoursRequired rdf:type rdf:Property ;
    rdfs:label 'Training Hours Required' ;
    rdfs:comment 'The total number of training hours required to obtain or renew this certification. Used for workforce development planning and compliance tracking.' ;
    rdfs:domain ind:CraftCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:apprenticeshipDurationHours rdf:type rdf:Property ;
    rdfs:label 'Apprenticeship Duration Hours' ;
    rdfs:comment 'Standard duration of apprenticeship training program in hours (e.g., 8000 hours for journeyman electrician). Used for workforce development planning and training program management.' ;
    rdfs:domain ind:SkillTrade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:apprenticeshipRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Apprenticeship Required Flag' ;
    rdfs:comment 'Indicates whether formal apprenticeship training is required or recommended for this trade skill. True if apprenticeship is a standard pathway; false otherwise.' ;
    rdfs:domain ind:SkillTrade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:averageHourlyRateUsd rdf:type rdf:Property ;
    rdfs:label 'Average Hourly Rate Usd' ;
    rdfs:comment 'Average or benchmark hourly labor rate for journeyman-level workers in this trade, in US dollars. Used for project cost estimation and budget planning. Actual rates vary by geography, project type, and union agreements.' ;
    rdfs:domain ind:SkillTrade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bimIntegrationLevel rdf:type rdf:Property ;
    rdfs:label 'Bim Integration Level' ;
    rdfs:comment 'Level of BIM (Building Information Modeling) technology integration and digital literacy expected for this trade (none, basic, intermediate, advanced). Used for technology training planning and digital construction readiness.' ;
    rdfs:domain ind:SkillTrade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationIssuingBody rdf:type rdf:Property ;
    rdfs:label 'Certification Issuing Body' ;
    rdfs:comment 'Name of the organization or regulatory body that issues the required certification for this trade (e.g., NCCER, AWS, NCCCO, state licensing board). Used for credential verification and compliance tracking.' ;
    rdfs:domain ind:SkillTrade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationTypeRequired rdf:type rdf:Property ;
    rdfs:label 'Certification Type Required' ;
    rdfs:comment 'Type of professional certification, license, or credential required to perform work in this trade (e.g., NCCER certification, state electrical license, AWS welding certification, NCCCO crane operator certification). Multiple certifications may be listed as comma-separated values.' ;
    rdfs:domain ind:SkillTrade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equipmentDependencyFlag rdf:type rdf:Property ;
    rdfs:label 'Equipment Dependency Flag' ;
    rdfs:comment 'Indicates whether this trade requires specialized heavy equipment or machinery to perform work (e.g., crane operators require cranes, equipment operators require excavators). True if equipment-dependent; false if primarily manual labor.' ;
    rdfs:domain ind:SkillTrade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hazardExposureLevel rdf:type rdf:Property ;
    rdfs:label 'Hazard Exposure Level' ;
    rdfs:comment 'Classification of typical occupational hazard exposure level for this trade (low, moderate, high, extreme). Used for risk assessment, insurance rating, and HSE planning.' ;
    rdfs:domain ind:SkillTrade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:laborShortageIndicator rdf:type rdf:Property ;
    rdfs:label 'Labor Shortage Indicator' ;
    rdfs:comment 'Current market assessment of labor availability for this trade (surplus, balanced, shortage, critical shortage). Used for strategic workforce planning and recruitment prioritization.' ;
    rdfs:domain ind:SkillTrade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mepDisciplineFlag rdf:type rdf:Property ;
    rdfs:label 'Mep Discipline Flag' ;
    rdfs:comment 'Indicates whether this trade is part of the MEP (Mechanical, Electrical, and Plumbing) disciplines. True for electricians, pipefitters, HVAC technicians, plumbers; false for structural and civil trades.' ;
    rdfs:domain ind:SkillTrade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:oshaTrainingRequirement rdf:type rdf:Property ;
    rdfs:label 'Osha Training Requirement' ;
    rdfs:comment 'Specific OSHA training courses or certifications required for this trade (e.g., OSHA 10-hour, OSHA 30-hour, confined space, fall protection, scaffolding). Used for safety compliance and site access control.' ;
    rdfs:domain ind:SkillTrade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:physicalDemandRating rdf:type rdf:Property ;
    rdfs:label 'Physical Demand Rating' ;
    rdfs:comment 'Classification of physical exertion and strength requirements for this trade (light, medium, heavy, very heavy). Used for workforce health management and ergonomic planning.' ;
    rdfs:domain ind:SkillTrade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seasonalDemandPattern rdf:type rdf:Property ;
    rdfs:label 'Seasonal Demand Pattern' ;
    rdfs:comment 'Description of typical seasonal demand fluctuation for this trade (e.g., high demand in summer for outdoor trades, year-round for indoor MEP work). Used for workforce capacity planning and recruitment timing.' ;
    rdfs:domain ind:SkillTrade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:skillLevelTiers rdf:type rdf:Property ;
    rdfs:label 'Skill Level Tiers' ;
    rdfs:comment 'Defined progression tiers or grades within this trade (e.g., apprentice, journeyman, foreman, general foreman, superintendent). Used for career path planning and labor rate determination. Typically stored as comma-separated hierarchy.' ;
    rdfs:domain ind:SkillTrade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradeCategory rdf:type rdf:Property ;
    rdfs:label 'Trade Category' ;
    rdfs:comment 'High-level classification grouping of the trade skill (structural, mechanical, electrical, civil, finishing, equipment operation, specialty). Used for workforce segmentation and reporting. [ENUM-REF-CANDIDATE: structural|mechanical|electrical|civil|finishing|equipment_operation|specialty — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SkillTrade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradeCode rdf:type rdf:Property ;
    rdfs:label 'Trade Code' ;
    rdfs:comment 'Standardized alphanumeric code identifying the construction trade or craft discipline (e.g., IW for ironworker, EL for electrician, CP for carpenter). Used for workforce planning, labor rate determination, and crew composition.' ;
    rdfs:domain ind:SkillTrade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradeName rdf:type rdf:Property ;
    rdfs:label 'Trade Name' ;
    rdfs:comment 'Full descriptive name of the construction trade or craft discipline (e.g., Ironworker, Pipefitter, Electrician, Carpenter, Concrete Finisher, Heavy Equipment Operator, Rigger, Welder).' ;
    rdfs:domain ind:SkillTrade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradeStatus rdf:type rdf:Property ;
    rdfs:label 'Trade Status' ;
    rdfs:comment 'Current lifecycle status of the trade skill classification. Active trades are available for workforce planning and assignment; inactive trades are no longer used; obsolete trades are deprecated; emerging trades are newly recognized.' ;
    rdfs:domain ind:SkillTrade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:travelRequirementTypical rdf:type rdf:Property ;
    rdfs:label 'Travel Requirement Typical' ;
    rdfs:comment 'Typical geographic travel requirement for workers in this trade (none, local, regional, national, international). Used for workforce planning and per diem budgeting.' ;
    rdfs:domain ind:SkillTrade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unionJurisdictionCode rdf:type rdf:Property ;
    rdfs:label 'Union Jurisdiction Code' ;
    rdfs:comment 'Code identifying the labor union or trade union that has jurisdiction over this craft discipline (e.g., IBEW for electricians, UA for pipefitters, IUOE for operators). Used for labor relations, collective bargaining, and compliance.' ;
    rdfs:domain ind:SkillTrade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unionJurisdictionName rdf:type rdf:Property ;
    rdfs:label 'Union Jurisdiction Name' ;
    rdfs:comment 'Full name of the labor union or trade union with jurisdiction over this craft (e.g., International Brotherhood of Electrical Workers, United Association of Plumbers and Pipefitters).' ;
    rdfs:domain ind:SkillTrade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:laborMobilizationId rdf:type rdf:Property ;
    rdfs:label 'Labor Mobilization Id' ;
    rdfs:comment 'Unique identifier for the labor mobilization record. Primary key for tracking worker movement to/from project sites.' ;
    rdfs:domain ind:LaborMobilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:destinationConstructionProjectId rdf:type rdf:Property ;
    rdfs:label 'Destination Construction Project Id' ;
    rdfs:comment 'Identifier of the project site the worker is mobilizing to. Null for demobilizations.' ;
    rdfs:domain ind:LaborMobilization ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ConstructionProject .

ind:primaryLaborConstructionProjectId rdf:type rdf:Property ;
    rdfs:label 'Primary Labor Construction Project Id' ;
    rdfs:comment 'Identifier of the project site the worker is mobilizing from. Null for initial mobilizations.' ;
    rdfs:domain ind:LaborMobilization ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ConstructionProject .

ind:staffingPlanId rdf:type rdf:Property ;
    rdfs:label 'Staffing Plan Id' ;
    rdfs:comment 'Foreign key linking to workforce.staffing_plan. Business justification: Labor mobilizations are triggered by staffing plans — when a staffing plan calls for workers to be deployed to a project, mobilization records are created to track the physical movement of those worke' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StaffingPlan .

ind:accommodationBookingReference rdf:type rdf:Property ;
    rdfs:label 'Accommodation Booking Reference' ;
    rdfs:comment 'Booking confirmation number for temporary accommodation (hotel, camp, rental housing).' ;
    rdfs:domain ind:LaborMobilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accommodationCostEstimate rdf:type rdf:Property ;
    rdfs:label 'Accommodation Cost Estimate' ;
    rdfs:comment 'Estimated total cost of temporary accommodation for the mobilization period.' ;
    rdfs:domain ind:LaborMobilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:accommodationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Accommodation Required Flag' ;
    rdfs:comment 'Indicates whether temporary accommodation is required at the destination site (True) or not (False).' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:actualArrivalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Arrival Timestamp' ;
    rdfs:comment 'Actual date and time the worker arrived at the destination project site, recorded for compliance and payroll purposes.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualDepartureTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Departure Timestamp' ;
    rdfs:comment 'Actual date and time the worker departed from the origin project site, recorded for compliance and payroll purposes.' ;
    rdfs:domain ind:LaborMobilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:mobilizationReason rdf:type rdf:Property ;
    rdfs:label 'Mobilization Reason' ;
    rdfs:comment 'Business justification or reason for the mobilization (e.g., project ramp-up, skill shortage, emergency response, project closeout).' ;
    rdfs:domain ind:LaborMobilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:perDiemDurationDays rdf:type rdf:Property ;
    rdfs:label 'Per Diem Duration Days' ;
    rdfs:comment 'Number of days the worker is entitled to receive per diem allowance.' ;
    rdfs:domain ind:LaborMobilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:siteAccessBadgeIssuedFlag rdf:type rdf:Property ;
    rdfs:label 'Site Access Badge Issued Flag' ;
    rdfs:comment 'Indicates whether a site access badge or credential has been issued to the worker at the destination site (True) or not (False).' ;
    rdfs:domain ind:LaborMobilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:specialRequirements rdf:type rdf:Property ;
    rdfs:label 'Special Requirements' ;
    rdfs:comment 'Any special requirements or considerations for the mobilization such as medical accommodations, dietary restrictions, security clearances, or equipment transport needs.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalMobilizationCost rdf:type rdf:Property ;
    rdfs:label 'Total Mobilization Cost' ;
    rdfs:comment 'Total estimated or actual cost of the mobilization including travel, accommodation, per diem, and administrative expenses.' ;
    rdfs:domain ind:LaborMobilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:travelBookingReference rdf:type rdf:Property ;
    rdfs:label 'Travel Booking Reference' ;
    rdfs:comment 'Booking confirmation number or reference code for travel arrangements (flight, train, rental car).' ;
    rdfs:domain ind:LaborMobilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:travelCostEstimate rdf:type rdf:Property ;
    rdfs:label 'Travel Cost Estimate' ;
    rdfs:comment 'Estimated total cost of travel arrangements including airfare, ground transportation, and related expenses.' ;
    rdfs:domain ind:LaborMobilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:travelMode rdf:type rdf:Property ;
    rdfs:label 'Travel Mode' ;
    rdfs:comment 'Primary mode of transportation arranged for the worker\'s mobilization journey.' ;
    rdfs:domain ind:LaborMobilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scopeId rdf:type rdf:Property ;
    rdfs:label 'Scope Id' ;
    rdfs:comment 'Foreign key linking to contract.contract_scope. Business justification: Scope-based labor planning: staffing plans are built against specific contract scope packages in construction. Project controls require direct traceability from contract scope to its staffing plan for' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Scope .

ind:actualHeadcount rdf:type rdf:Property ;
    rdfs:label 'Actual Headcount' ;
    rdfs:comment 'Actual number of workers deployed as of the last reporting period, enabling planned vs. actual variance analysis.' ;
    rdfs:domain ind:StaffingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualLaborHours rdf:type rdf:Property ;
    rdfs:label 'Actual Labor Hours' ;
    rdfs:comment 'Actual labor hours worked as of the last reporting period, supporting Earned Value Management (EVM) and productivity tracking.' ;
    rdfs:domain ind:StaffingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:agencyHeadcount rdf:type rdf:Property ;
    rdfs:label 'Agency Headcount' ;
    rdfs:comment 'Number of workers planned to be sourced through temporary staffing agencies or labor brokers.' ;
    rdfs:domain ind:StaffingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:baselineFlag rdf:type rdf:Property ;
    rdfs:label 'Baseline Flag' ;
    rdfs:comment 'Indicates whether this staffing plan is the approved baseline against which all future revisions and actuals will be compared.' ;
    rdfs:domain ind:StaffingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:craftLaborHeadcount rdf:type rdf:Property ;
    rdfs:label 'Craft Labor Headcount' ;
    rdfs:comment 'Number of skilled trade workers (carpenters, electricians, welders, masons, etc.) planned for the period.' ;
    rdfs:domain ind:StaffingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:directHireHeadcount rdf:type rdf:Property ;
    rdfs:label 'Direct Hire Headcount' ;
    rdfs:comment 'Number of workers planned to be sourced through direct employment by the general contractor or project owner.' ;
    rdfs:domain ind:StaffingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:headcountVariance rdf:type rdf:Property ;
    rdfs:label 'Headcount Variance' ;
    rdfs:comment 'Difference between planned and actual headcount (actual minus planned), indicating over- or under-staffing relative to the plan.' ;
    rdfs:domain ind:StaffingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:laborHoursVariance rdf:type rdf:Property ;
    rdfs:label 'Labor Hours Variance' ;
    rdfs:comment 'Difference between planned and actual labor hours (actual minus planned), supporting cost and schedule performance analysis.' ;
    rdfs:domain ind:StaffingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:peakHeadcount rdf:type rdf:Property ;
    rdfs:label 'Peak Headcount' ;
    rdfs:comment 'Maximum number of workers required at any single point during the planning period, critical for site logistics, accommodation, and safety planning.' ;
    rdfs:domain ind:StaffingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:peakHeadcountDate rdf:type rdf:Property ;
    rdfs:label 'Peak Headcount Date' ;
    rdfs:comment 'Date on which the peak headcount is expected to occur, enabling targeted resource mobilization and site readiness planning.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planningPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Planning Period End Date' ;
    rdfs:comment 'End date of the time period covered by this staffing plan, defining the conclusion of the workforce deployment window.' ;
    rdfs:domain ind:StaffingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planningPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Planning Period Start Date' ;
    rdfs:comment 'Start date of the time period covered by this staffing plan, defining the beginning of the workforce deployment window.' ;
    rdfs:domain ind:StaffingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rampDownEndDate rdf:type rdf:Property ;
    rdfs:label 'Ramp Down End Date' ;
    rdfs:comment 'Date when workforce demobilization is complete, marking the end of the labor deployment for this plan.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rampDownStartDate rdf:type rdf:Property ;
    rdfs:label 'Ramp Down Start Date' ;
    rdfs:comment 'Date when workforce demobilization begins, marking the start of the labor reduction curve as project activities wind down.' ;
    rdfs:domain ind:StaffingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rampUpEndDate rdf:type rdf:Property ;
    rdfs:label 'Ramp Up End Date' ;
    rdfs:comment 'Date when workforce reaches full planned strength, marking the end of the mobilization phase.' ;
    rdfs:domain ind:StaffingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rampUpStartDate rdf:type rdf:Property ;
    rdfs:label 'Ramp Up Start Date' ;
    rdfs:comment 'Date when workforce mobilization and ramp-up begins, marking the start of the labor deployment curve.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:siteAccessRequirements rdf:type rdf:Property ;
    rdfs:label 'Site Access Requirements' ;
    rdfs:comment 'Description of site access prerequisites for workers (security clearances, background checks, client-specific badging), critical for mobilization planning.' ;
    rdfs:domain ind:StaffingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:skillCertificationRequirements rdf:type rdf:Property ;
    rdfs:label 'Skill Certification Requirements' ;
    rdfs:comment 'Summary of mandatory certifications and qualifications required for workers in this staffing plan (e.g., \'OSHA 30, Confined Space, Rigging Level II\'), supporting compliance and safety planning.' ;
    rdfs:domain ind:StaffingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourcingStrategy rdf:type rdf:Property ;
    rdfs:label 'Sourcing Strategy' ;
    rdfs:comment 'Primary workforce sourcing approach for this staffing plan, defining how labor will be procured and managed.' ;
    rdfs:domain ind:StaffingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subcontractorHeadcount rdf:type rdf:Property ;
    rdfs:label 'Subcontractor Headcount' ;
    rdfs:comment 'Number of workers planned to be provided by subcontractors under contract to the general contractor.' ;
    rdfs:domain ind:StaffingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:supervisionHeadcount rdf:type rdf:Property ;
    rdfs:label 'Supervision Headcount' ;
    rdfs:comment 'Number of supervisory personnel (foremen, superintendents, site managers) planned for the period.' ;
    rdfs:domain ind:StaffingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:supportStaffHeadcount rdf:type rdf:Property ;
    rdfs:label 'Support Staff Headcount' ;
    rdfs:comment 'Number of support personnel (site engineers, QA/QC inspectors, safety officers, administrative staff) planned for the period.' ;
    rdfs:domain ind:StaffingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalPlannedHeadcount rdf:type rdf:Property ;
    rdfs:label 'Total Planned Headcount' ;
    rdfs:comment 'Total number of workers planned across all trades and roles for this staffing plan period, representing the aggregate workforce requirement.' ;
    rdfs:domain ind:StaffingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalPlannedLaborHours rdf:type rdf:Property ;
    rdfs:label 'Total Planned Labor Hours' ;
    rdfs:comment 'Total labor hours planned across all workers and trades for the planning period, used for cost estimation and productivity forecasting.' ;
    rdfs:domain ind:StaffingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tradeMixBreakdown rdf:type rdf:Property ;
    rdfs:label 'Trade Mix Breakdown' ;
    rdfs:comment 'Structured breakdown of planned headcount by trade category (e.g., \'Concrete:50|Steel:30|Electrical:25|Plumbing:20\'), supporting trade-specific procurement and scheduling.' ;
    rdfs:domain ind:StaffingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transportationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Transportation Required Flag' ;
    rdfs:comment 'Indicates whether worker transportation (buses, flights, shuttles) is required for this staffing plan, impacting mobilization logistics and costs.' ;
    rdfs:domain ind:StaffingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:apprenticeRatio rdf:type rdf:Property ;
    rdfs:label 'Apprentice Ratio' ;
    rdfs:comment 'The maximum allowable ratio of apprentices to journeymen for this trade classification, as defined by union agreements or prevailing wage law (e.g., 1:3 means one apprentice per three journeymen). Nullable if not applicable.' ;
    rdfs:domain ind:LaborRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:baseHourlyRate rdf:type rdf:Property ;
    rdfs:label 'Base Hourly Rate' ;
    rdfs:comment 'The straight-time hourly wage rate paid to the worker for regular hours (typically up to 8 hours per day or 40 hours per week). Excludes fringe benefits and burden.' ;
    rdfs:domain ind:LaborRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:certifiedPayrollRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Certified Payroll Required Flag' ;
    rdfs:comment 'Indicates whether this rate is subject to certified payroll reporting requirements under prevailing wage law (True) or not (False). Used to trigger compliance workflows in HCSS HeavyJob and Viewpoint Vista.' ;
    rdfs:domain ind:LaborRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:doubleTimeHourlyRate rdf:type rdf:Property ;
    rdfs:label 'Double Time Hourly Rate' ;
    rdfs:comment 'The hourly wage rate for double-time hours, typically 2.0x the base rate for hours worked on Sundays, holidays, or beyond a threshold (e.g., over 12 hours per day). Nullable if not applicable.' ;
    rdfs:domain ind:LaborRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:escalationClause rdf:type rdf:Property ;
    rdfs:label 'Escalation Clause' ;
    rdfs:comment 'Description of any contractual escalation provisions that adjust this rate over time (e.g., annual CPI adjustment, fixed percentage increase, renegotiation trigger). Nullable if no escalation applies.' ;
    rdfs:domain ind:LaborRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fringeBenefitRate rdf:type rdf:Property ;
    rdfs:label 'Fringe Benefit Rate' ;
    rdfs:comment 'The hourly cost of fringe benefits (health insurance, pension, vacation, training funds, etc.) as defined by the labor agreement or prevailing wage determination. Added to base wage to calculate total compensation.' ;
    rdfs:domain ind:LaborRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:jurisdiction rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction' ;
    rdfs:comment 'The geographic or contractual jurisdiction where this rate applies (e.g., Cook County IL, State of California, Federal Davis-Bacon). Used to enforce prevailing wage compliance.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overheadPercentage rdf:type rdf:Property ;
    rdfs:label 'Overhead Percentage' ;
    rdfs:comment 'The percentage markup applied to cover indirect costs and general overhead (field supervision, small tools, consumables, field office, etc.). Used in bid pricing and Guaranteed Maximum Price (GMP) calculations. Nullable if not applicable.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overtimeHourlyRate rdf:type rdf:Property ;
    rdfs:label 'Overtime Hourly Rate' ;
    rdfs:comment 'The hourly wage rate for overtime hours, typically 1.5x the base rate for hours beyond 8 per day or 40 per week, as defined by labor agreements or prevailing wage law.' ;
    rdfs:domain ind:LaborRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:payrollBurdenPercentage rdf:type rdf:Property ;
    rdfs:label 'Payroll Burden Percentage' ;
    rdfs:comment 'The percentage markup applied to gross wages to cover employer-paid payroll taxes (FICA, FUTA, SUTA, workers compensation insurance, general liability insurance). Expressed as a percentage (e.g., 35.50 for 35.5%).' ;
    rdfs:domain ind:LaborRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:prevailingWageDeterminationNumber rdf:type rdf:Property ;
    rdfs:label 'Prevailing Wage Determination Number' ;
    rdfs:comment 'The official reference number of the government-issued prevailing wage determination (e.g., Davis-Bacon wage decision number) that mandates this rate. Nullable for non-prevailing-wage projects.' ;
    rdfs:domain ind:LaborRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profitMarginPercentage rdf:type rdf:Property ;
    rdfs:label 'Profit Margin Percentage' ;
    rdfs:comment 'The profit margin percentage applied to the fully burdened labor cost for bid pricing. Used in EPC (Engineering, Procurement, and Construction) and GMP (Guaranteed Maximum Price) contracts. Nullable if not applicable.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rateCode rdf:type rdf:Property ;
    rdfs:label 'Rate Code' ;
    rdfs:comment 'Business identifier for the labor rate. Typically a concatenation of trade classification, skill level, and agreement reference used in estimating and job costing systems.' ;
    rdfs:domain ind:LaborRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateStatus rdf:type rdf:Property ;
    rdfs:label 'Rate Status' ;
    rdfs:comment 'Current lifecycle status of the labor rate record. Active rates are used in cost estimation and job costing. Expired or superseded rates are retained for historical cost analysis and audit trails.' ;
    rdfs:domain ind:LaborRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateType rdf:type rdf:Property ;
    rdfs:label 'Rate Type' ;
    rdfs:comment 'Classification of the rate basis: union (collective bargaining agreement), prevailing_wage (government-mandated), open_shop (non-union competitive), project_specific (negotiated for a single project), or market_rate (regional benchmark).' ;
    rdfs:domain ind:LaborRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shiftDifferentialRate rdf:type rdf:Property ;
    rdfs:label 'Shift Differential Rate' ;
    rdfs:comment 'Additional hourly premium paid for non-standard shifts (e.g., night shift, swing shift). Nullable if not applicable. Used in 24/7 operations and accelerated project schedules.' ;
    rdfs:domain ind:LaborRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:subsistenceRate rdf:type rdf:Property ;
    rdfs:label 'Subsistence Rate' ;
    rdfs:comment 'Daily subsistence allowance for lodging and living expenses when workers are required to stay overnight away from home. Nullable if not applicable. Used in remote project cost planning.' ;
    rdfs:domain ind:LaborRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalLoadedHourlyRate rdf:type rdf:Property ;
    rdfs:label 'Total Loaded Hourly Rate' ;
    rdfs:comment 'The all-in hourly cost including base wage, fringe benefits, payroll burden, overhead, and profit. This is the rate used for project cost estimation, Bill of Quantities (BOQ) pricing, and Earned Value Management (EVM) calculations.' ;
    rdfs:domain ind:LaborRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:travelZone rdf:type rdf:Property ;
    rdfs:label 'Travel Zone' ;
    rdfs:comment 'The geographic travel zone or radius from the union hall or home base that determines eligibility for travel pay, per diem, and subsistence. Nullable if not applicable.' ;
    rdfs:domain ind:LaborRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correspondenceId rdf:type rdf:Property ;
    rdfs:label 'Correspondence Id' ;
    rdfs:comment 'Unique identifier for the correspondence record. Primary key.' ;
    rdfs:domain ind:Correspondence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:parentCorrespondenceId rdf:type rdf:Property ;
    rdfs:label 'Parent Correspondence Id' ;
    rdfs:comment 'Reference to the parent correspondence record if this item is part of a threaded response chain. Nullable for root correspondence items.' ;
    rdfs:domain ind:Correspondence ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Correspondence .

ind:recipientContactId rdf:type rdf:Property ;
    rdfs:label 'Recipient Contact Id' ;
    rdfs:comment 'Foreign key linking to client.contact. Business justification: Client-directed correspondence is formally addressed to a specific client contact. recipient_name and recipient_email are plain-text denormalizations of client.contact. A FK supports correspondence tr' ;
    rdfs:domain ind:Design ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Contact .

ind:senderAccountId rdf:type rdf:Property ;
    rdfs:label 'Sender Account Id' ;
    rdfs:comment 'Foreign key linking to client.account. Business justification: Required for client communication log linking each sent correspondence to the originating client account.' ;
    rdfs:domain ind:Design ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Account .

ind:attachmentCount rdf:type rdf:Property ;
    rdfs:label 'Attachment Count' ;
    rdfs:comment 'Number of document attachments associated with this correspondence item (drawings, specifications, photos, reports).' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bodyText rdf:type rdf:Property ;
    rdfs:label 'Body Text' ;
    rdfs:comment 'Full text content of the correspondence message or letter body.' ;
    rdfs:domain ind:Correspondence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closureStatus rdf:type rdf:Property ;
    rdfs:label 'Closure Status' ;
    rdfs:comment 'Final closure status indicating whether the correspondence thread was accepted, rejected, or superseded by subsequent correspondence.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confidentialFlag rdf:type rdf:Property ;
    rdfs:label 'Confidential Flag' ;
    rdfs:comment 'Boolean indicator whether this correspondence is marked as confidential and subject to restricted access controls.' ;
    rdfs:domain ind:Correspondence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:correspondenceDate rdf:type rdf:Property ;
    rdfs:label 'Correspondence Date' ;
    rdfs:comment 'The date the correspondence was officially issued or sent. This is the principal business event timestamp for the correspondence lifecycle.' ;
    rdfs:domain ind:Correspondence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:correspondenceNumber rdf:type rdf:Property ;
    rdfs:label 'Correspondence Number' ;
    rdfs:comment 'Externally-known unique business identifier for the correspondence item as registered in the Aconex mail register. This is the official reference number used in contractual communications.' ;
    rdfs:domain ind:Correspondence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correspondenceStatus rdf:type rdf:Property ;
    rdfs:label 'Correspondence Status' ;
    rdfs:comment 'Current lifecycle status of the correspondence item tracking its workflow state from draft through closure.' ;
    rdfs:domain ind:Correspondence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correspondenceType rdf:type rdf:Property ;
    rdfs:label 'Correspondence Type' ;
    rdfs:comment 'Classification of the correspondence item. RFI (Request for Information), instruction, notice, claim, letter, or memo.' ;
    rdfs:domain ind:Correspondence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionList rdf:type rdf:Property ;
    rdfs:label 'Distribution List' ;
    rdfs:comment 'Comma-separated list of additional parties or roles who were copied on this correspondence for information or action.' ;
    rdfs:domain ind:Design ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recipientOrganization rdf:type rdf:Property ;
    rdfs:label 'Recipient Organization' ;
    rdfs:comment 'Name of the organization receiving the correspondence (contractor, client, consultant, subcontractor, or authority).' ;
    rdfs:domain ind:Design ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseDate rdf:type rdf:Property ;
    rdfs:label 'Response Date' ;
    rdfs:comment 'The date a formal response was issued for this correspondence. Nullable if no response has been provided.' ;
    rdfs:domain ind:Correspondence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:responseDueDate rdf:type rdf:Property ;
    rdfs:label 'Response Due Date' ;
    rdfs:comment 'The contractual or agreed date by which a response to this correspondence must be provided. Nullable if no response is required.' ;
    rdfs:domain ind:Design ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:responseMethod rdf:type rdf:Property ;
    rdfs:label 'Response Method' ;
    rdfs:comment 'The method or channel through which the response was delivered (email, formal letter, transmittal, meeting minutes, phone call).' ;
    rdfs:domain ind:Correspondence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Response Required Flag' ;
    rdfs:comment 'Boolean indicator whether a formal response is required for this correspondence.' ;
    rdfs:domain ind:Correspondence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:responseText rdf:type rdf:Property ;
    rdfs:label 'Response Text' ;
    rdfs:comment 'Full text content of the response provided to this correspondence. Nullable if no response has been issued.' ;
    rdfs:domain ind:Correspondence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:senderEmail rdf:type rdf:Property ;
    rdfs:label 'Sender Email' ;
    rdfs:comment 'Email address of the sender for correspondence tracking and response routing.' ;
    rdfs:domain ind:Design ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:senderName rdf:type rdf:Property ;
    rdfs:label 'Sender Name' ;
    rdfs:comment 'Full name of the individual who authored or sent the correspondence.' ;
    rdfs:domain ind:Correspondence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subject rdf:type rdf:Property ;
    rdfs:label 'Subject' ;
    rdfs:comment 'Subject line or title of the correspondence describing the topic or issue being communicated.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acknowledgementBy rdf:type rdf:Property ;
    rdfs:label 'Acknowledgement By' ;
    rdfs:comment 'Full name of the individual who provided formal acknowledgement on behalf of the recipient organization. Establishes personal accountability for receipt confirmation.' ;
    rdfs:domain ind:Transmittal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acknowledgementDate rdf:type rdf:Property ;
    rdfs:label 'Acknowledgement Date' ;
    rdfs:comment 'The date when the recipient formally acknowledged receipt of the transmittal. Null if not yet acknowledged. Provides legally defensible proof of document delivery.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acknowledgementRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Acknowledgement Required Flag' ;
    rdfs:comment 'Boolean indicator specifying whether the recipient is required to formally acknowledge receipt of the transmittal. True indicates acknowledgement is mandatory.' ;
    rdfs:domain ind:Transmittal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:acknowledgementStatus rdf:type rdf:Property ;
    rdfs:label 'Acknowledgement Status' ;
    rdfs:comment 'Current status of recipient acknowledgement tracking. Indicates whether the transmittal has been formally acknowledged by the recipient organization.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confidentialityLevel rdf:type rdf:Property ;
    rdfs:label 'Confidentiality Level' ;
    rdfs:comment 'Data classification level indicating the sensitivity and access restrictions applicable to the transmittal and its enclosed documents.' ;
    rdfs:domain ind:Design ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentCount rdf:type rdf:Property ;
    rdfs:label 'Document Count' ;
    rdfs:comment 'Total number of individual documents or drawings included in this transmittal package. Used for completeness verification and audit trail.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:purposeOfIssue rdf:type rdf:Property ;
    rdfs:label 'Purpose Of Issue' ;
    rdfs:comment 'The intended purpose or action required from the recipient upon receiving the transmittal. Defines the business intent behind the document distribution and guides recipient response obligations.' ;
    rdfs:domain ind:Transmittal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referenceTransmittalNumber rdf:type rdf:Property ;
    rdfs:label 'Reference Transmittal Number' ;
    rdfs:comment 'Transmittal number of a previous or related transmittal that this transmittal references, supersedes, or responds to. Establishes document lineage and traceability.' ;
    rdfs:domain ind:Transmittal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:senderContactName rdf:type rdf:Property ;
    rdfs:label 'Sender Contact Name' ;
    rdfs:comment 'Full name of the individual within the sender organization who prepared and issued the transmittal. Provides personal accountability for document distribution.' ;
    rdfs:domain ind:Transmittal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transmittalDescription rdf:type rdf:Property ;
    rdfs:label 'Transmittal Description' ;
    rdfs:comment 'Detailed narrative description of the transmittal contents, context, and any special instructions or notes for the recipient. Provides comprehensive background information.' ;
    rdfs:domain ind:Transmittal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transmittalNumber rdf:type rdf:Property ;
    rdfs:label 'Transmittal Number' ;
    rdfs:comment 'Unique business identifier for the transmittal as recognized by all project parties. Typically follows project-specific numbering conventions and serves as the externally-known reference for document distribution tracking.' ;
    rdfs:domain ind:Design ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transmittalStatus rdf:type rdf:Property ;
    rdfs:label 'Transmittal Status' ;
    rdfs:comment 'Current lifecycle status of the transmittal indicating its position in the document distribution workflow. Tracks progression from draft through issuance to acknowledgement or closure.' ;
    rdfs:domain ind:Transmittal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specificationId rdf:type rdf:Property ;
    rdfs:label 'Specification Id' ;
    rdfs:comment 'Foreign key linking to material.specification. Business justification: RFIs in construction are frequently raised to clarify or challenge material specifications (substitution requests, grade clarifications). Linking an RFI to the specific material specification being qu' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Specification .

ind:actualResponseDate rdf:type rdf:Property ;
    rdfs:label 'Actual Response Date' ;
    rdfs:comment 'The actual date on which the RFI response was provided and recorded in the system.' ;
    rdfs:domain ind:Rfi ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:closureNotes rdf:type rdf:Property ;
    rdfs:label 'Closure Notes' ;
    rdfs:comment 'Additional notes or comments recorded at the time of RFI closure, documenting final resolution or outstanding items.' ;
    rdfs:domain ind:Rfi ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dateRaised rdf:type rdf:Property ;
    rdfs:label 'Date Raised' ;
    rdfs:comment 'The date on which the RFI was formally submitted or raised in the project management system.' ;
    rdfs:domain ind:Design ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:responseContent rdf:type rdf:Property ;
    rdfs:label 'Response Content' ;
    rdfs:comment 'Detailed text of the response provided by the addressee, including clarifications, instructions, or references to supporting documentation.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseTimeDays rdf:type rdf:Property ;
    rdfs:label 'Response Time Days' ;
    rdfs:comment 'Calculated number of calendar days between date raised and actual response date, used for performance tracking and SLA compliance.' ;
    rdfs:domain ind:Rfi ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rfiDescription rdf:type rdf:Property ;
    rdfs:label 'Rfi Description' ;
    rdfs:comment 'Detailed description of the question, issue, or clarification being requested, including context and specific areas of concern.' ;
    rdfs:domain ind:Rfi ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rfiNumber rdf:type rdf:Property ;
    rdfs:label 'Rfi Number' ;
    rdfs:comment 'Business identifier for the RFI, typically a sequential or structured code used for tracking and reference in project documentation and correspondence.' ;
    rdfs:domain ind:Rfi ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rfiStatus rdf:type rdf:Property ;
    rdfs:label 'Rfi Status' ;
    rdfs:comment 'Current lifecycle status of the RFI indicating its position in the review and response workflow.' ;
    rdfs:domain ind:Rfi ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Schedule Impact Flag' ;
    rdfs:comment 'Indicates whether the RFI response has identified a potential schedule impact, potentially triggering an Extension of Time (EOT) request.' ;
    rdfs:domain ind:Design ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rfiDocumentRfiId rdf:type rdf:Property ;
    rdfs:label 'Rfi Document Rfi Id' ;
    rdfs:comment 'Foreign key linking to design.rfi. Business justification: RFI is currently siloed; adding a foreign key from document_register to rfi creates an inbound link and removes the redundant string reference column.' ;
    rdfs:domain ind:DocumentRegister ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Rfi .

ind:confidentialityClassification rdf:type rdf:Property ;
    rdfs:label 'Confidentiality Classification' ;
    rdfs:comment 'Security classification level of the document content determining access rights and distribution restrictions.' ;
    rdfs:domain ind:Design ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentPurpose rdf:type rdf:Property ;
    rdfs:label 'Document Purpose' ;
    rdfs:comment 'Brief statement describing the intended use and purpose of the document within the project context.' ;
    rdfs:domain ind:DocumentRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentRegisterStatus rdf:type rdf:Property ;
    rdfs:label 'Document Register Status' ;
    rdfs:comment 'Current lifecycle status of the document in the approval and distribution workflow. [ENUM-REF-CANDIDATE: draft|in_review|approved|issued_for_construction|issued_for_information|issued_for_tender|superseded|archived|void|cancelled — promote to reference product]' ;
    rdfs:domain ind:DocumentRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentTitle rdf:type rdf:Property ;
    rdfs:label 'Document Title' ;
    rdfs:comment 'Full descriptive title of the document as it appears on the document itself.' ;
    rdfs:domain ind:DocumentRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fileFormat rdf:type rdf:Property ;
    rdfs:label 'File Format' ;
    rdfs:comment 'Digital file format of the document (e.g., PDF for specifications, DWG for CAD drawings, RVT for Revit models). [ENUM-REF-CANDIDATE: PDF|DOCX|XLSX|DWG|RVT|IFC|XML — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Design ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fileSizeMb rdf:type rdf:Property ;
    rdfs:label 'File Size Mb' ;
    rdfs:comment 'Size of the document file in megabytes for storage and transmission planning.' ;
    rdfs:domain ind:Design ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isClientDeliverable rdf:type rdf:Property ;
    rdfs:label 'Is Client Deliverable' ;
    rdfs:comment 'Flag indicating whether this document is a contractual deliverable to the client requiring formal acceptance.' ;
    rdfs:domain ind:Design ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isControlledDocument rdf:type rdf:Property ;
    rdfs:label 'Is Controlled Document' ;
    rdfs:comment 'Flag indicating whether this document is subject to formal change control procedures and requires approval for any modifications.' ;
    rdfs:domain ind:Design ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:keywords rdf:type rdf:Property ;
    rdfs:label 'Keywords' ;
    rdfs:comment 'Comma-separated list of keywords or tags for document search and categorization purposes.' ;
    rdfs:domain ind:DocumentRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:languageCode rdf:type rdf:Property ;
    rdfs:label 'Language Code' ;
    rdfs:comment 'Three-letter ISO 639-2 code representing the primary language of the document content. [ENUM-REF-CANDIDATE: ENG|SPA|FRA|DEU|ARA|CHI|POR — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Design ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pageCount rdf:type rdf:Property ;
    rdfs:label 'Page Count' ;
    rdfs:comment 'Total number of pages in the document for printing and review planning purposes.' ;
    rdfs:domain ind:Design ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:retentionPeriodYears rdf:type rdf:Property ;
    rdfs:label 'Retention Period Years' ;
    rdfs:comment 'Number of years the document must be retained per regulatory, contractual, or organizational requirements before eligible for disposal.' ;
    rdfs:domain ind:Design ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reviewerName rdf:type rdf:Property ;
    rdfs:label 'Reviewer Name' ;
    rdfs:comment 'Name of the individual who reviewed the document for technical accuracy and completeness.' ;
    rdfs:domain ind:Design ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revisionDescription rdf:type rdf:Property ;
    rdfs:label 'Revision Description' ;
    rdfs:comment 'Brief description of the changes made in the current revision compared to the previous version.' ;
    rdfs:domain ind:Design ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageLocation rdf:type rdf:Property ;
    rdfs:label 'Storage Location' ;
    rdfs:comment 'Physical or digital location where the document is stored (e.g., Aconex folder path, SharePoint site, physical archive location).' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supersededByDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Superseded By Document Number' ;
    rdfs:comment 'Document number of the newer document that supersedes this document, if applicable. Used to maintain document lineage and version control.' ;
    rdfs:domain ind:DocumentRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supersedesDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Supersedes Document Number' ;
    rdfs:comment 'Document number of the older document that this document supersedes or replaces.' ;
    rdfs:domain ind:DocumentRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revisionId rdf:type rdf:Property ;
    rdfs:label 'Revision Id' ;
    rdfs:comment 'Primary key for revision' ;
    rdfs:domain ind:Design ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Revision .

ind:supersededRevisionId rdf:type rdf:Property ;
    rdfs:label 'Superseded Revision Id' ;
    rdfs:comment 'Reference to the previous revision that this version replaces. Maintains the revision chain and version history.' ;
    rdfs:domain ind:Revision ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Revision .

ind:authorName rdf:type rdf:Property ;
    rdfs:label 'Author Name' ;
    rdfs:comment 'Full name of the individual who authored or prepared this revision. Responsible party for the content creation.' ;
    rdfs:domain ind:Design ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeReason rdf:type rdf:Property ;
    rdfs:label 'Change Reason' ;
    rdfs:comment 'Primary reason or trigger for this revision. Categorizes the business driver behind the document update.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeSummary rdf:type rdf:Property ;
    rdfs:label 'Change Summary' ;
    rdfs:comment 'Concise summary of the specific changes made in this revision compared to the previous version. Highlights key modifications, additions, or deletions.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checksumHash rdf:type rdf:Property ;
    rdfs:label 'Checksum Hash' ;
    rdfs:comment 'Cryptographic hash (e.g., SHA-256) of the file content. Ensures file integrity and detects unauthorized modifications.' ;
    rdfs:domain ind:Revision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fileName rdf:type rdf:Property ;
    rdfs:label 'File Name' ;
    rdfs:comment 'Name of the physical file associated with this revision, including extension (e.g., Drawing_A101_RevB.pdf).' ;
    rdfs:domain ind:Revision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fileSizeBytes rdf:type rdf:Property ;
    rdfs:label 'File Size Bytes' ;
    rdfs:comment 'Size of the document file in bytes. Used for storage management and download estimation.' ;
    rdfs:domain ind:Revision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fileStoragePath rdf:type rdf:Property ;
    rdfs:label 'File Storage Path' ;
    rdfs:comment 'Full path or URI to the physical file location in the document management system or cloud storage. Enables retrieval of the actual document file.' ;
    rdfs:domain ind:Design ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isControlledCopy rdf:type rdf:Property ;
    rdfs:label 'Is Controlled Copy' ;
    rdfs:comment 'Indicates whether this revision is a controlled copy subject to formal change management. True for official project copies, false for reference or uncontrolled copies.' ;
    rdfs:domain ind:Revision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:revisionStatus rdf:type rdf:Property ;
    rdfs:label 'Revision Status' ;
    rdfs:comment 'Current lifecycle status of this revision. Tracks the approval and publication workflow state.' ;
    rdfs:domain ind:Design ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revisionType rdf:type rdf:Property ;
    rdfs:label 'Revision Type' ;
    rdfs:comment 'Classification of the revision based on the nature and impact of changes. Distinguishes between routine updates and significant modifications.' ;
    rdfs:domain ind:Design ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sheetCount rdf:type rdf:Property ;
    rdfs:label 'Sheet Count' ;
    rdfs:comment 'Total number of sheets or drawings in this revision (applicable for CAD and BIM documents). Used for drawing set completeness checks.' ;
    rdfs:domain ind:Design ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:workflowApprovalId rdf:type rdf:Property ;
    rdfs:label 'Workflow Approval Id' ;
    rdfs:comment 'Unique identifier for the workflow approval instance. Primary key for the workflow approval entity.' ;
    rdfs:domain ind:WorkflowApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actionDate rdf:type rdf:Property ;
    rdfs:label 'Action Date' ;
    rdfs:comment 'Date and time when the reviewer recorded their approval decision or action. Used for SLA compliance tracking and audit trail.' ;
    rdfs:domain ind:WorkflowApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actionTaken rdf:type rdf:Property ;
    rdfs:label 'Action Taken' ;
    rdfs:comment 'The decision or action recorded by the reviewer at the current workflow step. Determines routing to next step or workflow termination. [ENUM-REF-CANDIDATE: approved|approved_with_comments|rejected|no_objection|commented|delegated|returned_for_revision|acknowledged|pending — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:WorkflowApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalAuthorityLevel rdf:type rdf:Property ;
    rdfs:label 'Approval Authority Level' ;
    rdfs:comment 'The organizational or contractual authority level required to approve this workflow. Determines who has final sign-off rights per delegation of authority matrix. [ENUM-REF-CANDIDATE: project_team|discipline_lead|project_manager|design_manager|technical_director|client_representative|regulatory_authority — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignedReviewerRole rdf:type rdf:Property ;
    rdfs:label 'Assigned Reviewer Role' ;
    rdfs:comment 'The functional role or position assigned to review the current step (e.g., Lead Engineer, Design Manager, QA/QC Manager, Project Director). Defines approval authority.' ;
    rdfs:domain ind:WorkflowApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditTrailReference rdf:type rdf:Property ;
    rdfs:label 'Audit Trail Reference' ;
    rdfs:comment 'Reference identifier linking this workflow approval to the complete audit trail log in the document management system. Supports ISO 9001 and ISO 19650 compliance.' ;
    rdfs:domain ind:WorkflowApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentStepSequence rdf:type rdf:Property ;
    rdfs:label 'Current Step Sequence' ;
    rdfs:comment 'The ordinal position of the current approval step in the workflow chain. Used to track progress and determine next routing action.' ;
    rdfs:domain ind:WorkflowApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:delegationReason rdf:type rdf:Property ;
    rdfs:label 'Delegation Reason' ;
    rdfs:comment 'Explanation provided by the original reviewer for delegating the approval to another individual (e.g., absence, conflict of interest, technical expertise).' ;
    rdfs:domain ind:WorkflowApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationDate rdf:type rdf:Property ;
    rdfs:label 'Escalation Date' ;
    rdfs:comment 'Date and time when the workflow was escalated to higher approval authority or management attention due to delay or complexity.' ;
    rdfs:domain ind:WorkflowApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:initiatedDate rdf:type rdf:Property ;
    rdfs:label 'Initiated Date' ;
    rdfs:comment 'Date and time when the workflow approval was initiated and entered the approval chain. Marks the start of the approval lifecycle and SLA clock.' ;
    rdfs:domain ind:WorkflowApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lastReminderDate rdf:type rdf:Property ;
    rdfs:label 'Last Reminder Date' ;
    rdfs:comment 'Date and time when the most recent reminder notification was sent to the assigned reviewer. Used to schedule next reminder per escalation policy.' ;
    rdfs:domain ind:WorkflowApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:notificationSentFlag rdf:type rdf:Property ;
    rdfs:label 'Notification Sent Flag' ;
    rdfs:comment 'Indicator of whether automated notification was sent to the assigned reviewer when the workflow step was routed to them. True if notification sent.' ;
    rdfs:domain ind:WorkflowApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:outcomeDate rdf:type rdf:Property ;
    rdfs:label 'Outcome Date' ;
    rdfs:comment 'Date and time when the final workflow outcome was determined and the approval process was closed. Marks the end of the approval lifecycle.' ;
    rdfs:domain ind:WorkflowApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:overallOutcome rdf:type rdf:Property ;
    rdfs:label 'Overall Outcome' ;
    rdfs:comment 'Final outcome of the complete workflow approval process after all steps are completed. Determines document status and next business actions.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryRequirementFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Requirement Flag' ;
    rdfs:comment 'Indicator of whether this workflow approval is required to satisfy regulatory, statutory, or building code compliance obligations. True if regulatory-driven.' ;
    rdfs:domain ind:WorkflowApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reminderCount rdf:type rdf:Property ;
    rdfs:label 'Reminder Count' ;
    rdfs:comment 'Number of automated reminder notifications sent to the assigned reviewer for pending action. Used to track follow-up frequency and SLA risk.' ;
    rdfs:domain ind:WorkflowApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reviewerComments rdf:type rdf:Property ;
    rdfs:label 'Reviewer Comments' ;
    rdfs:comment 'Free-text comments, observations, or conditions recorded by the reviewer. Captures technical feedback, approval conditions, or reasons for rejection.' ;
    rdfs:domain ind:WorkflowApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaActualHours rdf:type rdf:Property ;
    rdfs:label 'Sla Actual Hours' ;
    rdfs:comment 'The actual elapsed time in hours from workflow step assignment to action completion. Used to calculate SLA compliance and identify bottlenecks.' ;
    rdfs:domain ind:WorkflowApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:slaComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Sla Compliance Flag' ;
    rdfs:comment 'Indicator of whether the workflow step was completed within the SLA target duration. True if compliant, False if breached.' ;
    rdfs:domain ind:WorkflowApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:slaTargetHours rdf:type rdf:Property ;
    rdfs:label 'Sla Target Hours' ;
    rdfs:comment 'The contractual or policy-defined target duration in hours for completing this workflow step. Used to measure compliance with approval turnaround commitments.' ;
    rdfs:domain ind:WorkflowApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalSteps rdf:type rdf:Property ;
    rdfs:label 'Total Steps' ;
    rdfs:comment 'Total number of approval steps defined in the workflow template. Used to calculate completion percentage and remaining steps.' ;
    rdfs:domain ind:WorkflowApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:workflowName rdf:type rdf:Property ;
    rdfs:label 'Workflow Name' ;
    rdfs:comment 'Descriptive name of the workflow approval instance, typically derived from the document title or approval purpose.' ;
    rdfs:domain ind:WorkflowApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workflowNumber rdf:type rdf:Property ;
    rdfs:label 'Workflow Number' ;
    rdfs:comment 'Business identifier for the workflow approval instance. Externally visible reference number used in correspondence and audit trails.' ;
    rdfs:domain ind:WorkflowApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workflowStatus rdf:type rdf:Property ;
    rdfs:label 'Workflow Status' ;
    rdfs:comment 'Current lifecycle state of the workflow approval. Tracks progression through the approval chain from initiation to final outcome. [ENUM-REF-CANDIDATE: initiated|in_progress|pending_review|approved|rejected|on_hold|cancelled|completed — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:WorkflowApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workflowType rdf:type rdf:Property ;
    rdfs:label 'Workflow Type' ;
    rdfs:comment 'Classification of the workflow approval by business purpose. Determines routing rules, SLA targets, and approval authority requirements. [ENUM-REF-CANDIDATE: design_review|submittal_approval|rfi_response|change_order_approval|drawing_approval|specification_review|technical_query|document_transmittal|noncompliance_review|method_statement_approval — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:WorkflowApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:handoverPackageId rdf:type rdf:Property ;
    rdfs:label 'Handover Package Id' ;
    rdfs:comment 'Unique identifier for the handover package record. Primary key. Role: MASTER_RESOURCE.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:HandoverPackage .

ind:clientAcceptanceStatus rdf:type rdf:Property ;
    rdfs:label 'Client Acceptance Status' ;
    rdfs:comment 'Status of client acceptance for this handover package: pending, accepted, conditionally accepted, rejected, or under review.' ;
    rdfs:domain ind:Design ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:completenessPercentage rdf:type rdf:Property ;
    rdfs:label 'Completeness Percentage' ;
    rdfs:comment 'Percentage of required documents and deliverables that have been compiled and included in the handover package (0.00 to 100.00).' ;
    rdfs:domain ind:Design ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:iso19650ComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Iso 19650 Compliance Flag' ;
    rdfs:comment 'Indicates whether this handover package complies with ISO 19650-3 operational phase information requirements (True/False).' ;
    rdfs:domain ind:Design ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:legalHoldFlag rdf:type rdf:Property ;
    rdfs:label 'Legal Hold Flag' ;
    rdfs:comment 'Indicates whether this handover package is subject to a legal hold for litigation support, dispute resolution, or regulatory investigation (True/False).' ;
    rdfs:domain ind:HandoverPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:legalHoldReason rdf:type rdf:Property ;
    rdfs:label 'Legal Hold Reason' ;
    rdfs:comment 'Description of the reason for the legal hold, including case reference or dispute identifier if applicable.' ;
    rdfs:domain ind:HandoverPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalHoldStartDate rdf:type rdf:Property ;
    rdfs:label 'Legal Hold Start Date' ;
    rdfs:comment 'Date on which the legal hold was placed on this handover package.' ;
    rdfs:domain ind:HandoverPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:packageNumber rdf:type rdf:Property ;
    rdfs:label 'Package Number' ;
    rdfs:comment 'Business identifier for the handover package, typically following project-specific numbering convention (e.g., PRJ-HP-001234). Externally-known unique code.' ;
    rdfs:domain ind:Design ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packageTitle rdf:type rdf:Property ;
    rdfs:label 'Package Title' ;
    rdfs:comment 'Descriptive title of the handover package indicating the scope or system covered (e.g., \'HVAC System O&M Documentation\', \'Structural As-Built Drawings\').' ;
    rdfs:domain ind:HandoverPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packageType rdf:type rdf:Property ;
    rdfs:label 'Package Type' ;
    rdfs:comment 'Classification of the handover package by document category: operations and maintenance manuals, as-built drawings, test and commissioning records, warranties and guarantees, certificates and approvals, or training materials.' ;
    rdfs:domain ind:Design ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedSubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Planned Submission Date' ;
    rdfs:comment 'Target date for submission of the handover package as per the project handover schedule and contract requirements.' ;
    rdfs:domain ind:Design ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requiredDocumentCount rdf:type rdf:Property ;
    rdfs:label 'Required Document Count' ;
    rdfs:comment 'Total number of documents required to be included in this handover package per the contract and handover plan.' ;
    rdfs:domain ind:HandoverPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reviewedBy rdf:type rdf:Property ;
    rdfs:label 'Reviewed By' ;
    rdfs:comment 'Name of the individual or role who reviewed the handover package for completeness and compliance before submission.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scopeOfWorks rdf:type rdf:Property ;
    rdfs:label 'Scope Of Works' ;
    rdfs:comment 'Detailed description of the scope of works, systems, or areas covered by this handover package (e.g., \'Mechanical systems for Building A floors 1-5\').' ;
    rdfs:domain ind:HandoverPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submittedDocumentCount rdf:type rdf:Property ;
    rdfs:label 'Submitted Document Count' ;
    rdfs:comment 'Number of documents that have been submitted and included in the handover package to date.' ;
    rdfs:domain ind:HandoverPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:handoverItemId rdf:type rdf:Property ;
    rdfs:label 'Handover Item Id' ;
    rdfs:comment 'Unique identifier for the handover item within the handover package tracking system.' ;
    rdfs:domain ind:HandoverItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualSubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Actual Submission Date' ;
    rdfs:comment 'Actual date on which the handover item was submitted to the client or project team, used to track schedule performance.' ;
    rdfs:domain ind:Design ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:certificationRequired rdf:type rdf:Property ;
    rdfs:label 'Certification Required' ;
    rdfs:comment 'Flag indicating whether this handover item requires professional certification, third-party verification, or authorized signoff.' ;
    rdfs:domain ind:HandoverItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:certifyingAuthority rdf:type rdf:Property ;
    rdfs:label 'Certifying Authority' ;
    rdfs:comment 'Name of the professional engineer, inspector, or third-party organization that certified or verified this handover item.' ;
    rdfs:domain ind:HandoverItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clientReviewDate rdf:type rdf:Property ;
    rdfs:label 'Client Review Date' ;
    rdfs:comment 'Date on which the client completed their review and provided feedback or approval decision for this handover item.' ;
    rdfs:domain ind:HandoverItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:clientReviewStatus rdf:type rdf:Property ;
    rdfs:label 'Client Review Status' ;
    rdfs:comment 'Status of the client or owner review process indicating whether the handover item has been accepted, requires revision, or is pending review. [ENUM-REF-CANDIDATE: not_submitted|pending_review|under_review|approved|approved_with_comments|rejected|resubmit_required — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:HandoverItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clientReviewerName rdf:type rdf:Property ;
    rdfs:label 'Client Reviewer Name' ;
    rdfs:comment 'Name of the client representative who reviewed and approved or rejected this handover item.' ;
    rdfs:domain ind:HandoverItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:completedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Completed Timestamp' ;
    rdfs:comment 'Date and time when this handover item was marked as completed and fully closed out with all requirements satisfied.' ;
    rdfs:domain ind:HandoverItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:contractualRequirement rdf:type rdf:Property ;
    rdfs:label 'Contractual Requirement' ;
    rdfs:comment 'Flag indicating whether this handover item is a mandatory contractual deliverable required by the project contract or client agreement.' ;
    rdfs:domain ind:HandoverItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fileLocation rdf:type rdf:Property ;
    rdfs:label 'File Location' ;
    rdfs:comment 'Network path, cloud storage location, or document management system reference where the electronic version of this handover item is stored.' ;
    rdfs:domain ind:HandoverItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:itemDescription rdf:type rdf:Property ;
    rdfs:label 'Item Description' ;
    rdfs:comment 'Detailed description of the handover item including scope, content, and any special requirements or conditions.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:itemNumber rdf:type rdf:Property ;
    rdfs:label 'Item Number' ;
    rdfs:comment 'Sequential or hierarchical numbering of the item within the handover package for tracking and reference purposes.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:itemStatus rdf:type rdf:Property ;
    rdfs:label 'Item Status' ;
    rdfs:comment 'Current lifecycle status of the handover item tracking its progress through preparation, submission, review, and approval stages. [ENUM-REF-CANDIDATE: not_started|in_preparation|submitted|under_review|approved|rejected|resubmitted|completed — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:HandoverItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:itemTitle rdf:type rdf:Property ;
    rdfs:label 'Item Title' ;
    rdfs:comment 'Descriptive title or name of the handover item that clearly identifies the deliverable.' ;
    rdfs:domain ind:HandoverItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:itemType rdf:type rdf:Property ;
    rdfs:label 'Item Type' ;
    rdfs:comment 'Classification of the handover deliverable item. [ENUM-REF-CANDIDATE: om_manual|as_built_drawing|fat_certificate|sat_record|warranty_certificate|commissioning_record|spare_parts_list|training_material|maintenance_schedule|test_certificate|inspection_report|compliance_certificate — promote to reference product]' ;
    rdfs:domain ind:HandoverItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:language rdf:type rdf:Property ;
    rdfs:label 'Language' ;
    rdfs:comment 'Primary language in which the handover item document is prepared, using ISO 639-1 two-letter language codes.' ;
    rdfs:domain ind:HandoverItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outstandingActionNotes rdf:type rdf:Property ;
    rdfs:label 'Outstanding Action Notes' ;
    rdfs:comment 'Description of any outstanding actions, corrections, or additional information required to complete or close out this handover item.' ;
    rdfs:domain ind:HandoverItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:systemReference rdf:type rdf:Property ;
    rdfs:label 'System Reference' ;
    rdfs:comment 'Reference to the specific building system, equipment system, or facility system that this handover item documents.' ;
    rdfs:domain ind:HandoverItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableStandards rdf:type rdf:Property ;
    rdfs:label 'Applicable Standards' ;
    rdfs:comment 'Comma-separated list of applicable quality, design, and construction standards governing this ITP (e.g., \'ISO 9001, ACI 318, ASME B31.3, IBC 2018\'). Defines the regulatory and technical framework.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defectLiabilityPeriodDays rdf:type rdf:Property ;
    rdfs:label 'Defect Liability Period Days' ;
    rdfs:comment 'Duration in days of the defects liability period applicable to work covered by this ITP. Defines the warranty period for quality defects.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:documentStorageLocation rdf:type rdf:Property ;
    rdfs:label 'Document Storage Location' ;
    rdfs:comment 'Physical or digital location where the ITP document and related inspection records are stored (e.g., Aconex folder path, SharePoint URL, physical file reference).' ;
    rdfs:domain ind:Itp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fatRequired rdf:type rdf:Property ;
    rdfs:label 'Fat Required' ;
    rdfs:comment 'Indicates whether a Factory Acceptance Test is required as part of this ITP. Applicable to equipment and prefabricated components.' ;
    rdfs:domain ind:Itp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:holdPointRequired rdf:type rdf:Property ;
    rdfs:label 'Hold Point Required' ;
    rdfs:comment 'Indicates whether this ITP includes mandatory hold points where work cannot proceed until inspection approval is obtained. Critical for compliance and risk management.' ;
    rdfs:domain ind:Itp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inspectionFrequency rdf:type rdf:Property ;
    rdfs:label 'Inspection Frequency' ;
    rdfs:comment 'Frequency or sampling rate for inspections defined in this ITP (e.g., \'100% inspection\', \'Every 10th unit\', \'Daily\', \'Per shift\'). Defines the intensity of quality control.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:itpNumber rdf:type rdf:Property ;
    rdfs:label 'Itp Number' ;
    rdfs:comment 'Business identifier for the ITP document, typically following a project-specific numbering convention. Used for external reference and document control.' ;
    rdfs:domain ind:Itp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialTestCertificateRequired rdf:type rdf:Property ;
    rdfs:label 'Material Test Certificate Required' ;
    rdfs:comment 'Indicates whether material test certificates must be submitted and verified as part of this ITP. Common for structural materials and critical components.' ;
    rdfs:domain ind:Itp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ndtMethodRequired rdf:type rdf:Property ;
    rdfs:label 'Ndt Method Required' ;
    rdfs:comment 'Type of non-destructive testing method required by this ITP, if applicable. Critical for structural integrity verification in construction. [ENUM-REF-CANDIDATE: none|visual|ultrasonic|radiographic|magnetic_particle|liquid_penetrant|eddy_current — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Itp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qcInspectorResponsibleParty rdf:type rdf:Property ;
    rdfs:label 'Qc Inspector Responsible Party' ;
    rdfs:comment 'Name or role of the contractor QC inspector responsible for verifying compliance with this ITP before submission to the client.' ;
    rdfs:domain ind:Itp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewPointRequired rdf:type rdf:Property ;
    rdfs:label 'Review Point Required' ;
    rdfs:comment 'Indicates whether this ITP includes review points where inspection records and test results must be submitted for review by the client or engineer.' ;
    rdfs:domain ind:Itp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:satRequired rdf:type rdf:Property ;
    rdfs:label 'Sat Required' ;
    rdfs:comment 'Indicates whether a Site Acceptance Test is required as part of this ITP. Applicable to installed equipment and systems commissioning.' ;
    rdfs:domain ind:Itp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:testMethodReference rdf:type rdf:Property ;
    rdfs:label 'Test Method Reference' ;
    rdfs:comment 'Reference to the standard test methods or procedures to be used for testing under this ITP (e.g., \'ASTM E165\', \'ISO 9712\', \'ACI 318 Section 5.6\').' ;
    rdfs:domain ind:Itp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:witnessPointRequired rdf:type rdf:Property ;
    rdfs:label 'Witness Point Required' ;
    rdfs:comment 'Indicates whether this ITP includes witness points where the client or third-party inspector must be notified and given the opportunity to witness the inspection.' ;
    rdfs:domain ind:Itp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:workPackageDescription rdf:type rdf:Property ;
    rdfs:label 'Work Package Description' ;
    rdfs:comment 'Detailed description of the construction work package, activity, or deliverable that this ITP covers. Defines the scope of inspection and testing.' ;
    rdfs:domain ind:Itp ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsibleCrewId rdf:type rdf:Property ;
    rdfs:label 'Responsible Crew Id' ;
    rdfs:comment 'Foreign key linking to workforce.crew. Business justification: ITP line often executed by a crew; linking crew provides crew-level accountability.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Crew .

ind:applicableStandard rdf:type rdf:Property ;
    rdfs:label 'Applicable Standard' ;
    rdfs:comment 'The industry standard, code, or specification that governs this inspection activity (e.g., ASTM, ASME, ACI, AISC, BS, EN, ISO standard reference).' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calibrationRequired rdf:type rdf:Property ;
    rdfs:label 'Calibration Required' ;
    rdfs:comment 'Indicates whether the test equipment used for this inspection must have valid calibration certificates before use.' ;
    rdfs:domain ind:ItpLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:clientWitnessRequired rdf:type rdf:Property ;
    rdfs:label 'Client Witness Required' ;
    rdfs:comment 'Indicates whether the client or their representative must be present to witness this inspection activity before work can proceed.' ;
    rdfs:domain ind:ItpLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:consultantWitnessRequired rdf:type rdf:Property ;
    rdfs:label 'Consultant Witness Required' ;
    rdfs:comment 'Indicates whether the consultant or engineer must be present to witness this inspection activity before work can proceed.' ;
    rdfs:domain ind:ItpLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:criticalPathFlag rdf:type rdf:Property ;
    rdfs:label 'Critical Path Flag' ;
    rdfs:comment 'Indicates whether this inspection activity is on the project critical path and delays would impact overall project schedule.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:environmentalConditions rdf:type rdf:Property ;
    rdfs:label 'Environmental Conditions' ;
    rdfs:comment 'Any specific environmental conditions or constraints that must be met during inspection (e.g., temperature range, humidity limits, weather restrictions, lighting requirements).' ;
    rdfs:domain ind:ItpLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdPointType rdf:type rdf:Property ;
    rdfs:label 'Hold Point Type' ;
    rdfs:comment 'Classification of the inspection point. Hold: work cannot proceed without approval. Witness: client/consultant must be present. Review: documentation review only. Surveillance: periodic monitoring.' ;
    rdfs:domain ind:ItpLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionMethod rdf:type rdf:Property ;
    rdfs:label 'Inspection Method' ;
    rdfs:comment 'The method or technique to be used for performing the inspection or test (e.g., visual inspection, ultrasonic testing, dimensional check, pressure test, material sampling).' ;
    rdfs:domain ind:ItpLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionStage rdf:type rdf:Property ;
    rdfs:label 'Inspection Stage' ;
    rdfs:comment 'The construction or manufacturing stage at which this inspection must be performed (e.g., pre-pour, during installation, post-weld, before backfill, at completion).' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:itpLineStatus rdf:type rdf:Property ;
    rdfs:label 'Itp Line Status' ;
    rdfs:comment 'Current status of this ITP line item in its lifecycle. Planned: not yet ready. Ready: prerequisites met. In Progress: inspection underway. Completed: inspection finished. Waived: inspection waived by authority. Cancelled: no longer required.' ;
    rdfs:domain ind:ItpLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ncrTriggerCriteria rdf:type rdf:Property ;
    rdfs:label 'Ncr Trigger Criteria' ;
    rdfs:comment 'The specific conditions or findings that would trigger the issuance of a Non-Conformance Report (NCR) if this inspection fails.' ;
    rdfs:domain ind:ItpLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationLeadTimeHours rdf:type rdf:Property ;
    rdfs:label 'Notification Lead Time Hours' ;
    rdfs:comment 'The minimum advance notice in hours that must be given to client, consultant, or third-party witnesses before performing this inspection.' ;
    rdfs:domain ind:ItpLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:requiredDocumentation rdf:type rdf:Property ;
    rdfs:label 'Required Documentation' ;
    rdfs:comment 'List of documents, certificates, or records that must be produced as evidence of inspection completion (e.g., test certificates, inspection reports, material certificates, calibration records).' ;
    rdfs:domain ind:ItpLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyRequirements rdf:type rdf:Property ;
    rdfs:label 'Safety Requirements' ;
    rdfs:comment 'Specific health, safety, and environment (HSE) requirements, personal protective equipment (PPE), or permits required for performing this inspection activity.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:samplingPlan rdf:type rdf:Property ;
    rdfs:label 'Sampling Plan' ;
    rdfs:comment 'The statistical sampling plan or sample size requirements for this inspection activity (e.g., AQL levels, sample quantity, sampling method).' ;
    rdfs:domain ind:ItpLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sequenceDependency rdf:type rdf:Property ;
    rdfs:label 'Sequence Dependency' ;
    rdfs:comment 'Description of any prerequisite inspections or activities that must be completed before this inspection can be performed.' ;
    rdfs:domain ind:ItpLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supersededDate rdf:type rdf:Property ;
    rdfs:label 'Superseded Date' ;
    rdfs:comment 'The date on which this ITP line item version was superseded by a newer revision. Null if this is the current active version.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:testEquipmentRequired rdf:type rdf:Property ;
    rdfs:label 'Test Equipment Required' ;
    rdfs:comment 'List of specialized test equipment, instruments, or tools required to perform this inspection or test (e.g., ultrasonic tester, pressure gauge, theodolite, concrete slump cone).' ;
    rdfs:domain ind:ItpLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thirdPartyWitnessRequired rdf:type rdf:Property ;
    rdfs:label 'Third Party Witness Required' ;
    rdfs:comment 'Indicates whether a third-party inspector, certification body, or regulatory authority must witness this inspection activity.' ;
    rdfs:domain ind:ItpLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:drawingRevisionId rdf:type rdf:Property ;
    rdfs:label 'Drawing Revision Id' ;
    rdfs:comment 'Foreign key linking to design.drawing_revision. Business justification: Inspections must record which drawing revision was current at time of inspection — a critical audit and contractual requirement. inspection.drawing_id links to the drawing, but revision-level traceabi' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DrawingRevision .

ind:checklistTemplateName rdf:type rdf:Property ;
    rdfs:label 'Checklist Template Name' ;
    rdfs:comment 'Name of the checklist template used (e.g., Concrete Pour Inspection Checklist, Structural Steel Welding Inspection, MEP Rough-in Checklist). Provides human-readable context.' ;
    rdfs:domain ind:Inspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checklistVersion rdf:type rdf:Property ;
    rdfs:label 'Checklist Version' ;
    rdfs:comment 'Version number of the checklist template used at the time of inspection. Ensures audit trail of which criteria were applied.' ;
    rdfs:domain ind:Inspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defectsIdentified rdf:type rdf:Property ;
    rdfs:label 'Defects Identified' ;
    rdfs:comment 'Description of specific defects, non-conformances, or quality issues identified during the inspection. Forms the basis for NCR (Non-Conformance Report) creation and defect tracking through DLP (Defects Liability Period).' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:humidityPercent rdf:type rdf:Property ;
    rdfs:label 'Humidity Percent' ;
    rdfs:comment 'Relative humidity percentage at the time of inspection. Relevant for coating, painting, and other moisture-sensitive quality checks.' ;
    rdfs:domain ind:Inspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inspectorCertification rdf:type rdf:Property ;
    rdfs:label 'Inspector Certification' ;
    rdfs:comment 'Professional certification or qualification held by the inspector (e.g., AWS CWI for welding, ACI for concrete, ASNT for NDT). Validates inspector competency.' ;
    rdfs:domain ind:Inspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectorSignatureCaptured rdf:type rdf:Property ;
    rdfs:label 'Inspector Signature Captured' ;
    rdfs:comment 'Boolean flag indicating whether the inspector\'s digital signature was captured as part of the inspection sign-off. True indicates signature obtained; false indicates signature pending or not required.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:locationType rdf:type rdf:Property ;
    rdfs:label 'Location Type' ;
    rdfs:comment 'Classification of where the inspection was physically conducted. Site indicates construction site; factory indicates manufacturer facility for FAT; workshop indicates fabrication shop; laboratory indicates testing facility; warehouse indicates storage location; offsite indicates other external location.' ;
    rdfs:domain ind:Inspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ncrRaised rdf:type rdf:Property ;
    rdfs:label 'Ncr Raised' ;
    rdfs:comment 'Boolean flag indicating whether a Non-Conformance Report (NCR) was raised as a result of this inspection. True indicates NCR created; false indicates no NCR required.' ;
    rdfs:domain ind:Inspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:observations rdf:type rdf:Property ;
    rdfs:label 'Observations' ;
    rdfs:comment 'General observations, notes, and comments recorded by the inspector during the inspection. Captures qualitative findings, context, and professional judgment.' ;
    rdfs:domain ind:Inspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:photoCount rdf:type rdf:Property ;
    rdfs:label 'Photo Count' ;
    rdfs:comment 'Number of photographs captured during the inspection as visual evidence of conditions, defects, or compliance.' ;
    rdfs:domain ind:Inspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reinspectionDate rdf:type rdf:Property ;
    rdfs:label 'Reinspection Date' ;
    rdfs:comment 'Scheduled date for follow-up reinspection to verify corrective actions have been implemented and defects resolved.' ;
    rdfs:domain ind:Inspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reinspectionRequired rdf:type rdf:Property ;
    rdfs:label 'Reinspection Required' ;
    rdfs:comment 'Boolean flag indicating whether a follow-up reinspection is required after corrective actions are completed. True indicates reinspection needed; false indicates no reinspection required.' ;
    rdfs:domain ind:Inspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:specificationReference rdf:type rdf:Property ;
    rdfs:label 'Specification Reference' ;
    rdfs:comment 'Reference to the technical specification, standard, or code against which the inspection was performed (e.g., ACI 318, AISC 360, project specification section). Defines acceptance criteria.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureCelsius rdf:type rdf:Property ;
    rdfs:label 'Temperature Celsius' ;
    rdfs:comment 'Ambient temperature in degrees Celsius at the time of inspection. Critical for temperature-sensitive activities such as concrete curing, welding, coating application.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalCheckItems rdf:type rdf:Property ;
    rdfs:label 'Total Check Items' ;
    rdfs:comment 'Total number of individual verification items in the checklist that were evaluated during this inspection.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:witnessSignatureCaptured rdf:type rdf:Property ;
    rdfs:label 'Witness Signature Captured' ;
    rdfs:comment 'Boolean flag indicating whether the witness party\'s digital signature was captured. True indicates signature obtained; false indicates signature pending or not required.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:workPackageReference rdf:type rdf:Property ;
    rdfs:label 'Work Package Reference' ;
    rdfs:comment 'Reference to the work package, activity, or WBS (Work Breakdown Structure) element being inspected. Links quality verification to project schedule and scope.' ;
    rdfs:domain ind:Inspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clientNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Client Notification Date' ;
    rdfs:comment 'Date when the client was formally notified of the non-conformance. Null if client notification was not required.' ;
    rdfs:domain ind:Ncr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:clientNotificationRequired rdf:type rdf:Property ;
    rdfs:label 'Client Notification Required' ;
    rdfs:comment 'Indicates whether the client must be formally notified of this non-conformance per contract requirements. Typically true for major or critical NCRs.' ;
    rdfs:domain ind:Ncr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:closedBy rdf:type rdf:Property ;
    rdfs:label 'Closed By' ;
    rdfs:comment 'Name or identifier of the person who authorized closure of the NCR. Typically a QA/QC manager or project quality manager.' ;
    rdfs:domain ind:Ncr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Completion Date' ;
    rdfs:comment 'Actual date when the corrective action was completed. Compared against target date for performance measurement.' ;
    rdfs:domain ind:Ncr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:correctiveActionDescription rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Description' ;
    rdfs:comment 'Detailed description of the corrective action(s) to be taken to address the immediate non-conformance. Part of the CAPA (Corrective and Preventive Action) process.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionResponsibleParty rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Responsible Party' ;
    rdfs:comment 'Name or identifier of the person or organization responsible for implementing the corrective action.' ;
    rdfs:domain ind:Ncr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionTargetDate rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Target Date' ;
    rdfs:comment 'Planned target date for completion of the corrective action. Used for tracking and escalation if deadlines are missed.' ;
    rdfs:domain ind:Ncr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:disposition rdf:type rdf:Property ;
    rdfs:label 'Disposition' ;
    rdfs:comment 'Formal decision on how the non-conforming work or material will be handled. Disposition determines the corrective action path and may require client approval for concessions.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispositionApprovedBy rdf:type rdf:Property ;
    rdfs:label 'Disposition Approved By' ;
    rdfs:comment 'Name or identifier of the person who approved the disposition decision. Typically a senior QA/QC manager, project manager, or client representative.' ;
    rdfs:domain ind:Ncr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispositionApprovedDate rdf:type rdf:Property ;
    rdfs:label 'Disposition Approved Date' ;
    rdfs:comment 'Date when the disposition was formally approved, allowing corrective action to proceed.' ;
    rdfs:domain ind:Ncr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dispositionJustification rdf:type rdf:Property ;
    rdfs:label 'Disposition Justification' ;
    rdfs:comment 'Technical and business justification for the selected disposition, including engineering analysis, code compliance assessment, and impact on functionality.' ;
    rdfs:domain ind:Ncr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectivenessReviewComments rdf:type rdf:Property ;
    rdfs:label 'Effectiveness Review Comments' ;
    rdfs:comment 'Comments from the effectiveness review assessing whether the corrective and preventive actions have successfully addressed the non-conformance and prevented recurrence.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedCostImpact rdf:type rdf:Property ;
    rdfs:label 'Estimated Cost Impact' ;
    rdfs:comment 'Estimated financial cost impact of the non-conformance including rework, material replacement, schedule delay, and potential liquidated damages. Used for cost tracking and recovery.' ;
    rdfs:domain ind:Ncr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:holdReleaseDate rdf:type rdf:Property ;
    rdfs:label 'Hold Release Date' ;
    rdfs:comment 'Date when the hold was released, allowing work to resume. Null if no hold was placed or if hold is still active.' ;
    rdfs:domain ind:Ncr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:holdStatus rdf:type rdf:Property ;
    rdfs:label 'Hold Status' ;
    rdfs:comment 'Indicates whether a hold has been placed on the affected work or material, preventing further work until the NCR is resolved. True if hold is active, False otherwise.' ;
    rdfs:domain ind:Ncr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ncrCategory rdf:type rdf:Property ;
    rdfs:label 'Ncr Category' ;
    rdfs:comment 'High-level classification of the type of non-conformance to support trend analysis and root cause categorization.' ;
    rdfs:domain ind:Ncr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ncrDescription rdf:type rdf:Property ;
    rdfs:label 'Ncr Description' ;
    rdfs:comment 'Detailed narrative description of the non-conformance, including what was observed, what was expected per specifications, and the extent of the deviation.' ;
    rdfs:domain ind:Ncr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ncrNumber rdf:type rdf:Property ;
    rdfs:label 'Ncr Number' ;
    rdfs:comment 'Business identifier for the NCR, typically following a project-specific numbering convention. Externally visible reference number used in correspondence and documentation.' ;
    rdfs:domain ind:Ncr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ncrStatus rdf:type rdf:Property ;
    rdfs:label 'Ncr Status' ;
    rdfs:comment 'Current lifecycle status of the NCR tracking its progression from identification through closure. Reflects the workflow state in the CAPA (Corrective and Preventive Action) cycle. [ENUM-REF-CANDIDATE: draft|open|under_investigation|pending_disposition|corrective_action_in_progress|verification_pending|closed|cancelled — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Ncr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preventiveActionDescription rdf:type rdf:Property ;
    rdfs:label 'Preventive Action Description' ;
    rdfs:comment 'Description of preventive actions to be taken to prevent recurrence of similar non-conformances. Addresses systemic issues identified in root cause analysis.' ;
    rdfs:domain ind:Ncr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preventiveActionResponsibleParty rdf:type rdf:Property ;
    rdfs:label 'Preventive Action Responsible Party' ;
    rdfs:comment 'Name or identifier of the person or organization responsible for implementing the preventive action.' ;
    rdfs:domain ind:Ncr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityAffected rdf:type rdf:Property ;
    rdfs:label 'Quantity Affected' ;
    rdfs:comment 'Numeric quantity of work, material, or units affected by the non-conformance (e.g., 150 cubic meters of concrete, 25 welds, 500 linear meters of pipe).' ;
    rdfs:domain ind:Ncr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reportedBy rdf:type rdf:Property ;
    rdfs:label 'Reported By' ;
    rdfs:comment 'Name or identifier of the person who identified and reported the non-conformance. Typically a QA/QC inspector, site engineer, or subcontractor representative.' ;
    rdfs:domain ind:Ncr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportedByOrganization rdf:type rdf:Property ;
    rdfs:label 'Reported By Organization' ;
    rdfs:comment 'Organization or company that the reporting person represents (e.g., General Contractor, Subcontractor, Client, Third-Party Inspector).' ;
    rdfs:domain ind:Ncr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rootCauseAnalysis rdf:type rdf:Property ;
    rdfs:label 'Root Cause Analysis' ;
    rdfs:comment 'Detailed analysis of the underlying root cause(s) of the non-conformance. May reference techniques such as 5 Whys, Fishbone Diagram, or Fault Tree Analysis.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationMethod rdf:type rdf:Property ;
    rdfs:label 'Verification Method' ;
    rdfs:comment 'Method used to verify that the corrective action was effective and the non-conformance has been resolved. May include re-inspection, testing, or document review. [ENUM-REF-CANDIDATE: visual_inspection|dimensional_check|material_test|functional_test|document_review|third_party_inspection|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationPerformedBy rdf:type rdf:Property ;
    rdfs:label 'Verification Performed By' ;
    rdfs:comment 'Name or identifier of the person who performed the verification of corrective action effectiveness. Typically a QA/QC inspector or independent verifier.' ;
    rdfs:domain ind:Ncr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationResult rdf:type rdf:Property ;
    rdfs:label 'Verification Result' ;
    rdfs:comment 'Outcome of the verification activity indicating whether the corrective action was effective and the non-conformance is resolved.' ;
    rdfs:domain ind:Ncr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actionDescription rdf:type rdf:Property ;
    rdfs:label 'Action Description' ;
    rdfs:comment 'Detailed narrative of the specific remediation steps to be taken, including scope, method, materials, and acceptance criteria.' ;
    rdfs:domain ind:CorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actionNumber rdf:type rdf:Property ;
    rdfs:label 'Action Number' ;
    rdfs:comment 'Business-readable identifier for the corrective or preventive action, typically formatted as NCR-XXXX-CA-YY for traceability.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actionStatus rdf:type rdf:Property ;
    rdfs:label 'Action Status' ;
    rdfs:comment 'Current lifecycle state of the corrective action: open (assigned but not started), in_progress (work underway), pending_verification (awaiting QA/QC review), verified (effectiveness confirmed), closed (completed and accepted), cancelled (no longer required).' ;
    rdfs:domain ind:CorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actionType rdf:type rdf:Property ;
    rdfs:label 'Action Type' ;
    rdfs:comment 'Classification of the action: corrective (addresses existing defect), preventive (prevents recurrence), containment (immediate isolation), or interim (temporary measure pending permanent fix).' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignedDate rdf:type rdf:Property ;
    rdfs:label 'Assigned Date' ;
    rdfs:comment 'Date when the corrective action was formally assigned to the responsible party.' ;
    rdfs:domain ind:CorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:clientApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Client Approval Date' ;
    rdfs:comment 'Date when the client formally approved the corrective action plan. Null if client approval is not required or pending.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:costEstimate rdf:type rdf:Property ;
    rdfs:label 'Cost Estimate' ;
    rdfs:comment 'Estimated cost to implement the corrective action, including labor, materials, equipment, and any rework or schedule impact costs.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:effectivenessReviewDate rdf:type rdf:Property ;
    rdfs:label 'Effectiveness Review Date' ;
    rdfs:comment 'Date when the effectiveness of the corrective action was formally reviewed, typically 30-90 days after implementation.' ;
    rdfs:domain ind:CorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectivenessReviewOutcome rdf:type rdf:Property ;
    rdfs:label 'Effectiveness Review Outcome' ;
    rdfs:comment 'Result of the effectiveness review: effective (action resolved the issue and prevented recurrence), partially_effective (issue partially resolved, additional action required), ineffective (action did not resolve the issue), pending_review (awaiting final assessment).' ;
    rdfs:domain ind:CorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isSystemicIssue rdf:type rdf:Property ;
    rdfs:label 'Is Systemic Issue' ;
    rdfs:comment 'Indicates whether the root cause analysis identified this as a systemic issue requiring organization-wide corrective action across multiple projects or processes.' ;
    rdfs:domain ind:CorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiresClientApproval rdf:type rdf:Property ;
    rdfs:label 'Requires Client Approval' ;
    rdfs:comment 'Indicates whether the corrective action requires formal approval from the client or project owner before implementation.' ;
    rdfs:domain ind:CorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiresDesignChange rdf:type rdf:Property ;
    rdfs:label 'Requires Design Change' ;
    rdfs:comment 'Indicates whether the corrective action requires a formal design change, triggering BIM (Building Information Modeling) revision and engineering approval workflows.' ;
    rdfs:domain ind:CorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:targetCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Target Completion Date' ;
    rdfs:comment 'Planned date by which the corrective action must be completed to meet project schedule and compliance requirements.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:verifiedByName rdf:type rdf:Property ;
    rdfs:label 'Verified By Name' ;
    rdfs:comment 'Name of the individual who performed the verification of the corrective action.' ;
    rdfs:domain ind:CorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:averagePassRate rdf:type rdf:Property ;
    rdfs:label 'Average Pass Rate' ;
    rdfs:comment 'Historical average pass rate (percentage) for inspections conducted using this checklist, used to identify problematic activities or checklist items.' ;
    rdfs:domain ind:Checklist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:checklistCode rdf:type rdf:Property ;
    rdfs:label 'Checklist Code' ;
    rdfs:comment 'Externally-known unique business identifier for the checklist template, used for reference in inspection documentation and ITP (Inspection and Test Plan) workflows.' ;
    rdfs:domain ind:Checklist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checklistDescription rdf:type rdf:Property ;
    rdfs:label 'Checklist Description' ;
    rdfs:comment 'Detailed description of the checklist purpose, scope, and applicability, including any special instructions or prerequisites for use.' ;
    rdfs:domain ind:Checklist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checklistName rdf:type rdf:Property ;
    rdfs:label 'Checklist Name' ;
    rdfs:comment 'Human-readable name of the checklist template describing the inspection scope (e.g., \'Concrete Pour Inspection\', \'Rebar Placement Verification\', \'Waterproofing Application Check\').' ;
    rdfs:domain ind:Checklist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:criticalItemsCount rdf:type rdf:Property ;
    rdfs:label 'Critical Items Count' ;
    rdfs:comment 'Number of check items in this checklist that are classified as critical and must pass for overall acceptance.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:estimatedDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Estimated Duration Minutes' ;
    rdfs:comment 'Estimated time in minutes required to complete the inspection using this checklist, used for resource planning and scheduling.' ;
    rdfs:domain ind:Checklist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:frequency rdf:type rdf:Property ;
    rdfs:label 'Frequency' ;
    rdfs:comment 'Frequency or trigger for when this checklist should be used (e.g., per concrete pour, daily for ongoing work, per material batch). [ENUM-REF-CANDIDATE: per_occurrence|daily|weekly|monthly|per_batch|per_lot|as_required — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Checklist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdPointFlag rdf:type rdf:Property ;
    rdfs:label 'Hold Point Flag' ;
    rdfs:comment 'Indicates whether this checklist represents a hold point where work cannot proceed until inspection is completed and accepted.' ;
    rdfs:domain ind:Checklist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ncrTriggerThreshold rdf:type rdf:Property ;
    rdfs:label 'Ncr Trigger Threshold' ;
    rdfs:comment 'Criteria that automatically trigger the issuance of an NCR (Non-Conformance Report) when inspection results fail to meet this threshold.' ;
    rdfs:domain ind:Checklist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referenceDocuments rdf:type rdf:Property ;
    rdfs:label 'Reference Documents' ;
    rdfs:comment 'List of supporting documents, drawings, specifications, or procedures that inspectors should reference when using this checklist.' ;
    rdfs:domain ind:Checklist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiredEquipment rdf:type rdf:Property ;
    rdfs:label 'Required Equipment' ;
    rdfs:comment 'List of tools, instruments, or equipment required to perform the inspection per this checklist (e.g., \'tape measure, level, ultrasonic thickness gauge, calibrated thermometer\').' ;
    rdfs:domain ind:Checklist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiredQualifications rdf:type rdf:Property ;
    rdfs:label 'Required Qualifications' ;
    rdfs:comment 'Qualifications, certifications, or competencies required for the inspector who will use this checklist (e.g., \'AWS CWI\', \'ACI Level 1\', \'ASNT NDT Level II\').' ;
    rdfs:domain ind:Checklist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usageCount rdf:type rdf:Property ;
    rdfs:label 'Usage Count' ;
    rdfs:comment 'Number of times this checklist template has been used in actual field inspections, used for analytics and continuous improvement.' ;
    rdfs:domain ind:Checklist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:witnessPointFlag rdf:type rdf:Property ;
    rdfs:label 'Witness Point Flag' ;
    rdfs:comment 'Indicates whether this checklist represents a witness point where the client or third-party inspector must be notified and given opportunity to witness the inspection.' ;
    rdfs:domain ind:Checklist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:checklistExecutionId rdf:type rdf:Property ;
    rdfs:label 'Checklist Execution Id' ;
    rdfs:comment 'Unique identifier for the completed checklist execution instance. Primary key for this quality inspection record.' ;
    rdfs:domain ind:ChecklistExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryChecklistConstructionProjectId rdf:type rdf:Property ;
    rdfs:label 'Primary Checklist Construction Project Id' ;
    rdfs:comment 'Reference to the construction project under which this quality inspection was performed.' ;
    rdfs:domain ind:ChecklistExecution ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ConstructionProject .

ind:compliancePercentage rdf:type rdf:Property ;
    rdfs:label 'Compliance Percentage' ;
    rdfs:comment 'Calculated percentage of checklist items that passed inspection, excluding N/A items. Formula: (pass_count / (total_items - na_count)) * 100.' ;
    rdfs:domain ind:ChecklistExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:criticalFailureFlag rdf:type rdf:Property ;
    rdfs:label 'Critical Failure Flag' ;
    rdfs:comment 'Indicates whether any critical or safety-related inspection items failed, requiring immediate stop-work or remediation.' ;
    rdfs:domain ind:ChecklistExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:documentReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Document Reference Number' ;
    rdfs:comment 'Reference number linking this checklist execution to the project document management system for archival and retrieval.' ;
    rdfs:domain ind:ChecklistExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:executionDate rdf:type rdf:Property ;
    rdfs:label 'Execution Date' ;
    rdfs:comment 'Date when the quality inspection checklist was executed on site.' ;
    rdfs:domain ind:ChecklistExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:executionEndTime rdf:type rdf:Property ;
    rdfs:label 'Execution End Time' ;
    rdfs:comment 'Timestamp when the inspector completed the checklist execution and submitted the results.' ;
    rdfs:domain ind:ChecklistExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:executionNumber rdf:type rdf:Property ;
    rdfs:label 'Execution Number' ;
    rdfs:comment 'Business-readable unique identifier for this checklist execution, often formatted as project-discipline-sequence (e.g., PRJ001-QC-0123).' ;
    rdfs:domain ind:ChecklistExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:executionStartTime rdf:type rdf:Property ;
    rdfs:label 'Execution Start Time' ;
    rdfs:comment 'Timestamp when the inspector began the checklist execution on site.' ;
    rdfs:domain ind:ChecklistExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:failCount rdf:type rdf:Property ;
    rdfs:label 'Fail Count' ;
    rdfs:comment 'Number of checklist items that failed inspection criteria and require corrective action.' ;
    rdfs:domain ind:ChecklistExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:humidityPercentage rdf:type rdf:Property ;
    rdfs:label 'Humidity Percentage' ;
    rdfs:comment 'Relative humidity percentage at the time of inspection, relevant for coating, painting, and material testing activities.' ;
    rdfs:domain ind:ChecklistExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inspectorRemarks rdf:type rdf:Property ;
    rdfs:label 'Inspector Remarks' ;
    rdfs:comment 'General observations, comments, or notes recorded by the inspector during the checklist execution. Provides context for inspection results.' ;
    rdfs:domain ind:ChecklistExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectorSignatureTimestamp rdf:type rdf:Property ;
    rdfs:label 'Inspector Signature Timestamp' ;
    rdfs:comment 'Timestamp when the inspector digitally signed off on the completed checklist execution.' ;
    rdfs:domain ind:ChecklistExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:naCount rdf:type rdf:Property ;
    rdfs:label 'Na Count' ;
    rdfs:comment 'Number of checklist items marked as not applicable to this specific inspection instance.' ;
    rdfs:domain ind:ChecklistExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ncrGeneratedFlag rdf:type rdf:Property ;
    rdfs:label 'Ncr Generated Flag' ;
    rdfs:comment 'Indicates whether this inspection resulted in the generation of one or more NCRs (Non-Conformance Reports) for failed items.' ;
    rdfs:domain ind:ChecklistExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:passCount rdf:type rdf:Property ;
    rdfs:label 'Pass Count' ;
    rdfs:comment 'Number of checklist items that passed inspection criteria.' ;
    rdfs:domain ind:ChecklistExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalItems rdf:type rdf:Property ;
    rdfs:label 'Total Items' ;
    rdfs:comment 'Total number of inspection items in the executed checklist.' ;
    rdfs:domain ind:ChecklistExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:witnessName rdf:type rdf:Property ;
    rdfs:label 'Witness Name' ;
    rdfs:comment 'Full name of the witness who co-signed the inspection for display and reporting purposes.' ;
    rdfs:domain ind:ChecklistExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:witnessRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Witness Required Flag' ;
    rdfs:comment 'Indicates whether this inspection requires a witness signature from client, consultant, or third-party inspector per contract requirements.' ;
    rdfs:domain ind:ChecklistExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:witnessSignatureTimestamp rdf:type rdf:Property ;
    rdfs:label 'Witness Signature Timestamp' ;
    rdfs:comment 'Timestamp when the witness digitally signed off on the completed checklist execution.' ;
    rdfs:domain ind:ChecklistExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:workActivityDescription rdf:type rdf:Property ;
    rdfs:label 'Work Activity Description' ;
    rdfs:comment 'Detailed description of the specific construction work activity or deliverable being inspected (e.g., \'Foundation concrete pour - Grid A1 to A5\', \'HVAC ductwork installation - Level 3\').' ;
    rdfs:domain ind:ChecklistExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testCertificateId rdf:type rdf:Property ;
    rdfs:label 'Test Certificate Id' ;
    rdfs:comment 'Primary key for test_certificate' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TestCertificate .

ind:accreditationBody rdf:type rdf:Property ;
    rdfs:label 'Accreditation Body' ;
    rdfs:comment 'Name of the accreditation authority that certified the laboratory (e.g., UKAS, A2LA, NABL, NATA).' ;
    rdfs:domain ind:TestCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryLotNumber rdf:type rdf:Property ;
    rdfs:label 'Delivery Lot Number' ;
    rdfs:comment 'Delivery or shipment lot number identifying the specific material consignment from which the sample was taken. Links certificate to goods receipt.' ;
    rdfs:domain ind:TestCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:heatNumber rdf:type rdf:Property ;
    rdfs:label 'Heat Number' ;
    rdfs:comment 'Steel mill heat number for steel and rebar materials, identifying the specific furnace melt. Essential for metallurgical traceability.' ;
    rdfs:domain ind:TestCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingLaboratory rdf:type rdf:Property ;
    rdfs:label 'Issuing Laboratory' ;
    rdfs:comment 'Name of the testing laboratory or organization that performed the tests and issued the certificate.' ;
    rdfs:domain ind:TestCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:laboratoryAccreditationNumber rdf:type rdf:Property ;
    rdfs:label 'Laboratory Accreditation Number' ;
    rdfs:comment 'Accreditation certificate number issued by the national or international accreditation body (e.g., ISO/IEC 17025 accreditation number). Validates the laboratory\'s competence.' ;
    rdfs:domain ind:TestCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialDescription rdf:type rdf:Property ;
    rdfs:label 'Material Description' ;
    rdfs:comment 'Detailed textual description of the material being tested, including grade, specification, and any relevant characteristics (e.g., Grade 60 Rebar, M30 Concrete, AC-20 Bitumen).' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialType rdf:type rdf:Property ;
    rdfs:label 'Material Type' ;
    rdfs:comment 'Category of construction material being tested. Covers primary materials used in infrastructure and building construction projects. [ENUM-REF-CANDIDATE: concrete|steel|aggregate|bitumen|soil|asphalt|geotextile|cement|rebar|structural_steel|weld|paint|coating — 13 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:passFailStatus rdf:type rdf:Property ;
    rdfs:label 'Pass Fail Status' ;
    rdfs:comment 'Overall determination of whether the tested material meets the specification requirements. Conditional pass indicates minor deviations requiring engineering review.' ;
    rdfs:domain ind:TestCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:samplingDate rdf:type rdf:Property ;
    rdfs:label 'Sampling Date' ;
    rdfs:comment 'Date when the material sample was collected from the batch, delivery, or construction site for testing.' ;
    rdfs:domain ind:TestCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:samplingLocation rdf:type rdf:Property ;
    rdfs:label 'Sampling Location' ;
    rdfs:comment 'Physical location where the material sample was collected (e.g., site name, warehouse, delivery truck, production line, grid reference).' ;
    rdfs:domain ind:TestCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specificationRequirement rdf:type rdf:Property ;
    rdfs:label 'Specification Requirement' ;
    rdfs:comment 'Required values or acceptance criteria per project specification, contract, or standard (e.g., minimum compressive strength 30 MPa, yield strength 420 MPa min).' ;
    rdfs:domain ind:TestCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technicianName rdf:type rdf:Property ;
    rdfs:label 'Technician Name' ;
    rdfs:comment 'Name of the laboratory technician or engineer who performed the testing and signed the certificate.' ;
    rdfs:domain ind:TestCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testDate rdf:type rdf:Property ;
    rdfs:label 'Test Date' ;
    rdfs:comment 'Date when the laboratory or field testing was performed on the sample.' ;
    rdfs:domain ind:TestCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:testMethod rdf:type rdf:Property ;
    rdfs:label 'Test Method' ;
    rdfs:comment 'Specific testing procedure or method applied (e.g., compression test, tensile test, slump test, sieve analysis, chemical analysis).' ;
    rdfs:domain ind:TestCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testParameters rdf:type rdf:Property ;
    rdfs:label 'Test Parameters' ;
    rdfs:comment 'List of specific properties or characteristics measured during testing (e.g., compressive strength, yield strength, elongation, gradation, moisture content). Stored as structured text or JSON.' ;
    rdfs:domain ind:TestCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testResults rdf:type rdf:Property ;
    rdfs:label 'Test Results' ;
    rdfs:comment 'Measured values and outcomes for each test parameter. Stored as structured text or JSON containing parameter-value pairs with units.' ;
    rdfs:domain ind:TestCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testStandard rdf:type rdf:Property ;
    rdfs:label 'Test Standard' ;
    rdfs:comment 'Industry or regulatory test standard followed during testing (e.g., ASTM C39, BS EN 12390, AASHTO T22, ISO 6892). Defines the test methodology and acceptance criteria.' ;
    rdfs:domain ind:TestCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workPackageCode rdf:type rdf:Property ;
    rdfs:label 'Work Package Code' ;
    rdfs:comment 'Work Breakdown Structure (WBS) code or work package identifier indicating where the tested material will be used in the project.' ;
    rdfs:domain ind:TestCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defectId rdf:type rdf:Property ;
    rdfs:label 'Defect Id' ;
    rdfs:comment 'Unique identifier for the defect record. Primary key for the defect entity.' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Defect .

ind:actualRectificationDate rdf:type rdf:Property ;
    rdfs:label 'Actual Rectification Date' ;
    rdfs:comment 'Actual date when the defect rectification work was completed.' ;
    rdfs:domain ind:Defect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assignedTo rdf:type rdf:Property ;
    rdfs:label 'Assigned To' ;
    rdfs:comment 'Name of the individual or team currently assigned to manage or rectify the defect.' ;
    rdfs:domain ind:Defect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defectDescription rdf:type rdf:Property ;
    rdfs:label 'Defect Description' ;
    rdfs:comment 'Detailed description of the defect including nature, extent, and any observable symptoms or deviations from specification.' ;
    rdfs:domain ind:Defect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defectNumber rdf:type rdf:Property ;
    rdfs:label 'Defect Number' ;
    rdfs:comment 'Business-facing unique identifier or reference number for the defect, typically used in correspondence and reporting.' ;
    rdfs:domain ind:Defect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defectStatus rdf:type rdf:Property ;
    rdfs:label 'Defect Status' ;
    rdfs:comment 'Current lifecycle status of the defect: open (newly identified), assigned (allocated to responsible party), in_progress (rectification underway), rectified (work completed, awaiting verification), verified (inspected and accepted), closed (fully resolved), rejected (not a valid defect). [ENUM-REF-CANDIDATE: open|assigned|in_progress|rectified|verified|closed|rejected — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Defect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defectType rdf:type rdf:Property ;
    rdfs:label 'Defect Type' ;
    rdfs:comment 'Classification of the defect by nature: workmanship (poor execution), material (defective materials), design (design flaw), installation (incorrect installation), finish (cosmetic/surface defects), structural (load-bearing issues), MEP (Mechanical Electrical Plumbing systems), or other. [ENUM-REF-CANDIDATE: workmanship|material|design|installation|finish|structural|MEP|other — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Defect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:identifiedBy rdf:type rdf:Property ;
    rdfs:label 'Identified By' ;
    rdfs:comment 'Name of the person or role who identified the defect (e.g., QA/QC inspector, client representative, commissioning engineer, site supervisor).' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impactOnHandover rdf:type rdf:Property ;
    rdfs:label 'Impact On Handover' ;
    rdfs:comment 'Indicates whether the defect impacts project handover or commissioning milestones (True if it blocks handover, False otherwise).' ;
    rdfs:domain ind:Defect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:locationBuilding rdf:type rdf:Property ;
    rdfs:label 'Location Building' ;
    rdfs:comment 'Building or structure identifier where the defect is located (e.g., Building A, Main Terminal, Power Block 1).' ;
    rdfs:domain ind:Defect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:locationGridReference rdf:type rdf:Property ;
    rdfs:label 'Location Grid Reference' ;
    rdfs:comment 'Grid reference or coordinate system identifier pinpointing the defect location on construction drawings (e.g., Grid A-3, Column Line B/5).' ;
    rdfs:domain ind:Defect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:locationLevel rdf:type rdf:Property ;
    rdfs:label 'Location Level' ;
    rdfs:comment 'Floor or level identifier where the defect is located (e.g., Ground Floor, Level 3, Basement 2, Roof).' ;
    rdfs:domain ind:Defect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:locationZone rdf:type rdf:Property ;
    rdfs:label 'Location Zone' ;
    rdfs:comment 'Zone, area, or room identifier where the defect is located (e.g., Zone A, Room 301, Lobby, Mechanical Room).' ;
    rdfs:domain ind:Defect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:photoReference rdf:type rdf:Property ;
    rdfs:label 'Photo Reference' ;
    rdfs:comment 'Reference or file path to photographic evidence of the defect, typically stored in document management system (e.g., Aconex, BIM 360).' ;
    rdfs:domain ind:Quality ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rectificationCost rdf:type rdf:Property ;
    rdfs:label 'Rectification Cost' ;
    rdfs:comment 'Estimated or actual cost incurred to rectify the defect, typically borne by the responsible contractor.' ;
    rdfs:domain ind:Defect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rectificationMethod rdf:type rdf:Property ;
    rdfs:label 'Rectification Method' ;
    rdfs:comment 'Description of the method or approach used to rectify the defect (e.g., rework, replacement, repair, adjustment, re-finishing).' ;
    rdfs:domain ind:Defect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetRectificationDate rdf:type rdf:Property ;
    rdfs:label 'Target Rectification Date' ;
    rdfs:comment 'Target or planned date by which the defect should be rectified, often driven by DLP (Defects Liability Period) expiry or contractual milestones.' ;
    rdfs:domain ind:Defect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:tradeDiscipline rdf:type rdf:Property ;
    rdfs:label 'Trade Discipline' ;
    rdfs:comment 'Construction trade or discipline responsible for the work where the defect occurred (e.g., Concrete, Steel, MEP, HVAC, Electrical, Plumbing, Finishes, Painting).' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:punchListId rdf:type rdf:Property ;
    rdfs:label 'Punch List Id' ;
    rdfs:comment 'Unique identifier for the punch list record. Primary key for the punch list entity.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PunchList .

ind:actualCloseoutDate rdf:type rdf:Property ;
    rdfs:label 'Actual Closeout Date' ;
    rdfs:comment 'The actual date on which the punch list was fully closed, indicating all items have been resolved and accepted. Nullable until closure is achieved.' ;
    rdfs:domain ind:PunchList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:closedItemsCount rdf:type rdf:Property ;
    rdfs:label 'Closed Items Count' ;
    rdfs:comment 'The current count of punch list items that have been resolved and closed. Indicates progress toward full punch list closure.' ;
    rdfs:domain ind:PunchList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contractReference rdf:type rdf:Property ;
    rdfs:label 'Contract Reference' ;
    rdfs:comment 'Reference to the contract or contract package under which this punch list is being managed. Links the punch list to contractual obligations and terms.' ;
    rdfs:domain ind:PunchList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dlpCommencementGate rdf:type rdf:Property ;
    rdfs:label 'Dlp Commencement Gate' ;
    rdfs:comment 'Boolean flag indicating whether closure of this punch list triggers the start of the Defects Liability Period (DLP). True means DLP clock starts upon punch list closure.' ;
    rdfs:domain ind:PunchList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:handoverGate rdf:type rdf:Property ;
    rdfs:label 'Handover Gate' ;
    rdfs:comment 'Boolean flag indicating whether closure of this punch list is a contractual gate for project handover. True means handover cannot proceed until this list is closed.' ;
    rdfs:domain ind:PunchList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:openItemsCount rdf:type rdf:Property ;
    rdfs:label 'Open Items Count' ;
    rdfs:comment 'The current count of punch list items that remain open or unresolved. Used to track progress toward close-out.' ;
    rdfs:domain ind:PunchList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:projectArea rdf:type rdf:Property ;
    rdfs:label 'Project Area' ;
    rdfs:comment 'The physical area, zone, building, or section of the project to which this punch list applies (e.g., \'Building A\', \'Zone 3\', \'East Wing\', \'Substation 2\').' ;
    rdfs:domain ind:PunchList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:punchListName rdf:type rdf:Property ;
    rdfs:label 'Punch List Name' ;
    rdfs:comment 'Descriptive name or title for the punch list, often indicating the milestone, area, or phase it relates to (e.g., \'Mechanical Completion - Building A\', \'Practical Completion - Zone 3\').' ;
    rdfs:domain ind:PunchList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:punchListNumber rdf:type rdf:Property ;
    rdfs:label 'Punch List Number' ;
    rdfs:comment 'Business identifier for the punch list, typically a human-readable code or number used for tracking and reference in project documentation and handover processes.' ;
    rdfs:domain ind:PunchList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:punchListStatus rdf:type rdf:Property ;
    rdfs:label 'Punch List Status' ;
    rdfs:comment 'Current lifecycle status of the punch list. Indicates whether the list is being compiled, actively worked, under review, or closed out.' ;
    rdfs:domain ind:PunchList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsiblePartyType rdf:type rdf:Property ;
    rdfs:label 'Responsible Party Type' ;
    rdfs:comment 'Classification of the party responsible for punch list resolution. Helps route accountability and track performance by party type.' ;
    rdfs:domain ind:PunchList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetCloseoutDate rdf:type rdf:Property ;
    rdfs:label 'Target Closeout Date' ;
    rdfs:comment 'The planned or contractually required date by which all items on the punch list must be resolved and the list closed. Critical for handover and DLP (Defects Liability Period) commencement.' ;
    rdfs:domain ind:PunchList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:totalItemsCount rdf:type rdf:Property ;
    rdfs:label 'Total Items Count' ;
    rdfs:comment 'The total number of punch list items (defects, incomplete works, commissioning tasks) recorded on this punch list.' ;
    rdfs:domain ind:PunchList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:creationDate rdf:type rdf:Property ;
    rdfs:label 'Creation Date' ;
    rdfs:comment 'The date on which the punch list was initially created or issued. Marks the start of the close-out tracking process for the associated milestone.' ;
    rdfs:domain ind:PunchList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:punchItemId rdf:type rdf:Property ;
    rdfs:label 'Punch Item Id' ;
    rdfs:comment 'Unique identifier for the punch list item. Primary key.' ;
    rdfs:domain ind:PunchItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:clientRepresentativeName rdf:type rdf:Property ;
    rdfs:label 'Client Representative Name' ;
    rdfs:comment 'Name of the client representative or consultant who witnessed or approved the punch item closure. Provides client acceptance traceability.' ;
    rdfs:domain ind:PunchItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveAction rdf:type rdf:Property ;
    rdfs:label 'Corrective Action' ;
    rdfs:comment 'Description of the corrective action taken or required to resolve the punch item. Provides remediation guidance and audit trail.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costImpact rdf:type rdf:Property ;
    rdfs:label 'Cost Impact' ;
    rdfs:comment 'Estimated or actual cost incurred to rectify the punch item. Used for financial tracking and back-charge to responsible parties.' ;
    rdfs:domain ind:PunchItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deferredToDlp rdf:type rdf:Property ;
    rdfs:label 'Deferred To Dlp' ;
    rdfs:comment 'Flag indicating whether the punch item was deferred to the DLP (Defects Liability Period) for post-handover rectification. True if deferred; false otherwise.' ;
    rdfs:domain ind:PunchItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:punchItemCategory rdf:type rdf:Property ;
    rdfs:label 'Punch Item Category' ;
    rdfs:comment 'Classification of the punch item by discipline or trade. Structural covers concrete, steel, and load-bearing elements; MEP (Mechanical Electrical and Plumbing) covers HVAC, electrical, plumbing, and fire protection; Architectural covers doors, windows, ceilings, and interior finishes; Civil covers site work, paving, and drainage; Finishes covers painting, flooring, and decorative elements; Landscaping covers external plantings and hardscapes.' ;
    rdfs:domain ind:PunchItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:punchItemStatus rdf:type rdf:Property ;
    rdfs:label 'Punch Item Status' ;
    rdfs:comment 'Current lifecycle status of the punch item. Open indicates newly identified; in_progress indicates work underway; completed indicates work finished awaiting verification; verified indicates inspection passed; closed indicates final acceptance; rejected indicates failed verification requiring rework.' ;
    rdfs:domain ind:PunchItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationInspector rdf:type rdf:Property ;
    rdfs:label 'Verification Inspector' ;
    rdfs:comment 'Name of the inspector or quality engineer who verified that the punch item was satisfactorily completed. Provides accountability for quality sign-off.' ;
    rdfs:domain ind:PunchItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedByName rdf:type rdf:Property ;
    rdfs:label 'Approved By Name' ;
    rdfs:comment 'Name of the individual who formally approved the quality plan for implementation.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedByRole rdf:type rdf:Property ;
    rdfs:label 'Approved By Role' ;
    rdfs:comment 'Organizational role or title of the approver (e.g., Project Director, Quality Director).' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditScheduleReference rdf:type rdf:Property ;
    rdfs:label 'Audit Schedule Reference' ;
    rdfs:comment 'Reference to the internal and external audit schedule defined for the project.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calibrationProcedureReference rdf:type rdf:Property ;
    rdfs:label 'Calibration Procedure Reference' ;
    rdfs:comment 'Reference to the procedure for calibration and maintenance of inspection, measuring, and test equipment.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clientApprovalRequired rdf:type rdf:Property ;
    rdfs:label 'Client Approval Required' ;
    rdfs:comment 'Indicates whether client approval is contractually required for this quality plan.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:continuousImprovementMechanism rdf:type rdf:Property ;
    rdfs:label 'Continuous Improvement Mechanism' ;
    rdfs:comment 'Description of mechanisms for continuous improvement, including lessons learned, corrective actions, and preventive actions.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentControlProcedure rdf:type rdf:Property ;
    rdfs:label 'Document Control Procedure' ;
    rdfs:comment 'Description of document control procedures for quality records, including numbering, distribution, revision, and archival.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:handoverQualityRequirements rdf:type rdf:Property ;
    rdfs:label 'Handover Quality Requirements' ;
    rdfs:comment 'Description of quality documentation and completion criteria required for project handover and commissioning.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionRegimeSummary rdf:type rdf:Property ;
    rdfs:label 'Inspection Regime Summary' ;
    rdfs:comment 'High-level summary of the inspection and testing regime, including hold points, witness points, and surveillance activities.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:itpRegisterReference rdf:type rdf:Property ;
    rdfs:label 'Itp Register Reference' ;
    rdfs:comment 'Reference to the master ITP register that lists all inspection and test plans governed by this quality plan.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialControlProcedure rdf:type rdf:Property ;
    rdfs:label 'Material Control Procedure' ;
    rdfs:comment 'Description of procedures for material receipt, inspection, storage, and traceability.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ncrProcedureReference rdf:type rdf:Property ;
    rdfs:label 'Ncr Procedure Reference' ;
    rdfs:comment 'Reference to the procedure for raising, investigating, and closing Non-Conformance Reports.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:organizationalStructure rdf:type rdf:Property ;
    rdfs:label 'Organizational Structure' ;
    rdfs:comment 'Description of the project quality organization, including roles, responsibilities, and reporting lines.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preparedByName rdf:type rdf:Property ;
    rdfs:label 'Prepared By Name' ;
    rdfs:comment 'Name of the individual or team responsible for preparing the quality plan.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preparedByRole rdf:type rdf:Property ;
    rdfs:label 'Prepared By Role' ;
    rdfs:comment 'Organizational role or title of the person who prepared the quality plan (e.g., Quality Manager, QA/QC Engineer).' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityManagerName rdf:type rdf:Property ;
    rdfs:label 'Quality Manager Name' ;
    rdfs:comment 'Name of the designated Quality Manager responsible for implementing this plan.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityObjectives rdf:type rdf:Property ;
    rdfs:label 'Quality Objectives' ;
    rdfs:comment 'Specific, measurable quality objectives defined for the project (e.g., zero NCRs in critical systems, 100% ITP compliance).' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityPolicyReference rdf:type rdf:Property ;
    rdfs:label 'Quality Policy Reference' ;
    rdfs:comment 'Reference to the organizational quality policy document that this plan implements.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewedByName rdf:type rdf:Property ;
    rdfs:label 'Reviewed By Name' ;
    rdfs:comment 'Name of the individual who reviewed the quality plan for technical accuracy and completeness.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewedByRole rdf:type rdf:Property ;
    rdfs:label 'Reviewed By Role' ;
    rdfs:comment 'Organizational role or title of the reviewer (e.g., Project Manager, Senior QA/QC Manager).' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scopeOfWork rdf:type rdf:Property ;
    rdfs:label 'Scope Of Work' ;
    rdfs:comment 'Description of the project scope covered by this quality plan, including major deliverables and work packages.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subcontractorQualityManagement rdf:type rdf:Property ;
    rdfs:label 'Subcontractor Quality Management' ;
    rdfs:comment 'Description of quality management requirements and oversight procedures for subcontractors and suppliers.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingRequirements rdf:type rdf:Property ;
    rdfs:label 'Training Requirements' ;
    rdfs:comment 'Description of quality-related training requirements for project personnel, including induction, competency assessments, and certifications.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:version rdf:type rdf:Property ;
    rdfs:label 'Version' ;
    rdfs:comment 'Version identifier for the quality plan document, incremented with each revision.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressLine1 rdf:type rdf:Property ;
    rdfs:label 'Address Line 1' ;
    rdfs:comment 'First line of the vendor\'s registered business address. Typically contains street number and street name. Used for correspondence, legal notices, and payment remittance.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressLine2 rdf:type rdf:Property ;
    rdfs:label 'Address Line 2' ;
    rdfs:comment 'Second line of the vendor\'s business address. Contains suite, floor, building, or other secondary address information. Nullable if not applicable.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:annualRevenueAmount rdf:type rdf:Property ;
    rdfs:label 'Annual Revenue Amount' ;
    rdfs:comment 'Vendor\'s reported annual revenue in the vendor\'s default currency. Used for vendor size classification, capacity assessment, and financial stability evaluation. Typically self-reported or obtained from financial statements.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:auditResult rdf:type rdf:Property ;
    rdfs:label 'Audit Result' ;
    rdfs:comment 'Outcome of the most recent vendor audit. Passed indicates full compliance; passed with conditions indicates minor findings requiring corrective action; failed indicates major non-conformances; not audited indicates no audit has been conducted.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Bank Account Number' ;
    rdfs:comment 'Vendor\'s bank account number for electronic payment receipt. Highly sensitive financial information used for ACH and wire transfer processing. Encrypted at rest and in transit.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankName rdf:type rdf:Property ;
    rdfs:label 'Bank Name' ;
    rdfs:comment 'Name of the financial institution where the vendor maintains their primary business account for payment receipt. Used for electronic payment processing and wire transfers.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankRoutingNumber rdf:type rdf:Property ;
    rdfs:label 'Bank Routing Number' ;
    rdfs:comment 'Bank routing number, SWIFT code, or IBAN for the vendor\'s bank account. Used to route electronic payments to the correct financial institution. Format varies by country and payment network.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bondingCapacityAmount rdf:type rdf:Property ;
    rdfs:label 'Bonding Capacity Amount' ;
    rdfs:comment 'Maximum bonding capacity available to the vendor in the vendor\'s default currency. Represents the total value of performance bonds and payment bonds the vendor can secure from their surety. Critical for subcontractor prequalification and large contract awards.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:diversityClassification rdf:type rdf:Property ;
    rdfs:label 'Diversity Classification' ;
    rdfs:comment 'Diversity certification status for the vendor. MBE (Minority Business Enterprise), WBE (Women Business Enterprise), DBE (Disadvantaged Business Enterprise), SDVOSB (Service-Disabled Veteran-Owned Small Business), HUBZone (Historically Underutilized Business Zone). Used for diversity spend reporting and compliance with client diversity requirements.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicCoverage rdf:type rdf:Property ;
    rdfs:label 'Geographic Coverage' ;
    rdfs:comment 'Geographic regions or markets where the vendor operates and can provide services. Free-text field listing countries, states, or regions. Used for project-specific vendor selection and logistics planning.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastAuditDate rdf:type rdf:Property ;
    rdfs:label 'Last Audit Date' ;
    rdfs:comment 'Date of the most recent vendor audit or compliance review. Audits assess quality systems, safety practices, financial controls, and contract compliance. Used to schedule periodic re-audits and maintain vendor qualification status.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:preferredVendorFlag rdf:type rdf:Property ;
    rdfs:label 'Preferred Vendor Flag' ;
    rdfs:comment 'Boolean flag indicating whether this vendor has preferred vendor status. Preferred vendors receive priority consideration for bid invitations, expedited approval processes, and favorable payment terms based on proven performance and strategic relationship.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:prequalificationScore rdf:type rdf:Property ;
    rdfs:label 'Prequalification Score' ;
    rdfs:comment 'Composite score from the vendor prequalification process evaluating financial stability, technical capability, safety record, quality performance, and past project experience. Scale typically 0-100. Used for vendor ranking and bid invitation decisions.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualityCertification rdf:type rdf:Property ;
    rdfs:label 'Quality Certification' ;
    rdfs:comment 'Quality management system certifications held by the vendor. Common certifications include ISO 9001 (Quality Management), ISO 14001 (Environmental Management), ISO 45001 (Occupational Health and Safety). Multiple certifications separated by semicolons.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationDate rdf:type rdf:Property ;
    rdfs:label 'Registration Date' ;
    rdfs:comment 'Date when the vendor was first registered in the vendor master system. Marks the beginning of the vendor relationship and is used for vendor tenure analysis and anniversary tracking.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:suspensionEndDate rdf:type rdf:Property ;
    rdfs:label 'Suspension End Date' ;
    rdfs:comment 'Planned or actual date when vendor suspension will be or was lifted. Nullable for indefinite suspensions or vendors that have never been suspended. Used for reinstatement planning and compliance tracking.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:suspensionStartDate rdf:type rdf:Property ;
    rdfs:label 'Suspension Start Date' ;
    rdfs:comment 'Date when vendor suspension or blocking became effective. Used to track suspension duration and trigger review processes. Nullable for vendors that have never been suspended.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:taxIdentificationNumber rdf:type rdf:Property ;
    rdfs:label 'Tax Identification Number' ;
    rdfs:comment 'Government-issued tax identification number for the vendor. Used for tax reporting, 1099 processing, and compliance with tax regulations. Format varies by jurisdiction (EIN in USA, VAT number in EU, GST number in other regions).' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorName rdf:type rdf:Property ;
    rdfs:label 'Vendor Name' ;
    rdfs:comment 'Full legal name of the vendor organization as registered with tax authorities. Used on contracts, purchase orders, and payment documents. Must match legal registration documents.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorStatus rdf:type rdf:Property ;
    rdfs:label 'Vendor Status' ;
    rdfs:comment 'Current lifecycle status of the vendor in the vendor master. Approved vendors can receive purchase orders; prospective vendors are under evaluation; suspended vendors have temporary restrictions; blocked vendors cannot receive new orders; inactive vendors are no longer used; under_review vendors are being re-qualified.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedMaterialCategories rdf:type rdf:Property ;
    rdfs:label 'Approved Material Categories' ;
    rdfs:comment 'Comma-separated list of material categories the vendor is qualified to supply. Examples include concrete, steel, MEP (Mechanical Electrical and Plumbing) equipment, formwork, aggregates. Aligns with MTO (Material Take-Off) classification.' ;
    rdfs:domain ind:VendorQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedServiceTypes rdf:type rdf:Property ;
    rdfs:label 'Approved Service Types' ;
    rdfs:comment 'Comma-separated list of service types the vendor is qualified to provide. Examples include earthworks, structural steel erection, electrical installation, HVAC installation, concrete placement, surveying.' ;
    rdfs:domain ind:VendorQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bondingCapacityCurrency rdf:type rdf:Property ;
    rdfs:label 'Bonding Capacity Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for bonding capacity limit. Typically USD for US-based projects.' ;
    rdfs:domain ind:VendorQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bondingCapacityLimit rdf:type rdf:Property ;
    rdfs:label 'Bonding Capacity Limit' ;
    rdfs:comment 'Maximum bonding capacity available from the vendor\'s surety company. Determines the maximum contract value the vendor can undertake. Critical for GC (General Contractor) and major subcontractor qualifications.' ;
    rdfs:domain ind:VendorQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:financialHealthScore rdf:type rdf:Property ;
    rdfs:label 'Financial Health Score' ;
    rdfs:comment 'Composite financial health assessment score ranging from 0.00 to 100.00. Based on credit rating, liquidity ratios, debt-to-equity, and financial statement analysis. Minimum threshold typically 60.00 for approval.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hsePerformanceRating rdf:type rdf:Property ;
    rdfs:label 'Hse Performance Rating' ;
    rdfs:comment 'HSE (Health Safety and Environment) performance rating based on TRIR (Total Recordable Incident Rate), LTI (Lost Time Injury) frequency, safety audit results, and compliance with OSHA (Occupational Safety and Health Administration) standards. Critical factor for vendor approval.' ;
    rdfs:domain ind:VendorQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceCertificateExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Insurance Certificate Expiry Date' ;
    rdfs:comment 'Expiry date of the vendor\'s insurance certificate. Procurement tracks this to ensure continuous coverage throughout contract execution.' ;
    rdfs:domain ind:VendorQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:insuranceGeneralLiabilityLimit rdf:type rdf:Property ;
    rdfs:label 'Insurance General Liability Limit' ;
    rdfs:comment 'General liability insurance coverage limit. Minimum requirements typically range from $1M to $10M depending on project size and risk profile.' ;
    rdfs:domain ind:VendorQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:insuranceWorkersCompVerified rdf:type rdf:Property ;
    rdfs:label 'Insurance Workers Comp Verified' ;
    rdfs:comment 'Indicates whether valid workers compensation insurance has been verified. Mandatory for all vendors providing on-site labor per OSHA (Occupational Safety and Health Administration) requirements.' ;
    rdfs:domain ind:VendorQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:iso14001CertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Iso 14001 Certificate Number' ;
    rdfs:comment 'Certificate number for ISO 14001 Environmental Management System certification.' ;
    rdfs:domain ind:VendorQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iso14001Certified rdf:type rdf:Property ;
    rdfs:label 'Iso 14001 Certified' ;
    rdfs:comment 'Indicates whether the vendor holds valid ISO 14001 Environmental Management System certification. Increasingly required for LEED (Leadership in Energy and Environmental Design) projects and environmentally sensitive sites.' ;
    rdfs:domain ind:VendorQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:iso14001ExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Iso 14001 Expiry Date' ;
    rdfs:comment 'Expiry date of ISO 14001 certification. Critical for projects with EPA (Environmental Protection Agency) compliance requirements.' ;
    rdfs:domain ind:VendorQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:iso45001CertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Iso 45001 Certificate Number' ;
    rdfs:comment 'Certificate number for ISO 45001 Occupational Health and Safety Management System certification.' ;
    rdfs:domain ind:VendorQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iso45001Certified rdf:type rdf:Property ;
    rdfs:label 'Iso 45001 Certified' ;
    rdfs:comment 'Indicates whether the vendor holds valid ISO 45001 Occupational Health and Safety Management System certification. Demonstrates commitment to worker safety and HSE (Health Safety and Environment) excellence.' ;
    rdfs:domain ind:VendorQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:iso45001ExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Iso 45001 Expiry Date' ;
    rdfs:comment 'Expiry date of ISO 45001 certification. Monitored to ensure ongoing HSE (Health Safety and Environment) compliance.' ;
    rdfs:domain ind:VendorQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:iso9001CertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Iso 9001 Certificate Number' ;
    rdfs:comment 'Certificate number for ISO 9001 Quality Management System certification. Used for verification with certification body.' ;
    rdfs:domain ind:VendorQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iso9001Certified rdf:type rdf:Property ;
    rdfs:label 'Iso 9001 Certified' ;
    rdfs:comment 'Indicates whether the vendor holds valid ISO 9001 Quality Management System certification. Often mandatory for critical material suppliers and major subcontractors.' ;
    rdfs:domain ind:VendorQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:iso9001ExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Iso 9001 Expiry Date' ;
    rdfs:comment 'Expiry date of ISO 9001 certification. Procurement monitors this to ensure vendors maintain valid certification throughout contract execution.' ;
    rdfs:domain ind:VendorQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ltiFrequencyRate rdf:type rdf:Property ;
    rdfs:label 'Lti Frequency Rate' ;
    rdfs:comment 'LTI (Lost Time Injury) frequency rate calculated as (number of LTIs × 1,000,000) / total hours worked. Measures severity of safety incidents. Target is typically below 1.0 for qualified vendors.' ;
    rdfs:domain ind:VendorQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:onTimeDeliveryRate rdf:type rdf:Property ;
    rdfs:label 'On Time Delivery Rate' ;
    rdfs:comment 'Percentage of past deliveries completed on or before scheduled date. Critical metric for CPM (Critical Path Method) schedule-sensitive projects. Target is typically above 90.00%.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pastPerformanceScore rdf:type rdf:Property ;
    rdfs:label 'Past Performance Score' ;
    rdfs:comment 'Composite past performance score ranging from 0.00 to 100.00. Based on historical project delivery, quality, schedule adherence, cost control, and client satisfaction. Derived from completed project evaluations and NCR (Non-Conformance Report) history.' ;
    rdfs:domain ind:VendorQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualificationAssessmentDate rdf:type rdf:Property ;
    rdfs:label 'Qualification Assessment Date' ;
    rdfs:comment 'Date when the qualification assessment was conducted. Includes site visits, document reviews, financial analysis, and technical capability evaluation.' ;
    rdfs:domain ind:VendorQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qualificationCategory rdf:type rdf:Property ;
    rdfs:label 'Qualification Category' ;
    rdfs:comment 'Primary category of goods or services the vendor is qualified to supply. MEP (Mechanical Electrical and Plumbing) is a specialized category for building systems contractors.' ;
    rdfs:domain ind:VendorQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualificationExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Qualification Expiry Date' ;
    rdfs:comment 'Date on which the vendor qualification expires and requires renewal. Typically set 1-3 years from start date depending on vendor category and risk profile.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qualificationNumber rdf:type rdf:Property ;
    rdfs:label 'Qualification Number' ;
    rdfs:comment 'Business identifier for the vendor qualification record. Externally visible unique reference number used in procurement communications and AVL (Approved Vendor List) documentation.' ;
    rdfs:domain ind:VendorQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualificationStartDate rdf:type rdf:Property ;
    rdfs:label 'Qualification Start Date' ;
    rdfs:comment 'Effective date from which the vendor qualification becomes valid. Vendors can only receive PO (Purchase Order) assignments on or after this date.' ;
    rdfs:domain ind:VendorQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qualificationStatus rdf:type rdf:Property ;
    rdfs:label 'Qualification Status' ;
    rdfs:comment 'Current lifecycle status of the vendor qualification. Approved vendors are eligible for PO (Purchase Order) issuance. Suspended vendors require re-qualification. Expired qualifications require renewal.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualificationType rdf:type rdf:Property ;
    rdfs:label 'Qualification Type' ;
    rdfs:comment 'Type of qualification process being conducted. Initial for new vendors, renewal for periodic re-assessment, re-qualification for vendors returning after suspension, conditional for limited-scope approval, emergency for urgent project needs.' ;
    rdfs:domain ind:VendorQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityDefectRate rdf:type rdf:Property ;
    rdfs:label 'Quality Defect Rate' ;
    rdfs:comment 'Historical quality defect rate expressed as percentage of deliverables requiring rework or NCR (Non-Conformance Report) issuance. Lower values indicate better quality performance. Target is typically below 5.00%.' ;
    rdfs:domain ind:VendorQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:suspensionDate rdf:type rdf:Property ;
    rdfs:label 'Suspension Date' ;
    rdfs:comment 'Date when the vendor qualification was suspended. Suspended vendors cannot receive new PO (Purchase Order) assignments until re-qualified.' ;
    rdfs:domain ind:VendorQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:technicalCapabilityScore rdf:type rdf:Property ;
    rdfs:label 'Technical Capability Score' ;
    rdfs:comment 'Assessment score of vendor technical capabilities ranging from 0.00 to 100.00. Evaluates equipment, workforce skills, past project complexity, and technical certifications. Minimum threshold typically 70.00 for complex EPC (Engineering Procurement and Construction) projects.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trirRate rdf:type rdf:Property ;
    rdfs:label 'Trir Rate' ;
    rdfs:comment 'TRIR (Total Recordable Incident Rate) calculated as (number of recordable incidents × 200,000) / total hours worked. Industry benchmark for construction is typically below 3.0. Lower values indicate better safety performance.' ;
    rdfs:domain ind:VendorQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:procurementMaterialMasterId rdf:type rdf:Property ;
    rdfs:label 'Procurement Material Master Id' ;
    rdfs:comment 'Unique identifier for the material master record in the procurement catalog. Primary key for the material catalog product.' ;
    rdfs:domain ind:MaterialCatalog ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Master .

ind:abcClassification rdf:type rdf:Property ;
    rdfs:label 'Abc Classification' ;
    rdfs:comment 'Inventory classification based on value and consumption frequency. A=High value/critical items requiring tight control, B=Moderate value, C=Low value/high volume items. Drives inventory policy and cycle counting frequency.' ;
    rdfs:domain ind:MaterialCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alternativeUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Alternative Unit Of Measure' ;
    rdfs:comment 'Secondary unit of measure for materials that can be ordered or issued in multiple units (e.g., cement ordered in bags but tracked in tons). Supports conversion factor calculations.' ;
    rdfs:domain ind:MaterialCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baseUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Base Unit Of Measure' ;
    rdfs:comment 'Primary unit of measure for material quantity tracking, ordering, and inventory management. Aligns with industry standards for construction materials (EA=Each, M=Meter, M2=Square Meter, M3=Cubic Meter, KG=Kilogram, TON=Metric Ton). [ENUM-REF-CANDIDATE: EA|M|M2|M3|KG|TON|L|GAL|FT|YD|LB|BAG|BOX|ROLL — 14 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:MaterialCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bimObjectReference rdf:type rdf:Property ;
    rdfs:label 'Bim Object Reference' ;
    rdfs:comment 'Unique identifier linking the material to its corresponding 3D object in BIM 360 or other BIM platforms. Enables digital twin integration and clash detection during design and construction phases.' ;
    rdfs:domain ind:MaterialCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCurrency rdf:type rdf:Property ;
    rdfs:label 'Cost Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for standard cost (e.g., USD, EUR, GBP). Supports multi-currency procurement and financial consolidation.' ;
    rdfs:domain ind:MaterialCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countryOfOrigin rdf:type rdf:Property ;
    rdfs:label 'Country Of Origin' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code indicating where the material is manufactured or sourced. Required for customs compliance, trade regulations, and local content reporting.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:createdDate rdf:type rdf:Property ;
    rdfs:label 'Created Date' ;
    rdfs:comment 'Date when the material master record was first created in the system. Used for audit trail and master data governance.' ;
    rdfs:domain ind:MaterialCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:customsTariffNumber rdf:type rdf:Property ;
    rdfs:label 'Customs Tariff Number' ;
    rdfs:comment 'Harmonized System (HS) code for international trade classification. Used for customs clearance, duty calculation, and import/export documentation for cross-border procurement.' ;
    rdfs:domain ind:MaterialCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dimensionUnit rdf:type rdf:Property ;
    rdfs:label 'Dimension Unit' ;
    rdfs:comment 'Unit of measure for length, width, and height dimensions. Typically meters (M) for construction industry standards.' ;
    rdfs:domain ind:MaterialCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:environmentalCertification rdf:type rdf:Property ;
    rdfs:label 'Environmental Certification' ;
    rdfs:comment 'Environmental sustainability certification held by the material (e.g., LEED certified, FSC certified, Energy Star). Supports green building requirements and sustainability reporting.' ;
    rdfs:domain ind:MaterialCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grossWeight rdf:type rdf:Property ;
    rdfs:label 'Gross Weight' ;
    rdfs:comment 'Total weight of the material including packaging, measured in kilograms. Used for logistics planning, transportation cost calculation, and site delivery scheduling.' ;
    rdfs:domain ind:MaterialCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hazardClass rdf:type rdf:Property ;
    rdfs:label 'Hazard Class' ;
    rdfs:comment 'UN hazard classification code for hazardous materials (e.g., Class 3 Flammable Liquids, Class 8 Corrosives). Required for transportation, storage, and safety data sheet (SDS) compliance.' ;
    rdfs:domain ind:MaterialCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazardousMaterialIndicator rdf:type rdf:Property ;
    rdfs:label 'Hazardous Material Indicator' ;
    rdfs:comment 'Flag indicating whether the material is classified as hazardous per OSHA and EPA regulations. Triggers special handling, storage, and HSE (Health Safety and Environment) compliance requirements.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:height rdf:type rdf:Property ;
    rdfs:label 'Height' ;
    rdfs:comment 'Height dimension of the material in meters. Essential for volume calculations and warehouse stacking constraints.' ;
    rdfs:domain ind:MaterialCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastModifiedDate rdf:type rdf:Property ;
    rdfs:label 'Last Modified Date' ;
    rdfs:comment 'Date when the material master record was last updated. Tracks data currency and supports change management processes.' ;
    rdfs:domain ind:MaterialCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:length rdf:type rdf:Property ;
    rdfs:label 'Length' ;
    rdfs:comment 'Length dimension of the material in meters. Critical for structural materials (beams, pipes, cables) and storage space planning.' ;
    rdfs:domain ind:MaterialCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:manufacturerName rdf:type rdf:Property ;
    rdfs:label 'Manufacturer Name' ;
    rdfs:comment 'Name of the primary manufacturer or brand for the material. Used for quality assurance, warranty tracking, and approved vendor list (AVL) compliance.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manufacturerPartNumber rdf:type rdf:Property ;
    rdfs:label 'Manufacturer Part Number' ;
    rdfs:comment 'Manufacturer\'s unique part number or model code for the material. Critical for exact specification matching, warranty claims, and spare parts procurement.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialGroup rdf:type rdf:Property ;
    rdfs:label 'Material Group' ;
    rdfs:comment 'Classification code grouping materials by procurement category (e.g., concrete, steel, MEP equipment, PPE). Used for procurement strategy, vendor assignment, and spend analysis.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialNumber rdf:type rdf:Property ;
    rdfs:label 'Material Number' ;
    rdfs:comment 'Unique business identifier for the material as defined in SAP MM Material Master. This is the externally-known code used across MTO (Material Take-Off), PO (Purchase Order), and goods receipt processes.' ;
    rdfs:domain ind:MaterialCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialStatus rdf:type rdf:Property ;
    rdfs:label 'Material Status' ;
    rdfs:comment 'Current lifecycle status of the material in the catalog. Controls procurement eligibility and inventory transactions. Blocked materials cannot be ordered; obsolete materials are phased out.' ;
    rdfs:domain ind:MaterialCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumOrderQuantity rdf:type rdf:Property ;
    rdfs:label 'Minimum Order Quantity' ;
    rdfs:comment 'Smallest quantity that can be ordered from suppliers in base unit of measure. Drives procurement batch sizing and inventory optimization.' ;
    rdfs:domain ind:MaterialCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netWeight rdf:type rdf:Property ;
    rdfs:label 'Net Weight' ;
    rdfs:comment 'Weight of the material excluding packaging, measured in kilograms. Used for material quantity verification and yield calculations in construction processes.' ;
    rdfs:domain ind:MaterialCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:procurementLeadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Procurement Lead Time Days' ;
    rdfs:comment 'Standard number of days from PO (Purchase Order) issuance to material delivery on site. Used for project scheduling, MRP (Material Requirements Planning), and critical path analysis.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:qualityInspectionRequired rdf:type rdf:Property ;
    rdfs:label 'Quality Inspection Required' ;
    rdfs:comment 'Flag indicating whether incoming goods receipt requires quality inspection per ITP (Inspection and Test Plan) before acceptance. Triggers QA/QC workflow in goods receipt process.' ;
    rdfs:domain ind:MaterialCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:shelfLifeDays rdf:type rdf:Property ;
    rdfs:label 'Shelf Life Days' ;
    rdfs:comment 'Maximum number of days the material can be stored before expiration or quality degradation. Critical for perishable materials (adhesives, sealants, chemicals) and inventory rotation (FIFO/FEFO).' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:shortDescription rdf:type rdf:Property ;
    rdfs:label 'Short Description' ;
    rdfs:comment 'Abbreviated description of the material for display in transaction screens, reports, and mobile applications. Limited to 40 characters for operational efficiency.' ;
    rdfs:domain ind:MaterialCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardCost rdf:type rdf:Property ;
    rdfs:label 'Standard Cost' ;
    rdfs:comment 'Baseline unit cost of the material used for project budgeting, cost estimation, and variance analysis. Updated periodically based on procurement history and market conditions.' ;
    rdfs:domain ind:MaterialCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:storageCondition rdf:type rdf:Property ;
    rdfs:label 'Storage Condition' ;
    rdfs:comment 'Required environmental conditions for material storage to maintain quality and safety. Drives warehouse zone assignment and inventory handling procedures. [ENUM-REF-CANDIDATE: ambient|climate_controlled|refrigerated|dry|ventilated|hazmat_certified|outdoor_covered|outdoor_uncovered — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:MaterialCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valuationClass rdf:type rdf:Property ;
    rdfs:label 'Valuation Class' ;
    rdfs:comment 'SAP valuation class code linking material to general ledger (GL) accounts for inventory valuation and cost of goods sold (COGS) posting. Drives financial accounting integration.' ;
    rdfs:domain ind:MaterialCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:volume rdf:type rdf:Property ;
    rdfs:label 'Volume' ;
    rdfs:comment 'Volumetric measurement of the material in cubic meters. Used for bulk materials (concrete, aggregates) and transportation capacity planning.' ;
    rdfs:domain ind:MaterialCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volumeUnit rdf:type rdf:Property ;
    rdfs:label 'Volume Unit' ;
    rdfs:comment 'Unit of measure for volume field. Typically cubic meters (M3) for construction bulk materials.' ;
    rdfs:domain ind:MaterialCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:weightUnit rdf:type rdf:Property ;
    rdfs:label 'Weight Unit' ;
    rdfs:comment 'Unit of measure for gross and net weight fields. Typically kilograms (KG) or metric tons (TON) for construction materials.' ;
    rdfs:domain ind:MaterialCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:width rdf:type rdf:Property ;
    rdfs:label 'Width' ;
    rdfs:comment 'Width dimension of the material in meters. Used for area calculations and storage layout planning.' ;
    rdfs:domain ind:MaterialCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rfqId rdf:type rdf:Property ;
    rdfs:label 'Rfq Id' ;
    rdfs:comment 'Unique identifier for the Request for Quotation record. Primary key for the RFQ entity.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Rfq .

ind:awardedVendorId rdf:type rdf:Property ;
    rdfs:label 'Awarded Vendor Id' ;
    rdfs:comment 'Identifier of the vendor to whom the contract or purchase order was awarded following RFQ evaluation. Null if RFQ is not yet awarded or was cancelled.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vendor .

ind:sourcingPlanId rdf:type rdf:Property ;
    rdfs:label 'Sourcing Plan Id' ;
    rdfs:comment 'Foreign key linking to procurement.sourcing_plan. Business justification: An RFQ is issued to execute a sourcing plan milestone (sourcing_plan.planned_rfq_date). The sourcing_plan defines the procurement strategy, category, and timeline; the RFQ is the operational execution' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SourcingPlan .

ind:awardedAmount rdf:type rdf:Property ;
    rdfs:label 'Awarded Amount' ;
    rdfs:comment 'Total monetary value of the contract or purchase order awarded to the winning vendor. Null if RFQ is not yet awarded.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bidBondAmount rdf:type rdf:Property ;
    rdfs:label 'Bid Bond Amount' ;
    rdfs:comment 'Monetary value of the bid bond required from vendors, if applicable. Typically a percentage of the estimated contract value.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bimReference rdf:type rdf:Property ;
    rdfs:label 'Bim Reference' ;
    rdfs:comment 'Reference to BIM model elements or clash detection reports that vendors should review to ensure dimensional and spatial compatibility of materials or equipment.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:boqReference rdf:type rdf:Property ;
    rdfs:label 'Boq Reference' ;
    rdfs:comment 'Reference to the Bill of Quantities document or section that this RFQ is based on. Links the RFQ to the project cost estimation and material take-off data.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:buyerContactEmail rdf:type rdf:Property ;
    rdfs:label 'Buyer Contact Email' ;
    rdfs:comment 'Email address of the buyer or procurement contact for vendor inquiries and quotation submissions.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:buyerContactName rdf:type rdf:Property ;
    rdfs:label 'Buyer Contact Name' ;
    rdfs:comment 'Name of the procurement professional or buyer responsible for managing this RFQ and serving as the primary point of contact for vendors.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:buyerContactPhone rdf:type rdf:Property ;
    rdfs:label 'Buyer Contact Phone' ;
    rdfs:comment 'Phone number of the buyer or procurement contact for urgent vendor communications.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cancellationReason rdf:type rdf:Property ;
    rdfs:label 'Cancellation Reason' ;
    rdfs:comment 'Explanation for why the RFQ was cancelled or withdrawn, if applicable. May include project scope changes, budget constraints, or inadequate vendor response.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryLocation rdf:type rdf:Property ;
    rdfs:label 'Delivery Location' ;
    rdfs:comment 'Physical site address or location code where the materials or equipment must be delivered. May reference a specific construction site, warehouse, or laydown area.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incoterms rdf:type rdf:Property ;
    rdfs:label 'Incoterms' ;
    rdfs:comment 'Incoterms code defining the responsibilities of buyer and seller for transportation, insurance, and risk transfer. Critical for international procurement. [ENUM-REF-CANDIDATE: EXW|FCA|CPT|CIP|DAP|DPU|DDP|FAS|FOB|CFR|CIF — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invitedVendorCount rdf:type rdf:Property ;
    rdfs:label 'Invited Vendor Count' ;
    rdfs:comment 'Number of vendors invited to submit quotations for this RFQ. Used to track competitive bidding and ensure adequate market coverage.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:issuingDepartment rdf:type rdf:Property ;
    rdfs:label 'Issuing Department' ;
    rdfs:comment 'Name or code of the department or business unit that issued the RFQ, such as Procurement, Project Management, or Engineering.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mtoReference rdf:type rdf:Property ;
    rdfs:label 'Mto Reference' ;
    rdfs:comment 'Reference to the Material Take-Off document or identifier that quantifies the materials required. Used to ensure RFQ quantities align with engineering estimates.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityRequirements rdf:type rdf:Property ;
    rdfs:label 'Quality Requirements' ;
    rdfs:comment 'Description of quality assurance and quality control requirements, including certifications (ISO 9001), testing protocols (FAT, SAT), and inspection plans (ITP) that vendors must comply with.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiredDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Required Delivery Date' ;
    rdfs:comment 'Target date by which the materials, equipment, or services must be delivered to the project site. Critical for project scheduling alignment using CPM.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:responseCount rdf:type rdf:Property ;
    rdfs:label 'Response Count' ;
    rdfs:comment 'Number of vendor quotations received in response to this RFQ. Indicates level of vendor interest and competitive response.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rfqStatus rdf:type rdf:Property ;
    rdfs:label 'Rfq Status' ;
    rdfs:comment 'Current lifecycle status of the RFQ. Tracks progression from draft creation through vendor response collection to final award or cancellation. [ENUM-REF-CANDIDATE: draft|issued|open|closed|awarded|cancelled|withdrawn — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rfqType rdf:type rdf:Property ;
    rdfs:label 'Rfq Type' ;
    rdfs:comment 'Classification of the RFQ based on the category of procurement: materials (concrete, steel), equipment (cranes, generators), services (engineering, testing), or subcontract work packages.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorPrequalificationRequired rdf:type rdf:Property ;
    rdfs:label 'Vendor Prequalification Required' ;
    rdfs:comment 'Indicates whether vendors must be prequalified or approved before they can submit quotations. Ensures only qualified vendors participate in the bidding process.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:vendorQuotationId rdf:type rdf:Property ;
    rdfs:label 'Vendor Quotation Id' ;
    rdfs:comment 'Unique identifier for the vendor quotation record. Primary key for this entity.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VendorQuotation .

ind:boqId rdf:type rdf:Property ;
    rdfs:label 'Boq Id' ;
    rdfs:comment 'Foreign key linking to bid.boq. Business justification: Vendor quotations are solicited against BOQ items in construction procurement. Linking quotation to BOQ enables price benchmarking against tendered quantities — a core bid evaluation and cost control ' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Boq .

ind:awardRecommendation rdf:type rdf:Property ;
    rdfs:label 'Award Recommendation' ;
    rdfs:comment 'Procurement team recommendation on whether to award the PO to this vendor based on evaluation results.' ;
    rdfs:domain ind:VendorQuotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commercialExceptions rdf:type rdf:Property ;
    rdfs:label 'Commercial Exceptions' ;
    rdfs:comment 'Vendor-declared exceptions or deviations from RFQ commercial terms (payment, delivery, penalties, etc.). Must be evaluated during bid tabulation.' ;
    rdfs:domain ind:VendorQuotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryLeadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Delivery Lead Time Days' ;
    rdfs:comment 'Number of calendar days from PO issuance to material delivery at site. Critical for project scheduling and CPM integration.' ;
    rdfs:domain ind:VendorQuotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deliveryTerms rdf:type rdf:Property ;
    rdfs:label 'Delivery Terms' ;
    rdfs:comment 'Incoterms delivery terms defining responsibility transfer point (e.g., EXW, FOB, CIF, DDP). Impacts freight cost allocation and risk.' ;
    rdfs:domain ind:VendorQuotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviationsFromSpecification rdf:type rdf:Property ;
    rdfs:label 'Deviations From Specification' ;
    rdfs:comment 'Vendor-declared exceptions, deviations, or clarifications to the RFQ technical specifications. Critical for commercial evaluation and risk assessment.' ;
    rdfs:domain ind:VendorQuotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discountPercentage rdf:type rdf:Property ;
    rdfs:label 'Discount Percentage' ;
    rdfs:comment 'Percentage discount offered by vendor from list price or previous quotation. Used for price negotiation and historical benchmarking.' ;
    rdfs:domain ind:VendorQuotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:evaluationDate rdf:type rdf:Property ;
    rdfs:label 'Evaluation Date' ;
    rdfs:comment 'Date when the quotation evaluation was completed and recommendation finalized.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:evaluationNotes rdf:type rdf:Property ;
    rdfs:label 'Evaluation Notes' ;
    rdfs:comment 'Free-text notes and comments from the evaluation team regarding technical compliance, commercial terms, or vendor performance considerations.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evaluationScore rdf:type rdf:Property ;
    rdfs:label 'Evaluation Score' ;
    rdfs:comment 'Composite evaluation score assigned during bid tabulation based on price, technical compliance, delivery, and vendor performance. Used for award recommendation.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:freightCost rdf:type rdf:Property ;
    rdfs:label 'Freight Cost' ;
    rdfs:comment 'Quoted freight or transportation cost if not included in unit price. Depends on delivery terms (Incoterms).' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quotationNumber rdf:type rdf:Property ;
    rdfs:label 'Quotation Number' ;
    rdfs:comment 'Vendor-assigned unique reference number for this quotation. External business identifier used for correspondence and tracking.' ;
    rdfs:domain ind:VendorQuotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quotationStatus rdf:type rdf:Property ;
    rdfs:label 'Quotation Status' ;
    rdfs:comment 'Current lifecycle status of the vendor quotation in the evaluation and award process.' ;
    rdfs:domain ind:VendorQuotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quotedQuantity rdf:type rdf:Property ;
    rdfs:label 'Quoted Quantity' ;
    rdfs:comment 'Quantity of material or service the vendor is quoting for. Must align with RFQ requested quantity.' ;
    rdfs:domain ind:VendorQuotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:technicalComplianceStatus rdf:type rdf:Property ;
    rdfs:label 'Technical Compliance Status' ;
    rdfs:comment 'Assessment of whether the quoted material meets the technical specifications defined in the RFQ. Evaluated by engineering team.' ;
    rdfs:domain ind:VendorQuotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalPrice rdf:type rdf:Property ;
    rdfs:label 'Total Price' ;
    rdfs:comment 'Total quoted price for the full quantity (unit price × quantity). May include or exclude taxes and freight depending on quotation terms.' ;
    rdfs:domain ind:VendorQuotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unitPrice rdf:type rdf:Property ;
    rdfs:label 'Unit Price' ;
    rdfs:comment 'Vendor-quoted price per unit of measure. Base price before taxes, freight, or other charges.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:validityEndDate rdf:type rdf:Property ;
    rdfs:label 'Validity End Date' ;
    rdfs:comment 'Date until which the vendor commits to honor the quoted price and terms. Critical for award decision timing.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:validityStartDate rdf:type rdf:Property ;
    rdfs:label 'Validity Start Date' ;
    rdfs:comment 'Date from which the quoted price and terms become valid. Typically the quotation submission date.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:warrantyTerms rdf:type rdf:Property ;
    rdfs:label 'Warranty Terms' ;
    rdfs:comment 'Detailed warranty terms and conditions including coverage scope, exclusions, and claim procedures.' ;
    rdfs:domain ind:VendorQuotation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acknowledgmentDate rdf:type rdf:Property ;
    rdfs:label 'Acknowledgment Date' ;
    rdfs:comment 'Date on which the vendor formally acknowledged receipt and acceptance of the purchase order terms.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:amendmentCount rdf:type rdf:Property ;
    rdfs:label 'Amendment Count' ;
    rdfs:comment 'Total number of formal amendments or change orders issued against this purchase order. Used for contract change management reporting.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:buyerName rdf:type rdf:Property ;
    rdfs:label 'Buyer Name' ;
    rdfs:comment 'Name of the procurement specialist or buyer responsible for managing this purchase order and vendor relationship.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cumulativeAmendmentValue rdf:type rdf:Property ;
    rdfs:label 'Cumulative Amendment Value' ;
    rdfs:comment 'Net change in purchase order value resulting from all amendments and change orders (positive or negative delta from original value).' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:currentRevisionNumber rdf:type rdf:Property ;
    rdfs:label 'Current Revision Number' ;
    rdfs:comment 'Revision number tracking minor corrections or clarifications within the current version. Used for document control and audit trail.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:currentVersionNumber rdf:type rdf:Property ;
    rdfs:label 'Current Version Number' ;
    rdfs:comment 'Version number of the purchase order reflecting amendments and change orders. Increments with each approved modification.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deliveryAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Delivery Address Line1' ;
    rdfs:comment 'Primary street address line for material or equipment delivery to construction site or warehouse.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Delivery Address Line2' ;
    rdfs:comment 'Secondary address line for delivery location (building, floor, gate number, or site-specific instructions).' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryCity rdf:type rdf:Property ;
    rdfs:label 'Delivery City' ;
    rdfs:comment 'City or municipality for delivery destination.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryCountryCode rdf:type rdf:Property ;
    rdfs:label 'Delivery Country Code' ;
    rdfs:comment 'Three-letter ISO country code for delivery destination (e.g., USA, CAN, GBR).' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryPostalCode rdf:type rdf:Property ;
    rdfs:label 'Delivery Postal Code' ;
    rdfs:comment 'Postal or ZIP code for delivery destination.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryStateProvince rdf:type rdf:Property ;
    rdfs:label 'Delivery State Province' ;
    rdfs:comment 'State, province, or region for delivery destination.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gmpAmount rdf:type rdf:Property ;
    rdfs:label 'Gmp Amount' ;
    rdfs:comment 'The contractual ceiling amount for this purchase order when GMP terms apply. Vendor cannot exceed this amount without approved change orders.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gmpFlag rdf:type rdf:Property ;
    rdfs:label 'Gmp Flag' ;
    rdfs:comment 'Indicates whether this purchase order is subject to a Guaranteed Maximum Price contract, capping the total cost exposure.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:issuedDate rdf:type rdf:Property ;
    rdfs:label 'Issued Date' ;
    rdfs:comment 'Date on which the purchase order was formally issued to the vendor. Marks the start of the contractual commitment.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastAmendmentDate rdf:type rdf:Property ;
    rdfs:label 'Last Amendment Date' ;
    rdfs:comment 'Date of the most recent amendment or change order applied to this purchase order.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastAmendmentType rdf:type rdf:Property ;
    rdfs:label 'Last Amendment Type' ;
    rdfs:comment 'Classification of the most recent amendment: scope change, quantity adjustment, price revision, delivery reschedule, formal change order, or terms modification.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalPoValue rdf:type rdf:Property ;
    rdfs:label 'Original Po Value' ;
    rdfs:comment 'Initial total value of the purchase order at time of first issuance, before any amendments or change orders. Used for cost variance analysis.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:poStatus rdf:type rdf:Property ;
    rdfs:label 'Po Status' ;
    rdfs:comment 'Current lifecycle status of the purchase order in the procurement workflow. Tracks progression from draft through approval, issuance, receipt, and closure. [ENUM-REF-CANDIDATE: draft|pending_approval|approved|issued|acknowledged|in_progress|partially_received|fully_received|closed|cancelled — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:poType rdf:type rdf:Property ;
    rdfs:label 'Po Type' ;
    rdfs:comment 'Classification of purchase order by procurement pattern: standard (one-time material/equipment), blanket (recurring supply agreement), framework (multi-project master agreement), subcontract (labor/construction services), service (professional services), rental (equipment lease).' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promisedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Promised Delivery Date' ;
    rdfs:comment 'Vendor-committed delivery date as confirmed in purchase order acknowledgment. Used for schedule risk assessment and expediting.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requestedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Requested Delivery Date' ;
    rdfs:comment 'Target date by which materials, equipment, or services are required on site. Used for procurement lead time planning and CPM schedule integration.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sapDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Document Number' ;
    rdfs:comment 'SAP MM system-generated unique document number for this purchase order. Used for ERP integration and cross-system reconciliation.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalPoValue rdf:type rdf:Property ;
    rdfs:label 'Total Po Value' ;
    rdfs:comment 'Total monetary value of the purchase order including all line items, taxes, and charges. Expressed in the currency specified by currency_code.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:serviceId rdf:type rdf:Property ;
    rdfs:label 'Service Id' ;
    rdfs:comment 'Foreign key linking to procurement.service. Business justification: PO lines can be for services (item_category = \'service\') in addition to materials. The service table is the master reference for procurable services. Linking po_line.service_id → service.service_id en' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Service .

ind:accountAssignmentCategory rdf:type rdf:Property ;
    rdfs:label 'Account Assignment Category' ;
    rdfs:comment 'SAP account assignment category indicating how costs are allocated: K=Cost Center, A=Asset, F=Order, P=Project, N=Network, U=Unknown. Determines financial posting logic.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deletionIndicator rdf:type rdf:Property ;
    rdfs:label 'Deletion Indicator' ;
    rdfs:comment 'Boolean flag indicating whether this line item has been marked for deletion. True if the line is logically deleted but retained for audit purposes.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:freeTextNote rdf:type rdf:Property ;
    rdfs:label 'Free Text Note' ;
    rdfs:comment 'Additional free-form notes or special instructions related to this line item, such as quality requirements, packaging instructions, or delivery constraints.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:goodsReceiptIndicator rdf:type rdf:Property ;
    rdfs:label 'Goods Receipt Indicator' ;
    rdfs:comment 'Boolean flag indicating whether a goods receipt is required for this line item. True if GR is mandatory before invoice processing.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:goodsReceiptQuantity rdf:type rdf:Property ;
    rdfs:label 'Goods Receipt Quantity' ;
    rdfs:comment 'The cumulative quantity of goods received to date against this line item. Used to track delivery progress and outstanding quantities.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:incotermsLocation rdf:type rdf:Property ;
    rdfs:label 'Incoterms Location' ;
    rdfs:comment 'The specific named place or port associated with the Incoterms designation, defining the point of delivery or risk transfer.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceReceiptIndicator rdf:type rdf:Property ;
    rdfs:label 'Invoice Receipt Indicator' ;
    rdfs:comment 'Boolean flag indicating whether invoice verification is required for this line item. True if IR is mandatory for payment processing.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:invoicedQuantity rdf:type rdf:Property ;
    rdfs:label 'Invoiced Quantity' ;
    rdfs:comment 'The cumulative quantity that has been invoiced to date against this line item. Used for three-way matching and payment reconciliation.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:itemCategory rdf:type rdf:Property ;
    rdfs:label 'Item Category' ;
    rdfs:comment 'Classification of the line item type indicating the procurement scenario: standard purchase, service procurement, consignment, subcontracting, or stock transfer.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineStatus rdf:type rdf:Property ;
    rdfs:label 'Line Status' ;
    rdfs:comment 'Current lifecycle status of the purchase order line item indicating its fulfillment state: open (not yet received), partially received, fully received, closed (completed), or cancelled.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netValue rdf:type rdf:Property ;
    rdfs:label 'Net Value' ;
    rdfs:comment 'The total net value of this line item calculated as ordered quantity multiplied by unit price, before taxes and discounts.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:orderedQuantity rdf:type rdf:Property ;
    rdfs:label 'Ordered Quantity' ;
    rdfs:comment 'The quantity of material or service ordered on this line item, expressed in the unit of measure specified.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:outstandingQuantity rdf:type rdf:Property ;
    rdfs:label 'Outstanding Quantity' ;
    rdfs:comment 'The remaining quantity yet to be delivered, calculated as ordered quantity minus goods receipt quantity. Critical for expediting and delivery monitoring.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overDeliveryTolerancePercent rdf:type rdf:Property ;
    rdfs:label 'Over Delivery Tolerance Percent' ;
    rdfs:comment 'The acceptable percentage by which the vendor may over-deliver beyond the ordered quantity without requiring approval. Used for goods receipt tolerance checking.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plantCode rdf:type rdf:Property ;
    rdfs:label 'Plant Code' ;
    rdfs:comment 'The plant or site location code where the material will be delivered or the service will be performed. Used for multi-site inventory and logistics management.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceUnit rdf:type rdf:Property ;
    rdfs:label 'Price Unit' ;
    rdfs:comment 'The quantity of units to which the unit price applies (e.g., price per 1, per 10, per 100 units). Used for bulk pricing scenarios.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:requisitionerName rdf:type rdf:Property ;
    rdfs:label 'Requisitioner Name' ;
    rdfs:comment 'Name of the person or department who requested this material or service, used for accountability and follow-up communication.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shortText rdf:type rdf:Property ;
    rdfs:label 'Short Text' ;
    rdfs:comment 'Brief descriptive text for the line item, typically used for quick identification and reporting purposes.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:underDeliveryTolerancePercent rdf:type rdf:Property ;
    rdfs:label 'Under Delivery Tolerance Percent' ;
    rdfs:comment 'The acceptable percentage by which the vendor may under-deliver below the ordered quantity without penalty. Used for goods receipt tolerance checking.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vendorMaterialNumber rdf:type rdf:Property ;
    rdfs:label 'Vendor Material Number' ;
    rdfs:comment 'The suppliers own material or part number for the item being procured. Used for cross-referencing and supplier communication.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mtoLineId rdf:type rdf:Property ;
    rdfs:label 'Mto Line Id' ;
    rdfs:comment 'Foreign key linking to material.mto_line. Business justification: Goods receipts in construction must be matched against MTO lines to track procurement fulfillment status. mto_line tracks actual_received_quantity and actual_received_date — these are populated from g' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MtoLine .

ind:warehouseId rdf:type rdf:Property ;
    rdfs:label 'Warehouse Id' ;
    rdfs:comment 'Foreign key linking to material.warehouse. Business justification: Goods receipt in construction triggers inventory posting to a specific warehouse. Direct FK enables warehouse-level receiving reports, storage capacity checks, and hazardous material certification val' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Warehouse .

ind:carrierName rdf:type rdf:Property ;
    rdfs:label 'Carrier Name' ;
    rdfs:comment 'Name of the transportation carrier or logistics provider who delivered the materials. Used for carrier performance tracking.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryCompletedFlag rdf:type rdf:Property ;
    rdfs:label 'Delivery Completed Flag' ;
    rdfs:comment 'Indicates whether this goods receipt completes the delivery for the purchase order line item (True=complete, False=partial delivery expected).' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deliveryNoteNumber rdf:type rdf:Property ;
    rdfs:label 'Delivery Note Number' ;
    rdfs:comment 'External delivery note or packing slip number provided by the vendor. Used for cross-referencing vendor shipment documentation.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Gr Document Number' ;
    rdfs:comment 'Unique business document number assigned to this goods receipt transaction. Used for audit trail and cross-system reconciliation.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceVerificationStatus rdf:type rdf:Property ;
    rdfs:label 'Invoice Verification Status' ;
    rdfs:comment 'Status of three-way match process comparing PO, goods receipt, and vendor invoice. Determines whether invoice can be paid.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Material Document Number' ;
    rdfs:comment 'SAP material document number generated upon goods receipt posting. Used for inventory movement tracking and financial integration.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:movementType rdf:type rdf:Property ;
    rdfs:label 'Movement Type' ;
    rdfs:comment 'SAP movement type code indicating the type of inventory transaction (e.g., 101=GR for PO, 122=Return Delivery). Determines financial and inventory impact.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receiptDate rdf:type rdf:Property ;
    rdfs:label 'Receipt Date' ;
    rdfs:comment 'Date on which the materials were physically received at the site or warehouse. Used for lead time analysis and schedule compliance tracking.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:receiptTimestamp rdf:type rdf:Property ;
    rdfs:label 'Receipt Timestamp' ;
    rdfs:comment 'Precise date and time when the goods receipt was recorded in the system. Used for audit trail and real-time inventory updates.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:receivedQuantity rdf:type rdf:Property ;
    rdfs:label 'Received Quantity' ;
    rdfs:comment 'Actual quantity of material physically received and accepted. This is the quantity that updates inventory and triggers invoice verification.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:receivingInspectorName rdf:type rdf:Property ;
    rdfs:label 'Receiving Inspector Name' ;
    rdfs:comment 'Full name of the receiving inspector who verified and accepted the delivery. Provides human-readable reference for audit and accountability.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rejectedQuantity rdf:type rdf:Property ;
    rdfs:label 'Rejected Quantity' ;
    rdfs:comment 'Quantity of material rejected due to quality issues, damage, or non-conformance. Triggers vendor return or credit memo process.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reversalDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Reversal Document Number' ;
    rdfs:comment 'Document number of the reversal transaction if this goods receipt was cancelled. Used for audit trail and reconciliation.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversalReason rdf:type rdf:Property ;
    rdfs:label 'Reversal Reason' ;
    rdfs:comment 'Reason code or description explaining why the goods receipt was reversed (e.g., incorrect posting, return to vendor, data entry error).' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialHandlingInstructions rdf:type rdf:Property ;
    rdfs:label 'Special Handling Instructions' ;
    rdfs:comment 'Any special handling requirements or instructions for the received materials (e.g., temperature control, hazardous material protocols, fragile handling).' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageLocationCode rdf:type rdf:Property ;
    rdfs:label 'Storage Location Code' ;
    rdfs:comment 'Code identifying the specific storage location, warehouse bin, or laydown area where the materials are stored after receipt.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalValue rdf:type rdf:Property ;
    rdfs:label 'Total Value' ;
    rdfs:comment 'Total monetary value of the goods receipt (received quantity × unit price). Updates inventory value and triggers accounts payable accrual.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trackingNumber rdf:type rdf:Property ;
    rdfs:label 'Tracking Number' ;
    rdfs:comment 'Shipment tracking number provided by the carrier. Enables real-time delivery status monitoring and proof of delivery.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transportationMode rdf:type rdf:Property ;
    rdfs:label 'Transportation Mode' ;
    rdfs:comment 'Method of transportation used to deliver the materials (truck, rail, air, sea, courier, pickup). Used for logistics analysis and lead time optimization.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unloadingPoint rdf:type rdf:Property ;
    rdfs:label 'Unloading Point' ;
    rdfs:comment 'Specific unloading dock, gate, or receiving area where the materials were delivered at the construction site.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valuationType rdf:type rdf:Property ;
    rdfs:label 'Valuation Type' ;
    rdfs:comment 'Material valuation category used for inventory accounting (e.g., standard cost, moving average price). Determines how the receipt is valued financially.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:varianceNotes rdf:type rdf:Property ;
    rdfs:label 'Variance Notes' ;
    rdfs:comment 'Free-text notes explaining any discrepancies, damages, or special conditions observed during goods receipt. Used for dispute resolution and vendor performance tracking.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:varianceReasonCode rdf:type rdf:Property ;
    rdfs:label 'Variance Reason Code' ;
    rdfs:comment 'Code indicating the reason for any variance between ordered and received quantities (e.g., short shipment, over delivery, damaged goods).' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialBoqLineId rdf:type rdf:Property ;
    rdfs:label 'Material Boq Line Id' ;
    rdfs:comment 'Foreign key linking to material.material_boq_line. Business justification: In construction, sourcing plans are created to procure items identified in the Bill of Quantities. Linking sourcing_plan to material_boq_line enables BOQ-driven procurement planning, contract quantity' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MaterialBoqLine .

ind:expeditingFrequency rdf:type rdf:Property ;
    rdfs:label 'Expediting Frequency' ;
    rdfs:comment 'Frequency of expediting reviews and supplier progress checks (e.g., weekly, monthly, milestone-based).' ;
    rdfs:domain ind:SourcingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expeditingMethod rdf:type rdf:Property ;
    rdfs:label 'Expediting Method' ;
    rdfs:comment 'Primary method used for expediting and progress monitoring (e.g., site visits to vendor facility, video conference, third-party inspection).' ;
    rdfs:domain ind:SourcingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expeditingRequired rdf:type rdf:Property ;
    rdfs:label 'Expediting Required' ;
    rdfs:comment 'Indicates whether active expediting and progress monitoring of the supplier is required due to schedule criticality or complexity.' ;
    rdfs:domain ind:SourcingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inspectionRequirements rdf:type rdf:Property ;
    rdfs:label 'Inspection Requirements' ;
    rdfs:comment 'Description of quality inspection and testing requirements for the procured materials or equipment (e.g., FAT, SAT, third-party certification, mill test certificates).' ;
    rdfs:domain ind:SourcingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isLongLeadItem rdf:type rdf:Property ;
    rdfs:label 'Is Long Lead Item' ;
    rdfs:comment 'Indicates whether this sourcing plan covers long-lead items requiring early procurement action due to extended manufacturing or delivery lead times.' ;
    rdfs:domain ind:SourcingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:packagingStrategy rdf:type rdf:Property ;
    rdfs:label 'Packaging Strategy' ;
    rdfs:comment 'Description of how procurement scope is bundled or split into packages for tendering (e.g., single package, split by trade, split by project phase, geographic split).' ;
    rdfs:domain ind:SourcingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedAwardDate rdf:type rdf:Property ;
    rdfs:label 'Planned Award Date' ;
    rdfs:comment 'Target date for awarding the purchase order or contract to the selected supplier. Critical milestone for procurement lead time calculation.' ;
    rdfs:domain ind:SourcingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:plannedBidClosingDate rdf:type rdf:Property ;
    rdfs:label 'Planned Bid Closing Date' ;
    rdfs:comment 'Target date by which vendor bids or proposals are due for evaluation.' ;
    rdfs:domain ind:SourcingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:plannedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Planned Delivery Date' ;
    rdfs:comment 'Target date for material or equipment delivery to site. Must align with construction schedule requirements and site readiness.' ;
    rdfs:domain ind:SourcingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:plannedInstallationDate rdf:type rdf:Property ;
    rdfs:label 'Planned Installation Date' ;
    rdfs:comment 'Target date for installation or commissioning of the procured materials or equipment. Drives backward scheduling of procurement activities.' ;
    rdfs:domain ind:SourcingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:plannedRfqDate rdf:type rdf:Property ;
    rdfs:label 'Planned Rfq Date' ;
    rdfs:comment 'Target date for issuing the RFQ or RFP to potential suppliers. Aligns with project procurement schedule milestones.' ;
    rdfs:domain ind:SourcingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:preferredSupplierList rdf:type rdf:Property ;
    rdfs:label 'Preferred Supplier List' ;
    rdfs:comment 'Comma-separated list of preferred or prequalified supplier names or codes to be invited for this procurement.' ;
    rdfs:domain ind:SourcingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:procurementCategory rdf:type rdf:Property ;
    rdfs:label 'Procurement Category' ;
    rdfs:comment 'Classification of the procurement scope covered by this plan (e.g., Structural Steel, MEP Equipment, Concrete Materials, Construction Services). Aligns with project WBS and material classification hierarchy.' ;
    rdfs:domain ind:SourcingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskClassification rdf:type rdf:Property ;
    rdfs:label 'Risk Classification' ;
    rdfs:comment 'Risk level associated with this procurement based on factors such as value, complexity, lead time, supplier market, and schedule impact.' ;
    rdfs:domain ind:SourcingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourcingMethod rdf:type rdf:Property ;
    rdfs:label 'Sourcing Method' ;
    rdfs:comment 'Procurement strategy and method to be used for acquiring the materials or services (e.g., competitive bidding, sole source negotiation, call-off from framework agreement).' ;
    rdfs:domain ind:SourcingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierPrequalificationRequired rdf:type rdf:Property ;
    rdfs:label 'Supplier Prequalification Required' ;
    rdfs:comment 'Indicates whether suppliers must be prequalified before being invited to bid for this procurement.' ;
    rdfs:domain ind:SourcingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:vendorEvaluationId rdf:type rdf:Property ;
    rdfs:label 'Vendor Evaluation Id' ;
    rdfs:comment 'Primary key for vendor_evaluation' ;
    rdfs:domain ind:VendorEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:avlEntryDate rdf:type rdf:Property ;
    rdfs:label 'Avl Entry Date' ;
    rdfs:comment 'Date when the vendor was added to the AVL (Approved Vendor List) following successful pre-qualification. Null for vendors not yet approved.' ;
    rdfs:domain ind:VendorEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:bidInvitationEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Bid Invitation Eligible Flag' ;
    rdfs:comment 'Boolean indicator (True/False) determining whether the vendor is currently eligible to receive bid invitations for RFP (Request for Proposal) and RFQ (Request for Quotation) based on evaluation outcome and qualification status.' ;
    rdfs:domain ind:VendorEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:bondingLimitAmount rdf:type rdf:Property ;
    rdfs:label 'Bonding Limit Amount' ;
    rdfs:comment 'Maximum contract value (in USD) for which the vendor can provide performance and payment bonds. Critical for pre-qualification and determines eligibility for large-scale EPC (Engineering Procurement and Construction) projects.' ;
    rdfs:domain ind:VendorEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:commercialComplianceScore rdf:type rdf:Property ;
    rdfs:label 'Commercial Compliance Score' ;
    rdfs:comment 'Numerical score (0-100) evaluating the vendor\'s adherence to contract terms, invoicing accuracy, payment terms compliance, and commercial documentation completeness.' ;
    rdfs:domain ind:VendorEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:correctiveActionRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Required Flag' ;
    rdfs:comment 'Boolean indicator (True/False) signaling that the vendor must implement corrective actions to address identified deficiencies before qualification can be maintained or upgraded.' ;
    rdfs:domain ind:VendorEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:evaluationNumber rdf:type rdf:Property ;
    rdfs:label 'Evaluation Number' ;
    rdfs:comment 'Business identifier for the vendor evaluation record. Format: VE-YYYYMMDD followed by sequence number.' ;
    rdfs:domain ind:VendorEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evaluationPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Evaluation Period End Date' ;
    rdfs:comment 'End date of the performance evaluation period. For periodic reviews, defines the close of the assessment window.' ;
    rdfs:domain ind:VendorEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:evaluationPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Evaluation Period Start Date' ;
    rdfs:comment 'Start date of the performance evaluation period. For periodic reviews, defines the beginning of the assessment window. For pre-qualification, represents the date evaluation commenced.' ;
    rdfs:domain ind:VendorEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:evaluationStatus rdf:type rdf:Property ;
    rdfs:label 'Evaluation Status' ;
    rdfs:comment 'Current lifecycle status of the vendor evaluation. Tracks progression from draft through approval or rejection.' ;
    rdfs:domain ind:VendorEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evaluationType rdf:type rdf:Property ;
    rdfs:label 'Evaluation Type' ;
    rdfs:comment 'Type of vendor evaluation being conducted. Pre-qualification for new vendors entering AVL (Approved Vendor List), periodic review for ongoing performance assessment, project-specific for bid eligibility, re-qualification for expired certifications, or incident-triggered for corrective action follow-up.' ;
    rdfs:domain ind:VendorEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hseIncidentCount rdf:type rdf:Property ;
    rdfs:label 'Hse Incident Count' ;
    rdfs:comment 'Total number of HSE (Health Safety and Environment) incidents (including LTI, near-misses, and safety violations) involving the vendor during the evaluation period.' ;
    rdfs:domain ind:VendorEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hseRatingScore rdf:type rdf:Property ;
    rdfs:label 'Hse Rating Score' ;
    rdfs:comment 'Numerical score (0-100) assessing the vendor\'s HSE (Health Safety and Environment) performance including TRIR (Total Recordable Incident Rate), LTI (Lost Time Injury) frequency, safety certifications (ISO 45001), and HSE management system maturity.' ;
    rdfs:domain ind:VendorEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:insuranceVerifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Insurance Verified Flag' ;
    rdfs:comment 'Boolean indicator (True/False) confirming that the vendor\'s general liability, professional indemnity, and workers\' compensation insurance policies have been verified and meet project requirements.' ;
    rdfs:domain ind:VendorEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:overallKpiRating rdf:type rdf:Property ;
    rdfs:label 'Overall Kpi Rating' ;
    rdfs:comment 'Composite numerical score (0-100) representing the weighted average of all evaluation dimensions (financial, technical, HSE, quality, delivery, responsiveness, commercial). Determines overall vendor performance grade.' ;
    rdfs:domain ind:VendorEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:performanceGrade rdf:type rdf:Property ;
    rdfs:label 'Performance Grade' ;
    rdfs:comment 'Letter grade (A through F) assigned based on overall KPI rating. A=Excellent (90-100), B=Good (80-89), C=Satisfactory (70-79), D=Marginal (60-69), F=Unsatisfactory (<60). Drives vendor tier classification and bid invitation priority.' ;
    rdfs:domain ind:VendorEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityAcceptanceRate rdf:type rdf:Property ;
    rdfs:label 'Quality Acceptance Rate' ;
    rdfs:comment 'Percentage (0-100) of delivered materials or services that passed quality inspection on first submission without NCR (Non-Conformance Report) during the evaluation period.' ;
    rdfs:domain ind:VendorEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualityCertificationScore rdf:type rdf:Property ;
    rdfs:label 'Quality Certification Score' ;
    rdfs:comment 'Numerical score (0-100) evaluating the vendor\'s quality management certifications (ISO 9001), QA/QC (Quality Assurance/Quality Control) processes, inspection capabilities, and adherence to ITP (Inspection and Test Plan) requirements.' ;
    rdfs:domain ind:VendorEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:responsivenessScore rdf:type rdf:Property ;
    rdfs:label 'Responsiveness Score' ;
    rdfs:comment 'Numerical score (0-100) assessing the vendor\'s responsiveness to RFI (Request for Information), RFQ (Request for Quotation), change orders, and issue resolution. Measures communication effectiveness and turnaround time.' ;
    rdfs:domain ind:VendorEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetAvailableFlag rdf:type rdf:Property ;
    rdfs:label 'Budget Available Flag' ;
    rdfs:comment 'Indicates whether sufficient budget is available in the assigned WBS element or cost center to cover the estimated cost of this requisition. True if budget is available, False if insufficient.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:closedDate rdf:type rdf:Property ;
    rdfs:label 'Closed Date' ;
    rdfs:comment 'Date when the purchase requisition was administratively closed after full conversion to procurement documents or cancellation, marking the end of its active lifecycle.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:conversionDate rdf:type rdf:Property ;
    rdfs:label 'Conversion Date' ;
    rdfs:comment 'Date when the purchase requisition was converted to an RFQ or PO document.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:conversionStatus rdf:type rdf:Property ;
    rdfs:label 'Conversion Status' ;
    rdfs:comment 'Indicates whether and how the approved purchase requisition has been converted into downstream procurement documents (RFQ for competitive bidding or direct PO for known vendors).' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:convertedDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Converted Document Number' ;
    rdfs:comment 'Document number of the RFQ or PO that was created from this purchase requisition, establishing traceability through the procurement lifecycle.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentApproverName rdf:type rdf:Property ;
    rdfs:label 'Current Approver Name' ;
    rdfs:comment 'Name of the individual currently responsible for reviewing and approving the purchase requisition in the workflow sequence.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedTotalCost rdf:type rdf:Property ;
    rdfs:label 'Estimated Total Cost' ;
    rdfs:comment 'Total estimated cost for the requisition line, calculated as quantity multiplied by estimated unit cost. Used for budget availability verification.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedUnitCost rdf:type rdf:Property ;
    rdfs:label 'Estimated Unit Cost' ;
    rdfs:comment 'Estimated cost per unit of the requested material or service, used for budget checking and preliminary cost estimation.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:justificationNotes rdf:type rdf:Property ;
    rdfs:label 'Justification Notes' ;
    rdfs:comment 'Business justification and rationale for the purchase requisition, including project need, schedule impact, and any special circumstances requiring expedited processing.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prNumber rdf:type rdf:Property ;
    rdfs:label 'Pr Number' ;
    rdfs:comment 'Business identifier for the purchase requisition, externally visible and used in procurement workflows and communications.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prStatus rdf:type rdf:Property ;
    rdfs:label 'Pr Status' ;
    rdfs:comment 'Current lifecycle status of the purchase requisition in the approval and conversion workflow. [ENUM-REF-CANDIDATE: draft|pending_approval|approved|rejected|converted|cancelled|closed — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prType rdf:type rdf:Property ;
    rdfs:label 'Pr Type' ;
    rdfs:comment 'Classification of the purchase requisition based on procurement category: standard materials, subcontract services, general services, stock transfers between sites, consignment arrangements, or equipment rental.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredVendorCode rdf:type rdf:Property ;
    rdfs:label 'Preferred Vendor Code' ;
    rdfs:comment 'Vendor code of the preferred or suggested supplier for this requisition, if the requester has a specific vendor recommendation based on prior performance or technical requirements.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:procurementStrategy rdf:type rdf:Property ;
    rdfs:label 'Procurement Strategy' ;
    rdfs:comment 'Sourcing approach to be used for fulfilling this requisition based on value, complexity, vendor availability, and time constraints.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rejectionDate rdf:type rdf:Property ;
    rdfs:label 'Rejection Date' ;
    rdfs:comment 'Date when the purchase requisition was rejected by an approver in the workflow, if applicable.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requesterEmail rdf:type rdf:Property ;
    rdfs:label 'Requester Email' ;
    rdfs:comment 'Email address of the requester for communication regarding the purchase requisition status, clarifications, and approvals.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requesterName rdf:type rdf:Property ;
    rdfs:label 'Requester Name' ;
    rdfs:comment 'Full name of the individual who created and submitted the purchase requisition.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestingDepartment rdf:type rdf:Property ;
    rdfs:label 'Requesting Department' ;
    rdfs:comment 'Name or code of the department or functional unit that originated the purchase requisition (e.g., Site Operations, Engineering, Procurement, MEP).' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requisitionDate rdf:type rdf:Property ;
    rdfs:label 'Requisition Date' ;
    rdfs:comment 'Date when the purchase requisition was created and submitted by the requesting party. Principal business event timestamp for the requisition.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:technicalSpecificationAttached rdf:type rdf:Property ;
    rdfs:label 'Technical Specification Attached' ;
    rdfs:comment 'Indicates whether detailed technical specifications, drawings, or engineering documents are attached to support the requisition evaluation and vendor quotation process.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:blockedReason rdf:type rdf:Property ;
    rdfs:label 'Blocked Reason' ;
    rdfs:comment 'Reason why the invoice is blocked from payment, such as pending approval, missing documentation, price variance, or quality hold.' ;
    rdfs:domain ind:VendorInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fiDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Fi Document Number' ;
    rdfs:comment 'The SAP FI document number generated when the invoice is posted to the financial accounting system. This is the system-generated accounting document reference.' ;
    rdfs:domain ind:VendorInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceGrossAmount rdf:type rdf:Property ;
    rdfs:label 'Invoice Gross Amount' ;
    rdfs:comment 'Total invoice amount before taxes and adjustments. Represents the base value of goods or services invoiced.' ;
    rdfs:domain ind:VendorInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:invoiceNetAmount rdf:type rdf:Property ;
    rdfs:label 'Invoice Net Amount' ;
    rdfs:comment 'Total invoice amount payable after applying taxes, discounts, and adjustments. This is the final amount due to the vendor.' ;
    rdfs:domain ind:VendorInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:invoiceReceivedDate rdf:type rdf:Property ;
    rdfs:label 'Invoice Received Date' ;
    rdfs:comment 'The date the invoice was received by the procurement or accounts payable department.' ;
    rdfs:domain ind:VendorInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentDueDate rdf:type rdf:Property ;
    rdfs:label 'Payment Due Date' ;
    rdfs:comment 'The date by which payment must be made to the vendor to comply with payment terms and avoid late payment penalties.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:aconexTransmittalReference rdf:type rdf:Property ;
    rdfs:label 'Aconex Transmittal Reference' ;
    rdfs:comment 'Reference number for the Aconex document transmittal through which the inspection documents were formally submitted and distributed.' ;
    rdfs:domain ind:InspectionRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:asBuiltDrawingDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'As Built Drawing Document Number' ;
    rdfs:comment 'Document control number for as-built drawings submitted by vendor showing final fabricated dimensions and configurations.' ;
    rdfs:domain ind:InspectionRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentReviewDate rdf:type rdf:Property ;
    rdfs:label 'Document Review Date' ;
    rdfs:comment 'Date when the document review was completed and approval status was assigned.' ;
    rdfs:domain ind:InspectionRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:documentReviewStatus rdf:type rdf:Property ;
    rdfs:label 'Document Review Status' ;
    rdfs:comment 'Current review status of the vendor-submitted inspection and technical documents. Tracks document approval workflow.' ;
    rdfs:domain ind:InspectionRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentReviewerName rdf:type rdf:Property ;
    rdfs:label 'Document Reviewer Name' ;
    rdfs:comment 'Name of the engineer or QA/QC specialist who reviewed and approved the inspection documentation.' ;
    rdfs:domain ind:InspectionRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentRevisionNumber rdf:type rdf:Property ;
    rdfs:label 'Document Revision Number' ;
    rdfs:comment 'Revision identifier for the inspection documentation package. Tracks version control for resubmissions and updates.' ;
    rdfs:domain ind:InspectionRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentSubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Document Submission Date' ;
    rdfs:comment 'Date when the vendor submitted the inspection documentation package for review.' ;
    rdfs:domain ind:InspectionRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:equipmentTagNumber rdf:type rdf:Property ;
    rdfs:label 'Equipment Tag Number' ;
    rdfs:comment 'Unique tag identifier for the specific equipment unit being inspected. Used for traceability in MEP and major equipment installations.' ;
    rdfs:domain ind:InspectionRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Inspection Order Number' ;
    rdfs:comment 'Business identifier for the inspection order issued to vendor or third-party inspector. Format: IO-YYYYNNNN.' ;
    rdfs:domain ind:InspectionRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionRemarks rdf:type rdf:Property ;
    rdfs:label 'Inspection Remarks' ;
    rdfs:comment 'Free-text field for inspector comments, observations, special conditions, or additional notes regarding the inspection findings.' ;
    rdfs:domain ind:InspectionRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionReportDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Inspection Report Document Number' ;
    rdfs:comment 'Document control number for the formal inspection report. Links to document management system for full report retrieval.' ;
    rdfs:domain ind:InspectionRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionResult rdf:type rdf:Property ;
    rdfs:label 'Inspection Result' ;
    rdfs:comment 'Overall outcome of the inspection. Pass indicates full compliance, conditional pass indicates minor non-conformances with agreed remediation, fail indicates rejection, pending retest indicates awaiting re-inspection.' ;
    rdfs:domain ind:InspectionRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionWitnessRequired rdf:type rdf:Property ;
    rdfs:label 'Inspection Witness Required' ;
    rdfs:comment 'Flag indicating whether client or third-party witness is contractually required to be present during inspection. True if witness hold point is specified in ITP.' ;
    rdfs:domain ind:InspectionRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inspectorName rdf:type rdf:Property ;
    rdfs:label 'Inspector Name' ;
    rdfs:comment 'Full name of the inspector or inspection agency representative who performed the inspection. May be internal QA/QC staff, third-party inspector, or client representative.' ;
    rdfs:domain ind:InspectionRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectorOrganization rdf:type rdf:Property ;
    rdfs:label 'Inspector Organization' ;
    rdfs:comment 'Name of the organization or agency that performed the inspection (e.g., internal QA/QC team, third-party inspection agency, client representative).' ;
    rdfs:domain ind:InspectionRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialDataSheetDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Material Data Sheet Document Number' ;
    rdfs:comment 'Document control number for the vendor-submitted material data sheet. Contains material properties, composition, and technical characteristics.' ;
    rdfs:domain ind:InspectionRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:omManualDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Om Manual Document Number' ;
    rdfs:comment 'Document control number for the vendor-submitted Operations and Maintenance manual. Required for equipment handover and commissioning.' ;
    rdfs:domain ind:InspectionRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:punchListItems rdf:type rdf:Property ;
    rdfs:label 'Punch List Items' ;
    rdfs:comment 'Comma-separated list or detailed description of outstanding punch list items, deficiencies, or minor non-conformances identified during inspection that require remediation before final release.' ;
    rdfs:domain ind:InspectionRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:releaseCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Release Certificate Number' ;
    rdfs:comment 'Unique certificate number issued upon successful inspection, authorizing shipment or installation. Format: RC-YYYYNNNN. Required before goods can be shipped to site.' ;
    rdfs:domain ind:InspectionRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipmentAuthorizationDate rdf:type rdf:Property ;
    rdfs:label 'Shipment Authorization Date' ;
    rdfs:comment 'Date when the vendor was formally authorized to ship the inspected materials to the construction site following successful inspection release.' ;
    rdfs:domain ind:InspectionRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:witnessOrganization rdf:type rdf:Property ;
    rdfs:label 'Witness Organization' ;
    rdfs:comment 'Name of the client organization or third-party entity that witnessed the inspection, if witness was required.' ;
    rdfs:domain ind:InspectionRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:witnessRepresentativeName rdf:type rdf:Property ;
    rdfs:label 'Witness Representative Name' ;
    rdfs:comment 'Name of the individual representative from the witness organization who attended the inspection.' ;
    rdfs:domain ind:InspectionRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supersededByModelBimModelId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Model Bim Model Id' ;
    rdfs:comment 'Reference to the newer BIM model version that replaces this one. Null if this is the current version.' ;
    rdfs:domain ind:BimModel ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BimModel .

ind:authorOrganization rdf:type rdf:Property ;
    rdfs:label 'Author Organization' ;
    rdfs:comment 'Organization or company responsible for authoring the BIM model (e.g., design consultant, contractor).' ;
    rdfs:domain ind:Design ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authoringSoftware rdf:type rdf:Property ;
    rdfs:label 'Authoring Software' ;
    rdfs:comment 'Software application used to create and edit the BIM model (e.g., Autodesk Revit, Bentley MicroStation, ArchiCAD, Tekla Structures).' ;
    rdfs:domain ind:BimModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:buildingZone rdf:type rdf:Property ;
    rdfs:label 'Building Zone' ;
    rdfs:comment 'Specific building, zone, or facility area that this BIM model represents (e.g., Tower A, Basement Level 2, North Wing).' ;
    rdfs:domain ind:BimModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clashCount rdf:type rdf:Property ;
    rdfs:label 'Clash Count' ;
    rdfs:comment 'Number of unresolved clashes identified in the latest clash detection run. Zero indicates coordination clearance.' ;
    rdfs:domain ind:BimModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:clashDetectionStatus rdf:type rdf:Property ;
    rdfs:label 'Clash Detection Status' ;
    rdfs:comment 'Status of clash detection analysis for this model against other discipline models. Critical for coordination.' ;
    rdfs:domain ind:Design ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coordinateSystem rdf:type rdf:Property ;
    rdfs:label 'Coordinate System' ;
    rdfs:comment 'Coordinate reference system used for model positioning (e.g., WGS84, NAD83, local grid). Ensures spatial alignment across disciplines.' ;
    rdfs:domain ind:BimModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:elementCount rdf:type rdf:Property ;
    rdfs:label 'Element Count' ;
    rdfs:comment 'Total number of BIM elements (objects) contained in the model. Indicator of model complexity.' ;
    rdfs:domain ind:BimModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:federationRole rdf:type rdf:Property ;
    rdfs:label 'Federation Role' ;
    rdfs:comment 'Role of this model in federated model assembly. Determines how it integrates with other discipline models.' ;
    rdfs:domain ind:BimModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lodClassification rdf:type rdf:Property ;
    rdfs:label 'Lod Classification' ;
    rdfs:comment 'Level of Development per AIA E202 and BIMForum LOD Specification. Defines the degree of geometric detail and information richness in the model elements.' ;
    rdfs:domain ind:BimModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modelName rdf:type rdf:Property ;
    rdfs:label 'Model Name' ;
    rdfs:comment 'Human-readable name of the BIM model describing its content and scope (e.g., Terminal Building Level 1 Architecture, Bridge Deck Structural Model).' ;
    rdfs:domain ind:BimModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modelNumber rdf:type rdf:Property ;
    rdfs:label 'Model Number' ;
    rdfs:comment 'Business identifier for the BIM model, typically following project naming conventions (e.g., ARC-L01-001, STR-F02-005). Used for external reference and communication.' ;
    rdfs:domain ind:BimModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modelStatus rdf:type rdf:Property ;
    rdfs:label 'Model Status' ;
    rdfs:comment 'Current lifecycle status of the BIM model. Controls access, usage, and workflow progression.' ;
    rdfs:domain ind:BimModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modelType rdf:type rdf:Property ;
    rdfs:label 'Model Type' ;
    rdfs:comment 'Classification of the model purpose and usage context within the project lifecycle.' ;
    rdfs:domain ind:BimModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modelVersion rdf:type rdf:Property ;
    rdfs:label 'Model Version' ;
    rdfs:comment 'Version identifier for this iteration of the BIM model. Tracks evolution and change history.' ;
    rdfs:domain ind:BimModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originElevationM rdf:type rdf:Property ;
    rdfs:label 'Origin Elevation M' ;
    rdfs:comment 'Elevation of the model origin point in meters above sea level. Provides vertical datum reference.' ;
    rdfs:domain ind:BimModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:originLatitude rdf:type rdf:Property ;
    rdfs:label 'Origin Latitude' ;
    rdfs:comment 'Latitude coordinate of the model origin point in decimal degrees. Establishes geolocation reference.' ;
    rdfs:domain ind:BimModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:originLongitude rdf:type rdf:Property ;
    rdfs:label 'Origin Longitude' ;
    rdfs:comment 'Longitude coordinate of the model origin point in decimal degrees. Establishes geolocation reference.' ;
    rdfs:domain ind:BimModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:softwareVersion rdf:type rdf:Property ;
    rdfs:label 'Software Version' ;
    rdfs:comment 'Version number of the authoring software used to create the model. Critical for compatibility and file exchange.' ;
    rdfs:domain ind:BimModel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cadFileName rdf:type rdf:Property ;
    rdfs:label 'Cad File Name' ;
    rdfs:comment 'Name of the CAD source file from which the drawing was generated.' ;
    rdfs:domain ind:Drawing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checkerName rdf:type rdf:Property ;
    rdfs:label 'Checker Name' ;
    rdfs:comment 'Name of the individual who performed technical checking or peer review of the drawing.' ;
    rdfs:domain ind:Drawing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drawingNumber rdf:type rdf:Property ;
    rdfs:label 'Drawing Number' ;
    rdfs:comment 'Unique alphanumeric identifier assigned to the drawing per project drawing numbering convention. Serves as the business key for the drawing register.' ;
    rdfs:domain ind:Drawing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drawingStatus rdf:type rdf:Property ;
    rdfs:label 'Drawing Status' ;
    rdfs:comment 'Current lifecycle status of the drawing (e.g., draft, issued for review, issued for construction, approved, superseded, archived). [ENUM-REF-CANDIDATE: draft|issued_for_review|issued_for_approval|issued_for_construction|approved|superseded|archived — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Drawing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drawingType rdf:type rdf:Property ;
    rdfs:label 'Drawing Type' ;
    rdfs:comment 'Classification of the drawing by its representation type (e.g., plan, elevation, section, detail, schedule, isometric).' ;
    rdfs:domain ind:Drawing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuePurpose rdf:type rdf:Property ;
    rdfs:label 'Issue Purpose' ;
    rdfs:comment 'Purpose for which the drawing was issued (e.g., for information, for review, for approval, for construction, for tender, as-built).' ;
    rdfs:domain ind:Drawing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scale rdf:type rdf:Property ;
    rdfs:label 'Scale' ;
    rdfs:comment 'Scale ratio of the drawing (e.g., 1:100, 1:50, NTS for not to scale).' ;
    rdfs:domain ind:Drawing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sheetSize rdf:type rdf:Property ;
    rdfs:label 'Sheet Size' ;
    rdfs:comment 'Standard paper or sheet size of the drawing (e.g., A0, A1, ARCH D, ARCH E). [ENUM-REF-CANDIDATE: A0|A1|A2|A3|A4|ARCH_D|ARCH_E — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Drawing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supersededByDrawingNumber rdf:type rdf:Property ;
    rdfs:label 'Superseded By Drawing Number' ;
    rdfs:comment 'Drawing number of the newer version that supersedes this drawing.' ;
    rdfs:domain ind:Drawing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supersedesDrawingNumber rdf:type rdf:Property ;
    rdfs:label 'Supersedes Drawing Number' ;
    rdfs:comment 'Drawing number of the previous version that this drawing supersedes or replaces.' ;
    rdfs:domain ind:Drawing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:zoneLocation rdf:type rdf:Property ;
    rdfs:label 'Zone Location' ;
    rdfs:comment 'Physical zone, building, or location within the project site that the drawing depicts.' ;
    rdfs:domain ind:Drawing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supersededRevisionDrawingRevisionId rdf:type rdf:Property ;
    rdfs:label 'Superseded Revision Drawing Revision Id' ;
    rdfs:comment 'Reference to the previous revision that this revision replaces or supersedes. Maintains the version control chain and audit trail.' ;
    rdfs:domain ind:DrawingRevision ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DrawingRevision .

ind:acknowledgmentRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Acknowledgment Required Flag' ;
    rdfs:comment 'Indicates whether recipients are required to formally acknowledge receipt and review of this revision. Used for critical or contractual revisions.' ;
    rdfs:domain ind:DrawingRevision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:acknowledgmentStatus rdf:type rdf:Property ;
    rdfs:label 'Acknowledgment Status' ;
    rdfs:comment 'Current status of acknowledgment from recipients. Tracks whether required acknowledgments have been received.' ;
    rdfs:domain ind:DrawingRevision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionDate rdf:type rdf:Property ;
    rdfs:label 'Distribution Date' ;
    rdfs:comment 'Date when this revision was distributed to project stakeholders. Marks the formal communication of the revision to the project team.' ;
    rdfs:domain ind:DrawingRevision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:distributionMethod rdf:type rdf:Property ;
    rdfs:label 'Distribution Method' ;
    rdfs:comment 'The method or channel used to distribute this revision to stakeholders. Tracks whether distribution was electronic, physical, or both.' ;
    rdfs:domain ind:DrawingRevision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionStatus rdf:type rdf:Property ;
    rdfs:label 'Distribution Status' ;
    rdfs:comment 'Current state of the distribution process for this revision. Tracks whether the revision has been sent to stakeholders and their acknowledgment status.' ;
    rdfs:domain ind:DrawingRevision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingEngineerName rdf:type rdf:Property ;
    rdfs:label 'Issuing Engineer Name' ;
    rdfs:comment 'Full name of the engineer who prepared and issued this revision. Provides human-readable identification for audit and communication purposes.' ;
    rdfs:domain ind:DrawingRevision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revisionCode rdf:type rdf:Property ;
    rdfs:label 'Revision Code' ;
    rdfs:comment 'Alphanumeric code identifying the specific revision version (e.g., A, B, C, P01, P02 for preliminary, C01 for construction issue). Follows project-specific or organizational revision coding standards.' ;
    rdfs:domain ind:DrawingRevision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revisionReason rdf:type rdf:Property ;
    rdfs:label 'Revision Reason' ;
    rdfs:comment 'Categorical classification of the business driver or trigger that necessitated this revision. Enables analysis of revision patterns and root causes. [ENUM-REF-CANDIDATE: rfi_response|design_change|client_instruction|coordination_issue|code_compliance|value_engineering|constructability_review|error_correction|scope_change|material_substitution|site_condition|regulatory_requirement — 12 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:DrawingRevision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approverRole rdf:type rdf:Property ;
    rdfs:label 'Approver Role' ;
    rdfs:comment 'Role or position of the approver (e.g., Lead Structural Engineer, Design Manager, Client Representative, QA/QC Manager).' ;
    rdfs:domain ind:TechnicalSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:environmentalRequirements rdf:type rdf:Property ;
    rdfs:label 'Environmental Requirements' ;
    rdfs:comment 'Environmental compliance requirements including LEED (Leadership in Energy and Environmental Design) criteria, sustainability standards, emissions limits, and waste management provisions.' ;
    rdfs:domain ind:TechnicalSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialRequirements rdf:type rdf:Property ;
    rdfs:label 'Material Requirements' ;
    rdfs:comment 'Detailed requirements for materials including grades, properties, certifications, and acceptance criteria (e.g., concrete strength class C30/37, steel grade S355, ASTM A615 Grade 60 rebar).' ;
    rdfs:domain ind:TechnicalSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sectionNumber rdf:type rdf:Property ;
    rdfs:label 'Section Number' ;
    rdfs:comment 'Detailed section number within CSI MasterFormat or project specification structure (e.g., 03 30 00 for Cast-in-Place Concrete, 23 05 13 for Common Motor Requirements for HVAC Equipment).' ;
    rdfs:domain ind:TechnicalSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specificationNumber rdf:type rdf:Property ;
    rdfs:label 'Specification Number' ;
    rdfs:comment 'Unique business identifier for the technical specification document, typically following organizational or project numbering conventions (e.g., SPEC-MEP-001, TS-2024-HVAC-05).' ;
    rdfs:domain ind:TechnicalSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specificationTitle rdf:type rdf:Property ;
    rdfs:label 'Specification Title' ;
    rdfs:comment 'Full descriptive title of the technical specification document, clearly identifying the scope of work, materials, or systems covered.' ;
    rdfs:domain ind:TechnicalSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specificationType rdf:type rdf:Property ;
    rdfs:label 'Specification Type' ;
    rdfs:comment 'Classification of specification approach: performance-based (outcome-focused), prescriptive (method-focused), proprietary (brand-specific), reference (standard-based), or master (template).' ;
    rdfs:domain ind:TechnicalSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submittalRequirements rdf:type rdf:Property ;
    rdfs:label 'Submittal Requirements' ;
    rdfs:comment 'List of required submittals including shop drawings, product data, samples, test reports, and certifications that must be provided for approval.' ;
    rdfs:domain ind:TechnicalSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supersedesSpecificationNumber rdf:type rdf:Property ;
    rdfs:label 'Supersedes Specification Number' ;
    rdfs:comment 'Specification number of the previous version that this revision replaces, maintaining document lineage and change history.' ;
    rdfs:domain ind:TechnicalSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technicalSpecificationStatus rdf:type rdf:Property ;
    rdfs:label 'Technical Specification Status' ;
    rdfs:comment 'Current lifecycle status of the technical specification document within the document control workflow. [ENUM-REF-CANDIDATE: draft|in_review|approved|issued_for_construction|superseded|archived|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TechnicalSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testingRequirements rdf:type rdf:Property ;
    rdfs:label 'Testing Requirements' ;
    rdfs:comment 'Required tests, inspections, and acceptance criteria including FAT (Factory Acceptance Test), SAT (Site Acceptance Test), and ITP (Inspection and Test Plan) references.' ;
    rdfs:domain ind:TechnicalSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workmanshipStandards rdf:type rdf:Property ;
    rdfs:label 'Workmanship Standards' ;
    rdfs:comment 'Standards and requirements for execution, installation, fabrication, and construction methods to ensure quality workmanship.' ;
    rdfs:domain ind:TechnicalSpecification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalWorkflowState rdf:type rdf:Property ;
    rdfs:label 'Approval Workflow State' ;
    rdfs:comment 'Current state of the internal approval workflow for this package before external submission. [ENUM-REF-CANDIDATE: not_started|in_progress|pending_review|pending_approval|approved|rejected|on_hold — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Package ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractualDueDate rdf:type rdf:Property ;
    rdfs:label 'Contractual Due Date' ;
    rdfs:comment 'Contractually mandated deadline for package submission to client or authority.' ;
    rdfs:domain ind:Package ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:drawingCount rdf:type rdf:Property ;
    rdfs:label 'Drawing Count' ;
    rdfs:comment 'Number of CAD drawings included in this package.' ;
    rdfs:domain ind:Package ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:recipientDistributionList rdf:type rdf:Property ;
    rdfs:label 'Recipient Distribution List' ;
    rdfs:comment 'Comma-separated list of organizations or individuals to whom this package is distributed.' ;
    rdfs:domain ind:Package ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsibleOrganization rdf:type rdf:Property ;
    rdfs:label 'Responsible Organization' ;
    rdfs:comment 'Name of the organization (contractor, consultant, JV partner) responsible for preparing this package.' ;
    rdfs:domain ind:Package ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specificationCount rdf:type rdf:Property ;
    rdfs:label 'Specification Count' ;
    rdfs:comment 'Number of technical specifications included in this package.' ;
    rdfs:domain ind:Package ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:submissionStatus rdf:type rdf:Property ;
    rdfs:label 'Submission Status' ;
    rdfs:comment 'Current status of the package submission to client or reviewing authority.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supersedesPackageNumber rdf:type rdf:Property ;
    rdfs:label 'Supersedes Package Number' ;
    rdfs:comment 'Package number of the previous version that this package replaces or supersedes.' ;
    rdfs:domain ind:Package ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvingClientContactId rdf:type rdf:Property ;
    rdfs:label 'Approving Client Contact Id' ;
    rdfs:comment 'Foreign key linking to client.contact. Business justification: Design submittals require formal client approval by a named client contact (e.g., client\'s engineer or project manager). Tracking the approving client contact enables submittal approval cycle-time rep' ;
    rdfs:domain ind:Submittal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Contact .

ind:actualReviewDate rdf:type rdf:Property ;
    rdfs:label 'Actual Review Date' ;
    rdfs:comment 'Actual date on which the review was completed and the submittal disposition was communicated back to the submitting party.' ;
    rdfs:domain ind:Submittal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:approvalDisposition rdf:type rdf:Property ;
    rdfs:label 'Approval Disposition' ;
    rdfs:comment 'Final disposition code assigned by the reviewing authority indicating the outcome of the review: approved for full acceptance without changes, approved_as_noted for conditional acceptance with minor comments that do not require resubmission, revise_and_resubmit for rework and formal resubmission required, rejected for non-compliance requiring major revision, no_exception_taken for acknowledgment without formal approval, reviewed_for_information for informational submittals not requiring approval.' ;
    rdfs:domain ind:Submittal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryAuthority rdf:type rdf:Property ;
    rdfs:label 'Regulatory Authority' ;
    rdfs:comment 'Name of the regulatory body or statutory authority whose approval or compliance verification is required for this submittal (e.g., local building department, fire marshal, environmental agency).' ;
    rdfs:domain ind:Submittal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiredSubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Required Submission Date' ;
    rdfs:comment 'Contractually mandated or schedule-driven date by which the submittal must be submitted to the design team or client for review, typically derived from the project schedule and procurement lead times.' ;
    rdfs:domain ind:Submittal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:responseNotes rdf:type rdf:Property ;
    rdfs:label 'Response Notes' ;
    rdfs:comment 'Response notes provided by the submitting party addressing reviewer comments, documenting how comments were incorporated or providing justification for alternative approaches.' ;
    rdfs:domain ind:Submittal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewComments rdf:type rdf:Property ;
    rdfs:label 'Review Comments' ;
    rdfs:comment 'Detailed technical comments, observations, and instructions provided by the reviewing authority during the review process, documenting required corrections, clarifications, or conditions of approval.' ;
    rdfs:domain ind:Submittal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewingOrganization rdf:type rdf:Property ;
    rdfs:label 'Reviewing Organization' ;
    rdfs:comment 'Name of the organization responsible for reviewing and approving this submittal, typically the design consultant, architect, or client representative.' ;
    rdfs:domain ind:Submittal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submittalNumber rdf:type rdf:Property ;
    rdfs:label 'Submittal Number' ;
    rdfs:comment 'Unique business identifier for the submittal within the project, typically following a project-specific numbering convention (e.g., S-001, SUB-MEP-001).' ;
    rdfs:domain ind:Submittal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submittalStatus rdf:type rdf:Property ;
    rdfs:label 'Submittal Status' ;
    rdfs:comment 'Current lifecycle status of the submittal in the review and approval workflow. Draft indicates preparation phase, submitted indicates formal lodgment, under_review indicates active evaluation, approved indicates full acceptance, approved_as_noted indicates conditional acceptance with minor comments, revise_and_resubmit indicates rework required, rejected indicates non-compliance, withdrawn indicates contractor cancellation, superseded indicates replacement by newer revision. [ENUM-REF-CANDIDATE: draft|submitted|under_review|approved|approved_as_noted|revise_and_resubmit|rejected|withdrawn|superseded — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Submittal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submittalType rdf:type rdf:Property ;
    rdfs:label 'Submittal Type' ;
    rdfs:comment 'Classification of the submittal item indicating the nature of the submission: shop drawings for fabrication details, product data sheets for material specifications, physical samples for approval, method statements for construction procedures, mix designs for concrete/asphalt, calculations for structural/MEP systems, or test reports for quality verification. [ENUM-REF-CANDIDATE: shop_drawing|product_data|sample|method_statement|mix_design|calculation|test_report — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Submittal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submittingOrganization rdf:type rdf:Property ;
    rdfs:label 'Submitting Organization' ;
    rdfs:comment 'Name of the contractor, subcontractor, or supplier organization responsible for preparing and submitting this submittal.' ;
    rdfs:domain ind:Submittal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supersedesSubmittalNumber rdf:type rdf:Property ;
    rdfs:label 'Supersedes Submittal Number' ;
    rdfs:comment 'Reference to the previous submittal number that this revision supersedes, establishing the revision chain and audit trail.' ;
    rdfs:domain ind:Submittal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewId rdf:type rdf:Property ;
    rdfs:label 'Review Id' ;
    rdfs:comment 'Unique identifier for the design review event. Primary key for the review product.' ;
    rdfs:domain ind:Review ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actionItemsCount rdf:type rdf:Property ;
    rdfs:label 'Action Items Count' ;
    rdfs:comment 'Number of action items or follow-up tasks assigned as a result of this design review.' ;
    rdfs:domain ind:Review ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:attendeeCount rdf:type rdf:Property ;
    rdfs:label 'Attendee Count' ;
    rdfs:comment 'Total number of participants who attended the design review event.' ;
    rdfs:domain ind:Review ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:attendeeList rdf:type rdf:Property ;
    rdfs:label 'Attendee List' ;
    rdfs:comment 'Comma-separated or structured list of names and roles of all participants in the design review event.' ;
    rdfs:domain ind:Review ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chairpersonName rdf:type rdf:Property ;
    rdfs:label 'Chairperson Name' ;
    rdfs:comment 'Name of the individual who chaired or led the design review meeting.' ;
    rdfs:domain ind:Review ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clashDetectionPerformed rdf:type rdf:Property ;
    rdfs:label 'Clash Detection Performed' ;
    rdfs:comment 'Indicates whether automated clash detection analysis was performed as part of this design review.' ;
    rdfs:domain ind:Review ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:clashesIdentifiedCount rdf:type rdf:Property ;
    rdfs:label 'Clashes Identified Count' ;
    rdfs:comment 'Number of design clashes or conflicts identified during clash detection analysis.' ;
    rdfs:domain ind:Review ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:commentsClosedCount rdf:type rdf:Property ;
    rdfs:label 'Comments Closed Count' ;
    rdfs:comment 'Number of review comments that have been resolved and closed.' ;
    rdfs:domain ind:Review ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:commentsOpenCount rdf:type rdf:Property ;
    rdfs:label 'Comments Open Count' ;
    rdfs:comment 'Number of review comments that remain open and require action.' ;
    rdfs:domain ind:Review ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:majorCommentsCount rdf:type rdf:Property ;
    rdfs:label 'Major Comments Count' ;
    rdfs:comment 'Number of major or critical comments raised that require mandatory resolution before approval.' ;
    rdfs:domain ind:Review ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minorCommentsCount rdf:type rdf:Property ;
    rdfs:label 'Minor Comments Count' ;
    rdfs:comment 'Number of minor comments raised that are recommended but not mandatory for approval.' ;
    rdfs:domain ind:Review ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minutesDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Minutes Document Reference' ;
    rdfs:comment 'Reference to the formal meeting minutes or record document for this design review event.' ;
    rdfs:domain ind:Review ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextReviewScheduledDate rdf:type rdf:Property ;
    rdfs:label 'Next Review Scheduled Date' ;
    rdfs:comment 'Planned date for the next design review or follow-up review event.' ;
    rdfs:domain ind:Review ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:recommendations rdf:type rdf:Property ;
    rdfs:label 'Recommendations' ;
    rdfs:comment 'Key recommendations or improvement suggestions arising from the design review.' ;
    rdfs:domain ind:Review ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewNumber rdf:type rdf:Property ;
    rdfs:label 'Review Number' ;
    rdfs:comment 'Business identifier for the design review event, typically following project numbering conventions (e.g., DR-001, IDC-2024-05).' ;
    rdfs:domain ind:Review ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewStatus rdf:type rdf:Property ;
    rdfs:label 'Review Status' ;
    rdfs:comment 'Current lifecycle status of the design review event.' ;
    rdfs:domain ind:Review ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewType rdf:type rdf:Property ;
    rdfs:label 'Review Type' ;
    rdfs:comment 'Classification of the design review event. Internal peer review is conducted within the design team; Interdisciplinary Check (IDC) validates coordination across disciplines; client milestone review is a formal client gate review; third-party review involves external consultants; authority review is conducted by regulatory bodies; constructability review assesses buildability.' ;
    rdfs:domain ind:Review ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signOffAuthority rdf:type rdf:Property ;
    rdfs:label 'Sign Off Authority' ;
    rdfs:comment 'Name or role of the individual or body with authority to approve or reject the design at this review stage (e.g., Chief Engineer, Client Representative, Regulatory Authority).' ;
    rdfs:domain ind:Review ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signOffDate rdf:type rdf:Property ;
    rdfs:label 'Sign Off Date' ;
    rdfs:comment 'Date on which the sign-off authority formally approved or rejected the design package.' ;
    rdfs:domain ind:Review ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:stage rdf:type rdf:Property ;
    rdfs:label 'Stage' ;
    rdfs:comment 'Design completion stage at which the review is conducted. IFC = Issued for Construction; IFD = Issued for Design; stages represent percentage completion milestones. [ENUM-REF-CANDIDATE: concept|30_percent|60_percent|90_percent|ifc|ifd|as_built — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:summary rdf:type rdf:Property ;
    rdfs:label 'Summary' ;
    rdfs:comment 'Executive summary or key findings from the design review event.' ;
    rdfs:domain ind:Review ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalCommentsRaised rdf:type rdf:Property ;
    rdfs:label 'Total Comments Raised' ;
    rdfs:comment 'Total number of review comments or issues raised during this design review event.' ;
    rdfs:domain ind:Review ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:originatorContactId rdf:type rdf:Property ;
    rdfs:label 'Originator Contact Id' ;
    rdfs:comment 'Foreign key linking to client.contact. Business justification: Change notices are originated by a client contact; linking enables change log reporting and responsibility tracking.' ;
    rdfs:domain ind:ChangeNotice ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Contact .

ind:actualCostImpactAmount rdf:type rdf:Property ;
    rdfs:label 'Actual Cost Impact Amount' ;
    rdfs:comment 'Actual realized financial impact of the change notice after implementation, expressed in the project base currency.' ;
    rdfs:domain ind:ChangeNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualScheduleImpactDays rdf:type rdf:Property ;
    rdfs:label 'Actual Schedule Impact Days' ;
    rdfs:comment 'Actual realized schedule impact in calendar days after implementation of the change notice.' ;
    rdfs:domain ind:ChangeNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:affectedDisciplines rdf:type rdf:Property ;
    rdfs:label 'Affected Disciplines' ;
    rdfs:comment 'Comma-separated list of all engineering disciplines impacted by this change notice, enabling cross-functional coordination.' ;
    rdfs:domain ind:ChangeNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalAuthority rdf:type rdf:Property ;
    rdfs:label 'Approval Authority' ;
    rdfs:comment 'Name or role of the individual or committee with authority to approve or reject this change notice (e.g., Project Manager, Chief Engineer, Change Control Board).' ;
    rdfs:domain ind:ChangeNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeNoticeDescription rdf:type rdf:Property ;
    rdfs:label 'Change Notice Description' ;
    rdfs:comment 'Detailed narrative describing the design change, including technical rationale, scope of work affected, and justification for the modification.' ;
    rdfs:domain ind:ChangeNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeNoticeNumber rdf:type rdf:Property ;
    rdfs:label 'Change Notice Number' ;
    rdfs:comment 'The externally-known unique business identifier for this change notice, typically following a project-specific numbering convention (e.g., ECN-2024-001).' ;
    rdfs:domain ind:ChangeNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeNoticeStatus rdf:type rdf:Property ;
    rdfs:label 'Change Notice Status' ;
    rdfs:comment 'Current lifecycle status of the change notice in the approval and implementation workflow. [ENUM-REF-CANDIDATE: draft|submitted|under_review|approved|rejected|implemented|closed|cancelled — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ChangeNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeNoticeType rdf:type rdf:Property ;
    rdfs:label 'Change Notice Type' ;
    rdfs:comment 'Classification of the change notice by its nature (design change, engineering change, specification change, material substitution, scope change, regulatory change).' ;
    rdfs:domain ind:ChangeNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clashDetectionImpact rdf:type rdf:Property ;
    rdfs:label 'Clash Detection Impact' ;
    rdfs:comment 'Description of any clash detection issues identified or resolved as a result of this change notice in the BIM coordination process.' ;
    rdfs:domain ind:ChangeNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clientApprovalRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Client Approval Required Flag' ;
    rdfs:comment 'Boolean indicator of whether formal client approval is contractually required for this change notice before implementation.' ;
    rdfs:domain ind:ChangeNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:estimatedScheduleImpactDays rdf:type rdf:Property ;
    rdfs:label 'Estimated Schedule Impact Days' ;
    rdfs:comment 'Estimated number of calendar days by which the project schedule will be extended or accelerated due to this change notice. Positive values indicate delays; negative values indicate acceleration.' ;
    rdfs:domain ind:ChangeNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:implementationStatus rdf:type rdf:Property ;
    rdfs:label 'Implementation Status' ;
    rdfs:comment 'Current status of the physical implementation of the approved change notice in the field or design deliverables.' ;
    rdfs:domain ind:ChangeNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originatingCause rdf:type rdf:Property ;
    rdfs:label 'Originating Cause' ;
    rdfs:comment 'Root cause or trigger that necessitated the change notice (client instruction, unforeseen site condition, design error, regulatory requirement, value engineering, constructability improvement).' ;
    rdfs:domain ind:ChangeNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originatorOrganization rdf:type rdf:Property ;
    rdfs:label 'Originator Organization' ;
    rdfs:comment 'Organization or company of the individual who initiated the change notice (e.g., client, contractor, subcontractor, consultant).' ;
    rdfs:domain ind:ChangeNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryReference rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reference' ;
    rdfs:comment 'Citation of the specific regulatory code, standard, or requirement that necessitates or is impacted by this change notice.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bidDecision rdf:type rdf:Property ;
    rdfs:label 'Bid Decision' ;
    rdfs:comment 'Decision on whether to submit a bid for the opportunity.' ;
