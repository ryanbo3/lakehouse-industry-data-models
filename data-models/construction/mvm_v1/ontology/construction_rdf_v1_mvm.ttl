ind:claimStatusReason rdf:type rdf:Property ;
    rdfs:label 'Claim Status Reason' ;
    rdfs:comment 'Explanation for the current status, such as reason for rejection or hold.' ;
    rdfs:domain ind:EotClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimSubmissionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Claim Submission Timestamp' ;
    rdfs:comment 'Date and time when the contractor formally submitted the EOT claim.' ;
    rdfs:domain ind:EotClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:claimType rdf:type rdf:Property ;
    rdfs:label 'Claim Type' ;
    rdfs:comment 'Category describing the contractual basis for the time extension request.' ;
    rdfs:domain ind:EotClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Claim Updated Timestamp' ;
    rdfs:comment 'Timestamp of the most recent modification to the claim record.' ;
    rdfs:domain ind:EotClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:daysAssessed rdf:type rdf:Property ;
    rdfs:label 'Days Assessed' ;
    rdfs:comment 'Number of days approved by the engineer after assessment.' ;
    rdfs:domain ind:EotClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:daysClaimed rdf:type rdf:Property ;
    rdfs:label 'Days Claimed' ;
    rdfs:comment 'Number of calendar days the contractor claims as an extension.' ;
    rdfs:domain ind:EotClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:determinationOutcome rdf:type rdf:Property ;
    rdfs:label 'Determination Outcome' ;
    rdfs:comment 'Final decision result after engineering review.' ;
    rdfs:domain ind:EotClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entitlementBasis rdf:type rdf:Property ;
    rdfs:label 'Entitlement Basis' ;
    rdfs:comment 'FIDIC sub-clause or contractual provision that justifies the claim.' ;
    rdfs:domain ind:EotClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:liquidatedDamagesImpact rdf:type rdf:Property ;
    rdfs:label 'Liquidated Damages Impact' ;
    rdfs:comment 'Estimated reduction in liquidated damages exposure due to the approved extension.' ;
    rdfs:domain ind:EotClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:supportingDocumentRefs rdf:type rdf:Property ;
    rdfs:label 'Supporting Document Refs' ;
    rdfs:comment 'Comma-separated list of document IDs (e.g., drawings, logs, photos) that substantiate the claim.' ;
    rdfs:domain ind:EotClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentReason rdf:type rdf:Property ;
    rdfs:label 'Assessment Reason' ;
    rdfs:comment 'Narrative explanation for why the LD assessment was generated (e.g., missed milestone, force majeure).' ;
    rdfs:domain ind:LdAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:delayDays rdf:type rdf:Property ;
    rdfs:label 'Delay Days' ;
    rdfs:comment 'Number of calendar days the milestone was delayed beyond the due date.' ;
    rdfs:domain ind:LdAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ldWaiverFlag rdf:type rdf:Property ;
    rdfs:label 'Ld Waiver Flag' ;
    rdfs:comment 'Indicates whether a waiver has been granted for this assessment (true = waiver granted).' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ldWaiverJustification rdf:type rdf:Property ;
    rdfs:label 'Ld Waiver Justification' ;
    rdfs:comment 'Explanation or contractual clause supporting the granted waiver.' ;
    rdfs:domain ind:LdAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:milestoneDueDate rdf:type rdf:Property ;
    rdfs:label 'Milestone Due Date' ;
    rdfs:comment 'Scheduled date by which the milestone was contractually required to be achieved.' ;
    rdfs:domain ind:LdAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:netLdDeducted rdf:type rdf:Property ;
    rdfs:label 'Net Ld Deducted' ;
    rdfs:comment 'Final liquidated damages amount deducted from the payment certificate after waivers.' ;
    rdfs:domain ind:LdAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recordAuditCreated rdf:type rdf:Property ;
    rdfs:label 'Record Audit Created' ;
    rdfs:comment 'Timestamp when the LD assessment record was first created in the system.' ;
    rdfs:domain ind:LdAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:recordAuditUpdated rdf:type rdf:Property ;
    rdfs:label 'Record Audit Updated' ;
    rdfs:comment 'Timestamp of the most recent update to the LD assessment record.' ;
    rdfs:domain ind:LdAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:totalLdAmount rdf:type rdf:Property ;
    rdfs:label 'Total Ld Amount' ;
    rdfs:comment 'Gross liquidated damages amount before any waivers or reductions.' ;
    rdfs:domain ind:LdAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:waiverAmount rdf:type rdf:Property ;
    rdfs:label 'Waiver Amount' ;
    rdfs:comment 'Amount of LD that has been waived or reduced per contractual negotiation.' ;
    rdfs:domain ind:LdAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contractRetentionLedgerStatus rdf:type rdf:Property ;
    rdfs:label 'Contract Retention Ledger Status' ;
    rdfs:comment 'Current lifecycle status of the retention ledger entry.' ;
    rdfs:domain ind:RetentionLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cumulativeRetentionBalance rdf:type rdf:Property ;
    rdfs:label 'Cumulative Retention Balance' ;
    rdfs:comment 'Running total of retention still held after this release.' ;
    rdfs:domain ind:RetentionLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:effectiveTimestamp rdf:type rdf:Property ;
    rdfs:label 'Effective Timestamp' ;
    rdfs:comment 'Exact point in time when the retention entry became effective.' ;
    rdfs:domain ind:RetentionLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:releaseAmount rdf:type rdf:Property ;
    rdfs:label 'Release Amount' ;
    rdfs:comment 'Amount of retention released in this transaction (partial or full).' ;
    rdfs:domain ind:RetentionLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:releaseReason rdf:type rdf:Property ;
    rdfs:label 'Release Reason' ;
    rdfs:comment 'Free-text explanation for why the retention was released (e.g., milestone achieved, DLP expiry).' ;
    rdfs:domain ind:RetentionLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retentionAdjustmentAmount rdf:type rdf:Property ;
    rdfs:label 'Retention Adjustment Amount' ;
    rdfs:comment 'Monetary adjustment to the retention (positive or negative) applied after initial calculation.' ;
    rdfs:domain ind:RetentionLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:retentionAdjustmentReason rdf:type rdf:Property ;
    rdfs:label 'Retention Adjustment Reason' ;
    rdfs:comment 'Explanation for why a retention adjustment was made.' ;
    rdfs:domain ind:RetentionLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retentionBondAmount rdf:type rdf:Property ;
    rdfs:label 'Retention Bond Amount' ;
    rdfs:comment 'Monetary value of the retention bond when substitution occurs.' ;
    rdfs:domain ind:RetentionLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:retentionBondCurrency rdf:type rdf:Property ;
    rdfs:label 'Retention Bond Currency' ;
    rdfs:comment 'Currency of the retention bond amount.' ;
    rdfs:domain ind:RetentionLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retentionBondSubstitutedFlag rdf:type rdf:Property ;
    rdfs:label 'Retention Bond Substituted Flag' ;
    rdfs:comment 'Indicates whether a retention bond was used in place of cash retention.' ;
    rdfs:domain ind:RetentionLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:retentionEntryNumber rdf:type rdf:Property ;
    rdfs:label 'Retention Entry Number' ;
    rdfs:comment 'Human-readable sequential identifier for the retention entry, often used in reports and certificates.' ;
    rdfs:domain ind:RetentionLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retentionHoldExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Retention Hold Expiry Date' ;
    rdfs:comment 'Date when a retention hold is scheduled to be lifted if unresolved.' ;
    rdfs:domain ind:RetentionLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:retentionHoldFlag rdf:type rdf:Property ;
    rdfs:label 'Retention Hold Flag' ;
    rdfs:comment 'Indicates if the retention amount is currently on hold (e.g., due to dispute).' ;
    rdfs:domain ind:RetentionLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:retentionHoldReason rdf:type rdf:Property ;
    rdfs:label 'Retention Hold Reason' ;
    rdfs:comment 'Explanation for why the retention is being held.' ;
    rdfs:domain ind:RetentionLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retentionReleasePercentage rdf:type rdf:Property ;
    rdfs:label 'Retention Release Percentage' ;
    rdfs:comment 'Percentage of the total retention released in this transaction.' ;
    rdfs:domain ind:RetentionLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:retentionReleaseSequence rdf:type rdf:Property ;
    rdfs:label 'Retention Release Sequence' ;
    rdfs:comment 'Ordinal number indicating the order of releases for a given contract.' ;
    rdfs:domain ind:RetentionLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:retentionReleaseType rdf:type rdf:Property ;
    rdfs:label 'Retention Release Type' ;
    rdfs:comment 'Reason category for the retention release (e.g., practical completion, DLP expiry).' ;
    rdfs:domain ind:RetentionLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retentionSource rdf:type rdf:Property ;
    rdfs:label 'Retention Source' ;
    rdfs:comment 'Origin of the retention amount (e.g., regular payment certificate, change order, or manual adjustment).' ;
    rdfs:domain ind:RetentionLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amendmentId rdf:type rdf:Property ;
    rdfs:label 'Amendment Id' ;
    rdfs:comment 'Unique surrogate key for each contract amendment record.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:amendmentCategory rdf:type rdf:Property ;
    rdfs:label 'Amendment Category' ;
    rdfs:comment 'High-level category of impact caused by the amendment.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amendmentDescription rdf:type rdf:Property ;
    rdfs:label 'Amendment Description' ;
    rdfs:comment 'Narrative description of the amendment purpose and changes.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amendmentScope rdf:type rdf:Property ;
    rdfs:label 'Amendment Scope' ;
    rdfs:comment 'Detailed description of the scope changes introduced.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amendmentStatus rdf:type rdf:Property ;
    rdfs:label 'Amendment Status' ;
    rdfs:comment 'Current lifecycle status of the amendment.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentSignedFlag rdf:type rdf:Property ;
    rdfs:label 'Document Signed Flag' ;
    rdfs:comment 'Indicates whether the amendment document has been signed.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:documentStoragePath rdf:type rdf:Property ;
    rdfs:label 'Document Storage Path' ;
    rdfs:comment 'File system or repository path where the signed amendment is stored.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:executionStatus rdf:type rdf:Property ;
    rdfs:label 'Execution Status' ;
    rdfs:comment 'Operational execution status of the amendment implementation.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impactFinancial rdf:type rdf:Property ;
    rdfs:label 'Impact Financial' ;
    rdfs:comment 'Monetary impact of the amendment on the contract value.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:impactScopeDescription rdf:type rdf:Property ;
    rdfs:label 'Impact Scope Description' ;
    rdfs:comment 'Narrative description of how the scope is affected.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalReviewStatus rdf:type rdf:Property ;
    rdfs:label 'Legal Review Status' ;
    rdfs:comment 'Status of the legal review process for the amendment.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Original Completion Date' ;
    rdfs:comment 'Original contract completion date prior to amendment.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:originalContractValue rdf:type rdf:Property ;
    rdfs:label 'Original Contract Value' ;
    rdfs:comment 'Contract value before any amendments.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentAdjustmentAmount rdf:type rdf:Property ;
    rdfs:label 'Payment Adjustment Amount' ;
    rdfs:comment 'Adjustment to payment schedule amount due to amendment.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentScheduleNewDate rdf:type rdf:Property ;
    rdfs:label 'Payment Schedule New Date' ;
    rdfs:comment 'New date for the next payment after amendment.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:bidBondId rdf:type rdf:Property ;
    rdfs:label 'Bid Bond Id' ;
    rdfs:comment 'Foreign key linking to bid.bond. Business justification: Bid bonds (bid domain) are converted to performance/retention bond guarantees (contract domain) upon award. Finance and legal teams must reconcile the originating bid bond against the contract-stage g' ;
    rdfs:domain ind:BondGuarantee ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Bond .

ind:bondAmount rdf:type rdf:Property ;
    rdfs:label 'Bond Amount' ;
    rdfs:comment 'Monetary value of the bond guarantee.' ;
    rdfs:domain ind:BondGuarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bondGuaranteeDescription rdf:type rdf:Property ;
    rdfs:label 'Bond Guarantee Description' ;
    rdfs:comment 'Free-text description or notes about the bond guarantee.' ;
    rdfs:domain ind:BondGuarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bondGuaranteeStatus rdf:type rdf:Property ;
    rdfs:label 'Bond Guarantee Status' ;
    rdfs:comment 'Current lifecycle status of the bond guarantee.' ;
    rdfs:domain ind:BondGuarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:callConditionDescription rdf:type rdf:Property ;
    rdfs:label 'Call Condition Description' ;
    rdfs:comment 'Conditions under which the bond can be called by the obligee.' ;
    rdfs:domain ind:BondGuarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:callDate rdf:type rdf:Property ;
    rdfs:label 'Call Date' ;
    rdfs:comment 'Date when the bond was called, if applicable.' ;
    rdfs:domain ind:BondGuarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:guaranteeNumber rdf:type rdf:Property ;
    rdfs:label 'Guarantee Number' ;
    rdfs:comment 'Unique identifier assigned to the bond guarantee by the issuing surety or bank.' ;
    rdfs:domain ind:BondGuarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guaranteePurpose rdf:type rdf:Property ;
    rdfs:label 'Guarantee Purpose' ;
    rdfs:comment 'Purpose of the bond guarantee within the contract.' ;
    rdfs:domain ind:BondGuarantee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subcontractAgreementId rdf:type rdf:Property ;
    rdfs:label 'Subcontract Agreement Id' ;
    rdfs:comment 'Identifier of the parent/main contract to which this subcontract is linked.' ;
    rdfs:domain ind:Subcontract ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Agreement .

ind:subcontractMainContractAgreementId rdf:type rdf:Property ;
    rdfs:label 'Subcontract Main Contract Agreement Id' ;
    rdfs:comment 'Identifier of the overarching contract under which this subcontract is issued.' ;
    rdfs:domain ind:Subcontract ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Agreement .

ind:completionDate rdf:type rdf:Property ;
    rdfs:label 'Completion Date' ;
    rdfs:comment 'Target date for subcontract completion as per the contract.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contractCategory rdf:type rdf:Property ;
    rdfs:label 'Contract Category' ;
    rdfs:comment 'High-level category of the subcontract agreement (e.g., Engineering Procurement Construction, Guaranteed Maximum Price, Lump-Sum).' ;
    rdfs:domain ind:Subcontract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defectsLiabilityPeriodEnd rdf:type rdf:Property ;
    rdfs:label 'Defects Liability Period End' ;
    rdfs:comment 'Date when the defects liability period expires.' ;
    rdfs:domain ind:Subcontract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:milestoneDescription rdf:type rdf:Property ;
    rdfs:label 'Milestone Description' ;
    rdfs:comment 'Key contractual milestones associated with the subcontract.' ;
    rdfs:domain ind:Subcontract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scopeSummary rdf:type rdf:Property ;
    rdfs:label 'Scope Summary' ;
    rdfs:comment 'Brief textual description of the work scope covered by the subcontract.' ;
    rdfs:domain ind:Subcontract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subcontractNumber rdf:type rdf:Property ;
    rdfs:label 'Subcontract Number' ;
    rdfs:comment 'External contract number or code assigned to the subcontract as defined in the main contract documents.' ;
    rdfs:domain ind:Subcontract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subcontractStatus rdf:type rdf:Property ;
    rdfs:label 'Subcontract Status' ;
    rdfs:comment 'Current lifecycle state of the subcontract.' ;
    rdfs:domain ind:Subcontract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subcontractType rdf:type rdf:Property ;
    rdfs:label 'Subcontract Type' ;
    rdfs:comment 'Classification of the subcontract based on procurement approach (e.g., domestic, nominated, specialist, trade).' ;
    rdfs:domain ind:Subcontract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valueAmount rdf:type rdf:Property ;
    rdfs:label 'Value Amount' ;
    rdfs:comment 'Total monetary value of the subcontract as agreed in the contract.' ;
    rdfs:domain ind:Subcontract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isLatePayment rdf:type rdf:Property ;
    rdfs:label 'Is Late Payment' ;
    rdfs:comment 'True if the actual payment date is later than the due date.' ;
    rdfs:domain ind:SubcontractPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isLdDeductionApplied rdf:type rdf:Property ;
    rdfs:label 'Is Ld Deduction Applied' ;
    rdfs:comment 'True when liquidated damages have been deducted from the payment.' ;
    rdfs:domain ind:SubcontractPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:paymentNumber rdf:type rdf:Property ;
    rdfs:label 'Payment Number' ;
    rdfs:comment 'Business-visible identifier assigned to the payment application (e.g., PAY-2023-00123).' ;
    rdfs:domain ind:SubcontractPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retentionPercent rdf:type rdf:Property ;
    rdfs:label 'Retention Percent' ;
    rdfs:comment 'Retention expressed as a percentage of the gross amount.' ;
    rdfs:domain ind:SubcontractPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:subcontractPaymentStatus rdf:type rdf:Property ;
    rdfs:label 'Subcontract Payment Status' ;
    rdfs:comment 'Current lifecycle state of the payment record.' ;
    rdfs:domain ind:SubcontractPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceAssessmentId rdf:type rdf:Property ;
    rdfs:label 'Compliance Assessment Id' ;
    rdfs:comment 'Foreign key linking to compliance.assessment. Business justification: Contract closeout checklists in construction require a compliance assessment sign-off (environmental audit, regulatory clearance) before the final certificate is issued. Role-prefixed \'compliance_asse' ;
    rdfs:domain ind:Closeout ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Assessment .

ind:finalPaymentCertificateId rdf:type rdf:Property ;
    rdfs:label 'Final Payment Certificate Id' ;
    rdfs:comment 'Foreign key linking to contract.payment_certificate. Business justification: closeout currently stores final_payment_certificate_number as a denormalized STRING. The contract closeout process is formally concluded with the issuance of a Final Payment Certificate (FPC). Adding ' ;
    rdfs:domain ind:Closeout ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PaymentCertificate .

ind:finalVendorInvoiceId rdf:type rdf:Property ;
    rdfs:label 'Final Vendor Invoice Id' ;
    rdfs:comment 'Foreign key linking to procurement.vendor_invoice. Business justification: Contract closeout requires confirmation that the final vendor invoice has been settled. Linking closeout to the final vendor_invoice supports financial closeout, final account reconciliation, and audi' ;
    rdfs:domain ind:Closeout ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VendorInvoice .

ind:practicalCompletionScheduleMilestoneId rdf:type rdf:Property ;
    rdfs:label 'Practical Completion Schedule Milestone Id' ;
    rdfs:comment 'Foreign key linking to schedule.schedule_milestone. Business justification: Contract closeout is triggered by achievement of the practical completion schedule milestone. closeout already references practical_completion_milestone_id (contract domain), but the schedule_mileston' ;
    rdfs:domain ind:Closeout ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ScheduleMilestone .

ind:bondReleaseFlag rdf:type rdf:Property ;
    rdfs:label 'Bond Release Flag' ;
    rdfs:comment 'Indicates whether performance/bid bonds have been released.' ;
    rdfs:domain ind:Closeout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:changeOrderSummary rdf:type rdf:Property ;
    rdfs:label 'Change Order Summary' ;
    rdfs:comment 'Narrative summary of all change orders applied during the project.' ;
    rdfs:domain ind:Closeout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checklistCompletedDate rdf:type rdf:Property ;
    rdfs:label 'Checklist Completed Date' ;
    rdfs:comment 'Date when the closeout checklist was marked as completed.' ;
    rdfs:domain ind:Closeout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:checklistStatus rdf:type rdf:Property ;
    rdfs:label 'Checklist Status' ;
    rdfs:comment 'Progress status of the closeout checklist.' ;
    rdfs:domain ind:Closeout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closeoutNumber rdf:type rdf:Property ;
    rdfs:label 'Closeout Number' ;
    rdfs:comment 'External reference number assigned to the contract closeout process.' ;
    rdfs:domain ind:Closeout ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closeoutStatus rdf:type rdf:Property ;
    rdfs:label 'Closeout Status' ;
    rdfs:comment 'Current lifecycle state of the closeout record.' ;
