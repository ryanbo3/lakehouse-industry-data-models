    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:masterName rdf:type rdf:Property ;
    rdfs:label 'Master Name' ;
    rdfs:comment 'Human-readable name of the material.' ;
    rdfs:domain ind:Master ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialCode rdf:type rdf:Property ;
    rdfs:label 'Material Code' ;
    rdfs:comment 'Enterprise-wide unique code or catalogue number for the material.' ;
