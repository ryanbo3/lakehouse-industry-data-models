    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inventoryManagementSystem rdf:type rdf:Property ;
    rdfs:label 'Inventory Management System' ;
    rdfs:comment 'Name of the downstream system that tracks inventory within this warehouse (e.g., SAP WM, Procore).' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isHazardousMaterialCertified rdf:type rdf:Property ;
    rdfs:label 'Is Hazardous Material Certified' ;
    rdfs:comment 'Indicates whether the warehouse holds a valid hazardous-material storage certification.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nextInspectionDue rdf:type rdf:Property ;
    rdfs:label 'Next Inspection Due' ;
    rdfs:comment 'Planned date for the next required inspection.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:securityLevel rdf:type rdf:Property ;
    rdfs:label 'Security Level' ;
    rdfs:comment 'Overall security classification of the warehouse.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:state rdf:type rdf:Property ;
    rdfs:label 'State' ;
    rdfs:comment 'State or province of the warehouse location.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageZoneDetails rdf:type rdf:Property ;
    rdfs:label 'Storage Zone Details' ;
    rdfs:comment 'Free-form description of internal zones, racks, bins, or yard sections.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureControlled rdf:type rdf:Property ;
    rdfs:label 'Temperature Controlled' ;
    rdfs:comment 'True if the warehouse maintains a controlled temperature environment.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:warehouseCode rdf:type rdf:Property ;
    rdfs:label 'Warehouse Code' ;
    rdfs:comment 'Business-visible alphanumeric code used to reference the warehouse in external systems.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:warehouseDescription rdf:type rdf:Property ;
    rdfs:label 'Warehouse Description' ;
    rdfs:comment 'Narrative description of the warehouse, its purpose, and special characteristics.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:warehouseName rdf:type rdf:Property ;
    rdfs:label 'Warehouse Name' ;
    rdfs:comment 'Human-readable name of the warehouse or laydown yard.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:warehouseStatus rdf:type rdf:Property ;
    rdfs:label 'Warehouse Status' ;
    rdfs:comment 'Current operational status of the warehouse.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:warehouseType rdf:type rdf:Property ;
    rdfs:label 'Warehouse Type' ;
    rdfs:comment 'Classification of the warehouse based on construction and regulatory characteristics.' ;
    rdfs:domain ind:Warehouse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stockLevelId rdf:type rdf:Property ;
    rdfs:label 'Stock Level Id' ;
    rdfs:comment 'System-generated unique identifier for each stock level record.' ;
    rdfs:domain ind:StockLevel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:blockedQuantity rdf:type rdf:Property ;
    rdfs:label 'Blocked Quantity' ;
    rdfs:comment 'Quantity held due to quality issues, holds, or regulatory restrictions.' ;
    rdfs:domain ind:StockLevel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:committedQuantity rdf:type rdf:Property ;
    rdfs:label 'Committed Quantity' ;
    rdfs:comment 'Quantity allocated to specific construction activities or contracts.' ;
    rdfs:domain ind:StockLevel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inTransitQuantity rdf:type rdf:Property ;
    rdfs:label 'In Transit Quantity' ;
    rdfs:comment 'Quantity that has been dispatched but not yet received at the location.' ;
    rdfs:domain ind:StockLevel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastMovementDate rdf:type rdf:Property ;
    rdfs:label 'Last Movement Date' ;
    rdfs:comment 'Date and time of the most recent stock transaction affecting this record.' ;
    rdfs:domain ind:StockLevel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lastMovementType rdf:type rdf:Property ;
    rdfs:label 'Last Movement Type' ;
    rdfs:comment 'Category of the most recent stock transaction.' ;
    rdfs:domain ind:StockLevel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxStockLevel rdf:type rdf:Property ;
    rdfs:label 'Max Stock Level' ;
    rdfs:comment 'Upper threshold for inventory to avoid over-stocking.' ;
    rdfs:domain ind:StockLevel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minStockLevel rdf:type rdf:Property ;
    rdfs:label 'Min Stock Level' ;
    rdfs:comment 'Lowest permissible inventory level before stock is considered understocked.' ;
    rdfs:domain ind:StockLevel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualityInspectionQuantity rdf:type rdf:Property ;
    rdfs:label 'Quality Inspection Quantity' ;
    rdfs:comment 'Quantity currently undergoing quality inspection or testing.' ;
    rdfs:domain ind:StockLevel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityOnHand rdf:type rdf:Property ;
    rdfs:label 'Quantity On Hand' ;
    rdfs:comment 'Total amount of material physically present in the location.' ;
    rdfs:domain ind:StockLevel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reorderPoint rdf:type rdf:Property ;
    rdfs:label 'Reorder Point' ;
    rdfs:comment 'Inventory level that triggers a replenishment request.' ;
    rdfs:domain ind:StockLevel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reservedQuantity rdf:type rdf:Property ;
    rdfs:label 'Reserved Quantity' ;
    rdfs:comment 'Quantity earmarked for pending work packages or purchase orders.' ;
    rdfs:domain ind:StockLevel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:safetyStock rdf:type rdf:Property ;
    rdfs:label 'Safety Stock' ;
    rdfs:comment 'Buffer quantity maintained to protect against demand variability or supply delays.' ;
    rdfs:domain ind:StockLevel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stockLevelStatus rdf:type rdf:Property ;
    rdfs:label 'Stock Level Status' ;
    rdfs:comment 'Current lifecycle status of the stock quantity.' ;
    rdfs:domain ind:StockLevel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierCode rdf:type rdf:Property ;
    rdfs:label 'Supplier Code' ;
    rdfs:comment 'External identifier of the supplier providing the material.' ;
    rdfs:domain ind:Material ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stockMovementId rdf:type rdf:Property ;
    rdfs:label 'Stock Movement Id' ;
    rdfs:comment 'Primary key for stock_movement' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:destinationWarehouseId rdf:type rdf:Property ;
    rdfs:label 'Destination Warehouse Id' ;
    rdfs:comment 'Foreign key linking to material.warehouse. Business justification: stock_movement records the physical destination of received goods using a free-text destination_warehouse_code string. Adding destination_warehouse_id as a proper FK to the warehouse master enables re' ;
    rdfs:domain ind:Material ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Warehouse .

ind:accountingEntryPosted rdf:type rdf:Property ;
    rdfs:label 'Accounting Entry Posted' ;
    rdfs:comment 'True when the financial posting for the receipt has been completed.' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:actualDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Actual Delivery Date' ;
    rdfs:comment 'Date on which the material physically arrived at the site.' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:freightCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Freight Currency Code' ;
    rdfs:comment 'Currency of the freight cost.' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:goodsReceiptType rdf:type rdf:Property ;
    rdfs:label 'Goods Receipt Type' ;
    rdfs:comment 'Indicates whether the receipt is from a purchase, internal transfer, or return.' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCriticalMaterial rdf:type rdf:Property ;
    rdfs:label 'Is Critical Material' ;
    rdfs:comment 'Indicates whether the material is classified as critical for project execution.' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isHazardous rdf:type rdf:Property ;
    rdfs:label 'Is Hazardous' ;
    rdfs:comment 'True if the material is hazardous and subject to special handling.' ;
    rdfs:domain ind:Material ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:netAmount rdf:type rdf:Property ;
    rdfs:label 'Net Amount' ;
    rdfs:comment 'Net monetary value after tax and any discounts.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityReceived rdf:type rdf:Property ;
    rdfs:label 'Quantity Received' ;
    rdfs:comment 'Amount of material physically received, expressed in the unit of measure.' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:receiptNumber rdf:type rdf:Property ;
    rdfs:label 'Receipt Number' ;
    rdfs:comment 'Business-visible identifier assigned to the receipt (e.g., GR-2023-000123).' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receiptStatus rdf:type rdf:Property ;
    rdfs:label 'Receipt Status' ;
    rdfs:comment 'Overall processing status of the goods receipt.' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceWarehouseCode rdf:type rdf:Property ;
    rdfs:label 'Source Warehouse Code' ;
    rdfs:comment 'Code of the warehouse or location from which the material originated.' ;
    rdfs:domain ind:StockMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requisitionId rdf:type rdf:Property ;
    rdfs:label 'Requisition Id' ;
    rdfs:comment 'Foreign key linking to material.requisition. Business justification: A goods_issue (material issued from warehouse to a WBS/cost center) is typically triggered by a material requisition. Linking goods_issue.requisition_id -> requisition establishes the fulfillment trac' ;
    rdfs:domain ind:Material ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Requisition .

ind:returnIssueGoodsIssueId rdf:type rdf:Property ;
    rdfs:label 'Return Issue Goods Issue Id' ;
    rdfs:comment 'Identifier of the goods issue record that reverses this transaction, if any.' ;
    rdfs:domain ind:GoodsIssue ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GoodsIssue .

ind:complianceFlag rdf:type rdf:Property ;
    rdfs:label 'Compliance Flag' ;
    rdfs:comment 'Indicates whether the issued material complies with project specifications and safety standards.' ;
    rdfs:domain ind:GoodsIssue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:goodsIssueStatus rdf:type rdf:Property ;
    rdfs:label 'Goods Issue Status' ;
    rdfs:comment 'Current processing state of the goods issue record.' ;
    rdfs:domain ind:GoodsIssue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazardClassification rdf:type rdf:Property ;
    rdfs:label 'Hazard Classification' ;
    rdfs:comment 'Safety classification of the material for handling and storage.' ;
    rdfs:domain ind:Material ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionRequired rdf:type rdf:Property ;
    rdfs:label 'Inspection Required' ;
    rdfs:comment 'True if a post-issue inspection is mandated for the material.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inspectionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Inspection Timestamp' ;
    rdfs:comment 'Date and time when the inspection was performed.' ;
    rdfs:domain ind:GoodsIssue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:isReturned rdf:type rdf:Property ;
    rdfs:label 'Is Returned' ;
    rdfs:comment 'Indicates whether the issued material was later returned to inventory.' ;
    rdfs:domain ind:GoodsIssue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:issueNumber rdf:type rdf:Property ;
    rdfs:label 'Issue Number' ;
    rdfs:comment 'External reference number assigned to the goods issue for tracking and reconciliation.' ;
    rdfs:domain ind:GoodsIssue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issueReason rdf:type rdf:Property ;
    rdfs:label 'Issue Reason' ;
    rdfs:comment 'Business reason for issuing the material.' ;
    rdfs:domain ind:GoodsIssue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issueTimestamp rdf:type rdf:Property ;
    rdfs:label 'Issue Timestamp' ;
    rdfs:comment 'Date and time when the material was physically issued from inventory.' ;
    rdfs:domain ind:GoodsIssue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:stockTransferId rdf:type rdf:Property ;
    rdfs:label 'Stock Transfer Id' ;
    rdfs:comment 'System-generated unique identifier for the stock transfer transaction.' ;
    rdfs:domain ind:StockTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sourceWarehouseId rdf:type rdf:Property ;
    rdfs:label 'Source Warehouse Id' ;
    rdfs:comment 'Identifier of the warehouse or storage location from which the material is transferred.' ;
    rdfs:domain ind:StockTransfer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Warehouse .

ind:expectedArrivalDate rdf:type rdf:Property ;
    rdfs:label 'Expected Arrival Date' ;
    rdfs:comment 'Planned date on which the material is expected to arrive at the destination.' ;
    rdfs:domain ind:StockTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:stockTransferStatus rdf:type rdf:Property ;
    rdfs:label 'Stock Transfer Status' ;
    rdfs:comment 'Current lifecycle state of the stock transfer (e.g., draft, planned, in-transit, completed, cancelled).' ;
    rdfs:domain ind:StockTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferNumber rdf:type rdf:Property ;
    rdfs:label 'Transfer Number' ;
    rdfs:comment 'Human-readable reference number assigned to the stock transfer for tracking and communication.' ;
    rdfs:domain ind:StockTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferReason rdf:type rdf:Property ;
    rdfs:label 'Transfer Reason' ;
    rdfs:comment 'Business reason for the material movement, such as site reallocation or surplus return.' ;
    rdfs:domain ind:StockTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferTimestamp rdf:type rdf:Property ;
    rdfs:label 'Transfer Timestamp' ;
    rdfs:comment 'Date and time when the material movement was initiated or recorded.' ;
    rdfs:domain ind:StockTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:transportMode rdf:type rdf:Property ;
    rdfs:label 'Transport Mode' ;
    rdfs:comment 'Mode of transportation used for the transfer.' ;
    rdfs:domain ind:StockTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractQuantity rdf:type rdf:Property ;
    rdfs:label 'Contract Quantity' ;
    rdfs:comment 'Quantity of the material that is contractually committed in the BOQ.' ;
    rdfs:domain ind:MaterialBoqLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isChangeOrder rdf:type rdf:Property ;
    rdfs:label 'Is Change Order' ;
    rdfs:comment 'Indicates whether this line originates from a change order (true) or the original BOQ (false).' ;
    rdfs:domain ind:MaterialBoqLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:materialBoqLineStatus rdf:type rdf:Property ;
    rdfs:label 'Material Boq Line Status' ;
    rdfs:comment 'Current lifecycle status of the BOQ line.' ;
    rdfs:domain ind:MaterialBoqLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualReceivedDate rdf:type rdf:Property ;
    rdfs:label 'Actual Received Date' ;
    rdfs:comment 'Date when the material was received on site.' ;
    rdfs:domain ind:MtoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actualReceivedQuantity rdf:type rdf:Property ;
    rdfs:label 'Actual Received Quantity' ;
    rdfs:comment 'Quantity of material actually received on site.' ;
    rdfs:domain ind:MtoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:complianceCertification rdf:type rdf:Property ;
    rdfs:label 'Compliance Certification' ;
    rdfs:comment 'Applicable certification or standard (e.g., ISO9001, ASTM) that the material meets.' ;
    rdfs:domain ind:MtoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:designQuantity rdf:type rdf:Property ;
    rdfs:label 'Design Quantity' ;
    rdfs:comment 'Quantity of the material calculated from design drawings or BIM models.' ;
    rdfs:domain ind:MtoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedUnitPrice rdf:type rdf:Property ;
    rdfs:label 'Estimated Unit Price' ;
    rdfs:comment 'Estimated cost per unit of material for procurement planning.' ;
    rdfs:domain ind:MtoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mtoStatus rdf:type rdf:Property ;
    rdfs:label 'Mto Status' ;
    rdfs:comment 'Current lifecycle status of the MTO line.' ;
    rdfs:domain ind:MtoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netRequiredQuantity rdf:type rdf:Property ;
    rdfs:label 'Net Required Quantity' ;
    rdfs:comment 'Total material quantity required after applying wastage factor.' ;
    rdfs:domain ind:MtoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:procurementStatus rdf:type rdf:Property ;
    rdfs:label 'Procurement Status' ;
    rdfs:comment 'Current status of the procurement process for this material line.' ;
    rdfs:domain ind:MtoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityUomFactor rdf:type rdf:Property ;
    rdfs:label 'Quantity Uom Factor' ;
    rdfs:comment 'Factor to convert between alternative units of measure for the material.' ;
    rdfs:domain ind:MtoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:requiredByDate rdf:type rdf:Property ;
    rdfs:label 'Required By Date' ;
    rdfs:comment 'Date by which the material must be on site to meet construction schedule.' ;
    rdfs:domain ind:Material ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:safetyDataSheetUrl rdf:type rdf:Property ;
    rdfs:label 'Safety Data Sheet Url' ;
    rdfs:comment 'Link to the safety data sheet document for the material.' ;
    rdfs:domain ind:Material ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supplierPreferred rdf:type rdf:Property ;
    rdfs:label 'Supplier Preferred' ;
    rdfs:comment 'Name or identifier of the preferred supplier for this material.' ;
    rdfs:domain ind:MtoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:varianceCost rdf:type rdf:Property ;
    rdfs:label 'Variance Cost' ;
    rdfs:comment 'Difference between total_estimated_cost and actual cost incurred.' ;
    rdfs:domain ind:MtoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceQuantity rdf:type rdf:Property ;
    rdfs:label 'Variance Quantity' ;
    rdfs:comment 'Difference between net_required_quantity and actual_received_quantity.' ;
    rdfs:domain ind:MtoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wastageFactor rdf:type rdf:Property ;
    rdfs:label 'Wastage Factor' ;
    rdfs:comment 'Percentage factor applied to account for material loss during construction.' ;
    rdfs:domain ind:MtoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:requestedByCraftWorkerId rdf:type rdf:Property ;
    rdfs:label 'Requested By Craft Worker Id' ;
    rdfs:comment 'Foreign key linking to workforce.craft_worker. Business justification: Material requisitions in construction are raised by craft foremen (craft workers with supervisory_role_flag=true) who identify site material needs. Tracking the requesting craft worker is required for' ;
    rdfs:domain ind:Requisition ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CraftWorker .

ind:costEstimateGross rdf:type rdf:Property ;
    rdfs:label 'Cost Estimate Gross' ;
    rdfs:comment 'Projected total cost of the requested material before taxes and discounts.' ;
    rdfs:domain ind:Requisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costEstimateNet rdf:type rdf:Property ;
    rdfs:label 'Cost Estimate Net' ;
    rdfs:comment 'Projected net cost after tax and any discounts.' ;
    rdfs:domain ind:Requisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costEstimateTax rdf:type rdf:Property ;
    rdfs:label 'Cost Estimate Tax' ;
    rdfs:comment 'Estimated tax component applicable to the material cost.' ;
    rdfs:domain ind:Requisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fulfillmentDate rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Date' ;
    rdfs:comment 'Date on which the material was actually issued to the site or received from a supplier.' ;
    rdfs:domain ind:Requisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fulfillmentStatus rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Status' ;
    rdfs:comment 'Progress state of the material issue or purchase fulfillment.' ;
    rdfs:domain ind:Requisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isEmergency rdf:type rdf:Property ;
    rdfs:label 'Is Emergency' ;
    rdfs:comment 'Indicates whether the requisition is an emergency (e.g., safety-critical) request.' ;
    rdfs:domain ind:Requisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isStockAvailable rdf:type rdf:Property ;
    rdfs:label 'Is Stock Available' ;
    rdfs:comment 'Indicates whether the requested material is currently available in warehouse inventory.' ;
    rdfs:domain ind:Requisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:justification rdf:type rdf:Property ;
    rdfs:label 'Justification' ;
    rdfs:comment 'Narrative explanation for why the material is needed, supporting approval decisions.' ;
    rdfs:domain ind:Requisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestTimestamp rdf:type rdf:Property ;
    rdfs:label 'Request Timestamp' ;
    rdfs:comment 'Date-time when the requisition was initially submitted by the site team.' ;
    rdfs:domain ind:Requisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:requisitionNumber rdf:type rdf:Property ;
    rdfs:label 'Requisition Number' ;
    rdfs:comment 'External business identifier assigned to the requisition (e.g., RQ-2024-00123).' ;
    rdfs:domain ind:Requisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requisitionStatus rdf:type rdf:Property ;
    rdfs:label 'Requisition Status' ;
    rdfs:comment 'Current lifecycle state of the requisition.' ;
    rdfs:domain ind:Requisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyReviewStatus rdf:type rdf:Property ;
    rdfs:label 'Safety Review Status' ;
    rdfs:comment 'Result of the safety compliance review required for certain hazardous materials.' ;
    rdfs:domain ind:Requisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableProjectType rdf:type rdf:Property ;
    rdfs:label 'Applicable Project Type' ;
    rdfs:comment 'Project categories where this specification may be applied.' ;
    rdfs:domain ind:Specification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceRequirements rdf:type rdf:Property ;
    rdfs:label 'Compliance Requirements' ;
    rdfs:comment 'Textual description of regulatory or client compliance requirements tied to the specification.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:handlingInstructions rdf:type rdf:Property ;
    rdfs:label 'Handling Instructions' ;
    rdfs:comment 'Guidelines for safe handling and transport of the material.' ;
    rdfs:domain ind:Specification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isDefault rdf:type rdf:Property ;
    rdfs:label 'Is Default' ;
    rdfs:comment 'Flag indicating whether this specification is the default for its material type.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:materialCategory rdf:type rdf:Property ;
    rdfs:label 'Material Category' ;
    rdfs:comment 'High-level category of the material (e.g., concrete, steel, MEP).' ;
    rdfs:domain ind:Specification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minCompressiveStrengthMpa rdf:type rdf:Property ;
    rdfs:label 'Min Compressive Strength Mpa' ;
    rdfs:comment 'Minimum compressive strength required for the material, expressed in megapascal.' ;
    rdfs:domain ind:Specification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minModulusOfElasticityGpa rdf:type rdf:Property ;
    rdfs:label 'Min Modulus Of Elasticity Gpa' ;
    rdfs:comment 'Minimum modulus of elasticity required, expressed in gigapascal.' ;
    rdfs:domain ind:Specification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minTensileStrengthMpa rdf:type rdf:Property ;
    rdfs:label 'Min Tensile Strength Mpa' ;
    rdfs:comment 'Minimum tensile strength required for the material, expressed in megapascal.' ;
    rdfs:domain ind:Specification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minYieldStrengthMpa rdf:type rdf:Property ;
    rdfs:label 'Min Yield Strength Mpa' ;
    rdfs:comment 'Minimum yield strength required for the material, expressed in megapascal.' ;
    rdfs:domain ind:Specification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:specificationCode rdf:type rdf:Property ;
    rdfs:label 'Specification Code' ;
    rdfs:comment 'Business identifier code assigned to the specification (e.g., SPEC-00123).' ;
    rdfs:domain ind:Specification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specificationDescription rdf:type rdf:Property ;
    rdfs:label 'Specification Description' ;
    rdfs:comment 'Detailed textual description of the specification purpose, scope, and application.' ;
    rdfs:domain ind:Specification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specificationName rdf:type rdf:Property ;
    rdfs:label 'Specification Name' ;
    rdfs:comment 'Human-readable name of the material specification.' ;
    rdfs:domain ind:Specification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specificationStatus rdf:type rdf:Property ;
    rdfs:label 'Specification Status' ;
    rdfs:comment 'Current lifecycle status of the specification.' ;
    rdfs:domain ind:Specification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardCode rdf:type rdf:Property ;
    rdfs:label 'Standard Code' ;
    rdfs:comment 'Specific standard code (e.g., ASTM C150, ISO 9001).' ;
    rdfs:domain ind:Specification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardReference rdf:type rdf:Property ;
    rdfs:label 'Standard Reference' ;
    rdfs:comment 'Reference to the governing standard body (e.g., ASTM, ISO, BS, ACI).' ;
    rdfs:domain ind:Specification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:substituteSpecificationCode rdf:type rdf:Property ;
    rdfs:label 'Substitute Specification Code' ;
    rdfs:comment 'Code of an alternative specification that can be used in place of this one.' ;
    rdfs:domain ind:Specification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:warrantyConditions rdf:type rdf:Property ;
    rdfs:label 'Warranty Conditions' ;
    rdfs:comment 'Specific conditions or exclusions that apply to the warranty.' ;
    rdfs:domain ind:Specification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wastageId rdf:type rdf:Property ;
    rdfs:label 'Wastage Id' ;
    rdfs:comment 'Primary key for wastage' ;
    rdfs:domain ind:Wastage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualQuantityConsumed rdf:type rdf:Property ;
    rdfs:label 'Actual Quantity Consumed' ;
    rdfs:comment 'Quantity of material actually used in the activity.' ;
    rdfs:domain ind:Wastage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cause rdf:type rdf:Property ;
    rdfs:label 'Cause' ;
    rdfs:comment 'Root cause of the material wastage.' ;
    rdfs:domain ind:Wastage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disposalLocation rdf:type rdf:Property ;
    rdfs:label 'Disposal Location' ;
    rdfs:comment 'Physical location where the waste was disposed or processed.' ;
    rdfs:domain ind:Wastage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isRecyclable rdf:type rdf:Property ;
    rdfs:label 'Is Recyclable' ;
    rdfs:comment 'Flag indicating whether the waste material is recyclable.' ;
    rdfs:domain ind:Wastage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reportingPeriod rdf:type rdf:Property ;
    rdfs:label 'Reporting Period' ;
    rdfs:comment 'Period (e.g., YYYY-MM) for which the waste is reported.' ;
    rdfs:domain ind:Wastage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wastageDate rdf:type rdf:Property ;
    rdfs:label 'Wastage Date' ;
    rdfs:comment 'Date on which the material wastage event occurred.' ;
    rdfs:domain ind:Wastage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:wastageStatus rdf:type rdf:Property ;
    rdfs:label 'Wastage Status' ;
    rdfs:comment 'Current lifecycle status of the wastage record.' ;
    rdfs:domain ind:Wastage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wasteCostAdjustment rdf:type rdf:Property ;
    rdfs:label 'Waste Cost Adjustment' ;
    rdfs:comment 'Adjustments (e.g., rebates, penalties) applied to the gross waste cost.' ;
    rdfs:domain ind:Wastage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wasteCostGross rdf:type rdf:Property ;
    rdfs:label 'Waste Cost Gross' ;
    rdfs:comment 'Total cost associated with the waste before any adjustments.' ;
    rdfs:domain ind:Wastage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wasteCostNet rdf:type rdf:Property ;
    rdfs:label 'Waste Cost Net' ;
    rdfs:comment 'Net cost after adjustments, representing the financial impact of the waste.' ;
    rdfs:domain ind:Wastage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wasteRecordNumber rdf:type rdf:Property ;
    rdfs:label 'Waste Record Number' ;
    rdfs:comment 'Human-readable identifier assigned to the wastage entry for tracking and reference.' ;
    rdfs:domain ind:Wastage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wasteType rdf:type rdf:Property ;
    rdfs:label 'Waste Type' ;
    rdfs:comment 'Category of material that was wasted.' ;
    rdfs:domain ind:Wastage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleCalendarId rdf:type rdf:Property ;
    rdfs:label 'Schedule Calendar Id' ;
    rdfs:comment 'Identifier of the calendar to which the activity is assigned.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ScheduleCalendar .

ind:activityCode rdf:type rdf:Property ;
    rdfs:label 'Activity Code' ;
    rdfs:comment 'Business identifier code assigned to the activity (e.g., unique activity number).' ;
    rdfs:domain ind:Activity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:activityName rdf:type rdf:Property ;
    rdfs:label 'Activity Name' ;
    rdfs:comment 'Human-readable name or title of the activity.' ;
    rdfs:domain ind:Activity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:activityStatus rdf:type rdf:Property ;
    rdfs:label 'Activity Status' ;
    rdfs:comment 'Current lifecycle status of the activity.' ;
    rdfs:domain ind:Activity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:constraintDate rdf:type rdf:Property ;
    rdfs:label 'Constraint Date' ;
    rdfs:comment 'Date associated with the scheduling constraint, if applicable.' ;
    rdfs:domain ind:Activity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:constraintType rdf:type rdf:Property ;
    rdfs:label 'Constraint Type' ;
    rdfs:comment 'Scheduling constraint applied to the activity.' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:freeFloatDays rdf:type rdf:Property ;
    rdfs:label 'Free Float Days' ;
    rdfs:comment 'Free float available for the activity in days.' ;
    rdfs:domain ind:Activity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:originalDurationDays rdf:type rdf:Property ;
    rdfs:label 'Original Duration Days' ;
    rdfs:comment 'Planned duration of the activity in calendar days at creation.' ;
    rdfs:domain ind:Activity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:remainingDurationDays rdf:type rdf:Property ;
    rdfs:label 'Remaining Duration Days' ;
    rdfs:comment 'Remaining duration in days based on current progress.' ;
    rdfs:domain ind:Activity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:activityRelationshipId rdf:type rdf:Property ;
    rdfs:label 'Activity Relationship Id' ;
    rdfs:comment 'System-generated unique identifier for the activity relationship record.' ;
    rdfs:domain ind:ActivityRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryPredecessorActivityId rdf:type rdf:Property ;
    rdfs:label 'Primary Predecessor Activity Id' ;
    rdfs:comment 'Identifier of the predecessor activity in the CPM network.' ;
    rdfs:domain ind:ActivityRelationship ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Activity .

ind:activityRelationshipDescription rdf:type rdf:Property ;
    rdfs:label 'Activity Relationship Description' ;
    rdfs:comment 'Free-text notes or comments describing the purpose or special conditions of the relationship.' ;
    rdfs:domain ind:ActivityRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:activityRelationshipStatus rdf:type rdf:Property ;
    rdfs:label 'Activity Relationship Status' ;
    rdfs:comment 'Current lifecycle status of the relationship record.' ;
    rdfs:domain ind:ActivityRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isDriving rdf:type rdf:Property ;
    rdfs:label 'Is Driving' ;
    rdfs:comment 'Flag indicating whether this relationship drives the schedule logic (true) or is a passive link (false).' ;
    rdfs:domain ind:ActivityRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lagDuration rdf:type rdf:Property ;
    rdfs:label 'Lag Duration' ;
    rdfs:comment 'Numeric amount of lag (or lead if negative) applied to the relationship, expressed in the units defined by lag_time_unit.' ;
    rdfs:domain ind:ActivityRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lagTimeUnit rdf:type rdf:Property ;
    rdfs:label 'Lag Time Unit' ;
    rdfs:comment 'Unit of measure for lag_duration (e.g., days, hours, minutes).' ;
    rdfs:domain ind:ActivityRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipSource rdf:type rdf:Property ;
    rdfs:label 'Relationship Source' ;
    rdfs:comment 'Origin of the relationship record: exported from scheduling tool or entered manually.' ;
    rdfs:domain ind:ActivityRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipType rdf:type rdf:Property ;
    rdfs:label 'Relationship Type' ;
    rdfs:comment 'Logical dependency type defining how the predecessor and successor activities are linked.' ;
    rdfs:domain ind:ActivityRelationship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bcwsAmount rdf:type rdf:Property ;
    rdfs:label 'Bcws Amount' ;
    rdfs:comment 'Monetary value of work scheduled in the baseline, used for Earned Value calculations.' ;
    rdfs:domain ind:ScheduleBaseline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isCurrent rdf:type rdf:Property ;
    rdfs:label 'Is Current' ;
    rdfs:comment 'Indicates whether this baseline is the active baseline for schedule comparisons.' ;
    rdfs:domain ind:ScheduleBaseline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scheduleBaselineDescription rdf:type rdf:Property ;
    rdfs:label 'Schedule Baseline Description' ;
    rdfs:comment 'Free-form text describing the purpose, scope, or notable characteristics of the baseline.' ;
    rdfs:domain ind:ScheduleBaseline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleBaselineName rdf:type rdf:Property ;
    rdfs:label 'Schedule Baseline Name' ;
    rdfs:comment 'Human-readable name given to the schedule baseline (e.g., "Original Contract Baseline").' ;
    rdfs:domain ind:ScheduleBaseline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleBaselineStatus rdf:type rdf:Property ;
    rdfs:label 'Schedule Baseline Status' ;
    rdfs:comment 'Current lifecycle state of the baseline record.' ;
    rdfs:domain ind:ScheduleBaseline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleToolProjectRef rdf:type rdf:Property ;
    rdfs:label 'Schedule Tool Project Ref' ;
    rdfs:comment 'External identifier of the project within the scheduling tool (e.g., Primavera project code).' ;
    rdfs:domain ind:ScheduleBaseline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalDurationDays rdf:type rdf:Property ;
    rdfs:label 'Total Duration Days' ;
    rdfs:comment 'Calculated total duration of the baseline in calendar days.' ;
    rdfs:domain ind:ScheduleBaseline ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:baselineActivityId rdf:type rdf:Property ;
    rdfs:label 'Baseline Activity Id' ;
    rdfs:comment 'Unique surrogate key for the baseline activity record.' ;
    rdfs:domain ind:BaselineActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:baselineActivityStatus rdf:type rdf:Property ;
    rdfs:label 'Baseline Activity Status' ;
    rdfs:comment 'Current lifecycle status of the activity within the baseline.' ;
    rdfs:domain ind:BaselineActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baselineConstraintDate rdf:type rdf:Property ;
    rdfs:label 'Baseline Constraint Date' ;
    rdfs:comment 'Date associated with the constraint type, if applicable.' ;
    rdfs:domain ind:BaselineActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:baselineConstraintType rdf:type rdf:Property ;
    rdfs:label 'Baseline Constraint Type' ;
    rdfs:comment 'Scheduling constraint applied to the activity in the baseline.' ;
    rdfs:domain ind:BaselineActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baselineCostVariance rdf:type rdf:Property ;
    rdfs:label 'Baseline Cost Variance' ;
    rdfs:comment 'Difference between actual cost incurred and baseline cost estimate.' ;
    rdfs:domain ind:BaselineActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:baselineEarlyFinish rdf:type rdf:Property ;
    rdfs:label 'Baseline Early Finish' ;
    rdfs:comment 'Earliest possible finish date for the activity in the approved baseline.' ;
    rdfs:domain ind:BaselineActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:baselineEarlyStart rdf:type rdf:Property ;
    rdfs:label 'Baseline Early Start' ;
    rdfs:comment 'Earliest possible start date for the activity in the approved baseline.' ;
    rdfs:domain ind:BaselineActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:baselineIsCritical rdf:type rdf:Property ;
    rdfs:label 'Baseline Is Critical' ;
    rdfs:comment 'True if the activity lies on the critical path of the baseline schedule.' ;
    rdfs:domain ind:BaselineActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:baselineLateFinish rdf:type rdf:Property ;
    rdfs:label 'Baseline Late Finish' ;
    rdfs:comment 'Latest permissible finish date for the activity in the approved baseline.' ;
    rdfs:domain ind:BaselineActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:baselineLateStart rdf:type rdf:Property ;
    rdfs:label 'Baseline Late Start' ;
    rdfs:comment 'Latest permissible start date for the activity in the approved baseline.' ;
    rdfs:domain ind:BaselineActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:baselineMilestoneFlag rdf:type rdf:Property ;
    rdfs:label 'Baseline Milestone Flag' ;
    rdfs:comment 'Indicates whether the activity is defined as a milestone in the baseline.' ;
    rdfs:domain ind:BaselineActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:baselineOriginalDuration rdf:type rdf:Property ;
    rdfs:label 'Baseline Original Duration' ;
    rdfs:comment 'Planned duration of the activity at baseline approval, expressed in whole days.' ;
    rdfs:domain ind:BaselineActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:baselinePercentComplete rdf:type rdf:Property ;
    rdfs:label 'Baseline Percent Complete' ;
    rdfs:comment 'Planned percentage of work completed for the activity at the baseline snapshot.' ;
    rdfs:domain ind:BaselineActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:baselineRemainingDuration rdf:type rdf:Property ;
    rdfs:label 'Baseline Remaining Duration' ;
    rdfs:comment 'Remaining planned duration as of the latest progress update, based on the baseline.' ;
    rdfs:domain ind:BaselineActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:baselineResourceType rdf:type rdf:Property ;
    rdfs:label 'Baseline Resource Type' ;
    rdfs:comment 'Category of resources assigned to the activity in the baseline.' ;
    rdfs:domain ind:BaselineActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baselineResourceUnits rdf:type rdf:Property ;
    rdfs:label 'Baseline Resource Units' ;
    rdfs:comment 'Total resource units (e.g., labor hours, equipment hours) planned for the activity in the baseline.' ;
    rdfs:domain ind:BaselineActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:baselineScheduleVariance rdf:type rdf:Property ;
    rdfs:label 'Baseline Schedule Variance' ;
    rdfs:comment 'Difference between actual start/finish and baseline dates, expressed in days.' ;
    rdfs:domain ind:BaselineActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:baselineTotalFloat rdf:type rdf:Property ;
    rdfs:label 'Baseline Total Float' ;
    rdfs:comment 'Amount of scheduling flexibility (float) for the activity in the baseline, expressed in days.' ;
    rdfs:domain ind:BaselineActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:availabilityPercentage rdf:type rdf:Property ;
    rdfs:label 'Availability Percentage' ;
    rdfs:comment 'Planned availability of the resource expressed as a percent of total time.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:billingRatePerHour rdf:type rdf:Property ;
    rdfs:label 'Billing Rate Per Hour' ;
    rdfs:comment 'Rate used for billing external parties for labor resources.' ;
    rdfs:domain ind:Resource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:certificationRequirements rdf:type rdf:Property ;
    rdfs:label 'Certification Requirements' ;
    rdfs:comment 'Required certifications or trainings for the resource (e.g., OSHA, LEED).' ;
    rdfs:domain ind:Resource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenter rdf:type rdf:Property ;
    rdfs:label 'Cost Center' ;
    rdfs:comment 'Organizational cost centre responsible for the resource.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defaultUnitsPerTime rdf:type rdf:Property ;
    rdfs:label 'Default Units Per Time' ;
    rdfs:comment 'Default allocation quantity when the resource is assigned without explicit units.' ;
    rdfs:domain ind:Resource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:depreciationRate rdf:type rdf:Property ;
    rdfs:label 'Depreciation Rate' ;
    rdfs:comment 'Annual depreciation rate expressed as a percentage.' ;
    rdfs:domain ind:Resource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:environmentalImpactScore rdf:type rdf:Property ;
    rdfs:label 'Environmental Impact Score' ;
    rdfs:comment 'Score reflecting the resource\'s environmental impact (e.g., emissions, waste).' ;
    rdfs:domain ind:Resource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isExternal rdf:type rdf:Property ;
    rdfs:label 'Is External' ;
    rdfs:comment 'True if the resource is provided by an external subcontractor or supplier.' ;
    rdfs:domain ind:Construction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isOvertimeAllowed rdf:type rdf:Property ;
    rdfs:label 'Is Overtime Allowed' ;
    rdfs:comment 'Indicates whether overtime work is permitted for this resource.' ;
    rdfs:domain ind:Resource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:laborCategory rdf:type rdf:Property ;
    rdfs:label 'Labor Category' ;
    rdfs:comment 'Category of labor (e.g., skilled, unskilled, supervisory).' ;
    rdfs:domain ind:Schedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastUsedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Used Timestamp' ;
    rdfs:comment 'Date-time when the resource was last assigned to an activity.' ;
    rdfs:domain ind:Resource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:maxConcurrentAssignments rdf:type rdf:Property ;
    rdfs:label 'Max Concurrent Assignments' ;
    rdfs:comment 'Maximum number of activities the resource can be assigned to simultaneously.' ;
    rdfs:domain ind:Resource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maxUnitsPerPeriod rdf:type rdf:Property ;
    rdfs:label 'Max Units Per Period' ;
    rdfs:comment 'Maximum quantity of the resource that can be allocated in a scheduling period.' ;
    rdfs:domain ind:Resource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overtimeFactor rdf:type rdf:Property ;
    rdfs:label 'Overtime Factor' ;
    rdfs:comment 'Multiplier applied to the price when the resource works overtime.' ;
    rdfs:domain ind:Resource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pricePerUnit rdf:type rdf:Property ;
    rdfs:label 'Price Per Unit' ;
    rdfs:comment 'Cost charged for one unit of the resource, used for cost-loaded schedules.' ;
    rdfs:domain ind:Resource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:procurementSource rdf:type rdf:Property ;
    rdfs:label 'Procurement Source' ;
    rdfs:comment 'Indicates whether the resource is sourced internally or from an external vendor.' ;
    rdfs:domain ind:Resource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resourceCode rdf:type rdf:Property ;
