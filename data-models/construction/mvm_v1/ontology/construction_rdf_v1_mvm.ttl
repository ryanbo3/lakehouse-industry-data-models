    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:projectStartDate rdf:type rdf:Property ;
    rdfs:label 'Project Start Date' ;
    rdfs:comment 'Planned start date of the construction project.' ;
    rdfs:domain ind:Tender ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryApprovalRequired rdf:type rdf:Property ;
