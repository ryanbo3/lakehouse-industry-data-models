    rdfs:comment 'Net asset classification under FASB ASC 958 for private institutions (with or without donor restrictions).' ;
    rdfs:domain ind:InvestmentPool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fiscalYearEndMonth rdf:type rdf:Property ;
    rdfs:label 'Fiscal Year End Month' ;
    rdfs:comment 'Month number (1-12) representing the fiscal year end for reporting purposes for this pool.' ;
    rdfs:domain ind:InvestmentPool ;
