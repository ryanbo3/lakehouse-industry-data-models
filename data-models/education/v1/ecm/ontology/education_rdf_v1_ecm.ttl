    rdfs:range xsd:integer .

ind:gasbFundType rdf:type rdf:Property ;
    rdfs:label 'Gasb Fund Type' ;
    rdfs:comment 'Fund type classification under GASB standards for public institutions.' ;
    rdfs:domain ind:InvestmentPool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:generalLedgerAccount rdf:type rdf:Property ;
