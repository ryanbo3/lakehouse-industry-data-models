    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:benchmarkIndex rdf:type rdf:Property ;
    rdfs:label 'Benchmark Index' ;
    rdfs:comment 'Primary market index or composite benchmark used to evaluate pool performance (e.g., S&P 500, MSCI World).' ;
