ind:finalPaymentDate rdf:type rdf:Property ;
    rdfs:label 'Final Payment Date' ;
    rdfs:comment 'Scheduled date for the last payment installment, marking the expected fulfillment of the gift commitment.' ;
    rdfs:domain ind:GiftAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:firstPaymentDate rdf:type rdf:Property ;
    rdfs:label 'First Payment Date' ;
    rdfs:comment 'Scheduled date for the initial payment installment under this gift agreement.' ;
    rdfs:domain ind:GiftAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:giftValuationDate rdf:type rdf:Property ;
