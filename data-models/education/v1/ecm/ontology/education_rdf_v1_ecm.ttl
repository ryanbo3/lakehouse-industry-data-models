ind:gradeAppealCaseId rdf:type rdf:Property ;
    rdfs:label 'Grade Appeal Case Id' ;
    rdfs:comment 'Primary key for grade_appeal_case' ;
    rdfs:domain ind:GradeAppealCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:relatedAcademicIntegrityCaseConductCaseId rdf:type rdf:Property ;
    rdfs:label 'Related Academic Integrity Case Conduct Case Id' ;
    rdfs:comment 'Identifier of a related academic integrity case if the grade appeal is connected to or resulted from an academic misconduct finding.' ;
    rdfs:domain ind:GradeAppealCase ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ConductCase .

ind:appealCaseNumber rdf:type rdf:Property ;
    rdfs:label 'Appeal Case Number' ;
    rdfs:comment 'Human-readable business identifier for the grade appeal case, typically formatted with prefix and sequential number for external reference and tracking.' ;
    rdfs:domain ind:GradeAppealCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appealFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Appeal Fee Amount' ;
    rdfs:comment 'Monetary fee charged to the student for filing the grade appeal, if applicable per institutional policy. Amount in institutional currency.' ;
    rdfs:domain ind:GradeAppealCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:appealFeePaid rdf:type rdf:Property ;
    rdfs:label 'Appeal Fee Paid' ;
    rdfs:comment 'Indicates whether the required appeal fee has been paid by the student.' ;
    rdfs:domain ind:GradeAppealCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:appealFeeWaived rdf:type rdf:Property ;
    rdfs:label 'Appeal Fee Waived' ;
    rdfs:comment 'Indicates whether the appeal fee was waived due to financial hardship or other institutional policy considerations.' ;
    rdfs:domain ind:GradeAppealCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:departmentRecommendation rdf:type rdf:Property ;
    rdfs:label 'Department Recommendation' ;
    rdfs:comment 'Recommendation provided by the academic department regarding the appeal, typically from the department chair or designated review committee.' ;
    rdfs:domain ind:GradeAppealCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationCount rdf:type rdf:Property ;
    rdfs:label 'Escalation Count' ;
    rdfs:comment 'Number of times the appeal has been escalated to a higher review level after an unfavorable decision at a lower level.' ;
    rdfs:domain ind:GradeAppealCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:gradeChangeEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Grade Change Effective Date' ;
    rdfs:comment 'Date on which the grade change becomes effective in the student\'s academic record, if the appeal is approved.' ;
    rdfs:domain ind:GradeAppealCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:hearingScheduledDate rdf:type rdf:Property ;
    rdfs:label 'Hearing Scheduled Date' ;
    rdfs:comment 'Date on which a formal hearing or review meeting is scheduled for the grade appeal case, if applicable based on appeal type and institutional policy.' ;
    rdfs:domain ind:GradeAppealCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:initialReviewCompletedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Initial Review Completed Timestamp' ;
    rdfs:comment 'Date and time when the initial administrative review of the appeal was completed to determine if it meets procedural requirements.' ;
    rdfs:domain ind:GradeAppealCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:instructorResponse rdf:type rdf:Property ;
    rdfs:label 'Instructor Response' ;
    rdfs:comment 'Written response from the instructor addressing the student\'s appeal claims and providing their perspective on the grading decision.' ;
    rdfs:domain ind:GradeAppealCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:instructorResponseTimestamp rdf:type rdf:Property ;
    rdfs:label 'Instructor Response Timestamp' ;
    rdfs:comment 'Date and time when the instructor submitted their response to the grade appeal.' ;
    rdfs:domain ind:GradeAppealCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:requestedGrade rdf:type rdf:Property ;
    rdfs:label 'Requested Grade' ;
    rdfs:comment 'The grade the student is requesting through the appeal process. May be null if student is requesting grade review without specifying desired outcome.' ;
    rdfs:domain ind:GradeAppealCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:studentNotifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Student Notified Timestamp' ;
    rdfs:comment 'Date and time when the student was officially notified of the appeal decision.' ;
    rdfs:domain ind:GradeAppealCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:supportingDocumentationProvided rdf:type rdf:Property ;
    rdfs:label 'Supporting Documentation Provided' ;
    rdfs:comment 'Indicates whether the student has submitted supporting documentation (assignments, exams, correspondence, medical records, etc.) to substantiate the appeal.' ;
    rdfs:domain ind:GradeAppealCase ;
