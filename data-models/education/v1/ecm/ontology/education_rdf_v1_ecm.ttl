    rdfs:domain ind:EadaReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:womensAssistantCoachSalariesTotal rdf:type rdf:Property ;
    rdfs:label 'Womens Assistant Coach Salaries Total' ;
