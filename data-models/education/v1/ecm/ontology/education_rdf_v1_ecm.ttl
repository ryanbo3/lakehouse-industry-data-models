    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lenderId rdf:type rdf:Property ;
    rdfs:label 'Lender Id' ;
    rdfs:comment 'Reference to the lender or loan servicer that holds the master promissory note.' ;
    rdfs:domain ind:Aid ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Lender .

ind:borrowerAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Borrower Address Line1' ;
    rdfs:comment 'The first line of the borrower\'s mailing address at the time of MPN signing.' ;
    rdfs:domain ind:MasterPromissoryNote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:borrowerAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Borrower Address Line2' ;
    rdfs:comment 'The second line of the borrower\'s mailing address (apartment, suite, etc.).' ;
    rdfs:domain ind:MasterPromissoryNote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:borrowerCity rdf:type rdf:Property ;
    rdfs:label 'Borrower City' ;
    rdfs:comment 'The city of the borrower\'s mailing address at the time of MPN signing.' ;
    rdfs:domain ind:MasterPromissoryNote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:borrowerCountry rdf:type rdf:Property ;
    rdfs:label 'Borrower Country' ;
    rdfs:comment 'The three-letter ISO country code of the borrower\'s mailing address at the time of MPN signing.' ;
    rdfs:domain ind:MasterPromissoryNote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:borrowerDateOfBirth rdf:type rdf:Property ;
    rdfs:label 'Borrower Date Of Birth' ;
    rdfs:comment 'The date of birth of the student borrower.' ;
    rdfs:domain ind:MasterPromissoryNote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:borrowerEmail rdf:type rdf:Property ;
    rdfs:label 'Borrower Email' ;
    rdfs:comment 'The primary email address of the student borrower at the time of MPN signing.' ;
    rdfs:domain ind:MasterPromissoryNote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:borrowerName rdf:type rdf:Property ;
    rdfs:label 'Borrower Name' ;
    rdfs:comment 'The full legal name of the student borrower as it appears on the master promissory note.' ;
    rdfs:domain ind:MasterPromissoryNote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:borrowerPhone rdf:type rdf:Property ;
    rdfs:label 'Borrower Phone' ;
    rdfs:comment 'The primary contact phone number of the student borrower at the time of MPN signing.' ;
    rdfs:domain ind:MasterPromissoryNote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:borrowerPostalCode rdf:type rdf:Property ;
    rdfs:label 'Borrower Postal Code' ;
    rdfs:comment 'The postal code of the borrower\'s mailing address at the time of MPN signing.' ;
    rdfs:domain ind:MasterPromissoryNote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:borrowerSsn rdf:type rdf:Property ;
    rdfs:label 'Borrower Ssn' ;
    rdfs:comment 'The Social Security Number of the student borrower who signed the master promissory note.' ;
    rdfs:domain ind:MasterPromissoryNote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:borrowerState rdf:type rdf:Property ;
    rdfs:label 'Borrower State' ;
    rdfs:comment 'The two-letter state code of the borrower\'s mailing address at the time of MPN signing.' ;
    rdfs:domain ind:MasterPromissoryNote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:counselingCompletedDate rdf:type rdf:Property ;
    rdfs:label 'Counseling Completed Date' ;
    rdfs:comment 'The date on which the borrower completed entrance counseling.' ;
    rdfs:domain ind:MasterPromissoryNote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:counselingCompletedFlag rdf:type rdf:Property ;
    rdfs:label 'Counseling Completed Flag' ;
    rdfs:comment 'Indicates whether the borrower completed entrance counseling prior to signing the master promissory note, as required by federal regulations.' ;
    rdfs:domain ind:MasterPromissoryNote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:defermentEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Deferment Eligible Flag' ;
    rdfs:comment 'Indicates whether loans originated under this MPN are eligible for deferment under federal regulations.' ;
    rdfs:domain ind:MasterPromissoryNote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:forbearanceEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Forbearance Eligible Flag' ;
    rdfs:comment 'Indicates whether loans originated under this MPN are eligible for forbearance under federal regulations.' ;
    rdfs:domain ind:MasterPromissoryNote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gracePeriodMonths rdf:type rdf:Property ;
    rdfs:label 'Grace Period Months' ;
    rdfs:comment 'The number of months of grace period before repayment begins after the borrower leaves school or drops below half-time enrollment.' ;
    rdfs:domain ind:MasterPromissoryNote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:interestRateType rdf:type rdf:Property ;
    rdfs:label 'Interest Rate Type' ;
    rdfs:comment 'Indicates whether the loans originated under this MPN carry a fixed or variable interest rate.' ;
    rdfs:domain ind:MasterPromissoryNote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lenderCode rdf:type rdf:Property ;
    rdfs:label 'Lender Code' ;
    rdfs:comment 'The standardized code assigned to the lender by the Department of Education.' ;
    rdfs:domain ind:Aid ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lenderName rdf:type rdf:Property ;
    rdfs:label 'Lender Name' ;
    rdfs:comment 'The name of the lender or loan servicer that holds the master promissory note.' ;
    rdfs:domain ind:Aid ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxLoanAmount rdf:type rdf:Property ;
    rdfs:label 'Max Loan Amount' ;
    rdfs:comment 'The maximum aggregate loan amount that can be originated under this master promissory note, if applicable. Nullable for unlimited MPNs.' ;
    rdfs:domain ind:MasterPromissoryNote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mpnNumber rdf:type rdf:Property ;
    rdfs:label 'Mpn Number' ;
    rdfs:comment 'The externally-known unique identifier assigned to the master promissory note by the federal loan servicer or lender.' ;
    rdfs:domain ind:MasterPromissoryNote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mpnStatus rdf:type rdf:Property ;
    rdfs:label 'Mpn Status' ;
    rdfs:comment 'Current lifecycle status of the master promissory note (e.g., active, expired, cancelled, completed, pending, suspended).' ;
    rdfs:domain ind:MasterPromissoryNote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originationFeePercent rdf:type rdf:Property ;
    rdfs:label 'Origination Fee Percent' ;
    rdfs:comment 'The origination fee percentage charged on loans originated under this master promissory note.' ;
    rdfs:domain ind:MasterPromissoryNote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:repaymentPlanType rdf:type rdf:Property ;
    rdfs:label 'Repayment Plan Type' ;
    rdfs:comment 'The default repayment plan type selected by the borrower at the time of MPN signing. [ENUM-REF-CANDIDATE: standard|graduated|extended|income_driven|income_based|pay_as_you_earn|revised_pay_as_you_earn|income_contingent — promote to reference product]' ;
    rdfs:domain ind:MasterPromissoryNote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signatureIpAddress rdf:type rdf:Property ;
    rdfs:label 'Signature Ip Address' ;
    rdfs:comment 'The IP address from which the borrower electronically signed the master promissory note, used for audit and fraud prevention.' ;
    rdfs:domain ind:MasterPromissoryNote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signatureMethod rdf:type rdf:Property ;
    rdfs:label 'Signature Method' ;
    rdfs:comment 'The method by which the borrower signed the master promissory note (e.g., electronic, paper, wet signature).' ;
    rdfs:domain ind:MasterPromissoryNote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signatureTimestamp rdf:type rdf:Property ;
    rdfs:label 'Signature Timestamp' ;
    rdfs:comment 'The precise date and time when the borrower completed the signature process for the master promissory note.' ;
    rdfs:domain ind:MasterPromissoryNote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:borrowerId rdf:type rdf:Property ;
    rdfs:label 'Borrower Id' ;
    rdfs:comment 'Primary key for borrower' ;
    rdfs:domain ind:Borrower ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:adverseCreditFlag rdf:type rdf:Property ;
    rdfs:label 'Adverse Credit Flag' ;
    rdfs:comment 'Indicates whether the borrower has adverse credit history as defined by federal Direct PLUS loan criteria. Affects PLUS loan eligibility.' ;
    rdfs:domain ind:Borrower ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:alternatePhoneNumber rdf:type rdf:Property ;
    rdfs:label 'Alternate Phone Number' ;
    rdfs:comment 'Secondary contact phone number for the borrower. Used when primary contact fails.' ;
    rdfs:domain ind:Borrower ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:borrowerStatus rdf:type rdf:Property ;
    rdfs:label 'Borrower Status' ;
    rdfs:comment 'Current lifecycle status of the borrower record. Active borrowers are eligible for new loans; inactive or suspended borrowers require review.' ;
    rdfs:domain ind:Borrower ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditAuthorizationFlag rdf:type rdf:Property ;
    rdfs:label 'Credit Authorization Flag' ;
    rdfs:comment 'Indicates whether the borrower has authorized the institution to perform credit checks for PLUS loan eligibility and adverse credit determination.' ;
    rdfs:domain ind:Borrower ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:defaultFlag rdf:type rdf:Property ;
    rdfs:label 'Default Flag' ;
    rdfs:comment 'Indicates whether the borrower is currently in default on any federal student loan. Blocks eligibility for additional Title IV aid.' ;
    rdfs:domain ind:Borrower ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:entranceCounselingDate rdf:type rdf:Property ;
    rdfs:label 'Entrance Counseling Date' ;
    rdfs:comment 'Date the borrower completed mandatory entrance loan counseling. Required before first disbursement of a Direct Loan.' ;
    rdfs:domain ind:Borrower ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:exitCounselingDate rdf:type rdf:Property ;
    rdfs:label 'Exit Counseling Date' ;
    rdfs:comment 'Date the borrower completed mandatory exit loan counseling. Required upon graduation, withdrawal, or dropping below half-time enrollment.' ;
    rdfs:domain ind:Borrower ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mpnExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Mpn Expiration Date' ;
    rdfs:comment 'Date the Master Promissory Note expires. Borrower must sign a new MPN after this date to receive additional loans.' ;
    rdfs:domain ind:Borrower ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nsldsMatchFlag rdf:type rdf:Property ;
    rdfs:label 'Nslds Match Flag' ;
    rdfs:comment 'Indicates whether the borrower record has been matched and verified against the National Student Loan Data System for existing federal loan and grant history.' ;
    rdfs:domain ind:Borrower ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:outstandingPrincipalBalance rdf:type rdf:Property ;
    rdfs:label 'Outstanding Principal Balance' ;
    rdfs:comment 'Current total outstanding principal balance across all federal loans for this borrower. Used to calculate remaining eligibility against aggregate limits.' ;
    rdfs:domain ind:Borrower ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:accreditationCycleYears rdf:type rdf:Property ;
    rdfs:label 'Accreditation Cycle Years' ;
    rdfs:comment 'Standard number of years in the accreditation cycle used by this accrediting body (e.g., 5, 7, 10 years).' ;
    rdfs:domain ind:AccreditingBody ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:complaintProcessUrl rdf:type rdf:Property ;
    rdfs:label 'Complaint Process Url' ;
    rdfs:comment 'URL to the accrediting body\'s complaint and grievance process documentation.' ;
    rdfs:domain ind:AccreditingBody ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disciplineFocus rdf:type rdf:Property ;
    rdfs:label 'Discipline Focus' ;
    rdfs:comment 'Primary academic discipline or professional field focus of the accrediting body for specialized or programmatic accreditors (e.g., Engineering, Business, Nursing, Law).' ;
    rdfs:domain ind:AccreditingBody ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:memberInstitutionCount rdf:type rdf:Property ;
    rdfs:label 'Member Institution Count' ;
    rdfs:comment 'Total number of institutions or programs currently accredited by this accrediting body.' ;
    rdfs:domain ind:AccreditingBody ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:peerReviewRequired rdf:type rdf:Property ;
    rdfs:label 'Peer Review Required' ;
    rdfs:comment 'Indicates whether this accrediting body requires peer review as part of its accreditation process.' ;
    rdfs:domain ind:AccreditingBody ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recognitionExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Recognition Expiration Date' ;
    rdfs:comment 'Date when the current recognition period expires and renewal is required.' ;
    rdfs:domain ind:AccreditingBody ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:recognizingAuthority rdf:type rdf:Property ;
    rdfs:label 'Recognizing Authority' ;
    rdfs:comment 'The authority that recognizes this accrediting body: USDE (U.S. Department of Education), CHEA (Council for Higher Education Accreditation), both, other, or none.' ;
    rdfs:domain ind:AccreditingBody ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:region rdf:type rdf:Property ;
    rdfs:label 'Region' ;
    rdfs:comment 'Specific geographic region served by the accrediting body if it is a regional accreditor (e.g., Middle States, New England, North Central, Northwest, Southern, Western).' ;
    rdfs:domain ind:AccreditingBody ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:selfStudyRequired rdf:type rdf:Property ;
    rdfs:label 'Self Study Required' ;
    rdfs:comment 'Indicates whether this accrediting body requires institutions to complete a comprehensive self-study as part of the accreditation process.' ;
    rdfs:domain ind:AccreditingBody ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:siteVisitRequired rdf:type rdf:Property ;
    rdfs:label 'Site Visit Required' ;
    rdfs:comment 'Indicates whether this accrediting body requires on-site evaluation visits as part of the accreditation process.' ;
    rdfs:domain ind:AccreditingBody ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:standardsEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Standards Effective Date' ;
    rdfs:comment 'Date when the current version of accreditation standards became effective.' ;
    rdfs:domain ind:AccreditingBody ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:standardsVersion rdf:type rdf:Property ;
    rdfs:label 'Standards Version' ;
    rdfs:comment 'Current version or edition of the accreditation standards used by this accrediting body.' ;
    rdfs:domain ind:AccreditingBody ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:substantiveChangePolicyUrl rdf:type rdf:Property ;
    rdfs:label 'Substantive Change Policy Url' ;
    rdfs:comment 'URL to the accrediting body\'s substantive change policy documentation.' ;
    rdfs:domain ind:AccreditingBody ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:titleIvEligibilityRequired rdf:type rdf:Property ;
    rdfs:label 'Title Iv Eligibility Required' ;
    rdfs:comment 'Indicates whether accreditation by this body is required for institutions to participate in federal Title IV student financial aid programs.' ;
    rdfs:domain ind:AccreditingBody ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:auditCost rdf:type rdf:Property ;
    rdfs:label 'Audit Cost' ;
    rdfs:comment 'The total cost incurred for the audit engagement, including internal staff time and external fees, expressed in U.S. dollars.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:auditHours rdf:type rdf:Property ;
    rdfs:label 'Audit Hours' ;
    rdfs:comment 'The total number of staff hours invested in conducting the audit engagement, including planning, fieldwork, and reporting.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:auditMethodology rdf:type rdf:Property ;
    rdfs:label 'Audit Methodology' ;
    rdfs:comment 'The audit approach and techniques used, such as risk-based audit, compliance audit, process audit, or systems audit.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditNumber rdf:type rdf:Property ;
    rdfs:label 'Audit Number' ;
    rdfs:comment 'Human-readable business identifier for the audit, typically formatted as AUD-YYYY-NNNNNN.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditObjective rdf:type rdf:Property ;
    rdfs:label 'Audit Objective' ;
    rdfs:comment 'The primary purpose and goals of the audit engagement, describing what the audit seeks to accomplish or verify.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditScope rdf:type rdf:Property ;
    rdfs:label 'Audit Scope' ;
    rdfs:comment 'The breadth and boundaries of the audit engagement, defining what organizational units, processes, or systems are included in the examination.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditStatus rdf:type rdf:Property ;
    rdfs:label 'Audit Status' ;
    rdfs:comment 'Current lifecycle state of the audit. Planned audits are scheduled but not started, in-progress audits are actively being conducted, fieldwork indicates data collection phase, reporting indicates draft preparation, issued means final report delivered, and closed indicates all follow-up completed.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditorOrganization rdf:type rdf:Property ;
    rdfs:label 'Auditor Organization' ;
    rdfs:comment 'The name of the organization or department conducting the audit, such as Internal Audit, external audit firm name, or regulatory agency.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionPlanReceivedDate rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Plan Received Date' ;
    rdfs:comment 'The date when management\'s corrective action plan was received by the audit function.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:criticalFindingCount rdf:type rdf:Property ;
    rdfs:label 'Critical Finding Count' ;
    rdfs:comment 'The number of critical-severity findings identified that require immediate management attention and remediation.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:departmentAudited rdf:type rdf:Property ;
    rdfs:label 'Department Audited' ;
    rdfs:comment 'The name of the academic or administrative department that is the subject of the audit.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedRemediationDate rdf:type rdf:Property ;
    rdfs:label 'Estimated Remediation Date' ;
    rdfs:comment 'The target date by which management commits to fully implement corrective actions to address audit findings.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:externalAuditorFee rdf:type rdf:Property ;
    rdfs:label 'External Auditor Fee' ;
    rdfs:comment 'The fee paid to external audit firms or consultants for conducting the audit, expressed in U.S. dollars. Null for internal audits.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:findingCount rdf:type rdf:Property ;
    rdfs:label 'Finding Count' ;
    rdfs:comment 'The total number of audit findings identified during the engagement, including all severity levels.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:highFindingCount rdf:type rdf:Property ;
    rdfs:label 'High Finding Count' ;
    rdfs:comment 'The number of high-severity findings identified that represent significant control weaknesses.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:leadAuditorName rdf:type rdf:Property ;
    rdfs:label 'Lead Auditor Name' ;
    rdfs:comment 'The full name of the principal auditor responsible for conducting and overseeing the audit engagement.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lowFindingCount rdf:type rdf:Property ;
    rdfs:label 'Low Finding Count' ;
    rdfs:comment 'The number of low-severity findings identified that represent minor control weaknesses or opportunities for improvement.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:mediumFindingCount rdf:type rdf:Property ;
    rdfs:label 'Medium Finding Count' ;
    rdfs:comment 'The number of medium-severity findings identified that represent moderate control weaknesses.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:overallOpinion rdf:type rdf:Property ;
    rdfs:label 'Overall Opinion' ;
    rdfs:comment 'The auditor\'s overall conclusion regarding the adequacy and effectiveness of controls in the audited area. Satisfactory indicates effective controls, needs improvement indicates control gaps requiring attention, unsatisfactory indicates significant control deficiencies, and adverse indicates pervasive control failures.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportDistributionList rdf:type rdf:Property ;
    rdfs:label 'Report Distribution List' ;
    rdfs:comment 'Comma-separated list of roles or individuals who received the final audit report, such as Board of Trustees, President, CFO, Audit Committee.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:samplingMethod rdf:type rdf:Property ;
    rdfs:label 'Sampling Method' ;
    rdfs:comment 'The technique used to select items for testing during the audit. Statistical sampling uses probability theory, judgmental sampling relies on auditor expertise, random sampling selects items by chance, stratified sampling divides population into subgroups, and census examines all items.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledEndDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled End Date' ;
    rdfs:comment 'The planned date when the audit engagement is scheduled to be completed.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:accreditationBodyId rdf:type rdf:Property ;
    rdfs:label 'Accreditation Body Id' ;
    rdfs:comment 'Reference to the external accreditation or regulatory body that recognizes or requires this certificate type.' ;
    rdfs:domain ind:CertificateTemplate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AccreditingBody .

ind:approvedByUserIdentityAccountId rdf:type rdf:Property ;
    rdfs:label 'Approved By User Identity Account Id' ;
    rdfs:comment 'Reference to the user who approved this certificate template for active use.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IdentityAccount .

ind:competencyFrameworkId rdf:type rdf:Property ;
    rdfs:label 'Competency Framework Id' ;
    rdfs:comment 'Reference to the competency or learning outcomes framework associated with this certificate template.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CompetencyFramework .

ind:printVendorId rdf:type rdf:Property ;
    rdfs:label 'Print Vendor Id' ;
    rdfs:comment 'Reference to the external print vendor or service provider used for physical certificate production.' ;
    rdfs:domain ind:CertificateTemplate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FinanceVendor .

ind:backgroundImageUrl rdf:type rdf:Property ;
    rdfs:label 'Background Image Url' ;
    rdfs:comment 'URL or file path to the background image or watermark used in the certificate template.' ;
    rdfs:domain ind:CertificateTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blockchainVerificationEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Blockchain Verification Enabled Flag' ;
    rdfs:comment 'Indicates whether certificates generated from this template are registered on a blockchain for tamper-proof verification.' ;
    rdfs:domain ind:CertificateTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:digitalSignatureEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Digital Signature Enabled Flag' ;
    rdfs:comment 'Indicates whether certificates generated from this template support digital signature technology for authentication.' ;
    rdfs:domain ind:CertificateTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:expirationPeriodMonths rdf:type rdf:Property ;
    rdfs:label 'Expiration Period Months' ;
    rdfs:comment 'Number of months after issuance when certificates from this template expire and require renewal. Null indicates no expiration.' ;
    rdfs:domain ind:CertificateTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:issuingAuthorityName rdf:type rdf:Property ;
    rdfs:label 'Issuing Authority Name' ;
    rdfs:comment 'Name of the institutional office, department, or official authorized to issue certificates from this template.' ;
    rdfs:domain ind:CertificateTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingAuthorityTitle rdf:type rdf:Property ;
    rdfs:label 'Issuing Authority Title' ;
    rdfs:comment 'Official title of the person or office authorized to issue certificates from this template (e.g., Registrar, Dean, President).' ;
    rdfs:domain ind:CertificateTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:layoutFormat rdf:type rdf:Property ;
    rdfs:label 'Layout Format' ;
    rdfs:comment 'Page orientation format for the certificate template.' ;
    rdfs:domain ind:CertificateTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:logoImageUrl rdf:type rdf:Property ;
    rdfs:label 'Logo Image Url' ;
    rdfs:comment 'URL or file path to the institutional logo image displayed on the certificate.' ;
    rdfs:domain ind:CertificateTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pageSize rdf:type rdf:Property ;
    rdfs:label 'Page Size' ;
    rdfs:comment 'Standard page size specification for the certificate template.' ;
    rdfs:domain ind:CertificateTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paperStockSpecification rdf:type rdf:Property ;
    rdfs:label 'Paper Stock Specification' ;
    rdfs:comment 'Technical specification of the paper stock used for physical certificates including weight, finish, and security features.' ;
    rdfs:domain ind:CertificateTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publicDisplayFlag rdf:type rdf:Property ;
    rdfs:label 'Public Display Flag' ;
    rdfs:comment 'Indicates whether certificates issued from this template can be publicly displayed or shared by recipients.' ;
    rdfs:domain ind:CertificateTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sealRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Seal Required Flag' ;
    rdfs:comment 'Indicates whether an official institutional seal or embossment is required on certificates generated from this template.' ;
    rdfs:domain ind:CertificateTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:securityFeatures rdf:type rdf:Property ;
    rdfs:label 'Security Features' ;
    rdfs:comment 'Description of security features embedded in the certificate template such as watermarks, holograms, QR codes, or blockchain verification.' ;
    rdfs:domain ind:CertificateTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signatureBlockCount rdf:type rdf:Property ;
    rdfs:label 'Signature Block Count' ;
    rdfs:comment 'Number of signature blocks included in the certificate template for authorized signatories.' ;
    rdfs:domain ind:CertificateTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:templateType rdf:type rdf:Property ;
    rdfs:label 'Template Type' ;
    rdfs:comment 'Classification of the certificate template by its primary purpose within the institution.' ;
    rdfs:domain ind:CertificateTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationUrl rdf:type rdf:Property ;
    rdfs:label 'Verification Url' ;
    rdfs:comment 'URL where third parties can verify the authenticity of certificates issued from this template.' ;
    rdfs:domain ind:CertificateTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:institutionId rdf:type rdf:Property ;
    rdfs:label 'Institution Id' ;
    rdfs:comment 'Primary key for institution' ;
    rdfs:domain ind:Education ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Institution .

ind:parentInstitutionId rdf:type rdf:Property ;
    rdfs:label 'Parent Institution Id' ;
    rdfs:comment 'Reference to the parent institution if this institution is a branch campus, satellite location, or subsidiary of a larger system.' ;
    rdfs:domain ind:Institution ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Institution .

ind:carnegieClassification rdf:type rdf:Property ;
    rdfs:label 'Carnegie Classification' ;
    rdfs:comment 'Carnegie Classification framework category describing the institution\'s mission, degree offerings, and research activity level.' ;
    rdfs:domain ind:Institution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emailDomain rdf:type rdf:Property ;
    rdfs:label 'Email Domain' ;
    rdfs:comment 'Primary email domain used by the institution for official communications and student/faculty email accounts.' ;
    rdfs:domain ind:Institution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentSizeCategory rdf:type rdf:Property ;
    rdfs:label 'Enrollment Size Category' ;
    rdfs:comment 'Classification of the institution based on total student enrollment headcount ranges.' ;
    rdfs:domain ind:Institution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:foundedYear rdf:type rdf:Property ;
    rdfs:label 'Founded Year' ;
    rdfs:comment 'Year the institution was originally established or chartered.' ;
    rdfs:domain ind:Institution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hispanicServingInstitution rdf:type rdf:Property ;
    rdfs:label 'Hispanic Serving Institution' ;
    rdfs:comment 'Indicates whether the institution meets the federal definition of a Hispanic-Serving Institution with at least 25% Hispanic enrollment.' ;
    rdfs:domain ind:Institution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:historicallyBlackCollege rdf:type rdf:Property ;
    rdfs:label 'Historically Black College' ;
    rdfs:comment 'Indicates whether the institution is designated as a Historically Black College or University under federal law.' ;
    rdfs:domain ind:Institution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:institutionLevel rdf:type rdf:Property ;
    rdfs:label 'Institution Level' ;
    rdfs:comment 'Primary level of instruction offered by the institution based on degree programs.' ;
    rdfs:domain ind:Institution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:institutionType rdf:type rdf:Property ;
    rdfs:label 'Institution Type' ;
    rdfs:comment 'Classification of the institution based on control and ownership structure.' ;
    rdfs:domain ind:Institution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:landGrantInstitution rdf:type rdf:Property ;
    rdfs:label 'Land Grant Institution' ;
    rdfs:comment 'Indicates whether the institution is designated as a land-grant institution under the Morrill Acts.' ;
    rdfs:domain ind:Institution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:localeClassification rdf:type rdf:Property ;
    rdfs:label 'Locale Classification' ;
    rdfs:comment 'Geographic setting classification describing the institution\'s location as city, suburb, town, or rural.' ;
    rdfs:domain ind:Institution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:opeCode rdf:type rdf:Property ;
    rdfs:label 'Ope Code' ;
    rdfs:comment 'Eight-digit identifier assigned by the US Department of Education Office of Postsecondary Education for Title IV program participation.' ;
    rdfs:domain ind:Institution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryAccreditor rdf:type rdf:Property ;
    rdfs:label 'Primary Accreditor' ;
    rdfs:comment 'Name of the primary regional or national accrediting agency responsible for institutional accreditation.' ;
    rdfs:domain ind:Institution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:religiousAffiliation rdf:type rdf:Property ;
    rdfs:label 'Religious Affiliation' ;
    rdfs:comment 'Religious denomination or affiliation of the institution, if applicable.' ;
    rdfs:domain ind:Institution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:systemName rdf:type rdf:Property ;
    rdfs:label 'System Name' ;
    rdfs:comment 'Name of the higher education system or consortium to which the institution belongs, if applicable.' ;
    rdfs:domain ind:Institution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tribalCollege rdf:type rdf:Property ;
    rdfs:label 'Tribal College' ;
    rdfs:comment 'Indicates whether the institution is a Tribal College or University chartered by a federally recognized tribe.' ;
    rdfs:domain ind:Institution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:accessibilityCompliant rdf:type rdf:Property ;
    rdfs:label 'Accessibility Compliant' ;
    rdfs:comment 'Indicates whether the assessment instrument meets accessibility standards such as WCAG 2.1 AA for students with disabilities.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:accommodationsAllowed rdf:type rdf:Property ;
    rdfs:label 'Accommodations Allowed' ;
    rdfs:comment 'Indicates whether the assessment instrument allows for student accommodations such as extended time or assistive technology.' ;
    rdfs:domain ind:AssessmentInstrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:alignmentToPlo rdf:type rdf:Property ;
    rdfs:label 'Alignment To Plo' ;
    rdfs:comment 'Indicates whether this assessment instrument is formally aligned to one or more Program Learning Outcomes.' ;
    rdfs:domain ind:AssessmentInstrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:alignmentToSlo rdf:type rdf:Property ;
    rdfs:label 'Alignment To Slo' ;
    rdfs:comment 'Indicates whether this assessment instrument is formally aligned to one or more Student Learning Outcomes.' ;
    rdfs:domain ind:AssessmentInstrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:collaborationAllowed rdf:type rdf:Property ;
    rdfs:label 'Collaboration Allowed' ;
    rdfs:comment 'Indicates whether students are permitted to collaborate or work in groups on this assessment instrument.' ;
    rdfs:domain ind:AssessmentInstrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:feedbackProvided rdf:type rdf:Property ;
    rdfs:label 'Feedback Provided' ;
    rdfs:comment 'Indicates whether students receive automated or instructor feedback upon completion of the assessment instrument.' ;
    rdfs:domain ind:AssessmentInstrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:feedbackTiming rdf:type rdf:Property ;
    rdfs:label 'Feedback Timing' ;
    rdfs:comment 'Timing at which feedback is released to students relative to assessment submission and grading.' ;
    rdfs:domain ind:AssessmentInstrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:instrumentCode rdf:type rdf:Property ;
    rdfs:label 'Instrument Code' ;
    rdfs:comment 'Unique business identifier code for the assessment instrument used in catalogs and external references.' ;
    rdfs:domain ind:AssessmentInstrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:instrumentType rdf:type rdf:Property ;
    rdfs:label 'Instrument Type' ;
    rdfs:comment 'Classification of the assessment instrument by its primary format and delivery method.' ;
    rdfs:domain ind:AssessmentInstrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumRetakes rdf:type rdf:Property ;
    rdfs:label 'Maximum Retakes' ;
    rdfs:comment 'Maximum number of times a student may retake or resubmit this assessment instrument if retakes are allowed.' ;
    rdfs:domain ind:AssessmentInstrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:proctoringRequired rdf:type rdf:Property ;
    rdfs:label 'Proctoring Required' ;
    rdfs:comment 'Indicates whether the assessment instrument requires proctoring or invigilation during administration.' ;
    rdfs:domain ind:AssessmentInstrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:questionCount rdf:type rdf:Property ;
    rdfs:label 'Question Count' ;
    rdfs:comment 'Total number of questions, items, or components included in this assessment instrument.' ;
    rdfs:domain ind:AssessmentInstrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:randomizationEnabled rdf:type rdf:Property ;
    rdfs:label 'Randomization Enabled' ;
    rdfs:comment 'Indicates whether question order or answer choices are randomized to reduce academic dishonesty.' ;
    rdfs:domain ind:AssessmentInstrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:retakeAllowed rdf:type rdf:Property ;
    rdfs:label 'Retake Allowed' ;
    rdfs:comment 'Indicates whether students are permitted to retake or resubmit this assessment instrument for a revised grade.' ;
    rdfs:domain ind:AssessmentInstrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:retiredDate rdf:type rdf:Property ;
    rdfs:label 'Retired Date' ;
    rdfs:comment 'Date when the assessment instrument was formally retired from active curriculum use.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:retiredReason rdf:type rdf:Property ;
    rdfs:label 'Retired Reason' ;
    rdfs:comment 'Explanation or justification for why the assessment instrument was retired from active use.' ;
    rdfs:domain ind:AssessmentInstrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalPoints rdf:type rdf:Property ;
    rdfs:label 'Total Points' ;
    rdfs:comment 'Maximum possible points or score that can be earned on this assessment instrument.' ;
    rdfs:domain ind:AssessmentInstrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:weightPercentage rdf:type rdf:Property ;
    rdfs:label 'Weight Percentage' ;
    rdfs:comment 'Percentage weight of this assessment instrument in the overall course grade calculation.' ;
    rdfs:domain ind:AssessmentInstrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:prerequisiteGroupId rdf:type rdf:Property ;
    rdfs:label 'Prerequisite Group Id' ;
    rdfs:comment 'Primary key for prerequisite_group' ;
    rdfs:domain ind:PrerequisiteGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:parentGroupId rdf:type rdf:Property ;
    rdfs:label 'Parent Group Id' ;
    rdfs:comment 'Identifier of the parent prerequisite group when this group is nested within a hierarchical prerequisite structure. Null for top-level groups.' ;
    rdfs:domain ind:PrerequisiteGroup ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PrerequisiteGroup .

ind:appliesToTransferStudents rdf:type rdf:Property ;
    rdfs:label 'Applies To Transfer Students' ;
    rdfs:comment 'Indicates whether this prerequisite group applies to transfer students or only to native students. Used for articulation agreement handling.' ;
    rdfs:domain ind:PrerequisiteGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:catalogDisplayText rdf:type rdf:Property ;
    rdfs:label 'Catalog Display Text' ;
    rdfs:comment 'Formatted text describing this prerequisite group as it should appear in the course catalog and student-facing documentation.' ;
    rdfs:domain ind:PrerequisiteGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competencyFramework rdf:type rdf:Property ;
    rdfs:label 'Competency Framework' ;
    rdfs:comment 'Name or identifier of the competency framework used to define prerequisite competencies in this group. Applicable when group_type is competency.' ;
    rdfs:domain ind:PrerequisiteGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enforcementLevel rdf:type rdf:Property ;
    rdfs:label 'Enforcement Level' ;
    rdfs:comment 'Level of enforcement for this prerequisite group: hard_block prevents enrollment, soft_warning allows enrollment with notification, advisory_only provides guidance without restriction.' ;
    rdfs:domain ind:PrerequisiteGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:logicOperator rdf:type rdf:Property ;
    rdfs:label 'Logic Operator' ;
    rdfs:comment 'Boolean logic operator defining how prerequisites within this group must be satisfied (AND requires all, OR requires any one, XOR requires exactly one).' ;
    rdfs:domain ind:PrerequisiteGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumCoursesRequired rdf:type rdf:Property ;
    rdfs:label 'Minimum Courses Required' ;
    rdfs:comment 'Minimum number of courses from this prerequisite group that must be completed to satisfy the requirement. Used for flexible prerequisite structures.' ;
    rdfs:domain ind:PrerequisiteGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minimumCreditsRequired rdf:type rdf:Property ;
    rdfs:label 'Minimum Credits Required' ;
    rdfs:comment 'Minimum number of credit hours from courses in this prerequisite group required to satisfy the prerequisite. Supports credit-based prerequisite rules.' ;
    rdfs:domain ind:PrerequisiteGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumGradeRequired rdf:type rdf:Property ;
    rdfs:label 'Minimum Grade Required' ;
    rdfs:comment 'Minimum grade that must be achieved in prerequisite courses within this group (e.g., C-, B, P for Pass, S for Satisfactory).' ;
    rdfs:domain ind:PrerequisiteGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sequenceOrder rdf:type rdf:Property ;
    rdfs:label 'Sequence Order' ;
    rdfs:comment 'Numeric ordering of this prerequisite group when multiple groups apply to a course, controlling display and evaluation sequence.' ;
    rdfs:domain ind:PrerequisiteGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:testScoreType rdf:type rdf:Property ;
    rdfs:label 'Test Score Type' ;
    rdfs:comment 'Type of standardized or placement test that can satisfy this prerequisite group (e.g., SAT, ACT, AP, CLEP, institutional placement test). Applicable when group_type is placement_test.' ;
    rdfs:domain ind:PrerequisiteGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waiverAllowed rdf:type rdf:Property ;
    rdfs:label 'Waiver Allowed' ;
    rdfs:comment 'Indicates whether this prerequisite group can be waived by authorized personnel (department chair, advisor, registrar).' ;
    rdfs:domain ind:PrerequisiteGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:waiverAuthorityRole rdf:type rdf:Property ;
    rdfs:label 'Waiver Authority Role' ;
    rdfs:comment 'Role or position authorized to grant waivers for this prerequisite group when waiver_allowed is true.' ;
    rdfs:domain ind:PrerequisiteGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewCommitteeId rdf:type rdf:Property ;
    rdfs:label 'Review Committee Id' ;
    rdfs:comment 'Primary key for review_committee' ;
    rdfs:domain ind:ReviewCommittee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:academicUnitId rdf:type rdf:Property ;
    rdfs:label 'Academic Unit Id' ;
    rdfs:comment 'Reference to the academic unit (college, school, department) that this committee serves or reports to.' ;
    rdfs:domain ind:ReviewCommittee ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrgUnit .

ind:chairEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Chair Employee Id' ;
    rdfs:comment 'Reference to the employee serving as the chair or lead of the review committee.' ;
    rdfs:domain ind:ReviewCommittee ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:secretaryEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Secretary Employee Id' ;
    rdfs:comment 'Reference to the employee serving as the secretary responsible for committee documentation and minutes.' ;
    rdfs:domain ind:ReviewCommittee ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:viceChairEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Vice Chair Employee Id' ;
    rdfs:comment 'Reference to the employee serving as the vice chair or co-lead of the review committee.' ;
    rdfs:domain ind:ReviewCommittee ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:appealLevel rdf:type rdf:Property ;
    rdfs:label 'Appeal Level' ;
    rdfs:comment 'Hierarchical level of this committee in the appeals process, where higher numbers indicate higher levels of appeal authority.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:averageReviewDurationDays rdf:type rdf:Property ;
    rdfs:label 'Average Review Duration Days' ;
    rdfs:comment 'Typical number of days required for the committee to complete a review from submission to decision.' ;
    rdfs:domain ind:ReviewCommittee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:charterDocumentUrl rdf:type rdf:Property ;
    rdfs:label 'Charter Document Url' ;
    rdfs:comment 'URL reference to the committee charter document that defines its purpose, authority, and operating procedures.' ;
    rdfs:domain ind:ReviewCommittee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:committeeCode rdf:type rdf:Property ;
    rdfs:label 'Committee Code' ;
    rdfs:comment 'Unique business identifier code for the review committee used in external communications and reporting.' ;
    rdfs:domain ind:ReviewCommittee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:committeeType rdf:type rdf:Property ;
    rdfs:label 'Committee Type' ;
    rdfs:comment 'Classification of the committee based on its primary review function within the enrollment lifecycle.' ;
    rdfs:domain ind:ReviewCommittee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decisionAuthorityLevel rdf:type rdf:Property ;
    rdfs:label 'Decision Authority Level' ;
    rdfs:comment 'Level of decision-making authority granted to the committee indicating whether decisions are recommendations or binding.' ;
    rdfs:domain ind:ReviewCommittee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalRepresentationFlag rdf:type rdf:Property ;
    rdfs:label 'External Representation Flag' ;
    rdfs:comment 'Indicates whether the committee includes external members from outside the institution.' ;
    rdfs:domain ind:ReviewCommittee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:facultyRepresentationFlag rdf:type rdf:Property ;
    rdfs:label 'Faculty Representation Flag' ;
    rdfs:comment 'Indicates whether the committee includes faculty members as part of its composition.' ;
    rdfs:domain ind:ReviewCommittee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:quorumRequirement rdf:type rdf:Property ;
    rdfs:label 'Quorum Requirement' ;
    rdfs:comment 'Minimum number of committee members required to be present for official review decisions.' ;
    rdfs:domain ind:ReviewCommittee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reviewCriteriaDocumentUrl rdf:type rdf:Property ;
    rdfs:label 'Review Criteria Document Url' ;
    rdfs:comment 'URL reference to the official document defining the review criteria and decision-making guidelines for this committee.' ;
    rdfs:domain ind:ReviewCommittee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewScope rdf:type rdf:Property ;
    rdfs:label 'Review Scope' ;
    rdfs:comment 'Academic level scope that defines which student populations this committee reviews.' ;
    rdfs:domain ind:ReviewCommittee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:staffRepresentationFlag rdf:type rdf:Property ;
    rdfs:label 'Staff Representation Flag' ;
    rdfs:comment 'Indicates whether the committee includes administrative staff members as part of its composition.' ;
    rdfs:domain ind:ReviewCommittee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:studentRepresentationFlag rdf:type rdf:Property ;
    rdfs:label 'Student Representation Flag' ;
    rdfs:comment 'Indicates whether the committee includes student members as part of its composition.' ;
    rdfs:domain ind:ReviewCommittee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:termSpecificFlag rdf:type rdf:Property ;
    rdfs:label 'Term Specific Flag' ;
    rdfs:comment 'Indicates whether the committee operates on a term-by-term basis or continuously throughout the academic year.' ;
    rdfs:domain ind:ReviewCommittee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:votingMemberCount rdf:type rdf:Property ;
    rdfs:label 'Voting Member Count' ;
    rdfs:comment 'Number of committee members with voting privileges on review decisions.' ;
    rdfs:domain ind:ReviewCommittee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:campusHousingAvailable rdf:type rdf:Property ;
    rdfs:label 'Campus Housing Available' ;
    rdfs:comment 'Indicates whether the institution provides on-campus housing facilities for students.' ;
    rdfs:domain ind:Institution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:campusSetting rdf:type rdf:Property ;
    rdfs:label 'Campus Setting' ;
    rdfs:comment 'Geographic setting classification of the institution\'s primary campus location.' ;
    rdfs:domain ind:Institution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:degreeGrantingStatus rdf:type rdf:Property ;
    rdfs:label 'Degree Granting Status' ;
    rdfs:comment 'Indicates whether the institution is authorized to grant degrees (true) or only offers certificates and non-degree programs (false).' ;
    rdfs:domain ind:Institution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:federalAidEligible rdf:type rdf:Property ;
    rdfs:label 'Federal Aid Eligible' ;
    rdfs:comment 'Indicates whether the institution is eligible to participate in federal student financial aid programs under Title IV.' ;
    rdfs:domain ind:Institution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:foundedDate rdf:type rdf:Property ;
    rdfs:label 'Founded Date' ;
    rdfs:comment 'Date when the institution was originally established or chartered.' ;
    rdfs:domain ind:Institution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:graduateOffering rdf:type rdf:Property ;
    rdfs:label 'Graduate Offering' ;
    rdfs:comment 'Indicates whether the institution offers graduate programs (master or doctoral degrees).' ;
    rdfs:domain ind:Institution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:highestDegreeOffered rdf:type rdf:Property ;
    rdfs:label 'Highest Degree Offered' ;
    rdfs:comment 'The highest level of degree or credential that the institution is authorized to confer.' ;
    rdfs:domain ind:Institution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:medicalDegreeGranting rdf:type rdf:Property ;
    rdfs:label 'Medical Degree Granting' ;
    rdfs:comment 'Indicates whether the institution grants medical degrees (MD, DO) through an accredited medical school.' ;
    rdfs:domain ind:Institution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:onlineProgramsOffered rdf:type rdf:Property ;
    rdfs:label 'Online Programs Offered' ;
    rdfs:comment 'Indicates whether the institution offers fully online degree or certificate programs.' ;
    rdfs:domain ind:Institution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:systemMember rdf:type rdf:Property ;
    rdfs:label 'System Member' ;
    rdfs:comment 'Indicates whether the institution is part of a larger multi-campus system or consortium.' ;
    rdfs:domain ind:Institution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:undergraduateOffering rdf:type rdf:Property ;
    rdfs:label 'Undergraduate Offering' ;
    rdfs:comment 'Indicates whether the institution offers undergraduate programs (associate or bachelor degrees).' ;
    rdfs:domain ind:Institution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recruitmentEventSessionId rdf:type rdf:Property ;
    rdfs:label 'Recruitment Event Session Id' ;
    rdfs:comment 'Primary key for recruitment_event_session' ;
    rdfs:domain ind:RecruitmentEventSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:capacityAvailable rdf:type rdf:Property ;
    rdfs:label 'Capacity Available' ;
    rdfs:comment 'Current number of open seats or slots remaining for registration in this session.' ;
    rdfs:domain ind:RecruitmentEventSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:capacityTotal rdf:type rdf:Property ;
    rdfs:label 'Capacity Total' ;
    rdfs:comment 'Maximum number of prospective students or attendees that can be accommodated in this session.' ;
    rdfs:domain ind:RecruitmentEventSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:checkInRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Check In Required Flag' ;
    rdfs:comment 'Indicates whether attendees must check in upon arrival or at the start of the session for attendance tracking.' ;
    rdfs:domain ind:RecruitmentEventSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:meetingAccessCode rdf:type rdf:Property ;
    rdfs:label 'Meeting Access Code' ;
    rdfs:comment 'Password or access code required to join the virtual session.' ;
    rdfs:domain ind:RecruitmentEventSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:presenterNames rdf:type rdf:Property ;
    rdfs:label 'Presenter Names' ;
    rdfs:comment 'Comma-separated list of names of faculty, staff, or student ambassadors who will present or facilitate this session.' ;
    rdfs:domain ind:RecruitmentEventSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sessionDescription rdf:type rdf:Property ;
    rdfs:label 'Session Description' ;
    rdfs:comment 'Detailed narrative description of the recruitment event session, including agenda, topics covered, and what prospective students can expect.' ;
    rdfs:domain ind:RecruitmentEventSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sessionEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Session End Timestamp' ;
    rdfs:comment 'Date and time when the recruitment event session is scheduled to conclude.' ;
    rdfs:domain ind:RecruitmentEventSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sessionName rdf:type rdf:Property ;
    rdfs:label 'Session Name' ;
    rdfs:comment 'Human-readable name or title of the recruitment event session (e.g., \'Engineering Open House Morning Session\', \'Virtual Campus Tour - Fall 2024\').' ;
    rdfs:domain ind:RecruitmentEventSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sessionNotes rdf:type rdf:Property ;
    rdfs:label 'Session Notes' ;
    rdfs:comment 'Internal notes or comments about the session for staff reference, including special instructions or post-event observations.' ;
    rdfs:domain ind:RecruitmentEventSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sessionStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Session Start Timestamp' ;
    rdfs:comment 'Date and time when the recruitment event session is scheduled to begin.' ;
    rdfs:domain ind:RecruitmentEventSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:waitlistEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Waitlist Enabled Flag' ;
    rdfs:comment 'Indicates whether a waitlist is available for prospective students when the session reaches full capacity.' ;
    rdfs:domain ind:RecruitmentEventSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:energyMeterId rdf:type rdf:Property ;
    rdfs:label 'Energy Meter Id' ;
    rdfs:comment 'Identifier for the energy metering system monitoring this floor. Used for utility cost allocation and energy management reporting.' ;
    rdfs:domain ind:Floor ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:UtilityMeter .

ind:ceilingFinishType rdf:type rdf:Property ;
    rdfs:label 'Ceiling Finish Type' ;
    rdfs:comment 'Primary ceiling finish or construction type on the floor. Affects acoustics, lighting, and maintenance requirements.' ;
    rdfs:domain ind:Floor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:circulationAreaSqft rdf:type rdf:Property ;
    rdfs:label 'Circulation Area Sqft' ;
    rdfs:comment 'Square footage dedicated to corridors, hallways, lobbies, and other circulation spaces on the floor. Used for space efficiency analysis.' ;
    rdfs:domain ind:Floor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:elevationFeet rdf:type rdf:Property ;
    rdfs:label 'Elevation Feet' ;
    rdfs:comment 'Vertical elevation of the floor level above a reference datum (typically ground level or building entrance). Used for accessibility planning and emergency response.' ;
    rdfs:domain ind:Floor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:emergencyExitCount rdf:type rdf:Property ;
    rdfs:label 'Emergency Exit Count' ;
    rdfs:comment 'Number of emergency exits available on the floor. Used for life safety compliance and emergency evacuation planning.' ;
    rdfs:domain ind:Floor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fireZone rdf:type rdf:Property ;
    rdfs:label 'Fire Zone' ;
    rdfs:comment 'Fire safety zone designation for the floor. Used for fire alarm system configuration, emergency response planning, and code compliance.' ;
    rdfs:domain ind:Floor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:floorCode rdf:type rdf:Property ;
    rdfs:label 'Floor Code' ;
    rdfs:comment 'Standardized alphanumeric code uniquely identifying the floor within the institution\'s facility coding system. Used for space accounting and reporting.' ;
    rdfs:domain ind:Floor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:floorFinishType rdf:type rdf:Property ;
    rdfs:label 'Floor Finish Type' ;
    rdfs:comment 'Primary flooring material or finish type on the floor. Impacts maintenance costs, cleaning schedules, and replacement planning.' ;
    rdfs:domain ind:Floor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:floorName rdf:type rdf:Property ;
    rdfs:label 'Floor Name' ;
    rdfs:comment 'Common or official name of the floor (e.g., Main Floor, Engineering Wing, Administrative Level). Used for wayfinding and communication.' ;
    rdfs:domain ind:Floor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:floorType rdf:type rdf:Property ;
    rdfs:label 'Floor Type' ;
    rdfs:comment 'Primary functional classification of the floor based on predominant use. Determines space allocation policies and cost recovery rates.' ;
    rdfs:domain ind:Floor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grossAreaSqft rdf:type rdf:Property ;
    rdfs:label 'Gross Area Sqft' ;
    rdfs:comment 'Total gross square footage of the floor measured from exterior wall to exterior wall. Used for facility cost allocation and space planning.' ;
    rdfs:domain ind:Floor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maintenanceZone rdf:type rdf:Property ;
    rdfs:label 'Maintenance Zone' ;
    rdfs:comment 'Facilities maintenance zone assignment for work order routing and custodial service scheduling.' ;
    rdfs:domain ind:Floor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mechanicalAreaSqft rdf:type rdf:Property ;
    rdfs:label 'Mechanical Area Sqft' ;
    rdfs:comment 'Square footage occupied by mechanical systems, HVAC equipment, electrical rooms, and building service areas on the floor.' ;
    rdfs:domain ind:Floor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:naturalLightAvailability rdf:type rdf:Property ;
    rdfs:label 'Natural Light Availability' ;
    rdfs:comment 'Assessment of natural daylight availability on the floor. Impacts energy efficiency, occupant well-being, and space desirability.' ;
    rdfs:domain ind:Floor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netAssignableAreaSqft rdf:type rdf:Property ;
    rdfs:label 'Net Assignable Area Sqft' ;
    rdfs:comment 'Net assignable square footage available for functional use, excluding circulation, mechanical, and structural spaces. Used for Facilities and Administrative (F&A) cost rate calculations.' ;
    rdfs:domain ind:Floor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:occupancyCapacity rdf:type rdf:Property ;
    rdfs:label 'Occupancy Capacity' ;
    rdfs:comment 'Maximum number of occupants permitted on the floor based on building code, fire safety regulations, and egress capacity. Used for emergency planning.' ;
    rdfs:domain ind:Floor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:roomCount rdf:type rdf:Property ;
    rdfs:label 'Room Count' ;
    rdfs:comment 'Total number of individual rooms or spaces on the floor. Used for space inventory and utilization tracking.' ;
    rdfs:domain ind:Floor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:securityZone rdf:type rdf:Property ;
    rdfs:label 'Security Zone' ;
    rdfs:comment 'Security access control zone designation. Determines access card permissions, surveillance coverage, and security protocols.' ;
    rdfs:domain ind:Floor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usableAreaSqft rdf:type rdf:Property ;
    rdfs:label 'Usable Area Sqft' ;
    rdfs:comment 'Usable square footage including assignable space plus circulation areas on the floor. Excludes only major vertical penetrations and building service areas.' ;
    rdfs:domain ind:Floor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvalLevel rdf:type rdf:Property ;
    rdfs:label 'Approval Level' ;
    rdfs:comment 'Organizational level required to approve work orders created from this template.' ;
    rdfs:domain ind:WorkOrderTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetTypeApplicable rdf:type rdf:Property ;
    rdfs:label 'Asset Type Applicable' ;
    rdfs:comment 'Type of facility asset or equipment this template is designed for (e.g., HVAC Unit, Elevator, Boiler, Roof).' ;
    rdfs:domain ind:WorkOrderTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:buildingSystem rdf:type rdf:Property ;
    rdfs:label 'Building System' ;
    rdfs:comment 'Building system or infrastructure category this template applies to (e.g., Mechanical, Electrical, Plumbing, Structural, Life Safety).' ;
    rdfs:domain ind:WorkOrderTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:category rdf:type rdf:Property ;
    rdfs:label 'Category' ;
    rdfs:comment 'Functional category or discipline of work (e.g., HVAC, Electrical, Plumbing, Grounds, Custodial).' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checklistItems rdf:type rdf:Property ;
    rdfs:label 'Checklist Items' ;
    rdfs:comment 'List of inspection or completion checklist items to be verified during work order execution.' ;
    rdfs:domain ind:WorkOrderTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedDurationHours rdf:type rdf:Property ;
    rdfs:label 'Estimated Duration Hours' ;
    rdfs:comment 'Expected time in hours required to complete work orders created from this template.' ;
    rdfs:domain ind:WorkOrderTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:laborHoursRequired rdf:type rdf:Property ;
    rdfs:label 'Labor Hours Required' ;
    rdfs:comment 'Standard labor hours required to complete work orders created from this template.' ;
    rdfs:domain ind:WorkOrderTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:materialsRequired rdf:type rdf:Property ;
    rdfs:label 'Materials Required' ;
    rdfs:comment 'List of materials, parts, or supplies typically required for work orders created from this template.' ;
    rdfs:domain ind:WorkOrderTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationRecipients rdf:type rdf:Property ;
    rdfs:label 'Notification Recipients' ;
    rdfs:comment 'List of roles or individuals who should be notified when work orders are created from this template.' ;
    rdfs:domain ind:WorkOrderTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:permitType rdf:type rdf:Property ;
    rdfs:label 'Permit Type' ;
    rdfs:comment 'Type of permit required if applicable (e.g., Hot Work, Confined Space, Electrical Lockout).' ;
    rdfs:domain ind:WorkOrderTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiresDowntime rdf:type rdf:Property ;
    rdfs:label 'Requires Downtime' ;
    rdfs:comment 'Indicates whether work orders from this template require facility or system downtime.' ;
    rdfs:domain ind:WorkOrderTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiresPermit rdf:type rdf:Property ;
    rdfs:label 'Requires Permit' ;
    rdfs:comment 'Indicates whether work orders from this template require a work permit or authorization before execution.' ;
    rdfs:domain ind:WorkOrderTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:skillLevelRequired rdf:type rdf:Property ;
    rdfs:label 'Skill Level Required' ;
    rdfs:comment 'Minimum skill or certification level required for personnel assigned to work orders from this template.' ;
    rdfs:domain ind:WorkOrderTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaCompletionHours rdf:type rdf:Property ;
    rdfs:label 'Sla Completion Hours' ;
    rdfs:comment 'Target completion time in hours for work orders created from this template per service level agreement.' ;
    rdfs:domain ind:WorkOrderTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:slaResponseHours rdf:type rdf:Property ;
    rdfs:label 'Sla Response Hours' ;
    rdfs:comment 'Target response time in hours for work orders created from this template per service level agreement.' ;
    rdfs:domain ind:WorkOrderTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:spaceTypeApplicable rdf:type rdf:Property ;
    rdfs:label 'Space Type Applicable' ;
    rdfs:comment 'Type of campus space this template is designed for (e.g., Classroom, Laboratory, Residence Hall, Office, Athletic Facility).' ;
    rdfs:domain ind:WorkOrderTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardProcedures rdf:type rdf:Property ;
    rdfs:label 'Standard Procedures' ;
    rdfs:comment 'Detailed step-by-step procedures or instructions for completing work orders based on this template.' ;
    rdfs:domain ind:WorkOrderTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:templateDescription rdf:type rdf:Property ;
    rdfs:label 'Template Description' ;
    rdfs:comment 'Detailed description of the work order template including scope, procedures, and expected outcomes.' ;
    rdfs:domain ind:WorkOrderTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:toolsRequired rdf:type rdf:Property ;
    rdfs:label 'Tools Required' ;
    rdfs:comment 'List of tools and equipment required to complete work orders based on this template.' ;
    rdfs:domain ind:WorkOrderTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradeSpecialty rdf:type rdf:Property ;
    rdfs:label 'Trade Specialty' ;
    rdfs:comment 'Specific trade or craft specialty required to execute work orders from this template (e.g., Electrician, Plumber, Carpenter).' ;
    rdfs:domain ind:WorkOrderTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workType rdf:type rdf:Property ;
    rdfs:label 'Work Type' ;
    rdfs:comment 'Classification of the type of work this template represents.' ;
    rdfs:domain ind:WorkOrderTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:comparisonPeriodId rdf:type rdf:Property ;
    rdfs:label 'Comparison Period Id' ;
    rdfs:comment 'Reference to a prior survey period used for year-over-year or period-over-period comparative analysis.' ;
    rdfs:domain ind:SurveyPeriod ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SurveyPeriod .

ind:archibusIntegrationFlag rdf:type rdf:Property ;
    rdfs:label 'Archibus Integration Flag' ;
    rdfs:comment 'Indicates whether this survey period data is integrated with or sourced from the Archibus facilities management system.' ;
    rdfs:domain ind:SurveyPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:baselinePeriodFlag rdf:type rdf:Property ;
    rdfs:label 'Baseline Period Flag' ;
    rdfs:comment 'Indicates whether this survey period serves as a baseline reference for future comparative analysis and trend reporting.' ;
    rdfs:domain ind:SurveyPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:certificationRequired rdf:type rdf:Property ;
    rdfs:label 'Certification Required' ;
    rdfs:comment 'Indicates whether formal certification or sign-off by authorized personnel is required for survey data collected during this period.' ;
    rdfs:domain ind:SurveyPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:faCostRateFlag rdf:type rdf:Property ;
    rdfs:label 'Fa Cost Rate Flag' ;
    rdfs:comment 'Indicates whether this survey period is used for F&A cost rate calculations and space allocation for federal indirect cost recovery.' ;
    rdfs:domain ind:SurveyPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryReportingFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reporting Flag' ;
    rdfs:comment 'Indicates whether this survey period is used for mandatory regulatory or governmental reporting (e.g., IPEDS, state facilities reports).' ;
    rdfs:domain ind:SurveyPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reportingTerm rdf:type rdf:Property ;
    rdfs:label 'Reporting Term' ;
    rdfs:comment 'The academic or calendar term designation for this survey period, used for cyclical reporting requirements.' ;
    rdfs:domain ind:SurveyPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surveyCoordinatorEmail rdf:type rdf:Property ;
    rdfs:label 'Survey Coordinator Email' ;
    rdfs:comment 'The email address of the survey coordinator for communication and coordination purposes.' ;
    rdfs:domain ind:SurveyPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surveyCoordinatorName rdf:type rdf:Property ;
    rdfs:label 'Survey Coordinator Name' ;
    rdfs:comment 'The name of the individual serving as the primary coordinator or point of contact for this survey period.' ;
    rdfs:domain ind:SurveyPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crewId rdf:type rdf:Property ;
    rdfs:label 'Crew Id' ;
    rdfs:comment 'Primary key for crew' ;
    rdfs:domain ind:Crew ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:homeBuildingId rdf:type rdf:Property ;
    rdfs:label 'Home Building Id' ;
    rdfs:comment 'Identifier of the primary building or facility where the crew is based.' ;
    rdfs:domain ind:Crew ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Building .

ind:activeWorkOrderCount rdf:type rdf:Property ;
    rdfs:label 'Active Work Order Count' ;
    rdfs:comment 'Current number of open work orders assigned to the crew, used for workload balancing and capacity planning.' ;
    rdfs:domain ind:Crew ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:adaComplianceTrained rdf:type rdf:Property ;
    rdfs:label 'Ada Compliance Trained' ;
    rdfs:comment 'Indicates whether crew members have received training on ADA accessibility requirements and compliance standards for facility modifications and maintenance.' ;
    rdfs:domain ind:Crew ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:averageWorkOrderCompletionDays rdf:type rdf:Property ;
    rdfs:label 'Average Work Order Completion Days' ;
    rdfs:comment 'Mean number of days the crew takes to complete assigned work orders, used as a key performance indicator (KPI) for crew efficiency.' ;
    rdfs:domain ind:Crew ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:certificationRequirements rdf:type rdf:Property ;
    rdfs:label 'Certification Requirements' ;
    rdfs:comment 'List of required certifications, licenses, or training credentials that crew members must hold (e.g., \'EPA 608 Universal\', \'Licensed Electrician\', \'Forklift Operator\', \'Asbestos Awareness\').' ;
    rdfs:domain ind:Crew ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crewCode rdf:type rdf:Property ;
    rdfs:label 'Crew Code' ;
    rdfs:comment 'Externally-known unique alphanumeric code assigned to the crew for identification in work orders and scheduling systems.' ;
    rdfs:domain ind:Crew ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crewName rdf:type rdf:Property ;
    rdfs:label 'Crew Name' ;
    rdfs:comment 'Human-readable name of the crew (e.g., \'HVAC Maintenance Team A\', \'Electrical Services Crew 3\').' ;
    rdfs:domain ind:Crew ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crewSize rdf:type rdf:Property ;
    rdfs:label 'Crew Size' ;
    rdfs:comment 'Number of personnel assigned to the crew.' ;
    rdfs:domain ind:Crew ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:crewStatus rdf:type rdf:Property ;
    rdfs:label 'Crew Status' ;
    rdfs:comment 'Current operational status of the crew in its lifecycle.' ;
    rdfs:domain ind:Crew ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crewType rdf:type rdf:Property ;
    rdfs:label 'Crew Type' ;
    rdfs:comment 'Classification of the crew based on primary function: maintenance (HVAC, electrical, plumbing), custodial (cleaning, sanitation), grounds (landscaping, snow removal), utilities (energy systems), construction (capital projects), or emergency response (safety, incident management).' ;
    rdfs:domain ind:Crew ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emergencyResponseCapable rdf:type rdf:Property ;
    rdfs:label 'Emergency Response Capable' ;
    rdfs:comment 'Indicates whether the crew is trained and equipped to respond to emergency situations (e.g., power outages, water leaks, HVAC failures, safety incidents).' ;
    rdfs:domain ind:Crew ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:equipmentAssigned rdf:type rdf:Property ;
    rdfs:label 'Equipment Assigned' ;
    rdfs:comment 'Major tools, vehicles, or equipment permanently assigned to the crew (e.g., \'Truck #45\', \'Scissor Lift\', \'Welding Kit\').' ;
    rdfs:domain ind:Crew ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hourlyLaborRate rdf:type rdf:Property ;
    rdfs:label 'Hourly Labor Rate' ;
    rdfs:comment 'Standard blended hourly labor rate for the crew used in work order costing and Facilities and Administrative (F&A) cost calculations.' ;
    rdfs:domain ind:Crew ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastSafetyTrainingDate rdf:type rdf:Property ;
    rdfs:label 'Last Safety Training Date' ;
    rdfs:comment 'Date when the crew last completed mandatory safety training, used to track compliance with OSHA and institutional safety requirements.' ;
    rdfs:domain ind:Crew ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:overtimeEligible rdf:type rdf:Property ;
    rdfs:label 'Overtime Eligible' ;
    rdfs:comment 'Indicates whether crew members are eligible for overtime compensation under Fair Labor Standards Act (FLSA) regulations.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:radioChannel rdf:type rdf:Property ;
    rdfs:label 'Radio Channel' ;
    rdfs:comment 'Two-way radio channel or frequency assigned to the crew for field communications.' ;
    rdfs:domain ind:Crew ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyIncidentCount rdf:type rdf:Property ;
    rdfs:label 'Safety Incident Count' ;
    rdfs:comment 'Cumulative number of recordable safety incidents involving this crew, tracked for OSHA reporting and safety performance metrics.' ;
    rdfs:domain ind:Crew ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:serviceArea rdf:type rdf:Property ;
    rdfs:label 'Service Area' ;
    rdfs:comment 'Geographic or functional area of campus that the crew is responsible for servicing (e.g., \'North Campus\', \'Medical Center Complex\', \'Athletic Facilities\').' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shiftEndTime rdf:type rdf:Property ;
    rdfs:label 'Shift End Time' ;
    rdfs:comment 'Standard end time for the crew\'s work shift in HH:MM format (24-hour clock).' ;
    rdfs:domain ind:Crew ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shiftSchedule rdf:type rdf:Property ;
    rdfs:label 'Shift Schedule' ;
    rdfs:comment 'Primary work shift pattern for the crew.' ;
    rdfs:domain ind:Crew ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shiftStartTime rdf:type rdf:Property ;
    rdfs:label 'Shift Start Time' ;
    rdfs:comment 'Standard start time for the crew\'s work shift in HH:MM format (24-hour clock).' ;
    rdfs:domain ind:Crew ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialization rdf:type rdf:Property ;
    rdfs:label 'Specialization' ;
    rdfs:comment 'Specific technical specialization or trade expertise of the crew (e.g., \'HVAC Systems\', \'Electrical Distribution\', \'Plumbing and Piping\', \'Carpentry\', \'Locksmith Services\').' ;
    rdfs:domain ind:Crew ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Approved By User Employee Id' ;
    rdfs:comment 'Identifier of the user who approved the payment batch.' ;
    rdfs:domain ind:PaymentBatch ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:modifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Modified By User Employee Id' ;
    rdfs:comment 'Identifier of the user who last modified the payment batch.' ;
    rdfs:domain ind:PaymentBatch ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:parentBatchId rdf:type rdf:Property ;
    rdfs:label 'Parent Batch Id' ;
    rdfs:comment 'Identifier of the parent payment batch if this batch is a split or child batch derived from a larger batch.' ;
    rdfs:domain ind:PaymentBatch ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PaymentBatch .

ind:reconciledByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Reconciled By User Employee Id' ;
    rdfs:comment 'Identifier of the user who performed the reconciliation of the payment batch.' ;
    rdfs:domain ind:PaymentBatch ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualProcessingTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Processing Timestamp' ;
    rdfs:comment 'The actual date and time when the payment batch processing was initiated.' ;
    rdfs:domain ind:PaymentBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:batchDescription rdf:type rdf:Property ;
    rdfs:label 'Batch Description' ;
    rdfs:comment 'Free-text description providing additional context or purpose for the payment batch.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:batchNumber rdf:type rdf:Property ;
    rdfs:label 'Batch Number' ;
    rdfs:comment 'Externally-known unique identifier for the payment batch, used for tracking and reconciliation across systems.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:batchType rdf:type rdf:Property ;
    rdfs:label 'Batch Type' ;
    rdfs:comment 'Classification of the payment batch based on the nature of payments included (e.g., payroll, vendor payments, student refunds, grant disbursements).' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:completedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Completed Timestamp' ;
    rdfs:comment 'Date and time when the payment batch processing was completed successfully.' ;
    rdfs:domain ind:PaymentBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:failedPaymentCount rdf:type rdf:Property ;
    rdfs:label 'Failed Payment Count' ;
    rdfs:comment 'The number of payment transactions that failed during processing in this batch.' ;
    rdfs:domain ind:PaymentBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:originatingSystem rdf:type rdf:Property ;
    rdfs:label 'Originating System' ;
    rdfs:comment 'The name or identifier of the source system that created or submitted the payment batch (e.g., PeopleSoft Financials, Workday, Banner).' ;
    rdfs:domain ind:PaymentBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiresDualApproval rdf:type rdf:Property ;
    rdfs:label 'Requires Dual Approval' ;
    rdfs:comment 'Boolean flag indicating whether the payment batch requires approval from two authorized users before processing.' ;
    rdfs:domain ind:PaymentBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scheduledProcessingDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Processing Date' ;
    rdfs:comment 'The date on which the payment batch is scheduled to be processed and payments disbursed.' ;
    rdfs:domain ind:PaymentBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:successfulPaymentCount rdf:type rdf:Property ;
    rdfs:label 'Successful Payment Count' ;
    rdfs:comment 'The number of payment transactions that were successfully processed in this batch.' ;
    rdfs:domain ind:PaymentBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalBatchAmount rdf:type rdf:Property ;
    rdfs:label 'Total Batch Amount' ;
    rdfs:comment 'The total monetary value of all payments included in this batch before any adjustments.' ;
    rdfs:domain ind:PaymentBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalPaymentCount rdf:type rdf:Property ;
    rdfs:label 'Total Payment Count' ;
    rdfs:comment 'The total number of individual payment transactions included in this batch.' ;
    rdfs:domain ind:PaymentBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:n1098tEligibleFlag rdf:type rdf:Property ;
    rdfs:label '1098t Eligible Flag' ;
    rdfs:comment 'Indicates whether the customer is eligible to receive IRS Form 1098-T Tuition Statement for tax reporting purposes. Based on enrollment status and qualified tuition payments.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:authorizedUserEmail rdf:type rdf:Property ;
    rdfs:label 'Authorized User Email' ;
    rdfs:comment 'Email address of an authorized third party (parent, guardian, sponsor) who may view billing statements and make payments on behalf of the customer. Requires FERPA authorization.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditLimitAmount rdf:type rdf:Property ;
    rdfs:label 'Credit Limit Amount' ;
    rdfs:comment 'Maximum outstanding balance allowed for this customer before holds are applied. Used for tuition payment plans and departmental charges.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:currentBalanceAmount rdf:type rdf:Property ;
    rdfs:label 'Current Balance Amount' ;
    rdfs:comment 'Current outstanding balance on the customer account. Positive values indicate amounts owed to the institution; negative values indicate credit balances.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:customerStatus rdf:type rdf:Property ;
    rdfs:label 'Customer Status' ;
    rdfs:comment 'Current lifecycle status of the customer account. Controls billing eligibility, payment processing, and account access. Hold status prevents registration and transcript release.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerType rdf:type rdf:Property ;
    rdfs:label 'Customer Type' ;
    rdfs:comment 'Classification of the customer relationship to the institution. Determines applicable billing rules, payment terms, and financial policies.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paperlessBillingFlag rdf:type rdf:Property ;
    rdfs:label 'Paperless Billing Flag' ;
    rdfs:comment 'Indicates whether the customer has opted for electronic billing statements instead of paper invoices.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:paymentPlanEnrolledFlag rdf:type rdf:Property ;
    rdfs:label 'Payment Plan Enrolled Flag' ;
    rdfs:comment 'Indicates whether the customer is enrolled in an installment payment plan for tuition and fees.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:paymentTermsCode rdf:type rdf:Property ;
    rdfs:label 'Payment Terms Code' ;
    rdfs:comment 'Standard payment terms applicable to this customer. Defines due dates, installment options, and late payment policies.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredPaymentMethod rdf:type rdf:Property ;
    rdfs:label 'Preferred Payment Method' ;
    rdfs:comment 'Customer\'s preferred payment instrument for tuition and fee payments.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:veteranStatusFlag rdf:type rdf:Property ;
    rdfs:label 'Veteran Status Flag' ;
    rdfs:comment 'Indicates whether the customer is a military veteran or active duty service member. Determines eligibility for VA education benefits and veteran-specific financial aid programs.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deanEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Dean Employee Id' ;
    rdfs:comment 'Reference to the employee serving as dean or chief academic officer of the college or school.' ;
    rdfs:domain ind:CollegeSchool ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:parentOrganizationId rdf:type rdf:Property ;
    rdfs:label 'Parent Organization Id' ;
    rdfs:comment 'Reference to the parent organizational unit if this college or school reports to another organizational entity within the institution hierarchy.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Organization .

ind:administrativeContactEmail rdf:type rdf:Property ;
    rdfs:label 'Administrative Contact Email' ;
    rdfs:comment 'Primary email address for administrative inquiries and correspondence for the college or school.' ;
    rdfs:domain ind:CollegeSchool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:administrativeContactName rdf:type rdf:Property ;
    rdfs:label 'Administrative Contact Name' ;
    rdfs:comment 'Name of the primary administrative contact person for the college or school.' ;
    rdfs:domain ind:CollegeSchool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:administrativeContactPhone rdf:type rdf:Property ;
    rdfs:label 'Administrative Contact Phone' ;
    rdfs:comment 'Primary phone number for administrative contact for the college or school.' ;
    rdfs:domain ind:CollegeSchool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetEntityCode rdf:type rdf:Property ;
    rdfs:label 'Budget Entity Code' ;
    rdfs:comment 'Budget entity code used for institutional budgeting and planning processes for the college or school.' ;
    rdfs:domain ind:CollegeSchool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endowmentBalanceAmount rdf:type rdf:Property ;
    rdfs:label 'Endowment Balance Amount' ;
    rdfs:comment 'Total market value of endowment funds held specifically for the benefit of the college or school.' ;
    rdfs:domain ind:CollegeSchool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:facultyCount rdf:type rdf:Property ;
    rdfs:label 'Faculty Count' ;
    rdfs:comment 'Current total number of faculty members (full-time and part-time) employed by the college or school.' ;
    rdfs:domain ind:CollegeSchool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fiscalYearBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Fiscal Year Budget Amount' ;
    rdfs:comment 'Total approved operating budget amount for the college or school for the current fiscal year.' ;
    rdfs:domain ind:CollegeSchool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isGraduateProgramsOffered rdf:type rdf:Property ;
    rdfs:label 'Is Graduate Programs Offered' ;
    rdfs:comment 'Indicates whether the college or school offers graduate-level degree programs (masters, doctoral, professional).' ;
    rdfs:domain ind:CollegeSchool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isOnlineProgramsOffered rdf:type rdf:Property ;
    rdfs:label 'Is Online Programs Offered' ;
    rdfs:comment 'Indicates whether the college or school offers fully online degree or certificate programs.' ;
    rdfs:domain ind:CollegeSchool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isUndergraduateProgramsOffered rdf:type rdf:Property ;
    rdfs:label 'Is Undergraduate Programs Offered' ;
    rdfs:comment 'Indicates whether the college or school offers undergraduate degree programs (associate, bachelors).' ;
    rdfs:domain ind:CollegeSchool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:physicalAddressCity rdf:type rdf:Property ;
    rdfs:label 'Physical Address City' ;
    rdfs:comment 'City where the college or school administrative offices are physically located.' ;
    rdfs:domain ind:CollegeSchool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:physicalAddressCountryCode rdf:type rdf:Property ;
    rdfs:label 'Physical Address Country Code' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code for the physical address of the college or school.' ;
    rdfs:domain ind:CollegeSchool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:physicalAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Physical Address Line1' ;
    rdfs:comment 'First line of the physical street address where the college or school administrative offices are located.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:physicalAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Physical Address Line2' ;
    rdfs:comment 'Second line of the physical street address (suite, building, floor) for the college or school administrative offices.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:physicalAddressPostalCode rdf:type rdf:Property ;
    rdfs:label 'Physical Address Postal Code' ;
    rdfs:comment 'Postal or ZIP code for the physical address of the college or school administrative offices.' ;
    rdfs:domain ind:CollegeSchool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:physicalAddressStateProvince rdf:type rdf:Property ;
    rdfs:label 'Physical Address State Province' ;
    rdfs:comment 'State or province where the college or school administrative offices are physically located.' ;
    rdfs:domain ind:CollegeSchool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:type rdf:type rdf:Property ;
    rdfs:label 'Type' ;
    rdfs:comment 'Classification of the organizational unit (college, school, division, institute, center, or faculty).' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentDivisionId rdf:type rdf:Property ;
    rdfs:label 'Parent Division Id' ;
    rdfs:comment 'Reference to the parent division in the organizational hierarchy. Null for top-level divisions.' ;
    rdfs:domain ind:Division ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Division .

ind:budgetAuthorityLevel rdf:type rdf:Property ;
    rdfs:label 'Budget Authority Level' ;
    rdfs:comment 'Level of budgetary authority granted to the division for financial planning and expenditure approval.' ;
    rdfs:domain ind:Division ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deanName rdf:type rdf:Property ;
    rdfs:label 'Dean Name' ;
    rdfs:comment 'Name of the dean, director, or senior administrator responsible for leading the division.' ;
    rdfs:domain ind:Division ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:departmentCount rdf:type rdf:Property ;
    rdfs:label 'Department Count' ;
    rdfs:comment 'Number of departments or units that report to this division.' ;
    rdfs:domain ind:Division ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:divisionAbbreviation rdf:type rdf:Property ;
    rdfs:label 'Division Abbreviation' ;
    rdfs:comment 'Shortened form of the division name used in reports and communications.' ;
    rdfs:domain ind:Division ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:divisionCode rdf:type rdf:Property ;
    rdfs:label 'Division Code' ;
    rdfs:comment 'Short alphanumeric code used to identify the division in financial transactions and reports. Externally-known business identifier.' ;
    rdfs:domain ind:Division ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:divisionName rdf:type rdf:Property ;
    rdfs:label 'Division Name' ;
    rdfs:comment 'Full official name of the division as used in organizational charts and financial statements.' ;
    rdfs:domain ind:Division ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:divisionType rdf:type rdf:Property ;
    rdfs:label 'Division Type' ;
    rdfs:comment 'Classification of the division by its primary functional area within the institution.' ;
    rdfs:domain ind:Division ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employeeHeadcount rdf:type rdf:Property ;
    rdfs:label 'Employee Headcount' ;
    rdfs:comment 'Total number of employees (faculty and staff) assigned to this division.' ;
    rdfs:domain ind:Division ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:endowmentFundBalance rdf:type rdf:Property ;
    rdfs:label 'Endowment Fund Balance' ;
    rdfs:comment 'Total balance of endowment funds specifically designated for this division. Expressed in institutional base currency.' ;
    rdfs:domain ind:Division ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fiscalResponsibilityFlag rdf:type rdf:Property ;
    rdfs:label 'Fiscal Responsibility Flag' ;
    rdfs:comment 'Indicates whether the division has direct fiscal responsibility and accountability for its budget.' ;
    rdfs:domain ind:Division ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:physicalCity rdf:type rdf:Property ;
    rdfs:label 'Physical City' ;
    rdfs:comment 'City where the division administrative office is located.' ;
    rdfs:domain ind:Division ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:physicalCountryCode rdf:type rdf:Property ;
    rdfs:label 'Physical Country Code' ;
    rdfs:comment 'Three-letter ISO country code for the division administrative office location.' ;
    rdfs:domain ind:Division ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:physicalPostalCode rdf:type rdf:Property ;
    rdfs:label 'Physical Postal Code' ;
    rdfs:comment 'Postal code (ZIP code) for the division administrative office location.' ;
    rdfs:domain ind:Division ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:physicalStateProvince rdf:type rdf:Property ;
    rdfs:label 'Physical State Province' ;
    rdfs:comment 'Two-letter state or province code where the division administrative office is located.' ;
    rdfs:domain ind:Division ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:journalBatchId rdf:type rdf:Property ;
    rdfs:label 'Journal Batch Id' ;
    rdfs:comment 'Primary key for journal_batch' ;
    rdfs:domain ind:JournalBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:businessUnitId rdf:type rdf:Property ;
    rdfs:label 'Business Unit Id' ;
    rdfs:comment 'Reference to the business unit, department, or organizational entity responsible for creating or owning this journal batch.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BusinessUnit .

ind:postedByUserIdentityAccountId rdf:type rdf:Property ;
    rdfs:label 'Posted By User Identity Account Id' ;
    rdfs:comment 'Reference to the user who posted this journal batch to the general ledger, supporting audit trail requirements.' ;
    rdfs:domain ind:JournalBatch ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IdentityAccount .

ind:recurringScheduleId rdf:type rdf:Property ;
    rdfs:label 'Recurring Schedule Id' ;
    rdfs:comment 'Reference to the recurring schedule definition that generated this batch, applicable only for recurring journal batches.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RecurringSchedule .

ind:batchDate rdf:type rdf:Property ;
    rdfs:label 'Batch Date' ;
    rdfs:comment 'The business date assigned to the journal batch, representing when the batch is effective for accounting purposes. This is the principal business event date for the batch.' ;
    rdfs:domain ind:JournalBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:batchName rdf:type rdf:Property ;
    rdfs:label 'Batch Name' ;
    rdfs:comment 'Descriptive name or title assigned to the journal batch for identification and categorization purposes.' ;
    rdfs:domain ind:JournalBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:batchSource rdf:type rdf:Property ;
    rdfs:label 'Batch Source' ;
    rdfs:comment 'Origin or method by which the journal batch was created. Manual indicates user-entered batches, automated indicates system-generated batches from business rules, interface indicates batches from integrated systems, import indicates batches loaded from external files, conversion indicates batches from legacy system migration, and system generated indicates batches created by scheduled processes.' ;
    rdfs:domain ind:JournalBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:batchStatus rdf:type rdf:Property ;
    rdfs:label 'Batch Status' ;
    rdfs:comment 'Current lifecycle status of the journal batch. Draft indicates initial creation, pending approval indicates submission for review, approved indicates authorization for posting, posted indicates successful posting to the general ledger, rejected indicates denial of approval, and cancelled indicates withdrawal from processing.' ;
    rdfs:domain ind:JournalBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlTotalAmount rdf:type rdf:Property ;
    rdfs:label 'Control Total Amount' ;
    rdfs:comment 'Optional control total entered by the user at batch creation time, used to validate that the sum of journal entries matches the expected total.' ;
    rdfs:domain ind:JournalBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:entryCount rdf:type rdf:Property ;
    rdfs:label 'Entry Count' ;
    rdfs:comment 'The total number of individual journal entries contained within this batch, used for control and reconciliation purposes.' ;
    rdfs:domain ind:JournalBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isBalanced rdf:type rdf:Property ;
    rdfs:label 'Is Balanced' ;
    rdfs:comment 'Indicates whether the journal batch is in balance, meaning total debits equal total credits. True indicates balanced, False indicates out of balance.' ;
    rdfs:domain ind:JournalBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lineCount rdf:type rdf:Property ;
    rdfs:label 'Line Count' ;
    rdfs:comment 'The total number of individual journal lines across all entries in this batch, used for control and reconciliation purposes.' ;
    rdfs:domain ind:JournalBatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:credentialAwarded rdf:type rdf:Property ;
    rdfs:label 'Credential Awarded' ;
    rdfs:comment 'The specific credential, degree, or certificate awarded upon program completion (e.g., Bachelor of Science, Master of Business Administration, Graduate Certificate).' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:internationalStudentEligible rdf:type rdf:Property ;
    rdfs:label 'International Student Eligible' ;
    rdfs:comment 'Flag indicating whether this program is approved for enrollment by international students on F-1 or J-1 visas.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:onlineEligible rdf:type rdf:Property ;
