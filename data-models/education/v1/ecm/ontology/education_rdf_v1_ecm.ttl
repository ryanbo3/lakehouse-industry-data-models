    rdfs:domain ind:PracticeSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recruitId rdf:type rdf:Property ;
    rdfs:label 'Recruit Id' ;
    rdfs:comment 'Unique identifier for the prospective student-athlete recruit record. Primary key.' ;
