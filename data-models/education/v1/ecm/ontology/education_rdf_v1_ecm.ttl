    rdfs:comment 'Primary general ledger account number associated with the investment pool in the ERP system.' ;
    rdfs:domain ind:InvestmentPool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inceptionDate rdf:type rdf:Property ;
    rdfs:label 'Inception Date' ;
    rdfs:comment 'Date when the investment pool was established and began operations.' ;
    rdfs:domain ind:InvestmentPool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:investmentManagerName rdf:type rdf:Property ;
    rdfs:label 'Investment Manager Name' ;
    rdfs:comment 'Name of the primary investment management firm responsible for managing the pool.' ;
    rdfs:domain ind:InvestmentPool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investmentStrategy rdf:type rdf:Property ;
    rdfs:label 'Investment Strategy' ;
    rdfs:comment 'Primary investment strategy governing asset allocation and risk tolerance for the pool.' ;
    rdfs:domain ind:InvestmentPool ;
