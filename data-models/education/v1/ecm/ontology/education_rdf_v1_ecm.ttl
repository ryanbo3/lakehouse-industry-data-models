    rdfs:domain ind:EadaReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:eligibilityCertificationId rdf:type rdf:Property ;
    rdfs:label 'Eligibility Certification Id' ;
    rdfs:comment 'Unique identifier for the eligibility certification record. Primary key for this transactional record of NCAA or NAIA eligibility certification conducted for a student-athlete.' ;
    rdfs:domain ind:EligibilityCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:certificationNotes rdf:type rdf:Property ;
    rdfs:label 'Certification Notes' ;
    rdfs:comment 'Additional notes, comments, or documentation related to this eligibility certification, including any special circumstances or conditions.' ;
    rdfs:domain ind:EligibilityCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationNumber rdf:type rdf:Property ;
    rdfs:label 'Certification Number' ;
    rdfs:comment 'Business identifier or reference number assigned to this eligibility certification event. May be used for tracking and audit purposes.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationStatus rdf:type rdf:Property ;
    rdfs:label 'Certification Status' ;
    rdfs:comment 'Current status of the eligibility certification process indicating whether the student-athlete has been certified, denied, or is awaiting review or waiver decision.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationTerm rdf:type rdf:Property ;
    rdfs:label 'Certification Term' ;
    rdfs:comment 'The specific academic term or period for which eligibility is certified (fall, spring, summer, or full academic year).' ;
    rdfs:domain ind:EligibilityCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certifyingOfficialName rdf:type rdf:Property ;
    rdfs:label 'Certifying Official Name' ;
    rdfs:comment 'Full name of the compliance staff member or faculty athletics representative who certified this eligibility determination.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:degreeApplicableCreditsRequired rdf:type rdf:Property ;
    rdfs:label 'Degree Applicable Credits Required' ;
    rdfs:comment 'Minimum number of degree-applicable credit hours required to be earned by this point in the student-athlete\'s academic career for eligibility certification.' ;
    rdfs:domain ind:EligibilityCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gpaRequirementMet rdf:type rdf:Property ;
    rdfs:label 'Gpa Requirement Met' ;
    rdfs:comment 'Flag indicating whether the student-athlete meets the minimum GPA requirement for eligibility.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:initialEligibilityClearanceSource rdf:type rdf:Property ;
    rdfs:label 'Initial Eligibility Clearance Source' ;
    rdfs:comment 'The organization or process that provided initial eligibility clearance for the student-athlete (NCAA Eligibility Center, NAIA Eligibility Center, or institutional review).' ;
    rdfs:domain ind:EligibilityCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumCreditHoursRequired rdf:type rdf:Property ;
    rdfs:label 'Minimum Credit Hours Required' ;
    rdfs:comment 'Minimum number of credit hours required for full-time enrollment status and eligibility certification based on NCAA or NAIA rules.' ;
    rdfs:domain ind:EligibilityCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:waiverCaseReference rdf:type rdf:Property ;
    rdfs:label 'Waiver Case Reference' ;
    rdfs:comment 'Reference number or identifier for any waiver case submitted on behalf of the student-athlete related to this eligibility certification.' ;
    rdfs:domain ind:EligibilityCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilityEventBookingId rdf:type rdf:Property ;
    rdfs:label 'Facility Event Booking Id' ;
    rdfs:comment 'Unique identifier for the facility event booking record. Primary key for this transactional entity.' ;
    rdfs:domain ind:FacilityEventBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:facilityId rdf:type rdf:Property ;
    rdfs:label 'Facility Id' ;
    rdfs:comment 'Reference to the athletic facility being booked (e.g., stadium, arena, practice field, gymnasium, natatorium).' ;
    rdfs:domain ind:Athletics ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AthleticFacility .

ind:primaryFacilityEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Facility Employee Id' ;
    rdfs:comment 'Reference to the staff member who approved this facility booking. Null if approval not yet granted or not required.' ;
    rdfs:domain ind:FacilityEventBooking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:approvalRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Approval Required Flag' ;
    rdfs:comment 'Indicates whether this booking requires administrative or athletic director approval before confirmation.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:approvalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Approval Timestamp' ;
    rdfs:comment 'Date and time when this facility booking was approved. Null if not yet approved or approval not required.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:bookingNumber rdf:type rdf:Property ;
    rdfs:label 'Booking Number' ;
    rdfs:comment 'Externally-visible unique booking reference number assigned to this facility reservation. Format: BK-YYYYMMDD.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bookingStatus rdf:type rdf:Property ;
    rdfs:label 'Booking Status' ;
    rdfs:comment 'Current lifecycle status of the facility booking. Tracks progression from initial request through completion or cancellation.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:broadcastFlag rdf:type rdf:Property ;
    rdfs:label 'Broadcast Flag' ;
    rdfs:comment 'Indicates whether this event will be broadcast or live-streamed (television, radio, or digital platforms).' ;
    rdfs:domain ind:FacilityEventBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cancellationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Cancellation Timestamp' ;
    rdfs:comment 'Date and time when this facility booking was cancelled. Null for non-cancelled bookings.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:cateringRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Catering Required Flag' ;
    rdfs:comment 'Indicates whether catering or food service is required for this event.' ;
    rdfs:domain ind:FacilityEventBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:conferenceGameFlag rdf:type rdf:Property ;
    rdfs:label 'Conference Game Flag' ;
    rdfs:comment 'Indicates whether this event is a conference competition. True for conference games, false otherwise.' ;
    rdfs:domain ind:Athletics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:conflictCheckStatus rdf:type rdf:Property ;
    rdfs:label 'Conflict Check Status' ;
    rdfs:comment 'Status of scheduling conflict verification against other facility bookings and institutional calendar events.' ;
    rdfs:domain ind:FacilityEventBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:depositAmount rdf:type rdf:Property ;
    rdfs:label 'Deposit Amount' ;
    rdfs:comment 'Security deposit or advance payment collected for this facility booking. Expressed in US dollars (USD).' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:durationHours rdf:type rdf:Property ;
    rdfs:label 'Duration Hours' ;
    rdfs:comment 'Total duration of the facility booking in hours, calculated from start to end time.' ;
    rdfs:domain ind:Athletics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:equipmentNeeds rdf:type rdf:Property ;
    rdfs:label 'Equipment Needs' ;
    rdfs:comment 'List of athletic or event equipment required for this booking (e.g., goals, nets, scoreboards, timing systems, audio-visual equipment).' ;
    rdfs:domain ind:FacilityEventBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedAttendance rdf:type rdf:Property ;
    rdfs:label 'Expected Attendance' ;
    rdfs:comment 'Anticipated number of attendees for this event. Used for capacity planning and staffing decisions.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:externalRentalFlag rdf:type rdf:Property ;
    rdfs:label 'External Rental Flag' ;
    rdfs:comment 'Indicates whether this booking is an external rental by a non-university organization generating revenue.' ;
    rdfs:domain ind:FacilityEventBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:homeAwayIndicator rdf:type rdf:Property ;
    rdfs:label 'Home Away Indicator' ;
    rdfs:comment 'Indicates whether this is a home game, away game, or neutral site event. Applicable to competitive athletic events only.' ;
    rdfs:domain ind:FacilityEventBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:opponentName rdf:type rdf:Property ;
    rdfs:label 'Opponent Name' ;
    rdfs:comment 'Name of the opposing team or institution for competitive events. Null for practices, rentals, and non-competitive events.' ;
    rdfs:domain ind:Athletics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parkingAllocationCount rdf:type rdf:Property ;
    rdfs:label 'Parking Allocation Count' ;
    rdfs:comment 'Number of parking spaces allocated or reserved for this event.' ;
    rdfs:domain ind:FacilityEventBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:postseasonFlag rdf:type rdf:Property ;
    rdfs:label 'Postseason Flag' ;
    rdfs:comment 'Indicates whether this event is part of postseason competition (playoffs, championships, tournaments).' ;
    rdfs:domain ind:FacilityEventBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rentalRevenueAmount rdf:type rdf:Property ;
    rdfs:label 'Rental Revenue Amount' ;
    rdfs:comment 'Total revenue generated from external facility rental. Null for internal university use. Expressed in US dollars (USD).' ;
    rdfs:domain ind:FacilityEventBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:requestingContactEmail rdf:type rdf:Property ;
    rdfs:label 'Requesting Contact Email' ;
    rdfs:comment 'Email address of the primary contact person for this facility booking.' ;
    rdfs:domain ind:FacilityEventBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestingContactName rdf:type rdf:Property ;
    rdfs:label 'Requesting Contact Name' ;
    rdfs:comment 'Full name of the primary contact person responsible for this booking request.' ;
    rdfs:domain ind:FacilityEventBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestingContactPhone rdf:type rdf:Property ;
    rdfs:label 'Requesting Contact Phone' ;
    rdfs:comment 'Phone number of the primary contact person for this facility booking.' ;
    rdfs:domain ind:FacilityEventBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestingOrganizationName rdf:type rdf:Property ;
    rdfs:label 'Requesting Organization Name' ;
    rdfs:comment 'Name of the organization, department, or external entity requesting the facility booking. Used for non-team bookings such as external rentals or university events.' ;
    rdfs:domain ind:FacilityEventBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:securityRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Security Required Flag' ;
    rdfs:comment 'Indicates whether additional security personnel or campus police presence is required for this event.' ;
    rdfs:domain ind:FacilityEventBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:setupRequirements rdf:type rdf:Property ;
    rdfs:label 'Setup Requirements' ;
    rdfs:comment 'Detailed description of facility setup needs including seating configuration, staging, lighting, sound system, and other special arrangements.' ;
    rdfs:domain ind:FacilityEventBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialInstructions rdf:type rdf:Property ;
    rdfs:label 'Special Instructions' ;
    rdfs:comment 'Additional notes, requirements, or special considerations for this facility booking.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ticketedEventFlag rdf:type rdf:Property ;
    rdfs:label 'Ticketed Event Flag' ;
    rdfs:comment 'Indicates whether this event requires ticketing and admission control.' ;
    rdfs:domain ind:FacilityEventBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gameId rdf:type rdf:Property ;
    rdfs:label 'Game Id' ;
    rdfs:comment 'Unique identifier for the athletic contest. Primary key.' ;
    rdfs:domain ind:Athletics ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Game .

ind:rescheduledGameId rdf:type rdf:Property ;
    rdfs:label 'Rescheduled Game Id' ;
    rdfs:comment 'Reference to the new game record if this game was rescheduled.' ;
    rdfs:domain ind:Game ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Game .

ind:attendance rdf:type rdf:Property ;
    rdfs:label 'Attendance' ;
    rdfs:comment 'Number of spectators who attended the game.' ;
    rdfs:domain ind:Game ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:awayTeamScore rdf:type rdf:Property ;
    rdfs:label 'Away Team Score' ;
    rdfs:comment 'Final score for the away team. Null if game not completed.' ;
    rdfs:domain ind:Game ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:broadcastNetwork rdf:type rdf:Property ;
    rdfs:label 'Broadcast Network' ;
    rdfs:comment 'Television or streaming network broadcasting the game (e.g., ESPN, CBS Sports, conference network).' ;
    rdfs:domain ind:Game ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:broadcastType rdf:type rdf:Property ;
    rdfs:label 'Broadcast Type' ;
    rdfs:comment 'Type of media broadcast for the game (television, streaming, radio, none).' ;
    rdfs:domain ind:Game ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:datetime rdf:type rdf:Property ;
    rdfs:label 'Datetime' ;
    rdfs:comment 'Combined scheduled date and time of the game as a timestamp in yyyy-MM-ddTHH:mm:ss.SSSXXX format.' ;
    rdfs:domain ind:Game ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:gameDate rdf:type rdf:Property ;
    rdfs:label 'Game Date' ;
    rdfs:comment 'Scheduled date of the athletic contest in yyyy-MM-dd format.' ;
    rdfs:domain ind:Game ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:gameNumber rdf:type rdf:Property ;
    rdfs:label 'Game Number' ;
    rdfs:comment 'Business identifier for the game, often used in schedules and communications (e.g., G-2024-001).' ;
    rdfs:domain ind:Game ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gameStatus rdf:type rdf:Property ;
    rdfs:label 'Game Status' ;
    rdfs:comment 'Current status of the game in its lifecycle (scheduled, in progress, completed, cancelled, postponed, forfeited).' ;
    rdfs:domain ind:Game ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gameTime rdf:type rdf:Property ;
    rdfs:label 'Game Time' ;
    rdfs:comment 'Scheduled start time of the game (e.g., 7:00 PM, 14:30).' ;
    rdfs:domain ind:Game ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:gameType rdf:type rdf:Property ;
    rdfs:label 'Game Type' ;
    rdfs:comment 'Classification of the game (regular season, conference, non-conference, exhibition, scrimmage, postseason, tournament).' ;
    rdfs:domain ind:Game ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headOfficialName rdf:type rdf:Property ;
    rdfs:label 'Head Official Name' ;
    rdfs:comment 'Name of the head referee or umpire for the game.' ;
    rdfs:domain ind:Game ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:homeAwayNeutral rdf:type rdf:Property ;
    rdfs:label 'Home Away Neutral' ;
    rdfs:comment 'Indicates whether the game is played at the institutional home venue, away, or at a neutral site.' ;
    rdfs:domain ind:Game ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:homeTeamScore rdf:type rdf:Property ;
    rdfs:label 'Home Team Score' ;
    rdfs:comment 'Final score for the home team. Null if game not completed.' ;
    rdfs:domain ind:Game ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:institutionalScore rdf:type rdf:Property ;
    rdfs:label 'Institutional Score' ;
    rdfs:comment 'Final score for the institution\'s team (home or away). Null if game not completed.' ;
    rdfs:domain ind:Game ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:officialsAssigned rdf:type rdf:Property ;
    rdfs:label 'Officials Assigned' ;
    rdfs:comment 'Names of referees, umpires, or officials assigned to the game (comma-separated list).' ;
    rdfs:domain ind:Game ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:opponentInstitutionCode rdf:type rdf:Property ;
    rdfs:label 'Opponent Institution Code' ;
    rdfs:comment 'Standard code identifying the opposing institution (e.g., IPEDS UnitID or NCAA institution code).' ;
    rdfs:domain ind:Game ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:opponentScore rdf:type rdf:Property ;
    rdfs:label 'Opponent Score' ;
    rdfs:comment 'Final score for the opposing team. Null if game not completed.' ;
    rdfs:domain ind:Game ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:overtimeFlag rdf:type rdf:Property ;
    rdfs:label 'Overtime Flag' ;
    rdfs:comment 'Indicates whether the game went into overtime or extra innings (True/False).' ;
    rdfs:domain ind:Game ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:overtimePeriods rdf:type rdf:Property ;
    rdfs:label 'Overtime Periods' ;
    rdfs:comment 'Number of overtime periods or extra innings played.' ;
    rdfs:domain ind:Game ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:resultCertifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Result Certified Flag' ;
    rdfs:comment 'Indicates whether the game result has been officially certified by athletics administration (True/False).' ;
    rdfs:domain ind:Game ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:resultCertifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Result Certified Timestamp' ;
    rdfs:comment 'Timestamp when the game result was officially certified in yyyy-MM-ddTHH:mm:ss.SSSXXX format.' ;
    rdfs:domain ind:Game ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:ticketRevenue rdf:type rdf:Property ;
    rdfs:label 'Ticket Revenue' ;
    rdfs:comment 'Total revenue generated from ticket sales for this game in US dollars.' ;
    rdfs:domain ind:Game ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tournamentName rdf:type rdf:Property ;
    rdfs:label 'Tournament Name' ;
    rdfs:comment 'Name of the tournament if the game is part of a tournament (e.g., NCAA Division I Championship, Conference Tournament).' ;
    rdfs:domain ind:Game ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tournamentRound rdf:type rdf:Property ;
    rdfs:label 'Tournament Round' ;
    rdfs:comment 'Round designation within a tournament (e.g., First Round, Quarterfinals, Semifinals, Finals).' ;
    rdfs:domain ind:Game ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:venueState rdf:type rdf:Property ;
    rdfs:label 'Venue State' ;
    rdfs:comment 'State or province where the game venue is located (two-letter abbreviation).' ;
    rdfs:domain ind:Game ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:weatherConditions rdf:type rdf:Property ;
    rdfs:label 'Weather Conditions' ;
    rdfs:comment 'Weather conditions at game time for outdoor events (e.g., sunny, rainy, temperature).' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gameParticipationId rdf:type rdf:Property ;
    rdfs:label 'Game Participation Id' ;
    rdfs:comment 'Unique identifier for each student-athlete participation record in a specific game or contest. Primary key for the game participation entity.' ;
    rdfs:domain ind:GameParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:aces rdf:type rdf:Property ;
    rdfs:label 'Aces' ;
    rdfs:comment 'Total aces served by the student-athlete in this match. Applicable to volleyball and tennis.' ;
    rdfs:domain ind:GameParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assists rdf:type rdf:Property ;
    rdfs:label 'Assists' ;
    rdfs:comment 'Total assists credited to the student-athlete in this game. Applicable to basketball, soccer, hockey, lacrosse.' ;
    rdfs:domain ind:GameParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:blocks rdf:type rdf:Property ;
    rdfs:label 'Blocks' ;
    rdfs:comment 'Total blocks recorded by the student-athlete in this game. Applicable to volleyball and basketball.' ;
    rdfs:domain ind:GameParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:competitionLevel rdf:type rdf:Property ;
    rdfs:label 'Competition Level' ;
    rdfs:comment 'Level of competition for this game. Determines whether the game counts toward NCAA eligibility and season-of-competition limits.' ;
    rdfs:domain ind:GameParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countsTowardEligibilityFlag rdf:type rdf:Property ;
    rdfs:label 'Counts Toward Eligibility Flag' ;
    rdfs:comment 'Indicates whether this game participation counts toward the student-athletes season of competition for NCAA eligibility purposes. True if counts, False otherwise.' ;
    rdfs:domain ind:GameParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:disciplinaryActionDescription rdf:type rdf:Property ;
    rdfs:label 'Disciplinary Action Description' ;
    rdfs:comment 'Detailed description of any disciplinary action taken against the student-athlete during or as a result of this game.' ;
    rdfs:domain ind:GameParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disciplinaryActionFlag rdf:type rdf:Property ;
    rdfs:label 'Disciplinary Action Flag' ;
    rdfs:comment 'Indicates whether any disciplinary action was taken against the student-athlete during or as a result of this game. True if action taken, False otherwise.' ;
    rdfs:domain ind:GameParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ejectionFlag rdf:type rdf:Property ;
    rdfs:label 'Ejection Flag' ;
    rdfs:comment 'Indicates whether the student-athlete was ejected from the game. True if ejected, False otherwise. Critical for NCAA compliance and disciplinary tracking.' ;
    rdfs:domain ind:GameParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ejectionReason rdf:type rdf:Property ;
    rdfs:label 'Ejection Reason' ;
    rdfs:comment 'Detailed reason for ejection if the student-athlete was ejected from the game. Includes rule violation description and referee notes.' ;
    rdfs:domain ind:GameParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:foulsCommitted rdf:type rdf:Property ;
    rdfs:label 'Fouls Committed' ;
    rdfs:comment 'Total fouls committed by the student-athlete in this game. Applicable to basketball, soccer, and other contact sports.' ;
    rdfs:domain ind:GameParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:goalsScored rdf:type rdf:Property ;
    rdfs:label 'Goals Scored' ;
    rdfs:comment 'Total goals scored by the student-athlete in this game. Applicable to soccer, hockey, lacrosse, water polo.' ;
    rdfs:domain ind:GameParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hits rdf:type rdf:Property ;
    rdfs:label 'Hits' ;
    rdfs:comment 'Total hits recorded by the student-athlete in this game. Applicable to baseball and softball.' ;
    rdfs:domain ind:GameParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:injuryDescription rdf:type rdf:Property ;
    rdfs:label 'Injury Description' ;
    rdfs:comment 'Brief description of the injury sustained during this game. Protected health information subject to HIPAA and FERPA restrictions.' ;
    rdfs:domain ind:Athletics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:injuryFlag rdf:type rdf:Property ;
    rdfs:label 'Injury Flag' ;
    rdfs:comment 'Indicates whether the student-athlete sustained an injury during this game. True if injured, False otherwise. Critical for medical tracking and eligibility.' ;
    rdfs:domain ind:GameParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inningsPlayed rdf:type rdf:Property ;
    rdfs:label 'Innings Played' ;
    rdfs:comment 'Number of innings the student-athlete participated in during the game. Applicable to baseball and softball.' ;
    rdfs:domain ind:GameParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:jerseyNumber rdf:type rdf:Property ;
    rdfs:label 'Jersey Number' ;
    rdfs:comment 'Jersey number worn by the student-athlete during this game. May differ from roster jersey number in some sports.' ;
    rdfs:domain ind:Athletics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:kills rdf:type rdf:Property ;
    rdfs:label 'Kills' ;
    rdfs:comment 'Total kills recorded by the student-athlete in this match. Applicable to volleyball.' ;
    rdfs:domain ind:GameParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:medicalClearanceRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Medical Clearance Required Flag' ;
    rdfs:comment 'Indicates whether medical clearance is required before the student-athlete can participate in future games. True if clearance required, False otherwise.' ;
    rdfs:domain ind:GameParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:minutesPlayed rdf:type rdf:Property ;
    rdfs:label 'Minutes Played' ;
    rdfs:comment 'Total minutes the student-athlete participated in the game. Applicable to sports with timed play (basketball, soccer, hockey, lacrosse).' ;
    rdfs:domain ind:GameParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:participationNotes rdf:type rdf:Property ;
    rdfs:label 'Participation Notes' ;
    rdfs:comment 'Additional notes or comments regarding the student-athletes participation in this game. May include coaching observations, special circumstances, or compliance notes.' ;
    rdfs:domain ind:GameParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:participationStatus rdf:type rdf:Property ;
    rdfs:label 'Participation Status' ;
    rdfs:comment 'Status indicating whether and how the student-athlete participated in the game. Critical for NCAA compliance reporting and eligibility tracking.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pointsScored rdf:type rdf:Property ;
    rdfs:label 'Points Scored' ;
    rdfs:comment 'Total points scored by the student-athlete in this game. Applicable to basketball, football (via touchdowns), track and field scoring systems.' ;
    rdfs:domain ind:GameParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:positionPlayed rdf:type rdf:Property ;
    rdfs:label 'Position Played' ;
    rdfs:comment 'Primary position the student-athlete played during this game. Sport-specific position codes (e.g., QB, PG, MF, P).' ;
    rdfs:domain ind:GameParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rebounds rdf:type rdf:Property ;
    rdfs:label 'Rebounds' ;
    rdfs:comment 'Total rebounds (offensive and defensive combined) by the student-athlete in this game. Applicable to basketball.' ;
    rdfs:domain ind:GameParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:redCards rdf:type rdf:Property ;
    rdfs:label 'Red Cards' ;
    rdfs:comment 'Number of red cards received by the student-athlete in this game. Applicable to soccer and other sports using card systems.' ;
    rdfs:domain ind:GameParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:runsBattedIn rdf:type rdf:Property ;
    rdfs:label 'Runs Batted In' ;
    rdfs:comment 'Total runs batted in by the student-athlete in this game. Applicable to baseball and softball.' ;
    rdfs:domain ind:GameParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:saves rdf:type rdf:Property ;
    rdfs:label 'Saves' ;
    rdfs:comment 'Total saves made by the student-athlete in this game. Applicable to goalkeepers in soccer, hockey, lacrosse, water polo.' ;
    rdfs:domain ind:GameParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:setsPlayed rdf:type rdf:Property ;
    rdfs:label 'Sets Played' ;
    rdfs:comment 'Number of sets the student-athlete participated in during the match. Applicable to volleyball and tennis.' ;
    rdfs:domain ind:GameParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:starterFlag rdf:type rdf:Property ;
    rdfs:label 'Starter Flag' ;
    rdfs:comment 'Indicates whether the student-athlete was in the starting lineup for this game. True if starter, False if substitute or did not play.' ;
    rdfs:domain ind:Athletics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:strikeouts rdf:type rdf:Property ;
    rdfs:label 'Strikeouts' ;
    rdfs:comment 'Total strikeouts recorded by the student-athlete in this game. For pitchers in baseball and softball, or batters who struck out.' ;
    rdfs:domain ind:GameParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:touchdowns rdf:type rdf:Property ;
    rdfs:label 'Touchdowns' ;
    rdfs:comment 'Total touchdowns scored by the student-athlete in this game. Applicable to football.' ;
    rdfs:domain ind:GameParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:yardsGained rdf:type rdf:Property ;
    rdfs:label 'Yards Gained' ;
    rdfs:comment 'Total yards gained by the student-athlete in this game. Applicable to football (rushing, passing, receiving yards).' ;
    rdfs:domain ind:GameParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:yellowCards rdf:type rdf:Property ;
    rdfs:label 'Yellow Cards' ;
    rdfs:comment 'Number of yellow cards received by the student-athlete in this game. Applicable to soccer and other sports using card systems.' ;
    rdfs:domain ind:GameParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nilActivityId rdf:type rdf:Property ;
    rdfs:label 'Nil Activity Id' ;
    rdfs:comment 'Unique identifier for the NIL activity record. Primary key for the nil_activity product.' ;
    rdfs:domain ind:NilActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:activityDescription rdf:type rdf:Property ;
    rdfs:label 'Activity Description' ;
    rdfs:comment 'Free-text description of the NIL activity, including the nature of services to be performed, deliverables, promotional obligations, and any other relevant details of the agreement.' ;
    rdfs:domain ind:NilActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:activityNumber rdf:type rdf:Property ;
    rdfs:label 'Activity Number' ;
    rdfs:comment 'Business identifier or tracking number assigned to this NIL activity for institutional reference and reporting purposes.' ;
    rdfs:domain ind:NilActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agreementEndDate rdf:type rdf:Property ;
    rdfs:label 'Agreement End Date' ;
    rdfs:comment 'The date on which the NIL agreement expires or terminates. Nullable for open-ended or ongoing agreements.' ;
    rdfs:domain ind:NilActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:agreementStartDate rdf:type rdf:Property ;
    rdfs:label 'Agreement Start Date' ;
    rdfs:comment 'The date on which the NIL agreement becomes effective and the student-athlete begins performing under the terms of the agreement.' ;
    rdfs:domain ind:NilActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:compensationCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Compensation Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code representing the currency in which the estimated compensation value is denominated (e.g., USD for United States Dollar).' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compensationType rdf:type rdf:Property ;
    rdfs:label 'Compensation Type' ;
    rdfs:comment 'Classification of the form of compensation provided under the NIL agreement (e.g., cash payment, goods, services, equity stake, mixed compensation).' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceNotes rdf:type rdf:Property ;
    rdfs:label 'Compliance Notes' ;
    rdfs:comment 'Free-text notes from the compliance office regarding this NIL activity, including any concerns, follow-up actions, or special conditions imposed.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conflictOfInterestFlag rdf:type rdf:Property ;
    rdfs:label 'Conflict Of Interest Flag' ;
    rdfs:comment 'Boolean indicator of whether this NIL activity presents a potential conflict of interest with institutional sponsors, partners, or values (e.g., competing brand, prohibited industry).' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:conflictOfInterestNotes rdf:type rdf:Property ;
    rdfs:label 'Conflict Of Interest Notes' ;
    rdfs:comment 'Free-text notes describing any identified conflict of interest, the nature of the conflict, and any mitigation steps taken.' ;
    rdfs:domain ind:NilActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disclosureDate rdf:type rdf:Property ;
    rdfs:label 'Disclosure Date' ;
    rdfs:comment 'The date on which the student-athlete disclosed this NIL activity to the institution for compliance review and record-keeping purposes.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:disclosureMethod rdf:type rdf:Property ;
    rdfs:label 'Disclosure Method' ;
    rdfs:comment 'The method or channel through which the student-athlete disclosed the NIL activity to the institution (e.g., online portal, email submission, paper form, verbal notification).' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedCompensationValue rdf:type rdf:Property ;
    rdfs:label 'Estimated Compensation Value' ;
    rdfs:comment 'The estimated total monetary value or fair market value of compensation the student-athlete will receive under this NIL agreement, including cash payments, goods, services, or other benefits.' ;
    rdfs:domain ind:NilActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:institutionalMarksApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Institutional Marks Approval Status' ;
    rdfs:comment 'Status of institutional approval for the use of institutional trademarks or marks in this NIL activity (e.g., not applicable, pending approval, approved, denied).' ;
    rdfs:domain ind:NilActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:institutionalMarksUsedFlag rdf:type rdf:Property ;
    rdfs:label 'Institutional Marks Used Flag' ;
    rdfs:comment 'Boolean indicator of whether the NIL activity involves the use of institutional trademarks, logos, uniforms, or other intellectual property owned by the institution.' ;
    rdfs:domain ind:NilActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:institutionalReviewStatus rdf:type rdf:Property ;
    rdfs:label 'Institutional Review Status' ;
    rdfs:comment 'Current status of the institutional compliance review of this NIL activity (e.g., pending review, reviewed, approved, flagged for concern, rejected, under investigation).' ;
    rdfs:domain ind:NilActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ncaaNilPolicyComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Ncaa Nil Policy Compliance Flag' ;
    rdfs:comment 'Boolean indicator of whether this NIL activity complies with NCAA Name, Image, and Likeness interim policy and guidelines.' ;
    rdfs:domain ind:NilActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ncaaPolicyVersion rdf:type rdf:Property ;
    rdfs:label 'Ncaa Policy Version' ;
    rdfs:comment 'Version or effective date reference of the NCAA NIL policy under which this activity was reviewed and approved.' ;
    rdfs:domain ind:NilActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payForPlayFlag rdf:type rdf:Property ;
    rdfs:label 'Pay For Play Flag' ;
    rdfs:comment 'Boolean indicator of whether this NIL activity was flagged as potentially constituting impermissible pay-for-play compensation tied to athletic participation or performance.' ;
    rdfs:domain ind:NilActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:quidProQuoFlag rdf:type rdf:Property ;
    rdfs:label 'Quid Pro Quo Flag' ;
    rdfs:comment 'Boolean indicator of whether this NIL activity was flagged as potentially being a quid pro quo arrangement tied to enrollment, athletic performance, or recruiting inducement, which would violate NCAA policy.' ;
    rdfs:domain ind:NilActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reviewDate rdf:type rdf:Property ;
    rdfs:label 'Review Date' ;
    rdfs:comment 'The date on which the institutional compliance office completed its review of this NIL activity.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:stateNilLawComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'State Nil Law Compliance Flag' ;
    rdfs:comment 'Boolean indicator of whether this NIL activity complies with applicable state Name, Image, and Likeness laws and regulations in the jurisdiction where the institution is located.' ;
    rdfs:domain ind:NilActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:stateNilLawReference rdf:type rdf:Property ;
    rdfs:label 'State Nil Law Reference' ;
    rdfs:comment 'Citation or reference to the specific state NIL law or statute that governs this activity (e.g., California SB 206, Florida HB 7003).' ;
    rdfs:domain ind:NilActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxReportingRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Tax Reporting Required Flag' ;
    rdfs:comment 'Boolean indicator of whether this NIL activity requires tax reporting (e.g., IRS Form 1099-MISC or 1099-NEC) due to the value of compensation received.' ;
    rdfs:domain ind:NilActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:thirdPartyEntityName rdf:type rdf:Property ;
    rdfs:label 'Third Party Entity Name' ;
    rdfs:comment 'Name of the third-party individual, business, or organization that is party to the NIL agreement with the student-athlete.' ;
    rdfs:domain ind:NilActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thirdPartyEntityType rdf:type rdf:Property ;
    rdfs:label 'Third Party Entity Type' ;
    rdfs:comment 'Classification of the third-party entity type (e.g., individual, corporation, limited liability company, partnership, nonprofit organization, NIL collective). [ENUM-REF-CANDIDATE: individual|corporation|llc|partnership|nonprofit|collective|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:NilActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nliComplianceOfficerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Nli Compliance Officer Employee Id' ;
    rdfs:comment 'Reference to the athletics compliance officer who reviewed and certified the NLI for NCAA compliance.' ;
    rdfs:domain ind:Nli ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:nliEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Nli Employee Id' ;
    rdfs:comment 'Reference to the staff member (coach or recruiting coordinator) who managed the recruitment and NLI process for this prospect.' ;
    rdfs:domain ind:Nli ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:prospectId rdf:type rdf:Property ;
    rdfs:label 'Prospect Id' ;
    rdfs:comment 'Reference to the recruiting prospect record if the athlete has not yet enrolled.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Prospect .

ind:academicYearCommitment rdf:type rdf:Property ;
    rdfs:label 'Academic Year Commitment' ;
    rdfs:comment 'Academic year for which the prospective student-athlete commits to enroll and compete (e.g., 2024-2025).' ;
    rdfs:domain ind:Nli ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceCertificationDate rdf:type rdf:Property ;
    rdfs:label 'Compliance Certification Date' ;
    rdfs:comment 'Date on which the athletics compliance office certified that the NLI and recruitment process met all NCAA regulations.' ;
    rdfs:domain ind:Athletics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:documentNumber rdf:type rdf:Property ;
    rdfs:label 'Document Number' ;
    rdfs:comment 'Official document number assigned to the signed NLI by the NCAA Eligibility Center or institutional athletics compliance office.' ;
    rdfs:domain ind:Nli ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentTerm rdf:type rdf:Property ;
    rdfs:label 'Enrollment Term' ;
    rdfs:comment 'Academic term in which the student-athlete is expected to enroll under the NLI commitment.' ;
    rdfs:domain ind:Nli ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initialEligibilityStatus rdf:type rdf:Property ;
    rdfs:label 'Initial Eligibility Status' ;
    rdfs:comment 'Status of the prospect\'s initial eligibility certification by the NCAA Eligibility Center at the time of NLI signing.' ;
    rdfs:domain ind:Nli ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:institutionalSignatoryName rdf:type rdf:Property ;
    rdfs:label 'Institutional Signatory Name' ;
    rdfs:comment 'Name of the institutional representative (typically Director of Athletics or designee) who signed the NLI on behalf of the institution.' ;
    rdfs:domain ind:Nli ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:institutionalSignatoryTitle rdf:type rdf:Property ;
    rdfs:label 'Institutional Signatory Title' ;
    rdfs:comment 'Official title of the institutional representative who signed the NLI (e.g., Director of Athletics, Compliance Officer).' ;
    rdfs:domain ind:Nli ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:institutionalSignatureDate rdf:type rdf:Property ;
    rdfs:label 'Institutional Signature Date' ;
    rdfs:comment 'Date on which the institutional representative signed the NLI, completing the binding agreement.' ;
    rdfs:domain ind:Nli ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ncaaEligibilityCenterNumber rdf:type rdf:Property ;
    rdfs:label 'Ncaa Eligibility Center Number' ;
    rdfs:comment 'Unique identifier assigned to the prospective student-athlete by the NCAA Eligibility Center for tracking initial eligibility certification.' ;
    rdfs:domain ind:Nli ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nliStatus rdf:type rdf:Property ;
    rdfs:label 'Nli Status' ;
    rdfs:comment 'Current status of the NLI agreement indicating whether it is active, voided, released, expired, or pending institutional acceptance.' ;
    rdfs:domain ind:Nli ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentGuardianSignatureDate rdf:type rdf:Property ;
    rdfs:label 'Parent Guardian Signature Date' ;
    rdfs:comment 'Date on which the parent or legal guardian signed the NLI, if required.' ;
    rdfs:domain ind:Nli ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:parentGuardianSignatureRequired rdf:type rdf:Property ;
    rdfs:label 'Parent Guardian Signature Required' ;
    rdfs:comment 'Indicates whether a parent or legal guardian signature was required on the NLI due to the prospect being a minor at the time of signing.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:penaltyWaiverDate rdf:type rdf:Property ;
    rdfs:label 'Penalty Waiver Date' ;
    rdfs:comment 'Date on which the penalty waiver decision was rendered by the NCAA or institutional authority.' ;
    rdfs:domain ind:Nli ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:penaltyWaiverStatus rdf:type rdf:Property ;
    rdfs:label 'Penalty Waiver Status' ;
    rdfs:comment 'Status of any waiver request to reduce or eliminate penalties associated with breaking the NLI commitment.' ;
    rdfs:domain ind:Nli ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programYear rdf:type rdf:Property ;
    rdfs:label 'Program Year' ;
    rdfs:comment 'NCAA NLI program year under which the agreement was executed, governing the applicable rules and regulations.' ;
    rdfs:domain ind:Nli ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordUpdatedBy rdf:type rdf:Property ;
    rdfs:label 'Record Updated By' ;
    rdfs:comment 'User or system identifier of the person or process that last updated the NLI record.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:releaseApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Release Approval Date' ;
    rdfs:comment 'Date on which the institution approved or denied the student-athlete\'s release request.' ;
    rdfs:domain ind:Nli ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:releaseApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Release Approval Status' ;
    rdfs:comment 'Status of the institutional decision on the student-athlete\'s request for release from the NLI.' ;
    rdfs:domain ind:Nli ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:releaseConditions rdf:type rdf:Property ;
    rdfs:label 'Release Conditions' ;
    rdfs:comment 'Any conditions or restrictions placed on the release from the NLI (e.g., restrictions on contacting specific institutions, geographic limitations).' ;
    rdfs:domain ind:Nli ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:releaseRequestDate rdf:type rdf:Property ;
    rdfs:label 'Release Request Date' ;
    rdfs:comment 'Date on which the student-athlete formally requested release from the NLI commitment.' ;
    rdfs:domain ind:Nli ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:releaseRequestReason rdf:type rdf:Property ;
    rdfs:label 'Release Request Reason' ;
    rdfs:comment 'Documented reason provided by the student-athlete for requesting release from the NLI (e.g., coaching change, personal circumstances, academic program unavailability).' ;
    rdfs:domain ind:Nli ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scholarshipDurationYears rdf:type rdf:Property ;
    rdfs:label 'Scholarship Duration Years' ;
    rdfs:comment 'Number of years for which the athletic scholarship is guaranteed under the NLI agreement.' ;
    rdfs:domain ind:Nli ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scholarshipOffered rdf:type rdf:Property ;
    rdfs:label 'Scholarship Offered' ;
    rdfs:comment 'Indicates whether an athletic scholarship was offered as part of the NLI agreement.' ;
    rdfs:domain ind:Nli ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:signingDate rdf:type rdf:Property ;
    rdfs:label 'Signing Date' ;
    rdfs:comment 'Date on which the prospective student-athlete signed the National Letter of Intent.' ;
    rdfs:domain ind:Nli ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:signingPeriod rdf:type rdf:Property ;
    rdfs:label 'Signing Period' ;
    rdfs:comment 'Designated NCAA signing period during which the NLI was executed (Early, Regular, or Late).' ;
    rdfs:domain ind:Nli ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:voidDate rdf:type rdf:Property ;
    rdfs:label 'Void Date' ;
    rdfs:comment 'Date on which the NLI was officially voided.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:voidReason rdf:type rdf:Property ;
    rdfs:label 'Void Reason' ;
    rdfs:comment 'Documented reason for voiding the NLI (e.g., failure to meet admission requirements, NCAA eligibility issues, institutional program discontinuation).' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:officialVisitId rdf:type rdf:Property ;
    rdfs:label 'Official Visit Id' ;
    rdfs:comment 'Unique identifier for the official visit record. Primary key.' ;
    rdfs:domain ind:OfficialVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:expenseCostCenterId rdf:type rdf:Property ;
    rdfs:label 'Expense Cost Center Id' ;
    rdfs:comment 'Foreign key linking to finance.cost_center. Business justification: Recruiting visit expenses are charged to team/sport cost centers for budget tracking and variance analysis. Enables athletic directors to monitor recruiting spending by sport against budgeted amounts ' ;
    rdfs:domain ind:OfficialVisit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostCenter .

ind:hostStudentAthleteId rdf:type rdf:Property ;
    rdfs:label 'Host Student Athlete Id' ;
    rdfs:comment 'Reference to the current student-athlete assigned to host the prospect during the visit.' ;
    rdfs:domain ind:OfficialVisit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StudentAthlete .

ind:primaryOfficialEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Official Employee Id' ;
    rdfs:comment 'Reference to the athletics staff member coordinating this official visit.' ;
    rdfs:domain ind:OfficialVisit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryOfficialCompliancePostCertifiedByStaffEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Official Compliance Post Certified By Staff Employee Id' ;
    rdfs:comment 'Reference to the compliance staff member who certified the visit post-completion.' ;
    rdfs:domain ind:OfficialVisit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:academicMeetingIncludedFlag rdf:type rdf:Property ;
    rdfs:label 'Academic Meeting Included Flag' ;
    rdfs:comment 'Indicates whether meetings with academic advisors or faculty were included in the official visit.' ;
    rdfs:domain ind:OfficialVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:accompanyingParentGuardianCount rdf:type rdf:Property ;
    rdfs:label 'Accompanying Parent Guardian Count' ;
    rdfs:comment 'Number of parents or legal guardians accompanying the prospect on the official visit (NCAA allows institution to pay for up to two).' ;
    rdfs:domain ind:OfficialVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accompanyingSpouseCount rdf:type rdf:Property ;
    rdfs:label 'Accompanying Spouse Count' ;
    rdfs:comment 'Number of spouses accompanying the prospect on the official visit (applicable for graduate transfers or older prospects).' ;
    rdfs:domain ind:OfficialVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:athleticEventAttendanceFlag rdf:type rdf:Property ;
    rdfs:label 'Athletic Event Attendance Flag' ;
    rdfs:comment 'Indicates whether the prospect attended an athletic event during the official visit.' ;
    rdfs:domain ind:OfficialVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:athleticFacilitiesTourIncludedFlag rdf:type rdf:Property ;
    rdfs:label 'Athletic Facilities Tour Included Flag' ;
    rdfs:comment 'Indicates whether a tour of athletic facilities was included in the official visit itinerary.' ;
    rdfs:domain ind:OfficialVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:campusTourIncludedFlag rdf:type rdf:Property ;
    rdfs:label 'Campus Tour Included Flag' ;
    rdfs:comment 'Indicates whether a campus tour was included in the official visit itinerary.' ;
    rdfs:domain ind:OfficialVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:compliancePostCertificationDate rdf:type rdf:Property ;
    rdfs:label 'Compliance Post Certification Date' ;
    rdfs:comment 'Date when the compliance office certified the official visit as compliant after completion.' ;
    rdfs:domain ind:OfficialVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:compliancePostCertificationStatus rdf:type rdf:Property ;
    rdfs:label 'Compliance Post Certification Status' ;
    rdfs:comment 'Status of compliance office post-visit certification confirming all expenses and activities were within NCAA regulations.' ;
    rdfs:domain ind:OfficialVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compliancePreApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Compliance Pre Approval Date' ;
    rdfs:comment 'Date when the compliance office approved the official visit to proceed.' ;
    rdfs:domain ind:OfficialVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:compliancePreApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Compliance Pre Approval Status' ;
    rdfs:comment 'Status of compliance office pre-approval for the official visit before it occurs.' ;
    rdfs:domain ind:OfficialVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceViolationDescription rdf:type rdf:Property ;
    rdfs:label 'Compliance Violation Description' ;
    rdfs:comment 'Detailed description of any compliance violations identified related to this official visit.' ;
    rdfs:domain ind:OfficialVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceViolationFlag rdf:type rdf:Property ;
    rdfs:label 'Compliance Violation Flag' ;
    rdfs:comment 'Indicates whether any NCAA compliance violations were identified during or after the official visit.' ;
    rdfs:domain ind:OfficialVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:entertainmentExpenseAmount rdf:type rdf:Property ;
    rdfs:label 'Entertainment Expense Amount' ;
    rdfs:comment 'Total amount paid by the institution for entertainment activities during the official visit (tickets to athletic events, campus activities, etc.).' ;
    rdfs:domain ind:OfficialVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:itineraryDescription rdf:type rdf:Property ;
    rdfs:label 'Itinerary Description' ;
    rdfs:comment 'Detailed description of the planned activities and schedule for the official visit.' ;
    rdfs:domain ind:OfficialVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lodgingExpenseAmount rdf:type rdf:Property ;
    rdfs:label 'Lodging Expense Amount' ;
    rdfs:comment 'Total amount paid by the institution for the prospect\'s lodging during the official visit.' ;
    rdfs:domain ind:OfficialVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mealsExpenseAmount rdf:type rdf:Property ;
    rdfs:label 'Meals Expense Amount' ;
    rdfs:comment 'Total amount paid by the institution for meals provided to the prospect during the official visit.' ;
    rdfs:domain ind:OfficialVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recruitingPeriodType rdf:type rdf:Property ;
    rdfs:label 'Recruiting Period Type' ;
    rdfs:comment 'Type of NCAA recruiting period during which the official visit occurs (contact, evaluation, quiet, or dead period).' ;
    rdfs:domain ind:Athletics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalVisitCost rdf:type rdf:Property ;
    rdfs:label 'Total Visit Cost' ;
    rdfs:comment 'Total cost of the official visit paid by the institution, including all allowable expenses.' ;
    rdfs:domain ind:OfficialVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transportationExpenseAmount rdf:type rdf:Property ;
    rdfs:label 'Transportation Expense Amount' ;
    rdfs:comment 'Total amount paid by the institution for the prospect\'s transportation to and from campus (airfare, mileage, etc.).' ;
    rdfs:domain ind:OfficialVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:visitEndDate rdf:type rdf:Property ;
    rdfs:label 'Visit End Date' ;
    rdfs:comment 'Date when the official visit ends. Must be within 48 hours of start date per NCAA regulations.' ;
    rdfs:domain ind:Athletics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:visitEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Visit End Timestamp' ;
    rdfs:comment 'Precise date and time when the official visit ends, used for 48-hour compliance tracking.' ;
    rdfs:domain ind:OfficialVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:visitNotes rdf:type rdf:Property ;
    rdfs:label 'Visit Notes' ;
    rdfs:comment 'Additional notes or comments about the official visit from recruiting staff or compliance office.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:visitNumber rdf:type rdf:Property ;
    rdfs:label 'Visit Number' ;
    rdfs:comment 'Sequential number of this official visit for the prospect (NCAA allows up to 5 official visits per prospect across all institutions).' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:visitStartDate rdf:type rdf:Property ;
    rdfs:label 'Visit Start Date' ;
    rdfs:comment 'Date when the official visit begins. NCAA official visits may not exceed 48 hours.' ;
    rdfs:domain ind:Athletics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:visitStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Visit Start Timestamp' ;
    rdfs:comment 'Precise date and time when the official visit begins, used for 48-hour compliance tracking.' ;
    rdfs:domain ind:OfficialVisit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:visitStatus rdf:type rdf:Property ;
    rdfs:label 'Visit Status' ;
    rdfs:comment 'Current status of the official visit in its lifecycle.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:practiceSessionId rdf:type rdf:Property ;
    rdfs:label 'Practice Session Id' ;
    rdfs:comment 'Unique identifier for the practice session record. Primary key.' ;
    rdfs:domain ind:PracticeSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryPracticeHeadCoachId rdf:type rdf:Property ;
    rdfs:label 'Primary Practice Head Coach Id' ;
    rdfs:comment 'Reference to the head coach responsible for supervising this practice session.' ;
    rdfs:domain ind:PracticeSession ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Coach .

ind:attendanceCount rdf:type rdf:Property ;
    rdfs:label 'Attendance Count' ;
    rdfs:comment 'Number of student-athletes who attended this practice session.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:caraCountableFlag rdf:type rdf:Property ;
    rdfs:label 'Cara Countable Flag' ;
    rdfs:comment 'Indicates whether this practice session counts toward the weekly and seasonal NCAA CARA hour limits (20 hours per week, 8 hours per week out-of-season).' ;
    rdfs:domain ind:PracticeSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:competitionPreparationFlag rdf:type rdf:Property ;
    rdfs:label 'Competition Preparation Flag' ;
    rdfs:comment 'Indicates whether this practice session was specifically focused on preparing for an upcoming competition or game.' ;
    rdfs:domain ind:PracticeSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:complianceCertificationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Compliance Certification Timestamp' ;
    rdfs:comment 'Timestamp when the practice session was certified as compliant by athletics compliance staff.' ;
    rdfs:domain ind:PracticeSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:complianceCertifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Compliance Certified Flag' ;
    rdfs:comment 'Indicates whether this practice session has been reviewed and certified as compliant with NCAA CARA hour regulations.' ;
    rdfs:domain ind:PracticeSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:complianceReviewRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Compliance Review Required Flag' ;
    rdfs:comment 'Indicates whether this practice session requires additional compliance review due to unusual circumstances or potential rule violations.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:heatIndex rdf:type rdf:Property ;
