    rdfs:comment 'Number of official visits the prospect has taken to the institution. NCAA limits official visits per sport and division.' ;
    rdfs:domain ind:Recruit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:position rdf:type rdf:Property ;
    rdfs:label 'Position' ;
    rdfs:comment 'Primary playing position or role of the prospective student-athlete within the sport (e.g., Point Guard, Setter, Midfielder).' ;
