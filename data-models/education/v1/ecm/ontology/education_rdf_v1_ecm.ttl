    rdfs:comment 'The deadline date by which students must complete verification requirements for this award year.' ;
    rdfs:domain ind:AwardYear ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:masterPromissoryNoteId rdf:type rdf:Property ;
    rdfs:label 'Master Promissory Note Id' ;
    rdfs:comment 'Primary key for master_promissory_note' ;
