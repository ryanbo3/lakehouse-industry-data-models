    rdfs:range xsd:string .

ind:constituentStatus rdf:type rdf:Property ;
    rdfs:label 'Constituent Status' ;
    rdfs:comment 'Current lifecycle status of the constituent record in the advancement system.' ;
    rdfs:domain ind:Constituent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:constituentType rdf:type rdf:Property ;
    rdfs:label 'Constituent Type' ;
    rdfs:comment 'Classification of the constituent\'s relationship to the institution (e.g., alumni, donor, friend of the university, parent, faculty, staff).' ;
    rdfs:domain ind:Constituent ;
