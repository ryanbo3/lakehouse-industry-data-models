ind:womensHeadCoachSalariesTotal rdf:type rdf:Property ;
    rdfs:label 'Womens Head Coach Salaries Total' ;
    rdfs:comment 'Total salaries and bonuses paid to all head coaches of womens teams during the reporting year.' ;
    rdfs:domain ind:EadaReport ;
    rdf:type owl:DatatypeProperty ;
