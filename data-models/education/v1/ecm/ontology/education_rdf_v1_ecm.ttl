ind:directUnsubsidizedLoanAnnualLimit rdf:type rdf:Property ;
    rdfs:label 'Direct Unsubsidized Loan Annual Limit' ;
    rdfs:comment 'The annual borrowing limit for Direct Unsubsidized Loans for undergraduate students in this award year.' ;
    rdfs:domain ind:AwardYear ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:disbursementEndDate rdf:type rdf:Property ;
    rdfs:label 'Disbursement End Date' ;
    rdfs:comment 'The latest date financial aid disbursements can be made for this award year.' ;
    rdfs:domain ind:AwardYear ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:disbursementStartDate rdf:type rdf:Property ;
    rdfs:label 'Disbursement Start Date' ;
    rdfs:comment 'The earliest date financial aid disbursements can be made for this award year.' ;
    rdfs:domain ind:AwardYear ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fafsaCycleCode rdf:type rdf:Property ;
    rdfs:label 'Fafsa Cycle Code' ;
    rdfs:comment 'FAFSA processing cycle identifier associated with this award year for federal aid application processing.' ;
    rdfs:domain ind:AwardYear ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:federalAwardYearCode rdf:type rdf:Property ;
    rdfs:label 'Federal Award Year Code' ;
    rdfs:comment 'Four-digit federal award year code used for Title IV federal student aid reporting and FAFSA processing (e.g., 2024 for the 2023-2024 award year).' ;
    rdfs:domain ind:AwardYear ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:federalPellMaximumAmount rdf:type rdf:Property ;
    rdfs:label 'Federal Pell Maximum Amount' ;
    rdfs:comment 'The maximum Federal Pell Grant award amount available for this award year as determined by federal regulations.' ;
    rdfs:domain ind:AwardYear ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isCurrentYear rdf:type rdf:Property ;
    rdfs:label 'Is Current Year' ;
    rdfs:comment 'Boolean flag indicating whether this is the current active award year for financial aid operations.' ;
    rdfs:domain ind:AwardYear ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isDefaultYear rdf:type rdf:Property ;
    rdfs:label 'Is Default Year' ;
    rdfs:comment 'Boolean flag indicating whether this award year should be used as the default selection in financial aid systems.' ;
    rdfs:domain ind:AwardYear ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:packagingEndDate rdf:type rdf:Property ;
    rdfs:label 'Packaging End Date' ;
    rdfs:comment 'The date when financial aid packaging operations conclude for this award year.' ;
    rdfs:domain ind:AwardYear ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:packagingStartDate rdf:type rdf:Property ;
    rdfs:label 'Packaging Start Date' ;
    rdfs:comment 'The date when financial aid packaging operations begin for this award year.' ;
    rdfs:domain ind:AwardYear ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:r2t4CalculationEnabled rdf:type rdf:Property ;
