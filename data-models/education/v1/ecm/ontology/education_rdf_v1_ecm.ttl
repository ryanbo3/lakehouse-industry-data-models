    rdfs:comment 'Calculated heat index during the practice session, combining temperature and humidity for heat illness risk assessment.' ;
    rdfs:domain ind:PracticeSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:injuryCount rdf:type rdf:Property ;
    rdfs:label 'Injury Count' ;
    rdfs:comment 'Number of injuries that occurred during this practice session.' ;
    rdfs:domain ind:PracticeSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:injuryOccurredFlag rdf:type rdf:Property ;
    rdfs:label 'Injury Occurred Flag' ;
    rdfs:comment 'Indicates whether any student-athlete injury occurred during this practice session.' ;
    rdfs:domain ind:PracticeSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mandatoryAttendanceFlag rdf:type rdf:Property ;
    rdfs:label 'Mandatory Attendance Flag' ;
    rdfs:comment 'Indicates whether attendance at this practice session was mandatory for all eligible team members.' ;
    rdfs:domain ind:PracticeSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:medicalStaffPresentFlag rdf:type rdf:Property ;
    rdfs:label 'Medical Staff Present Flag' ;
    rdfs:comment 'Indicates whether athletic training or medical staff were present during the practice session for injury prevention and response.' ;
    rdfs:domain ind:PracticeSession ;
    rdf:type owl:DatatypeProperty ;
