# --- Attribute Properties ---
ind:advancedDegreeId rdf:type rdf:Property ;
    rdfs:label 'Advanced Degree Id' ;
    rdfs:comment 'Unique identifier for the advanced degree record. Primary key for this entity.' ;
    rdfs:domain ind:AdvancedDegree ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:alumnusId rdf:type rdf:Property ;
    rdfs:label 'Alumnus Id' ;
    rdfs:comment 'Reference to the alumnus who earned this advanced degree at an external institution after leaving this institution.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Alumnus .

ind:cipCodeId rdf:type rdf:Property ;
    rdfs:label 'Cip Code Id' ;
    rdfs:comment 'Foreign key linking to curriculum.cip_code. Business justification: Alumni advanced degree tracking for outcomes assessment and prospect research (wealth screening) requires proper CIP classification. Enables analysis of graduate school pathways by field and STEM desi' ;
    rdfs:domain ind:Education ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CipCode .

ind:awardingInstitutionCity rdf:type rdf:Property ;
    rdfs:label 'Awarding Institution City' ;
    rdfs:comment 'The city where the awarding institution is located.' ;
    rdfs:domain ind:AdvancedDegree ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:awardingInstitutionCountry rdf:type rdf:Property ;
    rdfs:label 'Awarding Institution Country' ;
    rdfs:comment 'The three-letter ISO country code of the country where the awarding institution is located (e.g., USA, GBR, CAN, AUS).' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:awardingInstitutionIpedsCode rdf:type rdf:Property ;
    rdfs:label 'Awarding Institution Ipeds Code' ;
    rdfs:comment 'The six-digit IPEDS Unit ID (UNITID) that uniquely identifies the awarding institution in the federal postsecondary education database.' ;
    rdfs:domain ind:AdvancedDegree ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:awardingInstitutionName rdf:type rdf:Property ;
    rdfs:label 'Awarding Institution Name' ;
    rdfs:comment 'The full official name of the external institution that conferred this advanced degree to the alumnus.' ;
    rdfs:domain ind:AdvancedDegree ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:awardingInstitutionState rdf:type rdf:Property ;
    rdfs:label 'Awarding Institution State' ;
    rdfs:comment 'The state, province, or region where the awarding institution is located (applicable for USA, Canada, and other federated countries).' ;
    rdfs:domain ind:AdvancedDegree ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:awardingInstitutionType rdf:type rdf:Property ;
    rdfs:label 'Awarding Institution Type' ;
    rdfs:comment 'The institutional control or sector classification of the awarding institution (public, private nonprofit, private for-profit, or foreign).' ;
    rdfs:domain ind:AdvancedDegree ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:careerRelevanceFlag rdf:type rdf:Property ;
    rdfs:label 'Career Relevance Flag' ;
    rdfs:comment 'Boolean indicator of whether this advanced degree is directly relevant to the alumnus current or intended career path, used for career outcomes analysis.' ;
    rdfs:domain ind:AdvancedDegree ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:concentrationSpecialization rdf:type rdf:Property ;
    rdfs:label 'Concentration Specialization' ;
    rdfs:comment 'The specific concentration, specialization, track, or focus area within the broader field of study (e.g., Finance concentration within MBA, Artificial Intelligence specialization within Computer Science PhD).' ;
    rdfs:domain ind:AdvancedDegree ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:createdTimestamp rdf:type rdf:Property ;
    rdfs:label 'Created Timestamp' ;
    rdfs:comment 'The precise timestamp when this advanced degree record was first created in the system (format: yyyy-MM-ddTHH:mm:ss.SSSXXX).' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:dataSource rdf:type rdf:Property ;
    rdfs:label 'Data Source' ;
    rdfs:comment 'The source from which this advanced degree information was obtained (e.g., alumni survey, LinkedIn, National Student Clearinghouse, prospect research, direct alumnus report, institutional partnership).' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:degreeLevel rdf:type rdf:Property ;
    rdfs:label 'Degree Level' ;
    rdfs:comment 'The level of the advanced degree earned (masters, doctoral, professional such as JD/MD/MBA, post-doctoral, graduate certificate, or specialist degree).' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:degreeRecordNumber rdf:type rdf:Property ;
    rdfs:label 'Degree Record Number' ;
    rdfs:comment 'Business identifier for this advanced degree record, used for tracking and reference in advancement systems.' ;
    rdfs:domain ind:AdvancedDegree ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:degreeStatus rdf:type rdf:Property ;
    rdfs:label 'Degree Status' ;
    rdfs:comment 'The current status of the advanced degree record (completed and verified, in progress, withdrawn, deferred, verified by institution, or unverified self-reported).' ;
    rdfs:domain ind:AdvancedDegree ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:degreeTitle rdf:type rdf:Property ;
    rdfs:label 'Degree Title' ;
    rdfs:comment 'The full official title of the degree as conferred by the awarding institution (e.g., Master of Business Administration, Doctor of Philosophy in Computer Science).' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:degreeType rdf:type rdf:Property ;
    rdfs:label 'Degree Type' ;
    rdfs:comment 'The specific type or abbreviation of the degree earned (e.g., MBA, PhD, JD, MD, MS, MA, EdD, DBA, MFA, MPH).' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentStartYear rdf:type rdf:Property ;
    rdfs:label 'Enrollment Start Year' ;
    rdfs:comment 'The calendar year in which the alumnus began enrollment in the advanced degree program at the awarding institution.' ;
    rdfs:domain ind:AdvancedDegree ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fieldOfStudy rdf:type rdf:Property ;
    rdfs:label 'Field Of Study' ;
    rdfs:comment 'The primary academic discipline or field of study for the advanced degree (e.g., Computer Science, Business Administration, Medicine, Law, Engineering).' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fundingSource rdf:type rdf:Property ;
    rdfs:label 'Funding Source' ;
    rdfs:comment 'The primary source of funding for the advanced degree program (e.g., self-funded, employer-sponsored, fellowship, assistantship, scholarship, research grant).' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:graduationDate rdf:type rdf:Property ;
    rdfs:label 'Graduation Date' ;
    rdfs:comment 'The specific date on which the advanced degree was officially conferred (format: yyyy-MM-dd).' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:graduationYear rdf:type rdf:Property ;
    rdfs:label 'Graduation Year' ;
    rdfs:comment 'The calendar year in which the alumnus graduated and was conferred the advanced degree.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:honorsDistinction rdf:type rdf:Property ;
    rdfs:label 'Honors Distinction' ;
    rdfs:comment 'Any honors, distinctions, or special recognitions received with the advanced degree (e.g., summa cum laude, magna cum laude, with distinction, departmental honors).' ;
    rdfs:domain ind:AdvancedDegree ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastModifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Modified Timestamp' ;
    rdfs:comment 'The precise timestamp when this advanced degree record was most recently updated or modified (format: yyyy-MM-ddTHH:mm:ss.SSSXXX).' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:majorAdvisorName rdf:type rdf:Property ;
    rdfs:label 'Major Advisor Name' ;
    rdfs:comment 'The name of the primary faculty advisor, dissertation chair, or thesis supervisor who guided the alumnus through the advanced degree program.' ;
    rdfs:domain ind:AdvancedDegree ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notes rdf:type rdf:Property ;
    rdfs:label 'Notes' ;
    rdfs:comment 'Free-text notes or additional context about the advanced degree, including any special circumstances, clarifications, or supplementary information.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prospectResearchFlag rdf:type rdf:Property ;
    rdfs:label 'Prospect Research Flag' ;
    rdfs:comment 'Boolean indicator of whether this advanced degree record was obtained through prospect research activities for fundraising purposes.' ;
    rdfs:domain ind:Advancement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recordCreatedBy rdf:type rdf:Property ;
    rdfs:label 'Record Created By' ;
    rdfs:comment 'The user ID or system identifier of the person or process that created this advanced degree record.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordCreatedDate rdf:type rdf:Property ;
    rdfs:label 'Record Created Date' ;
    rdfs:comment 'The date on which this advanced degree record was first created in the system (format: yyyy-MM-dd).' ;
    rdfs:domain ind:Advancement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordLastModifiedBy rdf:type rdf:Property ;
    rdfs:label 'Record Last Modified By' ;
    rdfs:comment 'The user ID or system identifier of the person or process that most recently modified this advanced degree record.' ;
    rdfs:domain ind:AdvancedDegree ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordLastModifiedDate rdf:type rdf:Property ;
    rdfs:label 'Record Last Modified Date' ;
    rdfs:comment 'The date on which this advanced degree record was most recently updated or modified (format: yyyy-MM-dd).' ;
    rdfs:domain ind:Advancement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thesisDissertationTitle rdf:type rdf:Property ;
    rdfs:label 'Thesis Dissertation Title' ;
    rdfs:comment 'The title of the thesis, dissertation, or capstone project completed as part of the advanced degree requirements (applicable primarily to masters and doctoral degrees).' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationDate rdf:type rdf:Property ;
    rdfs:label 'Verification Date' ;
    rdfs:comment 'The date on which the advanced degree information was officially verified through external documentation or institutional confirmation (format: yyyy-MM-dd).' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:verificationMethod rdf:type rdf:Property ;
    rdfs:label 'Verification Method' ;
    rdfs:comment 'The method used to verify the advanced degree information (e.g., official transcript, National Student Clearinghouse, institutional registrar confirmation, LinkedIn profile, alumni survey).' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationStatus rdf:type rdf:Property ;
    rdfs:label 'Verification Status' ;
    rdfs:comment 'Indicates whether the advanced degree information has been verified through official transcripts or institutional confirmation, or is self-reported by the alumnus.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventId rdf:type rdf:Property ;
    rdfs:label 'Event Id' ;
    rdfs:comment 'Unique identifier for the advancement event record. Primary key for the advancement event entity.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Event .

ind:affinityGroupId rdf:type rdf:Property ;
    rdfs:label 'Affinity Group Id' ;
    rdfs:comment 'Reference to the alumni affinity group sponsoring or associated with this event. Examples: regional alumni chapter, academic college alumni society, athletic booster club. Null for institution-wide events.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AffinityGroup .

ind:buildingId rdf:type rdf:Property ;
    rdfs:label 'Building Id' ;
    rdfs:comment 'Foreign key linking to facility.building. Business justification: Advancement events (galas, donor receptions, alumni gatherings) occur in campus buildings. This FK links advancement_event to the facility building master, enabling facility scheduling and space utili' ;
    rdfs:domain ind:Education ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Building .

ind:campaignId rdf:type rdf:Property ;
    rdfs:label 'Campaign Id' ;
    rdfs:comment 'Reference to the fundraising campaign associated with this event. Links the event to broader fundraising initiatives such as capital campaigns, annual giving drives, or endowment campaigns.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Campaign .

ind:cleryIncidentId rdf:type rdf:Property ;
    rdfs:label 'Clery Incident Id' ;
    rdfs:comment 'Foreign key linking to compliance.clery_incident. Business justification: Alumni events held on campus or in Clery geography (Greek houses, adjacent properties) where crimes occur must be Clery-reported per 34 CFR 668.46. Link required for incident location verification and' ;
    rdfs:domain ind:Education ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CleryIncident .

ind:costCenterId rdf:type rdf:Property ;
    rdfs:label 'Cost Center Id' ;
    rdfs:comment 'Foreign key linking to finance.cost_center. Business justification: Advancement events are often hosted by academic units/cost centers for budget and expense tracking. Creating advancement_event.cost_center_id to link to finance.cost_center for event cost allocation.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostCenter .

ind:employeeId rdf:type rdf:Property ;
    rdfs:label 'Employee Id' ;
    rdfs:comment 'Reference to the advancement staff member responsible for planning and executing this event. Primary point of contact for event logistics, vendor coordination, and post-event reporting.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:fiscalPeriodId rdf:type rdf:Property ;
    rdfs:label 'Fiscal Period Id' ;
    rdfs:comment 'Foreign key linking to finance.fiscal_period. Business justification: Advancement events occur in specific fiscal periods for budget and expense tracking. Creating advancement_event.fiscal_period_id to link to finance.fiscal_period for period-based reporting.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FiscalPeriod .

ind:serviceRequestId rdf:type rdf:Property ;
    rdfs:label 'Service Request Id' ;
    rdfs:comment 'Foreign key linking to technology.service_request. Business justification: Advancement events requiring IT support (AV setup, live streaming, registration kiosks, WiFi provisioning) generate service requests that link to event context for resource planning, cost allocation, ' ;
    rdfs:domain ind:Education ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ServiceRequest .

ind:actualAttendance rdf:type rdf:Property ;
    rdfs:label 'Actual Attendance' ;
    rdfs:comment 'Confirmed number of individuals who attended the event. Captured through check-in systems or manual counts. Used for ROI analysis, per-attendee cost calculation, and future planning.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualCost rdf:type rdf:Property ;
    rdfs:label 'Actual Cost' ;
    rdfs:comment 'Total actual expenditure incurred for the advancement event after completion. Compared against budget to calculate variance and inform future event planning. Includes all invoiced and paid expenses.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetAmount rdf:type rdf:Property ;
    rdfs:label 'Budget Amount' ;
    rdfs:comment 'Total approved budget allocated for the advancement event. Includes venue rental, catering, entertainment, marketing, staffing, and other direct costs. Used for financial planning and variance analysis.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:currencyCode rdf:type rdf:Property ;
    rdfs:label 'Currency Code' ;
    rdfs:comment 'Three-letter ISO currency code for all monetary amounts associated with this event (registration fees, budget, costs). Typically USD for U.S. institutions but may vary for international events.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryMode rdf:type rdf:Property ;
    rdfs:label 'Delivery Mode' ;
    rdfs:comment 'Format through which the event is delivered to attendees. In-person events require physical venue, virtual events use online platforms, hybrid events combine both modalities.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:earlyRegistrationDeadline rdf:type rdf:Property ;
    rdfs:label 'Early Registration Deadline' ;
    rdfs:comment 'Date by which registrants must register to receive early registration pricing or benefits. Incentivizes early commitment and aids in planning.' ;
    rdfs:domain ind:Advancement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:earlyRegistrationFee rdf:type rdf:Property ;
    rdfs:label 'Early Registration Fee' ;
    rdfs:comment 'Discounted ticket price for attendees who register before the early registration deadline. Incentivizes early commitment and improves planning accuracy.' ;
    rdfs:domain ind:Advancement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:endTime rdf:type rdf:Property ;
    rdfs:label 'End Time' ;
    rdfs:comment 'Precise date and time when the advancement event concludes. Used for venue booking, catering planning, and staff scheduling.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:eventDate rdf:type rdf:Property ;
    rdfs:label 'Event Date' ;
    rdfs:comment 'Calendar date on which the advancement event takes place. Primary business event timestamp for scheduling, reporting, and fiscal year attribution.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:eventDescription rdf:type rdf:Property ;
    rdfs:label 'Event Description' ;
    rdfs:comment 'Detailed narrative description of the advancement event including purpose, agenda, featured speakers, and expected outcomes. Used in invitations, marketing materials, and internal planning documents.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventName rdf:type rdf:Property ;
    rdfs:label 'Event Name' ;
    rdfs:comment 'Official name of the advancement event as it appears in invitations, marketing materials, and donor communications. Examples: Annual Scholarship Gala, President\'s Circle Reception, Engineering Building Groundbreaking.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventNumber rdf:type rdf:Property ;
    rdfs:label 'Event Number' ;
    rdfs:comment 'Externally-visible unique business identifier for the advancement event. Used in communications, invitations, and reporting. Format may follow institutional conventions (e.g., EVT-2024-001).' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventStatus rdf:type rdf:Property ;
    rdfs:label 'Event Status' ;
    rdfs:comment 'Current lifecycle state of the advancement event. Tracks progression from initial planning through execution and post-event follow-up. [ENUM-REF-CANDIDATE: planning|registration_open|registration_closed|in_progress|completed|cancelled|postponed — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventType rdf:type rdf:Property ;
    rdfs:label 'Event Type' ;
    rdfs:comment 'Classification of the advancement event by format and purpose. Determines event planning requirements, budget allocation, and success metrics. [ENUM-REF-CANDIDATE: gala|reception|groundbreaking|lecture_series|campaign_kickoff|donor_recognition|stewardship_dinner|reunion|cultivation_event|solicitation_event — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fundraisingGoalAmount rdf:type rdf:Property ;
    rdfs:label 'Fundraising Goal Amount' ;
    rdfs:comment 'Target dollar amount of gifts or pledges to be secured at or attributed to this event. Used for fundraising events with solicitation components. Null for non-fundraising events.' ;
    rdfs:domain ind:Advancement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:guestRegistrationFee rdf:type rdf:Property ;
    rdfs:label 'Guest Registration Fee' ;
    rdfs:comment 'Ticket price for guests accompanying registered alumni or donors. May differ from standard alumni pricing to reflect different engagement levels.' ;
    rdfs:domain ind:Advancement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isFundraisingEvent rdf:type rdf:Property ;
    rdfs:label 'Is Fundraising Event' ;
    rdfs:comment 'Indicates whether this event includes direct fundraising solicitation or gift commitments. True for galas with pledge drives, campaign kickoffs, or solicitation dinners. Affects IRS reporting and gift attribution.' ;
    rdfs:domain ind:Advancement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:purpose rdf:type rdf:Property ;
    rdfs:label 'Purpose' ;
    rdfs:comment 'Primary strategic objective of the event within the donor engagement lifecycle. Cultivation events build relationships, stewardship events thank donors, recognition events honor contributions, and solicitation events request gifts.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationCapacity rdf:type rdf:Property ;
    rdfs:label 'Registration Capacity' ;
    rdfs:comment 'Maximum number of attendees that can register for the event. Determined by venue capacity, catering limits, or strategic attendance targets. Used to manage waitlists and close registration.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:registrationCloseDate rdf:type rdf:Property ;
    rdfs:label 'Registration Close Date' ;
    rdfs:comment 'Date when event registration closes. After this date, no new registrations are accepted. Used for final headcount, catering orders, and seating arrangements.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:registrationOpenDate rdf:type rdf:Property ;
    rdfs:label 'Registration Open Date' ;
    rdfs:comment 'Date when event registration becomes available to invitees. Marks the beginning of the registration period and triggers invitation communications.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requiresRsvp rdf:type rdf:Property ;
    rdfs:label 'Requires Rsvp' ;
    rdfs:comment 'Indicates whether attendees must formally register or RSVP to attend the event. True for capacity-limited or catered events requiring headcount. False for open-invitation events.' ;
    rdfs:domain ind:Advancement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reunionClassYear rdf:type rdf:Property ;
    rdfs:label 'Reunion Class Year' ;
    rdfs:comment 'Graduation year of the alumni class being honored at a reunion event. Used for milestone reunion planning (5th, 10th, 25th, 50th anniversaries). Null for non-reunion events.' ;
    rdfs:domain ind:Advancement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:standardRegistrationFee rdf:type rdf:Property ;
    rdfs:label 'Standard Registration Fee' ;
    rdfs:comment 'Regular ticket price for event attendance after early registration period. May vary by attendee type (alumnus, guest, non-alumnus). Revenue supports event costs and may contribute to fundraising goals.' ;
    rdfs:domain ind:Advancement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:startTime rdf:type rdf:Property ;
    rdfs:label 'Start Time' ;
    rdfs:comment 'Precise date and time when the advancement event begins. Used for invitation details, venue coordination, and attendance tracking.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:targetAttendance rdf:type rdf:Property ;
    rdfs:label 'Target Attendance' ;
    rdfs:comment 'Planned or goal number of attendees for the event. Set during planning phase based on venue capacity, strategic objectives, and historical data. Used to measure event success.' ;
    rdfs:domain ind:Advancement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:venueAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Venue Address Line1' ;
    rdfs:comment 'First line of the venue street address including building number and street name. Used for invitations, directions, and logistics coordination.' ;
    rdfs:domain ind:Advancement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:venueAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Venue Address Line2' ;
    rdfs:comment 'Second line of the venue street address for suite, floor, room number, or building name. Optional field for additional location details.' ;
    rdfs:domain ind:Advancement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:venueCity rdf:type rdf:Property ;
    rdfs:label 'Venue City' ;
    rdfs:comment 'City or municipality where the event venue is located. Used for regional event analysis and travel planning for attendees.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:venueCountryCode rdf:type rdf:Property ;
    rdfs:label 'Venue Country Code' ;
    rdfs:comment 'Three-letter ISO country code for the event venue location. Supports international event tracking and regional alumni engagement analysis.' ;
    rdfs:domain ind:Advancement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:venuePostalCode rdf:type rdf:Property ;
    rdfs:label 'Venue Postal Code' ;
    rdfs:comment 'Postal or ZIP code for the event venue location. Used for mapping, proximity analysis, and mailing logistics.' ;
    rdfs:domain ind:Advancement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:venueStateProvince rdf:type rdf:Property ;
    rdfs:label 'Venue State Province' ;
    rdfs:comment 'State, province, or administrative region where the event venue is located. Supports geographic segmentation and regional engagement analysis.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:virtualMeetingUrl rdf:type rdf:Property ;
    rdfs:label 'Virtual Meeting Url' ;
    rdfs:comment 'Web address or link for accessing the virtual event platform. Distributed to registered attendees prior to the event. Confidential to prevent unauthorized access.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:virtualPlatform rdf:type rdf:Property ;
    rdfs:label 'Virtual Platform' ;
    rdfs:comment 'Name of the technology platform used for virtual or hybrid event delivery. Examples: Zoom, Microsoft Teams, Webex, Hopin. Null for in-person only events.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:advancementFundId rdf:type rdf:Property ;
    rdfs:label 'Advancement Fund Id' ;
    rdfs:comment 'Unique identifier for the advancement fund. Primary key for the fund master record.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AdvancementFund .

ind:ledgerAccountId rdf:type rdf:Property ;
    rdfs:label 'Ledger Account Id' ;
    rdfs:comment 'Foreign key linking to finance.ledger_account. Business justification: Advancement funds (endowments, scholarships, capital campaigns) map to general ledger accounts for financial tracking and reporting. This FK links advancement_fund to the finance ledger_account master' ;
    rdfs:domain ind:Education ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LedgerAccount .

ind:managerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Manager Employee Id' ;
    rdfs:comment 'FK to hr.employee' ;
    rdfs:domain ind:Education ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:owningOrgUnitId rdf:type rdf:Property ;
    rdfs:label 'Owning Org Unit Id' ;
    rdfs:comment 'Foreign key linking to hr.org_unit. Business justification: Advancement funds are budget entities requiring org hierarchy linkage for financial accountability, NACUBO/IPEDS reporting, stewardship reporting, and institutional budget roll-ups. Owning_college_sch' ;
    rdfs:domain ind:Advancement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrgUnit .

ind:researchAwardId rdf:type rdf:Property ;
    rdfs:label 'Research Award Id' ;
    rdfs:comment 'Foreign key linking to research.research_award. Business justification: Endowed funds distribute to specific research awards annually. Critical for fund accounting, stewardship reporting, and demonstrating research impact to donors. Links gift-funded endowments to the res' ;
    rdfs:domain ind:Education ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ResearchAward .

ind:closureDate rdf:type rdf:Property ;
    rdfs:label 'Closure Date' ;
    rdfs:comment 'Date the fund was permanently closed to new gifts and distributions ceased. Applicable for term endowments that have expired or funds that have been fully expended per donor intent.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:currentMarketValue rdf:type rdf:Property ;
    rdfs:label 'Current Market Value' ;
    rdfs:comment 'Current total market value of the fund including principal, accumulated income, and investment gains/losses. Updated periodically based on investment pool valuation cycles.' ;
    rdfs:domain ind:AdvancementFund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:donorAdvisedFlag rdf:type rdf:Property ;
    rdfs:label 'Donor Advised Flag' ;
    rdfs:comment 'Indicates whether the fund allows donor advisory privileges for distribution recommendations. True if donor retains advisory rights per gift agreement; false for fully institutionally-controlled funds.' ;
    rdfs:domain ind:AdvancementFund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:donorRecognitionLevel rdf:type rdf:Property ;
    rdfs:label 'Donor Recognition Level' ;
    rdfs:comment 'Recognition tier or society membership associated with the fund based on gift size (e.g., Presidents Circle, Founders Society, Legacy Society). Used for donor engagement and event invitations.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:establishmentDate rdf:type rdf:Property ;
    rdfs:label 'Establishment Date' ;
    rdfs:comment 'Date the fund was officially established and began accepting gifts. Corresponds to board approval date or execution of gift agreement.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:facilitiesSupportFlag rdf:type rdf:Property ;
    rdfs:label 'Facilities Support Flag' ;
    rdfs:comment 'Indicates whether the fund supports capital projects, building maintenance, or facility improvements. True for facilities funds; false otherwise.' ;
    rdfs:domain ind:AdvancementFund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:facultySupportFlag rdf:type rdf:Property ;
    rdfs:label 'Faculty Support Flag' ;
    rdfs:comment 'Indicates whether the fund supports faculty positions, research, or professional development (e.g., endowed chairs, professorships, research grants). True for faculty support funds; false otherwise.' ;
    rdfs:domain ind:AdvancementFund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:firstDistributionDate rdf:type rdf:Property ;
    rdfs:label 'First Distribution Date' ;
    rdfs:comment 'Date of the first distribution from the fund to support its designated purpose. May differ from establishment date if fund needed to reach minimum threshold or had a waiting period.' ;
    rdfs:domain ind:AdvancementFund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fundCode rdf:type rdf:Property ;
    rdfs:label 'Fund Code' ;
    rdfs:comment 'Externally-known unique alphanumeric code identifying the fund in financial systems and donor communications. Used for gift designation and general ledger mapping.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fundName rdf:type rdf:Property ;
    rdfs:label 'Fund Name' ;
    rdfs:comment 'Official name of the fund as established by donor agreement or institutional policy. Used in donor reports, gift receipts, and stewardship communications.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fundStatus rdf:type rdf:Property ;
    rdfs:label 'Fund Status' ;
    rdfs:comment 'Current operational status of the fund. Active funds accept gifts and make distributions; inactive funds are temporarily not accepting gifts; closed funds are permanently closed; suspended funds are under review; pending-establishment funds are awaiting final approval or minimum threshold.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fundType rdf:type rdf:Property ;
    rdfs:label 'Fund Type' ;
    rdfs:comment 'Classification of the fund based on spending restrictions and permanence. Endowed funds maintain principal in perpetuity; expendable funds can be fully spent; restricted funds have donor-imposed purpose restrictions; unrestricted funds have no donor restrictions; quasi-endowments are board-designated; term endowments revert after a specified period.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:giftAgreementDocumentUrl rdf:type rdf:Property ;
    rdfs:label 'Gift Agreement Document Url' ;
    rdfs:comment 'URL or file path to the executed gift agreement or memorandum of understanding that established the fund and specifies donor restrictions and institutional obligations.' ;
    rdfs:domain ind:AdvancementFund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:giftRestrictionTerms rdf:type rdf:Property ;
    rdfs:label 'Gift Restriction Terms' ;
    rdfs:comment 'Detailed text of donor-imposed restrictions on fund use, including purpose restrictions, eligibility criteria for beneficiaries, geographic limitations, time restrictions, and any other conditions specified in the gift agreement.' ;
    rdfs:domain ind:AdvancementFund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investmentPoolAssignment rdf:type rdf:Property ;
    rdfs:label 'Investment Pool Assignment' ;
    rdfs:comment 'Name or identifier of the investment pool in which the fund assets are invested (e.g., Long-Term Investment Pool, Balanced Pool, Fixed Income Pool). Determines investment strategy and return profile.' ;
    rdfs:domain ind:AdvancementFund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastValuationDate rdf:type rdf:Property ;
    rdfs:label 'Last Valuation Date' ;
    rdfs:comment 'Date of the most recent market valuation used to update the current market value. Typically corresponds to fiscal quarter-end or year-end investment pool valuation.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:marketValueCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Market Value Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the current market value (e.g., USD, GBP, EUR).' ;
    rdfs:domain ind:AdvancementFund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumEndowmentThreshold rdf:type rdf:Property ;
    rdfs:label 'Minimum Endowment Threshold' ;
    rdfs:comment 'Minimum principal balance required to establish or maintain the fund as an endowment. Funds below this threshold may be held in a pooled fund until the minimum is reached.' ;
    rdfs:domain ind:AdvancementFund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nacuboClassification rdf:type rdf:Property ;
    rdfs:label 'Nacubo Classification' ;
    rdfs:comment 'Standardized fund classification per NACUBO reporting taxonomy. Used for endowment surveys, peer benchmarking, and financial statement preparation.' ;
    rdfs:domain ind:AdvancementFund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalGiftAmount rdf:type rdf:Property ;
    rdfs:label 'Original Gift Amount' ;
    rdfs:comment 'Total amount of the original gift(s) that established the fund, representing the historical principal. Used for UPMIFA historic dollar value calculations and endowment preservation compliance.' ;
    rdfs:domain ind:Advancement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:programSupportFlag rdf:type rdf:Property ;
    rdfs:label 'Program Support Flag' ;
    rdfs:comment 'Indicates whether the fund supports academic programs, departmental operations, or institutional initiatives. True for program support funds; false otherwise.' ;
    rdfs:domain ind:AdvancementFund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:purposeDescription rdf:type rdf:Property ;
    rdfs:label 'Purpose Description' ;
    rdfs:comment 'Detailed narrative describing the intended use of fund distributions, including eligible expenditure categories, beneficiary populations, and programmatic objectives as specified in the gift agreement or board resolution.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingFrequency rdf:type rdf:Property ;
    rdfs:label 'Reporting Frequency' ;
    rdfs:comment 'Frequency of stewardship reports to be provided to donors or fund beneficiaries, as specified in the gift agreement or institutional policy.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scholarshipFundFlag rdf:type rdf:Property ;
    rdfs:label 'Scholarship Fund Flag' ;
    rdfs:comment 'Indicates whether the fund is designated for student financial aid (scholarships, fellowships, or awards). True for scholarship funds; false for other purposes.' ;
    rdfs:domain ind:AdvancementFund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:spendingCalculationMethod rdf:type rdf:Property ;
    rdfs:label 'Spending Calculation Method' ;
    rdfs:comment 'Methodology used to calculate annual distributions. Total-return applies rate to smoothed market value; income-only distributes actual investment income; hybrid combines approaches; unit-value uses pooled fund units.' ;
    rdfs:domain ind:AdvancementFund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:spendingPolicyRate rdf:type rdf:Property ;
    rdfs:label 'Spending Policy Rate' ;
    rdfs:comment 'Annual distribution rate applied to the fund balance to calculate available spending, typically expressed as a decimal (e.g., 0.0450 for 4.5%). May be institution-wide policy or fund-specific per donor agreement.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stewardshipReportingRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Stewardship Reporting Required Flag' ;
    rdfs:comment 'Indicates whether the fund requires periodic stewardship reports to donors or their designees. True if donor agreement specifies reporting obligations; false otherwise.' ;
    rdfs:domain ind:AdvancementFund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:thresholdCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Threshold Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the minimum endowment threshold amount (e.g., USD, GBP, EUR).' ;
    rdfs:domain ind:Advancement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:underwaterStatusFlag rdf:type rdf:Property ;
    rdfs:label 'Underwater Status Flag' ;
    rdfs:comment 'Indicates whether the fund current market value has fallen below the historic dollar value (original gift amount), creating an underwater endowment. True if underwater; false if market value exceeds or equals historic value. Critical for UPMIFA compliance and spending decisions.' ;
    rdfs:domain ind:AdvancementFund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:varianceReportingRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Variance Reporting Required Flag' ;
    rdfs:comment 'Indicates whether the fund requires institutional approval or board notification for expenditures that deviate from the stated purpose or exceed normal spending policy. True if variance reporting is required per gift agreement or policy; false otherwise.' ;
    rdfs:domain ind:AdvancementFund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:academicProgramId rdf:type rdf:Property ;
    rdfs:label 'Academic Program Id' ;
    rdfs:comment 'Foreign key linking to curriculum.academic_program. Business justification: Alumni chapters and affinity groups organized by program (MBA Alumni, Engineering Society, etc.) require FK for event targeting, engagement metrics, and program-specific fundraising campaigns. Replace' ;
    rdfs:domain ind:Education ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AcademicProgram .

ind:chapterPresidentAlumnusId rdf:type rdf:Property ;
    rdfs:label 'Chapter President Alumnus Id' ;
    rdfs:comment 'Unique identifier linking the chapter president to their alumnus record in the alumni master data.' ;
    rdfs:domain ind:AffinityGroup ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Alumnus .

ind:institutionalStaffLiaisonEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Institutional Staff Liaison Employee Id' ;
    rdfs:comment 'Unique identifier linking the staff liaison to their employee record in the human resources system.' ;
    rdfs:domain ind:AffinityGroup ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:affinityGroupStatus rdf:type rdf:Property ;
    rdfs:label 'Affinity Group Status' ;
    rdfs:comment 'Current operational status of the affinity group in its lifecycle.' ;
    rdfs:domain ind:AffinityGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:annualDuesAmount rdf:type rdf:Property ;
    rdfs:label 'Annual Dues Amount' ;
    rdfs:comment 'Standard annual membership dues amount charged to members of this affinity group, in USD. Null if no dues are required.' ;
    rdfs:domain ind:AffinityGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:annualEventCount rdf:type rdf:Property ;
    rdfs:label 'Annual Event Count' ;
    rdfs:comment 'Number of events hosted by the affinity group in the current fiscal year. Key metric for chapter health assessment.' ;
    rdfs:domain ind:AffinityGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:associatedAthleticTeam rdf:type rdf:Property ;
    rdfs:label 'Associated Athletic Team' ;
    rdfs:comment 'Name of the athletic team or sport supported by the affinity group (e.g., \'Football\', \'Women\'s Basketball\'). Applicable to athletic booster clubs.' ;
    rdfs:domain ind:AffinityGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:charterExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Charter Expiration Date' ;
    rdfs:comment 'Date when the group\'s charter expires and requires renewal. Null for groups with perpetual charters.' ;
    rdfs:domain ind:AffinityGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:city rdf:type rdf:Property ;
    rdfs:label 'City' ;
    rdfs:comment 'City where the affinity group is headquartered or primarily active.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactEmail rdf:type rdf:Property ;
    rdfs:label 'Contact Email' ;
    rdfs:comment 'Primary email address for contacting the affinity group leadership or for general inquiries.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactPhone rdf:type rdf:Property ;
    rdfs:label 'Contact Phone' ;
    rdfs:comment 'Primary phone number for contacting the affinity group leadership.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countryCode rdf:type rdf:Property ;
    rdfs:label 'Country Code' ;
    rdfs:comment 'Three-letter ISO country code for the primary country where the affinity group operates.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:duesRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Dues Required Flag' ;
    rdfs:comment 'Indicates whether membership in this affinity group requires payment of dues. True if dues are required, False if membership is free.' ;
    rdfs:domain ind:AffinityGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:engagementTier rdf:type rdf:Property ;
    rdfs:label 'Engagement Tier' ;
    rdfs:comment 'Classification of the affinity group\'s engagement level based on activity metrics, event participation, and member involvement. Used for chapter health analysis and resource allocation.' ;
    rdfs:domain ind:AffinityGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:foundingDate rdf:type rdf:Property ;
    rdfs:label 'Founding Date' ;
    rdfs:comment 'Date when the affinity group was officially established or chartered by the institution.' ;
    rdfs:domain ind:Advancement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:geographicRegion rdf:type rdf:Property ;
    rdfs:label 'Geographic Region' ;
    rdfs:comment 'Geographic area served by the affinity group (e.g., \'San Francisco Bay Area\', \'Northeast Corridor\', \'International - Europe\'). Applicable primarily to geographic chapters.' ;
    rdfs:domain ind:AffinityGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:groupCode rdf:type rdf:Property ;
    rdfs:label 'Group Code' ;
    rdfs:comment 'Short alphanumeric code used to identify the affinity group in systems and reports.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:groupName rdf:type rdf:Property ;
    rdfs:label 'Group Name' ;
    rdfs:comment 'Official name of the affinity group, chapter, or alumni network as recognized by the institution.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:groupType rdf:type rdf:Property ;
    rdfs:label 'Group Type' ;
    rdfs:comment 'Classification of the affinity group by its organizing principle: geographic chapter (regional alumni clubs), academic college chapter (school/college-based), identity-based network (cultural, gender, LGBTQ+), athletic booster club (sports support), professional network (career/industry), or special interest (hobby, cause).' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastEventDate rdf:type rdf:Property ;
    rdfs:label 'Last Event Date' ;
    rdfs:comment 'Date of the most recent event hosted or sponsored by the affinity group. Used to track chapter activity and engagement.' ;
    rdfs:domain ind:AffinityGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastModifiedBy rdf:type rdf:Property ;
    rdfs:label 'Last Modified By' ;
    rdfs:comment 'Username or identifier of the user who last modified the affinity group record.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mailingAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Mailing Address Line1' ;
    rdfs:comment 'First line of the mailing address for the affinity group (street address or P.O. Box).' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mailingAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Mailing Address Line2' ;
    rdfs:comment 'Second line of the mailing address (suite, apartment, building, etc.). Nullable.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mailingCity rdf:type rdf:Property ;
    rdfs:label 'Mailing City' ;
    rdfs:comment 'City for the affinity group\'s mailing address.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mailingCountryCode rdf:type rdf:Property ;
    rdfs:label 'Mailing Country Code' ;
    rdfs:comment 'Three-letter ISO country code for the affinity group\'s mailing address.' ;
    rdfs:domain ind:Advancement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mailingPostalCode rdf:type rdf:Property ;
    rdfs:label 'Mailing Postal Code' ;
    rdfs:comment 'Postal code or ZIP code for the affinity group\'s mailing address.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mailingStateProvince rdf:type rdf:Property ;
    rdfs:label 'Mailing State Province' ;
    rdfs:comment 'State or province for the affinity group\'s mailing address.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:membershipCount rdf:type rdf:Property ;
    rdfs:label 'Membership Count' ;
    rdfs:comment 'Current number of active members enrolled in the affinity group. Updated periodically based on membership roster.' ;
    rdfs:domain ind:AffinityGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:missionStatement rdf:type rdf:Property ;
    rdfs:label 'Mission Statement' ;
    rdfs:comment 'Official mission statement or purpose description for the affinity group, articulating its goals and values.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recognitionLevel rdf:type rdf:Property ;
    rdfs:label 'Recognition Level' ;
    rdfs:comment 'Institutional recognition level awarded to the affinity group based on performance criteria such as membership growth, event quality, fundraising, and volunteer engagement.' ;
    rdfs:domain ind:Advancement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:socialMediaHandle rdf:type rdf:Property ;
    rdfs:label 'Social Media Handle' ;
    rdfs:comment 'Primary social media handle or username for the affinity group (e.g., Twitter, LinkedIn, Facebook). Format may vary by platform.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stateProvince rdf:type rdf:Property ;
    rdfs:label 'State Province' ;
    rdfs:comment 'State or province where the affinity group is primarily based. Applicable to domestic chapters.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalFundsRaisedYtd rdf:type rdf:Property ;
    rdfs:label 'Total Funds Raised Ytd' ;
    rdfs:comment 'Total dollar amount raised by the affinity group in the current fiscal year through fundraising activities, in USD.' ;
    rdfs:domain ind:Advancement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:websiteUrl rdf:type rdf:Property ;
    rdfs:label 'Website Url' ;
    rdfs:comment 'Public website URL for the affinity group, if one exists. May be a dedicated site or a page on the institutional alumni portal.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alumniAwardId rdf:type rdf:Property ;
    rdfs:label 'Alumni Award Id' ;
    rdfs:comment 'Unique identifier for the alumni award record. Primary key.' ;
    rdfs:domain ind:Advancement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AlumniAward .

ind:alumniEventId rdf:type rdf:Property ;
    rdfs:label 'Alumni Event Id' ;
    rdfs:comment 'Reference to the alumni event where the award was presented (e.g., homecoming, gala, commencement).' ;
    rdfs:domain ind:Advancement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AlumniEvent .

ind:awardCatalogId rdf:type rdf:Property ;
    rdfs:label 'Award Catalog Id' ;
    rdfs:comment 'Reference to the award definition in the institutional award catalog, defining the award name, category, and criteria.' ;
    rdfs:domain ind:Advancement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AwardCatalog .

ind:endowmentId rdf:type rdf:Property ;
    rdfs:label 'Endowment Id' ;
    rdfs:comment 'Reference to the endowment fund that supports this award, if funded by a named endowment.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Endowment .

ind:graduationTermId rdf:type rdf:Property ;
    rdfs:label 'Graduation Term Id' ;
    rdfs:comment 'Foreign key linking to enrollment.term. Business justification: Alumni awards often have eligibility criteria based on graduation term (e.g., 5-year, 10-year alumni awards). Award ceremonies are scheduled relative to reunion cycles tied to specific graduation term' ;
    rdfs:domain ind:AlumniAward ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Term .

ind:approvalAuthority rdf:type rdf:Property ;
    rdfs:label 'Approval Authority' ;
    rdfs:comment 'Name or title of the individual or body that provided final approval for the award.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalDate rdf:type rdf:Property ;
    rdfs:label 'Approval Date' ;
    rdfs:comment 'Date when the award selection received final institutional approval (e.g., by President, Board of Trustees).' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:awardCategory rdf:type rdf:Property ;
    rdfs:label 'Award Category' ;
    rdfs:comment 'Primary classification of the award type, used for reporting and segmentation of recognition programs.' ;
    rdfs:domain ind:Advancement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:awardName rdf:type rdf:Property ;
    rdfs:label 'Award Name' ;
    rdfs:comment 'Full name of the award as it appears on certificates and in official communications (e.g., Distinguished Alumni Award, Young Alumni Achievement Award).' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:awardNumber rdf:type rdf:Property ;
    rdfs:label 'Award Number' ;
    rdfs:comment 'Externally-known unique identifier or tracking number for this specific award instance, used in publications and communications.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:awardStatus rdf:type rdf:Property ;
    rdfs:label 'Award Status' ;
    rdfs:comment 'Current lifecycle status of the award record, tracking progression from nomination through presentation. [ENUM-REF-CANDIDATE: nominated|under_review|selected|approved|declined|presented|revoked — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:awardSubcategory rdf:type rdf:Property ;
    rdfs:label 'Award Subcategory' ;
    rdfs:comment 'Secondary classification providing additional granularity within the award category (e.g., professional achievement, community service, academic excellence).' ;
    rdfs:domain ind:AlumniAward ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:awardYear rdf:type rdf:Property ;
    rdfs:label 'Award Year' ;
    rdfs:comment 'Calendar or academic year in which the award was conferred, used for historical tracking and cohort analysis.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:citationText rdf:type rdf:Property ;
    rdfs:label 'Citation Text' ;
    rdfs:comment 'Official citation or commendation text read during the presentation ceremony and printed on the award certificate, summarizing the recipients achievements.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monetaryValue rdf:type rdf:Property ;
    rdfs:label 'Monetary Value' ;
    rdfs:comment 'Cash or scholarship value associated with the award, if applicable. Null for recognition-only awards.' ;
    rdfs:domain ind:Advancement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nominationDate rdf:type rdf:Property ;
    rdfs:label 'Nomination Date' ;
    rdfs:comment 'Date when the alumnus was formally nominated for this award.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nominationSource rdf:type rdf:Property ;
    rdfs:label 'Nomination Source' ;
    rdfs:comment 'Origin or channel through which the nomination was submitted. [ENUM-REF-CANDIDATE: self|peer|faculty|staff|committee|board|public — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Advancement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nominationStatement rdf:type rdf:Property ;
    rdfs:label 'Nomination Statement' ;
    rdfs:comment 'Detailed narrative statement submitted by the nominator explaining why the alumnus should receive the award.' ;
    rdfs:domain ind:Advancement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nominatorName rdf:type rdf:Property ;
    rdfs:label 'Nominator Name' ;
    rdfs:comment 'Full name of the individual or organization who submitted the nomination.' ;
    rdfs:domain ind:Advancement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nominatorRelationship rdf:type rdf:Property ;
    rdfs:label 'Nominator Relationship' ;
    rdfs:comment 'Description of the nominators relationship to the nominee (e.g., colleague, classmate, supervisor, community partner).' ;
    rdfs:domain ind:Advancement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:presentationDate rdf:type rdf:Property ;
    rdfs:label 'Presentation Date' ;
    rdfs:comment 'Date when the award was formally presented to the recipient at a ceremony or event.' ;
    rdfs:domain ind:Advancement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:presentationLocation rdf:type rdf:Property ;
    rdfs:label 'Presentation Location' ;
    rdfs:comment 'Venue or location where the award presentation ceremony took place.' ;
    rdfs:domain ind:Advancement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:presenterName rdf:type rdf:Property ;
    rdfs:label 'Presenter Name' ;
    rdfs:comment 'Name of the individual who formally presented the award to the recipient (e.g., President, Dean, Board Chair).' ;
    rdfs:domain ind:AlumniAward ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prospectQualificationFlag rdf:type rdf:Property ;
    rdfs:label 'Prospect Qualification Flag' ;
    rdfs:comment 'Indicates whether this award recipient should be flagged as a major gift prospect for advancement cultivation.' ;
    rdfs:domain ind:Advancement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:publicationDate rdf:type rdf:Property ;
    rdfs:label 'Publication Date' ;
    rdfs:comment 'Date when the award was announced in alumni publications, website, or press releases.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:publicationFlag rdf:type rdf:Property ;
    rdfs:label 'Publication Flag' ;
    rdfs:comment 'Indicates whether the award recipient has consented to public announcement and publication of the award in alumni communications.' ;
    rdfs:domain ind:AlumniAward ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recipientClassYear rdf:type rdf:Property ;
    rdfs:label 'Recipient Class Year' ;
    rdfs:comment 'Graduation year of the award recipient, used for reunion planning and cohort analysis.' ;
    rdfs:domain ind:AlumniAward ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:recipientDegree rdf:type rdf:Property ;
    rdfs:label 'Recipient Degree' ;
    rdfs:comment 'Primary degree earned by the recipient from the institution (e.g., BA, BS, MBA, PhD).' ;
    rdfs:domain ind:AlumniAward ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recipientMajor rdf:type rdf:Property ;
    rdfs:label 'Recipient Major' ;
    rdfs:comment 'Primary academic major or field of study of the award recipient during their time at the institution.' ;
    rdfs:domain ind:AlumniAward ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewCommittee rdf:type rdf:Property ;
    rdfs:label 'Review Committee' ;
    rdfs:comment 'Name or identifier of the committee responsible for evaluating this award nomination.' ;
    rdfs:domain ind:AlumniAward ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewStartDate rdf:type rdf:Property ;
    rdfs:label 'Review Start Date' ;
    rdfs:comment 'Date when the selection committee began formal review of this nomination.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:revocationDate rdf:type rdf:Property ;
    rdfs:label 'Revocation Date' ;
    rdfs:comment 'Date when the award was revoked, if applicable. Null for awards in good standing.' ;
    rdfs:domain ind:Advancement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:revocationReason rdf:type rdf:Property ;
    rdfs:label 'Revocation Reason' ;
    rdfs:comment 'Explanation for why the award was revoked, if applicable. Confidential institutional record.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:selectionDate rdf:type rdf:Property ;
    rdfs:label 'Selection Date' ;
    rdfs:comment 'Date when the recipient was officially selected to receive the award by the review committee or governing body.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:selectionRationale rdf:type rdf:Property ;
    rdfs:label 'Selection Rationale' ;
    rdfs:comment 'Internal documentation of the committees reasoning and justification for selecting this recipient.' ;
    rdfs:domain ind:AlumniAward ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alumniCommunicationPreferenceId rdf:type rdf:Property ;
    rdfs:label 'Alumni Communication Preference Id' ;
    rdfs:comment 'Unique identifier for each alumni communication preference record. Primary key for the alumni communication preference entity.' ;
    rdfs:domain ind:AlumniCommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bounceStatus rdf:type rdf:Property ;
    rdfs:label 'Bounce Status' ;
    rdfs:comment 'The current email deliverability status for this alumnus. Hard bounces indicate invalid addresses and trigger automatic suppression. Soft bounces are temporary delivery failures.' ;
    rdfs:domain ind:AlumniCommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:careerNewsOptIn rdf:type rdf:Property ;
    rdfs:label 'Career News Opt In' ;
    rdfs:comment 'Indicates whether the alumnus has opted in to receive communications about career services, job postings, professional development, and networking opportunities.' ;
    rdfs:domain ind:AlumniCommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:communicationFrequency rdf:type rdf:Property ;
    rdfs:label 'Communication Frequency' ;
    rdfs:comment 'The frequency at which the alumnus prefers to receive communications. Used to throttle outreach volume and respect alumni preferences.' ;
    rdfs:domain ind:Advancement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentIpAddress rdf:type rdf:Property ;
    rdfs:label 'Consent Ip Address' ;
    rdfs:comment 'The IP address from which the alumnus submitted their communication preferences via web form. Used for fraud detection and consent verification in compliance audits.' ;
    rdfs:domain ind:AlumniCommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentSource rdf:type rdf:Property ;
    rdfs:label 'Consent Source' ;
    rdfs:comment 'The channel or method through which the alumnus provided their communication preferences. Used for consent verification and audit trail purposes.' ;
    rdfs:domain ind:AlumniCommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Consent Timestamp' ;
    rdfs:comment 'The date and time when the alumnus provided or updated their communication preferences. Critical for GDPR and CAN-SPAM compliance auditing.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:consentUserAgent rdf:type rdf:Property ;
    rdfs:label 'Consent User Agent' ;
    rdfs:comment 'The browser user agent string captured when the alumnus submitted preferences via web form. Provides technical context for consent verification.' ;
    rdfs:domain ind:AlumniCommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:doNotContact rdf:type rdf:Property ;
    rdfs:label 'Do Not Contact' ;
    rdfs:comment 'Master suppression flag indicating the alumnus has requested no contact through any channel for any purpose. Overrides all other opt-in preferences. True if contact is prohibited.' ;
    rdfs:domain ind:AlumniCommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:doNotSolicit rdf:type rdf:Property ;
    rdfs:label 'Do Not Solicit' ;
    rdfs:comment 'Indicates the alumnus has specifically requested not to receive fundraising solicitations while remaining open to other types of communications. True if fundraising solicitation is prohibited.' ;
    rdfs:domain ind:AlumniCommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:doubleOptInConfirmed rdf:type rdf:Property ;
    rdfs:label 'Double Opt In Confirmed' ;
    rdfs:comment 'Indicates whether the alumnus has confirmed their email opt-in via a double opt-in process (confirmation link). True if confirmed. Required for GDPR-compliant email marketing.' ;
    rdfs:domain ind:AlumniCommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:doubleOptInTimestamp rdf:type rdf:Property ;
    rdfs:label 'Double Opt In Timestamp' ;
    rdfs:comment 'The date and time when the alumnus clicked the confirmation link in the double opt-in email. Provides audit trail for verified consent.' ;
    rdfs:domain ind:AlumniCommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:emailOptIn rdf:type rdf:Property ;
    rdfs:label 'Email Opt In' ;
    rdfs:comment 'Indicates whether the alumnus has explicitly opted in to receive email communications. True if opted in, False if opted out.' ;
    rdfs:domain ind:AlumniCommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:eventInvitationsOptIn rdf:type rdf:Property ;
    rdfs:label 'Event Invitations Opt In' ;
    rdfs:comment 'Indicates whether the alumnus has opted in to receive invitations to alumni events including reunions, homecoming, regional gatherings, and networking events.' ;
    rdfs:domain ind:AlumniCommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fundraisingAppealsOptIn rdf:type rdf:Property ;
    rdfs:label 'Fundraising Appeals Opt In' ;
    rdfs:comment 'Indicates whether the alumnus has opted in to receive fundraising appeals including annual giving campaigns, major gift solicitations, and planned giving information.' ;
    rdfs:domain ind:AlumniCommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gdprConsentVersion rdf:type rdf:Property ;
    rdfs:label 'Gdpr Consent Version' ;
    rdfs:comment 'The version identifier of the GDPR consent language and privacy policy that the alumnus agreed to. Required for international alumni subject to GDPR.' ;
    rdfs:domain ind:AlumniCommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gdprLawfulBasis rdf:type rdf:Property ;
    rdfs:label 'Gdpr Lawful Basis' ;
    rdfs:comment 'The GDPR Article 6 lawful basis under which the institution processes the alumnus communication data. Typically consent or legitimate interest for alumni relations.' ;
    rdfs:domain ind:AlumniCommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:institutionalNewsOptIn rdf:type rdf:Property ;
    rdfs:label 'Institutional News Opt In' ;
    rdfs:comment 'Indicates whether the alumnus has opted in to receive general institutional news including academic achievements, research highlights, campus updates, and alumni spotlights.' ;
    rdfs:domain ind:AlumniCommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isActive rdf:type rdf:Property ;
    rdfs:label 'Is Active' ;
    rdfs:comment 'Indicates whether this preference record is the current active record for the alumnus. True if active. Supports preference versioning and historical tracking.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastBounceTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Bounce Timestamp' ;
    rdfs:comment 'The date and time of the most recent email bounce event for this alumnus. Used to track deliverability issues and trigger address verification workflows.' ;
    rdfs:domain ind:AlumniCommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:phoneOptIn rdf:type rdf:Property ;
    rdfs:label 'Phone Opt In' ;
    rdfs:comment 'Indicates whether the alumnus has consented to receive phone calls from the institution for engagement, fundraising, or event invitations.' ;
    rdfs:domain ind:AlumniCommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:postalMailOptIn rdf:type rdf:Property ;
    rdfs:label 'Postal Mail Opt In' ;
    rdfs:comment 'Indicates whether the alumnus has opted in to receive postal mail communications including newsletters, magazines, and fundraising appeals.' ;
    rdfs:domain ind:AlumniCommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:preferenceExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Preference Expiration Date' ;
    rdfs:comment 'The date on which the current preferences expire and require re-confirmation. Used in jurisdictions requiring periodic consent renewal (e.g., GDPR soft opt-in).' ;
    rdfs:domain ind:AlumniCommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:preferenceLastUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Preference Last Updated Timestamp' ;
    rdfs:comment 'The date and time when any preference field in this record was last modified. Used to track preference change history and recency.' ;
    rdfs:domain ind:AlumniCommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:preferenceSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Preference Source System' ;
    rdfs:comment 'The name of the source system or application from which this preference record originated (e.g., Blackbaud Raisers Edge, Slate CRM, Alumni Portal). Used for data lineage and integration troubleshooting.' ;
    rdfs:domain ind:AlumniCommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredContactMethod rdf:type rdf:Property ;
    rdfs:label 'Preferred Contact Method' ;
    rdfs:comment 'The primary channel through which the alumnus prefers to be contacted. Used to route communications through the appropriate delivery system.' ;
    rdfs:domain ind:Advancement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredLanguage rdf:type rdf:Property ;
    rdfs:label 'Preferred Language' ;
    rdfs:comment 'The language in which the alumnus prefers to receive communications. Supports multilingual outreach for international alumni populations.' ;
    rdfs:domain ind:Advancement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:smsOptIn rdf:type rdf:Property ;
    rdfs:label 'Sms Opt In' ;
    rdfs:comment 'Indicates whether the alumnus has consented to receive text messages (SMS) for event reminders, urgent updates, or brief announcements.' ;
    rdfs:domain ind:AlumniCommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:spamComplaintFlag rdf:type rdf:Property ;
    rdfs:label 'Spam Complaint Flag' ;
    rdfs:comment 'Indicates whether the alumnus has marked institutional emails as spam. True if a spam complaint has been received. Triggers immediate suppression to protect sender reputation.' ;
    rdfs:domain ind:AlumniCommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:spamComplaintTimestamp rdf:type rdf:Property ;
    rdfs:label 'Spam Complaint Timestamp' ;
    rdfs:comment 'The date and time when the alumnus marked an institutional email as spam. Used for compliance reporting and sender reputation management.' ;
    rdfs:domain ind:AlumniCommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:suppressionEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Suppression Effective Date' ;
    rdfs:comment 'The date on which the do-not-contact or do-not-solicit suppression became effective. Used to ensure compliance with suppression requests from the specified date forward.' ;
    rdfs:domain ind:AlumniCommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:suppressionReason rdf:type rdf:Property ;
    rdfs:label 'Suppression Reason' ;
    rdfs:comment 'Free-text explanation for why the alumnus is suppressed from communications. Captures context such as deceased status, legal request, or complaint history.' ;
    rdfs:domain ind:AlumniCommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unsubscribeReason rdf:type rdf:Property ;
    rdfs:label 'Unsubscribe Reason' ;
    rdfs:comment 'Free-text or categorical reason provided by the alumnus for unsubscribing. Used for feedback analysis and communication strategy improvement.' ;
    rdfs:domain ind:AlumniCommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unsubscribeTimestamp rdf:type rdf:Property ;
    rdfs:label 'Unsubscribe Timestamp' ;
    rdfs:comment 'The date and time when the alumnus unsubscribed from communications. Used to track opt-out events and ensure immediate suppression.' ;
    rdfs:domain ind:AlumniCommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:volunteerOpportunitiesOptIn rdf:type rdf:Property ;
    rdfs:label 'Volunteer Opportunities Opt In' ;
    rdfs:comment 'Indicates whether the alumnus has opted in to receive information about volunteer opportunities including mentoring, admissions support, career advising, and board service.' ;
    rdfs:domain ind:AlumniCommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:alumniContactId rdf:type rdf:Property ;
    rdfs:label 'Alumni Contact Id' ;
    rdfs:comment 'Unique identifier for the alumni contact record. Primary key.' ;
    rdfs:domain ind:AlumniContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:addressVerificationStatus rdf:type rdf:Property ;
    rdfs:label 'Address Verification Status' ;
    rdfs:comment 'Indicates whether the address has been verified through USPS or other address validation services.' ;
    rdfs:domain ind:Advancement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactFrequencyPreference rdf:type rdf:Property ;
    rdfs:label 'Contact Frequency Preference' ;
    rdfs:comment 'How often the alumnus wishes to receive communications from the institution.' ;
    rdfs:domain ind:AlumniContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:doNotCallFlag rdf:type rdf:Property ;
    rdfs:label 'Do Not Call Flag' ;
    rdfs:comment 'Indicates the alumnus has opted out of telephone communications.' ;
    rdfs:domain ind:AlumniContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:doNotContactFlag rdf:type rdf:Property ;
    rdfs:label 'Do Not Contact Flag' ;
    rdfs:comment 'Global flag indicating the alumnus has requested no contact from the institution across all channels.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:doNotEmailFlag rdf:type rdf:Property ;
    rdfs:label 'Do Not Email Flag' ;
    rdfs:comment 'Indicates the alumnus has opted out of email communications.' ;
    rdfs:domain ind:AlumniContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:doNotMailFlag rdf:type rdf:Property ;
    rdfs:label 'Do Not Mail Flag' ;
    rdfs:comment 'Indicates the alumnus has opted out of postal mail communications.' ;
    rdfs:domain ind:AlumniContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:doNotSmsFlag rdf:type rdf:Property ;
    rdfs:label 'Do Not Sms Flag' ;
    rdfs:comment 'Indicates the alumnus has opted out of SMS text message communications.' ;
    rdfs:domain ind:AlumniContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:emailConsentSource rdf:type rdf:Property ;
    rdfs:label 'Email Consent Source' ;
    rdfs:comment 'The channel or method through which email consent was obtained.' ;
    rdfs:domain ind:AlumniContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emailConsentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Email Consent Timestamp' ;
    rdfs:comment 'The date and time when the alumnus provided consent for email communications.' ;
    rdfs:domain ind:AlumniContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:homeAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Home Address Line1' ;
    rdfs:comment 'The first line of the alumnus home mailing address (street number and name).' ;
    rdfs:domain ind:AlumniContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:homeAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Home Address Line2' ;
    rdfs:comment 'The second line of the alumnus home mailing address (apartment, suite, unit number).' ;
    rdfs:domain ind:AlumniContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:homeCity rdf:type rdf:Property ;
    rdfs:label 'Home City' ;
    rdfs:comment 'The city of the alumnus home address.' ;
    rdfs:domain ind:AlumniContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:homeCountryCode rdf:type rdf:Property ;
    rdfs:label 'Home Country Code' ;
    rdfs:comment 'The three-letter ISO country code of the alumnus home address.' ;
    rdfs:domain ind:AlumniContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:homePhone rdf:type rdf:Property ;
    rdfs:label 'Home Phone' ;
    rdfs:comment 'The alumnus home telephone number for voice contact.' ;
    rdfs:domain ind:AlumniContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:homePostalCode rdf:type rdf:Property ;
    rdfs:label 'Home Postal Code' ;
    rdfs:comment 'The postal or ZIP code of the alumnus home address.' ;
    rdfs:domain ind:AlumniContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:homeStateProvince rdf:type rdf:Property ;
    rdfs:label 'Home State Province' ;
    rdfs:comment 'The state or province of the alumnus home address.' ;
    rdfs:domain ind:AlumniContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:linkedinProfileUrl rdf:type rdf:Property ;
    rdfs:label 'Linkedin Profile Url' ;
    rdfs:comment 'The URL to the alumnus LinkedIn profile for professional networking and career tracking.' ;
    rdfs:domain ind:Advancement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mobilePhone rdf:type rdf:Property ;
    rdfs:label 'Mobile Phone' ;
    rdfs:comment 'The alumnus mobile telephone number for voice and SMS contact.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ncoaUpdateDate rdf:type rdf:Property ;
    rdfs:label 'Ncoa Update Date' ;
    rdfs:comment 'The date when the address was last updated through the USPS National Change of Address database.' ;
    rdfs:domain ind:Advancement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:optInCareerNews rdf:type rdf:Property ;
    rdfs:label 'Opt In Career News' ;
    rdfs:comment 'Indicates whether the alumnus has opted in to receive career-related news and opportunities.' ;
    rdfs:domain ind:AlumniContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:optInEventInvitations rdf:type rdf:Property ;
    rdfs:label 'Opt In Event Invitations' ;
    rdfs:comment 'Indicates whether the alumnus has opted in to receive invitations to alumni events.' ;
    rdfs:domain ind:AlumniContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:optInFundraisingAppeals rdf:type rdf:Property ;
    rdfs:label 'Opt In Fundraising Appeals' ;
    rdfs:comment 'Indicates whether the alumnus has opted in to receive fundraising and donation appeals.' ;
    rdfs:domain ind:AlumniContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:optInInstitutionalNews rdf:type rdf:Property ;
    rdfs:label 'Opt In Institutional News' ;
    rdfs:comment 'Indicates whether the alumnus has opted in to receive general institutional news and updates.' ;
    rdfs:domain ind:AlumniContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:phoneConsentSource rdf:type rdf:Property ;
    rdfs:label 'Phone Consent Source' ;
    rdfs:comment 'The channel or method through which phone consent was obtained.' ;
    rdfs:domain ind:AlumniContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phoneConsentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Phone Consent Timestamp' ;
    rdfs:comment 'The date and time when the alumnus provided consent for phone communications.' ;
    rdfs:domain ind:AlumniContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:preferredName rdf:type rdf:Property ;
    rdfs:label 'Preferred Name' ;
    rdfs:comment 'The name the alumnus prefers to be addressed by in communications and events.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryEmail rdf:type rdf:Property ;
    rdfs:label 'Primary Email' ;
    rdfs:comment 'The primary email address for alumni communications. Used as the default contact channel for digital outreach.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seasonalAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Seasonal Address Line1' ;
    rdfs:comment 'The first line of a seasonal or temporary address (e.g., winter residence).' ;
    rdfs:domain ind:AlumniContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seasonalAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Seasonal Address Line2' ;
    rdfs:comment 'The second line of a seasonal or temporary address.' ;
    rdfs:domain ind:AlumniContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seasonalCity rdf:type rdf:Property ;
    rdfs:label 'Seasonal City' ;
    rdfs:comment 'The city of the seasonal or temporary address.' ;
    rdfs:domain ind:AlumniContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seasonalCountryCode rdf:type rdf:Property ;
    rdfs:label 'Seasonal Country Code' ;
    rdfs:comment 'The three-letter ISO country code of the seasonal or temporary address.' ;
    rdfs:domain ind:AlumniContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seasonalEndDate rdf:type rdf:Property ;
    rdfs:label 'Seasonal End Date' ;
    rdfs:comment 'The date when the seasonal address becomes inactive each year.' ;
    rdfs:domain ind:AlumniContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:seasonalPostalCode rdf:type rdf:Property ;
    rdfs:label 'Seasonal Postal Code' ;
    rdfs:comment 'The postal or ZIP code of the seasonal or temporary address.' ;
    rdfs:domain ind:AlumniContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seasonalStartDate rdf:type rdf:Property ;
    rdfs:label 'Seasonal Start Date' ;
    rdfs:comment 'The date when the seasonal address becomes active each year.' ;
    rdfs:domain ind:AlumniContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:seasonalStateProvince rdf:type rdf:Property ;
    rdfs:label 'Seasonal State Province' ;
    rdfs:comment 'The state or province of the seasonal or temporary address.' ;
    rdfs:domain ind:AlumniContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:secondaryEmail rdf:type rdf:Property ;
    rdfs:label 'Secondary Email' ;
    rdfs:comment 'An alternate email address for the alumnus, often a professional or work email.' ;
    rdfs:domain ind:AlumniContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workPhone rdf:type rdf:Property ;
    rdfs:label 'Work Phone' ;
    rdfs:comment 'The alumnus work or business telephone number.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventCode rdf:type rdf:Property ;
    rdfs:label 'Event Code' ;
    rdfs:comment 'Externally-known unique business identifier for the event, used in communications and registration systems.' ;
    rdfs:domain ind:AlumniEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventEndDate rdf:type rdf:Property ;
    rdfs:label 'Event End Date' ;
    rdfs:comment 'The date the event concludes. For single-day events, this equals the start date. For multi-day events (e.g., reunion weekend), this is the final day.' ;
    rdfs:domain ind:AlumniEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:eventEndTime rdf:type rdf:Property ;
    rdfs:label 'Event End Time' ;
    rdfs:comment 'Precise timestamp when the event programming concludes, including time zone information.' ;
    rdfs:domain ind:AlumniEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:eventStartDate rdf:type rdf:Property ;
    rdfs:label 'Event Start Date' ;
    rdfs:comment 'The date the event begins. For single-day events, this is the event date. For multi-day events, this is the first day.' ;
    rdfs:domain ind:AlumniEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:eventStartTime rdf:type rdf:Property ;
    rdfs:label 'Event Start Time' ;
    rdfs:comment 'Precise timestamp when the event programming begins, including time zone information for accurate scheduling across regions.' ;
    rdfs:domain ind:AlumniEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:organizingStaffEmail rdf:type rdf:Property ;
    rdfs:label 'Organizing Staff Email' ;
    rdfs:comment 'Email address of the primary event organizer. Used for attendee inquiries and internal coordination.' ;
    rdfs:domain ind:AlumniEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:organizingStaffName rdf:type rdf:Property ;
    rdfs:label 'Organizing Staff Name' ;
    rdfs:comment 'Name of the primary advancement staff member responsible for planning and executing the event.' ;
    rdfs:domain ind:AlumniEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:organizingStaffPhone rdf:type rdf:Property ;
    rdfs:label 'Organizing Staff Phone' ;
    rdfs:comment 'Phone number of the primary event organizer for urgent inquiries and day-of-event coordination.' ;
    rdfs:domain ind:AlumniEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:venueName rdf:type rdf:Property ;
    rdfs:label 'Venue Name' ;
    rdfs:comment 'Name of the physical location or facility hosting the event (e.g., Alumni Center, Grand Ballroom, Stadium Club). Null for virtual-only events.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alumniEventRegistrationId rdf:type rdf:Property ;
    rdfs:label 'Alumni Event Registration Id' ;
    rdfs:comment 'Unique identifier for the alumni event registration record. Primary key for this entity.' ;
    rdfs:domain ind:AlumniEventRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accessibilityRequirements rdf:type rdf:Property ;
    rdfs:label 'Accessibility Requirements' ;
    rdfs:comment 'Free-text description of any accessibility accommodations needed by the alumnus (e.g., wheelchair access, sign language interpreter, hearing assistance). Ensures ADA (Americans with Disabilities Act) compliance.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cancellationDate rdf:type rdf:Property ;
    rdfs:label 'Cancellation Date' ;
    rdfs:comment 'Date when the registration was cancelled by the alumnus or staff. Null if the registration was not cancelled.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cancellationReason rdf:type rdf:Property ;
    rdfs:label 'Cancellation Reason' ;
    rdfs:comment 'Free-text explanation or categorized reason for registration cancellation (e.g., schedule conflict, illness, duplicate registration). Used for event planning improvement.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checkInMethod rdf:type rdf:Property ;
    rdfs:label 'Check In Method' ;
    rdfs:comment 'Method or channel used to check in the alumnus at the event (e.g., mobile app, QR code scan, manual staff entry).' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checkInTimestamp rdf:type rdf:Property ;
    rdfs:label 'Check In Timestamp' ;
    rdfs:comment 'Precise date and time when the alumnus checked in at the event venue. Null if the alumnus did not attend. Used for attendance verification and engagement scoring.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:confirmationEmailSentFlag rdf:type rdf:Property ;
    rdfs:label 'Confirmation Email Sent Flag' ;
    rdfs:comment 'Indicates whether a registration confirmation email was successfully sent to the alumnus.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dietaryRequirements rdf:type rdf:Property ;
    rdfs:label 'Dietary Requirements' ;
    rdfs:comment 'Free-text description of any dietary restrictions, allergies, or preferences specified by the alumnus (e.g., vegetarian, vegan, gluten-free, nut allergy). Used for catering planning.' ;
    rdfs:domain ind:Advancement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engagementScore rdf:type rdf:Property ;
    rdfs:label 'Engagement Score' ;
    rdfs:comment 'Calculated score representing the level of engagement demonstrated by this registration (e.g., based on early registration, attendance, participation). Used for alumni relationship scoring and predictive analytics.' ;
    rdfs:domain ind:Advancement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guestCount rdf:type rdf:Property ;
    rdfs:label 'Guest Count' ;
    rdfs:comment 'Number of additional guests accompanying the alumnus to the event. Used for capacity planning and catering.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nameBadgePrintedFlag rdf:type rdf:Property ;
    rdfs:label 'Name Badge Printed Flag' ;
    rdfs:comment 'Indicates whether a name badge has been printed for the alumnus for this event.' ;
    rdfs:domain ind:AlumniEventRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:paymentAmount rdf:type rdf:Property ;
    rdfs:label 'Payment Amount' ;
    rdfs:comment 'Total monetary amount paid or due for the registration, including all tickets and guests. Expressed in the institutions base currency (USD).' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentDate rdf:type rdf:Property ;
    rdfs:label 'Payment Date' ;
    rdfs:comment 'Date when payment was received or processed for the registration.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentMethod rdf:type rdf:Property ;
    rdfs:label 'Payment Method' ;
    rdfs:comment 'Instrument used for payment (e.g., credit card, bank transfer, check, cash, complimentary waiver). Distinct from payment channel.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentStatus rdf:type rdf:Property ;
    rdfs:label 'Payment Status' ;
    rdfs:comment 'Current status of payment for the registration. Tracks whether payment has been received, is outstanding, or has been refunded.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referralSource rdf:type rdf:Property ;
    rdfs:label 'Referral Source' ;
    rdfs:comment 'How the alumnus learned about the event (e.g., email invitation, social media, word of mouth, website). Used for marketing effectiveness analysis.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationCampaignCode rdf:type rdf:Property ;
    rdfs:label 'Registration Campaign Code' ;
    rdfs:comment 'Marketing campaign code or tracking identifier associated with the registration source. Enables ROI (Return on Investment) analysis of promotional efforts.' ;
    rdfs:domain ind:AlumniEventRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationDate rdf:type rdf:Property ;
    rdfs:label 'Registration Date' ;
    rdfs:comment 'Date when the alumnus registered for the event. Represents the business event date of registration submission.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationNumber rdf:type rdf:Property ;
    rdfs:label 'Registration Number' ;
    rdfs:comment 'Externally visible unique registration confirmation number provided to the alumnus upon successful registration.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationSource rdf:type rdf:Property ;
    rdfs:label 'Registration Source' ;
    rdfs:comment 'Channel or interface through which the registration was submitted. Enables analysis of registration channel effectiveness.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationStatus rdf:type rdf:Property ;
    rdfs:label 'Registration Status' ;
    rdfs:comment 'Current lifecycle status of the registration. Tracks progression from initial registration through event attendance or cancellation.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Registration Timestamp' ;
    rdfs:comment 'Precise date and time when the registration was submitted, including time zone information. Used for audit and sequence analysis.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:reminderEmailSentFlag rdf:type rdf:Property ;
    rdfs:label 'Reminder Email Sent Flag' ;
    rdfs:comment 'Indicates whether a pre-event reminder email was successfully sent to the alumnus.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:specialRequests rdf:type rdf:Property ;
    rdfs:label 'Special Requests' ;
    rdfs:comment 'Additional notes or special requests submitted by the alumnus during registration (e.g., seating preferences, program participation).' ;
    rdfs:domain ind:AlumniEventRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tableAssignment rdf:type rdf:Property ;
    rdfs:label 'Table Assignment' ;
    rdfs:comment 'Assigned table number or seating location for the alumnus at the event. Used for seated events with assigned seating.' ;
    rdfs:domain ind:AlumniEventRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ticketType rdf:type rdf:Property ;
    rdfs:label 'Ticket Type' ;
    rdfs:comment 'Type or category of ticket selected by the alumnus (e.g., general admission, VIP, early bird, complimentary, student rate). Determines pricing and access level.' ;
    rdfs:domain ind:Advancement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vipFlag rdf:type rdf:Property ;
    rdfs:label 'Vip Flag' ;
    rdfs:comment 'Indicates whether the alumnus is designated as a VIP (Very Important Person) for this event, requiring special handling or recognition.' ;
    rdfs:domain ind:AlumniEventRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:waitlistAddedDate rdf:type rdf:Property ;
    rdfs:label 'Waitlist Added Date' ;
    rdfs:comment 'Date when the alumnus was added to the event waitlist. Null if never waitlisted.' ;
    rdfs:domain ind:AlumniEventRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:waitlistPosition rdf:type rdf:Property ;
    rdfs:label 'Waitlist Position' ;
    rdfs:comment 'Numeric position of the alumnus on the event waitlist if registration status is waitlisted. Null if not on waitlist.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:alumniSurveyId rdf:type rdf:Property ;
    rdfs:label 'Alumni Survey Id' ;
    rdfs:comment 'Unique identifier for the alumni survey campaign. Primary key.' ;
    rdfs:domain ind:Advancement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AlumniSurvey .

ind:accreditationReviewId rdf:type rdf:Property ;
    rdfs:label 'Accreditation Review Id' ;
    rdfs:comment 'Foreign key linking to compliance.accreditation_review. Business justification: Alumni outcomes surveys (employment rates, graduate school placement, salary data) are REQUIRED evidence for specialized accreditors (ABET, AACSB, ACEN) and regional standards on student achievement. ' ;
    rdfs:domain ind:Education ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AccreditationReview .

ind:enterpriseApplicationId rdf:type rdf:Property ;
    rdfs:label 'Enterprise Application Id' ;
    rdfs:comment 'Foreign key linking to technology.enterprise_application. Business justification: Survey instruments deployed through specific platforms (Qualtrics, SurveyMonkey, Alchemer) need system tracking for response data integration, accreditation reporting workflows, and platform cost allo' ;
    rdfs:domain ind:Education ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EnterpriseApplication .

ind:surveyCampaignId rdf:type rdf:Property ;
    rdfs:label 'Survey Campaign Id' ;
    rdfs:comment 'Identifier of the parent survey campaign under which this individual response was collected.' ;
    rdfs:domain ind:AlumniSurvey ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Campaign .

ind:accreditationAssociation rdf:type rdf:Property ;
    rdfs:label 'Accreditation Association' ;
    rdfs:comment 'The accrediting body for which this survey data will be reported (e.g., AACSB, ABET, HLC, SACSCOC). Determines specific data elements required.' ;
    rdfs:domain ind:AlumniSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:completionPercentage rdf:type rdf:Property ;
    rdfs:label 'Completion Percentage' ;
    rdfs:comment 'Percentage of survey questions completed by this respondent (e.g., 85.50 for 85.5% completion).' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:continuingEducationInstitution rdf:type rdf:Property ;
    rdfs:label 'Continuing Education Institution' ;
    rdfs:comment 'Name of the institution where the alumnus is pursuing further education, if applicable.' ;
    rdfs:domain ind:Advancement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:continuingEducationProgram rdf:type rdf:Property ;
    rdfs:label 'Continuing Education Program' ;
    rdfs:comment 'The program or degree the alumnus is pursuing in continuing education.' ;
    rdfs:domain ind:Advancement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryChannel rdf:type rdf:Property ;
    rdfs:label 'Delivery Channel' ;
    rdfs:comment 'The channel through which the survey was delivered to the alumnus.' ;
    rdfs:domain ind:AlumniSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employerName rdf:type rdf:Property ;
    rdfs:label 'Employer Name' ;
    rdfs:comment 'Name of the organization employing the alumnus at time of response, if employed.' ;
    rdfs:domain ind:Advancement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employmentStatus rdf:type rdf:Property ;
    rdfs:label 'Employment Status' ;
    rdfs:comment 'The employment status of the alumnus at the time of survey response. Critical for NACE First Destination and IPEDS Graduate Outcomes reporting. [ENUM-REF-CANDIDATE: employed_full_time|employed_part_time|self_employed|continuing_education|military_service|volunteer_service|seeking_employment|not_seeking — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:graduationTerm rdf:type rdf:Property ;
    rdfs:label 'Graduation Term' ;
    rdfs:comment 'The academic term in which the alumnus graduated.' ;
    rdfs:domain ind:AlumniSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:industrySector rdf:type rdf:Property ;
    rdfs:label 'Industry Sector' ;
    rdfs:comment 'The industry sector of the alumnus employer (e.g., Technology, Healthcare, Finance, Education, Manufacturing).' ;
    rdfs:domain ind:Advancement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:instrumentVersion rdf:type rdf:Property ;
    rdfs:label 'Instrument Version' ;
    rdfs:comment 'Version identifier of the survey instrument used (e.g., \'v2.1\', \'2024-Spring\'). Ensures consistency when survey questions evolve over time.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invitationSentDate rdf:type rdf:Property ;
    rdfs:label 'Invitation Sent Date' ;
    rdfs:comment 'The date the survey invitation was sent to the alumnus.' ;
    rdfs:domain ind:AlumniSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:jobLocationCity rdf:type rdf:Property ;
    rdfs:label 'Job Location City' ;
    rdfs:comment 'City where the alumnus is employed.' ;
    rdfs:domain ind:Advancement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jobLocationCountryCode rdf:type rdf:Property ;
    rdfs:label 'Job Location Country Code' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code where the alumnus is employed (e.g., USA, CAN, GBR).' ;
    rdfs:domain ind:Advancement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jobLocationStateProvince rdf:type rdf:Property ;
    rdfs:label 'Job Location State Province' ;
    rdfs:comment 'State or province where the alumnus is employed.' ;
    rdfs:domain ind:Advancement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jobRelatedToDegree rdf:type rdf:Property ;
    rdfs:label 'Job Related To Degree' ;
    rdfs:comment 'Indicates whether the alumnus current employment is related to their degree field. Used for program effectiveness assessment.' ;
    rdfs:domain ind:AlumniSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jobStartDate rdf:type rdf:Property ;
    rdfs:label 'Job Start Date' ;
    rdfs:comment 'The date the alumnus began their current employment position.' ;
    rdfs:domain ind:AlumniSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:jobTitle rdf:type rdf:Property ;
    rdfs:label 'Job Title' ;
    rdfs:comment 'The job title or position held by the alumnus at time of response, if employed.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastReminderDate rdf:type rdf:Property ;
    rdfs:label 'Last Reminder Date' ;
    rdfs:comment 'The date of the most recent reminder communication sent to the alumnus.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reminderCount rdf:type rdf:Property ;
    rdfs:label 'Reminder Count' ;
    rdfs:comment 'Number of reminder communications sent to the alumnus to encourage survey completion.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:responseDate rdf:type rdf:Property ;
    rdfs:label 'Response Date' ;
    rdfs:comment 'The date on which the alumnus submitted their survey response.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:responseRateTarget rdf:type rdf:Property ;
    rdfs:label 'Response Rate Target' ;
    rdfs:comment 'The target response rate percentage for the survey campaign (e.g., 65.00 for 65%). Used to assess campaign effectiveness.' ;
    rdfs:domain ind:AlumniSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:responseSource rdf:type rdf:Property ;
    rdfs:label 'Response Source' ;
    rdfs:comment 'The method by which the response data was obtained. Some institutions supplement direct survey responses with data from other sources.' ;
    rdfs:domain ind:AlumniSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseStatus rdf:type rdf:Property ;
    rdfs:label 'Response Status' ;
    rdfs:comment 'Status of this individual alumnus response indicating completion level.' ;
    rdfs:domain ind:Advancement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseTimestamp rdf:type rdf:Property ;
    rdfs:label 'Response Timestamp' ;
    rdfs:comment 'The precise date and time when the alumnus completed and submitted the survey response.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:salaryCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Salary Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the reported salary (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salaryRange rdf:type rdf:Property ;
    rdfs:label 'Salary Range' ;
    rdfs:comment 'The salary range or band reported by the alumnus. Often collected in ranges rather than exact amounts to improve response rates.' ;
    rdfs:domain ind:Advancement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:satisfactionScore rdf:type rdf:Property ;
    rdfs:label 'Satisfaction Score' ;
    rdfs:comment 'Overall satisfaction rating provided by the alumnus regarding their educational experience (typically on a scale such as 1-5 or 1-10).' ;
    rdfs:domain ind:AlumniSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:surveyName rdf:type rdf:Property ;
    rdfs:label 'Survey Name' ;
    rdfs:comment 'The official name of the survey campaign (e.g., \'Class of 2023 First Destination Survey\', \'Alumni Career Outcomes Survey 2024\').' ;
    rdfs:domain ind:AlumniSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surveyStatus rdf:type rdf:Property ;
    rdfs:label 'Survey Status' ;
    rdfs:comment 'Current lifecycle status of the survey campaign.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surveyType rdf:type rdf:Property ;
    rdfs:label 'Survey Type' ;
    rdfs:comment 'The category of survey being administered. Determines the question set and reporting requirements.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetPopulation rdf:type rdf:Property ;
    rdfs:label 'Target Population' ;
    rdfs:comment 'Description of the intended respondent population (e.g., \'Class of 2023 Bachelor Degree Recipients\', \'MBA Graduates 2020-2023\', \'Engineering Alumni 5-Year Post-Graduation\').' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wouldRecommend rdf:type rdf:Property ;
    rdfs:label 'Would Recommend' ;
    rdfs:comment 'Indicates whether the alumnus would recommend the institution or program to others. Key metric for Net Promoter Score (NPS) calculation.' ;
    rdfs:domain ind:AlumniSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cocurricularRecordId rdf:type rdf:Property ;
    rdfs:label 'Cocurricular Record Id' ;
    rdfs:comment 'Foreign key linking to studentlife.cocurricular_record. Business justification: Gift officers leverage cocurricular achievements for donor storytelling, impact reporting, and leadership volunteer identification. Service hours, leadership roles, and awards inform recognition socie' ;
    rdfs:domain ind:Education ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CocurricularRecord .

ind:profileId rdf:type rdf:Property ;
    rdfs:label 'Profile Id' ;
    rdfs:comment 'Cross-reference to the original student identifier from the Student Information System (SIS). Links the alumnus record back to their student record for historical academic data retrieval. This is the business key that was assigned during enrollment.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Profile .

ind:alternateEmail rdf:type rdf:Property ;
    rdfs:label 'Alternate Email' ;
    rdfs:comment 'A secondary email address for the alumnus. Used as a backup contact method when the primary email is undeliverable or for work vs personal email segmentation.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alumniStatus rdf:type rdf:Property ;
    rdfs:label 'Alumni Status' ;
    rdfs:comment 'The current engagement status of the alumnus record. Active indicates the alumnus is reachable and engaged; Deceased indicates confirmed death; Lost indicates contact information is outdated; Do Not Contact indicates explicit request to cease communications.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cumulativeGpa rdf:type rdf:Property ;
    rdfs:label 'Cumulative Gpa' ;
    rdfs:comment 'The cumulative GPA earned by the alumnus at the time of graduation. Used for honors society identification, scholarship donor reporting, and academic achievement recognition. Typically on a 4.0 scale.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:currentEmployer rdf:type rdf:Property ;
    rdfs:label 'Current Employer' ;
    rdfs:comment 'The name of the organization where the alumnus is currently employed. Used for career outcomes tracking, employer engagement, and prospect research for major gift fundraising.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentJobTitle rdf:type rdf:Property ;
    rdfs:label 'Current Job Title' ;
    rdfs:comment 'The current professional title or position of the alumnus. Used for career outcomes reporting, networking events, and wealth screening for fundraising.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dateOfBirth rdf:type rdf:Property ;
    rdfs:label 'Date Of Birth' ;
    rdfs:comment 'The date of birth of the alumnus. Used for age-based segmentation, reunion year calculations, and identity verification. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:deceasedDate rdf:type rdf:Property ;
    rdfs:label 'Deceased Date' ;
    rdfs:comment 'The date on which the alumnus passed away, if known. Used for memorial records and in memoriam recognition. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:Advancement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:deceasedIndicator rdf:type rdf:Property ;
    rdfs:label 'Deceased Indicator' ;
    rdfs:comment 'Boolean flag indicating whether the alumnus is deceased. True if confirmed deceased, False otherwise. Used to suppress communications and update alumni records appropriately.' ;
    rdfs:domain ind:Alumnus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:departmentName rdf:type rdf:Property ;
    rdfs:label 'Department Name' ;
    rdfs:comment 'The academic department that administered the alumnus primary degree program. Used for department-level alumni engagement and faculty-alumni networking events.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:doNotSolicitFlag rdf:type rdf:Property ;
    rdfs:label 'Do Not Solicit Flag' ;
    rdfs:comment 'Boolean flag indicating the alumnus has requested no fundraising solicitations. True if do-not-solicit request is active, False otherwise. Suppresses fundraising appeals but allows other alumni communications.' ;
    rdfs:domain ind:Advancement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ethnicity rdf:type rdf:Property ;
    rdfs:label 'Ethnicity' ;
    rdfs:comment 'The self-reported ethnicity or race of the alumnus. Used for diversity reporting, IPEDS compliance, and targeted outreach to underrepresented alumni populations. [ENUM-REF-CANDIDATE: Hispanic or Latino|American Indian or Alaska Native|Asian|Black or African American|Native Hawaiian or Other Pacific Islander|White|Two or More Races|Unknown — promote to reference product]' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ferpaConsentFlag rdf:type rdf:Property ;
    rdfs:label 'Ferpa Consent Flag' ;
    rdfs:comment 'Boolean flag indicating whether the alumnus has provided consent to share directory information under FERPA regulations. True if consent given, False if restricted. Controls publication of alumni information in directories and public listings.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gender rdf:type rdf:Property ;
    rdfs:label 'Gender' ;
    rdfs:comment 'The self-identified gender of the alumnus. Used for demographic reporting and diversity analytics. Supports inclusive gender identity options.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:graduationTermCode rdf:type rdf:Property ;
    rdfs:label 'Graduation Term Code' ;
    rdfs:comment 'The specific academic term code in which the alumnus graduated (e.g., 202305 for Spring 2023). Provides more granular graduation timing than year alone.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:honorsDesignation rdf:type rdf:Property ;
    rdfs:label 'Honors Designation' ;
    rdfs:comment 'The Latin honors or other academic distinction awarded at graduation based on GPA or other criteria. Used for recognition programs and donor prospect research. [ENUM-REF-CANDIDATE: Summa Cum Laude|Magna Cum Laude|Cum Laude|Honors|High Honors|Highest Honors|None — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalFirstName rdf:type rdf:Property ;
    rdfs:label 'Legal First Name' ;
    rdfs:comment 'The legal first name of the alumnus as recorded in official institutional records and on the degree conferred. Used for official transcripts, diplomas, and legal correspondence.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalLastName rdf:type rdf:Property ;
    rdfs:label 'Legal Last Name' ;
    rdfs:comment 'The legal last name (surname/family name) of the alumnus as recorded in official institutional records and on the degree conferred. Used for official transcripts, diplomas, and legal correspondence.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalMiddleName rdf:type rdf:Property ;
    rdfs:label 'Legal Middle Name' ;
    rdfs:comment 'The legal middle name or initial of the alumnus as recorded in official institutional records. May be null if no middle name was provided.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maidenName rdf:type rdf:Property ;
    rdfs:label 'Maiden Name' ;
    rdfs:comment 'The birth surname of the alumnus, typically used to track alumni who have changed their last name after graduation. Critical for alumni search and reunion planning.' ;
    rdfs:domain ind:Advancement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredFirstName rdf:type rdf:Property ;
    rdfs:label 'Preferred First Name' ;
    rdfs:comment 'The first name the alumnus prefers to be called in informal communications, alumni events, and publications. May differ from legal name. Used for personalized engagement and respecting individual identity preferences.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredLastName rdf:type rdf:Property ;
    rdfs:label 'Preferred Last Name' ;
    rdfs:comment 'The last name the alumnus prefers to be used in informal communications and alumni engagement activities. Often reflects name changes due to marriage or personal preference.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryDegreeLevel rdf:type rdf:Property ;
    rdfs:label 'Primary Degree Level' ;
    rdfs:comment 'The highest degree level earned by the alumnus from the institution (e.g., Bachelor, Master, Doctoral, Certificate, Associate). Used for segmentation in fundraising appeals and alumni engagement strategies. [ENUM-REF-CANDIDATE: Certificate|Associate|Bachelor|Master|Doctoral|Professional|Post-Doctoral — promote to reference product]' ;
    rdfs:domain ind:Alumnus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryDegreeName rdf:type rdf:Property ;
    rdfs:label 'Primary Degree Name' ;
    rdfs:comment 'The full name of the primary degree earned (e.g., Bachelor of Science, Master of Business Administration, Doctor of Philosophy). Used for alumni directory listings and credential verification.' ;
    rdfs:domain ind:Alumnus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryMajor rdf:type rdf:Property ;
    rdfs:label 'Primary Major' ;
    rdfs:comment 'The primary field of study or major for the alumnus highest degree. Used for academic affinity segmentation and school/college-based fundraising campaigns.' ;
    rdfs:domain ind:Alumnus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryPhone rdf:type rdf:Property ;
    rdfs:label 'Primary Phone' ;
    rdfs:comment 'The primary telephone number for contacting the alumnus. Used for phonathon campaigns, event reminders, and urgent communications.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordCreatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Record Created Timestamp' ;
    rdfs:comment 'The date and time when this alumnus record was first created in the system. Used for audit trail and data lineage. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:recordSource rdf:type rdf:Property ;
    rdfs:label 'Record Source' ;
    rdfs:comment 'The system or process that created or last significantly updated this alumnus record. Used for data lineage tracking and data quality auditing. [ENUM-REF-CANDIDATE: SIS|CRM|Manual Entry|Data Import|Alumni Survey|Third Party|Merge — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Record Updated Timestamp' ;
    rdfs:comment 'The date and time when this alumnus record was last modified. Used for audit trail, data freshness assessment, and change tracking. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:schoolCollegeName rdf:type rdf:Property ;
    rdfs:label 'School College Name' ;
    rdfs:comment 'The name of the academic school, college, or division from which the alumnus graduated. Used for school-based fundraising campaigns and dean-level engagement strategies.' ;
    rdfs:domain ind:Alumnus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appealId rdf:type rdf:Property ;
    rdfs:label 'Appeal Id' ;
    rdfs:comment 'Unique identifier for the fundraising appeal or solicitation effort. Primary key.' ;
    rdfs:domain ind:Advancement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Appeal .

ind:orgUnitId rdf:type rdf:Property ;
    rdfs:label 'Org Unit Id' ;
    rdfs:comment 'Reference to the academic college or school benefiting from or sponsoring this appeal.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrgUnit .

ind:appealCode rdf:type rdf:Property ;
    rdfs:label 'Appeal Code' ;
    rdfs:comment 'Unique business identifier code for the appeal used in tracking and reporting. Typically alphanumeric code assigned by advancement office.' ;
    rdfs:domain ind:Appeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appealDescription rdf:type rdf:Property ;
    rdfs:label 'Appeal Description' ;
    rdfs:comment 'Detailed description of the appeal purpose, messaging strategy, and intended outcomes.' ;
    rdfs:domain ind:Appeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appealName rdf:type rdf:Property ;
    rdfs:label 'Appeal Name' ;
    rdfs:comment 'Descriptive name of the fundraising appeal or solicitation effort (e.g., Annual Fund Spring Mail, Homecoming Phonathon, President\'s Circle Dinner).' ;
    rdfs:domain ind:Appeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appealStatus rdf:type rdf:Property ;
    rdfs:label 'Appeal Status' ;
    rdfs:comment 'Current lifecycle status of the appeal indicating whether it is planned, active, completed, cancelled, or suspended.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appealType rdf:type rdf:Property ;
    rdfs:label 'Appeal Type' ;
    rdfs:comment 'Classification of the solicitation method used for this appeal (direct mail, email, phone, event, digital, personal ask, social media). [ENUM-REF-CANDIDATE: direct_mail|email|phone|event|digital|personal_ask|social_media — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:askAmountHigh rdf:type rdf:Property ;
    rdfs:label 'Ask Amount High' ;
    rdfs:comment 'Highest suggested gift amount presented to prospects in this appeal.' ;
    rdfs:domain ind:Appeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:askAmountLow rdf:type rdf:Property ;
    rdfs:label 'Ask Amount Low' ;
    rdfs:comment 'Lowest suggested gift amount presented to prospects in this appeal.' ;
    rdfs:domain ind:Appeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:askCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Ask Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the ask amounts (e.g., USD, GBP, CAD).' ;
    rdfs:domain ind:Appeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:averageGiftAmount rdf:type rdf:Property ;
    rdfs:label 'Average Gift Amount' ;
    rdfs:comment 'Average gift amount received per responding donor for this appeal, calculated as total_revenue_amount / response_count.' ;
    rdfs:domain ind:Appeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:caseReportableFlag rdf:type rdf:Property ;
    rdfs:label 'Case Reportable Flag' ;
    rdfs:comment 'Indicates whether this appeal and its results are included in CASE reporting and benchmarking surveys.' ;
    rdfs:domain ind:Advancement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:costCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Cost Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the solicitation cost amount (e.g., USD, GBP, CAD).' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:owningOffice rdf:type rdf:Property ;
    rdfs:label 'Owning Office' ;
    rdfs:comment 'Name of the advancement office or unit responsible for managing this appeal (e.g., Annual Giving, Major Gifts, Alumni Relations, Development Office).' ;
    rdfs:domain ind:Advancement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packageCode rdf:type rdf:Property ;
    rdfs:label 'Package Code' ;
    rdfs:comment 'Code identifying the specific solicitation package or creative treatment used in this appeal (e.g., letter version, email template, script version).' ;
    rdfs:domain ind:Advancement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseCount rdf:type rdf:Property ;
    rdfs:label 'Response Count' ;
    rdfs:comment 'Number of individuals or households who responded to this appeal with a gift or pledge.' ;
    rdfs:domain ind:Appeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:responseRatePercentage rdf:type rdf:Property ;
    rdfs:label 'Response Rate Percentage' ;
    rdfs:comment 'Percentage of targeted individuals who responded to the appeal, calculated as (response_count / target_count) * 100.' ;
    rdfs:domain ind:Appeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revenueCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Revenue Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the total revenue amount (e.g., USD, GBP, CAD).' ;
    rdfs:domain ind:Appeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roiPercentage rdf:type rdf:Property ;
    rdfs:label 'Roi Percentage' ;
    rdfs:comment 'Return on investment for this appeal expressed as a percentage, calculated as ((total_revenue_amount - solicitation_cost_amount) / solicitation_cost_amount) * 100.' ;
    rdfs:domain ind:Appeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:solicitationCostAmount rdf:type rdf:Property ;
    rdfs:label 'Solicitation Cost Amount' ;
    rdfs:comment 'Total cost incurred to execute this appeal including printing, postage, event costs, staff time, and vendor fees.' ;
    rdfs:domain ind:Appeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:solicitationEndDate rdf:type rdf:Property ;
    rdfs:label 'Solicitation End Date' ;
    rdfs:comment 'Date when the appeal solicitation effort ends or is scheduled to end.' ;
    rdfs:domain ind:Appeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:solicitationStartDate rdf:type rdf:Property ;
    rdfs:label 'Solicitation Start Date' ;
    rdfs:comment 'Date when the appeal solicitation effort begins or began. Represents the principal business event timestamp for this appeal.' ;
    rdfs:domain ind:Appeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:targetAudienceSegment rdf:type rdf:Property ;
    rdfs:label 'Target Audience Segment' ;
    rdfs:comment 'Description of the donor or prospect segment targeted by this appeal (e.g., alumni class of 2010, LYBUNT donors, major gift prospects, parents of current students).' ;
    rdfs:domain ind:Appeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetCount rdf:type rdf:Property ;
    rdfs:label 'Target Count' ;
    rdfs:comment 'Number of individuals or households targeted for solicitation in this appeal.' ;
    rdfs:domain ind:Appeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalRevenueAmount rdf:type rdf:Property ;
    rdfs:label 'Total Revenue Amount' ;
    rdfs:comment 'Total revenue generated from gifts and pledges attributed to this appeal.' ;
    rdfs:domain ind:Appeal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:awardRecipientId rdf:type rdf:Property ;
    rdfs:label 'Award Recipient Id' ;
    rdfs:comment 'Unique identifier for the award recipient record. Primary key for the award recipient entity.' ;
    rdfs:domain ind:AwardRecipient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:presentationEventId rdf:type rdf:Property ;
    rdfs:label 'Presentation Event Id' ;
    rdfs:comment 'Reference to the alumni event at which the award was presented. Links to event master data for venue, attendance, and program details.' ;
    rdfs:domain ind:AwardRecipient ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Event .

ind:engagementScoreImpact rdf:type rdf:Property ;
    rdfs:label 'Engagement Score Impact' ;
    rdfs:comment 'Point value added to the recipients overall alumni engagement score as a result of receiving this award. Reflects increased connection to the institution.' ;
    rdfs:domain ind:AwardRecipient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:featuredInPublicationFlag rdf:type rdf:Property ;
    rdfs:label 'Featured In Publication Flag' ;
    rdfs:comment 'Indicates whether the award recipient was featured in alumni magazines, newsletters, or other institutional publications. Used to track recognition and engagement activities.' ;
    rdfs:domain ind:AwardRecipient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:monetaryAwardAmount rdf:type rdf:Property ;
    rdfs:label 'Monetary Award Amount' ;
    rdfs:comment 'Dollar value of any monetary prize or stipend accompanying the award. Some awards are purely honorary while others include financial recognition.' ;
    rdfs:domain ind:AwardRecipient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pressReleaseDate rdf:type rdf:Property ;
    rdfs:label 'Press Release Date' ;
    rdfs:comment 'Date on which the press release announcing the award was distributed to media outlets and published on institutional channels.' ;
    rdfs:domain ind:AwardRecipient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pressReleaseIssuedFlag rdf:type rdf:Property ;
    rdfs:label 'Press Release Issued Flag' ;
    rdfs:comment 'Indicates whether a press release was issued to announce the award. Used to track public relations activities and media coverage.' ;
    rdfs:domain ind:AwardRecipient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:prospectRating rdf:type rdf:Property ;
    rdfs:label 'Prospect Rating' ;
    rdfs:comment 'Fundraising capacity rating assigned to the award recipient following the award conferral. May be updated based on research into the recipients professional success and philanthropic capacity.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publicationIssue rdf:type rdf:Property ;
    rdfs:label 'Publication Issue' ;
    rdfs:comment 'Specific issue or edition of the alumni publication in which the recipient was featured. Includes publication name, volume, and issue number.' ;
    rdfs:domain ind:AwardRecipient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recipientAcceptanceDate rdf:type rdf:Property ;
    rdfs:label 'Recipient Acceptance Date' ;
    rdfs:comment 'Date on which the alumnus formally accepted the award. Triggers planning for presentation ceremony and public announcement.' ;
    rdfs:domain ind:AwardRecipient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:recipientAcceptanceStatus rdf:type rdf:Property ;
    rdfs:label 'Recipient Acceptance Status' ;
    rdfs:comment 'Indicates whether the selected alumnus has formally accepted the award. Some recipients may decline due to personal or professional reasons.' ;
    rdfs:domain ind:AwardRecipient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recipientNumber rdf:type rdf:Property ;
    rdfs:label 'Recipient Number' ;
    rdfs:comment 'Business-facing unique identifier for this award recipient record. Used in communications, certificates, and external reporting. Format may include award year and sequence.' ;
    rdfs:domain ind:AwardRecipient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:selectionCommitteeReviewDate rdf:type rdf:Property ;
    rdfs:label 'Selection Committee Review Date' ;
    rdfs:comment 'Date on which the selection committee formally reviewed and evaluated the nomination. Represents a key milestone in the award decision process.' ;
    rdfs:domain ind:AwardRecipient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:selectionDecisionDate rdf:type rdf:Property ;
    rdfs:label 'Selection Decision Date' ;
    rdfs:comment 'Date on which the selection committee or governing body made the final decision to confer the award to this recipient.' ;
    rdfs:domain ind:AwardRecipient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:selectionStatus rdf:type rdf:Property ;
    rdfs:label 'Selection Status' ;
    rdfs:comment 'Current state of the award recipient record in the selection and conferral lifecycle. Tracks progression from nomination through final award presentation.' ;
    rdfs:domain ind:AwardRecipient ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:createdBy rdf:type rdf:Property ;
    rdfs:label 'Created By' ;
    rdfs:comment 'Username or identifier of the system user who created this award recipient record. Supports audit and accountability requirements.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentCampaignId rdf:type rdf:Property ;
    rdfs:label 'Parent Campaign Id' ;
    rdfs:comment 'Reference to the parent campaign if this is a sub-campaign within a larger comprehensive campaign hierarchy.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Campaign .

ind:activeMembershipCount rdf:type rdf:Property ;
    rdfs:label 'Active Membership Count' ;
    rdfs:comment 'Current number of active members in a recognition society. Null for fundraising campaigns.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:amountRaised rdf:type rdf:Property ;
    rdfs:label 'Amount Raised' ;
    rdfs:comment 'Total amount raised to date, including gifts, pledges, and planned gifts counted toward the campaign goal.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:campaignDescription rdf:type rdf:Property ;
    rdfs:label 'Campaign Description' ;
    rdfs:comment 'Detailed narrative describing the campaign purpose, objectives, and intended impact.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:campaignName rdf:type rdf:Property ;
    rdfs:label 'Campaign Name' ;
    rdfs:comment 'Full name of the fundraising campaign or recognition society.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:campaignNumber rdf:type rdf:Property ;
    rdfs:label 'Campaign Number' ;
    rdfs:comment 'Externally-known business identifier for the campaign, used in communications and reporting.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:campaignStatus rdf:type rdf:Property ;
    rdfs:label 'Campaign Status' ;
    rdfs:comment 'Current lifecycle status of the campaign: planning (pre-launch), quiet_phase (leadership gifts), public_phase (broad solicitation), active (ongoing), completed (goal achieved), suspended (temporarily paused), or cancelled (terminated). [ENUM-REF-CANDIDATE: planning|quiet_phase|public_phase|active|completed|suspended|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:campaignType rdf:type rdf:Property ;
    rdfs:label 'Campaign Type' ;
    rdfs:comment 'Classification of the campaign: comprehensive (institution-wide), capital (facilities/infrastructure), annual (yearly giving), endowment (permanent funds), emergency (crisis response), or recognition_society (donor club/giving circle).' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseReportingClassification rdf:type rdf:Property ;
    rdfs:label 'Case Reporting Classification' ;
    rdfs:comment 'CASE standard classification code for reporting purposes (e.g., comprehensive campaign, capital campaign).' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:donorCount rdf:type rdf:Property ;
    rdfs:label 'Donor Count' ;
    rdfs:comment 'Total number of unique donors who have contributed to this campaign.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:endDate rdf:type rdf:Property ;
    rdfs:label 'End Date' ;
    rdfs:comment 'Planned or actual end date of the campaign. Null for ongoing recognition societies.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:giftCountingRules rdf:type rdf:Property ;
    rdfs:label 'Gift Counting Rules' ;
    rdfs:comment 'Description of which gift types are counted toward campaign totals (e.g., outright gifts, pledges, planned gifts, matching gifts).' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:goalAmount rdf:type rdf:Property ;
    rdfs:label 'Goal Amount' ;
    rdfs:comment 'Target fundraising amount for the campaign in the specified currency.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:memberBenefitsDescription rdf:type rdf:Property ;
    rdfs:label 'Member Benefits Description' ;
    rdfs:comment 'Description of benefits provided to members of a recognition society (e.g., event invitations, publications, naming opportunities).' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumGivingThreshold rdf:type rdf:Property ;
    rdfs:label 'Minimum Giving Threshold' ;
    rdfs:comment 'Minimum cumulative or annual giving amount required for membership in a recognition society. Null for fundraising campaigns.' ;
    rdfs:domain ind:Advancement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:phase rdf:type rdf:Property ;
    rdfs:label 'Phase' ;
    rdfs:comment 'Current operational phase: planning (pre-launch), quiet (leadership solicitation), public (broad outreach), or completion (wrap-up and stewardship).' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priority rdf:type rdf:Property ;
    rdfs:label 'Priority' ;
    rdfs:comment 'Institutional priority level assigned to this campaign for resource allocation and strategic focus.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publicLaunchDate rdf:type rdf:Property ;
    rdfs:label 'Public Launch Date' ;
    rdfs:comment 'Date when the campaign transitioned from quiet phase to public phase and broad solicitation began.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:quietPhaseGoalAmount rdf:type rdf:Property ;
    rdfs:label 'Quiet Phase Goal Amount' ;
    rdfs:comment 'Target amount to be raised during the quiet phase before public launch, typically from leadership donors.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recognitionTier rdf:type rdf:Property ;
    rdfs:label 'Recognition Tier' ;
    rdfs:comment 'Tier or level within a recognition society hierarchy (e.g., Bronze, Silver, Gold, Platinum). Applicable to recognition societies.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:startDate rdf:type rdf:Property ;
    rdfs:label 'Start Date' ;
    rdfs:comment 'Official start date when the campaign becomes active for gift counting and solicitation.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:stewardshipPlan rdf:type rdf:Property ;
    rdfs:label 'Stewardship Plan' ;
    rdfs:comment 'Description of donor stewardship activities and recognition plans for campaign contributors.' ;
    rdfs:domain ind:Advancement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:successMetrics rdf:type rdf:Property ;
    rdfs:label 'Success Metrics' ;
    rdfs:comment 'Key performance indicators and success criteria for evaluating campaign effectiveness beyond dollar goals.' ;
    rdfs:domain ind:Advancement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:visibilityStatus rdf:type rdf:Property ;
    rdfs:label 'Visibility Status' ;
    rdfs:comment 'Controls who can view campaign information: public (all), internal (institution only), or confidential (restricted access).' ;
    rdfs:domain ind:Advancement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:careerRecordId rdf:type rdf:Property ;
    rdfs:label 'Career Record Id' ;
    rdfs:comment 'Unique identifier for the alumni career record. Primary key for the career history tracking system.' ;
    rdfs:domain ind:CareerRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:courseSectionId rdf:type rdf:Property ;
    rdfs:label 'Course Section Id' ;
    rdfs:comment 'Foreign key linking to instruction.course_section. Business justification: Accreditation bodies (ABET, regional accreditors) require employment outcome reporting by specific program and course sequences. Linking career records to course sections enables program-level effecti' ;
    rdfs:domain ind:Education ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CourseSection .

ind:surveyResponseId rdf:type rdf:Property ;
    rdfs:label 'Survey Response Id' ;
    rdfs:comment 'Reference to the alumni survey response that provided this career information. Links career data to broader alumni engagement and satisfaction surveys for integrated analysis.' ;
    rdfs:domain ind:Advancement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SurveyResponse .

ind:careerFieldAlignment rdf:type rdf:Property ;
    rdfs:label 'Career Field Alignment' ;
    rdfs:comment 'Assessment of how closely the position aligns with the alumni\'s degree program. Used for program effectiveness evaluation and accreditation reporting to AACSB, ABET, and other specialized accreditors.' ;
    rdfs:domain ind:CareerRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:careerNotes rdf:type rdf:Property ;
    rdfs:label 'Career Notes' ;
    rdfs:comment 'Free-text field for additional context about the career position, including special achievements, awards, promotions, or unique circumstances. Supports personalized alumni engagement and success story identification.' ;
    rdfs:domain ind:CareerRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cipCode rdf:type rdf:Property ;
    rdfs:label 'Cip Code' ;
    rdfs:comment 'Six-digit CIP code of the degree program associated with this career record. Enables standardized career outcomes reporting by academic discipline for IPEDS and accreditation.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:companyWebsite rdf:type rdf:Property ;
    rdfs:label 'Company Website' ;
    rdfs:comment 'Official website URL of the employer organization. Supports employer research, corporate partnership development, and validation of employer information.' ;
    rdfs:domain ind:CareerRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataCollectionMethod rdf:type rdf:Property ;
    rdfs:label 'Data Collection Method' ;
    rdfs:comment 'Specific method used to collect the career information. Distinguishes between online forms, phone interviews, email surveys, LinkedIn API integration, manual data entry by staff, or batch imports. Used for data quality assessment and process improvement.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employerIndustryCode rdf:type rdf:Property ;
    rdfs:label 'Employer Industry Code' ;
    rdfs:comment 'Six-digit NAICS code classifying the employer\'s primary industry sector. Used for career field analysis and accreditation reporting to AACSB and ABET.' ;
    rdfs:domain ind:CareerRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employerSizeCategory rdf:type rdf:Property ;
    rdfs:label 'Employer Size Category' ;
    rdfs:comment 'Classification of employer organization size. Startup (1-50 employees), Small (51-500), Medium (501-5000), Large (5001-50000), Enterprise (50000+). Supports employer relationship strategy and career outcomes diversity analysis.' ;
    rdfs:domain ind:CareerRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employmentCity rdf:type rdf:Property ;
    rdfs:label 'Employment City' ;
    rdfs:comment 'City where the alumni is employed. Supports geographic distribution analysis and regional alumni engagement strategies.' ;
    rdfs:domain ind:CareerRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employmentCountry rdf:type rdf:Property ;
    rdfs:label 'Employment Country' ;
    rdfs:comment 'Three-letter ISO country code where the alumni is employed. Supports international alumni tracking and global career outcomes reporting.' ;
    rdfs:domain ind:CareerRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employmentStateProvince rdf:type rdf:Property ;
    rdfs:label 'Employment State Province' ;
    rdfs:comment 'Two-letter state or province code where the alumni is employed. Follows USPS state abbreviations for US locations and ISO 3166-2 for international.' ;
    rdfs:domain ind:CareerRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employmentType rdf:type rdf:Property ;
    rdfs:label 'Employment Type' ;
    rdfs:comment 'Classification of the employment arrangement. Distinguishes between full-time, part-time, self-employed, contract, academic positions, and internships for FTE (Full-Time Equivalent) calculations and outcomes reporting.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCurrentPosition rdf:type rdf:Property ;
    rdfs:label 'Is Current Position' ;
    rdfs:comment 'Flag indicating whether this is the alumni\'s current employment position. True for active employment, false for historical positions.' ;
    rdfs:domain ind:CareerRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isFeaturedSuccessStory rdf:type rdf:Property ;
    rdfs:label 'Is Featured Success Story' ;
    rdfs:comment 'Flag indicating whether this career record has been selected as a featured alumni success story for marketing, recruitment, or advancement communications. Supports storytelling and donor engagement initiatives.' ;
    rdfs:domain ind:CareerRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSelfEmployed rdf:type rdf:Property ;
    rdfs:label 'Is Self Employed' ;
    rdfs:comment 'Flag indicating whether the alumni is self-employed or operates their own business. Supports entrepreneurship tracking and specialized alumni engagement programs for business owners.' ;
    rdfs:domain ind:CareerRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isStemPosition rdf:type rdf:Property ;
    rdfs:label 'Is Stem Position' ;
    rdfs:comment 'Flag indicating whether the position is classified as a STEM career. Used for STEM program outcomes reporting, federal grant compliance (NSF, NIH), and specialized accreditation (ABET).' ;
    rdfs:domain ind:CareerRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jobFunctionCategory rdf:type rdf:Property ;
    rdfs:label 'Job Function Category' ;
    rdfs:comment 'Broad functional area of the position such as Engineering, Marketing, Finance, Operations, Research, Education, Healthcare, Legal, or Technology. Supports career pathway analysis and alumni networking by professional interest.' ;
    rdfs:domain ind:CareerRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastVerifiedDate rdf:type rdf:Property ;
    rdfs:label 'Last Verified Date' ;
    rdfs:comment 'Date when the career information was last verified or confirmed as accurate. Used to assess data freshness and prioritize outreach for data updates.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:positionSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Position Sequence Number' ;
    rdfs:comment 'Sequential number indicating the order of this position in the alumni\'s career history. First position after graduation is 1, second is 2, etc. Supports career mobility and progression analysis.' ;
    rdfs:domain ind:CareerRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:recordStatus rdf:type rdf:Property ;
    rdfs:label 'Record Status' ;
    rdfs:comment 'Current lifecycle status of the career record. Active records are current and verified, archived records are historical, pending-verification records await confirmation, disputed records have data quality issues, and deleted records are soft-deleted for audit purposes.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remoteWorkStatus rdf:type rdf:Property ;
    rdfs:label 'Remote Work Status' ;
    rdfs:comment 'Classification of work location arrangement. Captures whether position is on-site, hybrid, or fully remote. Relevant for post-pandemic career outcomes analysis and alumni geographic engagement.' ;
    rdfs:domain ind:CareerRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salaryRangeBand rdf:type rdf:Property ;
    rdfs:label 'Salary Range Band' ;
    rdfs:comment 'Categorical salary range for the position. Collected in bands to protect privacy while enabling ROI (Return on Investment) and career outcomes analysis for accreditation.' ;
    rdfs:domain ind:CareerRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seniorityLevel rdf:type rdf:Property ;
    rdfs:label 'Seniority Level' ;
    rdfs:comment 'Career level classification of the position. Tracks alumni career progression and leadership attainment for advancement engagement and program effectiveness metrics.' ;
    rdfs:domain ind:CareerRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supervisorTitle rdf:type rdf:Property ;
    rdfs:label 'Supervisor Title' ;
    rdfs:comment 'Job title of the alumni\'s direct supervisor or manager. Provides organizational context and supports alumni networking by identifying potential mentors or senior alumni connections.' ;
    rdfs:domain ind:CareerRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:yearsToPosition rdf:type rdf:Property ;
    rdfs:label 'Years To Position' ;
    rdfs:comment 'Calculated number of years from degree completion to the start of this position. Used for time-to-employment metrics and career progression analysis for accreditation and program evaluation.' ;
    rdfs:domain ind:CareerRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:corporateSponsorshipId rdf:type rdf:Property ;
    rdfs:label 'Corporate Sponsorship Id' ;
    rdfs:comment 'Unique identifier for the corporate sponsorship agreement. Primary key for this entity.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CorporateSponsorship .

ind:primaryCorporateEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Corporate Employee Id' ;
    rdfs:comment 'Identifier for the advancement staff member assigned to manage the sponsor relationship, coordinate benefit delivery, and serve as primary institutional contact.' ;
    rdfs:domain ind:CorporateSponsorship ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:regulatoryFilingId rdf:type rdf:Property ;
    rdfs:label 'Regulatory Filing Id' ;
    rdfs:comment 'Foreign key linking to compliance.regulatory_filing. Business justification: Corporate sponsorships may trigger UBIT (unrelated business income tax) filings if quid-pro-quo benefits exceed IRS safe harbors. Link required for tax compliance review and Form 990-T preparation.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RegulatoryFiling .

ind:revenueLedgerAccountId rdf:type rdf:Property ;
    rdfs:label 'Revenue Ledger Account Id' ;
    rdfs:comment 'Foreign key linking to finance.ledger_account. Business justification: Corporate sponsorships post to revenue ledger accounts for GL accounting. Creating corporate_sponsorship.revenue_ledger_account_id to link to finance.ledger_account for revenue recognition.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LedgerAccount .

ind:sponsorOrganizationId rdf:type rdf:Property ;
    rdfs:label 'Sponsor Organization Id' ;
    rdfs:comment 'Reference to the corporate or foundation entity providing the sponsorship. Links to the organization master record in the advancement system.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Organization .

ind:autoRenewFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Renew Flag' ;
    rdfs:comment 'Indicates whether the sponsorship agreement automatically renews unless either party provides notice of termination.' ;
    rdfs:domain ind:Advancement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:benefitPackageDescription rdf:type rdf:Property ;
    rdfs:label 'Benefit Package Description' ;
    rdfs:comment 'Detailed description of the recognition benefits, naming rights, event access, branding opportunities, and other quid pro quo benefits provided to the sponsor in exchange for their financial support.' ;
    rdfs:domain ind:CorporateSponsorship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractDocumentUrl rdf:type rdf:Property ;
    rdfs:label 'Contract Document Url' ;
    rdfs:comment 'URL or file path to the signed sponsorship agreement document stored in the institutional document management system.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractDurationMonths rdf:type rdf:Property ;
    rdfs:label 'Contract Duration Months' ;
    rdfs:comment 'Length of the sponsorship agreement in months, calculated from start to end date.' ;
    rdfs:domain ind:CorporateSponsorship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contractEndDate rdf:type rdf:Property ;
    rdfs:label 'Contract End Date' ;
    rdfs:comment 'Date when the sponsorship agreement expires and sponsor benefits cease, unless renewed.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contractStartDate rdf:type rdf:Property ;
    rdfs:label 'Contract Start Date' ;
    rdfs:comment 'Date when the sponsorship agreement becomes effective and sponsor benefits begin to accrue.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fulfillmentCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Completion Date' ;
    rdfs:comment 'Date when all sponsor benefits and recognition obligations were fully delivered and completed.' ;
    rdfs:domain ind:CorporateSponsorship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fulfillmentStatus rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Status' ;
    rdfs:comment 'Current status of benefit delivery to the sponsor, tracking whether promised recognition and benefits have been provided.' ;
    rdfs:domain ind:CorporateSponsorship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastPaymentDate rdf:type rdf:Property ;
    rdfs:label 'Last Payment Date' ;
    rdfs:comment 'Date of the most recent payment received from the sponsor.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:namingRightsGranted rdf:type rdf:Property ;
    rdfs:label 'Naming Rights Granted' ;
    rdfs:comment 'Specific naming rights granted to the sponsor (e.g., building name, program name, endowed chair title, event title).' ;
    rdfs:domain ind:CorporateSponsorship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextPaymentDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Payment Due Date' ;
    rdfs:comment 'Date when the next scheduled sponsorship payment is expected from the sponsor.' ;
    rdfs:domain ind:CorporateSponsorship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentOutstanding rdf:type rdf:Property ;
    rdfs:label 'Payment Outstanding' ;
    rdfs:comment 'Remaining sponsorship amount not yet received, calculated as total sponsorship amount minus payments received to date.' ;
    rdfs:domain ind:CorporateSponsorship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentReceivedToDate rdf:type rdf:Property ;
    rdfs:label 'Payment Received To Date' ;
    rdfs:comment 'Cumulative amount of sponsorship payments received from the sponsor as of the current date.' ;
    rdfs:domain ind:CorporateSponsorship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentSchedule rdf:type rdf:Property ;
    rdfs:label 'Payment Schedule' ;
    rdfs:comment 'Frequency and timing of sponsorship payments (lump sum, annual installments, semi-annual, quarterly, monthly, or milestone-based).' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalDate rdf:type rdf:Property ;
    rdfs:label 'Renewal Date' ;
    rdfs:comment 'Date by which the sponsorship agreement must be renewed or renegotiated to continue beyond the current term.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:renewalEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Renewal Eligible Flag' ;
    rdfs:comment 'Indicates whether this sponsorship agreement is eligible for renewal at the end of the current term.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sponsorContactEmail rdf:type rdf:Property ;
    rdfs:label 'Sponsor Contact Email' ;
    rdfs:comment 'Email address of the primary contact person at the sponsoring organization.' ;
    rdfs:domain ind:CorporateSponsorship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sponsorContactName rdf:type rdf:Property ;
    rdfs:label 'Sponsor Contact Name' ;
    rdfs:comment 'Name of the primary contact person at the sponsoring organization responsible for this agreement.' ;
    rdfs:domain ind:CorporateSponsorship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sponsorContactPhone rdf:type rdf:Property ;
    rdfs:label 'Sponsor Contact Phone' ;
    rdfs:comment 'Phone number of the primary contact person at the sponsoring organization.' ;
    rdfs:domain ind:CorporateSponsorship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sponsorshipAmount rdf:type rdf:Property ;
    rdfs:label 'Sponsorship Amount' ;
    rdfs:comment 'Total monetary value of the sponsorship commitment over the full contract period, representing the gross financial support provided by the sponsor.' ;
    rdfs:domain ind:CorporateSponsorship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sponsorshipNumber rdf:type rdf:Property ;
    rdfs:label 'Sponsorship Number' ;
    rdfs:comment 'Externally-known unique identifier for the sponsorship agreement, used in contracts, invoices, and communications with the sponsor.' ;
    rdfs:domain ind:CorporateSponsorship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sponsorshipStatus rdf:type rdf:Property ;
    rdfs:label 'Sponsorship Status' ;
    rdfs:comment 'Current lifecycle state of the sponsorship agreement (draft under negotiation, pending approval, active and in effect, fulfilled and completed, expired at term end, or terminated early).' ;
    rdfs:domain ind:CorporateSponsorship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sponsorshipType rdf:type rdf:Property ;
    rdfs:label 'Sponsorship Type' ;
    rdfs:comment 'Category of sponsorship indicating what institutional asset or activity is being sponsored (event, academic program, facility naming, research initiative, scholarship fund, or athletics).' ;
    rdfs:domain ind:CorporateSponsorship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminationDate rdf:type rdf:Property ;
    rdfs:label 'Termination Date' ;
    rdfs:comment 'Date when the sponsorship agreement was terminated early, if applicable.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:terminationReason rdf:type rdf:Property ;
    rdfs:label 'Termination Reason' ;
    rdfs:comment 'Explanation for why the sponsorship agreement was terminated before the scheduled end date.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:donorId rdf:type rdf:Property ;
    rdfs:label 'Donor Id' ;
    rdfs:comment 'Unique identifier for the donor record. Primary key for the donor entity. Serves as the system-of-record identifier in Blackbaud Raisers Edge.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Donor .

ind:constituentId rdf:type rdf:Property ;
    rdfs:label 'Constituent Id' ;
    rdfs:comment 'External constituent identifier from Blackbaud Raisers Edge. Business-facing identifier used for donor lookup and correspondence.' ;
    rdfs:domain ind:Advancement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Constituent .

ind:identityAccountId rdf:type rdf:Property ;
    rdfs:label 'Identity Account Id' ;
    rdfs:comment 'Foreign key linking to technology.identity_account. Business justification: Donors with institutional accounts (online giving portals, event registration, donor dashboards) require identity linkage for SSO authentication, personalized giving history displays, and secure docum' ;
    rdfs:domain ind:Education ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IdentityAccount .

ind:primarySpouseDonorId rdf:type rdf:Property ;
    rdfs:label 'Primary Spouse Donor Id' ;
    rdfs:comment 'Identifier of the donor\'s spouse if the spouse is also a constituent in the database. Used for household giving analysis and joint recognition.' ;
    rdfs:domain ind:Donor ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Donor .

ind:consecutiveGivingYears rdf:type rdf:Property ;
    rdfs:label 'Consecutive Giving Years' ;
    rdfs:comment 'Number of consecutive fiscal years the donor has made a gift. Used to identify loyal donors for recognition societies and retention strategies.' ;
    rdfs:domain ind:Donor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:constituentClassification rdf:type rdf:Property ;
    rdfs:label 'Constituent Classification' ;
    rdfs:comment 'CASE-compliant constituent classification indicating primary relationship to the institution. Used for segmentation and reporting to CASE and VSE surveys.' ;
    rdfs:domain ind:Donor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deceasedFlag rdf:type rdf:Property ;
    rdfs:label 'Deceased Flag' ;
    rdfs:comment 'Indicates whether the donor is deceased. When true, suppresses all solicitation communications and triggers estate/planned giving protocols.' ;
    rdfs:domain ind:Advancement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:donorStatus rdf:type rdf:Property ;
    rdfs:label 'Donor Status' ;
    rdfs:comment 'Current lifecycle status of the donor record. Active donors have given within the last 24 months. Lapsed donors have not given recently but have historical giving. Deceased and do-not-contact statuses suppress solicitation.' ;
    rdfs:domain ind:Advancement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:donorType rdf:type rdf:Property ;
    rdfs:label 'Donor Type' ;
    rdfs:comment 'Classification of the donor entity type. Determines applicable tax treatment, reporting requirements, and stewardship protocols.' ;
    rdfs:domain ind:Donor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fiscalYearGivingTotal rdf:type rdf:Property ;
    rdfs:label 'Fiscal Year Giving Total' ;
    rdfs:comment 'Total giving from this donor in the current fiscal year. Used for annual fund reporting and donor recognition society qualification.' ;
    rdfs:domain ind:Donor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:givingCapacityRating rdf:type rdf:Property ;
    rdfs:label 'Giving Capacity Rating' ;
    rdfs:comment 'Prospect research rating indicating the donor\'s estimated philanthropic capacity. Used for major gift identification and portfolio assignment. Proprietary rating scale from wealth screening vendor.' ;
    rdfs:domain ind:Advancement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalName rdf:type rdf:Property ;
    rdfs:label 'Legal Name' ;
    rdfs:comment 'Full legal name of the donor as it appears on official documents, tax receipts, and gift agreements. For individuals: full legal name. For organizations: registered legal entity name.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portfolioAssignment rdf:type rdf:Property ;
    rdfs:label 'Portfolio Assignment' ;
    rdfs:comment 'Fundraising portfolio to which the donor is assigned. Indicates which advancement officer or team is responsible for donor cultivation and solicitation.' ;
    rdfs:domain ind:Donor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Primary Address Line1' ;
    rdfs:comment 'First line of the donor\'s primary mailing address (street number and name). Used for gift acknowledgments, tax receipts, and solicitation mailings.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Primary Address Line2' ;
    rdfs:comment 'Second line of the donor\'s primary mailing address (apartment, suite, unit, building). Optional field for additional address details.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryAffiliation rdf:type rdf:Property ;
    rdfs:label 'Primary Affiliation' ;
    rdfs:comment 'Primary institutional affiliation of the donor (e.g., College of Engineering, School of Business, Athletics). Used for targeted appeals and recognition.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryCity rdf:type rdf:Property ;
    rdfs:label 'Primary City' ;
    rdfs:comment 'City name for the donor\'s primary mailing address. Used for geographic segmentation and regional campaign targeting.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryCountryCode rdf:type rdf:Property ;
    rdfs:label 'Primary Country Code' ;
    rdfs:comment 'Three-letter ISO country code for the donor\'s primary mailing address. Used for international donor segmentation and tax compliance.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryPostalCode rdf:type rdf:Property ;
    rdfs:label 'Primary Postal Code' ;
    rdfs:comment 'Postal or ZIP code for the donor\'s primary mailing address. Used for address validation, NCOA processing, and geographic analysis.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryStateProvince rdf:type rdf:Property ;
    rdfs:label 'Primary State Province' ;
    rdfs:comment 'State or province code for the donor\'s primary mailing address. Two-letter abbreviation for US states or equivalent for international addresses.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salutation rdf:type rdf:Property ;
    rdfs:label 'Salutation' ;
    rdfs:comment 'Formal salutation used in correspondence and communications (e.g., Dr., Mr., Mrs., Ms., The Honorable). Respects donor preferences for formal address.' ;
    rdfs:domain ind:Donor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stewardshipTier rdf:type rdf:Property ;
    rdfs:label 'Stewardship Tier' ;
    rdfs:comment 'Donor stewardship level based on cumulative giving, giving capacity, and engagement. Determines frequency and type of personalized outreach and recognition.' ;
    rdfs:domain ind:Advancement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wealthScreeningDate rdf:type rdf:Property ;
    rdfs:label 'Wealth Screening Date' ;
    rdfs:comment 'Date when the donor\'s wealth and capacity rating was last updated through electronic screening or prospect research. Used to ensure rating currency.' ;
    rdfs:domain ind:Donor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:giftAgreementId rdf:type rdf:Property ;
    rdfs:label 'Gift Agreement Id' ;
    rdfs:comment 'Reference to the legal gift agreement document that governs this endowment\'s terms, restrictions, and spending provisions.' ;
    rdfs:domain ind:Advancement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GiftAgreement .

ind:investmentPoolId rdf:type rdf:Property ;
    rdfs:label 'Investment Pool Id' ;
    rdfs:comment 'Reference to the investment pool in which this endowment\'s assets are invested. Most endowments participate in a commingled investment pool for economies of scale.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InvestmentPool .

ind:primaryDonorId rdf:type rdf:Property ;
    rdfs:label 'Primary Donor Id' ;
    rdfs:comment 'Reference to the primary donor (alumnus or constituent) who established this endowment. Used for stewardship reporting and donor relations.' ;
    rdfs:domain ind:Endowment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Donor .

ind:principalLedgerAccountId rdf:type rdf:Property ;
    rdfs:label 'Principal Ledger Account Id' ;
    rdfs:comment 'Foreign key linking to finance.ledger_account. Business justification: Endowments post to principal ledger accounts for GL accounting of endowment assets. Creating endowment.principal_ledger_account_id to link to finance.ledger_account for financial reporting.' ;
    rdfs:domain ind:Endowment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LedgerAccount .

ind:accountingSegment rdf:type rdf:Property ;
    rdfs:label 'Accounting Segment' ;
    rdfs:comment 'The chart of accounts segment or cost center code to which spending distributions from this endowment are posted in the general ledger.' ;
    rdfs:domain ind:Endowment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:annualDistributionAmount rdf:type rdf:Property ;
    rdfs:label 'Annual Distribution Amount' ;
    rdfs:comment 'The dollar amount authorized for spending distribution from this endowment for the current fiscal year. Calculated based on spending policy rate and market value.' ;
    rdfs:domain ind:Endowment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:benefitingCollege rdf:type rdf:Property ;
    rdfs:label 'Benefiting College' ;
    rdfs:comment 'The academic college or school that receives spending distributions from this endowment. May be institution-wide for unrestricted endowments.' ;
    rdfs:domain ind:Endowment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:benefitingDepartment rdf:type rdf:Property ;
    rdfs:label 'Benefiting Department' ;
    rdfs:comment 'The specific academic department or administrative unit that receives spending distributions from this endowment, if more granular than college level.' ;
    rdfs:domain ind:Endowment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentPrincipalAmount rdf:type rdf:Property ;
    rdfs:label 'Current Principal Amount' ;
    rdfs:comment 'The current corpus or principal balance of the endowment, including all subsequent gifts added to principal. Represents the donor-restricted amount that must be maintained in perpetuity for true endowments.' ;
    rdfs:domain ind:Endowment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fundNumber rdf:type rdf:Property ;
    rdfs:label 'Fund Number' ;
    rdfs:comment 'The externally-known fund accounting number assigned to this endowment in the institutional chart of accounts. Used for financial reporting and donor communication.' ;
    rdfs:domain ind:Endowment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fundPurpose rdf:type rdf:Property ;
    rdfs:label 'Fund Purpose' ;
    rdfs:comment 'Detailed description of the donor-specified purpose and restrictions for spending distributions from this endowment. Defines how funds may be used (e.g., scholarships, faculty support, program funding).' ;
    rdfs:domain ind:Endowment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ipedsReportableFlag rdf:type rdf:Property ;
    rdfs:label 'Ipeds Reportable Flag' ;
    rdfs:comment 'Indicates whether this endowment is included in the institution\'s annual IPEDS Finance Survey endowment reporting. True if reportable, False if excluded.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastStewardshipReportDate rdf:type rdf:Property ;
    rdfs:label 'Last Stewardship Report Date' ;
    rdfs:comment 'The date when the most recent annual stewardship report was sent to the donor or their designee. Used to track stewardship compliance.' ;
    rdfs:domain ind:Endowment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:marketValue rdf:type rdf:Property ;
    rdfs:label 'Market Value' ;
    rdfs:comment 'The current fair market value of the endowment fund, including principal, accumulated gains, and reinvested income. This is the total investable asset value used for spending distribution calculations.' ;
    rdfs:domain ind:Endowment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:marketValueDate rdf:type rdf:Property ;
    rdfs:label 'Market Value Date' ;
    rdfs:comment 'The date as of which the market value was calculated. Typically the last business day of the fiscal quarter or year.' ;
    rdfs:domain ind:Endowment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:minimumBalanceRequired rdf:type rdf:Property ;
    rdfs:label 'Minimum Balance Required' ;
    rdfs:comment 'The minimum endowment balance required by institutional policy before spending distributions can begin. Typically $25,000 to $50,000 for most institutions.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nacuboReportableFlag rdf:type rdf:Property ;
    rdfs:label 'Nacubo Reportable Flag' ;
    rdfs:comment 'Indicates whether this endowment is included in the institution\'s annual NACUBO-Commonfund Study of Endowments participation. True if reportable, False if excluded.' ;
    rdfs:domain ind:Endowment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:namedHonoree rdf:type rdf:Property ;
    rdfs:label 'Named Honoree' ;
    rdfs:comment 'The individual or entity honored or memorialized by this endowment, as specified by the donor. Used in fund naming and stewardship communications.' ;
    rdfs:domain ind:Endowment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextStewardshipReportDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Stewardship Report Due Date' ;
    rdfs:comment 'The date by which the next annual stewardship report is due to be sent to the donor. Typically aligned with fiscal year-end reporting cycles.' ;
    rdfs:domain ind:Endowment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:originalGiftDate rdf:type rdf:Property ;
    rdfs:label 'Original Gift Date' ;
    rdfs:comment 'The date when the initial gift that established this endowment was received. May differ from establishment date if there was a delay in fund setup.' ;
    rdfs:domain ind:Endowment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:originalPrincipalAmount rdf:type rdf:Property ;
    rdfs:label 'Original Principal Amount' ;
    rdfs:comment 'The initial gift amount that established the endowment. This is the historic dollar value of the original contribution and serves as the baseline for UPMIFA spending policy calculations.' ;
    rdfs:domain ind:Endowment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:purposeCategory rdf:type rdf:Property ;
    rdfs:label 'Purpose Category' ;
    rdfs:comment 'High-level classification of the endowment\'s spending purpose for reporting and analysis. Aligns with NACUBO and IPEDS endowment reporting categories.' ;
    rdfs:domain ind:Endowment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:spendingPolicyMethod rdf:type rdf:Property ;
    rdfs:label 'Spending Policy Method' ;
    rdfs:comment 'The methodology used to calculate annual spending distributions. Total return: percentage of smoothed market value. Income only: actual income earned. Hybrid: combination approach.' ;
    rdfs:domain ind:Endowment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stewardshipReportStatus rdf:type rdf:Property ;
    rdfs:label 'Stewardship Report Status' ;
    rdfs:comment 'Status of the annual endowment stewardship report to the donor. Required: report must be sent. Completed: report has been delivered. Waived: donor declined reporting. Pending: report in preparation.' ;
    rdfs:domain ind:Endowment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:underwaterAmount rdf:type rdf:Property ;
    rdfs:label 'Underwater Amount' ;
    rdfs:comment 'The dollar amount by which the current market value is below the original principal, if the endowment is underwater. Null or zero if not underwater.' ;
    rdfs:domain ind:Endowment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:underwaterFlag rdf:type rdf:Property ;
    rdfs:label 'Underwater Flag' ;
    rdfs:comment 'Indicates whether the endowment\'s current market value has fallen below the original principal amount (underwater status). True if underwater, False if not. Affects spending policy decisions under UPMIFA.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:unitMarketValue rdf:type rdf:Property ;
    rdfs:label 'Unit Market Value' ;
    rdfs:comment 'The current market value per unit in the investment pool. Used to calculate the endowment\'s total market value from units held.' ;
    rdfs:domain ind:Endowment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unitsHeld rdf:type rdf:Property ;
    rdfs:label 'Units Held' ;
    rdfs:comment 'The number of units this endowment holds in the investment pool. Market value equals units held multiplied by unit market value.' ;
    rdfs:domain ind:Endowment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ytdDistributionAmount rdf:type rdf:Property ;
    rdfs:label 'Ytd Distribution Amount' ;
    rdfs:comment 'The cumulative amount distributed from this endowment during the current fiscal year to date. Used to track spending against the annual authorization.' ;
    rdfs:domain ind:Endowment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:engagementActivityId rdf:type rdf:Property ;
    rdfs:label 'Engagement Activity Id' ;
    rdfs:comment 'Unique identifier for each engagement activity record. Primary key for the engagement activity entity.' ;
    rdfs:domain ind:EngagementActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryEngagementEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Engagement Employee Id' ;
    rdfs:comment 'Reference to the advancement or alumni relations staff member who recorded or facilitated this engagement activity. Tracks ownership and accountability for relationship management.' ;
    rdfs:domain ind:EngagementActivity ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:programId rdf:type rdf:Property ;
    rdfs:label 'Program Id' ;
    rdfs:comment 'Reference to the alumni relations or advancement program under which this activity was conducted. Examples include annual giving programs, volunteer programs, or career services initiatives.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Education .

ind:activityDate rdf:type rdf:Property ;
    rdfs:label 'Activity Date' ;
    rdfs:comment 'The date on which the engagement activity occurred. Represents the primary business event timestamp for this interaction.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:activityStatus rdf:type rdf:Property ;
    rdfs:label 'Activity Status' ;
    rdfs:comment 'Current lifecycle status of the engagement activity. Tracks whether the activity was completed as planned, cancelled, or is still pending.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:activityTimestamp rdf:type rdf:Property ;
    rdfs:label 'Activity Timestamp' ;
    rdfs:comment 'Precise date and time when the engagement activity took place. Provides granular timing for activities requiring time-of-day tracking.' ;
    rdfs:domain ind:EngagementActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:activityType rdf:type rdf:Property ;
    rdfs:label 'Activity Type' ;
    rdfs:comment 'Classification of the engagement activity. Defines the nature of the interaction between the alumnus and the institution. [ENUM-REF-CANDIDATE: event_attendance|volunteer_service|mentorship_session|career_fair_participation|webinar|campus_visit|phone_call|email_response|social_media_interaction|donation_solicitation|survey_response|networking_event|reunion_attendance|board_meeting|committee_participation — promote to reference product]' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attendeeCount rdf:type rdf:Property ;
    rdfs:label 'Attendee Count' ;
    rdfs:comment 'Number of individuals who participated in the engagement activity. Applicable to group activities such as events, webinars, or meetings. Null for one-on-one interactions.' ;
    rdfs:domain ind:EngagementActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:channel rdf:type rdf:Property ;
    rdfs:label 'Channel' ;
    rdfs:comment 'The communication or interaction channel through which the engagement activity was conducted. Distinguishes the medium of interaction from the activity type.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costAmount rdf:type rdf:Property ;
    rdfs:label 'Cost Amount' ;
    rdfs:comment 'Direct cost incurred by the institution to conduct this engagement activity. Includes event costs, travel expenses, materials, or other direct expenditures. Used for ROI analysis and budget tracking.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:durationMinutes rdf:type rdf:Property ;
    rdfs:label 'Duration Minutes' ;
    rdfs:comment 'Length of the engagement activity in minutes. Applicable to activities with measurable duration such as phone calls, meetings, mentorship sessions, or events.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:followUpDate rdf:type rdf:Property ;
    rdfs:label 'Follow Up Date' ;
    rdfs:comment 'Target date by which follow-up action should be completed. Nullable if no follow-up is required or scheduled.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:followUpRequired rdf:type rdf:Property ;
    rdfs:label 'Follow Up Required' ;
    rdfs:comment 'Indicates whether this engagement activity requires a follow-up action or contact. Used to drive task management and ensure relationship continuity.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isMajorGiftRelated rdf:type rdf:Property ;
    rdfs:label 'Is Major Gift Related' ;
    rdfs:comment 'Indicates whether this engagement activity is part of a major gift cultivation, solicitation, or stewardship effort. Used to prioritize high-value donor relationship activities.' ;
    rdfs:domain ind:EngagementActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isVolunteerActivity rdf:type rdf:Property ;
    rdfs:label 'Is Volunteer Activity' ;
    rdfs:comment 'Indicates whether this activity represents volunteer service by the alumnus on behalf of the institution. Used to track volunteer engagement separately from other interaction types.' ;
    rdfs:domain ind:EngagementActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:location rdf:type rdf:Property ;
    rdfs:label 'Location' ;
    rdfs:comment 'Physical or virtual location where the engagement activity took place. May include campus building names, city names, or virtual platform identifiers.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modifiedBy rdf:type rdf:Property ;
    rdfs:label 'Modified By' ;
    rdfs:comment 'User identifier or system account that last modified this engagement activity record. Audit field for accountability and change management.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Modified Timestamp' ;
    rdfs:comment 'Date and time when this engagement activity record was last updated. Audit field for change tracking and data quality monitoring.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:outcome rdf:type rdf:Property ;
    rdfs:label 'Outcome' ;
    rdfs:comment 'Result or outcome of the engagement activity. Captures whether the activity achieved its intended purpose and what next steps may be required.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorityLevel rdf:type rdf:Property ;
    rdfs:label 'Priority Level' ;
    rdfs:comment 'Priority classification assigned to this engagement activity based on strategic importance, donor capacity, or relationship stage. Guides staff time allocation and follow-up urgency.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseCode rdf:type rdf:Property ;
    rdfs:label 'Response Code' ;
    rdfs:comment 'Standardized code capturing the alumnus response or reaction to the engagement activity. Used for tracking sentiment and engagement quality across interactions.' ;
    rdfs:domain ind:EngagementActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceRecordReference rdf:type rdf:Property ;
    rdfs:label 'Source Record Reference' ;
    rdfs:comment 'Unique identifier of this engagement activity record in the source operational system. Enables traceability and reconciliation with source systems.' ;
    rdfs:domain ind:EngagementActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystem rdf:type rdf:Property ;
    rdfs:label 'Source System' ;
    rdfs:comment 'Name of the operational system from which this engagement activity record originated. Examples include Blackbaud Raisers Edge, Slate CRM, or manual entry systems.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subject rdf:type rdf:Property ;
    rdfs:label 'Subject' ;
    rdfs:comment 'Brief subject line or title summarizing the purpose or topic of the engagement activity. Provides quick context for the interaction.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:giftId rdf:type rdf:Property ;
    rdfs:label 'Gift Id' ;
    rdfs:comment 'Unique identifier for the gift transaction. Primary key for the gift record.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Gift .

ind:giftEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Gift Employee Id' ;
    rdfs:comment 'Reference to the staff member, volunteer, or alumnus who solicited or facilitated the gift. Used for crediting and performance tracking.' ;
    rdfs:domain ind:Gift ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:giftOfficerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Gift Officer Employee Id' ;
    rdfs:comment 'Reference to the advancement staff member responsible for managing the donor relationship and processing this gift. Used for portfolio management and performance tracking.' ;
    rdfs:domain ind:Gift ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:ipedsSubmissionId rdf:type rdf:Property ;
    rdfs:label 'Ipeds Submission Id' ;
    rdfs:comment 'Foreign key linking to compliance.ipeds_submission. Business justification: Gifts are reported in IPEDS Finance component (private gifts/grants revenue) and IPEDS Endowment component. Direct link required for data integrity, audit reconciliation, and to support IPEDS keyholde' ;
    rdfs:domain ind:Education ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IpedsSubmission .

ind:pledgeId rdf:type rdf:Property ;
    rdfs:label 'Pledge Id' ;
    rdfs:comment 'Reference to the pledge record if this gift is a payment toward a multi-year pledge commitment. Links to the pledge master record for tracking fulfillment.' ;
    rdfs:domain ind:Advancement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Pledge .

ind:acknowledgmentDate rdf:type rdf:Property ;
    rdfs:label 'Acknowledgment Date' ;
    rdfs:comment 'The date the acknowledgment letter or receipt was sent to the donor. Required for IRS substantiation requirements and donor stewardship tracking.' ;
    rdfs:domain ind:Advancement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:acknowledgmentStatus rdf:type rdf:Property ;
    rdfs:label 'Acknowledgment Status' ;
    rdfs:comment 'Indicates whether a thank-you acknowledgment letter or receipt has been sent to the donor. Critical for donor stewardship and IRS compliance.' ;
    rdfs:domain ind:Gift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amount rdf:type rdf:Property ;
    rdfs:label 'Amount' ;
    rdfs:comment 'The monetary value of the gift in the transaction currency. For in-kind gifts, this represents the fair market value as appraised or declared.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:amountUsd rdf:type rdf:Property ;
    rdfs:label 'Amount Usd' ;
    rdfs:comment 'The gift amount converted to US Dollars using the exchange rate on the gift date. Used for consolidated reporting and CASE VSE compliance.' ;
    rdfs:domain ind:Gift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:anonymousFlag rdf:type rdf:Property ;
    rdfs:label 'Anonymous Flag' ;
    rdfs:comment 'Indicates whether the donor has requested anonymity for this gift. When true, donor identity is not disclosed in public recognition or reporting.' ;
    rdfs:domain ind:Advancement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:depositDate rdf:type rdf:Property ;
    rdfs:label 'Deposit Date' ;
    rdfs:comment 'The date the gift funds were deposited into the institutional bank account. Used for cash flow tracking and financial reconciliation.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:firstGiftDate rdf:type rdf:Property ;
    rdfs:label 'First Gift Date' ;
    rdfs:comment 'Date of the donor\'s first recorded gift to the institution. Used to calculate donor tenure and loyalty metrics. [Moved from donor: This attribute represents the date of the first gift transaction, which is a derived value from the gift association. It should be calculated from gift.gift_date rather than stored redundantly on the donor record.]' ;
    rdfs:domain ind:Gift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:giftDate rdf:type rdf:Property ;
    rdfs:label 'Gift Date' ;
    rdfs:comment 'The date the gift was received or postmarked, representing the official transaction date for accounting and reporting purposes. This is the primary business event timestamp for the gift.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:giftNumber rdf:type rdf:Property ;
    rdfs:label 'Gift Number' ;
    rdfs:comment 'Business identifier for the gift transaction, typically a human-readable sequential or formatted number assigned by the advancement office for tracking and reference purposes.' ;
    rdfs:domain ind:Gift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:giftSource rdf:type rdf:Property ;
    rdfs:label 'Gift Source' ;
    rdfs:comment 'Classification of the donor type: individual, corporation, foundation, organization, or other entity. Used for CASE VSE reporting and donor segmentation.' ;
    rdfs:domain ind:Gift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:giftStatus rdf:type rdf:Property ;
    rdfs:label 'Gift Status' ;
    rdfs:comment 'Current lifecycle status of the gift transaction indicating whether it has been received, is pending processing, or has been cancelled or adjusted.' ;
    rdfs:domain ind:Gift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:giftType rdf:type rdf:Property ;
    rdfs:label 'Gift Type' ;
    rdfs:comment 'Classification of the gift based on its nature: outright gift, pledge payment, matching gift, gift-in-kind, securities transfer, or planned giving instrument.' ;
    rdfs:domain ind:Gift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inKindDescription rdf:type rdf:Property ;
    rdfs:label 'In Kind Description' ;
    rdfs:comment 'Detailed description of the donated property, goods, or services for in-kind gifts. Required for IRS substantiation and institutional asset management.' ;
    rdfs:domain ind:Gift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:largestGiftAmount rdf:type rdf:Property ;
    rdfs:label 'Largest Gift Amount' ;
    rdfs:comment 'Dollar amount of the largest single gift received from this donor. Used for major gift benchmarking and upgrade solicitation strategies. [Moved from donor: This attribute represents the amount of the largest gift transaction, which is a derived value from the gift association. It should be calculated from gift.gift_amount rather than stored redundantly on the donor record.]' ;
    rdfs:domain ind:Gift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastGiftDate rdf:type rdf:Property ;
    rdfs:label 'Last Gift Date' ;
    rdfs:comment 'Date of the donor\'s most recent gift. Used to identify lapsed donors and calculate recency metrics for predictive modeling. [Moved from donor: This attribute represents the date of the most recent gift transaction, which is a derived value from the gift association. It should be calculated from gift.gift_date rather than stored redundantly on the donor record.]' ;
    rdfs:domain ind:Advancement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lifetimeGivingTotal rdf:type rdf:Property ;
    rdfs:label 'Lifetime Giving Total' ;
    rdfs:comment 'Cumulative total of all gifts received from this donor since the first gift date. Includes cash, pledges paid, and gifts-in-kind at fair market value. Excludes pledge balances. [Moved from donor: This attribute represents the cumulative sum of all gift amounts, which is a derived aggregate from the gift association. It should be calculated from SUM(gift.gift_amount) rather than stored redundantly on the donor record.]' ;
    rdfs:domain ind:Gift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:matchingGiftCompanyName rdf:type rdf:Property ;
    rdfs:label 'Matching Gift Company Name' ;
    rdfs:comment 'Name of the corporation or employer that may provide a matching gift for this donation. Used for matching gift claim processing.' ;
    rdfs:domain ind:Gift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:matchingGiftEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Matching Gift Eligible Flag' ;
    rdfs:comment 'Indicates whether this gift is eligible for corporate matching gift programs. Used to trigger matching gift solicitation workflows.' ;
    rdfs:domain ind:Advancement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:paymentReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Payment Reference Number' ;
    rdfs:comment 'External reference number from the payment processor, bank, or credit card transaction. Used for reconciliation and audit trail.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receiptNumber rdf:type rdf:Property ;
    rdfs:label 'Receipt Number' ;
    rdfs:comment 'Unique receipt number issued to the donor for tax purposes. Required for gifts above IRS thresholds and for donor record-keeping.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restrictionType rdf:type rdf:Property ;
    rdfs:label 'Restriction Type' ;
    rdfs:comment 'Classification of gift restrictions per FASB/GASB accounting standards: unrestricted, temporarily restricted, or permanently restricted (endowment).' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemCode rdf:type rdf:Property ;
    rdfs:label 'Source System Code' ;
    rdfs:comment 'The unique identifier for this gift record in the source operational system. Used for data lineage, reconciliation, and bi-directional synchronization.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stockShares rdf:type rdf:Property ;
    rdfs:label 'Stock Shares' ;
    rdfs:comment 'Number of shares transferred for securities gifts. Used in conjunction with stock price to calculate gift value.' ;
    rdfs:domain ind:Gift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stockSymbol rdf:type rdf:Property ;
    rdfs:label 'Stock Symbol' ;
    rdfs:comment 'Ticker symbol for securities gifts. Used for tracking stock transfers and calculating fair market value at the time of transfer.' ;
    rdfs:domain ind:Gift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxDeductibleAmount rdf:type rdf:Property ;
    rdfs:label 'Tax Deductible Amount' ;
    rdfs:comment 'The portion of the gift amount that qualifies as tax-deductible under IRS regulations. May differ from gift amount for quid pro quo gifts or benefits received.' ;
    rdfs:domain ind:Advancement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:groupMembershipId rdf:type rdf:Property ;
    rdfs:label 'Group Membership Id' ;
    rdfs:comment 'Unique identifier for the group membership record. Primary key for the group membership entity.' ;
    rdfs:domain ind:GroupMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:communicationPreference rdf:type rdf:Property ;
    rdfs:label 'Communication Preference' ;
    rdfs:comment 'The preferred method of communication for this group membership. Indicates how the alumnus wishes to receive group-related communications and updates.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:duesAmount rdf:type rdf:Property ;
    rdfs:label 'Dues Amount' ;
    rdfs:comment 'The monetary amount of dues associated with this membership for the current period. May be zero for complimentary or honorary memberships.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:duesCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Dues Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the dues amount. Typically USD for U.S. institutions but may vary for international chapters.' ;
    rdfs:domain ind:GroupMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:duesPaidDate rdf:type rdf:Property ;
    rdfs:label 'Dues Paid Date' ;
    rdfs:comment 'The date on which the membership dues were paid for the current period. Used to track payment timeliness and compliance.' ;
    rdfs:domain ind:GroupMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:duesPaymentStatus rdf:type rdf:Property ;
    rdfs:label 'Dues Payment Status' ;
    rdfs:comment 'Current payment status of membership dues. Paid indicates full payment received, unpaid indicates no payment, waived indicates dues exempted, partial indicates incomplete payment, overdue indicates past due date, and pending indicates payment processing.' ;
    rdfs:domain ind:GroupMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:electionDate rdf:type rdf:Property ;
    rdfs:label 'Election Date' ;
    rdfs:comment 'The date on which the alumnus was elected to a leadership position within the affinity group. Applicable for elected officer roles.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:eventsAttendedCount rdf:type rdf:Property ;
    rdfs:label 'Events Attended Count' ;
    rdfs:comment 'Total number of affinity group events attended by the alumnus since joining. Used to measure engagement level and chapter health.' ;
    rdfs:domain ind:GroupMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:joinMethod rdf:type rdf:Property ;
    rdfs:label 'Join Method' ;
    rdfs:comment 'The mechanism by which the alumnus joined this affinity group. Self-enrolled indicates alumnus initiated, staff-assigned indicates advancement office action, event-triggered indicates automatic enrollment from event attendance, auto-assigned indicates system rule-based assignment, invitation-accepted indicates response to invitation, and application-approved indicates formal application process.' ;
    rdfs:domain ind:GroupMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastEventAttendedDate rdf:type rdf:Property ;
    rdfs:label 'Last Event Attended Date' ;
    rdfs:comment 'The most recent date on which the alumnus attended an event hosted by this affinity group. Used to track recency of engagement.' ;
    rdfs:domain ind:GroupMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastRenewedDate rdf:type rdf:Property ;
    rdfs:label 'Last Renewed Date' ;
    rdfs:comment 'The most recent date on which the alumnus renewed this membership. Tracks renewal history and engagement continuity.' ;
    rdfs:domain ind:GroupMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:leadershipEndDate rdf:type rdf:Property ;
    rdfs:label 'Leadership End Date' ;
    rdfs:comment 'The date on which the alumnus completed or will complete their leadership term within the affinity group. Used for officer succession planning and historical tracking.' ;
    rdfs:domain ind:GroupMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:leadershipStartDate rdf:type rdf:Property ;
    rdfs:label 'Leadership Start Date' ;
    rdfs:comment 'The date on which the alumnus assumed a leadership role within the affinity group. Applicable only when membership_role indicates an officer or leadership position. Used for officer succession planning.' ;
    rdfs:domain ind:GroupMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:membershipNumber rdf:type rdf:Property ;
    rdfs:label 'Membership Number' ;
    rdfs:comment 'Externally-visible unique membership number or identifier assigned to this alumnus within the specific affinity group. May be used on membership cards or communications.' ;
    rdfs:domain ind:GroupMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:membershipRole rdf:type rdf:Property ;
    rdfs:label 'Membership Role' ;
    rdfs:comment 'The role or position the alumnus holds within the affinity group. Distinguishes between general members and leadership positions such as officers, board members, or chapter presidents. [ENUM-REF-CANDIDATE: member|officer|board_member|chapter_president|vice_president|treasurer|secretary|committee_chair|honorary_member — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:membershipStatus rdf:type rdf:Property ;
    rdfs:label 'Membership Status' ;
    rdfs:comment 'Current lifecycle status of the membership. Active indicates current participation, lapsed indicates expired membership, honorary indicates special recognition status, suspended indicates temporary hold, pending indicates awaiting approval, and inactive indicates permanently ended.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:membershipType rdf:type rdf:Property ;
    rdfs:label 'Membership Type' ;
    rdfs:comment 'Classification of the membership indicating the category or tier. Regular is standard annual membership, lifetime is permanent membership, associate is non-graduate affiliate, emeritus is retired member, student is current student affiliate, and young alumni is recent graduate category.' ;
    rdfs:domain ind:GroupMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:optInFlag rdf:type rdf:Property ;
    rdfs:label 'Opt In Flag' ;
    rdfs:comment 'Indicates whether the alumnus has explicitly opted in to receive communications and participate in activities for this affinity group. True means opted in, false means opted out.' ;
    rdfs:domain ind:GroupMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:termLengthMonths rdf:type rdf:Property ;
    rdfs:label 'Term Length Months' ;
    rdfs:comment 'The length of the membership or leadership term in months. Used for term-based memberships and officer positions to calculate expiration and succession timing.' ;
    rdfs:domain ind:Advancement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:volunteerHours rdf:type rdf:Property ;
    rdfs:label 'Volunteer Hours' ;
    rdfs:comment 'Total number of volunteer hours contributed by the alumnus in their capacity as a member of this affinity group. Used to track engagement and recognize service.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lifelongLearningEnrollmentId rdf:type rdf:Property ;
    rdfs:label 'Lifelong Learning Enrollment Id' ;
    rdfs:comment 'Unique identifier for the lifelong learning enrollment record. Primary key for this entity.' ;
    rdfs:domain ind:LifelongLearningEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:studentAccountId rdf:type rdf:Property ;
    rdfs:label 'Student Account Id' ;
    rdfs:comment 'Foreign key linking to billing.student_account. Business justification: Lifelong learning enrollments generate billing accounts for tuition and fees. Essential for alumni program billing integration, revenue recognition, and financial aid processing for continuing educati' ;
    rdfs:domain ind:Education ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StudentAccount .

ind:termId rdf:type rdf:Property ;
    rdfs:label 'Term Id' ;
    rdfs:comment 'Foreign key linking to enrollment.term. Business justification: Continuing education and certificate programs are often scheduled within institutional term structures for administrative consistency, resource planning, and financial aid eligibility determination. E' ;
    rdfs:domain ind:Education ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Term .

ind:tuitionChargeId rdf:type rdf:Property ;
    rdfs:label 'Tuition Charge Id' ;
    rdfs:comment 'Foreign key linking to billing.tuition_charge. Business justification: Direct link from lifelong learning enrollment to specific tuition charge enables precise revenue tracking, refund processing, and financial reporting for alumni continuing education programs. Critical' ;
    rdfs:domain ind:Education ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TuitionCharge .

ind:actualCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Actual Completion Date' ;
    rdfs:comment 'Actual date on which the alumnus completed all requirements for the lifelong learning program. Null if the program has not been completed.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:certificateIssueDate rdf:type rdf:Property ;
    rdfs:label 'Certificate Issue Date' ;
    rdfs:comment 'Date on which the certificate of completion was issued to the alumnus. Null if no certificate has been issued.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:certificateIssuedFlag rdf:type rdf:Property ;
    rdfs:label 'Certificate Issued Flag' ;
    rdfs:comment 'Indicates whether a certificate of completion or achievement was issued to the alumnus upon successful completion of the program.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:certificateNumber rdf:type rdf:Property ;
    rdfs:label 'Certificate Number' ;
    rdfs:comment 'Unique identifier or serial number assigned to the certificate issued for this enrollment. Used for verification and authentication purposes.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ceuCreditsEarned rdf:type rdf:Property ;
    rdfs:label 'Ceu Credits Earned' ;
    rdfs:comment 'Number of Continuing Education Unit credits earned by the alumnus upon successful completion of the program. CEUs are a standard measure of non-credit professional development.' ;
    rdfs:domain ind:LifelongLearningEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:completionStatus rdf:type rdf:Property ;
    rdfs:label 'Completion Status' ;
    rdfs:comment 'Indicator of whether the alumnus successfully completed the lifelong learning program and met all requirements for certification or recognition.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactHours rdf:type rdf:Property ;
    rdfs:label 'Contact Hours' ;
    rdfs:comment 'Total number of instructional contact hours associated with the lifelong learning program. Used for professional licensing and certification requirements.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deliveryModality rdf:type rdf:Property ;
    rdfs:label 'Delivery Modality' ;
    rdfs:comment 'Method by which the lifelong learning program is delivered. Indicates whether the program is conducted in-person, fully online, or in a hybrid format combining both.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentDate rdf:type rdf:Property ;
    rdfs:label 'Enrollment Date' ;
    rdfs:comment 'Date on which the alumnus enrolled in the lifelong learning program. Represents the official start of the enrollment relationship.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:enrollmentNotes rdf:type rdf:Property ;
    rdfs:label 'Enrollment Notes' ;
    rdfs:comment 'Free-text notes or comments related to the enrollment. May include special accommodations, administrative notes, or other relevant information.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentNumber rdf:type rdf:Property ;
    rdfs:label 'Enrollment Number' ;
    rdfs:comment 'Business identifier for the lifelong learning enrollment. Externally visible enrollment reference number used in communications and reporting.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentStatus rdf:type rdf:Property ;
    rdfs:label 'Enrollment Status' ;
    rdfs:comment 'Current lifecycle status of the enrollment. Tracks whether the alumnus is actively enrolled, has completed the program, withdrawn, or is in another state. [ENUM-REF-CANDIDATE: enrolled|in_progress|completed|withdrawn|incomplete|deferred|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Expected Completion Date' ;
    rdfs:comment 'Anticipated date by which the alumnus is expected to complete the lifelong learning program based on the program schedule and duration.' ;
    rdfs:domain ind:LifelongLearningEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:gradeEarned rdf:type rdf:Property ;
    rdfs:label 'Grade Earned' ;
    rdfs:comment 'Final grade or assessment result earned by the alumnus in the lifelong learning program. May be a letter grade, pass/fail, or other institutional grading scale.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:instructorName rdf:type rdf:Property ;
    rdfs:label 'Instructor Name' ;
    rdfs:comment 'Name of the primary instructor or facilitator for the lifelong learning program. May be null for self-paced or asynchronous programs.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oerBasedFlag rdf:type rdf:Property ;
    rdfs:label 'Oer Based Flag' ;
    rdfs:comment 'Indicates whether the lifelong learning program is based on or incorporates Open Educational Resources. Supports tracking of OER adoption and alumni engagement with open content.' ;
    rdfs:domain ind:LifelongLearningEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:offeringType rdf:type rdf:Property ;
    rdfs:label 'Offering Type' ;
    rdfs:comment 'Classification of the lifelong learning offering type. Distinguishes between MOOCs (Massive Open Online Courses), certificate programs, executive education, alumni audit courses, online modules, workshops, and other professional development formats. [ENUM-REF-CANDIDATE: mooc|certificate_program|executive_education|alumni_audit|online_module|workshop|professional_development|continuing_education — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:LifelongLearningEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:owningCollege rdf:type rdf:Property ;
    rdfs:label 'Owning College' ;
    rdfs:comment 'Name of the college, school, or academic division that owns and administers the lifelong learning program (e.g., College of Business, School of Engineering, Division of Continuing Education).' ;
    rdfs:domain ind:LifelongLearningEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:owningDepartment rdf:type rdf:Property ;
    rdfs:label 'Owning Department' ;
    rdfs:comment 'Name of the department or unit within the college that is responsible for the lifelong learning program.' ;
    rdfs:domain ind:LifelongLearningEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:passFailIndicator rdf:type rdf:Property ;
    rdfs:label 'Pass Fail Indicator' ;
    rdfs:comment 'Simple pass/fail indicator for programs that use binary assessment rather than letter grades.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:platformName rdf:type rdf:Property ;
    rdfs:label 'Platform Name' ;
    rdfs:comment 'Name of the learning management system or platform used to deliver the lifelong learning program (e.g., Canvas, Coursera, edX, institutional LMS).' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programCode rdf:type rdf:Property ;
    rdfs:label 'Program Code' ;
    rdfs:comment 'Institutional code or identifier for the lifelong learning program. Used for internal classification and reporting.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programName rdf:type rdf:Property ;
    rdfs:label 'Program Name' ;
    rdfs:comment 'Full name of the lifelong learning program or course in which the alumnus is enrolled. Examples include certificate program names, executive education course titles, or MOOC names.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scholarshipAmount rdf:type rdf:Property ;
    rdfs:label 'Scholarship Amount' ;
    rdfs:comment 'Dollar amount of scholarship or financial aid applied to the enrollment tuition. Null if no scholarship was applied.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scholarshipAppliedFlag rdf:type rdf:Property ;
    rdfs:label 'Scholarship Applied Flag' ;
    rdfs:comment 'Indicates whether a scholarship, discount, or financial aid was applied to reduce the tuition cost for this enrollment.' ;
    rdfs:domain ind:LifelongLearningEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tuitionAmount rdf:type rdf:Property ;
    rdfs:label 'Tuition Amount' ;
    rdfs:comment 'Tuition fee charged for the lifelong learning program. May be zero for complimentary alumni offerings or OER-based programs.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tuitionCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Tuition Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the tuition amount (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:LifelongLearningEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:withdrawalDate rdf:type rdf:Property ;
    rdfs:label 'Withdrawal Date' ;
    rdfs:comment 'Date on which the alumnus officially withdrew from the lifelong learning program. Null if the alumnus has not withdrawn.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:withdrawalReason rdf:type rdf:Property ;
    rdfs:label 'Withdrawal Reason' ;
    rdfs:comment 'Reason provided by the alumnus for withdrawing from the lifelong learning program. Used for program improvement and retention analysis.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:majorGiftProposalId rdf:type rdf:Property ;
    rdfs:label 'Major Gift Proposal Id' ;
    rdfs:comment 'Unique identifier for the major gift proposal record. Primary key for the major gift proposal entity.' ;
    rdfs:domain ind:MajorGiftProposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryMajorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Major Employee Id' ;
    rdfs:comment 'Identifier of the major gifts officer or fundraiser assigned to manage and steward this proposal through the solicitation lifecycle.' ;
    rdfs:domain ind:MajorGiftProposal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualCloseDate rdf:type rdf:Property ;
    rdfs:label 'Actual Close Date' ;
    rdfs:comment 'Date when the prospect made a final commitment decision (accepted or declined). Null until the proposal reaches a closed-won or closed-lost stage.' ;
    rdfs:domain ind:MajorGiftProposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:askAmount rdf:type rdf:Property ;
    rdfs:label 'Ask Amount' ;
    rdfs:comment 'The monetary amount being requested from the prospect in this major gift solicitation. Represents the target gift size for pipeline forecasting and capacity planning.' ;
    rdfs:domain ind:MajorGiftProposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:askDate rdf:type rdf:Property ;
    rdfs:label 'Ask Date' ;
    rdfs:comment 'Date when the formal solicitation ask was made to the prospect. Represents the key milestone when the proposal moved from cultivation to active solicitation.' ;
    rdfs:domain ind:MajorGiftProposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:boardApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Board Approval Date' ;
    rdfs:comment 'Date when the board of trustees or governing body formally approved acceptance of the major gift. Null if board approval is not required or has not yet occurred.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:boardApprovalRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Board Approval Required Flag' ;
    rdfs:comment 'Indicates whether the major gift proposal requires formal approval from the board of trustees or institutional leadership before acceptance. Typically true for gifts above a certain threshold or with special conditions.' ;
    rdfs:domain ind:MajorGiftProposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:committedAmount rdf:type rdf:Property ;
    rdfs:label 'Committed Amount' ;
    rdfs:comment 'Actual amount committed by the prospect if the proposal was accepted. May differ from the original ask amount due to negotiation. Null if proposal was declined or is still open.' ;
    rdfs:domain ind:MajorGiftProposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:confidentialFlag rdf:type rdf:Property ;
    rdfs:label 'Confidential Flag' ;
    rdfs:comment 'Indicates whether the major gift proposal contains sensitive or confidential information requiring restricted access. Used for data security and privacy compliance in advancement operations.' ;
    rdfs:domain ind:MajorGiftProposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:declineReason rdf:type rdf:Property ;
    rdfs:label 'Decline Reason' ;
    rdfs:comment 'Explanation or category code for why the prospect declined the major gift proposal. Used for prospect intelligence and future cultivation strategy. Null if proposal was not declined.' ;
    rdfs:domain ind:MajorGiftProposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedCloseDate rdf:type rdf:Property ;
    rdfs:label 'Expected Close Date' ;
    rdfs:comment 'Anticipated date when the prospect is expected to make a commitment decision on the major gift proposal. Used for pipeline forecasting and fiscal year revenue projections.' ;
    rdfs:domain ind:MajorGiftProposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fundDesignation rdf:type rdf:Property ;
    rdfs:label 'Fund Designation' ;
    rdfs:comment 'Name or code of the institutional fund, endowment, or program to which the major gift will be directed (e.g., \'Engineering Scholarship Fund\', \'Athletics Capital Campaign\', \'Unrestricted Annual Fund\').' ;
    rdfs:domain ind:MajorGiftProposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:giftAgreementDate rdf:type rdf:Property ;
    rdfs:label 'Gift Agreement Date' ;
    rdfs:comment 'Date when the formal gift agreement was executed by all parties. Used for legal compliance and stewardship reporting. Null if no agreement is required or has not been executed.' ;
    rdfs:domain ind:MajorGiftProposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:giftAgreementExecutedFlag rdf:type rdf:Property ;
    rdfs:label 'Gift Agreement Executed Flag' ;
    rdfs:comment 'Indicates whether a formal gift agreement or memorandum of understanding has been signed by both the donor and the institution. Required for endowments and restricted gifts with specific terms.' ;
    rdfs:domain ind:MajorGiftProposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:giftPurpose rdf:type rdf:Property ;
    rdfs:label 'Gift Purpose' ;
    rdfs:comment 'Primary purpose or use category for the proposed major gift (e.g., endowment, capital project, program operating support, scholarship, research funding, unrestricted support). [ENUM-REF-CANDIDATE: endowment|capital|program-support|scholarship|research|unrestricted|faculty-support|student-support — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Advancement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastContactDate rdf:type rdf:Property ;
    rdfs:label 'Last Contact Date' ;
    rdfs:comment 'Date of the most recent substantive contact or interaction with the prospect regarding this proposal. Used for tracking cultivation activity and ensuring timely follow-up.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:namingOpportunity rdf:type rdf:Property ;
    rdfs:label 'Naming Opportunity' ;
    rdfs:comment 'Description of any building, room, endowment, or program naming rights associated with the major gift proposal. Null if no naming opportunity is part of the solicitation.' ;
    rdfs:domain ind:Advancement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextActionDate rdf:type rdf:Property ;
    rdfs:label 'Next Action Date' ;
    rdfs:comment 'Scheduled date for the next planned action or follow-up activity related to the proposal. Used for gift officer task management and pipeline velocity tracking.' ;
    rdfs:domain ind:MajorGiftProposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextActionDescription rdf:type rdf:Property ;
    rdfs:label 'Next Action Description' ;
    rdfs:comment 'Description of the next planned action or step in the solicitation process (e.g., \'Schedule site visit\', \'Send proposal document\', \'Follow-up call with spouse\').' ;
    rdfs:domain ind:MajorGiftProposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:probabilityPercentage rdf:type rdf:Property ;
    rdfs:label 'Probability Percentage' ;
    rdfs:comment 'Estimated likelihood (0-100%) that the proposal will result in a closed-won outcome. Used for weighted pipeline forecasting and revenue projections. Typically increases as proposal advances through stages.' ;
    rdfs:domain ind:MajorGiftProposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:proposalDescription rdf:type rdf:Property ;
    rdfs:label 'Proposal Description' ;
    rdfs:comment 'Detailed narrative describing the major gift proposal, including the case for support, impact statement, and specific use of funds. Used for proposal documentation and stewardship reporting.' ;
    rdfs:domain ind:MajorGiftProposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proposalDocumentUrl rdf:type rdf:Property ;
    rdfs:label 'Proposal Document Url' ;
    rdfs:comment 'Link or file path to the formal written proposal document, case statement, or presentation materials. Used for document management and proposal version control.' ;
    rdfs:domain ind:MajorGiftProposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proposalNumber rdf:type rdf:Property ;
    rdfs:label 'Proposal Number' ;
    rdfs:comment 'Business identifier for the major gift proposal, typically a human-readable code or number used by gift officers and advancement staff to reference the proposal in communications and reports.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proposalOutcome rdf:type rdf:Property ;
    rdfs:label 'Proposal Outcome' ;
    rdfs:comment 'Final disposition of the major gift proposal. Indicates whether the prospect accepted, declined, deferred the decision, or the proposal was withdrawn. Null until proposal reaches a terminal stage.' ;
    rdfs:domain ind:MajorGiftProposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proposalStage rdf:type rdf:Property ;
    rdfs:label 'Proposal Stage' ;
    rdfs:comment 'Current stage of the major gift proposal in the fundraising pipeline. Tracks progression from initial identification through cultivation, ask, and closure. Used for pipeline management and forecasting. [ENUM-REF-CANDIDATE: identification|qualification|cultivation|solicitation|negotiation|stewardship|closed-won|closed-lost — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:MajorGiftProposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proposalStartDate rdf:type rdf:Property ;
    rdfs:label 'Proposal Start Date' ;
    rdfs:comment 'Date when the major gift proposal was formally created and entered into the advancement system. Marks the beginning of the proposals lifecycle for tracking and reporting.' ;
    rdfs:domain ind:MajorGiftProposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:proposalStatus rdf:type rdf:Property ;
    rdfs:label 'Proposal Status' ;
    rdfs:comment 'Operational status of the proposal indicating whether it is actively being pursued, on hold, withdrawn, or completed. Complements proposal_stage with administrative state information. [ENUM-REF-CANDIDATE: active|pending|on-hold|withdrawn|declined|accepted|completed — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proposalTitle rdf:type rdf:Property ;
    rdfs:label 'Proposal Title' ;
    rdfs:comment 'Descriptive title or name of the major gift proposal, summarizing the purpose or focus of the solicitation (e.g., \'Endowed Chair in Computer Science\', \'New Engineering Building Campaign\').' ;
    rdfs:domain ind:MajorGiftProposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proposalType rdf:type rdf:Property ;
    rdfs:label 'Proposal Type' ;
    rdfs:comment 'Classification of the major gift proposal by gift instrument or structure (e.g., outright cash gift, multi-year pledge, planned/deferred gift, foundation grant, corporate sponsorship, in-kind donation).' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:weightedAmount rdf:type rdf:Property ;
    rdfs:label 'Weighted Amount' ;
    rdfs:comment 'Calculated value representing ask_amount multiplied by probability_percentage, used for realistic pipeline forecasting and expected revenue modeling.' ;
    rdfs:domain ind:MajorGiftProposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:matchingGiftClaimId rdf:type rdf:Property ;
    rdfs:label 'Matching Gift Claim Id' ;
    rdfs:comment 'Unique identifier for the matching gift claim record. Primary key.' ;
    rdfs:domain ind:MatchingGiftClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:donorGiftId rdf:type rdf:Property ;
    rdfs:label 'Donor Gift Id' ;
    rdfs:comment 'Reference to the original donor gift that qualifies for employer matching. Links to the gift transaction that triggered this matching gift claim.' ;
    rdfs:domain ind:MatchingGiftClaim ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Gift .

ind:journalEntryId rdf:type rdf:Property ;
    rdfs:label 'Journal Entry Id' ;
    rdfs:comment 'Foreign key linking to finance.journal_entry. Business justification: Matching gift claims generate GL journal entries when payments are received. Creating matching_gift_claim.journal_entry_id to link to finance.journal_entry for revenue recognition and audit trail.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:JournalEntry .

ind:acknowledgmentSentFlag rdf:type rdf:Property ;
    rdfs:label 'Acknowledgment Sent Flag' ;
    rdfs:comment 'Indicates whether a gift acknowledgment letter or receipt was sent to the donor for the matching gift received.' ;
    rdfs:domain ind:Advancement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:appealDate rdf:type rdf:Property ;
    rdfs:label 'Appeal Date' ;
    rdfs:comment 'Date when an appeal was submitted to the employer to reconsider a denied matching gift claim.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:appealOutcome rdf:type rdf:Property ;
    rdfs:label 'Appeal Outcome' ;
    rdfs:comment 'The result of the matching gift claim appeal process, if an appeal was submitted.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appealSubmittedFlag rdf:type rdf:Property ;
    rdfs:label 'Appeal Submitted Flag' ;
    rdfs:comment 'Indicates whether an appeal was submitted to the employer after an initial denial of the matching gift claim.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:claimNumber rdf:type rdf:Property ;
    rdfs:label 'Claim Number' ;
    rdfs:comment 'Business identifier for the matching gift claim, often assigned by the matching gift platform or employer. Used for tracking and correspondence.' ;
    rdfs:domain ind:MatchingGiftClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimStatus rdf:type rdf:Property ;
    rdfs:label 'Claim Status' ;
    rdfs:comment 'Current lifecycle status of the matching gift claim in the processing workflow. [ENUM-REF-CANDIDATE: pending|submitted|under_review|approved|paid|denied|cancelled|expired — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:MatchingGiftClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimedMatchAmount rdf:type rdf:Property ;
    rdfs:label 'Claimed Match Amount' ;
    rdfs:comment 'The total matching gift amount claimed from the employer, calculated based on the original gift amount and match ratio.' ;
    rdfs:domain ind:MatchingGiftClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deadlineDate rdf:type rdf:Property ;
    rdfs:label 'Deadline Date' ;
    rdfs:comment 'The deadline date by which the matching gift claim must be submitted to the employer to remain eligible, typically based on the original gift date.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:denialDate rdf:type rdf:Property ;
    rdfs:label 'Denial Date' ;
    rdfs:comment 'Date when the matching gift claim was officially denied by the employer or platform.' ;
    rdfs:domain ind:MatchingGiftClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:denialReason rdf:type rdf:Property ;
    rdfs:label 'Denial Reason' ;
    rdfs:comment 'Explanation provided by the employer or platform for why the matching gift claim was denied, if applicable.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employerOrganizationCode rdf:type rdf:Property ;
    rdfs:label 'Employer Organization Code' ;
    rdfs:comment 'Reference to the employer organization entity in the advancement system that sponsors the matching gift program.' ;
    rdfs:domain ind:MatchingGiftClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:matchRatio rdf:type rdf:Property ;
    rdfs:label 'Match Ratio' ;
    rdfs:comment 'The ratio at which the employer matches the employee donation (e.g., 1.00 for dollar-for-dollar, 2.00 for two-to-one, 0.50 for half-match). Expressed as a multiplier.' ;
    rdfs:domain ind:MatchingGiftClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:matchingGiftProgramName rdf:type rdf:Property ;
    rdfs:label 'Matching Gift Program Name' ;
    rdfs:comment 'Name of the specific matching gift program offered by the employer, as some employers may have multiple programs with different rules.' ;
    rdfs:domain ind:MatchingGiftClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumMatchAmount rdf:type rdf:Property ;
    rdfs:label 'Maximum Match Amount' ;
    rdfs:comment 'The maximum total matching gift amount the employer will provide per employee per calendar or fiscal year.' ;
    rdfs:domain ind:MatchingGiftClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumGiftAmount rdf:type rdf:Property ;
    rdfs:label 'Minimum Gift Amount' ;
    rdfs:comment 'The minimum donation amount required by the employer matching gift program for a gift to qualify for matching.' ;
    rdfs:domain ind:MatchingGiftClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentReceivedDate rdf:type rdf:Property ;
    rdfs:label 'Payment Received Date' ;
    rdfs:comment 'Date when the institution received the matching gift payment from the employer.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:platformClaimReference rdf:type rdf:Property ;
    rdfs:label 'Platform Claim Reference' ;
    rdfs:comment 'External claim identifier assigned by the third-party matching gift platform for tracking and reconciliation.' ;
    rdfs:domain ind:MatchingGiftClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionDate rdf:type rdf:Property ;
    rdfs:label 'Submission Date' ;
    rdfs:comment 'Date when the matching gift claim was submitted to the employer or matching gift platform for processing.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:submissionMethod rdf:type rdf:Property ;
    rdfs:label 'Submission Method' ;
    rdfs:comment 'The method or channel through which the matching gift claim was submitted to the employer.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thirdPartyPlatformName rdf:type rdf:Property ;
    rdfs:label 'Third Party Platform Name' ;
    rdfs:comment 'Name of the third-party matching gift service or platform used to facilitate the claim (e.g., Double the Donation, HEP Development, Benevity).' ;
    rdfs:domain ind:MatchingGiftClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mentorshipMatchId rdf:type rdf:Property ;
    rdfs:label 'Mentorship Match Id' ;
    rdfs:comment 'Unique identifier for the mentorship match record. Primary key for the mentorship match entity.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MentorshipMatch .

ind:adaAccommodationId rdf:type rdf:Property ;
    rdfs:label 'Ada Accommodation Id' ;
    rdfs:comment 'Foreign key linking to compliance.ada_accommodation. Business justification: Student mentees may have ADA accommodations that must be communicated to alumni mentors (communication format preferences, meeting accessibility needs). Required for program compliance and to ensure e' ;
    rdfs:domain ind:Education ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AdaAccommodation .

ind:mentorAlumnusId rdf:type rdf:Property ;
    rdfs:label 'Mentor Alumnus Id' ;
    rdfs:comment 'Reference to the alumnus serving as the mentor in this match. Links to the alumnus master record.' ;
    rdfs:domain ind:MentorshipMatch ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Alumnus .

ind:mentorPrincipalInvestigatorId rdf:type rdf:Property ;
    rdfs:label 'Mentor Principal Investigator Id' ;
    rdfs:comment 'Foreign key linking to research.principal_investigator. Business justification: Faculty PIs serve as mentors in advancement programs (career mentoring, research mentoring). Advancement tracks faculty engagement for recognition, volunteer management, and demonstrating institutiona' ;
    rdfs:domain ind:MentorshipMatch ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PrincipalInvestigator .

ind:mentorshipProgramId rdf:type rdf:Property ;
    rdfs:label 'Mentorship Program Id' ;
    rdfs:comment 'Reference to the formal mentorship program under which this match was created.' ;
    rdfs:domain ind:Advancement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MentorshipProgram .

ind:actualDurationMonths rdf:type rdf:Property ;
    rdfs:label 'Actual Duration Months' ;
    rdfs:comment 'The actual duration of the mentorship relationship in months, calculated from start to end date.' ;
    rdfs:domain ind:MentorshipMatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:agreementSignedDate rdf:type rdf:Property ;
    rdfs:label 'Agreement Signed Date' ;
    rdfs:comment 'Date when the mentorship agreement was signed by both parties.' ;
    rdfs:domain ind:MentorshipMatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:agreementSignedFlag rdf:type rdf:Property ;
    rdfs:label 'Agreement Signed Flag' ;
    rdfs:comment 'Indicates whether both mentor and mentee signed the mentorship agreement or commitment form.' ;
    rdfs:domain ind:MentorshipMatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:expectedDurationMonths rdf:type rdf:Property ;
    rdfs:label 'Expected Duration Months' ;
    rdfs:comment 'The planned duration of the mentorship relationship in months as defined by the program structure.' ;
    rdfs:domain ind:MentorshipMatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:focusArea rdf:type rdf:Property ;
    rdfs:label 'Focus Area' ;
    rdfs:comment 'Primary focus area or theme of the mentorship relationship as defined at match creation. [ENUM-REF-CANDIDATE: career_development|academic_guidance|networking|industry_transition|leadership|entrepreneurship|work_life_balance — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:MentorshipMatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:industryAlignment rdf:type rdf:Property ;
    rdfs:label 'Industry Alignment' ;
    rdfs:comment 'The industry or professional field that this mentorship match is focused on (e.g., Technology, Healthcare, Finance).' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:matchDate rdf:type rdf:Property ;
    rdfs:label 'Match Date' ;
    rdfs:comment 'The date when the mentor and mentee were formally paired and the mentorship relationship began.' ;
    rdfs:domain ind:MentorshipMatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:matchEndDate rdf:type rdf:Property ;
    rdfs:label 'Match End Date' ;
    rdfs:comment 'The date when the mentorship relationship concluded, either through successful completion or early termination.' ;
    rdfs:domain ind:MentorshipMatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:matchMethod rdf:type rdf:Property ;
    rdfs:label 'Match Method' ;
    rdfs:comment 'The method used to create this match: algorithm-based matching, manual assignment by coordinator, self-selection by participants, or hybrid approach.' ;
    rdfs:domain ind:MentorshipMatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:matchNotes rdf:type rdf:Property ;
    rdfs:label 'Match Notes' ;
    rdfs:comment 'Free-text notes or comments about the mentorship match, including coordinator observations, special circumstances, or program-specific details.' ;
    rdfs:domain ind:MentorshipMatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:matchNumber rdf:type rdf:Property ;
    rdfs:label 'Match Number' ;
    rdfs:comment 'Business identifier for the mentorship match, used for external reference and communication.' ;
    rdfs:domain ind:MentorshipMatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:matchQualityScore rdf:type rdf:Property ;
    rdfs:label 'Match Quality Score' ;
    rdfs:comment 'Algorithmic or coordinator-assigned score indicating the quality or compatibility of the mentor-mentee pairing, typically on a scale of 1.00 to 5.00.' ;
    rdfs:domain ind:MentorshipMatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:matchStartDate rdf:type rdf:Property ;
    rdfs:label 'Match Start Date' ;
    rdfs:comment 'The official start date of the mentorship relationship, which may differ from match_date if there was a delay between pairing and first interaction.' ;
    rdfs:domain ind:MentorshipMatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:matchStatus rdf:type rdf:Property ;
    rdfs:label 'Match Status' ;
    rdfs:comment 'Current lifecycle status of the mentorship match. Active indicates ongoing relationship; completed indicates successful conclusion; withdrawn indicates early termination; paused indicates temporary suspension.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:menteeGoalsAchieved rdf:type rdf:Property ;
    rdfs:label 'Mentee Goals Achieved' ;
    rdfs:comment 'Number of mentee-defined goals that were successfully achieved during the mentorship relationship.' ;
    rdfs:domain ind:MentorshipMatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:menteeGoalsTotal rdf:type rdf:Property ;
    rdfs:label 'Mentee Goals Total' ;
    rdfs:comment 'Total number of goals defined by the mentee at the start of the mentorship relationship.' ;
    rdfs:domain ind:MentorshipMatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:menteeSatisfactionRating rdf:type rdf:Property ;
    rdfs:label 'Mentee Satisfaction Rating' ;
    rdfs:comment 'Mentee\'s satisfaction rating for the mentorship experience, typically on a scale of 1.00 to 5.00.' ;
    rdfs:domain ind:MentorshipMatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:menteeType rdf:type rdf:Property ;
    rdfs:label 'Mentee Type' ;
    rdfs:comment 'Indicates whether the mentee is a current student or a fellow alumnus participating in peer mentorship.' ;
    rdfs:domain ind:MentorshipMatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mentorSatisfactionRating rdf:type rdf:Property ;
    rdfs:label 'Mentor Satisfaction Rating' ;
    rdfs:comment 'Mentor\'s satisfaction rating for the mentorship experience, typically on a scale of 1.00 to 5.00.' ;
    rdfs:domain ind:MentorshipMatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:orientationCompletedFlag rdf:type rdf:Property ;
    rdfs:label 'Orientation Completed Flag' ;
    rdfs:comment 'Indicates whether both mentor and mentee completed the required program orientation before beginning their relationship.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:orientationCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Orientation Completion Date' ;
    rdfs:comment 'Date when both participants completed the mentorship program orientation.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:primaryCommunicationMode rdf:type rdf:Property ;
    rdfs:label 'Primary Communication Mode' ;
    rdfs:comment 'The primary method of communication used by the mentor and mentee for their interactions.' ;
    rdfs:domain ind:MentorshipMatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programCycle rdf:type rdf:Property ;
    rdfs:label 'Program Cycle' ;
    rdfs:comment 'The cohort or cycle designation for this match (e.g., Fall 2023, Spring 2024, FY2024-Q1).' ;
    rdfs:domain ind:Advancement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recognitionAwardedFlag rdf:type rdf:Property ;
    rdfs:label 'Recognition Awarded Flag' ;
    rdfs:comment 'Indicates whether the mentor received formal recognition or awards for their participation in this match.' ;
    rdfs:domain ind:Advancement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recognitionType rdf:type rdf:Property ;
    rdfs:label 'Recognition Type' ;
    rdfs:comment 'Type of recognition awarded to the mentor (e.g., certificate, award, public acknowledgment, points).' ;
    rdfs:domain ind:MentorshipMatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewedFlag rdf:type rdf:Property ;
    rdfs:label 'Renewed Flag' ;
    rdfs:comment 'Indicates whether this mentorship match was renewed or extended beyond the original program cycle.' ;
    rdfs:domain ind:MentorshipMatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sessionsCompleted rdf:type rdf:Property ;
    rdfs:label 'Sessions Completed' ;
    rdfs:comment 'Total count of documented mentorship sessions or interactions completed between mentor and mentee.' ;
    rdfs:domain ind:MentorshipMatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sessionsExpected rdf:type rdf:Property ;
    rdfs:label 'Sessions Expected' ;
    rdfs:comment 'The target number of mentorship sessions defined by the program requirements for this match.' ;
    rdfs:domain ind:MentorshipMatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:applicationCloseDate rdf:type rdf:Property ;
    rdfs:label 'Application Close Date' ;
    rdfs:comment 'The date when applications for the mentorship program close for the current cycle. After this date, no new applications are accepted until the next cycle.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:applicationOpenDate rdf:type rdf:Property ;
    rdfs:label 'Application Open Date' ;
    rdfs:comment 'The date when applications for the mentorship program open for the current cycle. Used to manage enrollment windows and communications.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:backgroundCheckRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Background Check Required Flag' ;
    rdfs:comment 'Indicates whether mentors must pass a background check before participating in the program. Typically required for programs involving current students or minors. True if required, false if not required.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:eligibilityCriteria rdf:type rdf:Property ;
    rdfs:label 'Eligibility Criteria' ;
    rdfs:comment 'Requirements that alumni or students must meet to participate in the program as mentors or mentees, such as graduation year, degree level, professional experience, geographic location, or membership status.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:matchingCriteria rdf:type rdf:Property ;
    rdfs:label 'Matching Criteria' ;
    rdfs:comment 'Detailed description of the criteria used to match mentors and mentees, such as industry sector, career stage, geographic location, academic major, demographic factors, professional interests, and personal goals.' ;
    rdfs:domain ind:MentorshipProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:matchingMethodology rdf:type rdf:Property ;
    rdfs:label 'Matching Methodology' ;
    rdfs:comment 'The method used to pair mentors with mentees. Staff-matched programs have advancement staff manually review profiles and create matches. Self-selected programs allow participants to browse and choose their own matches. Algorithm-matched programs use automated matching based on criteria such as industry, location, interests, and goals. Hybrid programs combine multiple approaches.' ;
    rdfs:domain ind:MentorshipProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumMenteeCapacity rdf:type rdf:Property ;
    rdfs:label 'Maximum Mentee Capacity' ;
    rdfs:comment 'The maximum number of mentees that can be enrolled in the program during a single cycle. Used for capacity planning and application management.' ;
    rdfs:domain ind:MentorshipProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maximumMentorCapacity rdf:type rdf:Property ;
    rdfs:label 'Maximum Mentor Capacity' ;
    rdfs:comment 'The maximum number of mentors that can be enrolled in the program during a single cycle. Used for capacity planning and recruitment management.' ;
    rdfs:domain ind:MentorshipProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:orientationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Orientation Required Flag' ;
    rdfs:comment 'Indicates whether participants must complete an orientation session before beginning their mentorship relationship. True if orientation is mandatory, false if optional or not offered.' ;
    rdfs:domain ind:MentorshipProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:programDescription rdf:type rdf:Property ;
    rdfs:label 'Program Description' ;
    rdfs:comment 'Comprehensive description of the mentorship programs purpose, goals, structure, and benefits. Used in marketing materials, program catalogs, and participant communications.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programDurationMonths rdf:type rdf:Property ;
    rdfs:label 'Program Duration Months' ;
    rdfs:comment 'The standard length of a mentorship relationship in this program, measured in months. Common durations are 6, 9, or 12 months.' ;
    rdfs:domain ind:MentorshipProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:programEndDate rdf:type rdf:Property ;
    rdfs:label 'Program End Date' ;
    rdfs:comment 'The date when the mentorship program was permanently closed or archived, if applicable. Null for active or ongoing programs.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:programFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Program Fee Amount' ;
    rdfs:comment 'The fee charged to participants to enroll in the mentorship program, if applicable. Zero or null if the program is offered at no cost. Amount in institutional base currency.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:programFeeCurrency rdf:type rdf:Property ;
    rdfs:label 'Program Fee Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the program fee amount. Typically USD for U.S. institutions.' ;
    rdfs:domain ind:MentorshipProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programLaunchDate rdf:type rdf:Property ;
    rdfs:label 'Program Launch Date' ;
    rdfs:comment 'The date when the mentorship program was first launched and began accepting participants. Used for historical tracking and program maturity analysis.' ;
    rdfs:domain ind:MentorshipProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:programNotes rdf:type rdf:Property ;
    rdfs:label 'Program Notes' ;
    rdfs:comment 'Free-form text field for additional information, special considerations, historical context, or operational notes about the mentorship program that do not fit in other structured fields.' ;
    rdfs:domain ind:MentorshipProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programObjectives rdf:type rdf:Property ;
    rdfs:label 'Program Objectives' ;
    rdfs:comment 'Specific learning and development objectives that the program aims to achieve for participants, such as career advancement, skill development, network expansion, or leadership growth.' ;
    rdfs:domain ind:MentorshipProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programStatus rdf:type rdf:Property ;
    rdfs:label 'Program Status' ;
    rdfs:comment 'Current operational status of the mentorship program. Active programs are currently accepting applications and matching participants. Inactive programs are not currently running but may resume. Suspended programs are temporarily paused. Planning programs are in development. Archived programs are permanently closed.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programType rdf:type rdf:Property ;
    rdfs:label 'Program Type' ;
    rdfs:comment 'Classification of the mentorship program by its primary focus area. Career mentorship supports professional development, academic mentorship supports scholarly pursuits, entrepreneurship supports startup and business ventures, diversity and inclusion supports underrepresented populations, peer mentorship connects alumni of similar experience levels, and executive mentorship connects senior leaders with emerging leaders.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programWebsiteUrl rdf:type rdf:Property ;
    rdfs:label 'Program Website Url' ;
    rdfs:comment 'The web address where prospective participants can learn more about the program, view requirements, and submit applications.' ;
    rdfs:domain ind:MentorshipProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scholarshipAvailableFlag rdf:type rdf:Property ;
    rdfs:label 'Scholarship Available Flag' ;
    rdfs:comment 'Indicates whether financial assistance or fee waivers are available for participants who cannot afford the program fee. True if scholarships are offered, false if not.' ;
    rdfs:domain ind:MentorshipProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:targetAudience rdf:type rdf:Property ;
    rdfs:label 'Target Audience' ;
    rdfs:comment 'Description of the intended participant population for the program, such as recent graduates, mid-career professionals, executive leaders, students from specific majors, or alumni from underrepresented groups.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timeCommitmentHours rdf:type rdf:Property ;
    rdfs:label 'Time Commitment Hours' ;
    rdfs:comment 'Expected number of hours per month or per cycle that participants should commit to the mentorship relationship. Used to set expectations and ensure program quality.' ;
    rdfs:domain ind:Advancement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trainingRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Training Required Flag' ;
    rdfs:comment 'Indicates whether mentors must complete formal training before being matched with mentees. True if training is mandatory, false if optional or not offered.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:virtualParticipationAllowedFlag rdf:type rdf:Property ;
    rdfs:label 'Virtual Participation Allowed Flag' ;
    rdfs:comment 'Indicates whether mentorship relationships can be conducted entirely remotely via video conferencing, phone, and email. True if virtual participation is permitted, false if in-person meetings are required.' ;
    rdfs:domain ind:MentorshipProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:outreachCommunicationId rdf:type rdf:Property ;
    rdfs:label 'Outreach Communication Id' ;
    rdfs:comment 'Unique identifier for the outreach communication record. Primary key.' ;
    rdfs:domain ind:OutreachCommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bounceReason rdf:type rdf:Property ;
    rdfs:label 'Bounce Reason' ;
    rdfs:comment 'The reason provided by the delivery system for why the communication bounced or failed to deliver (e.g., invalid address, mailbox full).' ;
    rdfs:domain ind:OutreachCommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clickedFlag rdf:type rdf:Property ;
    rdfs:label 'Clicked Flag' ;
    rdfs:comment 'Indicates whether the recipient clicked on any link within the digital communication. True if clicked, False if not clicked or not tracked.' ;
    rdfs:domain ind:OutreachCommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:clickedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Clicked Timestamp' ;
    rdfs:comment 'The date and time when the recipient first clicked on a link within the digital communication, if tracked.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:communicationDate rdf:type rdf:Property ;
    rdfs:label 'Communication Date' ;
    rdfs:comment 'The date on which the communication was sent or initiated to the alumnus.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:communicationNotes rdf:type rdf:Property ;
    rdfs:label 'Communication Notes' ;
    rdfs:comment 'Additional notes or comments about this communication, including context, special circumstances, or staff observations.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:communicationNumber rdf:type rdf:Property ;
    rdfs:label 'Communication Number' ;
    rdfs:comment 'Business-facing unique identifier or tracking number for this outreach communication, used for reference and audit purposes.' ;
    rdfs:domain ind:OutreachCommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:communicationStatus rdf:type rdf:Property ;
    rdfs:label 'Communication Status' ;
    rdfs:comment 'The current lifecycle status of the communication record (draft, scheduled, sent, completed, cancelled).' ;
    rdfs:domain ind:OutreachCommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:communicationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Communication Timestamp' ;
    rdfs:comment 'The precise date and time when the communication was sent or initiated, including time zone information.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:communicationType rdf:type rdf:Property ;
    rdfs:label 'Communication Type' ;
    rdfs:comment 'The medium or channel through which the communication was sent (email, letter, phone call, text message, social media direct message, postcard).' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryStatus rdf:type rdf:Property ;
    rdfs:label 'Delivery Status' ;
    rdfs:comment 'The delivery status of the communication indicating whether it was successfully sent, delivered, bounced, or failed.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Delivery Timestamp' ;
    rdfs:comment 'The date and time when the communication was confirmed as delivered to the recipient, if applicable.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:ferpaCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Ferpa Compliant Flag' ;
    rdfs:comment 'Indicates whether this communication was logged and handled in compliance with FERPA regulations. True if compliant, False otherwise.' ;
    rdfs:domain ind:OutreachCommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:followUpNotes rdf:type rdf:Property ;
    rdfs:label 'Follow Up Notes' ;
    rdfs:comment 'Notes or instructions regarding the required follow-up action for this communication.' ;
    rdfs:domain ind:OutreachCommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:followUpRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Follow Up Required Flag' ;
    rdfs:comment 'Indicates whether follow-up action is required by advancement staff based on this communication or its response. True if follow-up needed, False otherwise.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:messageBody rdf:type rdf:Property ;
    rdfs:label 'Message Body' ;
    rdfs:comment 'The full text content or body of the communication sent to the alumnus.' ;
    rdfs:domain ind:Advancement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:openedFlag rdf:type rdf:Property ;
    rdfs:label 'Opened Flag' ;
    rdfs:comment 'Indicates whether the digital communication (email, text) was opened by the recipient. True if opened, False if not opened or not tracked.' ;
    rdfs:domain ind:OutreachCommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:openedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Opened Timestamp' ;
    rdfs:comment 'The date and time when the digital communication was first opened by the recipient, if tracked.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:optOutFlag rdf:type rdf:Property ;
    rdfs:label 'Opt Out Flag' ;
    rdfs:comment 'Indicates whether the alumnus opted out of future communications as a result of this outreach. True if opted out, False otherwise.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:responseReceivedFlag rdf:type rdf:Property ;
    rdfs:label 'Response Received Flag' ;
    rdfs:comment 'Indicates whether a response was received from the alumnus following this communication. True if response received, False otherwise.' ;
    rdfs:domain ind:OutreachCommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:responseType rdf:type rdf:Property ;
    rdfs:label 'Response Type' ;
    rdfs:comment 'The type or nature of the response received from the alumnus (e.g., gift, pledge, inquiry, opt-out request, complaint).' ;
    rdfs:domain ind:OutreachCommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentCode rdf:type rdf:Property ;
    rdfs:label 'Segment Code' ;
    rdfs:comment 'A code identifying the alumni segment or target audience group for this communication (e.g., major gift prospects, young alumni, reunion class).' ;
    rdfs:domain ind:OutreachCommunication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:senderEmail rdf:type rdf:Property ;
    rdfs:label 'Sender Email' ;
    rdfs:comment 'The email address from which the communication was sent, if applicable.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:senderName rdf:type rdf:Property ;
    rdfs:label 'Sender Name' ;
    rdfs:comment 'The name of the staff member or office that appears as the sender of the communication.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:solicitationCode rdf:type rdf:Property ;
    rdfs:label 'Solicitation Code' ;
    rdfs:comment 'A code or identifier used to track the specific solicitation strategy or segment associated with this communication.' ;
    rdfs:domain ind:Advancement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedGiftId rdf:type rdf:Property ;
    rdfs:label 'Planned Gift Id' ;
    rdfs:comment 'Unique identifier for the planned gift record. Primary key.' ;
    rdfs:domain ind:PlannedGift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:donorAlumnusId rdf:type rdf:Property ;
    rdfs:label 'Donor Alumnus Id' ;
    rdfs:comment 'Reference to the alumnus who has made the planned gift commitment. Links to the alumnus master record.' ;
    rdfs:domain ind:PlannedGift ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Alumnus .

ind:actualMaturityDate rdf:type rdf:Property ;
    rdfs:label 'Actual Maturity Date' ;
    rdfs:comment 'Actual date when the planned gift matured and assets were transferred to the institution. Populated when commitment status reaches matured.' ;
    rdfs:domain ind:PlannedGift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:commitmentDate rdf:type rdf:Property ;
    rdfs:label 'Commitment Date' ;
    rdfs:comment 'Date when the donor formally communicated or documented their planned gift intention. Principal business event timestamp for this commitment.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:commitmentNumber rdf:type rdf:Property ;
    rdfs:label 'Commitment Number' ;
    rdfs:comment 'Externally-known unique identifier or reference number for the planned gift commitment, used in donor communications and legal documentation.' ;
    rdfs:domain ind:PlannedGift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commitmentStatus rdf:type rdf:Property ;
    rdfs:label 'Commitment Status' ;
    rdfs:comment 'Current lifecycle status of the planned gift commitment. Tracks progression from initial intention through legal execution to maturity or revocation.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contingentBeneficiaryFlag rdf:type rdf:Property ;
    rdfs:label 'Contingent Beneficiary Flag' ;
    rdfs:comment 'Indicates whether the institution is named as a contingent (secondary) beneficiary rather than primary beneficiary. Affects probability of realization and pipeline valuation.' ;
    rdfs:domain ind:PlannedGift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:designationPurpose rdf:type rdf:Property ;
    rdfs:label 'Designation Purpose' ;
    rdfs:comment 'Intended use or purpose of the planned gift proceeds as specified by the donor (e.g., scholarship endowment, faculty chair, unrestricted support, capital project).' ;
    rdfs:domain ind:PlannedGift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentationDate rdf:type rdf:Property ;
    rdfs:label 'Documentation Date' ;
    rdfs:comment 'Date when legal documentation was executed or verified. Distinct from commitment date, which may precede formal documentation.' ;
    rdfs:domain ind:PlannedGift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:estatePercentage rdf:type rdf:Property ;
    rdfs:label 'Estate Percentage' ;
    rdfs:comment 'Percentage of the donor\'s estate designated for the institution in bequest commitments. Null for fixed-amount or non-bequest vehicles.' ;
    rdfs:domain ind:PlannedGift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedValueAmount rdf:type rdf:Property ;
    rdfs:label 'Estimated Value Amount' ;
    rdfs:comment 'Estimated present or future value of the planned gift at maturity, used for pipeline reporting and stewardship tier assignment. Subject to periodic revaluation.' ;
    rdfs:domain ind:PlannedGift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:expectedMaturityDate rdf:type rdf:Property ;
    rdfs:label 'Expected Maturity Date' ;
    rdfs:comment 'Anticipated date when the planned gift will be realized and transferred to the institution. May be estimated based on actuarial tables for life-contingent gifts.' ;
    rdfs:domain ind:PlannedGift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fixedAmount rdf:type rdf:Property ;
    rdfs:label 'Fixed Amount' ;
    rdfs:comment 'Specific dollar amount designated in the planned gift commitment. Used for fixed bequests and annuity contracts. Null for percentage-based commitments.' ;
    rdfs:domain ind:PlannedGift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:giftVehicleType rdf:type rdf:Property ;
    rdfs:label 'Gift Vehicle Type' ;
    rdfs:comment 'The legal instrument or vehicle through which the planned gift will be realized. Determines tax treatment, timing, and stewardship approach.' ;
    rdfs:domain ind:PlannedGift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalDocumentationStatus rdf:type rdf:Property ;
    rdfs:label 'Legal Documentation Status' ;
    rdfs:comment 'Level of legal formalization of the planned gift commitment. Tracks progression from verbal intention through executed legal instruments to institutional verification.' ;
    rdfs:domain ind:PlannedGift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextContactDate rdf:type rdf:Property ;
    rdfs:label 'Next Contact Date' ;
    rdfs:comment 'Scheduled date for next stewardship contact or follow-up activity. Used for relationship management and stewardship workflow.' ;
    rdfs:domain ind:PlannedGift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:primaryBeneficiaryName rdf:type rdf:Property ;
    rdfs:label 'Primary Beneficiary Name' ;
    rdfs:comment 'Name of the primary beneficiary organization as documented in the legal instrument. Typically the institution\'s legal name or a specific college/school within it.' ;
    rdfs:domain ind:PlannedGift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recognitionName rdf:type rdf:Property ;
    rdfs:label 'Recognition Name' ;
    rdfs:comment 'Name(s) to be used for donor recognition purposes in planned giving society materials, honor rolls, and stewardship communications. May differ from legal name.' ;
    rdfs:domain ind:PlannedGift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recognitionPublishedFlag rdf:type rdf:Property ;
    rdfs:label 'Recognition Published Flag' ;
    rdfs:comment 'Indicates whether the donor has consented to public recognition of their planned gift commitment in institutional publications and honor rolls.' ;
    rdfs:domain ind:PlannedGift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:revaluationDate rdf:type rdf:Property ;
    rdfs:label 'Revaluation Date' ;
    rdfs:comment 'Date when the estimated value was last reviewed and updated. Planned gifts should be periodically revalued based on market conditions and actuarial updates.' ;
    rdfs:domain ind:PlannedGift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:revocableFlag rdf:type rdf:Property ;
    rdfs:label 'Revocable Flag' ;
    rdfs:comment 'Indicates whether the donor retains the legal right to revoke or modify the planned gift commitment. True for most bequests; false for irrevocable trusts and executed annuities.' ;
    rdfs:domain ind:PlannedGift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:receivableLedgerAccountId rdf:type rdf:Property ;
    rdfs:label 'Receivable Ledger Account Id' ;
    rdfs:comment 'Foreign key linking to finance.ledger_account. Business justification: Pledges post to pledge receivable ledger accounts for GL accounting. Creating pledge.receivable_ledger_account_id to link to finance.ledger_account for receivable tracking and financial reporting.' ;
    rdfs:domain ind:Pledge ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LedgerAccount .

ind:amountPaid rdf:type rdf:Property ;
    rdfs:label 'Amount Paid' ;
    rdfs:comment 'The cumulative amount that has been paid against the pledge to date, calculated from completed installment payments.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:balanceOutstanding rdf:type rdf:Property ;
    rdfs:label 'Balance Outstanding' ;
    rdfs:comment 'The remaining unpaid balance on the pledge, calculated as pledge_amount minus amount_paid minus write_off_amount.' ;
    rdfs:domain ind:Pledge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:designation rdf:type rdf:Property ;
    rdfs:label 'Designation' ;
    rdfs:comment 'The specific purpose, program, or project to which the pledge is designated, such as scholarship fund, building project, or unrestricted support.' ;
    rdfs:domain ind:Pledge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:finalInstallmentDate rdf:type rdf:Property ;
    rdfs:label 'Final Installment Date' ;
    rdfs:comment 'The due date for the final scheduled installment payment, representing the expected completion date of the pledge.' ;
    rdfs:domain ind:Pledge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:firstInstallmentDate rdf:type rdf:Property ;
    rdfs:label 'First Installment Date' ;
    rdfs:comment 'The due date for the first scheduled installment payment.' ;
    rdfs:domain ind:Pledge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:installmentFrequency rdf:type rdf:Property ;
    rdfs:label 'Installment Frequency' ;
    rdfs:comment 'The recurring schedule on which pledge installments are due, such as monthly, quarterly, or annually.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:installmentsPaid rdf:type rdf:Property ;
    rdfs:label 'Installments Paid' ;
    rdfs:comment 'The count of installments that have been successfully paid to date.' ;
    rdfs:domain ind:Pledge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastPaymentAmount rdf:type rdf:Property ;
    rdfs:label 'Last Payment Amount' ;
    rdfs:comment 'The amount of the most recent installment payment received.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nextInstallmentAmount rdf:type rdf:Property ;
    rdfs:label 'Next Installment Amount' ;
    rdfs:comment 'The scheduled payment amount for the next upcoming installment.' ;
    rdfs:domain ind:Pledge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nextInstallmentDate rdf:type rdf:Property ;
    rdfs:label 'Next Installment Date' ;
    rdfs:comment 'The due date for the next upcoming installment payment, used for reminder workflows and aging analysis.' ;
    rdfs:domain ind:Pledge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:numberOfInstallments rdf:type rdf:Property ;
    rdfs:label 'Number Of Installments' ;
    rdfs:comment 'The total number of scheduled installment payments for this pledge.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pledgeDate rdf:type rdf:Property ;
    rdfs:label 'Pledge Date' ;
    rdfs:comment 'The date on which the donor formally committed to the pledge. This is the principal business event timestamp for the pledge origination.' ;
    rdfs:domain ind:Pledge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pledgeNumber rdf:type rdf:Property ;
    rdfs:label 'Pledge Number' ;
    rdfs:comment 'Business-facing unique identifier or reference number for the pledge, often used in donor communications and receipts.' ;
    rdfs:domain ind:Pledge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pledgeStatus rdf:type rdf:Property ;
    rdfs:label 'Pledge Status' ;
    rdfs:comment 'Current lifecycle status of the pledge commitment indicating whether it is active, fulfilled, or terminated.' ;
    rdfs:domain ind:Pledge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pledgeType rdf:type rdf:Property ;
    rdfs:label 'Pledge Type' ;
    rdfs:comment 'Classification of the pledge based on its structure and conditions, such as outright, multi-year installment, or conditional commitment.' ;
    rdfs:domain ind:Pledge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reminderDate rdf:type rdf:Property ;
    rdfs:label 'Reminder Date' ;
    rdfs:comment 'The date on which a payment reminder should be sent to the donor for an upcoming installment.' ;
    rdfs:domain ind:Pledge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:writeOffAmount rdf:type rdf:Property ;
    rdfs:label 'Write Off Amount' ;
    rdfs:comment 'The portion of the pledge that has been written off as uncollectible, reducing the expected receivable.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:writeOffDate rdf:type rdf:Property ;
    rdfs:label 'Write Off Date' ;
    rdfs:comment 'The date on which the pledge or a portion thereof was written off as uncollectible.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:writeOffReason rdf:type rdf:Property ;
    rdfs:label 'Write Off Reason' ;
    rdfs:comment 'Explanation or justification for writing off the pledge amount, such as donor financial hardship, death, or inability to contact.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prospectRatingId rdf:type rdf:Property ;
    rdfs:label 'Prospect Rating Id' ;
    rdfs:comment 'Unique identifier for the prospect rating record. Primary key for the prospect rating entity.' ;
    rdfs:domain ind:ProspectRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryProspectEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Prospect Employee Id' ;
    rdfs:comment 'Reference to the advancement staff member (major gifts officer or prospect manager) assigned to manage this prospect based on the rating.' ;
    rdfs:domain ind:ProspectRating ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:affinityScore rdf:type rdf:Property ;
    rdfs:label 'Affinity Score' ;
    rdfs:comment 'Numerical score (0-100) representing the prospect\'s emotional connection and engagement with the institution, based on attendance, volunteerism, event participation, and communication responsiveness.' ;
    rdfs:domain ind:ProspectRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assignedRatingTier rdf:type rdf:Property ;
    rdfs:label 'Assigned Rating Tier' ;
    rdfs:comment 'Portfolio management tier assigned for major gifts officer workload distribution: tier 1 (highest capacity/priority), tier 2, tier 3, tier 4, or unassigned.' ;
    rdfs:domain ind:ProspectRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:boardMemberships rdf:type rdf:Property ;
    rdfs:label 'Board Memberships' ;
    rdfs:comment 'Corporate and nonprofit board memberships held by the prospect, indicating leadership capacity and network connections.' ;
    rdfs:domain ind:ProspectRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessInterestsValue rdf:type rdf:Property ;
    rdfs:label 'Business Interests Value' ;
    rdfs:comment 'Estimated value of private business ownership, partnerships, and closely-held company interests based on business valuation data and public filings.' ;
    rdfs:domain ind:ProspectRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capacityCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Capacity Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for all capacity amounts (e.g., USD, CAD, GBP).' ;
    rdfs:domain ind:ProspectRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capacityRating rdf:type rdf:Property ;
    rdfs:label 'Capacity Rating' ;
    rdfs:comment 'Overall giving capacity tier assigned to the prospect: major (100K-999K), principal (1M+), planned (estate gift potential), annual (under 100K), or unrated.' ;
    rdfs:domain ind:ProspectRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataQualityScore rdf:type rdf:Property ;
    rdfs:label 'Data Quality Score' ;
    rdfs:comment 'Numerical score (0-100) representing the completeness and reliability of the underlying data used to generate the rating, often provided by wealth screening vendors.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedAnnualIncome rdf:type rdf:Property ;
    rdfs:label 'Estimated Annual Income' ;
    rdfs:comment 'Estimated annual income from all sources including salary, bonuses, investment income, and business income, derived from compensation disclosures and wealth screening data.' ;
    rdfs:domain ind:ProspectRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedCapacityAmount rdf:type rdf:Property ;
    rdfs:label 'Estimated Capacity Amount' ;
    rdfs:comment 'Estimated total giving capacity in dollars based on wealth indicators, typically representing a lifetime giving potential or single major gift capacity.' ;
    rdfs:domain ind:ProspectRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedCapacityRangeHigh rdf:type rdf:Property ;
    rdfs:label 'Estimated Capacity Range High' ;
    rdfs:comment 'Upper bound of the estimated giving capacity range in dollars.' ;
    rdfs:domain ind:ProspectRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedCapacityRangeLow rdf:type rdf:Property ;
    rdfs:label 'Estimated Capacity Range Low' ;
    rdfs:comment 'Lower bound of the estimated giving capacity range in dollars.' ;
    rdfs:domain ind:ProspectRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedNetWorth rdf:type rdf:Property ;
    rdfs:label 'Estimated Net Worth' ;
    rdfs:comment 'Total estimated net worth calculated as sum of all assets (real estate, stocks, business interests, other investments) minus estimated liabilities.' ;
    rdfs:domain ind:ProspectRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:foundationAffiliations rdf:type rdf:Property ;
    rdfs:label 'Foundation Affiliations' ;
    rdfs:comment 'Names of private foundations where the prospect serves as trustee, officer, or donor, sourced from IRS Form 990 filings.' ;
    rdfs:domain ind:ProspectRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inclinationRating rdf:type rdf:Property ;
    rdfs:label 'Inclination Rating' ;
    rdfs:comment 'Qualitative assessment of the prospect\'s likelihood to give based on past giving behavior, philanthropic interests, and engagement patterns.' ;
    rdfs:domain ind:ProspectRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastReviewedDate rdf:type rdf:Property ;
    rdfs:label 'Last Reviewed Date' ;
    rdfs:comment 'Date when the rating was last reviewed and validated by prospect research staff, ensuring currency and accuracy.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextReviewDate rdf:type rdf:Property ;
    rdfs:label 'Next Review Date' ;
    rdfs:comment 'Scheduled date for the next rating review and refresh, typically 12-24 months from last review per CASE best practices.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:philanthropicInterests rdf:type rdf:Property ;
    rdfs:label 'Philanthropic Interests' ;
    rdfs:comment 'Known philanthropic interests and giving priorities of the prospect based on past giving history, foundation grants, board memberships, and public statements.' ;
    rdfs:domain ind:ProspectRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:politicalContributionsFlag rdf:type rdf:Property ;
    rdfs:label 'Political Contributions Flag' ;
    rdfs:comment 'Indicates whether the prospect has made political contributions disclosed in Federal Election Commission (FEC) records, signaling capacity and civic engagement.' ;
    rdfs:domain ind:ProspectRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:portfolioAssignmentDate rdf:type rdf:Property ;
    rdfs:label 'Portfolio Assignment Date' ;
    rdfs:comment 'Date when the prospect was assigned to a major gifts officer portfolio based on this rating.' ;
    rdfs:domain ind:ProspectRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:propensityScore rdf:type rdf:Property ;
    rdfs:label 'Propensity Score' ;
    rdfs:comment 'Predictive score (0-100) indicating likelihood of making a gift, often generated by statistical modeling or machine learning algorithms based on historical donor behavior.' ;
    rdfs:domain ind:ProspectRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ratingDate rdf:type rdf:Property ;
    rdfs:label 'Rating Date' ;
    rdfs:comment 'Date when the prospect rating was assigned or last updated. Principal business event timestamp for the rating lifecycle.' ;
    rdfs:domain ind:ProspectRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ratingEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Rating Effective Date' ;
    rdfs:comment 'Date from which the rating becomes effective for prospect management and major gifts officer portfolio assignment.' ;
    rdfs:domain ind:ProspectRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ratingExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Rating Expiration Date' ;
    rdfs:comment 'Date when the rating expires and should be refreshed. Typically 12-24 months from rating date per CASE best practices.' ;
    rdfs:domain ind:ProspectRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ratingNotes rdf:type rdf:Property ;
    rdfs:label 'Rating Notes' ;
    rdfs:comment 'Free-text notes from prospect researchers providing context, qualitative insights, and recommendations for cultivation strategy based on the rating.' ;
    rdfs:domain ind:ProspectRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ratingNumber rdf:type rdf:Property ;
    rdfs:label 'Rating Number' ;
    rdfs:comment 'Business identifier for the prospect rating record, typically assigned by the wealth screening vendor or prospect research office.' ;
    rdfs:domain ind:ProspectRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ratingStatus rdf:type rdf:Property ;
    rdfs:label 'Rating Status' ;
    rdfs:comment 'Current lifecycle status of the prospect rating: active (current and valid), expired (outdated), under review (being reassessed), pending (awaiting approval), or archived (historical record).' ;
    rdfs:domain ind:ProspectRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ratingType rdf:type rdf:Property ;
    rdfs:label 'Rating Type' ;
    rdfs:comment 'Classification of the rating methodology used: wealth screening from third-party vendor, manual prospect research, peer screening, electronic screening, or combined approach.' ;
    rdfs:domain ind:ProspectRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:realEstateHoldingsValue rdf:type rdf:Property ;
    rdfs:label 'Real Estate Holdings Value' ;
    rdfs:comment 'Estimated total value of real estate holdings owned by the prospect, sourced from public property records and wealth screening vendors.' ;
    rdfs:domain ind:ProspectRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:researchConfidenceLevel rdf:type rdf:Property ;
    rdfs:label 'Research Confidence Level' ;
    rdfs:comment 'Confidence level in the accuracy and completeness of the wealth indicators and capacity estimate: high (multiple verified sources), medium (limited sources), low (estimated or inferred).' ;
    rdfs:domain ind:ProspectRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:researchSource rdf:type rdf:Property ;
    rdfs:label 'Research Source' ;
    rdfs:comment 'Name of the third-party wealth screening vendor or research source that provided the rating data (e.g., DonorSearch, iWave, WealthEngine, RelSci).' ;
    rdfs:domain ind:ProspectRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:researchVendorCode rdf:type rdf:Property ;
    rdfs:label 'Research Vendor Code' ;
    rdfs:comment 'External identifier assigned by the wealth screening vendor to this rating record, used for data reconciliation and vendor support.' ;
    rdfs:domain ind:ProspectRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stockOwnershipValue rdf:type rdf:Property ;
    rdfs:label 'Stock Ownership Value' ;
    rdfs:comment 'Estimated value of publicly traded stock holdings, including insider holdings reported to SEC and beneficial ownership disclosed in proxy statements.' ;
    rdfs:domain ind:ProspectRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wealthIndicatorSource rdf:type rdf:Property ;
    rdfs:label 'Wealth Indicator Source' ;
    rdfs:comment 'Primary source of wealth indicators used in the rating: public records, SEC filings, proxy statements, Forbes/Fortune lists, foundation 990s, or third-party wealth screening vendor.' ;
    rdfs:domain ind:ProspectRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recognitionSocietyId rdf:type rdf:Property ;
    rdfs:label 'Recognition Society Id' ;
    rdfs:comment 'Unique identifier for the donor recognition society or giving club. Primary key.' ;
    rdfs:domain ind:RecognitionSociety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:associatedFundAdvancementFundId rdf:type rdf:Property ;
    rdfs:label 'Associated Fund Advancement Fund Id' ;
    rdfs:comment 'Reference to the specific fund or endowment that this recognition society supports or is tied to for giving credit.' ;
    rdfs:domain ind:RecognitionSociety ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AdvancementFund .

ind:activeMemberCount rdf:type rdf:Property ;
    rdfs:label 'Active Member Count' ;
    rdfs:comment 'Current number of active members who meet the giving threshold and are in good standing within the recognition society.' ;
    rdfs:domain ind:RecognitionSociety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:annualRecognitionEventFlag rdf:type rdf:Property ;
    rdfs:label 'Annual Recognition Event Flag' ;
    rdfs:comment 'Indicates whether the recognition society hosts an annual signature event for members (True) or not (False).' ;
    rdfs:domain ind:RecognitionSociety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:effectiveEndDate rdf:type rdf:Property ;
    rdfs:label 'Effective End Date' ;
    rdfs:comment 'Date on which the recognition society ceased operations or was retired, if applicable. Null for active societies.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectiveStartDate rdf:type rdf:Property ;
    rdfs:label 'Effective Start Date' ;
    rdfs:comment 'Date from which the recognition society began accepting members and conferring benefits under current criteria.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:endowmentFundedFlag rdf:type rdf:Property ;
    rdfs:label 'Endowment Funded Flag' ;
    rdfs:comment 'Indicates whether the recognition society is supported by or tied to an endowed fund (True) or operates through annual giving (False).' ;
    rdfs:domain ind:RecognitionSociety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:givingLevelTier rdf:type rdf:Property ;
    rdfs:label 'Giving Level Tier' ;
    rdfs:comment 'Hierarchical tier or level within the institutional donor recognition structure (e.g., Platinum, Gold, Silver, Bronze, or numeric tier designation).' ;
    rdfs:domain ind:RecognitionSociety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lifetimeMemberCount rdf:type rdf:Property ;
    rdfs:label 'Lifetime Member Count' ;
    rdfs:comment 'Total cumulative count of all individuals who have ever qualified for membership in the recognition society since its inception.' ;
    rdfs:domain ind:RecognitionSociety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:memberBenefitsSummary rdf:type rdf:Property ;
    rdfs:label 'Member Benefits Summary' ;
    rdfs:comment 'Summary of benefits, privileges, and recognition opportunities provided to members (e.g., exclusive events, publications, naming opportunities, special access).' ;
    rdfs:domain ind:RecognitionSociety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:membershipRenewalRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Membership Renewal Required Flag' ;
    rdfs:comment 'Indicates whether members must renew their membership annually by meeting the giving threshold each year (True) or if membership is conferred permanently once achieved (False).' ;
    rdfs:domain ind:RecognitionSociety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recognitionPublicationFlag rdf:type rdf:Property ;
    rdfs:label 'Recognition Publication Flag' ;
    rdfs:comment 'Indicates whether members of this recognition society are publicly acknowledged in institutional publications, honor rolls, or donor reports (True) or kept confidential (False).' ;
    rdfs:domain ind:RecognitionSociety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:societyCode rdf:type rdf:Property ;
    rdfs:label 'Society Code' ;
    rdfs:comment 'Short alphanumeric code used to identify the recognition society in operational systems and reporting.' ;
    rdfs:domain ind:RecognitionSociety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:societyDescription rdf:type rdf:Property ;
    rdfs:label 'Society Description' ;
    rdfs:comment 'Detailed narrative description of the recognition societys purpose, history, and significance within the institutions advancement program.' ;
    rdfs:domain ind:RecognitionSociety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:societyName rdf:type rdf:Property ;
    rdfs:label 'Society Name' ;
    rdfs:comment 'Official name of the donor recognition society or giving club (e.g., Presidents Circle, Deans Society, Heritage Society).' ;
    rdfs:domain ind:RecognitionSociety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:societyStatus rdf:type rdf:Property ;
    rdfs:label 'Society Status' ;
    rdfs:comment 'Current operational status of the recognition society indicating whether it is actively accepting members and conferring benefits.' ;
    rdfs:domain ind:RecognitionSociety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:societyType rdf:type rdf:Property ;
    rdfs:label 'Society Type' ;
    rdfs:comment 'Classification of the recognition society by giving program type (annual giving leadership clubs, major gift societies, planned giving heritage societies, cumulative lifetime giving, or special purpose recognition).' ;
    rdfs:domain ind:RecognitionSociety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thresholdPeriod rdf:type rdf:Property ;
    rdfs:label 'Threshold Period' ;
    rdfs:comment 'Time period over which the minimum giving threshold is measured (annual giving, lifetime cumulative, specific campaign, fiscal year, or calendar year).' ;
    rdfs:domain ind:RecognitionSociety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stewardshipActionId rdf:type rdf:Property ;
    rdfs:label 'Stewardship Action Id' ;
    rdfs:comment 'Unique identifier for the stewardship action record. Primary key.' ;
    rdfs:domain ind:StewardshipAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ferpaDisclosureId rdf:type rdf:Property ;
    rdfs:label 'Ferpa Disclosure Id' ;
    rdfs:comment 'Foreign key linking to compliance.ferpa_disclosure. Business justification: Stewardship reports to donors often include student/scholarship recipient information (names, majors, photos, testimonials). Each disclosure requires FERPA compliance documentation per 34 CFR 99.32 re' ;
    rdfs:domain ind:Education ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FerpaDisclosure .

ind:stewardshipPlanId rdf:type rdf:Property ;
    rdfs:label 'Stewardship Plan Id' ;
    rdfs:comment 'Reference to the overarching stewardship plan this action fulfills.' ;
    rdfs:domain ind:Advancement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StewardshipPlan .

ind:actionDate rdf:type rdf:Property ;
    rdfs:label 'Action Date' ;
    rdfs:comment 'The date the stewardship action was performed or is scheduled to be performed.' ;
    rdfs:domain ind:StewardshipAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actionNumber rdf:type rdf:Property ;
    rdfs:label 'Action Number' ;
    rdfs:comment 'Human-readable business identifier for the stewardship action, often used for tracking and reference.' ;
    rdfs:domain ind:StewardshipAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actionStatus rdf:type rdf:Property ;
    rdfs:label 'Action Status' ;
    rdfs:comment 'Current lifecycle status of the stewardship action (planned, in progress, completed, cancelled, deferred).' ;
    rdfs:domain ind:StewardshipAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actionType rdf:type rdf:Property ;
    rdfs:label 'Action Type' ;
    rdfs:comment 'Category of stewardship activity performed (e.g., thank-you letter, impact report, IRS 501(c)(3) substantiation letter, scholarship recipient introduction, named space dedication, endowment fund report, recognition event, personal visit, phone call, email update). [ENUM-REF-CANDIDATE: thank_you_letter|impact_report|gift_acknowledgment|scholarship_introduction|named_space_dedication|endowment_report|recognition_event|personal_visit|phone_call|email_update — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignedStaffName rdf:type rdf:Property ;
    rdfs:label 'Assigned Staff Name' ;
    rdfs:comment 'Full name of the advancement staff member assigned to this stewardship action.' ;
    rdfs:domain ind:StewardshipAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:communicationChannel rdf:type rdf:Property ;
    rdfs:label 'Communication Channel' ;
    rdfs:comment 'The delivery method or channel used for the stewardship communication (mail, email, phone, in-person, video call, text message).' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:completionDate rdf:type rdf:Property ;
    rdfs:label 'Completion Date' ;
    rdfs:comment 'The actual date the stewardship action was completed and delivered.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:donorResponseDate rdf:type rdf:Property ;
    rdfs:label 'Donor Response Date' ;
    rdfs:comment 'Date when the donor responded to the stewardship communication.' ;
    rdfs:domain ind:StewardshipAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:donorResponseNotes rdf:type rdf:Property ;
    rdfs:label 'Donor Response Notes' ;
    rdfs:comment 'Free-text notes capturing the content or sentiment of the donor\'s response.' ;
    rdfs:domain ind:StewardshipAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:donorResponseReceived rdf:type rdf:Property ;
    rdfs:label 'Donor Response Received' ;
    rdfs:comment 'Indicates whether the donor provided a response or acknowledgment to this stewardship action.' ;
    rdfs:domain ind:StewardshipAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:donorResponseType rdf:type rdf:Property ;
    rdfs:label 'Donor Response Type' ;
    rdfs:comment 'Method by which the donor responded to the stewardship action.' ;
    rdfs:domain ind:StewardshipAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impactMetricsIncluded rdf:type rdf:Property ;
    rdfs:label 'Impact Metrics Included' ;
    rdfs:comment 'Indicates whether quantitative impact metrics or outcomes were included in this stewardship communication.' ;
    rdfs:domain ind:StewardshipAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:irsAcknowledgmentRequired rdf:type rdf:Property ;
    rdfs:label 'Irs Acknowledgment Required' ;
    rdfs:comment 'Indicates whether this stewardship action fulfills IRS 501(c)(3) substantiation letter requirements for gifts of $250 or more.' ;
    rdfs:domain ind:StewardshipAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:irsAcknowledgmentSentDate rdf:type rdf:Property ;
    rdfs:label 'Irs Acknowledgment Sent Date' ;
    rdfs:comment 'Date when the IRS-compliant gift acknowledgment letter was sent to the donor.' ;
    rdfs:domain ind:StewardshipAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:movesManagementStage rdf:type rdf:Property ;
    rdfs:label 'Moves Management Stage' ;
    rdfs:comment 'Stage in the moves management cycle that this stewardship action supports (identification, cultivation, solicitation, stewardship).' ;
    rdfs:domain ind:StewardshipAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Date' ;
    rdfs:comment 'The originally planned date for this stewardship action, used for tracking timeliness and compliance with stewardship timelines.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scholarshipRecipientName rdf:type rdf:Property ;
    rdfs:label 'Scholarship Recipient Name' ;
    rdfs:comment 'Name of the student receiving scholarship support from the donor\'s gift, used in scholarship introduction letters.' ;
    rdfs:domain ind:StewardshipAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signerName rdf:type rdf:Property ;
    rdfs:label 'Signer Name' ;
    rdfs:comment 'Name of the individual whose signature appears on the stewardship communication (e.g., President, Dean, Development Officer).' ;
    rdfs:domain ind:StewardshipAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signerTitle rdf:type rdf:Property ;
    rdfs:label 'Signer Title' ;
    rdfs:comment 'Official title of the individual signing the stewardship communication.' ;
    rdfs:domain ind:StewardshipAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subjectLine rdf:type rdf:Property ;
    rdfs:label 'Subject Line' ;
    rdfs:comment 'Subject line or title of the stewardship communication, particularly for emails and letters.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:templateCode rdf:type rdf:Property ;
    rdfs:label 'Template Code' ;
    rdfs:comment 'Code identifying the template or format used for this stewardship communication.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:templateName rdf:type rdf:Property ;
    rdfs:label 'Template Name' ;
    rdfs:comment 'Descriptive name of the template used for this stewardship communication.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:academicCollege rdf:type rdf:Property ;
    rdfs:label 'Academic College' ;
    rdfs:comment 'College or school within the institution from which the alumnus graduated.' ;
    rdfs:domain ind:SurveyResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accreditationReportingCycle rdf:type rdf:Property ;
    rdfs:label 'Accreditation Reporting Cycle' ;
    rdfs:comment 'Accreditation reporting cycle or year in which this response was used (e.g., 2023-2024, Fall 2023).' ;
    rdfs:domain ind:SurveyResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:firstAccessDate rdf:type rdf:Property ;
    rdfs:label 'First Access Date' ;
    rdfs:comment 'Date when the alumnus first opened or accessed the survey.' ;
    rdfs:domain ind:SurveyResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:incentiveOfferedFlag rdf:type rdf:Property ;
    rdfs:label 'Incentive Offered Flag' ;
    rdfs:comment 'Indicates whether an incentive (gift card, prize entry, donation) was offered to encourage survey completion.' ;
    rdfs:domain ind:SurveyResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:incentiveType rdf:type rdf:Property ;
    rdfs:label 'Incentive Type' ;
    rdfs:comment 'Type of incentive offered to the alumnus (e.g., gift card, prize drawing entry, charitable donation).' ;
    rdfs:domain ind:SurveyResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jobRelatedToDegreeFlag rdf:type rdf:Property ;
    rdfs:label 'Job Related To Degree Flag' ;
    rdfs:comment 'Indicates whether the alumnus reported that their current job is related to their degree program.' ;
    rdfs:domain ind:SurveyResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jobSearchDurationMonths rdf:type rdf:Property ;
    rdfs:label 'Job Search Duration Months' ;
    rdfs:comment 'Number of months the alumnus spent searching for employment after graduation.' ;
    rdfs:domain ind:SurveyResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:responseChannel rdf:type rdf:Property ;
    rdfs:label 'Response Channel' ;
    rdfs:comment 'Channel or medium through which the alumnus submitted the survey response (web portal, mobile app, email link, phone interview, postal mail, or in-person event).' ;
    rdfs:domain ind:SurveyResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseNotes rdf:type rdf:Property ;
    rdfs:label 'Response Notes' ;
    rdfs:comment 'Free-text notes or comments recorded by survey administrators regarding this response.' ;
    rdfs:domain ind:SurveyResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseNumber rdf:type rdf:Property ;
    rdfs:label 'Response Number' ;
    rdfs:comment 'Business identifier for the survey response, typically generated by the survey platform or advancement system.' ;
    rdfs:domain ind:SurveyResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsePayloadJson rdf:type rdf:Property ;
    rdfs:label 'Response Payload Json' ;
    rdfs:comment 'JSON-formatted payload containing individual question responses and structured survey data for flexible storage and analysis.' ;
    rdfs:domain ind:SurveyResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:satisfactionRating rdf:type rdf:Property ;
    rdfs:label 'Satisfaction Rating' ;
    rdfs:comment 'Overall satisfaction rating provided by the alumnus, typically on a numeric scale (e.g., 1-5 or 1-10).' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:surveyInvitationDate rdf:type rdf:Property ;
    rdfs:label 'Survey Invitation Date' ;
    rdfs:comment 'Date when the survey invitation was sent to the alumnus.' ;
    rdfs:domain ind:SurveyResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:usedInAccreditationFlag rdf:type rdf:Property ;
    rdfs:label 'Used In Accreditation Flag' ;
    rdfs:comment 'Indicates whether this response was included in accreditation reporting (AACSB, ABET, program-level accreditation, or IPEDS).' ;
    rdfs:domain ind:SurveyResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:wouldRecommendFlag rdf:type rdf:Property ;
    rdfs:label 'Would Recommend Flag' ;
    rdfs:comment 'Indicates whether the alumnus would recommend the institution to others, often used for Net Promoter Score (NPS) calculation.' ;
    rdfs:domain ind:SurveyResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:volunteerAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Volunteer Assignment Id' ;
    rdfs:comment 'Unique identifier for the volunteer assignment record. Primary key for the volunteer assignment entity.' ;
    rdfs:domain ind:VolunteerAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:principalInvestigatorId rdf:type rdf:Property ;
    rdfs:label 'Principal Investigator Id' ;
    rdfs:comment 'Foreign key linking to research.principal_investigator. Business justification: Faculty PIs volunteer for advancement activities (advisory boards, fundraising events, donor cultivation). Advancement tracks faculty engagement for recognition, stewardship, and volunteer management.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PrincipalInvestigator .

ind:volunteerRoleId rdf:type rdf:Property ;
    rdfs:label 'Volunteer Role Id' ;
    rdfs:comment 'Reference to the volunteer role catalog entry that defines the role type, requirements, and program association.' ;
    rdfs:domain ind:Advancement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VolunteerRole .

ind:assignmentEndDate rdf:type rdf:Property ;
    rdfs:label 'Assignment End Date' ;
    rdfs:comment 'The date when the volunteer assignment officially ends or is scheduled to end. Nullable for open-ended assignments.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assignmentNotes rdf:type rdf:Property ;
    rdfs:label 'Assignment Notes' ;
    rdfs:comment 'General free-text notes about the volunteer assignment, including special arrangements, preferences, or contextual information.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentNumber rdf:type rdf:Property ;
    rdfs:label 'Assignment Number' ;
    rdfs:comment 'Human-readable business identifier for the volunteer assignment, formatted as VA- followed by 8 digits. Used for tracking and reporting purposes.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentStartDate rdf:type rdf:Property ;
    rdfs:label 'Assignment Start Date' ;
    rdfs:comment 'The date when the volunteer assignment officially begins. Used for tenure calculation and capacity planning.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assignmentStatus rdf:type rdf:Property ;
    rdfs:label 'Assignment Status' ;
    rdfs:comment 'Current lifecycle status of the volunteer assignment. Active indicates the volunteer is currently serving; completed indicates the assignment has ended successfully; on-hold indicates temporary suspension; cancelled indicates early termination; pending indicates awaiting start.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:backgroundCheckDate rdf:type rdf:Property ;
    rdfs:label 'Background Check Date' ;
    rdfs:comment 'The date when the background check was completed or cleared. Nullable if not yet completed or not required.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:backgroundCheckStatus rdf:type rdf:Property ;
    rdfs:label 'Background Check Status' ;
    rdfs:comment 'Current status of the background check for this volunteer assignment. Not-required if no check is needed; pending if in progress; cleared if approved; flagged if issues identified.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hoursServed rdf:type rdf:Property ;
    rdfs:label 'Hours Served' ;
    rdfs:comment 'Total number of volunteer hours served by the alumnus in this assignment. Used for recognition programs and engagement scoring.' ;
    rdfs:domain ind:Advancement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:performanceNotes rdf:type rdf:Property ;
    rdfs:label 'Performance Notes' ;
    rdfs:comment 'Free-text notes documenting the volunteer\'s performance, contributions, challenges, and feedback. Used for stewardship and future assignment planning.' ;
    rdfs:domain ind:VolunteerAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:performanceRating rdf:type rdf:Property ;
    rdfs:label 'Performance Rating' ;
    rdfs:comment 'Overall performance assessment of the volunteer in this assignment. Used for future assignment decisions and recognition.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recognitionDate rdf:type rdf:Property ;
    rdfs:label 'Recognition Date' ;
    rdfs:comment 'The date when formal recognition was awarded to the volunteer for this assignment. Nullable if not yet awarded.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:terminationNotes rdf:type rdf:Property ;
    rdfs:label 'Termination Notes' ;
    rdfs:comment 'Free-text notes documenting the circumstances and details of the assignment termination. Used for stewardship and future engagement planning.' ;
    rdfs:domain ind:VolunteerAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingCompletedFlag rdf:type rdf:Property ;
    rdfs:label 'Training Completed Flag' ;
    rdfs:comment 'Indicates whether the volunteer has completed required training for this assignment. True if training is complete; false otherwise.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:trainingCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Training Completion Date' ;
    rdfs:comment 'The date when the volunteer completed required training for this assignment. Nullable if training is not yet complete.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:activeStatus rdf:type rdf:Property ;
    rdfs:label 'Active Status' ;
    rdfs:comment 'Current lifecycle status of the volunteer role. Active roles are available for volunteer assignment; inactive roles are not currently recruiting.' ;
    rdfs:domain ind:VolunteerRole ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicationRequired rdf:type rdf:Property ;
    rdfs:label 'Application Required' ;
    rdfs:comment 'Indicates whether volunteers must submit a formal application to be considered for this role. False indicates open enrollment or staff assignment.' ;
    rdfs:domain ind:VolunteerRole ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:approvalRequired rdf:type rdf:Property ;
    rdfs:label 'Approval Required' ;
    rdfs:comment 'Indicates whether volunteer assignments to this role require formal approval by advancement staff or leadership. True for high-visibility or sensitive roles.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:associatedProgram rdf:type rdf:Property ;
    rdfs:label 'Associated Program' ;
    rdfs:comment 'The specific volunteer program or initiative this role supports (e.g., Alumni Admissions Network, Career Connections Program, Annual Fund Leadership Council).' ;
    rdfs:domain ind:VolunteerRole ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:backgroundCheckRequired rdf:type rdf:Property ;
    rdfs:label 'Background Check Required' ;
    rdfs:comment 'Indicates whether volunteers in this role must complete a background check before service. True for roles involving minors or sensitive institutional access.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:benefitsDescription rdf:type rdf:Property ;
    rdfs:label 'Benefits Description' ;
    rdfs:comment 'Description of benefits, recognition, or perks provided to volunteers in this role (e.g., Invitation to annual volunteer recognition dinner, Professional development opportunities, Networking access).' ;
    rdfs:domain ind:VolunteerRole ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capacityTarget rdf:type rdf:Property ;
    rdfs:label 'Capacity Target' ;
    rdfs:comment 'Target number of volunteers needed to fill this role across the institution. Used for recruitment planning and capacity management.' ;
    rdfs:domain ind:VolunteerRole ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:createdDate rdf:type rdf:Property ;
    rdfs:label 'Created Date' ;
    rdfs:comment 'Date when this volunteer role record was first created in the system.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicRestriction rdf:type rdf:Property ;
    rdfs:label 'Geographic Restriction' ;
    rdfs:comment 'Geographic limitations for volunteer service in this role (e.g., Local area only, Regional chapters, No restriction). Used for volunteer matching and assignment.' ;
    rdfs:domain ind:VolunteerRole ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impactStatement rdf:type rdf:Property ;
    rdfs:label 'Impact Statement' ;
    rdfs:comment 'Statement describing the institutional impact and value of this volunteer role. Used in recruitment materials to inspire volunteer engagement.' ;
    rdfs:domain ind:VolunteerRole ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastModifiedDate rdf:type rdf:Property ;
    rdfs:label 'Last Modified Date' ;
    rdfs:comment 'Date when this volunteer role record was most recently updated. Used for change tracking and data quality monitoring.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredQualifications rdf:type rdf:Property ;
    rdfs:label 'Preferred Qualifications' ;
    rdfs:comment 'Desired but not mandatory qualifications that would enhance volunteer effectiveness in this role (e.g., Leadership experience, Public speaking skills, Industry expertise).' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remoteEligible rdf:type rdf:Property ;
    rdfs:label 'Remote Eligible' ;
    rdfs:comment 'Indicates whether this volunteer role can be performed remotely or requires on-campus presence. True enables broader geographic volunteer participation.' ;
    rdfs:domain ind:VolunteerRole ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reportingRelationship rdf:type rdf:Property ;
    rdfs:label 'Reporting Relationship' ;
    rdfs:comment 'Description of the staff member or committee to whom volunteers in this role report (e.g., Director of Alumni Relations, Regional Volunteer Coordinator, Annual Fund Manager).' ;
    rdfs:domain ind:VolunteerRole ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiredQualifications rdf:type rdf:Property ;
    rdfs:label 'Required Qualifications' ;
    rdfs:comment 'Mandatory qualifications, credentials, or prerequisites for volunteers to serve in this role (e.g., Must be alumnus/alumna, Minimum 5 years professional experience, Background check required).' ;
    rdfs:domain ind:VolunteerRole ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roleCategory rdf:type rdf:Property ;
    rdfs:label 'Role Category' ;
    rdfs:comment 'Primary classification of the volunteer role by functional area. Determines the type of engagement and reporting hierarchy. [ENUM-REF-CANDIDATE: admissions_ambassador|career_mentor|class_agent|reunion_committee|advisory_board|scholarship_interviewer|phonathon_caller|event_volunteer|student_mentor|fundraising_volunteer|other — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:VolunteerRole ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roleCode rdf:type rdf:Property ;
    rdfs:label 'Role Code' ;
    rdfs:comment 'Short alphanumeric code used for internal reference and reporting (e.g., ADM-AMB, CAR-MEN, CLS-AGT).' ;
    rdfs:domain ind:VolunteerRole ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roleDescription rdf:type rdf:Property ;
    rdfs:label 'Role Description' ;
    rdfs:comment 'Comprehensive description of the volunteer role including responsibilities, expectations, and impact. Used for volunteer recruitment and orientation materials.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roleName rdf:type rdf:Property ;
    rdfs:label 'Role Name' ;
    rdfs:comment 'The official name of the volunteer role as presented to alumni and volunteers (e.g., Admissions Ambassador, Career Mentor, Class Agent, Reunion Committee Member).' ;
    rdfs:domain ind:VolunteerRole ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roleSubcategory rdf:type rdf:Property ;
    rdfs:label 'Role Subcategory' ;
    rdfs:comment 'Secondary classification providing additional granularity within the role category (e.g., within Career Mentor: Industry Mentor, Mock Interview Coach, Resume Reviewer).' ;
    rdfs:domain ind:VolunteerRole ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timeCommitmentEstimate rdf:type rdf:Property ;
    rdfs:label 'Time Commitment Estimate' ;
    rdfs:comment 'Expected time commitment for the volunteer role expressed in hours per month, hours per year, or descriptive terms (e.g., 2-4 hours per month, 10 hours annually, Flexible).' ;
    rdfs:domain ind:VolunteerRole ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timeCommitmentHoursMax rdf:type rdf:Property ;
    rdfs:label 'Time Commitment Hours Max' ;
    rdfs:comment 'Maximum estimated hours per year expected for this volunteer role. Used for volunteer matching and capacity planning.' ;
    rdfs:domain ind:VolunteerRole ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:timeCommitmentHoursMin rdf:type rdf:Property ;
    rdfs:label 'Time Commitment Hours Min' ;
    rdfs:comment 'Minimum estimated hours per year required for this volunteer role. Used for volunteer matching and capacity planning.' ;
    rdfs:domain ind:VolunteerRole ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trainingDescription rdf:type rdf:Property ;
    rdfs:label 'Training Description' ;
    rdfs:comment 'Description of required training programs, modules, or orientation sessions volunteers must complete (e.g., FERPA training, Admissions interview protocol, Fundraising ethics).' ;
    rdfs:domain ind:VolunteerRole ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingRequired rdf:type rdf:Property ;
    rdfs:label 'Training Required' ;
    rdfs:comment 'Indicates whether volunteers must complete formal training before beginning service in this role. True for roles requiring specific knowledge or compliance training.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:aidApplicationId rdf:type rdf:Property ;
    rdfs:label 'Aid Application Id' ;
    rdfs:comment 'Unique identifier for the financial aid application record. Primary key for the aid application entity.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AidApplication .

ind:aidSapEvaluationId rdf:type rdf:Property ;
    rdfs:label 'Aid Sap Evaluation Id' ;
    rdfs:comment 'Foreign key linking to aid.sap_evaluation. Business justification: Satisfactory Academic Progress (SAP) evaluation is performed at checkpoints and affects aid eligibility. The aid_application should reference the SAP evaluation record that determined eligibility for ' ;
    rdfs:domain ind:Education ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AidSapEvaluation .

ind:awardPackageId rdf:type rdf:Property ;
    rdfs:label 'Award Package Id' ;
    rdfs:comment 'Foreign key linking to aid.award_package. Business justification: An aid application results in the creation of an award package. This is a 1:1 or 1:0..1 relationship (application may not result in package if student is ineligible). The aid_application should refere' ;
    rdfs:domain ind:Education ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AwardPackage .

ind:awardYearId rdf:type rdf:Property ;
    rdfs:label 'Award Year Id' ;
    rdfs:comment 'Identifier of the academic award year for which the student is applying for financial aid (e.g., 2023-2024). Links to the award year reference table.' ;
    rdfs:domain ind:Aid ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AwardYear .

ind:isirRecordId rdf:type rdf:Property ;
    rdfs:label 'Isir Record Id' ;
    rdfs:comment 'Foreign key linking to aid.isir_record. Business justification: The aid_application is based on a specific ISIR (Institutional Student Information Record) received from CPS. Currently aid_application has isir_transaction_number as a STRING, but should FK to the is' ;
    rdfs:domain ind:Aid ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IsirRecord .

ind:regulatoryRequirementId rdf:type rdf:Property ;
    rdfs:label 'Regulatory Requirement Id' ;
    rdfs:comment 'Foreign key linking to compliance.regulatory_requirement. Business justification: Title IV applications must track governing federal regulations (HEA sections, 34 CFR parts) that define eligibility criteria, EFC calculation methodology, and verification requirements. Essential for ' ;
    rdfs:domain ind:Education ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RegulatoryRequirement .

ind:residenceBuildingId rdf:type rdf:Property ;
    rdfs:label 'Residence Building Id' ;
    rdfs:comment 'Foreign key linking to facility.building. Business justification: Financial aid COA budgets vary by housing type (on-campus residence hall vs off-campus). Aid applications capture housing_plan_code but need actual residence building for verification, COA calculation' ;
    rdfs:domain ind:AidApplication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Building .

ind:verificationId rdf:type rdf:Property ;
    rdfs:label 'Verification Id' ;
    rdfs:comment 'Foreign key linking to aid.verification. Business justification: Students selected for federal verification have a verification record that tracks the process. The aid_application should FK to the verification record. Columns verification_selection_flag, verificati' ;
    rdfs:domain ind:Aid ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Verification .

ind:aggregateLoanLimitFlag rdf:type rdf:Property ;
    rdfs:label 'Aggregate Loan Limit Flag' ;
    rdfs:comment 'Indicates whether the student has reached or exceeded federal aggregate loan limits for subsidized and unsubsidized Direct Loans. When true, student cannot borrow additional federal loans.' ;
    rdfs:domain ind:AidApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:applicationNumber rdf:type rdf:Property ;
    rdfs:label 'Application Number' ;
    rdfs:comment 'Business identifier for the financial aid application, often used for external reference and student communication.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicationStatus rdf:type rdf:Property ;
    rdfs:label 'Application Status' ;
    rdfs:comment 'Current processing status of the financial aid application in the institutional workflow. [ENUM-REF-CANDIDATE: submitted|under_review|verified|packaged|awarded|cancelled|incomplete — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cCodeFlag rdf:type rdf:Property ;
    rdfs:label 'C Code Flag' ;
    rdfs:comment 'Federal comment codes from the ISIR indicating issues that must be resolved before aid can be disbursed (e.g., conflicting information, missing signatures, data mismatches).' ;
    rdfs:domain ind:AidApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:citizenshipStatus rdf:type rdf:Property ;
    rdfs:label 'Citizenship Status' ;
    rdfs:comment 'Federal citizenship or eligible noncitizen status. Determines eligibility for federal Title IV financial aid programs.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coaAmount rdf:type rdf:Property ;
    rdfs:label 'Coa Amount' ;
    rdfs:comment 'Total Cost of Attendance budget assigned to this application. Includes tuition, fees, room, board, books, supplies, transportation, and personal expenses. Used to calculate financial need.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:defaultOverpaymentFlag rdf:type rdf:Property ;
    rdfs:label 'Default Overpayment Flag' ;
    rdfs:comment 'Indicates whether the student is in default on a federal student loan or owes an overpayment on a federal grant. Students with this flag are ineligible for Title IV aid until resolved.' ;
    rdfs:domain ind:AidApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:directLoanEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Direct Loan Eligible Flag' ;
    rdfs:comment 'Indicates whether the student is eligible for Federal Direct Loans (subsidized and/or unsubsidized) based on enrollment, citizenship, and loan limit checks.' ;
    rdfs:domain ind:AidApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:drugConvictionFlag rdf:type rdf:Property ;
    rdfs:label 'Drug Conviction Flag' ;
    rdfs:comment 'Indicates whether the student has a federal or state drug conviction that affects Title IV aid eligibility during the period of enrollment.' ;
    rdfs:domain ind:AidApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:enrollmentIntensity rdf:type rdf:Property ;
    rdfs:label 'Enrollment Intensity' ;
    rdfs:comment 'Expected enrollment intensity for the award year. Determines eligibility for certain aid programs and affects disbursement amounts.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fafsaReceiptDate rdf:type rdf:Property ;
    rdfs:label 'Fafsa Receipt Date' ;
    rdfs:comment 'Date the institution received the students FAFSA data from the federal processor. Critical for priority deadline determination and aid packaging sequencing.' ;
    rdfs:domain ind:AidApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:financialNeedAmount rdf:type rdf:Property ;
    rdfs:label 'Financial Need Amount' ;
    rdfs:comment 'Calculated financial need for the application. Computed as Cost of Attendance minus Expected Family Contribution (or Student Aid Index). Determines eligibility for need-based aid.' ;
    rdfs:domain ind:Aid ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:housingPlanCode rdf:type rdf:Property ;
    rdfs:label 'Housing Plan Code' ;
    rdfs:comment 'Students planned housing arrangement for the award year. Affects Cost of Attendance (COA) calculation as different housing plans have different budget allowances.' ;
    rdfs:domain ind:AidApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:institutionalMethodologyEfc rdf:type rdf:Property ;
    rdfs:label 'Institutional Methodology Efc' ;
    rdfs:comment 'Expected Family Contribution calculated using the institutions own methodology (e.g., CSS Profile). Used for awarding institutional need-based aid, separate from federal methodology.' ;
    rdfs:domain ind:AidApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pellEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Pell Eligible Flag' ;
    rdfs:comment 'Indicates whether the student is eligible for a Federal Pell Grant based on EFC/SAI and enrollment status.' ;
    rdfs:domain ind:Aid ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pellLeuPercentage rdf:type rdf:Property ;
    rdfs:label 'Pell Leu Percentage' ;
    rdfs:comment 'Percentage of the students lifetime Pell Grant eligibility used. Students are limited to 600% (equivalent to six years of full-time enrollment). Tracked cumulatively across all institutions.' ;
    rdfs:domain ind:AidApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:professionalJudgmentFlag rdf:type rdf:Property ;
    rdfs:label 'Professional Judgment Flag' ;
    rdfs:comment 'Indicates whether a financial aid administrator exercised professional judgment to adjust the students EFC/SAI or dependency status based on special circumstances.' ;
    rdfs:domain ind:Aid ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:professionalJudgmentReason rdf:type rdf:Property ;
    rdfs:label 'Professional Judgment Reason' ;
    rdfs:comment 'Documented reason for professional judgment adjustment, such as loss of employment, medical expenses, or dependency override.' ;
    rdfs:domain ind:Aid ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:selectiveServiceComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Selective Service Compliance Flag' ;
    rdfs:comment 'Indicates whether male students aged 18-25 have registered with Selective Service as required for Title IV aid eligibility.' ;
    rdfs:domain ind:AidApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:stateAidEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'State Aid Eligible Flag' ;
    rdfs:comment 'Indicates whether the student is eligible for state-funded financial aid programs based on residency and state-specific requirements.' ;
    rdfs:domain ind:AidApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:submittedDate rdf:type rdf:Property ;
    rdfs:label 'Submitted Date' ;
    rdfs:comment 'Timestamp when the student initially submitted the financial aid application to the institution.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unusualEnrollmentHistoryFlag rdf:type rdf:Property ;
    rdfs:label 'Unusual Enrollment History Flag' ;
    rdfs:comment 'Federal flag indicating the student has an unusual enrollment history pattern (attending multiple institutions in a short period). Requires additional documentation before aid can be disbursed.' ;
    rdfs:domain ind:AidApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:updatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Updated Timestamp' ;
    rdfs:comment 'System timestamp when the aid application record was last modified. Used for audit trail and data synchronization.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:veteranBenefitsFlag rdf:type rdf:Property ;
    rdfs:label 'Veteran Benefits Flag' ;
    rdfs:comment 'Indicates whether the student is receiving or eligible for veteran education benefits (e.g., GI Bill, Yellow Ribbon Program). Affects coordination of benefits and COA adjustments.' ;
    rdfs:domain ind:AidApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:aidFundId rdf:type rdf:Property ;
    rdfs:label 'Aid Fund Id' ;
    rdfs:comment 'Primary key for fund' ;
    rdfs:domain ind:Aid ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AidFund .

ind:academicLevelRequirement rdf:type rdf:Property ;
    rdfs:label 'Academic Level Requirement' ;
    rdfs:comment 'The academic level(s) of students eligible for this fund. Federal Pell Grants are undergraduate-only, while some institutional funds may be graduate-only or open to all levels.' ;
    rdfs:domain ind:AidFund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:annualAllocationAmount rdf:type rdf:Property ;
    rdfs:label 'Annual Allocation Amount' ;
    rdfs:comment 'The total dollar amount allocated to this fund for the current award year. For federal funds, this represents the institutional allocation from the Department of Education. For institutional funds, this is the budgeted amount.' ;
    rdfs:domain ind:AidFund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cfdaNumber rdf:type rdf:Property ;
    rdfs:label 'Cfda Number' ;
    rdfs:comment 'The five-digit CFDA number assigned to federal financial aid programs for tracking and reporting purposes (e.g., 84.063 for Federal Pell Grant, 84.268 for Federal Direct Loan). Applicable only to federal funds.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:citizenshipRequirement rdf:type rdf:Property ;
    rdfs:label 'Citizenship Requirement' ;
    rdfs:comment 'The citizenship or residency status required for eligibility. Federal Title IV aid requires U.S. citizenship or eligible non-citizen status. Some institutional funds may be open to international students.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coaComponentRestriction rdf:type rdf:Property ;
    rdfs:label 'Coa Component Restriction' ;
    rdfs:comment 'Specifies if this fund can only be applied to specific components of the student\'s Cost of Attendance (e.g., tuition and fees only, room and board only, books and supplies). Null if no restriction exists.' ;
    rdfs:domain ind:AidFund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disbursementFrequency rdf:type rdf:Property ;
    rdfs:label 'Disbursement Frequency' ;
    rdfs:comment 'The frequency with which this fund is disbursed to eligible students: one-time, per academic term, per semester, monthly (for work-study), or biweekly.' ;
    rdfs:domain ind:AidFund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disbursementMethod rdf:type rdf:Property ;
    rdfs:label 'Disbursement Method' ;
    rdfs:comment 'The method by which funds are disbursed: directly to the student, applied to the student account, paid by an employer (for work-study), or paid by a third party.' ;
    rdfs:domain ind:Aid ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:donorName rdf:type rdf:Property ;
    rdfs:label 'Donor Name' ;
    rdfs:comment 'The name of the individual, organization, or foundation that established this fund. Applicable to private and institutional scholarship funds. Confidential for donor privacy.' ;
    rdfs:domain ind:AidFund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:donorRestrictions rdf:type rdf:Property ;
    rdfs:label 'Donor Restrictions' ;
    rdfs:comment 'Free-text description of any donor-imposed restrictions on fund use, such as major field of study, geographic origin, demographic criteria, or other special conditions.' ;
    rdfs:domain ind:AidFund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveDate rdf:type rdf:Property ;
    rdfs:label 'Effective Date' ;
    rdfs:comment 'The date on which this fund becomes available for awarding and disbursement. Typically the start of the award year or the date donor funds are received.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:endowedFlag rdf:type rdf:Property ;
    rdfs:label 'Endowed Flag' ;
    rdfs:comment 'Indicates whether this is an endowed fund where only investment earnings are awarded, preserving the principal in perpetuity.' ;
    rdfs:domain ind:AidFund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:enrollmentStatusRequirement rdf:type rdf:Property ;
    rdfs:label 'Enrollment Status Requirement' ;
    rdfs:comment 'The minimum enrollment status required for a student to be eligible for this fund. Federal Pell Grants are available at any enrollment status, while some institutional scholarships require full-time enrollment.' ;
    rdfs:domain ind:Aid ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expirationDate rdf:type rdf:Property ;
    rdfs:label 'Expiration Date' ;
    rdfs:comment 'The date on which this fund is no longer available for new awards. For federal funds, this is typically the end of the award year. For endowed funds, this may be null indicating perpetual availability.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fundCategory rdf:type rdf:Property ;
    rdfs:label 'Fund Category' ;
    rdfs:comment 'The aid category indicating the nature of the financial assistance: grant (gift aid), loan (repayable), scholarship (merit or need-based gift), work-study (earned aid), fellowship, or assistantship.' ;
    rdfs:domain ind:AidFund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fundDescription rdf:type rdf:Property ;
    rdfs:label 'Fund Description' ;
    rdfs:comment 'Detailed description of the fund\'s purpose, eligibility criteria, and any special conditions. Used for student communication and financial aid counseling.' ;
    rdfs:domain ind:AidFund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gpaRequirement rdf:type rdf:Property ;
    rdfs:label 'Gpa Requirement' ;
    rdfs:comment 'The minimum cumulative GPA required for initial eligibility or continued eligibility (Satisfactory Academic Progress). Null if no GPA requirement exists.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:matchingPercentage rdf:type rdf:Property ;
    rdfs:label 'Matching Percentage' ;
    rdfs:comment 'The percentage of institutional funds required to match federal allocation. For example, SEOG requires 25% institutional match. Null if no matching requirement exists.' ;
    rdfs:domain ind:AidFund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:matchingRequirementFlag rdf:type rdf:Property ;
    rdfs:label 'Matching Requirement Flag' ;
    rdfs:comment 'Indicates whether this fund requires institutional matching funds. True for programs like Federal SEOG and Federal Work-Study that require institutional cost-sharing.' ;
    rdfs:domain ind:AidFund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maximumAwardAmount rdf:type rdf:Property ;
    rdfs:label 'Maximum Award Amount' ;
    rdfs:comment 'The maximum dollar amount that can be awarded to a single student from this fund per award year. For federal programs, this is the statutory maximum (e.g., Pell maximum).' ;
    rdfs:domain ind:Aid ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maximumYearsEligible rdf:type rdf:Property ;
    rdfs:label 'Maximum Years Eligible' ;
    rdfs:comment 'The maximum number of academic years a student may receive this fund. Federal Pell Grant has a 12-semester (6-year) lifetime limit. Null if no limit exists.' ;
    rdfs:domain ind:AidFund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:meritBasedFlag rdf:type rdf:Property ;
    rdfs:label 'Merit Based Flag' ;
    rdfs:comment 'Indicates whether this fund is awarded based on academic merit, talent, or achievement criteria rather than financial need.' ;
    rdfs:domain ind:Aid ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:minimumAwardAmount rdf:type rdf:Property ;
    rdfs:label 'Minimum Award Amount' ;
    rdfs:comment 'The minimum dollar amount that can be awarded to a single student from this fund. Used to ensure awards meet federal or donor-specified minimums.' ;
    rdfs:domain ind:Aid ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:needBasedFlag rdf:type rdf:Property ;
    rdfs:label 'Need Based Flag' ;
    rdfs:comment 'Indicates whether this fund is need-based (requires demonstrated financial need via FAFSA EFC calculation) or non-need-based (merit or other criteria).' ;
    rdfs:domain ind:Aid ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:payoutRate rdf:type rdf:Property ;
    rdfs:label 'Payout Rate' ;
    rdfs:comment 'The annual payout rate applied to endowed funds to determine the amount available for awarding, expressed as a decimal (e.g., 0.0450 for 4.5%). Null for non-endowed funds.' ;
    rdfs:domain ind:AidFund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:refundableFlag rdf:type rdf:Property ;
    rdfs:label 'Refundable Flag' ;
    rdfs:comment 'Indicates whether disbursed funds can be refunded to the student (creating a credit balance) or must only be applied to institutional charges. Relevant for Return of Title IV (R2T4) calculations.' ;
    rdfs:domain ind:AidFund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryProgramCode rdf:type rdf:Property ;
    rdfs:label 'Regulatory Program Code' ;
    rdfs:comment 'The federal or state program code for Title IV or state-regulated aid programs (e.g., PELL for Federal Pell Grant, SEOG for Federal Supplemental Educational Opportunity Grant, DL for Direct Loan, FWSP for Federal Work-Study Program). Empty for non-regulated institutional or private funds.' ;
    rdfs:domain ind:AidFund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remainingBalanceAmount rdf:type rdf:Property ;
    rdfs:label 'Remaining Balance Amount' ;
    rdfs:comment 'The current unawarded or undisbursed balance remaining in the fund. Updated in real-time as awards are packaged and disbursements are processed.' ;
    rdfs:domain ind:AidFund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:renewableFlag rdf:type rdf:Property ;
    rdfs:label 'Renewable Flag' ;
    rdfs:comment 'Indicates whether this fund award is renewable for multiple years if eligibility criteria continue to be met. Common for multi-year scholarships.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reportingCategory rdf:type rdf:Property ;
    rdfs:label 'Reporting Category' ;
    rdfs:comment 'The category used for external reporting to IPEDS, state agencies, or accreditation bodies. Maps fund to standardized reporting classifications.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:residencyRequirement rdf:type rdf:Property ;
    rdfs:label 'Residency Requirement' ;
    rdfs:comment 'State or geographic residency requirement for eligibility. Common for state grants and some institutional scholarships (e.g., must be a resident of California, must be from a specific county).' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Sap Required Flag' ;
    rdfs:comment 'Indicates whether students must meet Satisfactory Academic Progress standards to receive this fund. True for all federal Title IV aid; may vary for institutional funds.' ;
    rdfs:domain ind:AidFund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:selfHelpFlag rdf:type rdf:Property ;
    rdfs:label 'Self Help Flag' ;
    rdfs:comment 'Indicates whether this fund is classified as self-help aid (loans and work-study) versus gift aid (grants and scholarships). Used in financial aid packaging strategies.' ;
    rdfs:domain ind:Aid ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:taxableFlag rdf:type rdf:Property ;
    rdfs:label 'Taxable Flag' ;
    rdfs:comment 'Indicates whether this fund is considered taxable income to the student. Scholarships exceeding qualified education expenses and work-study earnings are typically taxable.' ;
    rdfs:domain ind:Aid ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:aidAwardId rdf:type rdf:Property ;
    rdfs:label 'Aid Award Id' ;
    rdfs:comment 'Primary key for award' ;
    rdfs:domain ind:Aid ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AidAward .

ind:coaBudgetId rdf:type rdf:Property ;
    rdfs:label 'Coa Budget Id' ;
    rdfs:comment 'Unique identifier of the Cost of Attendance (COA) budget used to determine eligibility for this award. Links to the COA master record.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CoaBudget .

ind:acceptanceDate rdf:type rdf:Property ;
    rdfs:label 'Acceptance Date' ;
    rdfs:comment 'The date on which the student accepted this award. Null if the award has not been accepted or was declined.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:acceptedAmount rdf:type rdf:Property ;
    rdfs:label 'Accepted Amount' ;
    rdfs:comment 'The dollar amount the student has accepted for this award. May be less than or equal to the offered amount. Null if award has not been accepted.' ;
    rdfs:domain ind:AidAward ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:aidYear rdf:type rdf:Property ;
    rdfs:label 'Aid Year' ;
    rdfs:comment 'The academic year for which this financial aid award applies, formatted as YYYY-YYYY (e.g., 2023-2024). Represents the federal aid year cycle.' ;
    rdfs:domain ind:Aid ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cancelledAmount rdf:type rdf:Property ;
    rdfs:label 'Cancelled Amount' ;
    rdfs:comment 'The dollar amount of this award that has been cancelled or revoked. Used when awards are reduced or eliminated after initial offer.' ;
    rdfs:domain ind:AidAward ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:comments rdf:type rdf:Property ;
    rdfs:label 'Comments' ;
    rdfs:comment 'Free-text field for additional notes, special conditions, or administrative comments about this award. Used for internal documentation and communication.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disbursedAmount rdf:type rdf:Property ;
    rdfs:label 'Disbursed Amount' ;
    rdfs:comment 'The cumulative dollar amount that has been disbursed to the student or applied to their account to date for this award. Tracks actual funds distributed.' ;
    rdfs:domain ind:AidAward ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:efcAmount rdf:type rdf:Property ;
    rdfs:label 'Efc Amount' ;
    rdfs:comment 'The Expected Family Contribution (EFC) amount calculated from the student\'s FAFSA (Free Application for Federal Student Aid) at the time this award was packaged. Used to determine need-based aid eligibility.' ;
    rdfs:domain ind:Aid ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:federalFundCode rdf:type rdf:Property ;
    rdfs:label 'Federal Fund Code' ;
    rdfs:comment 'Federal reporting code for Title IV funds as defined by the U.S. Department of Education. Used for FISAP, COD, and other federal reporting. Null for non-federal funds.' ;
    rdfs:domain ind:AidAward ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:firstDisbursementDate rdf:type rdf:Property ;
    rdfs:label 'First Disbursement Date' ;
    rdfs:comment 'The date of the first disbursement for this award. Null if no disbursements have occurred yet.' ;
    rdfs:domain ind:AidAward ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:interestRate rdf:type rdf:Property ;
    rdfs:label 'Interest Rate' ;
    rdfs:comment 'For loan awards, the annual interest rate as a decimal (e.g., 0.045 for 4.5%). Null for non-loan awards.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastDisbursementDate rdf:type rdf:Property ;
    rdfs:label 'Last Disbursement Date' ;
    rdfs:comment 'The date of the most recent disbursement for this award. Null if no disbursements have occurred yet.' ;
    rdfs:domain ind:AidAward ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:loanPeriodBeginDate rdf:type rdf:Property ;
    rdfs:label 'Loan Period Begin Date' ;
    rdfs:comment 'For loan awards, the start date of the loan period. Defines the enrollment period covered by the loan. Null for non-loan awards.' ;
    rdfs:domain ind:Aid ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:loanPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Loan Period End Date' ;
    rdfs:comment 'For loan awards, the end date of the loan period. Defines the enrollment period covered by the loan. Null for non-loan awards.' ;
    rdfs:domain ind:Aid ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:offerDate rdf:type rdf:Property ;
    rdfs:label 'Offer Date' ;
    rdfs:comment 'The date on which this award was officially offered to the student. Marks the beginning of the award lifecycle.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:offeredAmount rdf:type rdf:Property ;
    rdfs:label 'Offered Amount' ;
    rdfs:comment 'The total dollar amount initially offered to the student for this award. Represents the maximum potential award before student acceptance or adjustments.' ;
    rdfs:domain ind:AidAward ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:originationFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Origination Fee Amount' ;
    rdfs:comment 'For loan awards, the dollar amount of the origination fee deducted by the lender or federal government. Null for non-loan awards.' ;
    rdfs:domain ind:Aid ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:packagingGroup rdf:type rdf:Property ;
    rdfs:label 'Packaging Group' ;
    rdfs:comment 'Classification code used to group students for aid packaging purposes (e.g., freshman, transfer, graduate, athlete). Determines packaging rules and fund priority.' ;
    rdfs:domain ind:AidAward ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remainingAmount rdf:type rdf:Property ;
    rdfs:label 'Remaining Amount' ;
    rdfs:comment 'The dollar amount remaining to be disbursed for this award. Calculated as accepted amount minus disbursed amount.' ;
    rdfs:domain ind:AidAward ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revisionNumber rdf:type rdf:Property ;
    rdfs:label 'Revision Number' ;
    rdfs:comment 'Sequential counter tracking the number of times this award has been revised or adjusted. Starts at 0 for original award, increments with each change.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sapRequirementFlag rdf:type rdf:Property ;
    rdfs:label 'Sap Requirement Flag' ;
    rdfs:comment 'Indicates whether this award requires the student to maintain Satisfactory Academic Progress (SAP) as defined by federal Title IV regulations and institutional policy. True if SAP compliance is mandatory.' ;
    rdfs:domain ind:AidAward ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:subsidizedFlag rdf:type rdf:Property ;
    rdfs:label 'Subsidized Flag' ;
    rdfs:comment 'For loan awards, indicates whether the loan is subsidized (true) or unsubsidized (false). Subsidized loans do not accrue interest while the student is enrolled. Null for non-loan awards.' ;
    rdfs:domain ind:AidAward ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:updatedByUser rdf:type rdf:Property ;
    rdfs:label 'Updated By User' ;
    rdfs:comment 'Username or identifier of the system user or process that last modified this award record. Audit trail for accountability.' ;
    rdfs:domain ind:AidAward ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defaultStatusFlag rdf:type rdf:Property ;
    rdfs:label 'Default Status Flag' ;
    rdfs:comment 'Indicates whether the student is in default on any federal student loans, affecting eligibility for additional aid.' ;
    rdfs:domain ind:AwardPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:demonstratedNeedAmount rdf:type rdf:Property ;
    rdfs:label 'Demonstrated Need Amount' ;
    rdfs:comment 'Calculated financial need for the student, typically COA minus EFC, representing the gap to be filled by aid.' ;
    rdfs:domain ind:AwardPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dependencyStatus rdf:type rdf:Property ;
    rdfs:label 'Dependency Status' ;
    rdfs:comment 'Student dependency status as determined by FAFSA, affecting eligibility for certain aid types.' ;
    rdfs:domain ind:Aid ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:housingStatus rdf:type rdf:Property ;
    rdfs:label 'Housing Status' ;
    rdfs:comment 'Student housing arrangement used to determine the appropriate COA budget.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastRevisionDate rdf:type rdf:Property ;
    rdfs:label 'Last Revision Date' ;
    rdfs:comment 'Date of the most recent revision to this award package.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:offerLetterSentDate rdf:type rdf:Property ;
    rdfs:label 'Offer Letter Sent Date' ;
    rdfs:comment 'Date on which the award offer letter was sent to the student.' ;
    rdfs:domain ind:AwardPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:overawardAmount rdf:type rdf:Property ;
    rdfs:label 'Overaward Amount' ;
    rdfs:comment 'Amount by which total awarded aid exceeds the COA or regulatory limits, requiring resolution to maintain Title IV compliance.' ;
    rdfs:domain ind:AwardPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overawardDetectedFlag rdf:type rdf:Property ;
    rdfs:label 'Overaward Detected Flag' ;
    rdfs:comment 'Indicates whether an overaward condition has been detected for this package.' ;
    rdfs:domain ind:AwardPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:overawardResolutionDate rdf:type rdf:Property ;
    rdfs:label 'Overaward Resolution Date' ;
    rdfs:comment 'Date on which the overaward was resolved or waived.' ;
    rdfs:domain ind:AwardPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:overawardResolutionStatus rdf:type rdf:Property ;
    rdfs:label 'Overaward Resolution Status' ;
    rdfs:comment 'Current status of overaward resolution efforts, tracking whether the overaward has been addressed.' ;
    rdfs:domain ind:AwardPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packageNumber rdf:type rdf:Property ;
    rdfs:label 'Package Number' ;
    rdfs:comment 'Business identifier for the award package, typically used in communications and reporting.' ;
    rdfs:domain ind:AwardPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packageStatus rdf:type rdf:Property ;
    rdfs:label 'Package Status' ;
    rdfs:comment 'Current lifecycle status of the award package indicating its stage in the financial aid workflow.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packagingDate rdf:type rdf:Property ;
    rdfs:label 'Packaging Date' ;
    rdfs:comment 'Date on which the award package was initially assembled and packaged by the financial aid office.' ;
    rdfs:domain ind:AwardPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:packagingMethodology rdf:type rdf:Property ;
    rdfs:label 'Packaging Methodology' ;
    rdfs:comment 'The methodology or strategy used to assemble this award package, indicating the basis for aid allocation.' ;
    rdfs:domain ind:AwardPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pellLifetimeEligibilityUsedPercent rdf:type rdf:Property ;
    rdfs:label 'Pell Lifetime Eligibility Used Percent' ;
    rdfs:comment 'Percentage of lifetime Pell Grant eligibility the student has used, capped at 600 percent (equivalent to 6 years).' ;
    rdfs:domain ind:AwardPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:professionalJudgmentAppliedFlag rdf:type rdf:Property ;
    rdfs:label 'Professional Judgment Applied Flag' ;
    rdfs:comment 'Indicates whether professional judgment was exercised to adjust the EFC or COA for this student.' ;
    rdfs:domain ind:AwardPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:revisionReason rdf:type rdf:Property ;
    rdfs:label 'Revision Reason' ;
    rdfs:comment 'Explanation for the most recent revision to the award package, such as change in enrollment status, additional aid received, or correction.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapStatus rdf:type rdf:Property ;
    rdfs:label 'Sap Status' ;
    rdfs:comment 'Student Satisfactory Academic Progress status at the time of packaging, required for continued Title IV eligibility.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:studentAcceptanceDate rdf:type rdf:Property ;
    rdfs:label 'Student Acceptance Date' ;
    rdfs:comment 'Date on which the student accepted the award package or specific awards within it.' ;
    rdfs:domain ind:AwardPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:totalAwardedAmount rdf:type rdf:Property ;
    rdfs:label 'Total Awarded Amount' ;
    rdfs:comment 'Total amount of financial aid awarded in this package across all aid types (grants, loans, scholarships, work-study).' ;
    rdfs:domain ind:AwardPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalCoaAmount rdf:type rdf:Property ;
    rdfs:label 'Total Coa Amount' ;
    rdfs:comment 'Total cost of attendance amount for the student for this award year, including tuition, fees, room, board, books, and other allowable expenses.' ;
    rdfs:domain ind:Aid ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalGrantAmount rdf:type rdf:Property ;
    rdfs:label 'Total Grant Amount' ;
    rdfs:comment 'Total amount of grant aid (gift aid that does not require repayment) included in this package.' ;
    rdfs:domain ind:AwardPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalLoanAmount rdf:type rdf:Property ;
    rdfs:label 'Total Loan Amount' ;
    rdfs:comment 'Total amount of loan aid (funds requiring repayment) included in this package.' ;
    rdfs:domain ind:AwardPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalScholarshipAmount rdf:type rdf:Property ;
    rdfs:label 'Total Scholarship Amount' ;
    rdfs:comment 'Total amount of scholarship aid (merit or need-based gift aid) included in this package.' ;
    rdfs:domain ind:AwardPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalWorkStudyAmount rdf:type rdf:Property ;
    rdfs:label 'Total Work Study Amount' ;
    rdfs:comment 'Total amount of work-study aid (earned through part-time employment) included in this package.' ;
    rdfs:domain ind:AwardPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unmetNeedAmount rdf:type rdf:Property ;
    rdfs:label 'Unmet Need Amount' ;
    rdfs:comment 'Remaining financial need after all awarded aid is applied, representing the gap the student must cover through other means.' ;
    rdfs:domain ind:AwardPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:verificationCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Verification Completion Date' ;
    rdfs:comment 'Date on which FAFSA verification was completed for this award package.' ;
    rdfs:domain ind:AwardPackage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:diningPlanId rdf:type rdf:Property ;
    rdfs:label 'Dining Plan Id' ;
    rdfs:comment 'Foreign key linking to studentlife.dining_plan. Business justification: COA budgets must reflect actual meal plan costs, not estimates. Different dining plans have different costs; aid packaging requires precise room & board component. Business process: COA calculation us' ;
    rdfs:domain ind:Education ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DiningPlan .

ind:academicLevel rdf:type rdf:Property ;
    rdfs:label 'Academic Level' ;
    rdfs:comment 'Academic level of students for whom this COA budget applies (undergraduate, graduate, professional, post-baccalaureate, doctoral, certificate).' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedBy rdf:type rdf:Property ;
    rdfs:label 'Approved By' ;
    rdfs:comment 'Name or identifier of the financial aid administrator or committee who approved this COA budget template.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:booksSuppliesAmount rdf:type rdf:Property ;
    rdfs:label 'Books Supplies Amount' ;
    rdfs:comment 'Estimated cost of books, course materials, supplies, and equipment required for the academic program.' ;
    rdfs:domain ind:CoaBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetCode rdf:type rdf:Property ;
    rdfs:label 'Budget Code' ;
    rdfs:comment 'Institution-defined code uniquely identifying this COA budget template (e.g., UG_DEP_ONCAMPUS, GRAD_IND_OFFCAMPUS).' ;
    rdfs:domain ind:CoaBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetDescription rdf:type rdf:Property ;
    rdfs:label 'Budget Description' ;
    rdfs:comment 'Detailed description of the student population and assumptions for this COA budget template, including eligibility criteria and usage notes.' ;
    rdfs:domain ind:CoaBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetName rdf:type rdf:Property ;
    rdfs:label 'Budget Name' ;
    rdfs:comment 'Descriptive name of the COA budget template (e.g., Undergraduate Dependent On-Campus, Graduate Independent Off-Campus with Family).' ;
    rdfs:domain ind:CoaBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetStatus rdf:type rdf:Property ;
    rdfs:label 'Budget Status' ;
    rdfs:comment 'Current lifecycle status of this COA budget template (draft, active, superseded, archived).' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetVersion rdf:type rdf:Property ;
    rdfs:label 'Budget Version' ;
    rdfs:comment 'Version number of this COA budget template, incremented when budget amounts are revised during the award year.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:creditHourMaximum rdf:type rdf:Property ;
    rdfs:label 'Credit Hour Maximum' ;
    rdfs:comment 'Maximum number of credit hours covered by this COA budget template, null if no upper limit applies.' ;
    rdfs:domain ind:CoaBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:creditHourMinimum rdf:type rdf:Property ;
    rdfs:label 'Credit Hour Minimum' ;
    rdfs:comment 'Minimum number of credit hours required for students to be eligible for this COA budget template, based on enrollment status.' ;
    rdfs:domain ind:CoaBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dependentCareAmount rdf:type rdf:Property ;
    rdfs:label 'Dependent Care Amount' ;
    rdfs:comment 'Allowance for dependent care expenses (childcare or eldercare) for students with dependents, if applicable to this budget template.' ;
    rdfs:domain ind:CoaBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:disabilityExpensesAmount rdf:type rdf:Property ;
    rdfs:label 'Disability Expenses Amount' ;
    rdfs:comment 'Allowance for disability-related expenses for students with documented disabilities, if applicable to this budget template.' ;
    rdfs:domain ind:CoaBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:federalMethodologyFlag rdf:type rdf:Property ;
    rdfs:label 'Federal Methodology Flag' ;
    rdfs:comment 'Indicates whether this COA budget complies with federal Title IV methodology requirements for need-based aid packaging (True/False).' ;
    rdfs:domain ind:CoaBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:housingType rdf:type rdf:Property ;
    rdfs:label 'Housing Type' ;
    rdfs:comment 'Expected housing arrangement for students using this COA budget (on-campus, off-campus, with-parents).' ;
    rdfs:domain ind:CoaBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:institutionalMethodologyFlag rdf:type rdf:Property ;
    rdfs:label 'Institutional Methodology Flag' ;
    rdfs:comment 'Indicates whether this COA budget uses institutional methodology for institutional aid packaging, which may differ from federal methodology (True/False).' ;
    rdfs:domain ind:CoaBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:loanFeesAmount rdf:type rdf:Property ;
    rdfs:label 'Loan Fees Amount' ;
    rdfs:comment 'Allowance for loan origination fees and other costs associated with federal student loans, if applicable.' ;
    rdfs:domain ind:CoaBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:personalExpensesAmount rdf:type rdf:Property ;
    rdfs:label 'Personal Expenses Amount' ;
    rdfs:comment 'Allowance for miscellaneous personal expenses including clothing, laundry, entertainment, and other living costs.' ;
    rdfs:domain ind:CoaBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:professionalLicensureAmount rdf:type rdf:Property ;
    rdfs:label 'Professional Licensure Amount' ;
    rdfs:comment 'Allowance for professional licensure exam fees, certification costs, and related expenses for professional programs (e.g., bar exam, medical boards).' ;
    rdfs:domain ind:CoaBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:residencyStatus rdf:type rdf:Property ;
    rdfs:label 'Residency Status' ;
    rdfs:comment 'Student residency classification for tuition and fee purposes (in-state, out-of-state, international).' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roomBoardAmount rdf:type rdf:Property ;
    rdfs:label 'Room Board Amount' ;
    rdfs:comment 'Allowance for housing and food expenses based on the housing type assumption (on-campus room and board rates or off-campus living allowance).' ;
    rdfs:domain ind:CoaBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:studyAbroadAmount rdf:type rdf:Property ;
    rdfs:label 'Study Abroad Amount' ;
    rdfs:comment 'Additional allowance for study abroad program costs including international travel, visa fees, and higher living expenses, if applicable.' ;
    rdfs:domain ind:CoaBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:termType rdf:type rdf:Property ;
    rdfs:label 'Term Type' ;
    rdfs:comment 'Academic term structure for which this COA budget is calculated (academic-year, fall-semester, spring-semester, summer-session, quarter, trimester).' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transportationAmount rdf:type rdf:Property ;
    rdfs:label 'Transportation Amount' ;
    rdfs:comment 'Allowance for transportation costs including commuting to campus and travel between home and school.' ;
    rdfs:domain ind:CoaBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tuitionFeesAmount rdf:type rdf:Property ;
    rdfs:label 'Tuition Fees Amount' ;
    rdfs:comment 'Standard tuition and mandatory fees component of the COA budget for the award year and enrollment status.' ;
    rdfs:domain ind:CoaBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:disbursementId rdf:type rdf:Property ;
    rdfs:label 'Disbursement Id' ;
    rdfs:comment 'Unique identifier for the financial aid disbursement record. Primary key. Inferred role: TRANSACTION_HEADER.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Disbursement .

ind:aidYearId rdf:type rdf:Property ;
    rdfs:label 'Aid Year Id' ;
    rdfs:comment 'Reference to the financial aid year for which this disbursement applies. Typically spans July 1 to June 30.' ;
    rdfs:domain ind:Aid ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AwardYear .

ind:itServiceId rdf:type rdf:Property ;
    rdfs:label 'It Service Id' ;
    rdfs:comment 'Foreign key linking to technology.it_service. Business justification: Disbursement processing is delivered as an IT service. Linking disbursements to the IT service enables service-level reporting, outage impact analysis (identifying affected disbursements during servic' ;
    rdfs:domain ind:Education ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ItService .

ind:loanRecordId rdf:type rdf:Property ;
    rdfs:label 'Loan Record Id' ;
    rdfs:comment 'Foreign key linking to aid.loan_record. Business justification: For loan disbursements, the disbursement record should optionally reference the loan_record for loan-specific tracking (COD reporting, NSLDS reporting, servicer information). This is in addition to th' ;
    rdfs:domain ind:Aid ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LoanRecord .

ind:r2t4CalculationId rdf:type rdf:Property ;
    rdfs:label 'R2t4 Calculation Id' ;
    rdfs:comment 'Foreign key linking to aid.r2t4_calculation. Business justification: When a student withdraws, Return to Title IV (R2T4) calculations determine which disbursements must be returned. Disbursements affected by R2T4 should reference the calculation record. Columns return_' ;
    rdfs:domain ind:Education ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:R2t4Calculation .

ind:studentlifeHousingAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Studentlife Housing Assignment Id' ;
    rdfs:comment 'Foreign key linking to studentlife.housing_assignment. Business justification: Title IV disbursement authorization requires verified housing assignment when aid includes room/board costs. Compliance process: aid offices confirm student is actually residing in housing before rele' ;
    rdfs:domain ind:Education ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StudentlifeHousingAssignment .

ind:anticipatedDisbursementFlag rdf:type rdf:Property ;
    rdfs:label 'Anticipated Disbursement Flag' ;
    rdfs:comment 'Indicates whether this disbursement was made in anticipation of future enrollment. Used for early disbursements before term start.' ;
    rdfs:domain ind:Disbursement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:authorizationDate rdf:type rdf:Property ;
    rdfs:label 'Authorization Date' ;
    rdfs:comment 'The date on which the disbursement was authorized by the financial aid office. Precedes the actual disbursement date.' ;
    rdfs:domain ind:Disbursement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:bankAccountLastFour rdf:type rdf:Property ;
    rdfs:label 'Bank Account Last Four' ;
    rdfs:comment 'Last four digits of the bank account to which funds were disbursed. Used for verification without exposing full account number.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:codReportingDate rdf:type rdf:Property ;
    rdfs:label 'Cod Reporting Date' ;
    rdfs:comment 'The date on which this disbursement was reported to the federal COD system. Used for compliance tracking.' ;
    rdfs:domain ind:Disbursement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:codReportingFlag rdf:type rdf:Property ;
    rdfs:label 'Cod Reporting Flag' ;
    rdfs:comment 'Indicates whether this disbursement has been reported to the federal COD system. Required for all Title IV disbursements.' ;
    rdfs:domain ind:Disbursement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:disbursementDate rdf:type rdf:Property ;
    rdfs:label 'Disbursement Date' ;
    rdfs:comment 'The date on which the disbursement was actually released to the student account or paid to the student. Principal business event timestamp for this transaction.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:disbursementNumber rdf:type rdf:Property ;
    rdfs:label 'Disbursement Number' ;
    rdfs:comment 'Business identifier for the disbursement. Human-readable reference number used in communications and reconciliation.' ;
    rdfs:domain ind:Aid ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disbursementStatus rdf:type rdf:Property ;
    rdfs:label 'Disbursement Status' ;
    rdfs:comment 'Current lifecycle status of the disbursement. Tracks the disbursement through approval, release, and potential return workflows.' ;
    rdfs:domain ind:Disbursement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentStatusAtDisbursement rdf:type rdf:Property ;
    rdfs:label 'Enrollment Status At Disbursement' ;
    rdfs:comment 'The students enrollment status at the time of disbursement. Critical for Title IV eligibility and disbursement amount calculations.' ;
    rdfs:domain ind:Disbursement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdFlag rdf:type rdf:Property ;
    rdfs:label 'Hold Flag' ;
    rdfs:comment 'Indicates whether a hold was placed on this disbursement preventing release. Holds may be due to verification, SAP, or other compliance issues.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:holdReasonCode rdf:type rdf:Property ;
    rdfs:label 'Hold Reason Code' ;
    rdfs:comment 'Code indicating the reason for any disbursement hold. Examples include verification incomplete, SAP suspension, enrollment below threshold.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holdReleaseDate rdf:type rdf:Property ;
    rdfs:label 'Hold Release Date' ;
    rdfs:comment 'The date on which any disbursement hold was released, allowing the disbursement to proceed.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lateDisbursementFlag rdf:type rdf:Property ;
    rdfs:label 'Late Disbursement Flag' ;
    rdfs:comment 'Indicates whether this disbursement was made after the normal disbursement window. Requires special processing and documentation.' ;
    rdfs:domain ind:Disbursement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:netDisbursementAmount rdf:type rdf:Property ;
    rdfs:label 'Net Disbursement Amount' ;
    rdfs:comment 'The net amount received by the student after deductions for fees, charges, or institutional holds. May differ from gross disbursement amount.' ;
    rdfs:domain ind:Disbursement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nsldsReportingFlag rdf:type rdf:Property ;
    rdfs:label 'Nslds Reporting Flag' ;
    rdfs:comment 'Indicates whether this disbursement has been reported to NSLDS. Required for federal loan and grant tracking.' ;
    rdfs:domain ind:Disbursement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:periodBeginDate rdf:type rdf:Property ;
    rdfs:label 'Period Begin Date' ;
    rdfs:comment 'The start date of the enrollment period covered by this disbursement. Defines the academic period for which aid is being disbursed.' ;
    rdfs:domain ind:Disbursement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:periodEndDate rdf:type rdf:Property ;
    rdfs:label 'Period End Date' ;
    rdfs:comment 'The end date of the enrollment period covered by this disbursement. Defines the academic period for which aid is being disbursed.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sapStatusAtDisbursement rdf:type rdf:Property ;
    rdfs:label 'Sap Status At Disbursement' ;
    rdfs:comment 'The students SAP status at the time of disbursement. Students must meet SAP standards to receive Title IV aid.' ;
    rdfs:domain ind:Disbursement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledDisbursementDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Disbursement Date' ;
    rdfs:comment 'The originally planned date for the disbursement. May differ from actual disbursement date due to holds, eligibility changes, or processing delays.' ;
    rdfs:domain ind:Disbursement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sequence rdf:type rdf:Property ;
    rdfs:label 'Sequence' ;
    rdfs:comment 'Sequential number indicating which disbursement this is for the award (1st, 2nd, 3rd, etc.). Used for multi-disbursement awards.' ;
    rdfs:domain ind:Disbursement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:titleIvEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Title Iv Eligible Flag' ;
    rdfs:comment 'Indicates whether the student met all Title IV eligibility requirements at the time of disbursement. Required for federal aid compliance.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:automaticZeroEfcFlag rdf:type rdf:Property ;
    rdfs:label 'Automatic Zero Efc Flag' ;
    rdfs:comment 'Indicates whether the student qualifies for an automatic zero EFC based on income thresholds and other criteria.' ;
    rdfs:domain ind:IsirRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:commentCodes rdf:type rdf:Property ;
    rdfs:label 'Comment Codes' ;
    rdfs:comment 'Comma-separated list of comment codes providing additional information about the student\'s application, eligibility issues, or required actions.' ;
    rdfs:domain ind:IsirRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctionFlag rdf:type rdf:Property ;
    rdfs:label 'Correction Flag' ;
    rdfs:comment 'Indicates whether this ISIR represents a correction to a previously processed FAFSA application.' ;
    rdfs:domain ind:IsirRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cpsVersion rdf:type rdf:Property ;
    rdfs:label 'Cps Version' ;
    rdfs:comment 'Two-digit version number of the CPS software used to process this FAFSA application.' ;
    rdfs:domain ind:IsirRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:efc rdf:type rdf:Property ;
    rdfs:label 'Efc' ;
    rdfs:comment 'Expected Family Contribution calculated by the federal need analysis formula. Represents the amount a family is expected to contribute toward the student\'s education. Used for award years prior to 2024-2025.' ;
    rdfs:domain ind:IsirRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fafsaSignatureDate rdf:type rdf:Property ;
    rdfs:label 'Fafsa Signature Date' ;
    rdfs:comment 'Date when the student (and parent, if applicable) signed the FAFSA application.' ;
    rdfs:domain ind:IsirRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:householdSize rdf:type rdf:Property ;
    rdfs:label 'Household Size' ;
    rdfs:comment 'Number of people in the student\'s or parent\'s household as reported on the FAFSA. Used in federal need analysis calculation.' ;
    rdfs:domain ind:IsirRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isirSource rdf:type rdf:Property ;
    rdfs:label 'Isir Source' ;
    rdfs:comment 'Indicates whether this ISIR is from an original FAFSA submission, a correction, or a renewal application.' ;
    rdfs:domain ind:IsirRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maritalStatus rdf:type rdf:Property ;
    rdfs:label 'Marital Status' ;
    rdfs:comment 'Student\'s marital status as of the FAFSA filing date.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:numberInCollege rdf:type rdf:Property ;
    rdfs:label 'Number In College' ;
    rdfs:comment 'Number of household members who will be enrolled in postsecondary education during the award year. Used in federal need analysis calculation.' ;
    rdfs:domain ind:IsirRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:parentAgi rdf:type rdf:Property ;
    rdfs:label 'Parent Agi' ;
    rdfs:comment 'Parent\'s adjusted gross income from federal tax return for the base year. Applicable only for dependent students.' ;
    rdfs:domain ind:IsirRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:parentCashSavings rdf:type rdf:Property ;
    rdfs:label 'Parent Cash Savings' ;
    rdfs:comment 'Total value of parent\'s cash, savings, and checking account balances as of the FAFSA filing date. Applicable only for dependent students.' ;
    rdfs:domain ind:IsirRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:parentIncomeTaxPaid rdf:type rdf:Property ;
    rdfs:label 'Parent Income Tax Paid' ;
    rdfs:comment 'Amount of U.S. income tax paid by the parent(s) for the base year. Applicable only for dependent students.' ;
    rdfs:domain ind:IsirRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:parentInvestmentNetWorth rdf:type rdf:Property ;
    rdfs:label 'Parent Investment Net Worth' ;
    rdfs:comment 'Net worth of parent\'s investments including stocks, bonds, real estate (excluding primary residence), and other investment assets. Applicable only for dependent students.' ;
    rdfs:domain ind:IsirRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:parentMaritalStatus rdf:type rdf:Property ;
    rdfs:label 'Parent Marital Status' ;
    rdfs:comment 'Marital status of the parent(s) as of the FAFSA filing date. Applicable only for dependent students.' ;
    rdfs:domain ind:IsirRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentUntaxedIncome rdf:type rdf:Property ;
    rdfs:label 'Parent Untaxed Income' ;
    rdfs:comment 'Total untaxed income and benefits received by the parent(s). Applicable only for dependent students.' ;
    rdfs:domain ind:IsirRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pellEligibilityFlag rdf:type rdf:Property ;
    rdfs:label 'Pell Eligibility Flag' ;
    rdfs:comment 'Indicates whether the student is eligible for a Federal Pell Grant based on the calculated EFC/SAI and other eligibility criteria.' ;
    rdfs:domain ind:IsirRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:processedDate rdf:type rdf:Property ;
    rdfs:label 'Processed Date' ;
    rdfs:comment 'Date when the FAFSA application was processed by the Central Processing System (CPS) and the ISIR was generated.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:receivedDate rdf:type rdf:Property ;
    rdfs:label 'Received Date' ;
    rdfs:comment 'Date when the institution received the ISIR record from the CPS.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rejectReasonCodes rdf:type rdf:Property ;
    rdfs:label 'Reject Reason Codes' ;
    rdfs:comment 'Comma-separated list of reject codes indicating data errors or missing information that prevented full processing of the FAFSA. Blank if no rejects.' ;
    rdfs:domain ind:IsirRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sai rdf:type rdf:Property ;
    rdfs:label 'Sai' ;
    rdfs:comment 'Student Aid Index calculated by the federal need analysis formula. Replaces EFC starting with the 2024-2025 award year. Represents the measure of a family\'s financial strength.' ;
    rdfs:domain ind:IsirRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:simplifiedNeedsTestFlag rdf:type rdf:Property ;
    rdfs:label 'Simplified Needs Test Flag' ;
    rdfs:comment 'Indicates whether the student qualifies for the simplified needs test, which excludes asset information from the need analysis calculation.' ;
    rdfs:domain ind:IsirRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ssn rdf:type rdf:Property ;
    rdfs:label 'Ssn' ;
    rdfs:comment 'Student\'s Social Security Number as reported on the FAFSA. Used for federal aid eligibility verification and identity matching.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stateOfLegalResidence rdf:type rdf:Property ;
    rdfs:label 'State Of Legal Residence' ;
    rdfs:comment 'Two-letter state code indicating the student\'s state of legal residence for tuition purposes.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:studentAgi rdf:type rdf:Property ;
    rdfs:label 'Student Agi' ;
    rdfs:comment 'Student\'s adjusted gross income from federal tax return for the base year. Used in federal need analysis calculation.' ;
    rdfs:domain ind:IsirRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:studentCashSavings rdf:type rdf:Property ;
    rdfs:label 'Student Cash Savings' ;
    rdfs:comment 'Total value of student\'s cash, savings, and checking account balances as of the FAFSA filing date.' ;
    rdfs:domain ind:IsirRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:studentIncomeTaxPaid rdf:type rdf:Property ;
    rdfs:label 'Student Income Tax Paid' ;
    rdfs:comment 'Amount of U.S. income tax paid by the student for the base year.' ;
    rdfs:domain ind:IsirRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:studentInvestmentNetWorth rdf:type rdf:Property ;
    rdfs:label 'Student Investment Net Worth' ;
    rdfs:comment 'Net worth of student\'s investments including stocks, bonds, real estate (excluding primary residence), and other investment assets.' ;
    rdfs:domain ind:IsirRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:studentUntaxedIncome rdf:type rdf:Property ;
    rdfs:label 'Student Untaxed Income' ;
    rdfs:comment 'Total untaxed income and benefits received by the student, including child support, IRA deductions, and other untaxed income sources.' ;
    rdfs:domain ind:IsirRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transactionNumber rdf:type rdf:Property ;
    rdfs:label 'Transaction Number' ;
    rdfs:comment 'Sequential transaction number assigned by the Central Processing System (CPS) for each FAFSA submission or correction. Higher numbers indicate more recent submissions.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationSelectionFlag rdf:type rdf:Property ;
    rdfs:label 'Verification Selection Flag' ;
    rdfs:comment 'Indicates whether the student has been selected for federal verification by the CPS. True if selected, False if not selected.' ;
    rdfs:domain ind:IsirRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:verificationTrackingFlag rdf:type rdf:Property ;
    rdfs:label 'Verification Tracking Flag' ;
    rdfs:comment 'Two-character code indicating the specific verification tracking group assigned by the CPS (e.g., V1, V4, V5, V6). Blank if not selected for verification.' ;
    rdfs:domain ind:IsirRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:arInvoiceId rdf:type rdf:Property ;
    rdfs:label 'Ar Invoice Id' ;
    rdfs:comment 'Foreign key linking to finance.ar_invoice. Business justification: Institutional loans (Perkins, emergency, short-term) generate AR invoices when repayment begins. Loan principal becomes a receivable tracked through student AR system. Essential for loan servicing, co' ;
    rdfs:domain ind:Education ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ArInvoice .

ind:mpnId rdf:type rdf:Property ;
    rdfs:label 'Mpn Id' ;
    rdfs:comment 'The unique identifier for the Master Promissory Note under which this loan was originated. An MPN can cover multiple loans over multiple years.' ;
    rdfs:domain ind:LoanRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MasterPromissoryNote .

ind:parentBorrowerId rdf:type rdf:Property ;
    rdfs:label 'Parent Borrower Id' ;
    rdfs:comment 'Unique identifier for the parent borrower if this is a Direct PLUS Parent loan. Links to the parent/guardian record. Null for student-borrowed loans.' ;
    rdfs:domain ind:Aid ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Borrower .

ind:academicYear rdf:type rdf:Property ;
    rdfs:label 'Academic Year' ;
    rdfs:comment 'The academic year for which the loan was originated, in format YYYY-YYYY (e.g., 2023-2024). Used for reporting and cohort analysis.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:aggregateLoanBalance rdf:type rdf:Property ;
    rdfs:label 'Aggregate Loan Balance' ;
    rdfs:comment 'The student\'s total outstanding loan balance across all prior loans at the time of this loan origination, in USD. Used to verify the student has not exceeded aggregate limits.' ;
    rdfs:domain ind:LoanRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:aggregateLoanLimit rdf:type rdf:Property ;
    rdfs:label 'Aggregate Loan Limit' ;
    rdfs:comment 'The maximum cumulative loan amount the student is eligible to borrow across all years, in USD. Varies by dependency status, grade level, and loan type.' ;
    rdfs:domain ind:Aid ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:anticipatedDisbursementDate rdf:type rdf:Property ;
    rdfs:label 'Anticipated Disbursement Date' ;
    rdfs:comment 'The expected date for loan disbursement as reported to COD at origination. Used for planning and student account projections.' ;
    rdfs:domain ind:LoanRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:borrowerType rdf:type rdf:Property ;
    rdfs:label 'Borrower Type' ;
    rdfs:comment 'Identifies the type of borrower for this loan. STUDENT=undergraduate student borrower (Direct Subsidized/Unsubsidized), PARENT=parent borrower (Direct PLUS Parent), GRADUATE_STUDENT=graduate/professional student borrower (Direct Unsubsidized or PLUS Grad).' ;
    rdfs:domain ind:Aid ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cancellationReasonCode rdf:type rdf:Property ;
    rdfs:label 'Cancellation Reason Code' ;
    rdfs:comment 'The reason code for loan cancellation, if applicable. STUDENT_REQUEST=student requested cancellation, ELIGIBILITY_CHANGE=student became ineligible, ENROLLMENT_CHANGE=student dropped below half-time, DUPLICATE=duplicate loan record, OTHER=other reason.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:codAcceptedDate rdf:type rdf:Property ;
    rdfs:label 'Cod Accepted Date' ;
    rdfs:comment 'The date on which the loan record was accepted by the COD system. Confirms federal approval for loan origination and disbursement.' ;
    rdfs:domain ind:LoanRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:codTransactionNumber rdf:type rdf:Property ;
    rdfs:label 'Cod Transaction Number' ;
    rdfs:comment 'The unique transaction identifier assigned by the COD system for this loan origination or disbursement. Used for reconciliation and audit trails.' ;
    rdfs:domain ind:LoanRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditCheckPassedIndicator rdf:type rdf:Property ;
    rdfs:label 'Credit Check Passed Indicator' ;
    rdfs:comment 'Indicates whether the borrower (parent or graduate student) passed the credit check required for PLUS loans. Not applicable to Direct Subsidized or Unsubsidized loans. True=passed, False=failed or not applicable.' ;
    rdfs:domain ind:LoanRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:endorserRequiredIndicator rdf:type rdf:Property ;
    rdfs:label 'Endorser Required Indicator' ;
    rdfs:comment 'Indicates whether an endorser (co-signer) is required for a PLUS loan due to adverse credit history. True=endorser required, False=not required.' ;
    rdfs:domain ind:LoanRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:entranceCounselingCompletedDate rdf:type rdf:Property ;
    rdfs:label 'Entrance Counseling Completed Date' ;
    rdfs:comment 'The date on which the student completed entrance counseling, a federal requirement for first-time borrowers. Must be completed before first disbursement.' ;
    rdfs:domain ind:LoanRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:gradeLevel rdf:type rdf:Property ;
    rdfs:label 'Grade Level' ;
    rdfs:comment 'The student\'s academic grade level at the time of loan origination. Determines annual and aggregate loan limits. UG=Undergraduate, GRAD=Graduate, PROFESSIONAL=Professional (e.g., law, medicine).' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grossLoanAmount rdf:type rdf:Property ;
    rdfs:label 'Gross Loan Amount' ;
    rdfs:comment 'The total loan amount before any fees are deducted, in USD. This is the principal amount the student is authorized to borrow.' ;
    rdfs:domain ind:LoanRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:loanNumber rdf:type rdf:Property ;
    rdfs:label 'Loan Number' ;
    rdfs:comment 'Externally-known unique loan identifier assigned by the institution or federal system. Used for tracking and reporting to COD (Common Origination and Disbursement) and loan servicers.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loanServicerCode rdf:type rdf:Property ;
    rdfs:label 'Loan Servicer Code' ;
    rdfs:comment 'The code identifying the federal loan servicer assigned to manage this loan after disbursement (e.g., MOHELA, Nelnet, Great Lakes). Used for borrower communication and repayment tracking.' ;
    rdfs:domain ind:LoanRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loanStatus rdf:type rdf:Property ;
    rdfs:label 'Loan Status' ;
    rdfs:comment 'Current lifecycle status of the loan record. ORIGINATED=loan has been originated but not yet disbursed, DISBURSED=funds have been released to student account, CANCELLED=loan was cancelled before disbursement, RETURNED=disbursed funds were returned, ADJUSTED=loan amount or terms were adjusted post-origination.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loanTypeCode rdf:type rdf:Property ;
    rdfs:label 'Loan Type Code' ;
    rdfs:comment 'Classification of the loan product. SUB=Direct Subsidized Loan, UNSUB=Direct Unsubsidized Loan, PLUS_PARENT=Direct PLUS Loan for Parents, PLUS_GRAD=Direct PLUS Loan for Graduate Students, PERKINS=Federal Perkins Loan, PRIVATE=Private/Alternative Loan.' ;
    rdfs:domain ind:LoanRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mpnSignedDate rdf:type rdf:Property ;
    rdfs:label 'Mpn Signed Date' ;
    rdfs:comment 'The date on which the student (or parent for PLUS loans) signed the Master Promissory Note. Required before loan disbursement.' ;
    rdfs:domain ind:Aid ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:netLoanAmount rdf:type rdf:Property ;
    rdfs:label 'Net Loan Amount' ;
    rdfs:comment 'The actual loan amount disbursed to the student after origination fees are deducted (gross_loan_amount minus origination_fee_amount), in USD.' ;
    rdfs:domain ind:LoanRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nsldsReportedDate rdf:type rdf:Property ;
    rdfs:label 'Nslds Reported Date' ;
    rdfs:comment 'The date on which this loan record was reported to the National Student Loan Data System. Required for federal compliance and borrower loan history tracking.' ;
    rdfs:domain ind:LoanRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:originationDate rdf:type rdf:Property ;
    rdfs:label 'Origination Date' ;
    rdfs:comment 'The date on which the loan was officially originated and the borrower became legally obligated. This is the principal business event timestamp for the loan record.' ;
    rdfs:domain ind:LoanRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:subsidizedIndicator rdf:type rdf:Property ;
    rdfs:label 'Subsidized Indicator' ;
    rdfs:comment 'Indicates whether the loan is subsidized (government pays interest during in-school, grace, and deferment periods). True for Direct Subsidized Loans, False for all other loan types.' ;
    rdfs:domain ind:LoanRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:termCode rdf:type rdf:Property ;
    rdfs:label 'Term Code' ;
    rdfs:comment 'The academic term code (e.g., FALL2023, SPR2024) during which the loan was originated. Links to the institutional term calendar.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:professionalJudgmentId rdf:type rdf:Property ;
    rdfs:label 'Professional Judgment Id' ;
    rdfs:comment 'Unique identifier for the professional judgment decision record.' ;
    rdfs:domain ind:ProfessionalJudgment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:housingApplicationId rdf:type rdf:Property ;
    rdfs:label 'Housing Application Id' ;
    rdfs:comment 'Foreign key linking to studentlife.housing_application. Business justification: Professional judgment often involves housing cost adjustments (student requests commuter status due to family circumstances, documents inability to afford on-campus housing). PJ documentation must ref' ;
    rdfs:domain ind:Education ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:HousingApplication .

ind:policyId rdf:type rdf:Property ;
    rdfs:label 'Policy Id' ;
    rdfs:comment 'Foreign key linking to compliance.policy. Business justification: Professional judgment decisions must be made under documented institutional policies complying with 34 CFR 668.53. Policy reference ensures consistent application of PJ authority, documentation standa' ;
    rdfs:domain ind:Education ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Policy .

ind:adjustedCoa rdf:type rdf:Property ;
    rdfs:label 'Adjusted Coa' ;
    rdfs:comment 'The revised Cost of Attendance after professional judgment adjustment.' ;
    rdfs:domain ind:ProfessionalJudgment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:adjustedDependencyStatus rdf:type rdf:Property ;
    rdfs:label 'Adjusted Dependency Status' ;
    rdfs:comment 'The students revised dependency status (dependent or independent) after professional judgment override.' ;
    rdfs:domain ind:ProfessionalJudgment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adjustedEfc rdf:type rdf:Property ;
    rdfs:label 'Adjusted Efc' ;
    rdfs:comment 'The recalculated Expected Family Contribution after professional judgment adjustment.' ;
    rdfs:domain ind:ProfessionalJudgment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:adjustedValue rdf:type rdf:Property ;
    rdfs:label 'Adjusted Value' ;
    rdfs:comment 'The new value of the element after professional judgment was applied (may be numeric, text, or status depending on adjustment category).' ;
    rdfs:domain ind:ProfessionalJudgment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:adjustmentCategory rdf:type rdf:Property ;
    rdfs:label 'Adjustment Category' ;
    rdfs:comment 'The financial aid element being adjusted: Expected Family Contribution (EFC), Cost of Attendance (COA), dependency status, income, assets, enrollment status, or other. [ENUM-REF-CANDIDATE: efc|coa|dependency_status|income|assets|enrollment_status|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appealDeadlineDate rdf:type rdf:Property ;
    rdfs:label 'Appeal Deadline Date' ;
    rdfs:comment 'The deadline by which the student must submit an appeal of the professional judgment decision.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:appealEligible rdf:type rdf:Property ;
    rdfs:label 'Appeal Eligible' ;
    rdfs:comment 'Indicates whether the student is eligible to appeal the professional judgment decision per institutional policy.' ;
    rdfs:domain ind:ProfessionalJudgment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:approvingAdministratorName rdf:type rdf:Property ;
    rdfs:label 'Approving Administrator Name' ;
    rdfs:comment 'Full name of the financial aid administrator who approved the professional judgment decision.' ;
    rdfs:domain ind:ProfessionalJudgment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvingAdministratorTitle rdf:type rdf:Property ;
    rdfs:label 'Approving Administrator Title' ;
    rdfs:comment 'Job title of the financial aid administrator who approved the professional judgment decision (e.g., Director of Financial Aid, Associate Director).' ;
    rdfs:domain ind:ProfessionalJudgment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditFlag rdf:type rdf:Property ;
    rdfs:label 'Audit Flag' ;
    rdfs:comment 'Indicates whether this professional judgment case has been flagged for internal or external audit review.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:auditNotes rdf:type rdf:Property ;
    rdfs:label 'Audit Notes' ;
    rdfs:comment 'Notes or findings recorded during audit review of this professional judgment decision.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctedIsirTransactionNumber rdf:type rdf:Property ;
    rdfs:label 'Corrected Isir Transaction Number' ;
    rdfs:comment 'The ISIR transaction number for any corrected FAFSA submitted after professional judgment adjustment, if applicable.' ;
    rdfs:domain ind:ProfessionalJudgment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decisionDate rdf:type rdf:Property ;
    rdfs:label 'Decision Date' ;
    rdfs:comment 'The date when the professional judgment decision was finalized (approved or denied).' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:decisionStatus rdf:type rdf:Property ;
    rdfs:label 'Decision Status' ;
    rdfs:comment 'Current status of the professional judgment decision: pending initial review, approved, denied, withdrawn by student, or under review.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentationReceivedDate rdf:type rdf:Property ;
    rdfs:label 'Documentation Received Date' ;
    rdfs:comment 'The date when supporting documentation was received by the financial aid office.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isirTransactionNumber rdf:type rdf:Property ;
    rdfs:label 'Isir Transaction Number' ;
    rdfs:comment 'The ISIR transaction number associated with the FAFSA data used for the original EFC calculation before professional judgment.' ;
    rdfs:domain ind:ProfessionalJudgment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalCoa rdf:type rdf:Property ;
    rdfs:label 'Original Coa' ;
    rdfs:comment 'The original Cost of Attendance before professional judgment adjustment.' ;
    rdfs:domain ind:ProfessionalJudgment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:originalDependencyStatus rdf:type rdf:Property ;
    rdfs:label 'Original Dependency Status' ;
    rdfs:comment 'The students original dependency status (dependent or independent) as determined by FAFSA before professional judgment.' ;
    rdfs:domain ind:ProfessionalJudgment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalEfc rdf:type rdf:Property ;
    rdfs:label 'Original Efc' ;
    rdfs:comment 'The original Expected Family Contribution calculated from the FAFSA before professional judgment adjustment.' ;
    rdfs:domain ind:ProfessionalJudgment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:originalValue rdf:type rdf:Property ;
    rdfs:label 'Original Value' ;
    rdfs:comment 'The original value of the element before professional judgment was applied (may be numeric, text, or status depending on adjustment category).' ;
    rdfs:domain ind:ProfessionalJudgment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pjType rdf:type rdf:Property ;
    rdfs:label 'Pj Type' ;
    rdfs:comment 'The category of professional judgment exercised: special circumstance (income/asset adjustment), dependency override (independent status), cost of attendance adjustment, unusual enrollment history waiver, satisfactory academic progress appeal, or other.' ;
    rdfs:domain ind:ProfessionalJudgment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reasonCode rdf:type rdf:Property ;
    rdfs:label 'Reason Code' ;
    rdfs:comment 'Institutional code or category describing the specific reason for the professional judgment (e.g., job loss, medical expenses, divorce, death of parent, natural disaster).' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reasonDescription rdf:type rdf:Property ;
    rdfs:label 'Reason Description' ;
    rdfs:comment 'Detailed narrative explanation of the circumstances that warranted the professional judgment decision.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:repackagingCompletedDate rdf:type rdf:Property ;
    rdfs:label 'Repackaging Completed Date' ;
    rdfs:comment 'The date when the financial aid repackaging was completed following the professional judgment adjustment.' ;
    rdfs:domain ind:ProfessionalJudgment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:repackagingRequired rdf:type rdf:Property ;
    rdfs:label 'Repackaging Required' ;
    rdfs:comment 'Indicates whether the students financial aid award package must be recalculated and reissued as a result of this professional judgment decision.' ;
    rdfs:domain ind:ProfessionalJudgment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requestDate rdf:type rdf:Property ;
    rdfs:label 'Request Date' ;
    rdfs:comment 'The date when the student or family submitted the professional judgment request.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reviewerNotes rdf:type rdf:Property ;
    rdfs:label 'Reviewer Notes' ;
    rdfs:comment 'Internal notes or comments recorded by the financial aid administrator during the review and decision process.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportingDocumentation rdf:type rdf:Property ;
    rdfs:label 'Supporting Documentation' ;
    rdfs:comment 'Description or reference to the documentation submitted by the student to support the professional judgment request (e.g., tax returns, medical bills, unemployment notice, death certificate).' ;
    rdfs:domain ind:ProfessionalJudgment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalCalculationR2t4CalculationId rdf:type rdf:Property ;
    rdfs:label 'Original Calculation R2t4 Calculation Id' ;
    rdfs:comment 'Reference to the original R2T4 calculation record if this is a recalculation. Null if this is the initial calculation.' ;
    rdfs:domain ind:R2t4Calculation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:R2t4Calculation .

ind:primaryR2t4EmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary R2t4 Employee Id' ;
    rdfs:comment 'Identifier of the financial aid staff member who performed or initiated the R2T4 calculation.' ;
    rdfs:domain ind:R2t4Calculation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:studentAthleteId rdf:type rdf:Property ;
    rdfs:label 'Student Athlete Id' ;
    rdfs:comment 'Foreign key linking to athletics.student_athlete. Business justification: Return of Title IV calculations for withdrawn student-athletes require coordination with athletic compliance to determine impact on athletic scholarship, eligibility clock, and seasons of competition.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StudentAthlete .

ind:calculationMethod rdf:type rdf:Property ;
    rdfs:label 'Calculation Method' ;
    rdfs:comment 'Method used for the R2T4 calculation based on the program structure: standard (credit-hour term-based), modular (courses not spanning entire term), or nonstandard term (non-traditional calendar).' ;
    rdfs:domain ind:R2t4Calculation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calculationNumber rdf:type rdf:Property ;
    rdfs:label 'Calculation Number' ;
    rdfs:comment 'Business identifier for the R2T4 calculation, typically formatted as aid year, term, and sequence number for audit and tracking purposes.' ;
    rdfs:domain ind:R2t4Calculation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calculationStatus rdf:type rdf:Property ;
    rdfs:label 'Calculation Status' ;
    rdfs:comment 'Current lifecycle status of the R2T4 calculation process.' ;
    rdfs:domain ind:R2t4Calculation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calculationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Calculation Timestamp' ;
    rdfs:comment 'Date and time when the R2T4 calculation was performed or last recalculated.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:daysCompleted rdf:type rdf:Property ;
    rdfs:label 'Days Completed' ;
    rdfs:comment 'Number of calendar days the student completed in the payment period before withdrawing, calculated from payment period start date to withdrawal date.' ;
    rdfs:domain ind:R2t4Calculation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:determinationDate rdf:type rdf:Property ;
    rdfs:label 'Determination Date' ;
    rdfs:comment 'Date the institution determined that the student withdrew. This date triggers the 45-day return deadline and is critical for compliance timing.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:grantProtectionAmount rdf:type rdf:Property ;
    rdfs:label 'Grant Protection Amount' ;
    rdfs:comment 'Amount of grant aid protected from return under the 50% grant protection rule. Students are not required to return grant overpayments if the amount is 50% or less of total grants received.' ;
    rdfs:domain ind:R2t4Calculation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:institutionalCharges rdf:type rdf:Property ;
    rdfs:label 'Institutional Charges' ;
    rdfs:comment 'Total institutional charges (tuition, fees, room, board) assessed to the student for the payment period, used to calculate the institutional share of unearned aid to be returned.' ;
    rdfs:domain ind:R2t4Calculation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:institutionalReturnAmount rdf:type rdf:Property ;
    rdfs:label 'Institutional Return Amount' ;
    rdfs:comment 'Amount of unearned Title IV aid the institution is responsible for returning to the Department of Education, calculated based on institutional charges and unearned aid.' ;
    rdfs:domain ind:R2t4Calculation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastDateOfAttendance rdf:type rdf:Property ;
    rdfs:label 'Last Date Of Attendance' ;
    rdfs:comment 'Last documented date the student attended an academically-related activity. Used when the institution is required to take attendance.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentPeriodDays rdf:type rdf:Property ;
    rdfs:label 'Payment Period Days' ;
    rdfs:comment 'Total number of calendar days in the payment period, calculated as the difference between payment period end date and start date.' ;
    rdfs:domain ind:R2t4Calculation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:paymentPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Payment Period End Date' ;
    rdfs:comment 'End date of the payment period (typically the term end date) used to calculate the percentage of the period completed.' ;
    rdfs:domain ind:R2t4Calculation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Payment Period Start Date' ;
    rdfs:comment 'Start date of the payment period (typically the term start date) used to calculate the percentage of the period completed.' ;
    rdfs:domain ind:R2t4Calculation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:percentageCompleted rdf:type rdf:Property ;
    rdfs:label 'Percentage Completed' ;
    rdfs:comment 'Percentage of the payment period the student completed before withdrawing, calculated as (days completed / payment period days) * 100. Capped at 60% per federal regulation.' ;
    rdfs:domain ind:R2t4Calculation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:postWithdrawalDisbursementAmount rdf:type rdf:Property ;
    rdfs:label 'Post Withdrawal Disbursement Amount' ;
    rdfs:comment 'Amount of Title IV aid the student earned but was not yet disbursed at the time of withdrawal. The institution must offer this to the student within regulatory timeframes.' ;
    rdfs:domain ind:R2t4Calculation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recalculationFlag rdf:type rdf:Property ;
    rdfs:label 'Recalculation Flag' ;
    rdfs:comment 'Indicates whether this calculation is a recalculation of a previously completed R2T4 calculation, typically due to corrected data or audit findings.' ;
    rdfs:domain ind:R2t4Calculation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:returnCompletedDate rdf:type rdf:Property ;
    rdfs:label 'Return Completed Date' ;
    rdfs:comment 'Date the institution completed the return of unearned Title IV funds to the Department of Education.' ;
    rdfs:domain ind:R2t4Calculation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:returnDeadlineDate rdf:type rdf:Property ;
    rdfs:label 'Return Deadline Date' ;
    rdfs:comment 'Deadline by which the institution must return unearned Title IV funds to the Department of Education, typically 45 days from the date the institution determined the student withdrew.' ;
    rdfs:domain ind:R2t4Calculation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reviewTimestamp rdf:type rdf:Property ;
    rdfs:label 'Review Timestamp' ;
    rdfs:comment 'Date and time when the R2T4 calculation was reviewed and approved.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sixtyPercentRuleApplied rdf:type rdf:Property ;
    rdfs:label 'Sixty Percent Rule Applied' ;
    rdfs:comment 'Indicates whether the 60% rule was applied. If a student completes more than 60% of the payment period, they earn 100% of Title IV aid and no return is required.' ;
    rdfs:domain ind:R2t4Calculation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:studentReturnAmount rdf:type rdf:Property ;
    rdfs:label 'Student Return Amount' ;
    rdfs:comment 'Amount of unearned Title IV aid the student is responsible for returning, calculated as total unearned aid minus institutional return amount.' ;
    rdfs:domain ind:R2t4Calculation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalTitleIvAidDisbursed rdf:type rdf:Property ;
    rdfs:label 'Total Title Iv Aid Disbursed' ;
    rdfs:comment 'Total amount of Title IV federal aid that was disbursed to the student or on behalf of the student for the payment period as of the withdrawal date.' ;
    rdfs:domain ind:R2t4Calculation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalTitleIvAidEarned rdf:type rdf:Property ;
    rdfs:label 'Total Title Iv Aid Earned' ;
    rdfs:comment 'Amount of Title IV aid the student earned based on the percentage of the payment period completed, calculated as total disbursed aid * percentage completed (or 100% if percentage >= 60%).' ;
    rdfs:domain ind:R2t4Calculation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalTitleIvAidUnearned rdf:type rdf:Property ;
    rdfs:label 'Total Title Iv Aid Unearned' ;
    rdfs:comment 'Amount of Title IV aid that was not earned and must be returned, calculated as total disbursed aid - total earned aid.' ;
    rdfs:domain ind:R2t4Calculation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:withdrawalType rdf:type rdf:Property ;
    rdfs:label 'Withdrawal Type' ;
    rdfs:comment 'Type of withdrawal that triggered the R2T4 calculation: official (student formally withdrew), unofficial (student stopped attending without formal withdrawal), or administrative (institution-initiated withdrawal).' ;
    rdfs:domain ind:R2t4Calculation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:academicPlanConditions rdf:type rdf:Property ;
    rdfs:label 'Academic Plan Conditions' ;
    rdfs:comment 'Detailed conditions and requirements the student must meet under the academic plan, such as minimum term GPA, credit load restrictions, mandatory advising, or tutoring participation.' ;
    rdfs:domain ind:AidSapEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:academicPlanEndTerm rdf:type rdf:Property ;
    rdfs:label 'Academic Plan End Term' ;
    rdfs:comment 'The academic term code when the student\'s academic plan is scheduled to conclude, by which time the student must return to meeting SAP standards.' ;
    rdfs:domain ind:AidSapEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:academicPlanRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Academic Plan Required Flag' ;
    rdfs:comment 'Indicates whether the student is required to follow an academic plan as a condition of probation status. True if academic plan is required; false otherwise.' ;
    rdfs:domain ind:AidSapEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:academicPlanStartTerm rdf:type rdf:Property ;
    rdfs:label 'Academic Plan Start Term' ;
    rdfs:comment 'The academic term code when the student\'s academic plan begins, typically the term immediately following an approved appeal.' ;
    rdfs:domain ind:AidSapEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appealDecision rdf:type rdf:Property ;
    rdfs:label 'Appeal Decision' ;
    rdfs:comment 'The outcome of the SAP appeal review: approved (student placed on probation with academic plan), denied (suspension upheld), pending review, or withdrawn by student.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appealDecisionDate rdf:type rdf:Property ;
    rdfs:label 'Appeal Decision Date' ;
    rdfs:comment 'The date on which the SAP appeal decision was rendered by the financial aid office or appeals committee.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:appealReason rdf:type rdf:Property ;
    rdfs:label 'Appeal Reason' ;
    rdfs:comment 'The documented reason(s) for the SAP appeal, such as serious illness, death of family member, military deployment, or other mitigating circumstances that affected academic performance.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appealReviewerName rdf:type rdf:Property ;
    rdfs:label 'Appeal Reviewer Name' ;
    rdfs:comment 'The name of the financial aid officer, committee chair, or official who reviewed and decided the SAP appeal.' ;
    rdfs:domain ind:AidSapEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:completionRatePercentage rdf:type rdf:Property ;
    rdfs:label 'Completion Rate Percentage' ;
    rdfs:comment 'The student\'s pace of progression, calculated as (cumulative earned credits / cumulative attempted credits) * 100. Federal regulation requires minimum 67% completion rate.' ;
    rdfs:domain ind:AidSapEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cumulativeCreditsAttempted rdf:type rdf:Property ;
    rdfs:label 'Cumulative Credits Attempted' ;
    rdfs:comment 'Total number of credit hours the student has attempted in the program as of this evaluation, including withdrawals, incompletes, and failed courses.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cumulativeCreditsEarned rdf:type rdf:Property ;
    rdfs:label 'Cumulative Credits Earned' ;
    rdfs:comment 'Total number of credit hours the student has successfully completed (passed) in the program as of this evaluation.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:evaluationDate rdf:type rdf:Property ;
    rdfs:label 'Evaluation Date' ;
    rdfs:comment 'The date on which the Satisfactory Academic Progress evaluation was performed. Typically occurs at the end of a term or payment period.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:evaluationType rdf:type rdf:Property ;
    rdfs:label 'Evaluation Type' ;
    rdfs:comment 'The type or trigger of the SAP evaluation: end of term, payment period checkpoint, annual review, mid-term check, appeal review, or reinstatement evaluation.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialAidEligibilityStatus rdf:type rdf:Property ;
    rdfs:label 'Financial Aid Eligibility Status' ;
    rdfs:comment 'The student\'s Title IV financial aid eligibility status resulting from this SAP evaluation: eligible (meeting standards), ineligible (suspended), or conditional (probation with academic plan).' ;
    rdfs:domain ind:AidSapEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumCreditsAllowed rdf:type rdf:Property ;
    rdfs:label 'Maximum Credits Allowed' ;
    rdfs:comment 'The maximum number of credit hours the student may attempt to complete the program, calculated as 150% of the published program length per federal regulation.' ;
    rdfs:domain ind:AidSapEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maximumTimeframeStatus rdf:type rdf:Property ;
    rdfs:label 'Maximum Timeframe Status' ;
    rdfs:comment 'Status of the maximum timeframe measure. Within_limit indicates the student can complete the program within 150% of published length; exceeded indicates the student cannot.' ;
    rdfs:domain ind:AidSapEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumCompletionRateRequired rdf:type rdf:Property ;
    rdfs:label 'Minimum Completion Rate Required' ;
    rdfs:comment 'The minimum completion rate percentage required by the institution\'s SAP policy. Federal regulation mandates at least 67%.' ;
    rdfs:domain ind:AidSapEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumGpaRequired rdf:type rdf:Property ;
    rdfs:label 'Minimum Gpa Required' ;
    rdfs:comment 'The minimum cumulative GPA required by the institution\'s SAP policy for the student\'s program and academic level at the time of evaluation.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:notificationMethod rdf:type rdf:Property ;
    rdfs:label 'Notification Method' ;
    rdfs:comment 'The method by which the SAP evaluation results were communicated to the student: email, postal mail, student portal message, in-person meeting, or phone call.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationSentDate rdf:type rdf:Property ;
    rdfs:label 'Notification Sent Date' ;
    rdfs:comment 'The date on which the institution notified the student of their SAP evaluation results and financial aid eligibility status.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:overallSapStatus rdf:type rdf:Property ;
    rdfs:label 'Overall Sap Status' ;
    rdfs:comment 'The overall Satisfactory Academic Progress status resulting from this evaluation: meeting standards, warning (first failure), suspension (ineligible for aid), probation (on academic plan after appeal), dismissed, or reinstated.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorSapStatus rdf:type rdf:Property ;
    rdfs:label 'Prior Sap Status' ;
    rdfs:comment 'The student\'s SAP status from the immediately preceding evaluation period, used to determine progression through warning, suspension, and probation stages. [ENUM-REF-CANDIDATE: meeting|warning|suspension|probation|dismissed|reinstated|first_evaluation — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:AidSapEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programPublishedLength rdf:type rdf:Property ;
    rdfs:label 'Program Published Length' ;
    rdfs:comment 'The published length of the student\'s academic program in credit hours, used as the basis for calculating the 150% maximum timeframe.' ;
    rdfs:domain ind:AidSapEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualitativeMeasureStatus rdf:type rdf:Property ;
    rdfs:label 'Qualitative Measure Status' ;
    rdfs:comment 'Status of the qualitative measure (cumulative GPA requirement). Pass indicates the student meets the minimum cumulative GPA threshold; fail indicates below threshold.' ;
    rdfs:domain ind:AidSapEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantitativeMeasureStatus rdf:type rdf:Property ;
    rdfs:label 'Quantitative Measure Status' ;
    rdfs:comment 'Status of the quantitative measure (pace/completion rate requirement). Pass indicates the student meets the minimum 67% completion rate; fail indicates below threshold.' ;
    rdfs:domain ind:AidSapEvaluation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scholarshipId rdf:type rdf:Property ;
    rdfs:label 'Scholarship Id' ;
    rdfs:comment 'Unique identifier for the scholarship record. Primary key for the scholarship catalog.' ;
    rdfs:domain ind:Scholarship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:concentrationId rdf:type rdf:Property ;
    rdfs:label 'Concentration Id' ;
    rdfs:comment 'Foreign key linking to curriculum.concentration. Business justification: Some scholarships target specific concentrations within programs (e.g., "Cybersecurity Concentration Scholarship" within Computer Science program). While less common than program-level restrictions, c' ;
    rdfs:domain ind:Education ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Concentration .

ind:studentOrgId rdf:type rdf:Property ;
    rdfs:label 'Student Org Id' ;
    rdfs:comment 'Foreign key linking to studentlife.student_org. Business justification: Many scholarships are restricted to members of specific student organizations (Greek life scholarships, club-specific awards, honor society scholarships). Business process: Scholarship eligibility ver' ;
    rdfs:domain ind:Education ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StudentOrg .

ind:applicationDeadline rdf:type rdf:Property ;
    rdfs:label 'Application Deadline' ;
    rdfs:comment 'Final date by which students must submit scholarship applications or supporting materials to be considered for the award cycle.' ;
    rdfs:domain ind:Scholarship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:applicationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Application Required Flag' ;
    rdfs:comment 'Indicates whether students must submit a separate scholarship application to be considered, or if the scholarship is automatically awarded based on admission or FAFSA data.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:awardNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Award Notification Date' ;
    rdfs:comment 'Date on which scholarship recipients are notified of their award. Used for planning financial aid packaging timelines and student communication.' ;
    rdfs:domain ind:Scholarship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:classStanding rdf:type rdf:Property ;
    rdfs:label 'Class Standing' ;
    rdfs:comment 'Specific class year or standing required for scholarship eligibility. May restrict awards to incoming freshmen, continuing sophomores, juniors, seniors, or graduate students.' ;
    rdfs:domain ind:Scholarship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactName rdf:type rdf:Property ;
    rdfs:label 'Contact Name' ;
    rdfs:comment 'Name of the institutional staff member, department, or external organization contact responsible for administering the scholarship and answering student inquiries.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coordinationRule rdf:type rdf:Property ;
    rdfs:label 'Coordination Rule' ;
    rdfs:comment 'Rule governing how this scholarship interacts with other financial aid in the student\'s award package. Determines whether the scholarship is stackable with other aid, reduces need-based aid, replaces loans, replaces work-study, or has no coordination requirements.' ;
    rdfs:domain ind:Scholarship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:donorOrganizationName rdf:type rdf:Property ;
    rdfs:label 'Donor Organization Name' ;
    rdfs:comment 'Name of the individual donor, corporation, foundation, or organization that established or funds the scholarship. Critical for external and endowed scholarships for stewardship and recognition purposes.' ;
    rdfs:domain ind:Scholarship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endowmentFlag rdf:type rdf:Property ;
    rdfs:label 'Endowment Flag' ;
    rdfs:comment 'Indicates whether the scholarship is funded by an endowment with perpetual principal and annual earnings distribution, as opposed to annual or one-time funding.' ;
    rdfs:domain ind:Scholarship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:majorRestriction rdf:type rdf:Property ;
    rdfs:label 'Major Restriction' ;
    rdfs:comment 'Academic major, program, or field of study required for scholarship eligibility. May specify a single major, a list of eligible majors, or a broad discipline such as STEM (Science Technology Engineering Mathematics) or business.' ;
    rdfs:domain ind:Scholarship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumYearsAwarded rdf:type rdf:Property ;
    rdfs:label 'Maximum Years Awarded' ;
    rdfs:comment 'Maximum number of academic years a student may receive this scholarship, including initial award and renewals. Typically 4 for undergraduate scholarships, variable for graduate programs.' ;
    rdfs:domain ind:Scholarship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minimumCreditHours rdf:type rdf:Property ;
    rdfs:label 'Minimum Credit Hours' ;
    rdfs:comment 'Minimum number of credit hours per term that a student must be enrolled in to be eligible for or retain the scholarship. Typically used to enforce full-time or half-time enrollment requirements.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumGpa rdf:type rdf:Property ;
    rdfs:label 'Minimum Gpa' ;
    rdfs:comment 'Minimum cumulative or term GPA required for initial eligibility or renewal of the scholarship. Expressed on a 4.0 scale.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:renewalCriteria rdf:type rdf:Property ;
    rdfs:label 'Renewal Criteria' ;
    rdfs:comment 'Detailed description of the academic, enrollment, and behavioral requirements a student must maintain to renew the scholarship for subsequent years. May include minimum GPA, credit hour requirements, major continuation, and Satisfactory Academic Progress (SAP) standards.' ;
    rdfs:domain ind:Scholarship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scholarshipCode rdf:type rdf:Property ;
    rdfs:label 'Scholarship Code' ;
    rdfs:comment 'Externally-known unique code or identifier for the scholarship used in financial aid packaging and student communications. Business identifier for the scholarship.' ;
    rdfs:domain ind:Scholarship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scholarshipName rdf:type rdf:Property ;
    rdfs:label 'Scholarship Name' ;
    rdfs:comment 'Full official name of the scholarship or grant program as it appears in institutional publications and award letters.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scholarshipStatus rdf:type rdf:Property ;
    rdfs:label 'Scholarship Status' ;
    rdfs:comment 'Current lifecycle status of the scholarship. Indicates whether the scholarship is actively available for awarding, temporarily suspended, permanently discontinued, or pending approval for activation.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scholarshipType rdf:type rdf:Property ;
    rdfs:label 'Scholarship Type' ;
    rdfs:comment 'Classification of the scholarship by its primary awarding criteria and funding structure. Distinguishes merit-based, need-based, departmental, endowed, external/private, athletic, diversity, research, and service scholarships. [ENUM-REF-CANDIDATE: merit|need_based|departmental|endowed|external|athletic|diversity|research|service — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:childSupportPaidVerificationDate rdf:type rdf:Property ;
    rdfs:label 'Child Support Paid Verification Date' ;
    rdfs:comment 'The date documentation of child support paid was received and verified.' ;
    rdfs:domain ind:Verification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:conflictingInformationDescription rdf:type rdf:Property ;
    rdfs:label 'Conflicting Information Description' ;
    rdfs:comment 'Description of the conflicting information identified and how it was resolved.' ;
    rdfs:domain ind:Verification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conflictingInformationIndicator rdf:type rdf:Property ;
    rdfs:label 'Conflicting Information Indicator' ;
    rdfs:comment 'Indicates whether conflicting information was identified that requires resolution before verification can be completed.' ;
    rdfs:domain ind:Verification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:correctionRequiredIndicator rdf:type rdf:Property ;
    rdfs:label 'Correction Required Indicator' ;
    rdfs:comment 'Indicates whether a FAFSA correction is required based on verification findings.' ;
    rdfs:domain ind:Verification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:correctionSubmittedDate rdf:type rdf:Property ;
    rdfs:label 'Correction Submitted Date' ;
    rdfs:comment 'The date the FAFSA correction was submitted to CPS following verification.' ;
    rdfs:domain ind:Verification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dependencyOverrideDate rdf:type rdf:Property ;
    rdfs:label 'Dependency Override Date' ;
    rdfs:comment 'The date the dependency override decision was made and documented.' ;
    rdfs:domain ind:Verification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dependencyOverrideIndicator rdf:type rdf:Property ;
    rdfs:label 'Dependency Override Indicator' ;
    rdfs:comment 'Indicates whether a dependency override was granted by the financial aid administrator, changing the student\'s dependency status from dependent to independent.' ;
    rdfs:domain ind:Verification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dependencyOverrideReason rdf:type rdf:Property ;
    rdfs:label 'Dependency Override Reason' ;
    rdfs:comment 'Narrative explanation of the unusual circumstances justifying the dependency override (e.g., abandonment, abuse, incarceration of parents).' ;
    rdfs:domain ind:Verification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exclusionReason rdf:type rdf:Property ;
    rdfs:label 'Exclusion Reason' ;
    rdfs:comment 'Explanation of why the student was excluded from verification (e.g., received only unsubsidized loans, parent information not required).' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:highSchoolCompletionVerificationDate rdf:type rdf:Property ;
    rdfs:label 'High School Completion Verification Date' ;
    rdfs:comment 'The date high school completion status (diploma, GED, homeschool) was verified.' ;
    rdfs:domain ind:Verification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:householdSizeVerificationDate rdf:type rdf:Property ;
    rdfs:label 'Household Size Verification Date' ;
    rdfs:comment 'The date household size documentation was received and verified.' ;
    rdfs:domain ind:Verification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:identityVerificationReceivedDate rdf:type rdf:Property ;
    rdfs:label 'Identity Verification Received Date' ;
    rdfs:comment 'The date identity verification documentation (e.g., copy of driver\'s license, passport) was received.' ;
    rdfs:domain ind:Verification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:incomeVerificationMethod rdf:type rdf:Property ;
    rdfs:label 'Income Verification Method' ;
    rdfs:comment 'The method used to verify income information. IRS_DRT=IRS Data Retrieval Tool, TAX_TRANSCRIPT=IRS Tax Return Transcript, W2=W-2 forms, 1099=1099 forms, NOT_REQUIRED=income verification not required for this tracking group.' ;
    rdfs:domain ind:Verification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:numberInCollegeVerificationDate rdf:type rdf:Property ;
    rdfs:label 'Number In College Verification Date' ;
    rdfs:comment 'The date documentation verifying the number of household members enrolled in college was received.' ;
    rdfs:domain ind:Verification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:professionalJudgmentDate rdf:type rdf:Property ;
    rdfs:label 'Professional Judgment Date' ;
    rdfs:comment 'The date the professional judgment adjustment was made.' ;
    rdfs:domain ind:Verification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:professionalJudgmentIndicator rdf:type rdf:Property ;
    rdfs:label 'Professional Judgment Indicator' ;
    rdfs:comment 'Indicates whether professional judgment was exercised to adjust data elements used to calculate the Expected Family Contribution (EFC).' ;
    rdfs:domain ind:Verification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reviewerName rdf:type rdf:Property ;
    rdfs:label 'Reviewer Name' ;
    rdfs:comment 'The full name of the financial aid administrator who reviewed and completed the verification.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:selectionSource rdf:type rdf:Property ;
    rdfs:label 'Selection Source' ;
    rdfs:comment 'Indicates whether the student was selected for verification by the Central Processing System (CPS) or by the institution.' ;
    rdfs:domain ind:Verification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:snapBenefitsVerificationDate rdf:type rdf:Property ;
    rdfs:label 'Snap Benefits Verification Date' ;
    rdfs:comment 'The date documentation of SNAP benefits receipt was verified (applicable for V5 tracking group).' ;
    rdfs:domain ind:Verification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:taxTranscriptReceivedDate rdf:type rdf:Property ;
    rdfs:label 'Tax Transcript Received Date' ;
    rdfs:comment 'The date the IRS tax return transcript or equivalent tax documentation was received from the student or parent.' ;
    rdfs:domain ind:Verification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:trackingGroup rdf:type rdf:Property ;
    rdfs:label 'Tracking Group' ;
    rdfs:comment 'The federal verification tracking group assigned by CPS (Central Processing System) or institutionally. V1=Standard Verification Group, V4=Custom Verification Group, V5=Aggregate Household Resources, V6=IRS Income Tax Return Filers.' ;
    rdfs:domain ind:Verification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waiverReason rdf:type rdf:Property ;
    rdfs:label 'Waiver Reason' ;
    rdfs:comment 'Explanation of why the verification requirement was waived (e.g., death of student, natural disaster, student withdrew before verification completed).' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:veteranBenefitId rdf:type rdf:Property ;
    rdfs:label 'Veteran Benefit Id' ;
    rdfs:comment 'Unique identifier for the veteran benefit record. Primary key for the veteran benefit entity.' ;
    rdfs:domain ind:VeteranBenefit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:certificationTermId rdf:type rdf:Property ;
    rdfs:label 'Certification Term Id' ;
    rdfs:comment 'Unique identifier for the academic term for which enrollment was certified to the VA. Links to the term reference table in the Student Information System.' ;
    rdfs:domain ind:VeteranBenefit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Term .

ind:benefitChapter rdf:type rdf:Property ;
    rdfs:label 'Benefit Chapter' ;
    rdfs:comment 'The specific VA education benefit program chapter under which the student is receiving benefits. CH33 = Post-9/11 GI Bill, CH30 = Montgomery GI Bill Active Duty, CH35 = Survivors and Dependents Educational Assistance, CH1606 = Montgomery GI Bill Selected Reserve, VRAP = Veteran Rapid Retraining Assistance Program.' ;
    rdfs:domain ind:VeteranBenefit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:benefitPercentage rdf:type rdf:Property ;
    rdfs:label 'Benefit Percentage' ;
    rdfs:comment 'The percentage of full benefit entitlement the student is eligible to receive, ranging from 0.00 to 100.00. For Post-9/11 GI Bill, determined by length of active duty service (e.g., 90 days = 40%, 36 months = 100%).' ;
    rdfs:domain ind:VeteranBenefit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:benefitStatus rdf:type rdf:Property ;
    rdfs:label 'Benefit Status' ;
    rdfs:comment 'Current lifecycle status of the veteran benefit. Active = currently receiving benefits, Pending = application submitted awaiting approval, Suspended = temporarily paused, Terminated = ended by student or institution, Exhausted = all benefit entitlement used, Denied = application rejected by VA.' ;
    rdfs:domain ind:VeteranBenefit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bookStipendAmount rdf:type rdf:Property ;
    rdfs:label 'Book Stipend Amount' ;
    rdfs:comment 'The annual book and supplies stipend amount the student is eligible to receive under Post-9/11 GI Bill (CH33). Typically $1,000 per academic year, prorated based on training time and benefit percentage. Not applicable for other benefit chapters.' ;
    rdfs:domain ind:VeteranBenefit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:certificateOfEligibilityNumber rdf:type rdf:Property ;
    rdfs:label 'Certificate Of Eligibility Number' ;
    rdfs:comment 'The unique certificate number issued by the Department of Veterans Affairs confirming the student\'s eligibility for education benefits. Required for enrollment certification and benefit disbursement.' ;
    rdfs:domain ind:VeteranBenefit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationDate rdf:type rdf:Property ;
    rdfs:label 'Certification Date' ;
    rdfs:comment 'The date on which the School Certifying Official (SCO) certified the student\'s enrollment to the VA for the current term. Required for VA payment processing and compliance tracking.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:certifiedCreditHours rdf:type rdf:Property ;
    rdfs:label 'Certified Credit Hours' ;
    rdfs:comment 'The number of credit hours certified to the VA for the current enrollment period. Used to determine the student\'s training time (full-time, three-quarter-time, half-time) and corresponding benefit payment rate.' ;
    rdfs:domain ind:VeteranBenefit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:delimitingDate rdf:type rdf:Property ;
    rdfs:label 'Delimiting Date' ;
    rdfs:comment 'The final date by which the student must use their veteran education benefits. For Post-9/11 GI Bill, typically 15 years from the date of last discharge from active duty. After this date, unused benefits expire.' ;
    rdfs:domain ind:VeteranBenefit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:eligibilityBeginDate rdf:type rdf:Property ;
    rdfs:label 'Eligibility Begin Date' ;
    rdfs:comment 'The date on which the student becomes eligible to receive veteran education benefits under this benefit chapter. Typically corresponds to the service discharge date or eligibility determination date.' ;
    rdfs:domain ind:VeteranBenefit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:eligibilityEndDate rdf:type rdf:Property ;
    rdfs:label 'Eligibility End Date' ;
    rdfs:comment 'The date on which the student\'s eligibility for veteran education benefits expires. For Post-9/11 GI Bill (CH33), typically 15 years from last discharge date. Null if no expiration or benefit exhausted before expiration.' ;
    rdfs:domain ind:VeteranBenefit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:kickerEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Kicker Eligible Flag' ;
    rdfs:comment 'Boolean flag indicating whether the student is eligible for an additional monthly kicker payment (also known as College Fund) based on their military service agreement. True = kicker eligible, False = not eligible. Kicker is an additional benefit on top of standard GI Bill payments.' ;
    rdfs:domain ind:VeteranBenefit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:kickerMonthlyAmount rdf:type rdf:Property ;
    rdfs:label 'Kicker Monthly Amount' ;
    rdfs:comment 'The additional monthly kicker payment amount the student is eligible to receive based on their military service agreement. Null if student is not kicker eligible.' ;
    rdfs:domain ind:VeteranBenefit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastCertificationChangeDate rdf:type rdf:Property ;
    rdfs:label 'Last Certification Change Date' ;
    rdfs:comment 'The date of the most recent change to the student\'s enrollment certification submitted to the VA. Changes may include enrollment status updates, credit hour adjustments, or program changes that affect benefit eligibility.' ;
    rdfs:domain ind:VeteranBenefit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastCertificationChangeReason rdf:type rdf:Property ;
    rdfs:label 'Last Certification Change Reason' ;
    rdfs:comment 'Description of the reason for the most recent change to the student\'s enrollment certification. Examples include course withdrawal, program change, enrollment status change, or correction of certification error.' ;
    rdfs:domain ind:VeteranBenefit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monthlyHousingAllowanceAmount rdf:type rdf:Property ;
    rdfs:label 'Monthly Housing Allowance Amount' ;
    rdfs:comment 'The monthly housing allowance amount the student is eligible to receive under Post-9/11 GI Bill (CH33). Amount is based on the Basic Allowance for Housing (BAH) rate for an E-5 with dependents at the institution\'s ZIP code. Not applicable for other benefit chapters.' ;
    rdfs:domain ind:VeteranBenefit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:remainingEntitlementMonths rdf:type rdf:Property ;
    rdfs:label 'Remaining Entitlement Months' ;
    rdfs:comment 'The number of months of benefit entitlement remaining for the student. Typically starts at 36 months for full-time enrollment and decreases based on certified enrollment hours. Tracked to two decimal places for partial month usage.' ;
    rdfs:domain ind:VeteranBenefit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scoRemarks rdf:type rdf:Property ;
    rdfs:label 'Sco Remarks' ;
    rdfs:comment 'Free-text notes and remarks entered by the School Certifying Official regarding the student\'s veteran benefit status, certification issues, special circumstances, or communication with the VA. Used for case management and compliance documentation.' ;
    rdfs:domain ind:VeteranBenefit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingTime rdf:type rdf:Property ;
    rdfs:label 'Training Time' ;
    rdfs:comment 'The enrollment intensity classification for the student based on certified credit hours. Full-time = 12+ credits (undergraduate) or 9+ credits (graduate), Three-quarter-time = 9-11 credits (UG) or 7-8 credits (G), Half-time = 6-8 credits (UG) or 5-6 credits (G), Less-than-half-time = below half-time threshold.' ;
    rdfs:domain ind:VeteranBenefit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:tuitionAndFeesPaidToSchool rdf:type rdf:Property ;
    rdfs:label 'Tuition And Fees Paid To School' ;
    rdfs:comment 'The total amount of tuition and fees paid directly to the institution by the VA on behalf of the student for the current enrollment period. For Post-9/11 GI Bill, capped at the in-state tuition rate for public institutions or the national maximum for private institutions.' ;
    rdfs:domain ind:VeteranBenefit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vocationalRehabFlag rdf:type rdf:Property ;
    rdfs:label 'Vocational Rehab Flag' ;
    rdfs:comment 'Boolean flag indicating whether the student is receiving benefits under the Vocational Rehabilitation and Employment (VR&E) program (Chapter 31) in addition to or instead of standard education benefits. True = VR&E participant, False = not VR&E participant.' ;
    rdfs:domain ind:VeteranBenefit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:vrAndECounselorEmail rdf:type rdf:Property ;
    rdfs:label 'Vr And E Counselor Email' ;
    rdfs:comment 'The email address for the VA Vocational Rehabilitation Counselor assigned to the student. Null if student is not a VR&E participant.' ;
    rdfs:domain ind:VeteranBenefit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vrAndECounselorName rdf:type rdf:Property ;
    rdfs:label 'Vr And E Counselor Name' ;
    rdfs:comment 'The name of the VA Vocational Rehabilitation Counselor assigned to the student. Null if student is not a VR&E participant.' ;
    rdfs:domain ind:VeteranBenefit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vrAndECounselorPhone rdf:type rdf:Property ;
    rdfs:label 'Vr And E Counselor Phone' ;
    rdfs:comment 'The contact phone number for the VA Vocational Rehabilitation Counselor assigned to the student. Null if student is not a VR&E participant.' ;
    rdfs:domain ind:VeteranBenefit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:yellowRibbonInstitutionContribution rdf:type rdf:Property ;
    rdfs:label 'Yellow Ribbon Institution Contribution' ;
    rdfs:comment 'The amount the institution has agreed to contribute toward the student\'s tuition and fees under the Yellow Ribbon Program. The VA matches this amount dollar-for-dollar. Null if student is not a Yellow Ribbon participant.' ;
    rdfs:domain ind:VeteranBenefit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:yellowRibbonParticipantFlag rdf:type rdf:Property ;
    rdfs:label 'Yellow Ribbon Participant Flag' ;
    rdfs:comment 'Boolean flag indicating whether the student is participating in the Yellow Ribbon Program, which provides additional funding for tuition and fees exceeding the Post-9/11 GI Bill maximum benefit. True = participating, False = not participating. Only applicable to Post-9/11 GI Bill (CH33) recipients at 100% benefit level.' ;
    rdfs:domain ind:VeteranBenefit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:yellowRibbonVaContribution rdf:type rdf:Property ;
    rdfs:label 'Yellow Ribbon Va Contribution' ;
    rdfs:comment 'The amount the Department of Veterans Affairs contributes toward the student\'s tuition and fees under the Yellow Ribbon Program, matching the institution\'s contribution. Null if student is not a Yellow Ribbon participant.' ;
    rdfs:domain ind:VeteranBenefit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:workstudyAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Workstudy Assignment Id' ;
    rdfs:comment 'Unique identifier for the work-study assignment record. Primary key.' ;
    rdfs:domain ind:WorkstudyAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:positionId rdf:type rdf:Property ;
    rdfs:label 'Position Id' ;
    rdfs:comment 'Identifier of the specific work-study position or job posting to which the student is assigned.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Position .

ind:supervisorInstructorId rdf:type rdf:Property ;
    rdfs:label 'Supervisor Instructor Id' ;
    rdfs:comment 'Foreign key linking to faculty.instructor. Business justification: Faculty routinely supervise work-study students in research labs, departmental offices, and as teaching assistants. Supervisor relationship is essential for timesheet approval, performance evaluation,' ;
    rdfs:domain ind:WorkstudyAssignment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Instructor .

ind:workBuildingId rdf:type rdf:Property ;
    rdfs:label 'Work Building Id' ;
    rdfs:comment 'Foreign key linking to facility.building. Business justification: Federal work-study assignments require tracking physical work location for student reporting, supervisor oversight, and cost center allocation. Work_location is currently free text that should be norm' ;
    rdfs:domain ind:WorkstudyAssignment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Building .

ind:workRoomId rdf:type rdf:Property ;
    rdfs:label 'Work Room Id' ;
    rdfs:comment 'Foreign key linking to facility.room. Business justification: Work-study positions are assigned to specific rooms (offices, labs, libraries). Room-level tracking enables precise work location communication to students, supervisor contact information lookup, spac' ;
    rdfs:domain ind:WorkstudyAssignment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Room .

ind:actualTerminationDate rdf:type rdf:Property ;
    rdfs:label 'Actual Termination Date' ;
    rdfs:comment 'The actual date the student ceased work under this assignment, which may differ from the scheduled end date if terminated early or extended.' ;
    rdfs:domain ind:WorkstudyAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:authorizedHoursPerWeek rdf:type rdf:Property ;
    rdfs:label 'Authorized Hours Per Week' ;
    rdfs:comment 'Maximum number of hours per week the student is authorized to work under this assignment, typically capped to ensure academic progress.' ;
    rdfs:domain ind:WorkstudyAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:communityServiceFlag rdf:type rdf:Property ;
    rdfs:label 'Community Service Flag' ;
    rdfs:comment 'Indicates whether this work-study assignment qualifies as community service employment, which has specific federal reporting and percentage requirements.' ;
    rdfs:domain ind:WorkstudyAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cumulativeEarningsToDate rdf:type rdf:Property ;
    rdfs:label 'Cumulative Earnings To Date' ;
    rdfs:comment 'Total amount earned by the student under this assignment from the start date through the current date, updated as payroll is processed.' ;
    rdfs:domain ind:WorkstudyAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:federalSharePercentage rdf:type rdf:Property ;
    rdfs:label 'Federal Share Percentage' ;
    rdfs:comment 'The percentage of wages paid by federal work-study funds, typically 75% for most positions and up to 100% for community service roles.' ;
    rdfs:domain ind:WorkstudyAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hourlyRate rdf:type rdf:Property ;
    rdfs:label 'Hourly Rate' ;
    rdfs:comment 'The hourly wage rate paid to the student for work performed, must meet or exceed federal or state minimum wage requirements.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:i9VerificationDate rdf:type rdf:Property ;
    rdfs:label 'I9 Verification Date' ;
    rdfs:comment 'Date on which the students I-9 employment eligibility verification was completed.' ;
    rdfs:domain ind:WorkstudyAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:i9VerificationStatus rdf:type rdf:Property ;
    rdfs:label 'I9 Verification Status' ;
    rdfs:comment 'Status of the students I-9 employment eligibility verification, required for all U.S. work-study employment.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:institutionalSharePercentage rdf:type rdf:Property ;
    rdfs:label 'Institutional Share Percentage' ;
    rdfs:comment 'The percentage of wages paid by the institution or employer, typically 25% for most positions unless higher federal share applies.' ;
    rdfs:domain ind:WorkstudyAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:jobDescription rdf:type rdf:Property ;
    rdfs:label 'Job Description' ;
    rdfs:comment 'Detailed description of the work-study job duties, responsibilities, and learning outcomes associated with the position.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastUpdatedBy rdf:type rdf:Property ;
    rdfs:label 'Last Updated By' ;
    rdfs:comment 'Identifier or username of the financial aid counselor or system user who last modified this assignment record.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Updated Timestamp' ;
    rdfs:comment 'Timestamp when this work-study assignment record was most recently modified.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:payrollAccountCode rdf:type rdf:Property ;
    rdfs:label 'Payroll Account Code' ;
    rdfs:comment 'General ledger account code or cost center to which the students work-study wages are charged for financial accounting purposes.' ;
    rdfs:domain ind:WorkstudyAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remainingBalance rdf:type rdf:Property ;
    rdfs:label 'Remaining Balance' ;
    rdfs:comment 'The remaining work-study award balance available for the student to earn, calculated as total award amount minus cumulative earnings to date.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalAwardAmount rdf:type rdf:Property ;
    rdfs:label 'Total Award Amount' ;
    rdfs:comment 'The total work-study award amount allocated to the student for this assignment period, representing the maximum earnings authorized.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:athleticAwardId rdf:type rdf:Property ;
    rdfs:label 'Athletic Award Id' ;
    rdfs:comment 'Unique identifier for the athletic award record. Primary key for the athletic award entity.' ;
    rdfs:domain ind:AthleticAward ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryAthleticEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Athletic Employee Id' ;
    rdfs:comment 'Reference to the staff member (coach, athletic director, faculty athletics representative) who nominated the student-athlete or team for the award. Null if nomination was external or not applicable.' ;
    rdfs:domain ind:Athletics ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:sportId rdf:type rdf:Property ;
    rdfs:label 'Sport Id' ;
    rdfs:comment 'Foreign key linking to athletics.sport. Business justification: athletic_award is given for achievement in a specific sport. Currently uses sport_code/sport_name but lacks FK to sport master table. Adding sport_id enables JOIN to retrieve sport_name and other spor' ;
    rdfs:domain ind:Education ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Sport .

ind:teamId rdf:type rdf:Property ;
    rdfs:label 'Team Id' ;
    rdfs:comment 'Reference to the team that received the award. Null if the award is conferred upon an individual rather than a team.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Team .

ind:tertiaryAthleticLastUpdatedByStaffEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Athletic Last Updated By Staff Employee Id' ;
    rdfs:comment 'Reference to the staff member who most recently updated the award record.' ;
    rdfs:domain ind:AthleticAward ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:awardCertificateIssuedFlag rdf:type rdf:Property ;
    rdfs:label 'Award Certificate Issued Flag' ;
    rdfs:comment 'Indicates whether a physical or digital certificate has been issued to the recipient. True if issued, False otherwise.' ;
    rdfs:domain ind:AthleticAward ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:awardDate rdf:type rdf:Property ;
    rdfs:label 'Award Date' ;
    rdfs:comment 'Date on which the award was officially conferred or announced. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:AthleticAward ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:awardDescription rdf:type rdf:Property ;
    rdfs:label 'Award Description' ;
    rdfs:comment 'Detailed narrative description of the award, including criteria, significance, and any special circumstances or achievements that led to the recognition.' ;
    rdfs:domain ind:AthleticAward ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:awardLevel rdf:type rdf:Property ;
    rdfs:label 'Award Level' ;
    rdfs:comment 'Geographic or organizational scope of the award. Values include institutional (university-level), conference (athletic conference), regional (multi-state or regional association), national (country-wide), and international (global competition).' ;
    rdfs:domain ind:AthleticAward ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:awardNotes rdf:type rdf:Property ;
    rdfs:label 'Award Notes' ;
    rdfs:comment 'Free-text field for additional notes, comments, or context related to the award, including special circumstances, historical significance, or administrative remarks.' ;
    rdfs:domain ind:AthleticAward ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:awardTrophyIssuedFlag rdf:type rdf:Property ;
    rdfs:label 'Award Trophy Issued Flag' ;
    rdfs:comment 'Indicates whether a physical trophy or plaque has been issued to the recipient. True if issued, False otherwise.' ;
    rdfs:domain ind:AthleticAward ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:awardType rdf:type rdf:Property ;
    rdfs:label 'Award Type' ;
    rdfs:comment 'Categorical classification of the award type. Standardized values include All-Conference, All-American, Academic All-American, Player of the Week, Player of the Month, Most Valuable Player (MVP), Rookie of the Year, Sportsmanship Award, and Championship Trophy. [ENUM-REF-CANDIDATE: all-conference|all-american|academic all-american|player of the week|player of the month|mvp|rookie of the year|sportsmanship|championship trophy — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:awardingBody rdf:type rdf:Property ;
    rdfs:label 'Awarding Body' ;
    rdfs:comment 'Name of the organization, conference, or institution that conferred the award (e.g., Big Ten Conference, NCAA, College Sports Information Directors of America, institutional athletics department).' ;
    rdfs:domain ind:AthleticAward ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:benefitDescription rdf:type rdf:Property ;
    rdfs:label 'Benefit Description' ;
    rdfs:comment 'Description of any non-monetary benefits associated with the award, such as equipment, travel, training opportunities, or recognition events.' ;
    rdfs:domain ind:AthleticAward ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceReportDate rdf:type rdf:Property ;
    rdfs:label 'Compliance Report Date' ;
    rdfs:comment 'Date on which the award was reported to the governing body for compliance tracking. Null if not yet reported or not reportable. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:AthleticAward ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:complianceReportableFlag rdf:type rdf:Property ;
    rdfs:label 'Compliance Reportable Flag' ;
    rdfs:comment 'Indicates whether the award must be reported to NCAA, NAIA, or other governing bodies for compliance purposes. True if reportable, False otherwise.' ;
    rdfs:domain ind:AthleticAward ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:conferenceAffiliation rdf:type rdf:Property ;
    rdfs:label 'Conference Affiliation' ;
    rdfs:comment 'Name of the athletic conference to which the team or student-athlete belonged at the time the award was earned (e.g., Big Ten Conference, Atlantic Coast Conference, Southeastern Conference).' ;
    rdfs:domain ind:Athletics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentRecordFlag rdf:type rdf:Property ;
    rdfs:label 'Current Record Flag' ;
    rdfs:comment 'Indicates whether this is the current active version of the award record. True for the current record, False for historical versions. Supports slowly changing dimension (SCD) Type 2 tracking.' ;
    rdfs:domain ind:AthleticAward ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:divisionLevel rdf:type rdf:Property ;
    rdfs:label 'Division Level' ;
    rdfs:comment 'Athletic division or competitive level at which the award was earned. Values include NCAA Division I, NCAA Division II, NCAA Division III, NAIA (National Association of Intercollegiate Athletics), NJCAA (National Junior College Athletic Association), club, and intramural. [ENUM-REF-CANDIDATE: NCAA Division I|NCAA Division II|NCAA Division III|NAIA|NJCAA|club|intramural — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Athletics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publicAnnouncementDate rdf:type rdf:Property ;
    rdfs:label 'Public Announcement Date' ;
    rdfs:comment 'Date on which the award was publicly announced. Null if not yet announced or if public announcement does not apply. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:AthleticAward ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:publicAnnouncementFlag rdf:type rdf:Property ;
    rdfs:label 'Public Announcement Flag' ;
    rdfs:comment 'Indicates whether the award has been publicly announced through press releases, social media, or institutional communications. True if announced, False otherwise.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recipientType rdf:type rdf:Property ;
    rdfs:label 'Recipient Type' ;
    rdfs:comment 'Indicates whether the award was conferred upon an individual student-athlete or a team. Values are individual or team.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Record Effective Date' ;
    rdfs:comment 'Date from which this version of the award record is considered effective for reporting and analytics purposes. Supports slowly changing dimension (SCD) Type 2 tracking. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:Athletics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:recordExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Record Expiration Date' ;
    rdfs:comment 'Date on which this version of the award record is superseded by a newer version. Null for the current active record. Supports slowly changing dimension (SCD) Type 2 tracking. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:Athletics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scholarshipCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Scholarship Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the scholarship value (e.g., USD, CAD, EUR). Null if no financial benefit is associated with the award.' ;
    rdfs:domain ind:AthleticAward ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scholarshipValueAmount rdf:type rdf:Property ;
    rdfs:label 'Scholarship Value Amount' ;
    rdfs:comment 'Monetary value of any scholarship or financial benefit associated with the award, expressed in US dollars. Null if the award carries no financial benefit.' ;
    rdfs:domain ind:AthleticAward ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:season rdf:type rdf:Property ;
    rdfs:label 'Season' ;
    rdfs:comment 'Athletic season during which the award was earned. Values include fall, winter, spring, and summer.' ;
    rdfs:domain ind:Athletics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:selectionCriteria rdf:type rdf:Property ;
    rdfs:label 'Selection Criteria' ;
    rdfs:comment 'Description of the criteria used to select the award recipient, such as athletic performance, academic achievement, leadership, sportsmanship, or community service.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:athleticEligibilityId rdf:type rdf:Property ;
    rdfs:label 'Athletic Eligibility Id' ;
    rdfs:comment 'Unique identifier for the athletic eligibility record.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AthleticEligibility .

ind:titleIxCaseId rdf:type rdf:Property ;
    rdfs:label 'Title Ix Case Id' ;
    rdfs:comment 'Foreign key linking to compliance.title_ix_case. Business justification: Title IX cases can result in interim measures or sanctions affecting athletic eligibility (suspension from team activities, no-contact orders). Real business process: eligibility officers place compli' ;
    rdfs:domain ind:Education ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TitleIxCase .

ind:amateurismCertificationStatus rdf:type rdf:Property ;
    rdfs:label 'Amateurism Certification Status' ;
    rdfs:comment 'Status of the student-athlete\'s amateurism certification through the NCAA Eligibility Center.' ;
    rdfs:domain ind:Athletics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:athleticScholarshipFlag rdf:type rdf:Property ;
    rdfs:label 'Athletic Scholarship Flag' ;
    rdfs:comment 'Indicates whether the student-athlete is receiving an athletic scholarship.' ;
    rdfs:domain ind:Athletics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:certificationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Certification Timestamp' ;
    rdfs:comment 'The date and time when this eligibility record was certified.' ;
    rdfs:domain ind:Athletics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:complianceHoldFlag rdf:type rdf:Property ;
    rdfs:label 'Compliance Hold Flag' ;
    rdfs:comment 'Indicates whether a compliance hold has been placed on the student-athlete preventing participation until resolved.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:complianceHoldReason rdf:type rdf:Property ;
    rdfs:label 'Compliance Hold Reason' ;
    rdfs:comment 'Description of the reason for any compliance hold placed on the student-athlete.' ;
    rdfs:domain ind:Athletics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditHoursEnrolled rdf:type rdf:Property ;
    rdfs:label 'Credit Hours Enrolled' ;
    rdfs:comment 'The number of credit hours in which the student-athlete is currently enrolled.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:degreeApplicableCreditsEarned rdf:type rdf:Property ;
    rdfs:label 'Degree Applicable Credits Earned' ;
    rdfs:comment 'The total number of degree-applicable credit hours earned by the student-athlete.' ;
    rdfs:domain ind:Athletics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:eligibilityCertificationDate rdf:type rdf:Property ;
    rdfs:label 'Eligibility Certification Date' ;
    rdfs:comment 'The date on which the current eligibility status was certified by the institution\'s compliance office.' ;
    rdfs:domain ind:AthleticEligibility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:eligibilityNotes rdf:type rdf:Property ;
    rdfs:label 'Eligibility Notes' ;
    rdfs:comment 'Additional notes or comments regarding the student-athlete\'s eligibility status, waivers, or special circumstances.' ;
    rdfs:domain ind:AthleticEligibility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eligibilityStatus rdf:type rdf:Property ;
    rdfs:label 'Eligibility Status' ;
    rdfs:comment 'Current eligibility status of the student-athlete for competition in this sport.' ;
    rdfs:domain ind:AthleticEligibility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eligibilityYear rdf:type rdf:Property ;
    rdfs:label 'Eligibility Year' ;
    rdfs:comment 'The year of eligibility for the student-athlete (1st through 5th year, or 6th year in rare cases with medical hardship).' ;
    rdfs:domain ind:Athletics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fullTimeEnrollmentVerified rdf:type rdf:Property ;
    rdfs:label 'Full Time Enrollment Verified' ;
    rdfs:comment 'Indicates whether the student-athlete has been verified as enrolled full-time for the current term.' ;
    rdfs:domain ind:Athletics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gpaThresholdMet rdf:type rdf:Property ;
    rdfs:label 'Gpa Threshold Met' ;
    rdfs:comment 'Indicates whether the student-athlete meets the minimum GPA threshold required for athletic eligibility.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:initialEligibilityCertifiedDate rdf:type rdf:Property ;
    rdfs:label 'Initial Eligibility Certified Date' ;
    rdfs:comment 'The date on which the student-athlete\'s initial eligibility was certified by the NCAA Eligibility Center.' ;
    rdfs:domain ind:Athletics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:medicalHardshipSeason rdf:type rdf:Property ;
    rdfs:label 'Medical Hardship Season' ;
    rdfs:comment 'The season for which a medical hardship waiver was granted or requested.' ;
    rdfs:domain ind:Athletics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:medicalHardshipWaiverStatus rdf:type rdf:Property ;
    rdfs:label 'Medical Hardship Waiver Status' ;
    rdfs:comment 'Status of any medical hardship waiver request that would grant an additional year of eligibility due to injury or illness.' ;
    rdfs:domain ind:Athletics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumCreditHoursMet rdf:type rdf:Property ;
    rdfs:label 'Minimum Credit Hours Met' ;
    rdfs:comment 'Indicates whether the student-athlete meets the minimum credit hour requirement for eligibility (typically 12 credit hours for full-time status).' ;
    rdfs:domain ind:Athletics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nextEligibilityReviewDate rdf:type rdf:Property ;
    rdfs:label 'Next Eligibility Review Date' ;
    rdfs:comment 'The scheduled date for the next eligibility review (typically at the start of each term or season).' ;
    rdfs:domain ind:Athletics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:oneTimeTransferExceptionUsed rdf:type rdf:Property ;
    rdfs:label 'One Time Transfer Exception Used' ;
    rdfs:comment 'Indicates whether the student-athlete has used their one-time transfer exception allowing immediate eligibility.' ;
    rdfs:domain ind:Athletics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:progressTowardDegreeMet rdf:type rdf:Property ;
    rdfs:label 'Progress Toward Degree Met' ;
    rdfs:comment 'Indicates whether the student-athlete meets the progress-toward-degree requirement for continued eligibility.' ;
    rdfs:domain ind:Athletics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:progressTowardDegreePercentage rdf:type rdf:Property ;
    rdfs:label 'Progress Toward Degree Percentage' ;
    rdfs:comment 'The percentage of degree requirements completed by the student-athlete, used to determine eligibility continuation.' ;
    rdfs:domain ind:Athletics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:redshirtStatus rdf:type rdf:Property ;
    rdfs:label 'Redshirt Status' ;
    rdfs:comment 'Indicates whether the student-athlete is redshirting (practicing but not competing to preserve a year of eligibility).' ;
    rdfs:domain ind:Athletics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:redshirtYear rdf:type rdf:Property ;
    rdfs:label 'Redshirt Year' ;
    rdfs:comment 'The academic year during which the student-athlete redshirted, if applicable.' ;
    rdfs:domain ind:Athletics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:satisfactoryAcademicProgressMet rdf:type rdf:Property ;
    rdfs:label 'Satisfactory Academic Progress Met' ;
    rdfs:comment 'Indicates whether the student-athlete meets Satisfactory Academic Progress standards required for financial aid and athletic eligibility.' ;
    rdfs:domain ind:AthleticEligibility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:seasonsCompeted rdf:type rdf:Property ;
    rdfs:label 'Seasons Competed' ;
    rdfs:comment 'The number of seasons of competition the student-athlete has used in this sport.' ;
    rdfs:domain ind:Athletics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:seasonsRemaining rdf:type rdf:Property ;
    rdfs:label 'Seasons Remaining' ;
    rdfs:comment 'The number of seasons of competition remaining for the student-athlete in this sport.' ;
    rdfs:domain ind:Athletics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:termGpa rdf:type rdf:Property ;
    rdfs:label 'Term Gpa' ;
    rdfs:comment 'The GPA of the student-athlete for the current or most recent term.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transferEligibilityStatus rdf:type rdf:Property ;
    rdfs:label 'Transfer Eligibility Status' ;
    rdfs:comment 'Eligibility status specific to transfer students, indicating whether transfer requirements have been met.' ;
    rdfs:domain ind:Athletics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferInstitutionName rdf:type rdf:Property ;
    rdfs:label 'Transfer Institution Name' ;
    rdfs:comment 'Name of the institution from which the student-athlete transferred, if applicable.' ;
    rdfs:domain ind:Athletics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferStudentFlag rdf:type rdf:Property ;
    rdfs:label 'Transfer Student Flag' ;
    rdfs:comment 'Indicates whether the student-athlete is a transfer student from another institution.' ;
    rdfs:domain ind:Athletics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:athleticFacilityId rdf:type rdf:Property ;
    rdfs:label 'Athletic Facility Id' ;
    rdfs:comment 'Unique identifier for the athletic facility record. Primary key.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AthleticFacility .

ind:operatingBudgetId rdf:type rdf:Property ;
    rdfs:label 'Operating Budget Id' ;
    rdfs:comment 'Foreign key linking to finance.budget. Business justification: Athletic facilities have dedicated operating and capital budgets for maintenance, utilities, renovations, and staffing. Budget tracking enables facility managers to monitor spending, plan capital proj' ;
    rdfs:domain ind:Athletics ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Budget .

ind:operatingCostCenterId rdf:type rdf:Property ;
    rdfs:label 'Operating Cost Center Id' ;
    rdfs:comment 'Foreign key linking to finance.cost_center. Business justification: Athletic facilities have operating budgets for maintenance, utilities, staffing, and capital improvements tracked by cost center. Required for facility financial management, budget planning, and cost ' ;
    rdfs:domain ind:Athletics ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostCenter .

ind:primarySportId rdf:type rdf:Property ;
    rdfs:label 'Primary Sport Id' ;
    rdfs:comment 'FK to athletics.sport' ;
    rdfs:domain ind:Athletics ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Sport .

ind:adaAccessibleSeatingCount rdf:type rdf:Property ;
    rdfs:label 'Ada Accessible Seating Count' ;
    rdfs:comment 'Number of wheelchair-accessible seating positions available in the facility, as required by ADA compliance standards.' ;
    rdfs:domain ind:AthleticFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:buildingSquareFootage rdf:type rdf:Property ;
    rdfs:label 'Building Square Footage' ;
    rdfs:comment 'Total enclosed building square footage of the facility. Used for maintenance planning, utility allocation, and space utilization reporting.' ;
    rdfs:domain ind:AthleticFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:climateControlledFlag rdf:type rdf:Property ;
    rdfs:label 'Climate Controlled Flag' ;
    rdfs:comment 'Indicates whether the facility has heating, ventilation, and air conditioning (HVAC) systems for climate control. True if climate controlled, False otherwise.' ;
    rdfs:domain ind:AthleticFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:concessionStandsCount rdf:type rdf:Property ;
    rdfs:label 'Concession Stands Count' ;
    rdfs:comment 'Number of concession stands or food service points available in the facility for spectators.' ;
    rdfs:domain ind:AthleticFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:facilityCode rdf:type rdf:Property ;
    rdfs:label 'Facility Code' ;
    rdfs:comment 'Short alphanumeric code used to identify the athletic facility in scheduling systems, event management, and reporting. Typically 3-10 characters.' ;
    rdfs:domain ind:AthleticFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilityName rdf:type rdf:Property ;
    rdfs:label 'Facility Name' ;
    rdfs:comment 'Official name of the athletic facility (e.g., Memorial Stadium, Johnson Arena, Smith Aquatic Center).' ;
    rdfs:domain ind:AthleticFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilityStatus rdf:type rdf:Property ;
    rdfs:label 'Facility Status' ;
    rdfs:comment 'Current operational status of the athletic facility (active, inactive, under construction, under renovation, decommissioned).' ;
    rdfs:domain ind:AthleticFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilityType rdf:type rdf:Property ;
    rdfs:label 'Facility Type' ;
    rdfs:comment 'Classification of the athletic facility by its primary function and structure (e.g., stadium, arena, field, court, track, pool, weight room, training room, practice facility, locker room). [ENUM-REF-CANDIDATE: stadium|arena|field|court|track|pool|weight_room|training_room|practice_facility|locker_room — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:AthleticFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:homeVenueFlag rdf:type rdf:Property ;
    rdfs:label 'Home Venue Flag' ;
    rdfs:comment 'Indicates whether this facility serves as the official home venue for one or more varsity teams. True if home venue, False otherwise.' ;
    rdfs:domain ind:AthleticFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastRenovationYear rdf:type rdf:Property ;
    rdfs:label 'Last Renovation Year' ;
    rdfs:comment 'Year of the most recent major renovation or upgrade to the facility. Null if no major renovations have occurred since construction.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lightingLuxLevel rdf:type rdf:Property ;
    rdfs:label 'Lighting Lux Level' ;
    rdfs:comment 'Measured illumination level in lux at playing surface level. Required for NCAA competition certification and broadcast standards.' ;
    rdfs:domain ind:AthleticFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lightingType rdf:type rdf:Property ;
    rdfs:label 'Lighting Type' ;
    rdfs:comment 'Type of lighting system installed in the facility (e.g., LED, metal halide, halogen, natural, none). Critical for scheduling evening events and broadcast compliance.' ;
    rdfs:domain ind:AthleticFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lockerRoomCount rdf:type rdf:Property ;
    rdfs:label 'Locker Room Count' ;
    rdfs:comment 'Number of team locker rooms available in the facility. Includes home, visitor, and official locker rooms.' ;
    rdfs:domain ind:AthleticFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:naiaCertificationStatus rdf:type rdf:Property ;
    rdfs:label 'Naia Certification Status' ;
    rdfs:comment 'Current NAIA facility certification status indicating compliance with NAIA competition and safety standards. Applicable only for NAIA member institutions.' ;
    rdfs:domain ind:AthleticFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ncaaCertificationDate rdf:type rdf:Property ;
    rdfs:label 'Ncaa Certification Date' ;
    rdfs:comment 'Date when the facility received its most recent NCAA certification. Null if not certified or not applicable.' ;
    rdfs:domain ind:Athletics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ncaaCertificationExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Ncaa Certification Expiration Date' ;
    rdfs:comment 'Date when the current NCAA facility certification expires and recertification is required. Null if not certified or not applicable.' ;
    rdfs:domain ind:Athletics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ncaaCertificationStatus rdf:type rdf:Property ;
    rdfs:label 'Ncaa Certification Status' ;
    rdfs:comment 'Current NCAA facility certification status indicating compliance with NCAA competition and safety standards (certified, provisional, not certified, not applicable for non-NCAA sports).' ;
    rdfs:domain ind:Athletics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outdoorFlag rdf:type rdf:Property ;
    rdfs:label 'Outdoor Flag' ;
    rdfs:comment 'Indicates whether the facility is primarily an outdoor venue. True for outdoor facilities, False for indoor or enclosed facilities.' ;
    rdfs:domain ind:AthleticFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:parkingSpacesCount rdf:type rdf:Property ;
    rdfs:label 'Parking Spaces Count' ;
    rdfs:comment 'Number of parking spaces allocated to or adjacent to the athletic facility. Includes general, reserved, and ADA-accessible spaces.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:playingSurfaceType rdf:type rdf:Property ;
    rdfs:label 'Playing Surface Type' ;
    rdfs:comment 'Type of playing surface installed in the facility (e.g., natural grass, artificial turf, hardwood, synthetic floor, clay, concrete, rubberized track, water, ice, sand). [ENUM-REF-CANDIDATE: natural_grass|artificial_turf|hardwood|synthetic_floor|clay|concrete|rubberized_track|water|ice|sand — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:AthleticFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pressBoxCapacity rdf:type rdf:Property ;
    rdfs:label 'Press Box Capacity' ;
    rdfs:comment 'Number of media personnel that can be accommodated in the press box or media area. Null if no dedicated press area exists.' ;
    rdfs:domain ind:AthleticFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:restroomCount rdf:type rdf:Property ;
    rdfs:label 'Restroom Count' ;
    rdfs:comment 'Total number of public restroom facilities available in the venue. Used for capacity planning and ADA compliance verification.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:schedulingPriority rdf:type rdf:Property ;
    rdfs:label 'Scheduling Priority' ;
    rdfs:comment 'Numeric priority ranking used in facility scheduling systems to resolve conflicts. Lower numbers indicate higher priority (e.g., 1 = varsity competition, 2 = varsity practice, 3 = club sports, 4 = intramural).' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scoreboardType rdf:type rdf:Property ;
    rdfs:label 'Scoreboard Type' ;
    rdfs:comment 'Type of scoreboard system installed in the facility (e.g., LED video, LED matrix, digital, manual, none).' ;
    rdfs:domain ind:AthleticFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seatingCapacity rdf:type rdf:Property ;
    rdfs:label 'Seating Capacity' ;
    rdfs:comment 'Maximum number of spectators that can be seated in the facility for events. Null for facilities without spectator seating (e.g., practice fields, weight rooms).' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:secondarySportsServed rdf:type rdf:Property ;
    rdfs:label 'Secondary Sports Served' ;
    rdfs:comment 'Comma-separated list of additional sports that utilize this facility for practice, competition, or training (e.g., Track and Field, Soccer, Lacrosse).' ;
    rdfs:domain ind:AthleticFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standingCapacity rdf:type rdf:Property ;
    rdfs:label 'Standing Capacity' ;
    rdfs:comment 'Maximum number of standing spectators allowed in designated standing areas. Null if no standing areas exist.' ;
    rdfs:domain ind:AthleticFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:surfaceDimensionsLengthFt rdf:type rdf:Property ;
    rdfs:label 'Surface Dimensions Length Ft' ;
    rdfs:comment 'Length of the playing surface in feet. Used to verify compliance with sport-specific field/court dimension requirements.' ;
    rdfs:domain ind:AthleticFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:surfaceDimensionsWidthFt rdf:type rdf:Property ;
    rdfs:label 'Surface Dimensions Width Ft' ;
    rdfs:comment 'Width of the playing surface in feet. Used to verify compliance with sport-specific field/court dimension requirements.' ;
    rdfs:domain ind:AthleticFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trainingRoomAvailableFlag rdf:type rdf:Property ;
    rdfs:label 'Training Room Available Flag' ;
    rdfs:comment 'Indicates whether the facility includes an on-site athletic training room for injury treatment and rehabilitation. True if available, False otherwise.' ;
    rdfs:domain ind:AthleticFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:videoReplaySystemFlag rdf:type rdf:Property ;
    rdfs:label 'Video Replay System Flag' ;
    rdfs:comment 'Indicates whether the facility is equipped with an instant replay system for officiating and fan engagement. True if equipped, False otherwise.' ;
    rdfs:domain ind:AthleticFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:weightRoomAvailableFlag rdf:type rdf:Property ;
    rdfs:label 'Weight Room Available Flag' ;
    rdfs:comment 'Indicates whether the facility includes an on-site strength and conditioning weight room. True if available, False otherwise.' ;
    rdfs:domain ind:AthleticFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:yearBuilt rdf:type rdf:Property ;
    rdfs:label 'Year Built' ;
    rdfs:comment 'Year the facility was originally constructed. Used for capital planning, depreciation, and renovation scheduling.' ;
    rdfs:domain ind:AthleticFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:athleticScholarshipId rdf:type rdf:Property ;
    rdfs:label 'Athletic Scholarship Id' ;
    rdfs:comment 'Unique identifier for the athletic scholarship award record.' ;
    rdfs:domain ind:AthleticScholarship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:expenseLedgerAccountId rdf:type rdf:Property ;
    rdfs:label 'Expense Ledger Account Id' ;
    rdfs:comment 'Foreign key linking to finance.ledger_account. Business justification: Scholarship expenses must post to specific general ledger accounts for financial statement preparation, EADA reporting (athletically-related student aid by gender), and NCAA financial reporting. Requi' ;
    rdfs:domain ind:Athletics ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LedgerAccount .

ind:financialAidAwardId rdf:type rdf:Property ;
    rdfs:label 'Financial Aid Award Id' ;
    rdfs:comment 'Foreign key linking to aid.award. Business justification: Athletic scholarships are a type of financial aid award. This FK links athletic_scholarship to the aid award master, enabling unified financial aid tracking and compliance reporting (NCAA, Title IX, I' ;
    rdfs:domain ind:Education ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AidAward .

ind:fundingFinanceFundId rdf:type rdf:Property ;
    rdfs:label 'Funding Finance Fund Id' ;
    rdfs:comment 'Foreign key linking to finance.finance_fund. Business justification: Athletic scholarships are funded from specific restricted endowments, unrestricted operating funds, or donor-designated funds. Required for fund accounting, donor stewardship reporting, endowment spen' ;
    rdfs:domain ind:AthleticScholarship ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FinanceFund .

ind:nliId rdf:type rdf:Property ;
    rdfs:label 'Nli Id' ;
    rdfs:comment 'Foreign key linking to athletics.nli. Business justification: athletic_scholarship references nli_reference_number and nli_signed_date, indicating a relationship to the nli (National Letter of Intent) table. Adding nli_id FK enables JOIN to retrieve full NLI det' ;
    rdfs:domain ind:Athletics ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Nli .

ind:aidType rdf:type rdf:Property ;
    rdfs:label 'Aid Type' ;
    rdfs:comment 'Primary classification of the financial aid: athletic (based on athletic ability), academic (based on academic achievement), need_based (based on financial need), merit_based (based on non-athletic merit), or combined (multiple criteria).' ;
    rdfs:domain ind:AthleticScholarship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appealFiledFlag rdf:type rdf:Property ;
    rdfs:label 'Appeal Filed Flag' ;
    rdfs:comment 'Indicates whether the student-athlete has filed an appeal regarding scholarship reduction or cancellation (true) or no appeal has been filed (false).' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:awardApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Award Approval Date' ;
    rdfs:comment 'Date when the scholarship award was officially approved by the authorized staff member or committee.' ;
    rdfs:domain ind:AthleticScholarship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:awardEndDate rdf:type rdf:Property ;
    rdfs:label 'Award End Date' ;
    rdfs:comment 'Date when the scholarship award period ends. May be null for multi-year awards pending annual renewal.' ;
    rdfs:domain ind:AthleticScholarship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:awardStartDate rdf:type rdf:Property ;
    rdfs:label 'Award Start Date' ;
    rdfs:comment 'Date when the scholarship award period begins and financial aid becomes effective.' ;
    rdfs:domain ind:AthleticScholarship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cancellationFlag rdf:type rdf:Property ;
    rdfs:label 'Cancellation Flag' ;
    rdfs:comment 'Indicates whether the scholarship has been cancelled before the end of the award period (true) or remains in effect (false).' ;
    rdfs:domain ind:AthleticScholarship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:complianceVerifiedDate rdf:type rdf:Property ;
    rdfs:label 'Compliance Verified Date' ;
    rdfs:comment 'Date when the compliance office completed verification of the scholarship award. Null if verification is pending.' ;
    rdfs:domain ind:AthleticScholarship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:complianceVerifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Compliance Verified Flag' ;
    rdfs:comment 'Indicates whether the scholarship has been verified by the compliance office to meet all NCAA/NAIA regulations and institutional policies (true) or verification is pending (false).' ;
    rdfs:domain ind:AthleticScholarship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:counterExemptionReason rdf:type rdf:Property ;
    rdfs:label 'Counter Exemption Reason' ;
    rdfs:comment 'Explanation for why the scholarship is exempt from counting toward team limits (e.g., medical hardship waiver, academic honor award, need-based aid). Null if scholarship counts as a counter.' ;
    rdfs:domain ind:AthleticScholarship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:counterFlag rdf:type rdf:Property ;
    rdfs:label 'Counter Flag' ;
    rdfs:comment 'Indicates whether this scholarship counts toward the team\'s NCAA/NAIA equivalency or head count limit (true) or is exempt from counting (false).' ;
    rdfs:domain ind:AthleticScholarship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:equivalencyValue rdf:type rdf:Property ;
    rdfs:label 'Equivalency Value' ;
    rdfs:comment 'Numeric value representing the scholarship as a fraction of a full equivalency (e.g., 0.5000 for half scholarship, 1.0000 for full). Used for NCAA/NAIA equivalency limit calculations.' ;
    rdfs:domain ind:AthleticScholarship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fundSource rdf:type rdf:Property ;
    rdfs:label 'Fund Source' ;
    rdfs:comment 'Source of funding for the scholarship (e.g., athletic department budget, endowment, donor-funded, institutional aid, conference grant).' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:multiYearAwardFlag rdf:type rdf:Property ;
    rdfs:label 'Multi Year Award Flag' ;
    rdfs:comment 'Indicates whether the scholarship is a multi-year award guaranteed beyond a single academic year (true) or a one-year renewable award (false).' ;
    rdfs:domain ind:AthleticScholarship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:multiYearDurationYears rdf:type rdf:Property ;
    rdfs:label 'Multi Year Duration Years' ;
    rdfs:comment 'Number of years for which a multi-year scholarship is guaranteed. Null for one-year renewable awards.' ;
    rdfs:domain ind:AthleticScholarship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nliReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Nli Reference Number' ;
    rdfs:comment 'Reference number for the National Letter of Intent signed by the student-athlete committing to the institution. Null if no NLI was signed.' ;
    rdfs:domain ind:AthleticScholarship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reductionAmount rdf:type rdf:Property ;
    rdfs:label 'Reduction Amount' ;
    rdfs:comment 'Dollar amount by which the scholarship was reduced. Null if no reduction has occurred.' ;
    rdfs:domain ind:AthleticScholarship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reductionDate rdf:type rdf:Property ;
    rdfs:label 'Reduction Date' ;
    rdfs:comment 'Date when the scholarship reduction became effective. Null if no reduction has occurred.' ;
    rdfs:domain ind:AthleticScholarship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reductionFlag rdf:type rdf:Property ;
    rdfs:label 'Reduction Flag' ;
    rdfs:comment 'Indicates whether the scholarship award amount has been reduced during the award period (true) or remains at the original amount (false).' ;
    rdfs:domain ind:AthleticScholarship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reductionReason rdf:type rdf:Property ;
    rdfs:label 'Reduction Reason' ;
    rdfs:comment 'Detailed explanation for why the scholarship was reduced, including reference to applicable NCAA bylaws or institutional policies. Null if no reduction has occurred.' ;
    rdfs:domain ind:AthleticScholarship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalStatus rdf:type rdf:Property ;
    rdfs:label 'Renewal Status' ;
    rdfs:comment 'Status of scholarship renewal for the subsequent academic year: renewed (approved for continuation), not_renewed (not extended), pending_review (under evaluation), or ineligible (student-athlete does not meet renewal criteria).' ;
    rdfs:domain ind:AthleticScholarship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:boosterId rdf:type rdf:Property ;
    rdfs:label 'Booster Id' ;
    rdfs:comment 'Unique identifier for the booster record. Primary key for the booster entity.' ;
    rdfs:domain ind:Booster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:thirdPartyContractId rdf:type rdf:Property ;
    rdfs:label 'Third Party Contract Id' ;
    rdfs:comment 'Foreign key linking to billing.third_party_contract. Business justification: Boosters/donors establish third-party payment contracts for student-athletes (corporate sponsors, booster clubs paying tuition). Business tracks booster-funded scholarships through third-party billing' ;
    rdfs:domain ind:Education ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ThirdPartyContract .

ind:trainingProgramId rdf:type rdf:Property ;
    rdfs:label 'Training Program Id' ;
    rdfs:comment 'Foreign key linking to compliance.training_program. Business justification: Boosters required to complete compliance briefings on NCAA rules (recruiting restrictions, impermissible benefits, representative of athletics interests designation). Real business process: compliance' ;
    rdfs:domain ind:Education ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TrainingProgram .

ind:addressLine1 rdf:type rdf:Property ;
    rdfs:label 'Address Line1' ;
    rdfs:comment 'First line of the booster\'s mailing address (street address).' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressLine2 rdf:type rdf:Property ;
    rdfs:label 'Address Line2' ;
    rdfs:comment 'Second line of the booster\'s mailing address (suite, apartment, building).' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alumniFlag rdf:type rdf:Property ;
    rdfs:label 'Alumni Flag' ;
    rdfs:comment 'Indicates whether the booster is an alumnus/alumna of the institution.' ;
    rdfs:domain ind:Booster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:boosterStatus rdf:type rdf:Property ;
    rdfs:label 'Booster Status' ;
    rdfs:comment 'Current status of the booster relationship: active (currently engaged), inactive (no recent activity), suspended (compliance hold), deceased (individual only), or restricted (prohibited from certain activities).' ;
    rdfs:domain ind:Booster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:boosterType rdf:type rdf:Property ;
    rdfs:label 'Booster Type' ;
    rdfs:comment 'Classification of the booster entity type: individual person, corporate entity, foundation, organization, alumni association, or booster club.' ;
    rdfs:domain ind:Booster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:classificationDate rdf:type rdf:Property ;
    rdfs:label 'Classification Date' ;
    rdfs:comment 'Date when the individual or organization was officially classified as a booster under NCAA/NAIA definitions.' ;
    rdfs:domain ind:Booster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:clubMemberFlag rdf:type rdf:Property ;
    rdfs:label 'Club Member Flag' ;
    rdfs:comment 'Indicates whether the booster is a member of an official athletics booster club or support organization.' ;
    rdfs:domain ind:Booster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:complianceBriefingCompleted rdf:type rdf:Property ;
    rdfs:label 'Compliance Briefing Completed' ;
    rdfs:comment 'Indicates whether the booster has successfully completed the required NCAA/NAIA compliance education and briefing.' ;
    rdfs:domain ind:Booster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:complianceBriefingDate rdf:type rdf:Property ;
    rdfs:label 'Compliance Briefing Date' ;
    rdfs:comment 'Date when the booster completed the most recent NCAA/NAIA compliance education and briefing.' ;
    rdfs:domain ind:Booster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:complianceBriefingRequired rdf:type rdf:Property ;
    rdfs:label 'Compliance Briefing Required' ;
    rdfs:comment 'Indicates whether the booster is required to complete NCAA/NAIA compliance education and briefing based on their level of involvement.' ;
    rdfs:domain ind:Booster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:complianceIncidentCount rdf:type rdf:Property ;
    rdfs:label 'Compliance Incident Count' ;
    rdfs:comment 'Total number of compliance incidents or violations associated with this booster.' ;
    rdfs:domain ind:Booster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:complianceIncidentFlag rdf:type rdf:Property ;
    rdfs:label 'Compliance Incident Flag' ;
    rdfs:comment 'Indicates whether the booster has been associated with any NCAA/NAIA compliance incidents or violations.' ;
    rdfs:domain ind:Booster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:complianceRestrictionDetails rdf:type rdf:Property ;
    rdfs:label 'Compliance Restriction Details' ;
    rdfs:comment 'Description of any compliance-related restrictions currently imposed on the booster, including scope and duration.' ;
    rdfs:domain ind:Booster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceRestrictionFlag rdf:type rdf:Property ;
    rdfs:label 'Compliance Restriction Flag' ;
    rdfs:comment 'Indicates whether the booster is currently subject to any compliance-related restrictions on their involvement with the athletics program.' ;
    rdfs:domain ind:Booster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:corporateSponsorFlag rdf:type rdf:Property ;
    rdfs:label 'Corporate Sponsor Flag' ;
    rdfs:comment 'Indicates whether the booster (typically corporate or foundation type) has entered into sponsorship agreements with the athletics program.' ;
    rdfs:domain ind:Booster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:donorFlag rdf:type rdf:Property ;
    rdfs:label 'Donor Flag' ;
    rdfs:comment 'Indicates whether the booster has made financial contributions to the athletics program or related entities.' ;
    rdfs:domain ind:Booster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:formerStudentAthleteFlag rdf:type rdf:Property ;
    rdfs:label 'Former Student Athlete Flag' ;
    rdfs:comment 'Indicates whether the booster was a former student-athlete at the institution.' ;
    rdfs:domain ind:Booster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:individualFirstName rdf:type rdf:Property ;
    rdfs:label 'Individual First Name' ;
    rdfs:comment 'First name of the booster if booster_type is individual. Null for corporate/foundation boosters.' ;
    rdfs:domain ind:Booster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:individualLastName rdf:type rdf:Property ;
    rdfs:label 'Individual Last Name' ;
    rdfs:comment 'Last name of the booster if booster_type is individual. Null for corporate/foundation boosters.' ;
    rdfs:domain ind:Booster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:individualMiddleName rdf:type rdf:Property ;
    rdfs:label 'Individual Middle Name' ;
    rdfs:comment 'Middle name or initial of the booster if booster_type is individual. Null for corporate/foundation boosters.' ;
    rdfs:domain ind:Booster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:involvementType rdf:type rdf:Property ;
    rdfs:label 'Involvement Type' ;
    rdfs:comment 'Primary type of booster involvement with the athletics program: donor (financial contributor), volunteer (time/service), ticket holder (season ticket purchaser), sponsor (corporate sponsorship), board member (booster club leadership), or multiple (combination of types).' ;
    rdfs:domain ind:Booster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastComplianceIncidentDate rdf:type rdf:Property ;
    rdfs:label 'Last Compliance Incident Date' ;
    rdfs:comment 'Date of the most recent compliance incident or violation associated with this booster.' ;
    rdfs:domain ind:Booster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastContributionAmount rdf:type rdf:Property ;
    rdfs:label 'Last Contribution Amount' ;
    rdfs:comment 'Dollar amount of the most recent financial contribution made by the booster.' ;
    rdfs:domain ind:Booster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastContributionDate rdf:type rdf:Property ;
    rdfs:label 'Last Contribution Date' ;
    rdfs:comment 'Date of the most recent financial contribution made by the booster.' ;
    rdfs:domain ind:Booster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextComplianceBriefingDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Compliance Briefing Due Date' ;
    rdfs:comment 'Date by which the booster must complete their next compliance education and briefing to maintain active status.' ;
    rdfs:domain ind:Booster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:organizationName rdf:type rdf:Property ;
    rdfs:label 'Organization Name' ;
    rdfs:comment 'Legal name of the organization, corporation, foundation, or booster club if booster_type is not individual. Null for individual boosters.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postalCode rdf:type rdf:Property ;
    rdfs:label 'Postal Code' ;
    rdfs:comment 'Postal or ZIP code of the booster\'s mailing address.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seasonTicketHolderFlag rdf:type rdf:Property ;
    rdfs:label 'Season Ticket Holder Flag' ;
    rdfs:comment 'Indicates whether the booster currently holds or has held season tickets for athletics events.' ;
    rdfs:domain ind:Booster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:secondarySportCodes rdf:type rdf:Property ;
    rdfs:label 'Secondary Sport Codes' ;
    rdfs:comment 'Comma-separated list of additional sport codes the booster supports or is involved with beyond the primary sport.' ;
    rdfs:domain ind:Booster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalLifetimeContributions rdf:type rdf:Property ;
    rdfs:label 'Total Lifetime Contributions' ;
    rdfs:comment 'Cumulative total dollar amount of all financial contributions made by the booster to the athletics program since classification date. Summary field for reporting purposes.' ;
    rdfs:domain ind:Booster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volunteerFlag rdf:type rdf:Property ;
    rdfs:label 'Volunteer Flag' ;
    rdfs:comment 'Indicates whether the booster has volunteered time or services to the athletics program.' ;
    rdfs:domain ind:Booster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:coachId rdf:type rdf:Property ;
    rdfs:label 'Coach Id' ;
    rdfs:comment 'Unique identifier for the coaching staff member. Primary key for the coach entity.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Coach .

ind:patronId rdf:type rdf:Property ;
    rdfs:label 'Patron Id' ;
    rdfs:comment 'Foreign key linking to library.patron. Business justification: Coaches use library services for professional development, recruiting research, and academic support activities. Tracking coach library usage enables targeted outreach, collection development for coac' ;
    rdfs:domain ind:Education ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Patron .

ind:salaryCostCenterId rdf:type rdf:Property ;
    rdfs:label 'Salary Cost Center Id' ;
    rdfs:comment 'Foreign key linking to finance.cost_center. Business justification: Coach salaries and benefits are charged to specific athletic department cost centers for budget tracking and financial reporting. Essential for payroll accounting, budget management, and EADA reportin' ;
    rdfs:domain ind:Education ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostCenter .

ind:staffEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Staff Employee Id' ;
    rdfs:comment 'Reference to the staff member record in the human resources system. Links coaching staff to their broader institutional employment record.' ;
    rdfs:domain ind:Coach ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:almaMater rdf:type rdf:Property ;
    rdfs:label 'Alma Mater' ;
    rdfs:comment 'Name of the institution from which the coaching staff member earned their undergraduate degree. Used for media guides and biographical materials.' ;
    rdfs:domain ind:Coach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bioUrl rdf:type rdf:Property ;
    rdfs:label 'Bio Url' ;
    rdfs:comment 'Web address of the coaching staff member\'s official biography page on the athletics department website. Used for public information and media relations.' ;
    rdfs:domain ind:Coach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caraSupervisionAuthorized rdf:type rdf:Property ;
    rdfs:label 'Cara Supervision Authorized' ;
    rdfs:comment 'Indicates whether the coach is authorized to supervise countable athletically related activities under NCAA time management rules. Only certain staff roles are permitted to supervise CARA.' ;
    rdfs:domain ind:Coach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:coachingRole rdf:type rdf:Property ;
    rdfs:label 'Coaching Role' ;
    rdfs:comment 'Functional coaching role classification. Determines NCAA/NAIA countable coach status, recruiting authorization, and compensation structure. [ENUM-REF-CANDIDATE: head_coach|assistant_coach|associate_head_coach|graduate_assistant|volunteer_coach|strength_coach|athletic_trainer|director_of_operations — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Coach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coachingSpecialization rdf:type rdf:Property ;
    rdfs:label 'Coaching Specialization' ;
    rdfs:comment 'Specific area of coaching expertise or position group responsibility. Examples include offensive coordinator, defensive backs coach, pitching coach, recruiting coordinator.' ;
    rdfs:domain ind:Coach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceTrainingCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Compliance Training Completion Date' ;
    rdfs:comment 'Date the coaching staff member completed the most recent NCAA compliance training. Training must be completed annually before the start of the recruiting period.' ;
    rdfs:domain ind:Coach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:complianceTrainingStatus rdf:type rdf:Property ;
    rdfs:label 'Compliance Training Status' ;
    rdfs:comment 'Status of mandatory NCAA compliance training completion. All coaching staff must complete annual compliance training covering recruiting rules, eligibility, and amateurism.' ;
    rdfs:domain ind:Coach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countableCoachFlag rdf:type rdf:Property ;
    rdfs:label 'Countable Coach Flag' ;
    rdfs:comment 'Indicates whether this coaching staff member counts against the NCAA limit for countable coaches in their sport. Countable coaches have specific recruiting and on-field coaching privileges.' ;
    rdfs:domain ind:Coach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:emailAddress rdf:type rdf:Property ;
    rdfs:label 'Email Address' ;
    rdfs:comment 'Primary institutional email address for the coaching staff member. Used for official communications, recruiting correspondence, and compliance notifications.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:firstName rdf:type rdf:Property ;
    rdfs:label 'First Name' ;
    rdfs:comment 'Legal first name of the coaching staff member as recorded in human resources records.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hireDate rdf:type rdf:Property ;
    rdfs:label 'Hire Date' ;
    rdfs:comment 'Original date the coaching staff member was first hired by the athletics department, regardless of role changes or contract renewals.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastName rdf:type rdf:Property ;
    rdfs:label 'Last Name' ;
    rdfs:comment 'Legal last name of the coaching staff member as recorded in human resources records.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:middleName rdf:type rdf:Property ;
    rdfs:label 'Middle Name' ;
    rdfs:comment 'Legal middle name or initial of the coaching staff member.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:officeLocation rdf:type rdf:Property ;
    rdfs:label 'Office Location' ;
    rdfs:comment 'Physical office location or building assignment for the coaching staff member within the athletics facilities.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phoneNumber rdf:type rdf:Property ;
    rdfs:label 'Phone Number' ;
    rdfs:comment 'Primary contact phone number for the coaching staff member. Used for recruiting, team communications, and emergency contact.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:photoUrl rdf:type rdf:Property ;
    rdfs:label 'Photo Url' ;
    rdfs:comment 'Web address of the coaching staff member\'s official headshot or action photo. Used for media guides, website, and promotional materials.' ;
    rdfs:domain ind:Coach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recruitingAuthorizationLevel rdf:type rdf:Property ;
    rdfs:label 'Recruiting Authorization Level' ;
    rdfs:comment 'Level of recruiting activity authorization. Full authorization allows on-campus and off-campus recruiting; limited restricts to on-campus only; none prohibits recruiting contact.' ;
    rdfs:domain ind:Coach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safesportTrainingCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Safesport Training Completion Date' ;
    rdfs:comment 'Date the coaching staff member completed the most recent SafeSport training module. Training must be renewed annually.' ;
    rdfs:domain ind:Coach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:safesportTrainingStatus rdf:type rdf:Property ;
    rdfs:label 'Safesport Training Status' ;
    rdfs:comment 'Status of NCAA SafeSport training completion. All coaching staff with student-athlete contact must complete SafeSport training annually.' ;
    rdfs:domain ind:Coach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:secondarySportCode rdf:type rdf:Property ;
    rdfs:label 'Secondary Sport Code' ;
    rdfs:comment 'Standardized code for a secondary sport assignment, applicable when a coach serves multiple programs (common in smaller institutions or multi-season sports).' ;
    rdfs:domain ind:Athletics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:yearsOfExperience rdf:type rdf:Property ;
    rdfs:label 'Years Of Experience' ;
    rdfs:comment 'Total years of coaching experience across all institutions and levels. Used for media guides, recruiting materials, and compensation benchmarking.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:complianceWaiverId rdf:type rdf:Property ;
    rdfs:label 'Compliance Waiver Id' ;
    rdfs:comment 'Unique identifier for the compliance waiver request. Primary key for the compliance waiver record.' ;
    rdfs:domain ind:ComplianceWaiver ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:complianceObligationId rdf:type rdf:Property ;
    rdfs:label 'Compliance Obligation Id' ;
    rdfs:comment 'Foreign key linking to compliance.obligation. Business justification: Athletic compliance waivers (eligibility waivers, medical hardship waivers) relate to specific institutional compliance obligations (NCAA rules, conference rules). This FK links athletics.compliance_w' ;
    rdfs:domain ind:Education ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Obligation .

ind:appealSubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Appeal Submission Date' ;
    rdfs:comment 'Date on which an appeal was submitted following a waiver denial. Null if no appeal has been filed.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:athleticDirectorApprovalFlag rdf:type rdf:Property ;
    rdfs:label 'Athletic Director Approval Flag' ;
    rdfs:comment 'Boolean flag indicating whether the athletic director approved the waiver submission (true) or not (false). Typically required for institutional waiver submissions.' ;
    rdfs:domain ind:ComplianceWaiver ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:complianceOfficerName rdf:type rdf:Property ;
    rdfs:label 'Compliance Officer Name' ;
    rdfs:comment 'Full name of the institutional compliance officer or staff member responsible for the waiver request.' ;
    rdfs:domain ind:ComplianceWaiver ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conferenceCode rdf:type rdf:Property ;
    rdfs:label 'Conference Code' ;
    rdfs:comment 'Code representing the athletic conference if the waiver is submitted to a conference governing body.' ;
    rdfs:domain ind:Athletics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decisionOutcome rdf:type rdf:Property ;
    rdfs:label 'Decision Outcome' ;
    rdfs:comment 'Final outcome of the waiver decision: approved (fully granted), denied (rejected), partially_approved (some relief granted), conditional_approval (approved with conditions).' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decisionRationale rdf:type rdf:Property ;
    rdfs:label 'Decision Rationale' ;
    rdfs:comment 'Detailed explanation provided by the governing body for the waiver decision, including reasoning for approval or denial and any conditions imposed.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eligibilityImpact rdf:type rdf:Property ;
    rdfs:label 'Eligibility Impact' ;
    rdfs:comment 'Description of how the waiver decision impacts the student-athlete\'s eligibility, including changes to eligibility clock, seasons of competition, or scholarship status.' ;
    rdfs:domain ind:ComplianceWaiver ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eligibilityYearAdjustment rdf:type rdf:Property ;
    rdfs:label 'Eligibility Year Adjustment' ;
    rdfs:comment 'Adjustment to the student-athlete\'s eligibility year count as a result of the waiver (positive for restored years, negative for forfeited years). Null if not applicable.' ;
    rdfs:domain ind:ComplianceWaiver ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:expectedDecisionDate rdf:type rdf:Property ;
    rdfs:label 'Expected Decision Date' ;
    rdfs:comment 'Anticipated date by which a decision is expected from the governing body, based on standard processing timelines or expedited review schedules.' ;
    rdfs:domain ind:ComplianceWaiver ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:governingBody rdf:type rdf:Property ;
    rdfs:label 'Governing Body' ;
    rdfs:comment 'The governing body to which the waiver is submitted: NCAA (National Collegiate Athletic Association), NAIA (National Association of Intercollegiate Athletics), NJCAA (National Junior College Athletic Association), or conference-level governing body.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:governingBodyDivision rdf:type rdf:Property ;
    rdfs:label 'Governing Body Division' ;
    rdfs:comment 'Division level within the governing body (e.g., Division I, Division II, Division III for NCAA).' ;
    rdfs:domain ind:ComplianceWaiver ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headCoachEndorsementFlag rdf:type rdf:Property ;
    rdfs:label 'Head Coach Endorsement Flag' ;
    rdfs:comment 'Boolean flag indicating whether the head coach of the sport endorsed or supported the waiver request (true) or not (false).' ;
    rdfs:domain ind:ComplianceWaiver ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:immediateEligibilityGranted rdf:type rdf:Property ;
    rdfs:label 'Immediate Eligibility Granted' ;
    rdfs:comment 'Boolean flag indicating whether the waiver granted immediate eligibility for competition (true) or if a waiting period applies (false). Applicable primarily to transfer waivers.' ;
    rdfs:domain ind:ComplianceWaiver ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:institutionalPosition rdf:type rdf:Property ;
    rdfs:label 'Institutional Position' ;
    rdfs:comment 'The institution\'s official position or recommendation regarding the waiver request, as submitted to the governing body.' ;
    rdfs:domain ind:ComplianceWaiver ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seasonsRestored rdf:type rdf:Property ;
    rdfs:label 'Seasons Restored' ;
    rdfs:comment 'Number of seasons of competition restored to the student-athlete as a result of the waiver approval. Null if waiver was denied or not applicable.' ;
    rdfs:domain ind:ComplianceWaiver ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:supportingDocumentationFlag rdf:type rdf:Property ;
    rdfs:label 'Supporting Documentation Flag' ;
    rdfs:comment 'Boolean flag indicating whether supporting documentation (medical records, transcripts, affidavits, etc.) was submitted with the waiver request (true) or not (false).' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:waiverNotes rdf:type rdf:Property ;
    rdfs:label 'Waiver Notes' ;
    rdfs:comment 'Additional notes, comments, or internal documentation related to the waiver request, including follow-up actions, communications with the governing body, or special considerations.' ;
    rdfs:domain ind:ComplianceWaiver ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waiverNumber rdf:type rdf:Property ;
    rdfs:label 'Waiver Number' ;
    rdfs:comment 'Externally-known business identifier for the waiver request, often assigned by the governing body or institution compliance office.' ;
    rdfs:domain ind:ComplianceWaiver ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waiverRequestSummary rdf:type rdf:Property ;
    rdfs:label 'Waiver Request Summary' ;
    rdfs:comment 'Brief summary of the waiver request, including the circumstances and justification for the waiver as presented to the governing body.' ;
    rdfs:domain ind:ComplianceWaiver ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waiverStatus rdf:type rdf:Property ;
    rdfs:label 'Waiver Status' ;
    rdfs:comment 'Current lifecycle status of the waiver request: draft (being prepared), submitted (sent to governing body), pending (awaiting initial review), under_review (actively being evaluated), approved (granted), denied (rejected), appealed (denial appealed), withdrawn (request withdrawn by institution). [ENUM-REF-CANDIDATE: draft|submitted|pending|under_review|approved|denied|appealed|withdrawn — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waiverType rdf:type rdf:Property ;
    rdfs:label 'Waiver Type' ;
    rdfs:comment 'Classification of the waiver request type: eligibility (general eligibility exception), hardship (personal/family hardship), transfer (transfer eligibility exception), medical (medical hardship/injury), recruiting (recruiting violation waiver), amateurism (amateur status restoration).' ;
    rdfs:domain ind:ComplianceWaiver ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drugTestId rdf:type rdf:Property ;
    rdfs:label 'Drug Test Id' ;
    rdfs:comment 'Unique identifier for the drug test record. Primary key for the drug test entity.' ;
    rdfs:domain ind:DrugTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryDrugEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Drug Employee Id' ;
    rdfs:comment 'Reference to the institutional staff member (typically compliance officer or athletic director) who notified the student-athlete of the test result.' ;
    rdfs:domain ind:DrugTest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:researchIrbProtocolId rdf:type rdf:Property ;
    rdfs:label 'Research Irb Protocol Id' ;
    rdfs:comment 'Foreign key linking to research.irb_protocol. Business justification: Links drug testing data used in IRB-approved research (epidemiological studies, substance use patterns, testing efficacy research). Required for research compliance when de-identified testing data is ' ;
    rdfs:domain ind:Education ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IrbProtocol .

ind:appealFiledDate rdf:type rdf:Property ;
    rdfs:label 'Appeal Filed Date' ;
    rdfs:comment 'The date on which the student-athlete submitted a formal appeal of the test result or sanction. Null if no appeal was filed.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:bSampleRequestedFlag rdf:type rdf:Property ;
    rdfs:label 'B Sample Requested Flag' ;
    rdfs:comment 'Indicates whether the student-athlete requested analysis of the B sample (confirmatory sample) following a positive A sample result, as permitted under NCAA and WADA protocols.' ;
    rdfs:domain ind:DrugTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:bSampleResult rdf:type rdf:Property ;
    rdfs:label 'B Sample Result' ;
    rdfs:comment 'The outcome of the B sample analysis: confirmed (positive result verified), not confirmed (positive result not verified), not requested (athlete did not request B sample analysis), or pending (analysis in progress).' ;
    rdfs:domain ind:DrugTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chainOfCustodyNumber rdf:type rdf:Property ;
    rdfs:label 'Chain Of Custody Number' ;
    rdfs:comment 'Unique tracking number documenting the handling and transfer of the specimen from collection through analysis and storage.' ;
    rdfs:domain ind:DrugTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectionSiteCode rdf:type rdf:Property ;
    rdfs:label 'Collection Site Code' ;
    rdfs:comment 'Standardized code identifying the collection site or facility where the sample was obtained.' ;
    rdfs:domain ind:DrugTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:concentrationLevel rdf:type rdf:Property ;
    rdfs:label 'Concentration Level' ;
    rdfs:comment 'The measured concentration or quantity of the detected substance in the specimen, typically expressed in ng/mL or other laboratory units. Applicable for positive results.' ;
    rdfs:domain ind:DrugTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gamesMissed rdf:type rdf:Property ;
    rdfs:label 'Games Missed' ;
    rdfs:comment 'The number of contests or competitions the student-athlete was ineligible to participate in due to the drug test sanction.' ;
    rdfs:domain ind:DrugTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:laboratoryAccreditationNumber rdf:type rdf:Property ;
    rdfs:label 'Laboratory Accreditation Number' ;
    rdfs:comment 'Accreditation identifier for the testing laboratory, confirming compliance with WADA or NCAA standards.' ;
    rdfs:domain ind:DrugTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationDate rdf:type rdf:Property ;
    rdfs:label 'Notification Date' ;
    rdfs:comment 'The date on which the student-athlete was officially notified of a positive test result or other adverse finding.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:positiveSubstanceName rdf:type rdf:Property ;
    rdfs:label 'Positive Substance Name' ;
    rdfs:comment 'The specific banned substance or metabolite detected in a positive test result. Null if test result is negative.' ;
    rdfs:domain ind:DrugTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resultReportedDate rdf:type rdf:Property ;
    rdfs:label 'Result Reported Date' ;
    rdfs:comment 'The date on which the laboratory reported the test results to the institution or governing body.' ;
    rdfs:domain ind:DrugTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sanctionImposed rdf:type rdf:Property ;
    rdfs:label 'Sanction Imposed' ;
    rdfs:comment 'Description of the penalty or sanction imposed on the student-athlete as a result of a positive test (e.g., suspension from competition, loss of eligibility, mandatory counseling, withholding of financial aid). Null if no sanction was imposed.' ;
    rdfs:domain ind:DrugTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specimenCode rdf:type rdf:Property ;
    rdfs:label 'Specimen Code' ;
    rdfs:comment 'Unique identifier assigned to the biological specimen for chain of custody tracking and laboratory processing.' ;
    rdfs:domain ind:DrugTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specimenType rdf:type rdf:Property ;
    rdfs:label 'Specimen Type' ;
    rdfs:comment 'The type of biological specimen collected for testing (urine, blood, saliva, or hair).' ;
    rdfs:domain ind:DrugTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:substanceClass rdf:type rdf:Property ;
    rdfs:label 'Substance Class' ;
    rdfs:comment 'The category or class of the detected substance (e.g., stimulant, anabolic agent, cannabinoid, narcotic, diuretic, masking agent). Applicable for positive results.' ;
    rdfs:domain ind:DrugTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:substancesTested rdf:type rdf:Property ;
    rdfs:label 'Substances Tested' ;
    rdfs:comment 'List or description of the substance classes or specific substances included in the testing panel (e.g., stimulants, anabolic agents, cannabinoids, narcotics, diuretics, masking agents).' ;
    rdfs:domain ind:DrugTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:suspensionEndDate rdf:type rdf:Property ;
    rdfs:label 'Suspension End Date' ;
    rdfs:comment 'The date on which a suspension or eligibility withholding sanction ends, allowing the student-athlete to return to competition. Applicable if a suspension was imposed.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:suspensionStartDate rdf:type rdf:Property ;
    rdfs:label 'Suspension Start Date' ;
    rdfs:comment 'The date on which a suspension or eligibility withholding sanction begins. Applicable if a suspension was imposed.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:testDate rdf:type rdf:Property ;
    rdfs:label 'Test Date' ;
    rdfs:comment 'The date on which the drug test sample was collected from the student-athlete.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:testLocation rdf:type rdf:Property ;
    rdfs:label 'Test Location' ;
    rdfs:comment 'The physical location or facility where the drug test sample was collected.' ;
    rdfs:domain ind:DrugTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testResult rdf:type rdf:Property ;
    rdfs:label 'Test Result' ;
    rdfs:comment 'The outcome of the drug test: negative (no banned substances detected), positive (banned substance detected), dilute (sample concentration too low), invalid (sample compromised), refused (athlete declined to provide sample), or pending (results not yet available).' ;
    rdfs:domain ind:DrugTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testTime rdf:type rdf:Property ;
    rdfs:label 'Test Time' ;
    rdfs:comment 'The precise timestamp when the drug test sample was collected, including time zone information.' ;
    rdfs:domain ind:DrugTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:testType rdf:type rdf:Property ;
    rdfs:label 'Test Type' ;
    rdfs:comment 'The category of drug test administered: random selection, reasonable suspicion, championship event, post-season, pre-season, or follow-up testing.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testingLaboratoryName rdf:type rdf:Property ;
    rdfs:label 'Testing Laboratory Name' ;
    rdfs:comment 'Name of the certified laboratory that performed the drug test analysis.' ;
    rdfs:domain ind:DrugTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testingProgram rdf:type rdf:Property ;
    rdfs:label 'Testing Program' ;
    rdfs:comment 'The governing body or program under which the drug test was administered (NCAA, conference, institutional, NAIA, or other).' ;
    rdfs:domain ind:DrugTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:therapeuticUseExemptionFlag rdf:type rdf:Property ;
    rdfs:label 'Therapeutic Use Exemption Flag' ;
    rdfs:comment 'Indicates whether the student-athlete has an approved Therapeutic Use Exemption for the detected substance, which may mitigate or nullify a positive result.' ;
    rdfs:domain ind:DrugTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:thresholdExceededFlag rdf:type rdf:Property ;
    rdfs:label 'Threshold Exceeded Flag' ;
    rdfs:comment 'Indicates whether the detected substance concentration exceeded the NCAA or WADA reporting threshold, triggering a positive result.' ;
    rdfs:domain ind:DrugTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tueApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Tue Approval Date' ;
    rdfs:comment 'The date on which the Therapeutic Use Exemption was approved by the NCAA or institutional medical authority. Null if no TUE applies.' ;
    rdfs:domain ind:DrugTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:eadaReportId rdf:type rdf:Property ;
    rdfs:label 'Eada Report Id' ;
    rdfs:comment 'Unique identifier for the EADA report submission record.' ;
    rdfs:domain ind:EadaReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:campusId rdf:type rdf:Property ;
    rdfs:label 'Campus Id' ;
    rdfs:comment 'Identifier for the higher education institution submitting the EADA report.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Campus .

ind:athleticsDirectorEmail rdf:type rdf:Property ;
    rdfs:label 'Athletics Director Email' ;
    rdfs:comment 'Official email address of the Director of Athletics for EADA reporting correspondence.' ;
    rdfs:domain ind:EadaReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:athleticsDirectorName rdf:type rdf:Property ;
    rdfs:label 'Athletics Director Name' ;
    rdfs:comment 'Full name of the Director of Athletics responsible for the athletics program during the reporting year.' ;
    rdfs:domain ind:EadaReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:athleticsDirectorPhone rdf:type rdf:Property ;
    rdfs:label 'Athletics Director Phone' ;
    rdfs:comment 'Official phone number of the Director of Athletics for EADA reporting correspondence.' ;
    rdfs:domain ind:EadaReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certifiedByName rdf:type rdf:Property ;
    rdfs:label 'Certified By Name' ;
    rdfs:comment 'Full name of the institutional official who certified the EADA report (typically the president or chancellor).' ;
    rdfs:domain ind:EadaReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certifiedByTitle rdf:type rdf:Property ;
    rdfs:label 'Certified By Title' ;
    rdfs:comment 'Official title of the person who certified the EADA report.' ;
    rdfs:domain ind:EadaReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coeducationalAthleticallyRelatedStudentAid rdf:type rdf:Property ;
