ind:coeducationalOperatingExpenses rdf:type rdf:Property ;
    rdfs:label 'Coeducational Operating Expenses' ;
    rdfs:comment 'Total operating expenses for coeducational teams where applicable.' ;
    rdfs:domain ind:EadaReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coeducationalParticipants rdf:type rdf:Property ;
