    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:practiceDate rdf:type rdf:Property ;
    rdfs:label 'Practice Date' ;
    rdfs:comment 'The calendar date on which the practice session occurred. Principal business event timestamp for this transaction.' ;
    rdfs:domain ind:PracticeSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:practiceEndTime rdf:type rdf:Property ;
    rdfs:label 'Practice End Time' ;
    rdfs:comment 'The timestamp when the practice session concluded, used for precise CARA hour calculation.' ;
    rdfs:domain ind:PracticeSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:practiceFocus rdf:type rdf:Property ;
    rdfs:label 'Practice Focus' ;
    rdfs:comment 'Primary focus or objective of the practice session (e.g., offensive drills, defensive strategy, conditioning, scrimmage).' ;
    rdfs:domain ind:PracticeSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:practiceIntensityLevel rdf:type rdf:Property ;
    rdfs:label 'Practice Intensity Level' ;
    rdfs:comment 'Subjective assessment of the overall intensity level of the practice session.' ;
