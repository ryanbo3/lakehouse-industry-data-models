    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bookValueAmount rdf:type rdf:Property ;
    rdfs:label 'Book Value Amount' ;
    rdfs:comment 'Historical cost basis or book value of assets in the investment pool.' ;
    rdfs:domain ind:InvestmentPool ;
    rdf:type owl:DatatypeProperty ;
