ind:degreeEarned rdf:type rdf:Property ;
    rdfs:label 'Degree Earned' ;
    rdfs:comment 'The primary degree or credential earned by the constituent (e.g., BA, BS, MBA, PhD).' ;
    rdfs:domain ind:Constituent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:industry rdf:type rdf:Property ;
    rdfs:label 'Industry' ;
    rdfs:comment 'The industry sector in which the constituent is employed.' ;
    rdfs:domain ind:Constituent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prefix rdf:type rdf:Property ;
    rdfs:label 'Prefix' ;
    rdfs:comment 'Honorific or title prefix for the constituent (e.g., Dr., Mr., Ms., Prof.).' ;
    rdfs:domain ind:Constituent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryCountry rdf:type rdf:Property ;
    rdfs:label 'Primary Country' ;
    rdfs:comment 'Three-letter ISO country code for the constituent\'s primary address (e.g., USA, CAN, GBR).' ;
    rdfs:domain ind:Constituent ;
