    rdfs:comment 'Indicates whether the student\'s official transcript has been updated to reflect the grade change resulting from a successful appeal.' ;
    rdfs:domain ind:GradeAppealCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

