ind:mensOperatingExpenses rdf:type rdf:Property ;
    rdfs:label 'Mens Operating Expenses' ;
    rdfs:comment 'Total operating expenses for mens teams including travel, equipment, uniforms, and game expenses.' ;
    rdfs:domain ind:EadaReport ;
    rdf:type owl:DatatypeProperty ;
