    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:practiceNotes rdf:type rdf:Property ;
    rdfs:label 'Practice Notes' ;
    rdfs:comment 'Free-text notes about the practice session, including coaching observations, special circumstances, or compliance annotations.' ;
    rdfs:domain ind:PracticeSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:practiceSessionNumber rdf:type rdf:Property ;
    rdfs:label 'Practice Session Number' ;
    rdfs:comment 'Business identifier for the practice session, typically formatted as season-team-sequence (e.g., 2024-FB-001).' ;
    rdfs:domain ind:PracticeSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:practiceStartTime rdf:type rdf:Property ;
    rdfs:label 'Practice Start Time' ;
    rdfs:comment 'The timestamp when the practice session began, used for precise CARA hour calculation.' ;
    rdfs:domain ind:PracticeSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:practiceStatus rdf:type rdf:Property ;
    rdfs:label 'Practice Status' ;
    rdfs:comment 'Current lifecycle status of the practice session.' ;
    rdfs:domain ind:PracticeSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:practiceType rdf:type rdf:Property ;
    rdfs:label 'Practice Type' ;
    rdfs:comment 'Classification of the practice activity type. Determines whether the session counts toward NCAA CARA hour limits.' ;
    rdfs:domain ind:PracticeSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scrimmageFlag rdf:type rdf:Property ;
