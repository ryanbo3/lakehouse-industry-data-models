    rdfs:comment 'Total recruiting expenses for coeducational teams where applicable.' ;
    rdfs:domain ind:EadaReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coeducationalRevenues rdf:type rdf:Property ;
