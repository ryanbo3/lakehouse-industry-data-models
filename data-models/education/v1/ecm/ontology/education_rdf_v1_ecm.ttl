    rdfs:comment 'Boolean flag indicating whether Return to Title IV calculations are enabled and required for withdrawals in this award year.' ;
    rdfs:domain ind:AwardYear ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sapEvaluationRequired rdf:type rdf:Property ;
    rdfs:label 'Sap Evaluation Required' ;
    rdfs:comment 'Boolean flag indicating whether Satisfactory Academic Progress evaluation is required for students receiving aid in this award year.' ;
    rdfs:domain ind:AwardYear ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:verificationDeadlineDate rdf:type rdf:Property ;
