ind:marketValueAmount rdf:type rdf:Property ;
    rdfs:label 'Market Value Amount' ;
    rdfs:comment 'Current total market value of all assets held in the investment pool.' ;
    rdfs:domain ind:InvestmentPool ;
    rdf:type owl:DatatypeProperty ;
