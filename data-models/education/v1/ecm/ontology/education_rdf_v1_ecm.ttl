ind:giftLevelMinimum rdf:type rdf:Property ;
    rdfs:label 'Gift Level Minimum' ;
    rdfs:comment 'The minimum gift amount threshold that qualifies a donor for inclusion in this stewardship plan.' ;
    rdfs:domain ind:StewardshipPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:primaryContactMethod rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Method' ;
    rdfs:comment 'The preferred or primary channel for donor communication under this stewardship plan.' ;
    rdfs:domain ind:StewardshipPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorityScore rdf:type rdf:Property ;
    rdfs:label 'Priority Score' ;
    rdfs:comment 'A numeric score representing the relative priority or importance of this stewardship plan within the advancement portfolio (higher values indicate higher priority).' ;
    rdfs:domain ind:StewardshipPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reviewCycle rdf:type rdf:Property ;
    rdfs:label 'Review Cycle' ;
    rdfs:comment 'The scheduled frequency for reviewing and updating this stewardship plan to ensure continued relevance and effectiveness.' ;
    rdfs:domain ind:StewardshipPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetDonorCount rdf:type rdf:Property ;
