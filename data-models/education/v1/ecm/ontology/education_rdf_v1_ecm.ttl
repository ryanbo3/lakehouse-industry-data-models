    rdfs:range xsd:decimal .

ind:poolName rdf:type rdf:Property ;
    rdfs:label 'Pool Name' ;
    rdfs:comment 'Official name of the investment pool as recognized by the institution and investment managers.' ;
    rdfs:domain ind:InvestmentPool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:poolStatus rdf:type rdf:Property ;
    rdfs:label 'Pool Status' ;
    rdfs:comment 'Current operational status of the investment pool in its lifecycle.' ;
    rdfs:domain ind:InvestmentPool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:poolType rdf:type rdf:Property ;
    rdfs:label 'Pool Type' ;
    rdfs:comment 'Classification of the investment pool based on its purpose and restrictions.' ;
    rdfs:domain ind:InvestmentPool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rebalancingFrequency rdf:type rdf:Property ;
    rdfs:label 'Rebalancing Frequency' ;
    rdfs:comment 'Frequency at which the pool\'s asset allocation is reviewed and rebalanced to target allocations.' ;
    rdfs:domain ind:InvestmentPool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sociallyResponsibleFlag rdf:type rdf:Property ;
