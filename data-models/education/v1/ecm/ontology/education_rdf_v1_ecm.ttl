    rdfs:domain ind:EadaReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reportNotes rdf:type rdf:Property ;
    rdfs:label 'Report Notes' ;
    rdfs:comment 'Additional notes, clarifications, or contextual information about the EADA report data or submission.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportPreparerEmail rdf:type rdf:Property ;
    rdfs:label 'Report Preparer Email' ;
    rdfs:comment 'Email address of the staff member who prepared the EADA report for follow-up questions.' ;
    rdfs:domain ind:EadaReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportPreparerName rdf:type rdf:Property ;
    rdfs:label 'Report Preparer Name' ;
    rdfs:comment 'Full name of the staff member who prepared the EADA report data.' ;
    rdfs:domain ind:EadaReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportPreparerPhone rdf:type rdf:Property ;
    rdfs:label 'Report Preparer Phone' ;
    rdfs:comment 'Phone number of the staff member who prepared the EADA report for follow-up questions.' ;
    rdfs:domain ind:EadaReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingYear rdf:type rdf:Property ;
    rdfs:label 'Reporting Year' ;
    rdfs:comment 'The academic year for which athletics data is being reported in YYYY format (e.g., 2023 represents the 2022-2023 academic year).' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:submissionStatus rdf:type rdf:Property ;
    rdfs:label 'Submission Status' ;
    rdfs:comment 'Current status of the EADA report in the submission workflow to the U.S. Department of Education.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalAthleticsExpenses rdf:type rdf:Property ;
    rdfs:label 'Total Athletics Expenses' ;
    rdfs:comment 'Combined total expenses for the entire intercollegiate athletics program including both mens and womens sports.' ;
    rdfs:domain ind:EadaReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalAthleticsRevenues rdf:type rdf:Property ;
    rdfs:label 'Total Athletics Revenues' ;
    rdfs:comment 'Combined total revenues for the entire intercollegiate athletics program including both mens and womens sports.' ;
    rdfs:domain ind:EadaReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalFemaleAssistantCoaches rdf:type rdf:Property ;
    rdfs:label 'Total Female Assistant Coaches' ;
