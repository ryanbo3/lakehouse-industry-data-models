    rdfs:range xsd:string .

ind:liquidityClassification rdf:type rdf:Property ;
    rdfs:label 'Liquidity Classification' ;
    rdfs:comment 'Classification of the pool\'s overall liquidity based on the ability to convert assets to cash.' ;
