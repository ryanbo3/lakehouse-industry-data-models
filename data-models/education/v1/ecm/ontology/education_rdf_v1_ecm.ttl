    rdfs:range xsd:string .

ind:businessPhone rdf:type rdf:Property ;
    rdfs:label 'Business Phone' ;
    rdfs:comment 'Work or business telephone number for the constituent.' ;
    rdfs:domain ind:Constituent ;
