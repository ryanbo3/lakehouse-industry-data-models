    rdfs:comment 'Designation of the competitive season phase during which the practice occurred. Affects CARA hour limits and compliance rules.' ;
    rdfs:domain ind:PracticeSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureFahrenheit rdf:type rdf:Property ;
