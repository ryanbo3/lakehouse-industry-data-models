    rdfs:comment 'Total amount of athletically related student aid awarded to male student-athletes during the reporting year.' ;
    rdfs:domain ind:EadaReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mensHeadCoachSalariesTotal rdf:type rdf:Property ;
    rdfs:label 'Mens Head Coach Salaries Total' ;
    rdfs:comment 'Total salaries and bonuses paid to all head coaches of mens teams during the reporting year.' ;
    rdfs:domain ind:EadaReport ;
    rdf:type owl:DatatypeProperty ;
