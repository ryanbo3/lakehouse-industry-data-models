    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:platformStatus rdf:type rdf:Property ;
    rdfs:label 'Platform Status' ;
    rdfs:comment 'Current operational status of the platform within the library system.' ;
    rdfs:domain ind:Platform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:platformType rdf:type rdf:Property ;
    rdfs:label 'Platform Type' ;
    rdfs:comment 'Classification of the platform based on its primary function and content delivery model.' ;
    rdfs:domain ind:Platform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:platformUrl rdf:type rdf:Property ;
    rdfs:label 'Platform Url' ;
    rdfs:comment 'Primary web address for accessing the platform.' ;
    rdfs:domain ind:Platform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proxyPrefix rdf:type rdf:Property ;
    rdfs:label 'Proxy Prefix' ;
    rdfs:comment 'URL prefix added by the proxy server to enable off-campus access to platform resources.' ;
    rdfs:domain ind:Platform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subjectCoverage rdf:type rdf:Property ;
    rdfs:label 'Subject Coverage' ;
    rdfs:comment 'Broad subject areas or disciplines covered by the platform\'s content (e.g., STEM, Humanities, Social Sciences, Multidisciplinary).' ;
    rdfs:domain ind:Platform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sushiApiKey rdf:type rdf:Property ;
    rdfs:label 'Sushi Api Key' ;
    rdfs:comment 'API key or token used to authenticate SUSHI requests to the platform.' ;
    rdfs:domain ind:Platform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sushiRequestorCode rdf:type rdf:Property ;
    rdfs:label 'Sushi Requestor Code' ;
    rdfs:comment 'Requestor identifier used for SUSHI authentication, often representing the library or consortium.' ;
    rdfs:domain ind:Platform ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentPublisherId rdf:type rdf:Property ;
    rdfs:label 'Parent Publisher Id' ;
    rdfs:comment 'Reference to the parent publisher if this publisher is an imprint or subsidiary of a larger publishing house.' ;
    rdfs:domain ind:Publisher ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Publisher .

ind:copyrightPolicyUrl rdf:type rdf:Property ;
    rdfs:label 'Copyright Policy Url' ;
    rdfs:comment 'URL to the publishers copyright and permissions policy documentation.' ;
    rdfs:domain ind:Publisher ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defunctYear rdf:type rdf:Property ;
    rdfs:label 'Defunct Year' ;
    rdfs:comment 'Year the publisher ceased operations, if applicable.' ;
    rdfs:domain ind:Publisher ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:foundingYear rdf:type rdf:Property ;
    rdfs:label 'Founding Year' ;
    rdfs:comment 'Year the publisher was established or founded.' ;
    rdfs:domain ind:Publisher ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:imprint rdf:type rdf:Property ;
    rdfs:label 'Imprint' ;
    rdfs:comment 'Imprint or brand name under which the publisher releases materials. An imprint is a trade name under which a publisher or group of publishers publishes a work.' ;
    rdfs:domain ind:Publisher ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isbnPrefix rdf:type rdf:Property ;
    rdfs:label 'Isbn Prefix' ;
    rdfs:comment 'The ISBN prefix assigned to this publisher by the International ISBN Agency. Format: GS1 prefix (978 or 979) followed by registration group and registrant elements.' ;
    rdfs:domain ind:Publisher ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issnPrefix rdf:type rdf:Property ;
    rdfs:label 'Issn Prefix' ;
    rdfs:comment 'The ISSN prefix or range assigned to this publisher for serial publications.' ;
    rdfs:domain ind:Publisher ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licensingTerms rdf:type rdf:Property ;
    rdfs:label 'Licensing Terms' ;
    rdfs:comment 'Standard licensing terms or Creative Commons license types typically used by the publisher.' ;
    rdfs:domain ind:Publisher ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:openAccessPolicy rdf:type rdf:Property ;
    rdfs:label 'Open Access Policy' ;
    rdfs:comment 'The publishers policy regarding open access publishing and availability of scholarly content.' ;
    rdfs:domain ind:Publisher ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:peerReviewPolicy rdf:type rdf:Property ;
    rdfs:label 'Peer Review Policy' ;
    rdfs:comment 'The type of peer review process employed by the publisher for scholarly publications.' ;
    rdfs:domain ind:Publisher ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:predatoryFlag rdf:type rdf:Property ;
    rdfs:label 'Predatory Flag' ;
    rdfs:comment 'Indicator of whether the publisher has been identified as predatory or questionable by recognized watchdog organizations.' ;
    rdfs:domain ind:Publisher ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:preferredVendorFlag rdf:type rdf:Property ;
    rdfs:label 'Preferred Vendor Flag' ;
    rdfs:comment 'Indicates whether this publisher is designated as a preferred vendor for acquisitions.' ;
    rdfs:domain ind:Publisher ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:publisherCode rdf:type rdf:Property ;
    rdfs:label 'Publisher Code' ;
    rdfs:comment 'Standardized code or abbreviation used to identify the publisher in library systems and cataloging records.' ;
    rdfs:domain ind:Publisher ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publisherType rdf:type rdf:Property ;
    rdfs:label 'Publisher Type' ;
    rdfs:comment 'Classification of the publisher by organizational type and business model.' ;
    rdfs:domain ind:Publisher ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Vendor Account Number' ;
    rdfs:comment 'Account or customer number assigned by the publisher for institutional purchasing and licensing.' ;
    rdfs:domain ind:Publisher ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:healthAppointmentId rdf:type rdf:Property ;
    rdfs:label 'Health Appointment Id' ;
    rdfs:comment 'Primary key for health_appointment' ;
    rdfs:domain ind:HealthAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualEndTime rdf:type rdf:Property ;
    rdfs:label 'Actual End Time' ;
    rdfs:comment 'The actual date and time when the health appointment concluded.' ;
    rdfs:domain ind:HealthAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualStartTime rdf:type rdf:Property ;
    rdfs:label 'Actual Start Time' ;
    rdfs:comment 'The actual date and time when the health appointment began, as recorded during check-in or service delivery.' ;
    rdfs:domain ind:HealthAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:appointmentNotes rdf:type rdf:Property ;
    rdfs:label 'Appointment Notes' ;
    rdfs:comment 'Additional clinical or administrative notes recorded during or after the health appointment.' ;
    rdfs:domain ind:HealthAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingCode rdf:type rdf:Property ;
    rdfs:label 'Billing Code' ;
    rdfs:comment 'The billing or procedure code associated with the health appointment for financial and insurance processing.' ;
    rdfs:domain ind:HealthAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cancelledBy rdf:type rdf:Property ;
    rdfs:label 'Cancelled By' ;
    rdfs:comment 'Indicates the party who initiated the cancellation of the health appointment.' ;
    rdfs:domain ind:HealthAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checkInTime rdf:type rdf:Property ;
    rdfs:label 'Check In Time' ;
    rdfs:comment 'The date and time when the student checked in for the health appointment at the facility reception.' ;
    rdfs:domain ind:HealthAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:chiefComplaint rdf:type rdf:Property ;
    rdfs:label 'Chief Complaint' ;
    rdfs:comment 'The primary reason or symptom reported by the student for seeking the health appointment.' ;
    rdfs:domain ind:HealthAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confirmationMethod rdf:type rdf:Property ;
    rdfs:label 'Confirmation Method' ;
    rdfs:comment 'The communication channel used to confirm the health appointment with the student.' ;
    rdfs:domain ind:HealthAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentObtained rdf:type rdf:Property ;
    rdfs:label 'Consent Obtained' ;
    rdfs:comment 'Indicates whether informed consent for treatment or services was obtained from the student.' ;
    rdfs:domain ind:HealthAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:insuranceVerified rdf:type rdf:Property ;
    rdfs:label 'Insurance Verified' ;
    rdfs:comment 'Indicates whether the students health insurance coverage has been verified prior to the appointment.' ;
    rdfs:domain ind:HealthAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reminderSentFlag rdf:type rdf:Property ;
    rdfs:label 'Reminder Sent Flag' ;
    rdfs:comment 'Indicates whether an appointment reminder notification was sent to the student.' ;
    rdfs:domain ind:HealthAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reminderSentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Reminder Sent Timestamp' ;
    rdfs:comment 'The date and time when the appointment reminder notification was sent to the student.' ;
    rdfs:domain ind:HealthAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scheduledEndTime rdf:type rdf:Property ;
    rdfs:label 'Scheduled End Time' ;
    rdfs:comment 'The precise date and time when the health appointment is scheduled to end.' ;
    rdfs:domain ind:HealthAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:telehealthFlag rdf:type rdf:Property ;
    rdfs:label 'Telehealth Flag' ;
    rdfs:comment 'Indicates whether the health appointment was conducted via telehealth or virtual consultation rather than in-person.' ;
    rdfs:domain ind:HealthAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:visitReason rdf:type rdf:Property ;
    rdfs:label 'Visit Reason' ;
    rdfs:comment 'Detailed description of the purpose or clinical reason for the health appointment.' ;
    rdfs:domain ind:HealthAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waitTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Wait Time Minutes' ;
    rdfs:comment 'The duration in minutes between check-in and the actual start of the appointment, used for service quality monitoring.' ;
    rdfs:domain ind:HealthAppointment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:mealPlanId rdf:type rdf:Property ;
    rdfs:label 'Meal Plan Id' ;
    rdfs:comment 'Reference to the dining services meal plan associated with this housing contract.' ;
    rdfs:domain ind:HousingContract ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DiningPlan .

ind:cancellationFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Cancellation Fee Amount' ;
    rdfs:comment 'Monetary penalty assessed for early termination or cancellation of the housing contract.' ;
    rdfs:domain ind:HousingContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:checkInDate rdf:type rdf:Property ;
    rdfs:label 'Check In Date' ;
    rdfs:comment 'Actual date when the student physically moved into the assigned housing unit.' ;
    rdfs:domain ind:HousingContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:checkOutDate rdf:type rdf:Property ;
    rdfs:label 'Check Out Date' ;
    rdfs:comment 'Actual date when the student physically vacated the assigned housing unit and returned keys.' ;
    rdfs:domain ind:HousingContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contractAmount rdf:type rdf:Property ;
    rdfs:label 'Contract Amount' ;
    rdfs:comment 'Total monetary value of the housing contract for the full contract period before any adjustments or fees.' ;
    rdfs:domain ind:HousingContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:parentGuardianSignedDate rdf:type rdf:Property ;
    rdfs:label 'Parent Guardian Signed Date' ;
    rdfs:comment 'Date when the parent or legal guardian co-signed the housing contract if required.' ;
    rdfs:domain ind:HousingContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:renewalEligible rdf:type rdf:Property ;
    rdfs:label 'Renewal Eligible' ;
    rdfs:comment 'Indicates whether the student is eligible to renew this housing contract for a subsequent term or academic year.' ;
    rdfs:domain ind:HousingContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:roommatePreference rdf:type rdf:Property ;
    rdfs:label 'Roommate Preference' ;
    rdfs:comment 'Student-indicated preferences or requests for roommate matching used during room assignment.' ;
    rdfs:domain ind:HousingContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:termsAccepted rdf:type rdf:Property ;
    rdfs:label 'Terms Accepted' ;
    rdfs:comment 'Indicates whether the student has formally accepted the terms and conditions of the housing contract.' ;
    rdfs:domain ind:HousingContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:termsVersion rdf:type rdf:Property ;
    rdfs:label 'Terms Version' ;
    rdfs:comment 'Version identifier of the housing contract terms and conditions document that the student accepted.' ;
    rdfs:domain ind:HousingContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationTemplateId rdf:type rdf:Property ;
    rdfs:label 'Notification Template Id' ;
    rdfs:comment 'Reference to the communication template used for workflow notifications (e.g., email template ID, message format identifier).' ;
    rdfs:domain ind:Technology ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NotificationTemplate .

ind:previousVersionId rdf:type rdf:Property ;
    rdfs:label 'Previous Version Id' ;
    rdfs:comment 'Reference to the prior version of this workflow, enabling version history tracking and rollback capability.' ;
    rdfs:domain ind:ApprovalWorkflow ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ApprovalWorkflow .

ind:allowsParallelApproval rdf:type rdf:Property ;
    rdfs:label 'Allows Parallel Approval' ;
    rdfs:comment 'Indicates whether multiple approval stages can be processed simultaneously (true) or must be sequential (false).' ;
    rdfs:domain ind:ApprovalWorkflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:approvalAuthorityMatrix rdf:type rdf:Property ;
    rdfs:label 'Approval Authority Matrix' ;
    rdfs:comment 'Structured definition of approval authority levels, thresholds, and role-based permissions that govern who can approve at each stage (stored as JSON or structured text).' ;
    rdfs:domain ind:ApprovalWorkflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalRatePercentage rdf:type rdf:Property ;
    rdfs:label 'Approval Rate Percentage' ;
    rdfs:comment 'Percentage of requests submitted through this workflow that result in final approval (vs. rejection or cancellation), used for workflow effectiveness analysis.' ;
    rdfs:domain ind:ApprovalWorkflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvalStageCount rdf:type rdf:Property ;
    rdfs:label 'Approval Stage Count' ;
    rdfs:comment 'Total number of sequential approval stages defined in this workflow (e.g., 1 for single-stage, 3 for three-tier approval).' ;
    rdfs:domain ind:ApprovalWorkflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:auditTrailRequired rdf:type rdf:Property ;
    rdfs:label 'Audit Trail Required' ;
    rdfs:comment 'Indicates whether this workflow requires comprehensive audit logging of all actions, decisions, and state changes for compliance or governance purposes.' ;
    rdfs:domain ind:ApprovalWorkflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:autoApprovalCriteria rdf:type rdf:Property ;
    rdfs:label 'Auto Approval Criteria' ;
    rdfs:comment 'Business rules and conditions that trigger automatic approval without human intervention (e.g., \'Amount < $500 AND Requester in Pre-Approved List\').' ;
    rdfs:domain ind:ApprovalWorkflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:autoApprovalEnabled rdf:type rdf:Property ;
    rdfs:label 'Auto Approval Enabled' ;
    rdfs:comment 'Indicates whether this workflow supports automatic approval based on predefined business rules (e.g., amounts below threshold, pre-authorized requesters).' ;
    rdfs:domain ind:ApprovalWorkflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:averageCompletionHours rdf:type rdf:Property ;
    rdfs:label 'Average Completion Hours' ;
    rdfs:comment 'Mean number of hours taken to complete approval requests in this workflow, calculated from historical data for performance monitoring.' ;
    rdfs:domain ind:ApprovalWorkflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:commentsRequired rdf:type rdf:Property ;
    rdfs:label 'Comments Required' ;
    rdfs:comment 'Indicates whether approvers must provide comments or justification when approving or rejecting requests in this workflow.' ;
    rdfs:domain ind:ApprovalWorkflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:delegationAllowed rdf:type rdf:Property ;
    rdfs:label 'Delegation Allowed' ;
    rdfs:comment 'Indicates whether approvers can delegate their approval authority to another user within this workflow.' ;
    rdfs:domain ind:ApprovalWorkflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:escalationEnabled rdf:type rdf:Property ;
    rdfs:label 'Escalation Enabled' ;
    rdfs:comment 'Indicates whether this workflow includes automatic escalation to higher authority if approvals are not completed within the defined timeframe.' ;
    rdfs:domain ind:ApprovalWorkflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:escalationThresholdHours rdf:type rdf:Property ;
    rdfs:label 'Escalation Threshold Hours' ;
    rdfs:comment 'Number of hours after which an approval request is automatically escalated to the next level of authority if not acted upon.' ;
    rdfs:domain ind:ApprovalWorkflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:integrationSystemCode rdf:type rdf:Property ;
    rdfs:label 'Integration System Code' ;
    rdfs:comment 'Code identifying the source or integrated enterprise system that triggers or consumes this workflow (e.g., \'ERP-FIN\', \'HCM\', \'SIS\', \'ITSM\').' ;
    rdfs:domain ind:ApprovalWorkflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isTemplate rdf:type rdf:Property ;
    rdfs:label 'Is Template' ;
    rdfs:comment 'Indicates whether this workflow serves as a reusable template that can be cloned to create new workflow instances with similar structure.' ;
    rdfs:domain ind:ApprovalWorkflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:notificationEnabled rdf:type rdf:Property ;
    rdfs:label 'Notification Enabled' ;
    rdfs:comment 'Indicates whether email or system notifications are sent to stakeholders at key workflow milestones (submission, approval, rejection, completion).' ;
    rdfs:domain ind:Technology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rejectionReturnsToOriginator rdf:type rdf:Property ;
    rdfs:label 'Rejection Returns To Originator' ;
    rdfs:comment 'Indicates whether a rejection at any stage returns the request to the original requester (true) or terminates the workflow immediately (false).' ;
    rdfs:domain ind:ApprovalWorkflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiresUnanimousApproval rdf:type rdf:Property ;
    rdfs:label 'Requires Unanimous Approval' ;
    rdfs:comment 'Indicates whether all approvers at each stage must approve (true) or if a single approval is sufficient (false).' ;
    rdfs:domain ind:ApprovalWorkflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:retentionPeriodYears rdf:type rdf:Property ;
    rdfs:label 'Retention Period Years' ;
    rdfs:comment 'Number of years that completed workflow instances and their associated records must be retained for regulatory or institutional policy compliance.' ;
    rdfs:domain ind:ApprovalWorkflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:serviceLevelAgreementHours rdf:type rdf:Property ;
    rdfs:label 'Service Level Agreement Hours' ;
    rdfs:comment 'Target number of hours within which requests in this workflow should be completed from submission to final decision, as defined by institutional service standards.' ;
    rdfs:domain ind:ApprovalWorkflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:workflowCode rdf:type rdf:Property ;
    rdfs:label 'Workflow Code' ;
    rdfs:comment 'Unique business identifier code for the workflow, used for system integration and reference (e.g., \'FAC-HIRE-01\', \'BUDG-REQ-STD\').' ;
    rdfs:domain ind:ApprovalWorkflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workflowName rdf:type rdf:Property ;
    rdfs:label 'Workflow Name' ;
    rdfs:comment 'Human-readable name of the approval workflow (e.g., \'Faculty Hiring Approval\', \'Budget Request Approval\', \'Course Proposal Review\').' ;
    rdfs:domain ind:ApprovalWorkflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workflowStatus rdf:type rdf:Property ;
    rdfs:label 'Workflow Status' ;
    rdfs:comment 'Current lifecycle status of the approval workflow indicating whether it is in use, being designed, temporarily disabled, or retired.' ;
    rdfs:domain ind:ApprovalWorkflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workflowType rdf:type rdf:Property ;
    rdfs:label 'Workflow Type' ;
    rdfs:comment 'Category of approval workflow based on the business domain it serves (financial approvals, HR processes, academic reviews, procurement, IT service requests, access management).' ;
    rdfs:domain ind:ApprovalWorkflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certifiedEnterpriseApplicationId rdf:type rdf:Property ;
    rdfs:label 'Certified Enterprise Application Id' ;
    rdfs:comment 'Foreign key linking to technology.enterprise_application. Business justification: Access certifications are scoped to specific enterprise applications. The access_certification table has an \'application_id\' field (BIGINT) that should be a FK to enterprise_application. Access certif' ;
    rdfs:domain ind:AccessCertification ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EnterpriseApplication .

ind:approvedItemsCount rdf:type rdf:Property ;
    rdfs:label 'Approved Items Count' ;
    rdfs:comment 'Number of access items that were certified as appropriate and approved for continued access.' ;
    rdfs:domain ind:AccessCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:auditTrailReference rdf:type rdf:Property ;
    rdfs:label 'Audit Trail Reference' ;
    rdfs:comment 'External reference identifier linking this certification campaign to detailed audit logs and evidence repositories for compliance verification.' ;
    rdfs:domain ind:AccessCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:automatedFlag rdf:type rdf:Property ;
    rdfs:label 'Automated Flag' ;
    rdfs:comment 'Indicates whether this certification campaign leverages automated review workflows and decision support tools versus manual review processes.' ;
    rdfs:domain ind:AccessCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:certificationScope rdf:type rdf:Property ;
    rdfs:label 'Certification Scope' ;
    rdfs:comment 'Organizational or functional boundary of the certification campaign, defining whether it covers the entire institution, specific departments, applications, roles, or individuals.' ;
    rdfs:domain ind:AccessCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationType rdf:type rdf:Property ;
    rdfs:label 'Certification Type' ;
    rdfs:comment 'Category of access being certified, distinguishing between user-level, role-based, privileged, application-specific, data-level, or network access reviews.' ;
    rdfs:domain ind:AccessCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Escalation Required Flag' ;
    rdfs:comment 'Indicates whether unresolved or high-risk access items require escalation to senior management or security governance committees.' ;
    rdfs:domain ind:AccessCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:initiatedDate rdf:type rdf:Property ;
    rdfs:label 'Initiated Date' ;
    rdfs:comment 'Date when the access certification campaign was formally launched and notifications sent to reviewers.' ;
    rdfs:domain ind:AccessCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reviewPeriodEnd rdf:type rdf:Property ;
    rdfs:label 'Review Period End' ;
    rdfs:comment 'Ending date of the access period being reviewed in this certification campaign.' ;
    rdfs:domain ind:AccessCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reviewPeriodStart rdf:type rdf:Property ;
    rdfs:label 'Review Period Start' ;
    rdfs:comment 'Beginning date of the access period being reviewed in this certification campaign.' ;
    rdfs:domain ind:AccessCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reviewedItemsCount rdf:type rdf:Property ;
    rdfs:label 'Reviewed Items Count' ;
    rdfs:comment 'Number of access items that have been reviewed and decided upon by certifiers as of the current state.' ;
    rdfs:domain ind:AccessCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:revokedItemsCount rdf:type rdf:Property ;
    rdfs:label 'Revoked Items Count' ;
    rdfs:comment 'Number of access items that were identified as inappropriate and marked for revocation or removal.' ;
    rdfs:domain ind:AccessCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalItemsCount rdf:type rdf:Property ;
    rdfs:label 'Total Items Count' ;
    rdfs:comment 'Total number of access items (user accounts, roles, permissions) included in this certification campaign for review.' ;
    rdfs:domain ind:AccessCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:problemId rdf:type rdf:Property ;
    rdfs:label 'Problem Id' ;
    rdfs:comment 'Primary key for problem' ;
    rdfs:domain ind:Problem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assignedGroup rdf:type rdf:Property ;
    rdfs:label 'Assigned Group' ;
    rdfs:comment 'Support group or team responsible for managing the problem resolution.' ;
    rdfs:domain ind:Problem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignedTo rdf:type rdf:Property ;
    rdfs:label 'Assigned To' ;
    rdfs:comment 'Name or identifier of the individual or team currently assigned to investigate and resolve the problem.' ;
    rdfs:domain ind:Problem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeRequestNumber rdf:type rdf:Property ;
    rdfs:label 'Change Request Number' ;
    rdfs:comment 'Reference number of the change request created to implement the permanent solution for this problem.' ;
    rdfs:domain ind:Problem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:detectedDate rdf:type rdf:Property ;
    rdfs:label 'Detected Date' ;
    rdfs:comment 'Date when the underlying issue was first detected in the environment, which may precede the reported date.' ;
    rdfs:domain ind:Problem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:impact rdf:type rdf:Property ;
    rdfs:label 'Impact' ;
    rdfs:comment 'Scope of business impact indicating how many users or services are affected.' ;
    rdfs:domain ind:Problem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentCount rdf:type rdf:Property ;
    rdfs:label 'Incident Count' ;
    rdfs:comment 'Number of incidents that have been linked to or caused by this problem.' ;
    rdfs:domain ind:Problem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:knownErrorFlag rdf:type rdf:Property ;
    rdfs:label 'Known Error Flag' ;
    rdfs:comment 'Indicates whether this problem has been classified as a known error with documented root cause and workaround.' ;
    rdfs:domain ind:Problem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:permanentSolution rdf:type rdf:Property ;
    rdfs:label 'Permanent Solution' ;
    rdfs:comment 'Documented permanent fix or solution that addresses the root cause of the problem.' ;
    rdfs:domain ind:Problem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:problemCategory rdf:type rdf:Property ;
    rdfs:label 'Problem Category' ;
    rdfs:comment 'High-level categorization of the problem domain.' ;
    rdfs:domain ind:Problem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:problemNumber rdf:type rdf:Property ;
    rdfs:label 'Problem Number' ;
    rdfs:comment 'Human-readable unique problem ticket number assigned by the service management system.' ;
    rdfs:domain ind:Problem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:problemSubcategory rdf:type rdf:Property ;
    rdfs:label 'Problem Subcategory' ;
    rdfs:comment 'Detailed subcategory providing granular classification within the problem category.' ;
    rdfs:domain ind:Problem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:problemType rdf:type rdf:Property ;
    rdfs:label 'Problem Type' ;
    rdfs:comment 'Classification indicating whether the problem was identified reactively (after incidents) or proactively (before incidents occur).' ;
    rdfs:domain ind:Problem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportedBy rdf:type rdf:Property ;
    rdfs:label 'Reported By' ;
    rdfs:comment 'Name or identifier of the person who initially reported or identified the problem.' ;
    rdfs:domain ind:Problem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolvedDate rdf:type rdf:Property ;
    rdfs:label 'Resolved Date' ;
    rdfs:comment 'Date when the problem was resolved with a permanent solution implemented.' ;
    rdfs:domain ind:Problem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rootCause rdf:type rdf:Property ;
    rdfs:label 'Root Cause' ;
    rdfs:comment 'Documented root cause of the problem identified through investigation and analysis.' ;
    rdfs:domain ind:Problem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rootCauseIdentifiedDate rdf:type rdf:Property ;
    rdfs:label 'Root Cause Identified Date' ;
    rdfs:comment 'Date when the root cause of the problem was successfully identified.' ;
    rdfs:domain ind:Problem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:severity rdf:type rdf:Property ;
    rdfs:label 'Severity' ;
    rdfs:comment 'Technical severity level indicating the extent of service degradation or disruption.' ;
    rdfs:domain ind:Problem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetResolutionDate rdf:type rdf:Property ;
    rdfs:label 'Target Resolution Date' ;
    rdfs:comment 'Target or committed date by which the problem should be resolved based on priority and service level agreements.' ;
    rdfs:domain ind:Problem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:urgency rdf:type rdf:Property ;
    rdfs:label 'Urgency' ;
    rdfs:comment 'Time sensitivity indicating how quickly the problem must be resolved.' ;
    rdfs:domain ind:Problem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorReference rdf:type rdf:Property ;
    rdfs:label 'Vendor Reference' ;
    rdfs:comment 'Reference number or case identifier from an external vendor if the problem involves third-party products or services.' ;
    rdfs:domain ind:Problem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workaround rdf:type rdf:Property ;
    rdfs:label 'Workaround' ;
    rdfs:comment 'Temporary solution or workaround to reduce or eliminate the impact of the problem before permanent resolution.' ;
    rdfs:domain ind:Problem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:categoryId rdf:type rdf:Property ;
    rdfs:label 'Category Id' ;
    rdfs:comment 'Reference to the primary category or topic area this article belongs to within the knowledge base taxonomy.' ;
    rdfs:domain ind:KnowledgeArticle ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:KnowledgeCategory .

ind:subcategoryId rdf:type rdf:Property ;
    rdfs:label 'Subcategory Id' ;
    rdfs:comment 'Reference to the secondary classification level for more granular organization of the article.' ;
    rdfs:domain ind:KnowledgeArticle ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:KnowledgeSubcategory .

ind:articleNumber rdf:type rdf:Property ;
    rdfs:label 'Article Number' ;
    rdfs:comment 'Human-readable unique identifier for the knowledge article, typically displayed to end users and support staff.' ;
    rdfs:domain ind:KnowledgeArticle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:articleType rdf:type rdf:Property ;
    rdfs:label 'Article Type' ;
    rdfs:comment 'Classification of the knowledge article by its purpose and structure.' ;
    rdfs:domain ind:KnowledgeArticle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:audience rdf:type rdf:Property ;
    rdfs:label 'Audience' ;
    rdfs:comment 'Primary intended audience or user group for this knowledge article.' ;
    rdfs:domain ind:KnowledgeArticle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:averageRating rdf:type rdf:Property ;
    rdfs:label 'Average Rating' ;
    rdfs:comment 'Mean rating score provided by users, typically on a scale of 1 to 5.' ;
    rdfs:domain ind:KnowledgeArticle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:content rdf:type rdf:Property ;
    rdfs:label 'Content' ;
    rdfs:comment 'The full body text of the knowledge article containing detailed information, instructions, or guidance.' ;
    rdfs:domain ind:KnowledgeArticle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalUrl rdf:type rdf:Property ;
    rdfs:label 'External Url' ;
    rdfs:comment 'Optional hyperlink to an external resource or reference related to this article.' ;
    rdfs:domain ind:KnowledgeArticle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:helpfulCount rdf:type rdf:Property ;
    rdfs:label 'Helpful Count' ;
    rdfs:comment 'Number of users who marked this article as helpful or useful.' ;
    rdfs:domain ind:KnowledgeArticle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isFeatured rdf:type rdf:Property ;
    rdfs:label 'Is Featured' ;
    rdfs:comment 'Indicates whether this article is promoted or highlighted in the knowledge base interface.' ;
    rdfs:domain ind:Technology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSearchable rdf:type rdf:Property ;
    rdfs:label 'Is Searchable' ;
    rdfs:comment 'Indicates whether this article is included in knowledge base search indexes.' ;
    rdfs:domain ind:Technology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:notHelpfulCount rdf:type rdf:Property ;
    rdfs:label 'Not Helpful Count' ;
    rdfs:comment 'Number of users who marked this article as not helpful or inadequate.' ;
    rdfs:domain ind:KnowledgeArticle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:publishedDate rdf:type rdf:Property ;
    rdfs:label 'Published Date' ;
    rdfs:comment 'Date when the article was first made available to its intended audience.' ;
    rdfs:domain ind:KnowledgeArticle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:relatedIncidentCount rdf:type rdf:Property ;
    rdfs:label 'Related Incident Count' ;
    rdfs:comment 'Number of service desk incidents that have been linked to or resolved using this article.' ;
    rdfs:domain ind:KnowledgeArticle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:requiresAuthentication rdf:type rdf:Property ;
    rdfs:label 'Requires Authentication' ;
    rdfs:comment 'Indicates whether users must be authenticated to access this article.' ;
    rdfs:domain ind:KnowledgeArticle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:resolutionTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Resolution Time Minutes' ;
    rdfs:comment 'Average time in minutes that incidents are resolved when this article is applied.' ;
    rdfs:domain ind:KnowledgeArticle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:visibility rdf:type rdf:Property ;
    rdfs:label 'Visibility' ;
    rdfs:comment 'Access control level determining who can view this article in the knowledge base.' ;
    rdfs:domain ind:KnowledgeArticle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactPersonEmail rdf:type rdf:Property ;
    rdfs:label 'Contact Person Email' ;
    rdfs:comment 'Email address for the primary contact person at the lender organization.' ;
    rdfs:domain ind:Lender ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactPersonPhone rdf:type rdf:Property ;
    rdfs:label 'Contact Person Phone' ;
    rdfs:comment 'Direct phone number for the primary contact person at the lender organization.' ;
    rdfs:domain ind:Lender ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactPersonTitle rdf:type rdf:Property ;
    rdfs:label 'Contact Person Title' ;
    rdfs:comment 'Job title of the primary contact person at the lender organization.' ;
    rdfs:domain ind:Lender ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:federalLenderId rdf:type rdf:Property ;
    rdfs:label 'Federal Lender Id' ;
    rdfs:comment 'Federal lender identification number assigned by the U.S. Department of Education for Title IV loan programs.' ;
    rdfs:domain ind:Lender ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lenderShortName rdf:type rdf:Property ;
    rdfs:label 'Lender Short Name' ;
    rdfs:comment 'Abbreviated or display name of the lender used in reports and student-facing communications.' ;
    rdfs:domain ind:Lender ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lenderType rdf:type rdf:Property ;
    rdfs:label 'Lender Type' ;
    rdfs:comment 'Classification of the lender based on the loan program type (e.g., Federal Direct Loan Program, FFELP, private lender, institutional lender, state agency, alternative lender).' ;
    rdfs:domain ind:Lender ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredLenderFlag rdf:type rdf:Property ;
    rdfs:label 'Preferred Lender Flag' ;
    rdfs:comment 'Indicates whether this lender is on the institution\'s preferred lender list for student loan recommendations.' ;
    rdfs:domain ind:Lender ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:servicerFlag rdf:type rdf:Property ;
    rdfs:label 'Servicer Flag' ;
    rdfs:comment 'Indicates whether this lender also acts as a loan servicer (True) or is purely an originating lender (False).' ;
    rdfs:domain ind:Lender ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:taxId rdf:type rdf:Property ;
    rdfs:label 'Tax Id' ;
    rdfs:comment 'Federal Employer Identification Number (EIN) or Tax ID for the lender organization.' ;
    rdfs:domain ind:Lender ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alignmentStandard rdf:type rdf:Property ;
    rdfs:label 'Alignment Standard' ;
    rdfs:comment 'External standard or framework to which this competency framework is aligned or mapped (e.g., Degree Qualifications Profile, Lumina Foundation DQP, European Qualifications Framework). Supports articulation and transfer.' ;
    rdfs:domain ind:CompetencyFramework ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableDegreeLevels rdf:type rdf:Property ;
    rdfs:label 'Applicable Degree Levels' ;
    rdfs:comment 'Comma-separated list of degree levels to which this framework applies (e.g., undergraduate, graduate, doctoral, certificate, associate). Supports filtering and applicability rules. [ENUM-REF-CANDIDATE: undergraduate|graduate|doctoral|certificate|associate|professional|post_doctoral — promote to reference product if more granular tracking needed]' ;
    rdfs:domain ind:CompetencyFramework ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competencyDomains rdf:type rdf:Property ;
    rdfs:label 'Competency Domains' ;
    rdfs:comment 'Total number of distinct competency domains or categories defined in this framework (e.g., cognitive, affective, psychomotor; or technical, professional, interpersonal).' ;
    rdfs:domain ind:CompetencyFramework ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:competencyLevels rdf:type rdf:Property ;
    rdfs:label 'Competency Levels' ;
    rdfs:comment 'Total number of hierarchical competency levels defined in this framework (e.g., 3 for beginner/intermediate/advanced, 6 for Bloom\'s cognitive levels). Used for competency progression mapping.' ;
    rdfs:domain ind:CompetencyFramework ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:discipline rdf:type rdf:Property ;
    rdfs:label 'Discipline' ;
    rdfs:comment 'Primary academic discipline or field of study to which this competency framework applies (e.g., Business Administration, Engineering, Computer Science, Liberal Arts). May be null for cross-disciplinary frameworks.' ;
    rdfs:domain ind:CompetencyFramework ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:frameworkCode rdf:type rdf:Property ;
    rdfs:label 'Framework Code' ;
    rdfs:comment 'Externally-known unique code or identifier for the competency framework (e.g., AACSB-2020, ABET-EAC, QAA-FHEQ). Used for cross-institutional references and accreditation mapping.' ;
    rdfs:domain ind:CompetencyFramework ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:frameworkName rdf:type rdf:Property ;
    rdfs:label 'Framework Name' ;
    rdfs:comment 'Full official name of the competency framework (e.g., Association to Advance Collegiate Schools of Business Assurance of Learning Standards, Framework for Higher Education Qualifications).' ;
    rdfs:domain ind:CompetencyFramework ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:frameworkType rdf:type rdf:Property ;
    rdfs:label 'Framework Type' ;
    rdfs:comment 'Classification of the competency framework by scope and authority: accreditation (AACSB, ABET), institutional (university-specific), disciplinary (field-specific), professional (industry certification), national (country-level qualifications), or international (global standards).' ;
    rdfs:domain ind:CompetencyFramework ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingOrganization rdf:type rdf:Property ;
    rdfs:label 'Issuing Organization' ;
    rdfs:comment 'Name of the organization, accrediting body, or institution that published and maintains the competency framework (e.g., AACSB International, ABET, Quality Assurance Agency for Higher Education).' ;
    rdfs:domain ind:CompetencyFramework ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingOrganizationUrl rdf:type rdf:Property ;
    rdfs:label 'Issuing Organization Url' ;
    rdfs:comment 'Official website URL of the issuing organization where the framework documentation and updates can be accessed.' ;
    rdfs:domain ind:CompetencyFramework ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scope rdf:type rdf:Property ;
    rdfs:label 'Scope' ;
    rdfs:comment 'Level of application for the competency framework: program (degree/certificate program level), course (individual course level), institutional (university-wide), discipline (academic field), or industry (professional sector).' ;
    rdfs:domain ind:CompetencyFramework ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxonomyType rdf:type rdf:Property ;
    rdfs:label 'Taxonomy Type' ;
    rdfs:comment 'Educational taxonomy model used to structure competency levels within this framework: blooms (Bloom\'s Taxonomy), solo (Structure of Observed Learning Outcomes), fink (Fink\'s Taxonomy of Significant Learning), custom (institution-defined), or other.' ;
    rdfs:domain ind:CompetencyFramework ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ledgerId rdf:type rdf:Property ;
    rdfs:label 'Ledger Id' ;
    rdfs:comment 'Primary key for ledger' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accountingStandard rdf:type rdf:Property ;
    rdfs:label 'Accounting Standard' ;
    rdfs:comment 'The primary accounting standard framework governing this ledger (Governmental Accounting Standards Board, Financial Accounting Standards Board, or International Financial Reporting Standards).' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditTrailEnabled rdf:type rdf:Property ;
    rdfs:label 'Audit Trail Enabled' ;
    rdfs:comment 'Indicates whether this ledger maintains a complete audit trail of all transaction postings, adjustments, and reversals.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:baseCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Base Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code representing the primary currency in which this ledger maintains balances.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetControlEnabled rdf:type rdf:Property ;
    rdfs:label 'Budget Control Enabled' ;
    rdfs:comment 'Indicates whether this ledger enforces budget checking and encumbrance controls to prevent overspending.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:chartOfAccountsId rdf:type rdf:Property ;
    rdfs:label 'Chart Of Accounts Id' ;
    rdfs:comment 'Reference to the chart of accounts structure that defines the account hierarchy and coding structure for this ledger.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:consolidationLedgerId rdf:type rdf:Property ;
    rdfs:label 'Consolidation Ledger Id' ;
    rdfs:comment 'Reference to the consolidation ledger into which this ledger rolls up for institutional financial reporting.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:createdByUserId rdf:type rdf:Property ;
    rdfs:label 'Created By User Id' ;
    rdfs:comment 'The user identifier of the person who created this ledger record.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:encumbranceAccountingEnabled rdf:type rdf:Property ;
    rdfs:label 'Encumbrance Accounting Enabled' ;
    rdfs:comment 'Indicates whether this ledger tracks purchase orders and commitments as encumbrances against available budgets.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:erpSystemCode rdf:type rdf:Property ;
    rdfs:label 'Erp System Code' ;
    rdfs:comment 'Code identifying the ERP system (e.g., Oracle PeopleSoft Financials, Workday, Banner) that manages this ledger.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fiscalYearStartMonth rdf:type rdf:Property ;
    rdfs:label 'Fiscal Year Start Month' ;
    rdfs:comment 'The month (1-12) in which the fiscal year begins for this ledger. Typically July (7) for higher education institutions.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fundAccountingEnabled rdf:type rdf:Property ;
    rdfs:label 'Fund Accounting Enabled' ;
    rdfs:comment 'Indicates whether this ledger uses fund accounting principles to track restricted and unrestricted resources separately.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:grantAccountingEnabled rdf:type rdf:Property ;
    rdfs:label 'Grant Accounting Enabled' ;
    rdfs:comment 'Indicates whether this ledger supports sponsored project and grant accounting with compliance tracking.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:intercompanyEliminationRequired rdf:type rdf:Property ;
    rdfs:label 'Intercompany Elimination Required' ;
    rdfs:comment 'Indicates whether transactions in this ledger require intercompany elimination entries during consolidation.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ipedsReportingEnabled rdf:type rdf:Property ;
    rdfs:label 'Ipeds Reporting Enabled' ;
    rdfs:comment 'Indicates whether this ledger provides data for mandatory IPEDS federal reporting to the National Center for Education Statistics.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastClosedPeriod rdf:type rdf:Property ;
    rdfs:label 'Last Closed Period' ;
    rdfs:comment 'The most recent accounting period (YYYY-MM format) that has been closed and locked in this ledger.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastModifiedByUserId rdf:type rdf:Property ;
    rdfs:label 'Last Modified By User Id' ;
    rdfs:comment 'The user identifier of the person who most recently modified this ledger record.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ledgerCode rdf:type rdf:Property ;
    rdfs:label 'Ledger Code' ;
    rdfs:comment 'Short alphanumeric code uniquely identifying the ledger for external reference and reporting purposes.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ledgerDescription rdf:type rdf:Property ;
    rdfs:label 'Ledger Description' ;
    rdfs:comment 'Detailed narrative description of the ledger\'s purpose, scope, and business function within the institution.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ledgerName rdf:type rdf:Property ;
    rdfs:label 'Ledger Name' ;
    rdfs:comment 'Full descriptive name of the ledger used for identification and reporting.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ledgerStatus rdf:type rdf:Property ;
    rdfs:label 'Ledger Status' ;
    rdfs:comment 'Current operational status of the ledger indicating whether it is available for transaction posting.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ledgerType rdf:type rdf:Property ;
    rdfs:label 'Ledger Type' ;
    rdfs:comment 'Classification of the ledger indicating its functional purpose within the institutional financial structure.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:multiCurrencyEnabled rdf:type rdf:Property ;
    rdfs:label 'Multi Currency Enabled' ;
    rdfs:comment 'Indicates whether this ledger supports transactions and balances in multiple currencies with automatic conversion.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nacuboReportingEnabled rdf:type rdf:Property ;
    rdfs:label 'Nacubo Reporting Enabled' ;
    rdfs:comment 'Indicates whether this ledger participates in NACUBO benchmarking and comparative reporting surveys.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:parentLedgerId rdf:type rdf:Property ;
    rdfs:label 'Parent Ledger Id' ;
    rdfs:comment 'Reference to the parent ledger in a hierarchical ledger structure. Null for top-level general ledgers.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reportingEntityType rdf:type rdf:Property ;
    rdfs:label 'Reporting Entity Type' ;
    rdfs:comment 'Classification of the reporting entity relationship for GASB financial reporting purposes.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retainedEarningsAccount rdf:type rdf:Property ;
    rdfs:label 'Retained Earnings Account' ;
    rdfs:comment 'The general ledger account code used to accumulate retained earnings or net position for this ledger.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:suspenseAccount rdf:type rdf:Property ;
    rdfs:label 'Suspense Account' ;
    rdfs:comment 'The general ledger account code used for temporary holding of unclassified or pending transactions.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetAuthorityFlag rdf:type rdf:Property ;
    rdfs:label 'Budget Authority Flag' ;
    rdfs:comment 'Indicates whether this business unit has independent budget authority and can approve expenditures.' ;
    rdfs:domain ind:BusinessUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deanOrDirectorName rdf:type rdf:Property ;
    rdfs:label 'Dean Or Director Name' ;
    rdfs:comment 'Name of the dean, director, or senior administrator responsible for this business unit.' ;
    rdfs:domain ind:BusinessUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fiscalOfficerName rdf:type rdf:Property ;
    rdfs:label 'Fiscal Officer Name' ;
    rdfs:comment 'Name of the fiscal officer or business manager responsible for financial operations of this business unit.' ;
    rdfs:domain ind:BusinessUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fundGroup rdf:type rdf:Property ;
    rdfs:label 'Fund Group' ;
    rdfs:comment 'Primary fund group classification for this business unit per fund accounting principles.' ;
    rdfs:domain ind:BusinessUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:organizationLevel rdf:type rdf:Property ;
    rdfs:label 'Organization Level' ;
    rdfs:comment 'Hierarchical level of the business unit within the institutional structure (e.g., 1=University, 2=College, 3=Department, 4=Program).' ;
    rdfs:domain ind:BusinessUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:parentBusinessUnitId rdf:type rdf:Property ;
    rdfs:label 'Parent Business Unit Id' ;
    rdfs:comment 'Reference to the parent business unit in the organizational hierarchy. Null for top-level units.' ;
    rdfs:domain ind:BusinessUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:revenueGeneratingFlag rdf:type rdf:Property ;
    rdfs:label 'Revenue Generating Flag' ;
    rdfs:comment 'Indicates whether this business unit generates direct revenue (e.g., tuition, grants, auxiliary services).' ;
    rdfs:domain ind:BusinessUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:accountCategory rdf:type rdf:Property ;
    rdfs:label 'Account Category' ;
    rdfs:comment 'General ledger account category that this recurring schedule primarily affects.' ;
    rdfs:domain ind:RecurringSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:autoGenerateFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Generate Flag' ;
    rdfs:comment 'Indicates whether scheduled transactions are automatically generated by the system or require manual approval.' ;
    rdfs:domain ind:RecurringSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:businessDayAdjustment rdf:type rdf:Property ;
    rdfs:label 'Business Day Adjustment' ;
    rdfs:comment 'Rule for adjusting scheduled dates that fall on non-business days (weekends, holidays) to ensure execution on valid business days.' ;
    rdfs:domain ind:RecurringSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dayOfMonth rdf:type rdf:Property ;
    rdfs:label 'Day Of Month' ;
    rdfs:comment 'Specific day of the month when the recurring schedule executes (1-31). Null if not applicable to the frequency type.' ;
    rdfs:domain ind:RecurringSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dayOfWeek rdf:type rdf:Property ;
    rdfs:label 'Day Of Week' ;
    rdfs:comment 'Specific day of the week when the recurring schedule executes. Applicable for weekly and biweekly frequencies.' ;
    rdfs:domain ind:RecurringSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:executionTime rdf:type rdf:Property ;
    rdfs:label 'Execution Time' ;
    rdfs:comment 'Time of day when the recurring schedule executes, in HH:MM:SS format (24-hour).' ;
    rdfs:domain ind:RecurringSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fiscalPeriodAlignment rdf:type rdf:Property ;
    rdfs:label 'Fiscal Period Alignment' ;
    rdfs:comment 'Alignment of the schedule execution relative to institutional fiscal periods for financial reporting consistency.' ;
    rdfs:domain ind:RecurringSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holidayCalendarCode rdf:type rdf:Property ;
    rdfs:label 'Holiday Calendar Code' ;
    rdfs:comment 'Code identifying the institutional or regional holiday calendar used for business day calculations.' ;
    rdfs:domain ind:RecurringSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:intervalCount rdf:type rdf:Property ;
    rdfs:label 'Interval Count' ;
    rdfs:comment 'Number of frequency periods between occurrences. For example, 2 with monthly frequency means every 2 months.' ;
    rdfs:domain ind:RecurringSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastExecutionDate rdf:type rdf:Property ;
    rdfs:label 'Last Execution Date' ;
    rdfs:comment 'Date when the recurring schedule last executed and generated a scheduled transaction or activity.' ;
    rdfs:domain ind:RecurringSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:maxOccurrences rdf:type rdf:Property ;
    rdfs:label 'Max Occurrences' ;
    rdfs:comment 'Maximum number of times this recurring schedule will execute before automatically expiring. Null for unlimited occurrences.' ;
    rdfs:domain ind:RecurringSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:monthOfYear rdf:type rdf:Property ;
    rdfs:label 'Month Of Year' ;
    rdfs:comment 'Specific month when the recurring schedule executes (1-12). Applicable for annual and semiannual frequencies.' ;
    rdfs:domain ind:RecurringSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nextExecutionDate rdf:type rdf:Property ;
    rdfs:label 'Next Execution Date' ;
    rdfs:comment 'Calculated date when the recurring schedule will next execute based on frequency rules and business day adjustments.' ;
    rdfs:domain ind:RecurringSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:notificationEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Notification Enabled Flag' ;
    rdfs:comment 'Indicates whether system notifications are sent when scheduled transactions are generated or require action.' ;
    rdfs:domain ind:RecurringSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:occurrenceCount rdf:type rdf:Property ;
    rdfs:label 'Occurrence Count' ;
    rdfs:comment 'Current count of how many times this recurring schedule has executed since activation.' ;
    rdfs:domain ind:RecurringSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ownerDepartmentCode rdf:type rdf:Property ;
    rdfs:label 'Owner Department Code' ;
    rdfs:comment 'Code identifying the institutional department or unit responsible for maintaining and approving this recurring schedule.' ;
    rdfs:domain ind:RecurringSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleDescription rdf:type rdf:Property ;
    rdfs:label 'Schedule Description' ;
    rdfs:comment 'Detailed description of the recurring schedule including its business purpose, scope, and application within institutional financial operations.' ;
    rdfs:domain ind:RecurringSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalDeadlineDaysPrior rdf:type rdf:Property ;
    rdfs:label 'Approval Deadline Days Prior' ;
    rdfs:comment 'Number of days before the pay date that all payroll approvals must be completed by supervisors and payroll administrators.' ;
    rdfs:domain ind:PayrollCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:calendarCode rdf:type rdf:Property ;
    rdfs:label 'Calendar Code' ;
    rdfs:comment 'Business identifier code for the payroll calendar used in external reporting and system integration (e.g., BIWEEKLY_STAFF, MONTHLY_FACULTY).' ;
    rdfs:domain ind:PayrollCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calendarName rdf:type rdf:Property ;
    rdfs:label 'Calendar Name' ;
    rdfs:comment 'Human-readable name of the payroll calendar (e.g., Bi-Weekly Staff Payroll, Monthly Faculty Payroll).' ;
    rdfs:domain ind:PayrollCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defaultPayDayOfMonth rdf:type rdf:Property ;
    rdfs:label 'Default Pay Day Of Month' ;
    rdfs:comment 'The standard day of the month on which payroll is disbursed for monthly calendars (e.g., 25th of each month). Null for non-monthly calendars.' ;
    rdfs:domain ind:PayrollCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:defaultPayDayOfWeek rdf:type rdf:Property ;
    rdfs:label 'Default Pay Day Of Week' ;
    rdfs:comment 'The standard day of the week on which payroll is disbursed for this calendar (e.g., Friday for biweekly staff).' ;
    rdfs:domain ind:PayrollCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employeeGroup rdf:type rdf:Property ;
    rdfs:label 'Employee Group' ;
    rdfs:comment 'The employee classification group that this payroll calendar applies to, aligning with institutional workforce segmentation.' ;
    rdfs:domain ind:PayrollCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:holidayAdjustmentRule rdf:type rdf:Property ;
    rdfs:label 'Holiday Adjustment Rule' ;
    rdfs:comment 'Rule for adjusting pay dates when the scheduled pay date falls on a holiday or weekend.' ;
    rdfs:domain ind:PayrollCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:includesSummerPay rdf:type rdf:Property ;
    rdfs:label 'Includes Summer Pay' ;
    rdfs:comment 'Indicates whether this payroll calendar includes summer pay periods, relevant for academic calendars where faculty may have optional summer compensation.' ;
    rdfs:domain ind:PayrollCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isAcademicYearCalendar rdf:type rdf:Property ;
    rdfs:label 'Is Academic Year Calendar' ;
    rdfs:comment 'Indicates whether this payroll calendar follows the academic year schedule (True) or the fiscal year schedule (False).' ;
    rdfs:domain ind:PayrollCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:payFrequencyDays rdf:type rdf:Property ;
    rdfs:label 'Pay Frequency Days' ;
    rdfs:comment 'Number of days between pay periods (e.g., 14 for biweekly, 7 for weekly, 30 for monthly).' ;
    rdfs:domain ind:PayrollCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:payPeriodsPerYear rdf:type rdf:Property ;
    rdfs:label 'Pay Periods Per Year' ;
    rdfs:comment 'Total number of pay periods in a calendar year for this payroll calendar (e.g., 26 for biweekly, 12 for monthly).' ;
    rdfs:domain ind:PayrollCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:payrollProcessingSystem rdf:type rdf:Property ;
    rdfs:label 'Payroll Processing System' ;
    rdfs:comment 'The name or identifier of the payroll system used to process this calendar (e.g., Workday HCM, PeopleSoft, ADP).' ;
    rdfs:domain ind:PayrollCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timeEntryCutoffDaysPrior rdf:type rdf:Property ;
    rdfs:label 'Time Entry Cutoff Days Prior' ;
    rdfs:comment 'Number of days before the pay date that time entry must be submitted and approved for inclusion in the payroll run.' ;
    rdfs:domain ind:PayrollCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:applicableJobFamilies rdf:type rdf:Property ;
    rdfs:label 'Applicable Job Families' ;
    rdfs:comment 'Comma-separated list of job family codes or names to which this competency framework applies.' ;
    rdfs:domain ind:CompetencyFramework ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competencyCount rdf:type rdf:Property ;
    rdfs:label 'Competency Count' ;
    rdfs:comment 'Total number of individual competencies defined within this framework.' ;
    rdfs:domain ind:CompetencyFramework ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:externalReferenceUrl rdf:type rdf:Property ;
    rdfs:label 'External Reference Url' ;
    rdfs:comment 'Web address linking to external documentation, industry standards, or source materials for this competency framework.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:frameworkCategory rdf:type rdf:Property ;
    rdfs:label 'Framework Category' ;
    rdfs:comment 'Organizational scope and applicability category of the competency framework.' ;
    rdfs:domain ind:CompetencyFramework ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:integrationSystem rdf:type rdf:Property ;
    rdfs:label 'Integration System' ;
    rdfs:comment 'Name of the primary HR system or platform where this competency framework is implemented (e.g., \'Workday HCM\', \'SuccessFactors\', \'PeopleSoft\').' ;
    rdfs:domain ind:CompetencyFramework ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:multiLanguageSupportFlag rdf:type rdf:Property ;
    rdfs:label 'Multi Language Support Flag' ;
    rdfs:comment 'Indicates whether this competency framework has been translated and is available in multiple languages.' ;
    rdfs:domain ind:CompetencyFramework ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:proficiencyLevels rdf:type rdf:Property ;
    rdfs:label 'Proficiency Levels' ;
    rdfs:comment 'Number of proficiency or mastery levels defined in the framework rating scale (e.g., 3 for Basic/Intermediate/Advanced, 5 for a five-point scale).' ;
    rdfs:domain ind:CompetencyFramework ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:proficiencyScaleDescription rdf:type rdf:Property ;
    rdfs:label 'Proficiency Scale Description' ;
    rdfs:comment 'Textual description of the proficiency levels and rating scale used in this framework (e.g., \'1=Awareness, 2=Basic, 3=Intermediate, 4=Advanced, 5=Expert\').' ;
    rdfs:domain ind:CompetencyFramework ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purposeStatement rdf:type rdf:Property ;
    rdfs:label 'Purpose Statement' ;
    rdfs:comment 'Formal statement articulating the strategic purpose and business objectives the competency framework is designed to support.' ;
    rdfs:domain ind:CompetencyFramework ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Compliance Flag' ;
    rdfs:comment 'Indicates whether this competency framework is required to meet specific regulatory or accreditation requirements.' ;
    rdfs:domain ind:CompetencyFramework ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryReference rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reference' ;
    rdfs:comment 'Citation or reference to the regulatory requirement, accreditation standard, or compliance mandate that this framework addresses.' ;
    rdfs:domain ind:CompetencyFramework ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceOrganization rdf:type rdf:Property ;
    rdfs:label 'Source Organization' ;
    rdfs:comment 'Name of the organization or body that developed or published the original competency framework (e.g., \'SHRM\', \'CUPA-HR\', \'Internal HR Development Team\').' ;
    rdfs:domain ind:CompetencyFramework ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceType rdf:type rdf:Property ;
    rdfs:label 'Source Type' ;
    rdfs:comment 'Origin classification of the competency framework indicating whether it was developed internally, adopted from external sources, or customized from industry standards.' ;
    rdfs:domain ind:CompetencyFramework ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usageScope rdf:type rdf:Property ;
    rdfs:label 'Usage Scope' ;
    rdfs:comment 'HR processes and applications in which this competency framework is utilized. [ENUM-REF-CANDIDATE: recruitment|performance_management|succession_planning|learning_development|compensation|career_pathing|talent_assessment — promote to reference product]' ;
    rdfs:domain ind:CompetencyFramework ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:libraryId rdf:type rdf:Property ;
    rdfs:label 'Library Id' ;
    rdfs:comment 'Primary key for library' ;
    rdfs:domain ind:Library ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:annualCirculationVolume rdf:type rdf:Property ;
    rdfs:label 'Annual Circulation Volume' ;
    rdfs:comment 'Total number of items circulated (checked out) in the most recent fiscal year. Key performance metric for library usage and collection relevance.' ;
    rdfs:domain ind:Library ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:annualGateCount rdf:type rdf:Property ;
    rdfs:label 'Annual Gate Count' ;
    rdfs:comment 'Total number of patron visits to the library facility in the most recent fiscal year, typically measured by electronic gate counters.' ;
    rdfs:domain ind:Library ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:collectionSizeDigital rdf:type rdf:Property ;
    rdfs:label 'Collection Size Digital' ;
    rdfs:comment 'Total number of digital items and electronic resources accessible through the library including e-books, e-journals, databases, and digital archives.' ;
    rdfs:domain ind:Library ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:collectionSizePhysical rdf:type rdf:Property ;
    rdfs:label 'Collection Size Physical' ;
    rdfs:comment 'Total number of physical items in the library collection including books, journals, media, and other tangible materials. Reported to IPEDS and accreditation bodies.' ;
    rdfs:domain ind:Library ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:computerWorkstationCount rdf:type rdf:Property ;
    rdfs:label 'Computer Workstation Count' ;
    rdfs:comment 'Number of public computer workstations available for patron use.' ;
    rdfs:domain ind:Library ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:directorName rdf:type rdf:Property ;
    rdfs:label 'Director Name' ;
    rdfs:comment 'Name of the current library director or dean of libraries responsible for overall library operations and strategic direction.' ;
    rdfs:domain ind:Library ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discoveryServiceCode rdf:type rdf:Property ;
    rdfs:label 'Discovery Service Code' ;
    rdfs:comment 'Code identifying the discovery service or search platform used for patron resource discovery. Examples include Primo, Summon, EBSCO Discovery Service, WorldCat Discovery.' ;
    rdfs:domain ind:Library ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:floorLocation rdf:type rdf:Property ;
    rdfs:label 'Floor Location' ;
    rdfs:comment 'Specific floor or floors within the building where library services and collections are located. May include multiple floors or specific room numbers.' ;
    rdfs:domain ind:Library ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ilsSystemCode rdf:type rdf:Property ;
    rdfs:label 'Ils System Code' ;
    rdfs:comment 'Code identifying the integrated library system or library services platform used by this library. Common systems include Alma (Ex Libris), Sierra (Innovative), Koha (open source), FOLIO (open source), Symphony (SirsiDynix), and Voyager (Ex Libris legacy).' ;
    rdfs:domain ind:Library ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastAccreditationReviewDate rdf:type rdf:Property ;
    rdfs:label 'Last Accreditation Review Date' ;
    rdfs:comment 'Date of the most recent accreditation review or assessment of library services and resources.' ;
    rdfs:domain ind:Library ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:libraryType rdf:type rdf:Property ;
    rdfs:label 'Library Type' ;
    rdfs:comment 'Classification of the library based on its function and scope within the institution. Main libraries serve as central hubs, branch libraries serve specific campuses, departmental libraries support specific academic departments, special collections house rare materials, digital libraries provide electronic resources, and archives preserve institutional records.' ;
    rdfs:domain ind:Library ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oclcSymbol rdf:type rdf:Property ;
    rdfs:label 'Oclc Symbol' ;
    rdfs:comment 'Unique OCLC institution symbol used for interlibrary loan, cataloging, and resource sharing through WorldCat and other OCLC services.' ;
    rdfs:domain ind:Library ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatingHoursWeekly rdf:type rdf:Property ;
    rdfs:label 'Operating Hours Weekly' ;
    rdfs:comment 'Total number of hours the library is open to patrons during a typical week during the academic term. Used for service level reporting and staffing planning.' ;
    rdfs:domain ind:Library ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:staffCountFte rdf:type rdf:Property ;
    rdfs:label 'Staff Count Fte' ;
    rdfs:comment 'Total number of library staff measured in full-time equivalents, including librarians, support staff, and student workers. Reported to IPEDS.' ;
    rdfs:domain ind:Library ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:studyRoomCount rdf:type rdf:Property ;
    rdfs:label 'Study Room Count' ;
    rdfs:comment 'Number of individual or group study rooms available for patron reservation and use.' ;
    rdfs:domain ind:Library ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:supportsInterlibraryLoan rdf:type rdf:Property ;
    rdfs:label 'Supports Interlibrary Loan' ;
    rdfs:comment 'Indicates whether this library participates in interlibrary loan services, allowing patrons to borrow materials from other libraries and lending materials to external institutions.' ;
    rdfs:domain ind:Library ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supportsOerTracking rdf:type rdf:Property ;
    rdfs:label 'Supports Oer Tracking' ;
    rdfs:comment 'Indicates whether this library tracks and promotes open educational resources as part of its collection and services to reduce textbook costs for students.' ;
    rdfs:domain ind:Library ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:totalSquareFootage rdf:type rdf:Property ;
    rdfs:label 'Total Square Footage' ;
    rdfs:comment 'Total physical space of the library facility measured in square feet. Used for space planning, capacity analysis, and reporting to accreditation bodies.' ;
    rdfs:domain ind:Library ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:attachmentAllowed rdf:type rdf:Property ;
    rdfs:label 'Attachment Allowed' ;
    rdfs:comment 'Indicates whether file attachments can be included with notifications generated from this template.' ;
    rdfs:domain ind:NotificationTemplate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:audienceType rdf:type rdf:Property ;
    rdfs:label 'Audience Type' ;
    rdfs:comment 'The primary recipient audience segment for which this notification template is designed.' ;
    rdfs:domain ind:Technology ;
