    rdfs:range xsd:string .

ind:donorSegment rdf:type rdf:Property ;
    rdfs:label 'Donor Segment' ;
    rdfs:comment 'The target donor segment or constituency group that this stewardship plan is designed to engage (e.g., major donors, alumni, corporate partners, foundation supporters).' ;
    rdfs:domain ind:StewardshipPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engagementFrequency rdf:type rdf:Property ;
    rdfs:label 'Engagement Frequency' ;
    rdfs:comment 'The planned frequency of donor touchpoints and stewardship activities under this plan.' ;
    rdfs:domain ind:StewardshipPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventInvitationFlag rdf:type rdf:Property ;
    rdfs:label 'Event Invitation Flag' ;
    rdfs:comment 'Indicates whether donors in this stewardship plan are invited to exclusive donor events and recognition ceremonies.' ;
    rdfs:domain ind:StewardshipPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:giftAcknowledgmentTemplate rdf:type rdf:Property ;
    rdfs:label 'Gift Acknowledgment Template' ;
    rdfs:comment 'The name or identifier of the gift acknowledgment letter template used for donors in this stewardship plan.' ;
    rdfs:domain ind:StewardshipPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:giftLevelMaximum rdf:type rdf:Property ;
    rdfs:label 'Gift Level Maximum' ;
    rdfs:comment 'The maximum gift amount threshold for this stewardship plan tier. Null indicates no upper limit.' ;
    rdfs:domain ind:StewardshipPlan ;
    rdf:type owl:DatatypeProperty ;
