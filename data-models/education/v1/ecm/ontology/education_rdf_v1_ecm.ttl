    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fundId rdf:type rdf:Property ;
    rdfs:label 'Fund Id' ;
    rdfs:comment 'Reference to the institutional fund or account that will receive and manage the gift proceeds.' ;
