    rdfs:range xsd:decimal .

ind:commitmentAmount rdf:type rdf:Property ;
    rdfs:label 'Commitment Amount' ;
    rdfs:comment 'Total monetary value pledged by the donor under this gift agreement, representing the full commitment before any payments.' ;
    rdfs:domain ind:GiftAgreement ;
    rdf:type owl:DatatypeProperty ;
