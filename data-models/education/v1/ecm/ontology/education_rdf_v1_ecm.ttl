ind:prospectStateProvince rdf:type rdf:Property ;
    rdfs:label 'Prospect State Province' ;
    rdfs:comment 'State or province of the prospective student-athlete\'s residence.' ;
    rdfs:domain ind:Recruit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ratingSource rdf:type rdf:Property ;
    rdfs:label 'Rating Source' ;
    rdfs:comment 'Name of the recruiting service or organization that provided the prospect rating (e.g., 247Sports, Rivals, ESPN).' ;
    rdfs:domain ind:Recruit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recruitingClassYear rdf:type rdf:Property ;
    rdfs:label 'Recruiting Class Year' ;
    rdfs:comment 'Academic year in which the prospect is expected to enroll and begin competing (e.g., 2025 for Fall 2025 enrollment).' ;
    rdfs:domain ind:Athletics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recruitingStatus rdf:type rdf:Property ;
    rdfs:label 'Recruiting Status' ;
    rdfs:comment 'Current stage of the recruiting process for this prospect. Tracks progression from initial identification through commitment or withdrawal. [ENUM-REF-CANDIDATE: identified|contacted|evaluated|offered|committed|signed|declined|withdrawn — promote to reference product]' ;
    rdfs:domain ind:Recruit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recruitingStatusDate rdf:type rdf:Property ;
    rdfs:label 'Recruiting Status Date' ;
    rdfs:comment 'Date when the current recruiting status was assigned or last updated.' ;
    rdfs:domain ind:Recruit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:recruitingTerritory rdf:type rdf:Property ;
    rdfs:label 'Recruiting Territory' ;
    rdfs:comment 'Geographic region or territory assigned to the recruiting coach responsible for this prospect (e.g., Southeast, Midwest, California).' ;
    rdfs:domain ind:Recruit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:satScore rdf:type rdf:Property ;
    rdfs:label 'Sat Score' ;
    rdfs:comment 'Prospect\'s SAT composite score, used in conjunction with GPA for NCAA initial eligibility determination.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:scholarshipOfferDate rdf:type rdf:Property ;
    rdfs:label 'Scholarship Offer Date' ;
    rdfs:comment 'Date on which an athletic scholarship offer was extended to the prospect, if applicable.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scholarshipOfferExtended rdf:type rdf:Property ;
    rdfs:label 'Scholarship Offer Extended' ;
    rdfs:comment 'Indicates whether an athletic scholarship offer has been extended to the prospect.' ;
    rdfs:domain ind:Education ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:unofficialVisitCount rdf:type rdf:Property ;
    rdfs:label 'Unofficial Visit Count' ;
    rdfs:comment 'Number of unofficial visits the prospect has made to the institution at their own expense.' ;
    rdfs:domain ind:Recruit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:weightPounds rdf:type rdf:Property ;
    rdfs:label 'Weight Pounds' ;
    rdfs:comment 'Prospect\'s weight measured in pounds, relevant for sport-specific evaluation.' ;
    rdfs:domain ind:Athletics ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:recruitingContactId rdf:type rdf:Property ;
    rdfs:label 'Recruiting Contact Id' ;
    rdfs:comment 'Unique identifier for each recruiting contact interaction record. Primary key for the recruiting contact transaction.' ;
    rdfs:domain ind:RecruitingContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryRecruitingEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Recruiting Employee Id' ;
    rdfs:comment 'Identifier of the athletics staff member (coach, recruiting coordinator, or authorized personnel) who initiated or conducted the recruiting contact.' ;
    rdfs:domain ind:RecruitingContact ;
    rdf:type owl:ObjectProperty ;
