ind:isPrimaryAccount rdf:type rdf:Property ;
    rdfs:label 'Is Primary Account' ;
    rdfs:comment 'Boolean flag indicating whether this is the primary or default bank account for payments to this vendor. Only one account per vendor should be marked as primary.' ;
    rdfs:domain ind:VendorBankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maximumPaymentAmount rdf:type rdf:Property ;
    rdfs:label 'Maximum Payment Amount' ;
    rdfs:comment 'The maximum single payment amount allowed for this account, often set for risk management and fraud prevention purposes.' ;
    rdfs:domain ind:VendorBankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumPaymentAmount rdf:type rdf:Property ;
    rdfs:label 'Minimum Payment Amount' ;
    rdfs:comment 'The minimum payment amount threshold required for processing payments to this account, if applicable.' ;
    rdfs:domain ind:VendorBankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentMethodSupported rdf:type rdf:Property ;
    rdfs:label 'Payment Method Supported' ;
    rdfs:comment 'The primary payment method or electronic funds transfer mechanism supported by this bank account (ACH for US, SEPA for Europe, BACS for UK, etc.).' ;
    rdfs:domain ind:VendorBankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:swiftCode rdf:type rdf:Property ;
    rdfs:label 'Swift Code' ;
    rdfs:comment 'The international bank identifier code (BIC/SWIFT) used for international wire transfers and cross-border payments. Required for international vendor payments.' ;
    rdfs:domain ind:VendorBankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxReportingRequired rdf:type rdf:Property ;
    rdfs:label 'Tax Reporting Required' ;
    rdfs:comment 'Boolean flag indicating whether payments to this account require tax reporting (e.g., 1099 reporting for US vendors).' ;
    rdfs:domain ind:VendorBankAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regionId rdf:type rdf:Property ;
    rdfs:label 'Region Id' ;
    rdfs:comment 'Reference to the geographic or organizational region to which this work location belongs.' ;
