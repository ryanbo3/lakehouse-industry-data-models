ind:locationType rdf:type rdf:Property ;
    rdfs:label 'Location Type' ;
    rdfs:comment 'Classification of the work location based on its operational function within the insurance enterprise.' ;
    rdfs:domain ind:WorkLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:openedDate rdf:type rdf:Property ;
    rdfs:label 'Opened Date' ;
    rdfs:comment 'Date when the work location was officially opened for business operations.' ;
    rdfs:domain ind:WorkLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:parkingSpaces rdf:type rdf:Property ;
    rdfs:label 'Parking Spaces' ;
    rdfs:comment 'Number of parking spaces available at the work location.' ;
    rdfs:domain ind:WorkLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:seatingCapacity rdf:type rdf:Property ;
    rdfs:label 'Seating Capacity' ;
    rdfs:comment 'Maximum number of employees that can be seated at the work location.' ;
    rdfs:domain ind:WorkLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:securityLevel rdf:type rdf:Property ;
    rdfs:label 'Security Level' ;
    rdfs:comment 'Classification of physical security measures in place at the work location.' ;
    rdfs:domain ind:WorkLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:squareFootage rdf:type rdf:Property ;
    rdfs:label 'Square Footage' ;
    rdfs:comment 'Total square footage of the work location facility.' ;
    rdfs:domain ind:WorkLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:jobRequisitionId rdf:type rdf:Property ;
    rdfs:label 'Job Requisition Id' ;
    rdfs:comment 'Reference to the job opening for which the candidate is being interviewed.' ;
    rdfs:domain ind:InterviewScorecard ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Requisition .

ind:advanceToNextRound rdf:type rdf:Property ;
    rdfs:label 'Advance To Next Round' ;
    rdfs:comment 'Indicator of whether the interviewer recommends advancing the candidate to the next interview round.' ;
    rdfs:domain ind:InterviewScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:candidateSalaryExpectation rdf:type rdf:Property ;
    rdfs:label 'Candidate Salary Expectation' ;
    rdfs:comment 'The salary amount or range that the candidate indicated as their compensation expectation.' ;
    rdfs:domain ind:InterviewScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:communicationScore rdf:type rdf:Property ;
    rdfs:label 'Communication Score' ;
    rdfs:comment 'Numeric rating of the candidate\'s verbal and written communication effectiveness.' ;
    rdfs:domain ind:InterviewScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:culturalFitScore rdf:type rdf:Property ;
    rdfs:label 'Cultural Fit Score' ;
    rdfs:comment 'Numeric rating of how well the candidate aligns with the organization\'s values and culture.' ;
    rdfs:domain ind:InterviewScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:detailedFeedback rdf:type rdf:Property ;
    rdfs:label 'Detailed Feedback' ;
    rdfs:comment 'Comprehensive written feedback from the interviewer covering all aspects of the candidate\'s performance and interview responses.' ;
    rdfs:domain ind:InterviewScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceIndustryKnowledgeScore rdf:type rdf:Property ;
    rdfs:label 'Insurance Industry Knowledge Score' ;
    rdfs:comment 'Numeric rating of the candidate\'s understanding of life insurance, annuities, underwriting, actuarial concepts, and regulatory requirements specific to the insurance industry.' ;
    rdfs:domain ind:InterviewScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:interviewDate rdf:type rdf:Property ;
    rdfs:label 'Interview Date' ;
    rdfs:comment 'Date when the interview was conducted.' ;
    rdfs:domain ind:InterviewScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:interviewDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Interview Duration Minutes' ;
    rdfs:comment 'Total length of the interview session measured in minutes.' ;
    rdfs:domain ind:InterviewScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:leadershipPotentialScore rdf:type rdf:Property ;
    rdfs:label 'Leadership Potential Score' ;
    rdfs:comment 'Numeric rating of the candidate\'s demonstrated or potential leadership capabilities.' ;
    rdfs:domain ind:InterviewScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overallScore rdf:type rdf:Property ;
    rdfs:label 'Overall Score' ;
    rdfs:comment 'Aggregate numeric score representing the candidate\'s overall performance, typically on a scale such as 1-5 or 1-10.' ;
    rdfs:domain ind:InterviewScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:problemSolvingScore rdf:type rdf:Property ;
    rdfs:label 'Problem Solving Score' ;
    rdfs:comment 'Numeric rating of the candidate\'s analytical thinking and problem-solving abilities.' ;
    rdfs:domain ind:InterviewScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:questionsAsked rdf:type rdf:Property ;
    rdfs:label 'Questions Asked' ;
    rdfs:comment 'List or summary of the key questions posed to the candidate during the interview session.' ;
    rdfs:domain ind:InterviewScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recommendationNotes rdf:type rdf:Property ;
    rdfs:label 'Recommendation Notes' ;
    rdfs:comment 'Additional notes and context supporting the interviewer\'s hiring recommendation decision.' ;
    rdfs:domain ind:InterviewScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:redFlagsIdentified rdf:type rdf:Property ;
    rdfs:label 'Red Flags Identified' ;
    rdfs:comment 'Documentation of any concerns, warning signs, or disqualifying factors observed during the interview.' ;
    rdfs:domain ind:InterviewScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relocationRequired rdf:type rdf:Property ;
    rdfs:label 'Relocation Required' ;
    rdfs:comment 'Indicator of whether the candidate would need to relocate for this position.' ;
    rdfs:domain ind:InterviewScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:relocationWillingness rdf:type rdf:Property ;
    rdfs:label 'Relocation Willingness' ;
    rdfs:comment 'The candidate\'s expressed willingness to relocate if required for the position.' ;
    rdfs:domain ind:InterviewScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Reviewed Timestamp' ;
    rdfs:comment 'Date and time when the scorecard was reviewed by the hiring manager or HR team.' ;
    rdfs:domain ind:InterviewScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:salaryExpectationDiscussed rdf:type rdf:Property ;
    rdfs:label 'Salary Expectation Discussed' ;
    rdfs:comment 'Indicator of whether compensation expectations were discussed during the interview.' ;
    rdfs:domain ind:InterviewScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scorecardStatus rdf:type rdf:Property ;
