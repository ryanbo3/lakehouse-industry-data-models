    rdfs:comment 'Version identifier of the interview scorecard template used for this evaluation.' ;
    rdfs:domain ind:InterviewScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:startDateAvailability rdf:type rdf:Property ;
    rdfs:label 'Start Date Availability' ;
    rdfs:comment 'Earliest date the candidate indicated they would be available to begin employment.' ;
    rdfs:domain ind:InterviewScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:strengthsSummary rdf:type rdf:Property ;
    rdfs:label 'Strengths Summary' ;
    rdfs:comment 'Narrative description of the candidate\'s key strengths and positive attributes observed during the interview.' ;
    rdfs:domain ind:InterviewScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submittedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Submitted Timestamp' ;
    rdfs:comment 'Date and time when the interviewer submitted the completed scorecard for review.' ;
    rdfs:domain ind:InterviewScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:technicalCompetencyScore rdf:type rdf:Property ;
    rdfs:label 'Technical Competency Score' ;
    rdfs:comment 'Numeric rating of the candidate\'s technical skills and domain knowledge relevant to the position.' ;
    rdfs:domain ind:InterviewScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:weaknessesSummary rdf:type rdf:Property ;
    rdfs:label 'Weaknesses Summary' ;
    rdfs:comment 'Narrative description of areas where the candidate showed gaps, weaknesses, or opportunities for improvement.' ;
    rdfs:domain ind:InterviewScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payrollCalendarId rdf:type rdf:Property ;
    rdfs:label 'Payroll Calendar Id' ;
    rdfs:comment 'Reference to the payroll calendar that defines the schedule and rules for this period.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PayrollCalendar .

ind:checkDate rdf:type rdf:Property ;
    rdfs:label 'Check Date' ;
