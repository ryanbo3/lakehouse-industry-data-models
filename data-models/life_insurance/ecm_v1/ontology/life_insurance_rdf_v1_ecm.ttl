ind:locationName rdf:type rdf:Property ;
    rdfs:label 'Location Name' ;
    rdfs:comment 'Official name of the work location (e.g., \'New York Regional Office\', \'Chicago Claims Center\').' ;
    rdfs:domain ind:WorkLocation ;
