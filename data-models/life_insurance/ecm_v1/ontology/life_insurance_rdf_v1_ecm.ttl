    rdfs:comment 'Code identifying the employee group or division using this payroll calendar (e.g., SALARIED, HOURLY, EXECUTIVE, UNION_A).' ;
    rdfs:domain ind:PayrollCalendar ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payrollProcessingDate rdf:type rdf:Property ;
    rdfs:label 'Payroll Processing Date' ;
