    rdfs:comment 'Current workflow state of the interview scorecard in the evaluation and approval process.' ;
    rdfs:domain ind:InterviewScorecard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scorecardTemplateVersion rdf:type rdf:Property ;
