    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Region .

ind:buildingOwnership rdf:type rdf:Property ;
    rdfs:label 'Building Ownership' ;
    rdfs:comment 'Indicates whether the work location is owned, leased, or shared by the organization.' ;
