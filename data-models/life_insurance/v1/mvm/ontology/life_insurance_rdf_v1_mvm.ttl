ind:termLifePremiumAmount rdf:type rdf:Property ;
    rdfs:label 'Term Life Premium Amount' ;
    rdfs:comment 'Total premium amount for term life insurance policies issued during this period.' ;
    rdfs:domain ind:ProductionActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalPremiumAmount rdf:type rdf:Property ;
    rdfs:label 'Total Premium Amount' ;
    rdfs:comment 'Total premium amount collected or placed by the producer during this period across all products.' ;
    rdfs:domain ind:ProductionActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:universalLifeCount rdf:type rdf:Property ;
    rdfs:label 'Universal Life Count' ;
    rdfs:comment 'Number of universal life insurance policies issued during this period.' ;
    rdfs:domain ind:ProductionActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:universalLifePremiumAmount rdf:type rdf:Property ;
    rdfs:label 'Universal Life Premium Amount' ;
    rdfs:comment 'Total premium amount for universal life insurance policies issued during this period.' ;
    rdfs:domain ind:ProductionActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vulCount rdf:type rdf:Property ;
    rdfs:label 'Vul Count' ;
    rdfs:comment 'Number of variable universal life insurance policies issued during this period.' ;
    rdfs:domain ind:ProductionActivity ;
    rdf:type owl:DatatypeProperty ;
