ind:trainingCategory rdf:type rdf:Property ;
    rdfs:label 'Training Category' ;
    rdfs:comment 'Business category of the training such as AML/BSA, product training (IUL, FIA, GMWB), suitability, ethics, sales practices, or carrier-specific certification. [ENUM-REF-CANDIDATE: aml_bsa|product_iul|product_fia|product_gmwb|suitability|ethics|sales_practices|carrier_certification|dol_fiduciary|state_ce|finra_compliance — promote to reference product]' ;
    rdfs:domain ind:ProducerTraining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingCostAmount rdf:type rdf:Property ;
