ind:vulPremiumAmount rdf:type rdf:Property ;
    rdfs:label 'Vul Premium Amount' ;
    rdfs:comment 'Total premium amount for variable universal life insurance policies issued during this period.' ;
    rdfs:domain ind:ProductionActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wholeLifeCount rdf:type rdf:Property ;
    rdfs:label 'Whole Life Count' ;
    rdfs:comment 'Number of whole life insurance policies issued during this period.' ;
    rdfs:domain ind:ProductionActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:wholeLifePremiumAmount rdf:type rdf:Property ;
    rdfs:label 'Whole Life Premium Amount' ;
    rdfs:comment 'Total premium amount for whole life insurance policies issued during this period.' ;
    rdfs:domain ind:ProductionActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:parentAgencyId rdf:type rdf:Property ;
    rdfs:label 'Parent Agency Id' ;
    rdfs:comment 'Reference to the parent agency in multi-tier distribution hierarchies, enabling upline agency tracking for MGAs and BGAs.' ;
    rdfs:domain ind:Agency ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Agency .

ind:agencyCode rdf:type rdf:Property ;
    rdfs:label 'Agency Code' ;
    rdfs:comment 'Carrier-assigned unique code for the agency used in policy administration and commission systems.' ;
    rdfs:domain ind:Agency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agencyType rdf:type rdf:Property ;
    rdfs:label 'Agency Type' ;
    rdfs:comment 'Classification of the agency entity: BGA (Brokerage General Agency), MGA (Managing General Agent), GA (General Agent), IMO (Independent Marketing Organization), NMO (National Marketing Organization), or Captive Agency.' ;
    rdfs:domain ind:Agency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brokerDealerCrdNumber rdf:type rdf:Property ;
    rdfs:label 'Broker Dealer Crd Number' ;
    rdfs:comment 'FINRA CRD number of the broker-dealer firm the agency is affiliated with for variable product distribution.' ;
    rdfs:domain ind:Agent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Contract Effective Date' ;
    rdfs:comment 'Date when the agency\'s distribution contract with the carrier became effective.' ;
    rdfs:domain ind:Agency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contractTerminationDate rdf:type rdf:Property ;
    rdfs:label 'Contract Termination Date' ;
    rdfs:comment 'Date when the agency\'s distribution contract was terminated, if applicable.' ;
    rdfs:domain ind:Agency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dbaName rdf:type rdf:Property ;
    rdfs:label 'Dba Name' ;
    rdfs:comment 'Trade name or DBA name under which the agency operates in the market, if different from legal name.' ;
    rdfs:domain ind:Agency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:linesOfAuthority rdf:type rdf:Property ;
    rdfs:label 'Lines Of Authority' ;
    rdfs:comment 'Comma-separated list of insurance lines the agency is authorized to sell (e.g., Life, Annuity, Accident and Health, Variable Products).' ;
    rdfs:domain ind:Agent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:principalOfficerName rdf:type rdf:Property ;
    rdfs:label 'Principal Officer Name' ;
    rdfs:comment 'Full name of the principal officer or designated responsible party for the agency.' ;
    rdfs:domain ind:Agency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:websiteUrl rdf:type rdf:Property ;
    rdfs:label 'Website Url' ;
    rdfs:comment 'Public website URL for the agency, if available.' ;
    rdfs:domain ind:Agency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryAgencyProducerId rdf:type rdf:Property ;
    rdfs:label 'Primary Agency Producer Id' ;
    rdfs:comment 'Reference to the individual producer in this affiliation relationship.' ;
    rdfs:domain ind:AgencyProducerAffiliation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Producer .

ind:affiliationNotes rdf:type rdf:Property ;
    rdfs:label 'Affiliation Notes' ;
    rdfs:comment 'Free-form text field for capturing additional information, special circumstances, or administrative notes related to this agency-producer affiliation. Used for internal documentation and context.' ;
    rdfs:domain ind:AgencyProducerAffiliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affiliationStatus rdf:type rdf:Property ;
    rdfs:label 'Affiliation Status' ;
    rdfs:comment 'Current lifecycle status of the agency-producer affiliation. Active indicates the relationship is in force, inactive indicates temporarily not producing, suspended indicates regulatory or compliance hold, pending indicates awaiting approval or onboarding completion, terminated indicates relationship has ended.' ;
    rdfs:domain ind:AgencyProducerAffiliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affiliationType rdf:type rdf:Property ;
    rdfs:label 'Affiliation Type' ;
    rdfs:comment 'Classification of the relationship between the producer and agency. Employed indicates W-2 employee status, contracted indicates 1099 independent contractor, sub-agent indicates hierarchical sub-relationship, independent indicates non-exclusive arrangement, captive indicates exclusive arrangement, broker indicates broker-dealer relationship.' ;
    rdfs:domain ind:AgencyProducerAffiliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryAgencyFlag rdf:type rdf:Property ;
    rdfs:label 'Primary Agency Flag' ;
    rdfs:comment 'Indicates whether this agency is the producer\'s primary or home agency affiliation. True for primary agency, false for secondary or additional affiliations. Used in multi-agency affiliation scenarios common in independent distribution channels.' ;
    rdfs:domain ind:AgencyProducerAffiliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:variableProductsAuthorizedFlag rdf:type rdf:Property ;
    rdfs:label 'Variable Products Authorized Flag' ;
    rdfs:comment 'Indicates whether the producer is authorized to sell variable life insurance and variable annuity products through this agency affiliation. True if authorized, false if not. Requires active FINRA registration and broker-dealer affiliation.' ;
    rdfs:domain ind:AgencyProducerAffiliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:templateId rdf:type rdf:Property ;
    rdfs:label 'Template Id' ;
    rdfs:comment 'Foreign key linking to document.document_template. Business justification: Documents are generated from templates. A policy contract document is created from a policy_contract_template. Many documents can be generated from one template (N:1). No bidirectional conflict. Stron' ;
    rdfs:domain ind:LifeInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Template .

ind:archivedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Archived Timestamp' ;
    rdfs:comment 'Date and time when the document was moved to archive storage. Tracks transition from active to archived state per retention policy.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:destroyedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Destroyed Timestamp' ;
    rdfs:comment 'Date and time when the document was destroyed per retention policy. Audit trail for compliance with record destruction requirements.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:documentCategory rdf:type rdf:Property ;
    rdfs:label 'Document Category' ;
    rdfs:comment 'High-level category grouping for the document type. Used for broad classification and filtering of document inventory. [ENUM-REF-CANDIDATE: policy|application|illustration|underwriting|claim|annuity|regulatory|disclosure|correspondence|form — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentDescription rdf:type rdf:Property ;
    rdfs:label 'Document Description' ;
    rdfs:comment 'Detailed description of the document content, purpose, and context. Provides additional metadata for search and classification.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentNumber rdf:type rdf:Property ;
    rdfs:label 'Document Number' ;
    rdfs:comment 'Business identifier for the document. Human-readable unique number assigned to the document for tracking and reference purposes.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eDeliveryConsentFlag rdf:type rdf:Property ;
    rdfs:label 'E Delivery Consent Flag' ;
    rdfs:comment 'Indicates whether the policyholder has consented to electronic delivery of this document type. True if e-delivery is authorized, false if paper delivery required.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fileFormat rdf:type rdf:Property ;
    rdfs:label 'File Format' ;
    rdfs:comment 'Technical file format of the stored document. Identifies the MIME type or file extension for retrieval and rendering. [ENUM-REF-CANDIDATE: pdf|docx|tiff|jpeg|png|xml|html|txt — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fileSizeBytes rdf:type rdf:Property ;
    rdfs:label 'File Size Bytes' ;
    rdfs:comment 'Size of the document file in bytes. Used for storage management and transmission planning.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hash rdf:type rdf:Property ;
    rdfs:label 'Hash' ;
    rdfs:comment 'Cryptographic hash of the document content. Used for integrity verification, tamper detection, and duplicate detection.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:indexedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Indexed Timestamp' ;
    rdfs:comment 'Date and time when the document was indexed for search and retrieval. Tracks completion of document imaging and metadata extraction processes.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:isLatestVersion rdf:type rdf:Property ;
    rdfs:label 'Is Latest Version' ;
    rdfs:comment 'Indicates whether this document record represents the most current version. True if this is the active version, false if superseded.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:legalHoldFlag rdf:type rdf:Property ;
    rdfs:label 'Legal Hold Flag' ;
    rdfs:comment 'Indicates whether this document is subject to a legal hold and must be preserved beyond normal retention schedules. True if under legal hold, false otherwise.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lifecycleStatus rdf:type rdf:Property ;
    rdfs:label 'Lifecycle Status' ;
    rdfs:comment 'Current state of the document in its lifecycle. Tracks progression from draft through active use to archival or destruction per retention policy.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originationChannel rdf:type rdf:Property ;
    rdfs:label 'Origination Channel' ;
    rdfs:comment 'Channel or method through which the document was received or created. Identifies the source interface for document intake. [ENUM-REF-CANDIDATE: web|mobile|email|fax|mail|agent_portal|customer_portal|call_center|branch — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pageCount rdf:type rdf:Property ;
    rdfs:label 'Page Count' ;
    rdfs:comment 'Number of pages in the document. Relevant for printed documents and multi-page electronic files.' ;
    rdfs:domain ind:LifeInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:regulatoryBody rdf:type rdf:Property ;
    rdfs:label 'Regulatory Body' ;
    rdfs:comment 'Name of the regulatory body associated with this document. Examples include state Department of Insurance, NAIC, SEC, FINRA, IRS.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryFilingFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Filing Flag' ;
    rdfs:comment 'Indicates whether this document is a regulatory filing submitted to or received from a regulatory body. True if regulatory filing, false otherwise.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:retentionEndDate rdf:type rdf:Property ;
    rdfs:label 'Retention End Date' ;
    rdfs:comment 'Date when the document retention period expires and the document becomes eligible for destruction. Calculated based on retention category and applicable regulations.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:signatureRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Signature Required Flag' ;
    rdfs:comment 'Indicates whether this document requires a signature for validity. True if signature is mandatory, false otherwise.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:signatureStatus rdf:type rdf:Property ;
    rdfs:label 'Signature Status' ;
    rdfs:comment 'Current status of signature collection for this document. Tracks progression through signature workflow.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageLocationUri rdf:type rdf:Property ;
    rdfs:label 'Storage Location Uri' ;
    rdfs:comment 'Uniform Resource Identifier pointing to the physical or logical storage location of the document file. May reference cloud storage, content management system, or file system path.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:title rdf:type rdf:Property ;
    rdfs:label 'Title' ;
    rdfs:comment 'Descriptive title or name of the document. Human-readable label that summarizes the document content or purpose.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supersededByVersionId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Version Id' ;
    rdfs:comment 'Reference to the document_version_id that supersedes this version. Null if this is the current active version. Enables version chain navigation.' ;
    rdfs:domain ind:Version ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Version .

ind:authorName rdf:type rdf:Property ;
    rdfs:label 'Author Name' ;
    rdfs:comment 'Name of the individual or system user who created or authored this document version. Used for audit trail and accountability.' ;
    rdfs:domain ind:Version ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorRole rdf:type rdf:Property ;
    rdfs:label 'Author Role' ;
    rdfs:comment 'Organizational role or job function of the author at the time of version creation (e.g., Underwriter, Policy Services Representative, Compliance Officer, Actuarial Analyst).' ;
    rdfs:domain ind:Version ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checksumHash rdf:type rdf:Property ;
    rdfs:label 'Checksum Hash' ;
    rdfs:comment 'Cryptographic hash (e.g., SHA-256, MD5) of the document file content. Used for integrity verification, tamper detection, and duplicate detection. Critical for regulatory audit and litigation hold.' ;
    rdfs:domain ind:Version ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eligibleForPurgeDate rdf:type rdf:Property ;
    rdfs:label 'Eligible For Purge Date' ;
    rdfs:comment 'Calculated date when this document version becomes eligible for deletion or purge based on retention_period_years and retention_trigger_date. Used for automated archival and compliance-driven purge processes.' ;
    rdfs:domain ind:Version ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:encryptionMethod rdf:type rdf:Property ;
    rdfs:label 'Encryption Method' ;
    rdfs:comment 'Encryption algorithm or method applied to the document file (e.g., AES-256, RSA-2048). Null if is_encrypted is false.' ;
    rdfs:domain ind:Version ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:extractedTextAvailable rdf:type rdf:Property ;
    rdfs:label 'Extracted Text Available' ;
    rdfs:comment 'Indicates whether searchable text content has been extracted and indexed for this document version. True if text is available for full-text search; false otherwise.' ;
    rdfs:domain ind:Version ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hashAlgorithm rdf:type rdf:Property ;
    rdfs:label 'Hash Algorithm' ;
    rdfs:comment 'Cryptographic algorithm used to generate the checksum hash. Identifies the hashing method for verification and compliance purposes.' ;
    rdfs:domain ind:Version ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isDigitallySigned rdf:type rdf:Property ;
    rdfs:label 'Is Digitally Signed' ;
    rdfs:comment 'Indicates whether this document version carries a digital signature for authenticity and non-repudiation. True if digitally signed; false otherwise.' ;
    rdfs:domain ind:Version ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isEncrypted rdf:type rdf:Property ;
    rdfs:label 'Is Encrypted' ;
    rdfs:comment 'Indicates whether this document version is stored in encrypted format. True if encryption is applied at rest; false otherwise. Critical for HIPAA and data privacy compliance.' ;
    rdfs:domain ind:Version ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isUnderLitigationHold rdf:type rdf:Property ;
    rdfs:label 'Is Under Litigation Hold' ;
    rdfs:comment 'Indicates whether this document version is subject to a legal hold or litigation preservation order. True if hold is active; false otherwise. Prevents deletion or modification during legal proceedings.' ;
    rdfs:domain ind:Version ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:languageCode rdf:type rdf:Property ;
    rdfs:label 'Language Code' ;
    rdfs:comment 'ISO 639-1 two-letter language code indicating the primary language of the document content (e.g., EN for English, ES for Spanish, FR for French). Supports multilingual policy administration.' ;
    rdfs:domain ind:LifeInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastAccessedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Accessed Timestamp' ;
    rdfs:comment 'Date and time when this document version was last retrieved or viewed by a user or system. Used for usage analytics and compliance monitoring.' ;
    rdfs:domain ind:Version ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:litigationHoldDate rdf:type rdf:Property ;
    rdfs:label 'Litigation Hold Date' ;
    rdfs:comment 'Date when the litigation hold was placed on this document version. Null if is_under_litigation_hold is false.' ;
    rdfs:domain ind:Version ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mimeType rdf:type rdf:Property ;
    rdfs:label 'Mime Type' ;
    rdfs:comment 'Standard MIME type identifier for the document file (e.g., application/pdf, image/tiff, application/xml). Used for content type validation and browser rendering.' ;
    rdfs:domain ind:Version ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ocrConfidenceScore rdf:type rdf:Property ;
    rdfs:label 'Ocr Confidence Score' ;
    rdfs:comment 'Average confidence score (0.00 to 100.00) of the OCR text extraction process. Higher scores indicate greater accuracy. Null if ocr_processed_flag is false.' ;
    rdfs:domain ind:Version ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ocrProcessedFlag rdf:type rdf:Property ;
    rdfs:label 'Ocr Processed Flag' ;
    rdfs:comment 'Indicates whether this document version has been processed through optical character recognition to extract text content. True if OCR has been applied; false otherwise.' ;
    rdfs:domain ind:Version ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:retentionPeriodYears rdf:type rdf:Property ;
    rdfs:label 'Retention Period Years' ;
    rdfs:comment 'Number of years this document version must be retained per regulatory or business policy requirements. Drives archival and purge schedules aligned with state Department of Insurance (DOI) requirements.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:retentionTriggerDate rdf:type rdf:Property ;
    rdfs:label 'Retention Trigger Date' ;
    rdfs:comment 'Date from which the retention period begins counting. Typically the effective date, approval date, or policy termination date depending on document type and regulatory requirements.' ;
    rdfs:domain ind:Version ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:signatureTimestamp rdf:type rdf:Property ;
    rdfs:label 'Signature Timestamp' ;
    rdfs:comment 'Date and time when the digital signature was applied to this document version. Null if is_digitally_signed is false.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:signerName rdf:type rdf:Property ;
    rdfs:label 'Signer Name' ;
    rdfs:comment 'Name of the individual or entity whose digital signature is applied to this document version. Used for legal authenticity and audit trail.' ;
    rdfs:domain ind:Version ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemVersionCode rdf:type rdf:Property ;
    rdfs:label 'Source System Version Code' ;
    rdfs:comment 'Original version identifier or document key from the source system. Used for traceability and reconciliation with upstream systems.' ;
    rdfs:domain ind:Version ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageUri rdf:type rdf:Property ;
    rdfs:label 'Storage Uri' ;
    rdfs:comment 'Full path or URI to the physical storage location of this document version in the document management system, content repository, or cloud storage (e.g., S3 bucket path, Azure Blob URI, file system path).' ;
    rdfs:domain ind:Version ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:versionStatus rdf:type rdf:Property ;
    rdfs:label 'Version Status' ;
    rdfs:comment 'Current lifecycle status of this document version. Tracks progression from draft through approval to active use and eventual archival or supersession. [ENUM-REF-CANDIDATE: draft|pending_approval|approved|active|superseded|archived|withdrawn — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:LifeInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:versionType rdf:type rdf:Property ;
    rdfs:label 'Version Type' ;
    rdfs:comment 'Classification of the version change event. Distinguishes between original issuance, amendments, corrections, reissues, and endorsement attachments.' ;
    rdfs:domain ind:LifeInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryDocumentId rdf:type rdf:Property ;
    rdfs:label 'Primary Document Id' ;
    rdfs:comment 'Foreign key linking to document.document. Business justification: A package may have a \'primary\' or \'lead\' document (e.g., the application form in a new business package, the policy contract in an issue package). One package has one primary document (1:1 or N:1). Id' ;
    rdfs:domain ind:Package ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Document .

ind:assemblyDate rdf:type rdf:Property ;
    rdfs:label 'Assembly Date' ;
    rdfs:comment 'The date when the document package was initially assembled or created for the associated business transaction.' ;
    rdfs:domain ind:Package ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assignedDate rdf:type rdf:Property ;
    rdfs:label 'Assigned Date' ;
    rdfs:comment 'The date when the document package was assigned to the current user or work queue for processing.' ;
    rdfs:domain ind:Package ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:completenessPercentage rdf:type rdf:Property ;
    rdfs:label 'Completeness Percentage' ;
    rdfs:comment 'Calculated percentage representing the ratio of received required documents to total required documents, expressed as a value between 0.00 and 100.00.' ;
    rdfs:domain ind:Package ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:eDeliveryConsentDate rdf:type rdf:Property ;
    rdfs:label 'E Delivery Consent Date' ;
    rdfs:comment 'The date when electronic delivery consent was obtained from the policyholder.' ;
    rdfs:domain ind:Package ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:externalReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'External Reference Number' ;
    rdfs:comment 'External tracking number or reference identifier provided by the submitter, agent, or third party for cross-system reconciliation.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:imagingBatchNumber rdf:type rdf:Property ;
    rdfs:label 'Imaging Batch Number' ;
    rdfs:comment 'Identifier for the document imaging batch in which the physical documents in this package were scanned and digitized.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:imagingDate rdf:type rdf:Property ;
    rdfs:label 'Imaging Date' ;
    rdfs:comment 'The date when the documents in this package were scanned and imaged into the document management system.' ;
    rdfs:domain ind:Package ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:optionalDocumentCount rdf:type rdf:Property ;
    rdfs:label 'Optional Document Count' ;
    rdfs:comment 'Total number of optional or supplemental documents included in the package beyond the required set.' ;
    rdfs:domain ind:Package ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:packageDescription rdf:type rdf:Property ;
    rdfs:label 'Package Description' ;
    rdfs:comment 'Free-text description providing additional context about the document package, its purpose, or special handling instructions.' ;
    rdfs:domain ind:Package ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packageNumber rdf:type rdf:Property ;
    rdfs:label 'Package Number' ;
    rdfs:comment 'Business-facing unique identifier or reference number for the document package, used for tracking and communication purposes.' ;
    rdfs:domain ind:Package ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packageStatus rdf:type rdf:Property ;
    rdfs:label 'Package Status' ;
    rdfs:comment 'Current lifecycle status of the document package. Tracks progression through workflow stages including draft, submitted, in review, complete, incomplete, NIGO (Not In Good Order), approved, rejected, or archived. [ENUM-REF-CANDIDATE: draft|submitted|in_review|complete|incomplete|nigo|approved|rejected|archived — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Package ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packageType rdf:type rdf:Property ;
    rdfs:label 'Package Type' ;
    rdfs:comment 'Classification of the document package based on its business purpose. Examples include new business (NB) application package, policy issuance kit, claim submission package, annual statement package, regulatory filing bundle, underwriting submission, policy servicing request, reinstatement package, 1035 exchange documentation, or beneficiary change package. [ENUM-REF-CANDIDATE: new_business_application|policy_issuance_kit|claim_submission|annual_statement|regulatory_filing|underwriting_submission|policy_servicing|reinstatement|1035_exchange|beneficiary_change — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Package ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivedDocumentCount rdf:type rdf:Property ;
    rdfs:label 'Received Document Count' ;
    rdfs:comment 'Total number of required documents that have been received and logged into the package.' ;
    rdfs:domain ind:Package ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:regulatoryJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Regulatory Jurisdiction' ;
    rdfs:comment 'The state or jurisdiction whose regulatory requirements govern this document package, typically the state of policy issuance or claim filing.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiredDocumentCount rdf:type rdf:Property ;
    rdfs:label 'Required Document Count' ;
    rdfs:comment 'Total number of documents designated as required for this package type and business transaction.' ;
    rdfs:domain ind:Package ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:retentionExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Retention Expiration Date' ;
    rdfs:comment 'The calculated date when the retention period expires and the document package becomes eligible for archival or destruction per records management policy.' ;
    rdfs:domain ind:Package ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:slaDueDate rdf:type rdf:Property ;
    rdfs:label 'Sla Due Date' ;
    rdfs:comment 'The target date by which the document package must be processed to meet service level agreement commitments.' ;
    rdfs:domain ind:LifeInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:primaryNigoApplicationId rdf:type rdf:Property ;
    rdfs:label 'Primary Nigo Application Id' ;
    rdfs:comment 'Reference to the new business application that contains the NIGO condition. Links to the policy application undergoing processing.' ;
    rdfs:domain ind:NigoRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Application .

ind:agingDays rdf:type rdf:Property ;
    rdfs:label 'Aging Days' ;
    rdfs:comment 'Number of calendar days the NIGO condition has been open since identification. Key metric for SLA monitoring and agent performance tracking.' ;
    rdfs:domain ind:NigoRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:escalationDate rdf:type rdf:Property ;
    rdfs:label 'Escalation Date' ;
    rdfs:comment 'Date when the NIGO condition was escalated to higher authority. Null if never escalated.' ;
    rdfs:domain ind:NigoRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:escalationFlag rdf:type rdf:Property ;
    rdfs:label 'Escalation Flag' ;
    rdfs:comment 'Indicates whether the NIGO condition has been escalated to management or senior underwriting due to aging, complexity, or business impact.' ;
    rdfs:domain ind:NigoRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:escalationReason rdf:type rdf:Property ;
    rdfs:label 'Escalation Reason' ;
    rdfs:comment 'Free-text explanation of why the NIGO condition was escalated (e.g., exceeded SLA, unresponsive agent, complex resolution required).' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedDelayDays rdf:type rdf:Property ;
    rdfs:label 'Estimated Delay Days' ;
    rdfs:comment 'Estimated number of days the NIGO condition will delay policy issuance. Used for customer expectation management and SLA forecasting.' ;
    rdfs:domain ind:NigoRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:followUpCount rdf:type rdf:Property ;
    rdfs:label 'Follow Up Count' ;
    rdfs:comment 'Number of follow-up attempts made to resolve the NIGO condition. Indicates persistence required and potential agent quality issues.' ;
    rdfs:domain ind:NigoRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:identifiedDate rdf:type rdf:Property ;
    rdfs:label 'Identified Date' ;
    rdfs:comment 'Date when the NIGO condition was first identified during application processing or document review. Key metric for SLA tracking.' ;
    rdfs:domain ind:NigoRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:impactOnIssueDate rdf:type rdf:Property ;
    rdfs:label 'Impact On Issue Date' ;
    rdfs:comment 'Indicates whether the NIGO condition is expected to delay the policy issue date beyond the original target.' ;
    rdfs:domain ind:NigoRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastFollowUpDate rdf:type rdf:Property ;
    rdfs:label 'Last Follow Up Date' ;
    rdfs:comment 'Date of the most recent follow-up communication regarding the NIGO condition. Used to determine next action timing.' ;
    rdfs:domain ind:NigoRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastModifiedBy rdf:type rdf:Property ;
    rdfs:label 'Last Modified By' ;
    rdfs:comment 'User identifier or system process that last modified the NIGO record. Supports audit trail and change tracking.' ;
    rdfs:domain ind:NigoRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextFollowUpDate rdf:type rdf:Property ;
    rdfs:label 'Next Follow Up Date' ;
    rdfs:comment 'Scheduled date for the next follow-up action on the NIGO condition. Supports proactive case management.' ;
    rdfs:domain ind:NigoRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:notificationSentDate rdf:type rdf:Property ;
    rdfs:label 'Notification Sent Date' ;
    rdfs:comment 'Date when notification of the NIGO condition was sent to the responsible party (agent or applicant). Required for state DOI compliance on timely communication.' ;
    rdfs:domain ind:LifeInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:resolutionMethod rdf:type rdf:Property ;
    rdfs:label 'Resolution Method' ;
    rdfs:comment 'Method by which the NIGO condition was resolved. Examples: corrected_form (resubmitted corrected document), waiver_granted (underwriter waived requirement), additional_doc (supplemental documentation provided), phone_verification (verbal confirmation obtained), withdrawn (application withdrawn).' ;
    rdfs:domain ind:NigoRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolvedBy rdf:type rdf:Property ;
    rdfs:label 'Resolved By' ;
    rdfs:comment 'Name or identifier of the person or system that resolved the NIGO condition and returned the application to good order.' ;
    rdfs:domain ind:NigoRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolvedDate rdf:type rdf:Property ;
    rdfs:label 'Resolved Date' ;
    rdfs:comment 'Date when the NIGO condition was fully resolved and the application returned to good order status. Null if still open.' ;
    rdfs:domain ind:NigoRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:responsiblePartyContact rdf:type rdf:Property ;
    rdfs:label 'Responsible Party Contact' ;
    rdfs:comment 'Email address or phone number of the responsible party for follow-up communication regarding the NIGO condition.' ;
    rdfs:domain ind:NigoRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsiblePartyName rdf:type rdf:Property ;
    rdfs:label 'Responsible Party Name' ;
    rdfs:comment 'Name of the specific individual or organization responsible for resolving the NIGO condition.' ;
    rdfs:domain ind:NigoRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsiblePartyType rdf:type rdf:Property ;
    rdfs:label 'Responsible Party Type' ;
    rdfs:comment 'Category of party responsible for correcting the NIGO condition. Determines routing and follow-up workflow.' ;
    rdfs:domain ind:NigoRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemRecordReference rdf:type rdf:Property ;
    rdfs:label 'Source System Record Reference' ;
    rdfs:comment 'Primary key or unique identifier of the NIGO record in the source operational system. Enables traceability and reconciliation.' ;
    rdfs:domain ind:NigoRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stateJurisdiction rdf:type rdf:Property ;
    rdfs:label 'State Jurisdiction' ;
    rdfs:comment 'Two-letter US state code or jurisdiction where the policy will be issued. Determines applicable state DOI timeliness and communication requirements.' ;
    rdfs:domain ind:LifeInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:createdBy rdf:type rdf:Property ;
    rdfs:label 'Created By' ;
    rdfs:comment 'User identifier or system process that created the NIGO record. Supports audit trail and accountability.' ;
    rdfs:domain ind:LifeInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryConsentId rdf:type rdf:Property ;
    rdfs:label 'Delivery Consent Id' ;
    rdfs:comment 'Primary key for delivery_consent' ;
    rdfs:domain ind:Document ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DeliveryConsent .

ind:consentDocumentId rdf:type rdf:Property ;
    rdfs:label 'Consent Document Id' ;
    rdfs:comment 'Reference to the stored consent form or agreement document signed by the policyholder.' ;
    rdfs:domain ind:DeliveryConsent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Document .

ind:alternateEmailAddress rdf:type rdf:Property ;
    rdfs:label 'Alternate Email Address' ;
    rdfs:comment 'Secondary or backup email address for electronic document delivery if primary email fails.' ;
    rdfs:domain ind:DeliveryConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentDeviceType rdf:type rdf:Property ;
    rdfs:label 'Consent Device Type' ;
    rdfs:comment 'Type of device used by the policyholder to provide electronic delivery consent.' ;
    rdfs:domain ind:DeliveryConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentIpAddress rdf:type rdf:Property ;
    rdfs:label 'Consent Ip Address' ;
    rdfs:comment 'IP address from which the electronic consent was submitted, captured for audit trail and fraud prevention purposes.' ;
    rdfs:domain ind:DeliveryConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentLanguage rdf:type rdf:Property ;
    rdfs:label 'Consent Language' ;
    rdfs:comment 'Two-letter ISO 639-1 language code indicating the language in which the consent was provided and in which documents should be delivered.' ;
    rdfs:domain ind:DeliveryConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentMethod rdf:type rdf:Property ;
    rdfs:label 'Consent Method' ;
    rdfs:comment 'Method by which the policyholder provided their electronic delivery consent, such as through web portal, mobile app, e-signature platform, or traditional wet signature.' ;
    rdfs:domain ind:DeliveryConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentScope rdf:type rdf:Property ;
    rdfs:label 'Consent Scope' ;
    rdfs:comment 'Scope of documents covered by the electronic delivery consent, indicating whether consent applies to all documents or specific categories such as policy documents, billing statements, or claims correspondence.' ;
    rdfs:domain ind:DeliveryConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentStatus rdf:type rdf:Property ;
    rdfs:label 'Consent Status' ;
    rdfs:comment 'Current status of the electronic delivery consent indicating whether the policyholder has granted, revoked, or is pending consent for electronic document delivery.' ;
    rdfs:domain ind:DeliveryConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Consent Timestamp' ;
    rdfs:comment 'Precise timestamp when the consent was captured or last modified, including time zone information.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:consentUserAgent rdf:type rdf:Property ;
    rdfs:label 'Consent User Agent' ;
    rdfs:comment 'Browser or application user agent string captured at the time of consent submission for technical audit trail.' ;
    rdfs:domain ind:DeliveryConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentVersion rdf:type rdf:Property ;
    rdfs:label 'Consent Version' ;
    rdfs:comment 'Version identifier of the consent form or terms and conditions that the policyholder agreed to, used to track changes in consent language over time.' ;
    rdfs:domain ind:DeliveryConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataClassification rdf:type rdf:Property ;
    rdfs:label 'Data Classification' ;
    rdfs:comment 'Classification level of the consent record indicating the sensitivity and handling requirements of the data.' ;
    rdfs:domain ind:DeliveryConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isActive rdf:type rdf:Property ;
    rdfs:label 'Is Active' ;
    rdfs:comment 'Indicates whether this consent record is currently active and in effect for electronic document delivery.' ;
    rdfs:domain ind:DeliveryConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastVerificationDate rdf:type rdf:Property ;
    rdfs:label 'Last Verification Date' ;
    rdfs:comment 'Date when the email address or delivery channel was last verified as valid and deliverable.' ;
    rdfs:domain ind:DeliveryConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:optInMarketingFlag rdf:type rdf:Property ;
    rdfs:label 'Opt In Marketing Flag' ;
    rdfs:comment 'Indicates whether the policyholder has opted in to receive marketing communications via electronic delivery channels.' ;
    rdfs:domain ind:DeliveryConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:preferredDeliveryChannel rdf:type rdf:Property ;
    rdfs:label 'Preferred Delivery Channel' ;
    rdfs:comment 'Policyholder\'s preferred channel for receiving insurance documents, including electronic options (email, portal, mobile app) or traditional mail.' ;
    rdfs:domain ind:DeliveryConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revocationMethod rdf:type rdf:Property ;
    rdfs:label 'Revocation Method' ;
    rdfs:comment 'Method by which the policyholder revoked their electronic delivery consent.' ;
    rdfs:domain ind:DeliveryConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revocationReason rdf:type rdf:Property ;
    rdfs:label 'Revocation Reason' ;
    rdfs:comment 'Free-text explanation or reason code provided by the policyholder for revoking electronic delivery consent.' ;
    rdfs:domain ind:DeliveryConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stateComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'State Compliance Flag' ;
    rdfs:comment 'Indicates whether this consent record meets the specific e-delivery compliance requirements of the applicable state jurisdiction per NAIC model regulation and state-specific DOI rules.' ;
    rdfs:domain ind:DeliveryConsent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deliveryEventId rdf:type rdf:Property ;
    rdfs:label 'Delivery Event Id' ;
    rdfs:comment 'Primary key for delivery_event' ;
    rdfs:domain ind:DeliveryEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:confirmationReceiptTimestamp rdf:type rdf:Property ;
    rdfs:label 'Confirmation Receipt Timestamp' ;
    rdfs:comment 'Date and time when the recipient explicitly acknowledged receipt of the document through a confirmation mechanism.' ;
    rdfs:domain ind:DeliveryEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:deliveryBatchNumber rdf:type rdf:Property ;
    rdfs:label 'Delivery Batch Number' ;
    rdfs:comment 'Identifier for the batch job or campaign that initiated this delivery event. Groups related delivery events for operational tracking.' ;
    rdfs:domain ind:DeliveryEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryChannel rdf:type rdf:Property ;
    rdfs:label 'Delivery Channel' ;
    rdfs:comment 'The electronic or physical channel through which the document delivery was attempted. Tracks the method used to reach the recipient.' ;
    rdfs:domain ind:DeliveryEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryMethodPreference rdf:type rdf:Property ;
    rdfs:label 'Delivery Method Preference' ;
    rdfs:comment 'Recipient\'s stated preference for document delivery method. Used to route delivery attempts to preferred channels.' ;
    rdfs:domain ind:DeliveryEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryPriority rdf:type rdf:Property ;
    rdfs:label 'Delivery Priority' ;
    rdfs:comment 'Priority level assigned to this delivery event. Determines processing order and SLA requirements.' ;
    rdfs:domain ind:DeliveryEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:encryptionFlag rdf:type rdf:Property ;
    rdfs:label 'Encryption Flag' ;
    rdfs:comment 'Indicates whether the document was encrypted during transmission and storage for this delivery event.' ;
    rdfs:domain ind:DeliveryEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:failureCode rdf:type rdf:Property ;
    rdfs:label 'Failure Code' ;
    rdfs:comment 'Standardized code representing the category of delivery failure (e.g., invalid address, mailbox full, recipient blocked).' ;
    rdfs:domain ind:DeliveryEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failureReason rdf:type rdf:Property ;
    rdfs:label 'Failure Reason' ;
    rdfs:comment 'Detailed explanation of why the delivery attempt failed. Captures technical error messages, bounce reasons, or recipient unavailability details.' ;
    rdfs:domain ind:DeliveryEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fallbackToPaperFlag rdf:type rdf:Property ;
    rdfs:label 'Fallback To Paper Flag' ;
    rdfs:comment 'Indicates whether the system has triggered a fallback to physical paper delivery due to repeated electronic delivery failures.' ;
    rdfs:domain ind:DeliveryEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ipAddress rdf:type rdf:Property ;
    rdfs:label 'Ip Address' ;
    rdfs:comment 'IP address from which the recipient accessed or opened the document. Used for security audit and fraud detection.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxRetryAttempts rdf:type rdf:Property ;
    rdfs:label 'Max Retry Attempts' ;
    rdfs:comment 'Maximum number of retry attempts configured for this delivery event before escalation or fallback to paper.' ;
    rdfs:domain ind:DeliveryEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nextRetryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Next Retry Timestamp' ;
    rdfs:comment 'Scheduled date and time for the next delivery retry attempt, if the current attempt failed.' ;
    rdfs:domain ind:DeliveryEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:openedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Opened Timestamp' ;
    rdfs:comment 'Date and time when the recipient opened or accessed the delivered document. Provides confirmation of receipt and engagement.' ;
    rdfs:domain ind:DeliveryEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:paperFallbackTimestamp rdf:type rdf:Property ;
    rdfs:label 'Paper Fallback Timestamp' ;
    rdfs:comment 'Date and time when the fallback to paper delivery was initiated after electronic delivery failures.' ;
    rdfs:domain ind:DeliveryEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:recipientEmail rdf:type rdf:Property ;
    rdfs:label 'Recipient Email' ;
    rdfs:comment 'Email address to which the document was delivered. Primary contact channel for electronic delivery.' ;
    rdfs:domain ind:DeliveryEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recipientPhone rdf:type rdf:Property ;
    rdfs:label 'Recipient Phone' ;
    rdfs:comment 'Phone number used for SMS notification of document delivery, if applicable.' ;
    rdfs:domain ind:DeliveryEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retryCount rdf:type rdf:Property ;
    rdfs:label 'Retry Count' ;
    rdfs:comment 'Number of times the system has attempted to redeliver the document after initial failure. Tracks persistence of delivery efforts.' ;
    rdfs:domain ind:LifeInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Sent Timestamp' ;
    rdfs:comment 'Date and time when the delivery attempt was initiated by the system. Represents the start of the delivery event.' ;
    rdfs:domain ind:DeliveryEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:slaMetFlag rdf:type rdf:Property ;
    rdfs:label 'Sla Met Flag' ;
    rdfs:comment 'Indicates whether the delivery event met the defined SLA target for delivery time.' ;
    rdfs:domain ind:LifeInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:slaTargetHours rdf:type rdf:Property ;
    rdfs:label 'Sla Target Hours' ;
    rdfs:comment 'Target number of hours within which the document must be delivered to meet service level agreement commitments.' ;
    rdfs:domain ind:DeliveryEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trackingNumber rdf:type rdf:Property ;
    rdfs:label 'Tracking Number' ;
    rdfs:comment 'External tracking identifier provided by the delivery service provider (e.g., email service tracking ID, portal session ID).' ;
    rdfs:domain ind:DeliveryEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:userAgent rdf:type rdf:Property ;
    rdfs:label 'User Agent' ;
    rdfs:comment 'Browser or application user agent string captured when the recipient accessed the document. Provides device and platform context.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supersededByScheduleRetentionScheduleId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Schedule Retention Schedule Id' ;
    rdfs:comment 'Reference to the retention schedule record that supersedes this rule, enabling version history tracking.' ;
    rdfs:domain ind:RetentionSchedule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RetentionSchedule .

ind:acordFormIndicator rdf:type rdf:Property ;
    rdfs:label 'Acord Form Indicator' ;
    rdfs:comment 'Indicates whether this document type is a standardized ACORD form used across the insurance industry.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:auditTrailRequired rdf:type rdf:Property ;
    rdfs:label 'Audit Trail Required' ;
    rdfs:comment 'Indicates whether an audit trail of document access, modifications, and destruction must be maintained for compliance purposes.' ;
    rdfs:domain ind:RetentionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:businessJustification rdf:type rdf:Property ;
    rdfs:label 'Business Justification' ;
    rdfs:comment 'Business rationale for the retention period beyond regulatory minimum, such as operational need, litigation risk, or customer service requirements.' ;
    rdfs:domain ind:RetentionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destructionAuthorizationRequired rdf:type rdf:Property ;
    rdfs:label 'Destruction Authorization Required' ;
    rdfs:comment 'Indicates whether formal authorization from legal, compliance, or records management is required before document destruction.' ;
    rdfs:domain ind:RetentionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:destructionMethod rdf:type rdf:Property ;
    rdfs:label 'Destruction Method' ;
    rdfs:comment 'Required method for destroying documents at end of retention period (secure shred, electronic purge, degaussing, incineration, certified destruction).' ;
    rdfs:domain ind:RetentionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eDeliveryEligible rdf:type rdf:Property ;
    rdfs:label 'E Delivery Eligible' ;
    rdfs:comment 'Indicates whether this document type is eligible for electronic delivery to policyholders or beneficiaries, subject to consent requirements.' ;
    rdfs:domain ind:RetentionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:effectiveEndDate rdf:type rdf:Property ;
    rdfs:label 'Effective End Date' ;
    rdfs:comment 'Date when this retention schedule rule is superseded or no longer applicable. Null indicates currently active rule.' ;
    rdfs:domain ind:LifeInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectiveStartDate rdf:type rdf:Property ;
    rdfs:label 'Effective Start Date' ;
    rdfs:comment 'Date when this retention schedule rule becomes effective and enforceable.' ;
    rdfs:domain ind:LifeInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:exceptionProcessAvailable rdf:type rdf:Property ;
    rdfs:label 'Exception Process Available' ;
    rdfs:comment 'Indicates whether a formal exception process exists to deviate from this retention schedule under specific business or legal circumstances.' ;
    rdfs:domain ind:RetentionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:legalHoldOverrideAllowed rdf:type rdf:Property ;
    rdfs:label 'Legal Hold Override Allowed' ;
    rdfs:comment 'Indicates whether this document type can be subject to legal hold that overrides the standard retention schedule during litigation or regulatory investigation.' ;
    rdfs:domain ind:RetentionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maximumRetentionYears rdf:type rdf:Property ;
    rdfs:label 'Maximum Retention Years' ;
    rdfs:comment 'Maximum recommended number of years the document should be retained before authorized destruction. Null indicates indefinite retention.' ;
    rdfs:domain ind:RetentionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minimumRetentionYears rdf:type rdf:Property ;
    rdfs:label 'Minimum Retention Years' ;
    rdfs:comment 'Minimum number of years the document must be retained from the retention trigger event to comply with regulatory requirements.' ;
    rdfs:domain ind:RetentionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nigoTrackingApplicable rdf:type rdf:Property ;
    rdfs:label 'Nigo Tracking Applicable' ;
    rdfs:comment 'Indicates whether NIGO tracking (incomplete or deficient document submissions) applies to this document type during new business processing.' ;
    rdfs:domain ind:RetentionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:piiPhiIndicator rdf:type rdf:Property ;
    rdfs:label 'Pii Phi Indicator' ;
    rdfs:comment 'Indicates whether documents of this type typically contain PII or PHI, requiring enhanced privacy and security controls.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:privacyClassification rdf:type rdf:Property ;
    rdfs:label 'Privacy Classification' ;
    rdfs:comment 'Data classification level for documents of this type, determining access controls and handling requirements.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordUpdatedBy rdf:type rdf:Property ;
    rdfs:label 'Record Updated By' ;
    rdfs:comment 'User ID or system identifier of the person or process that last updated this retention schedule record.' ;
    rdfs:domain ind:RetentionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retentionMedium rdf:type rdf:Property ;
    rdfs:label 'Retention Medium' ;
    rdfs:comment 'Acceptable storage medium for retaining the document (electronic, paper, microfilm, optical, any).' ;
    rdfs:domain ind:RetentionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retentionScheduleStatus rdf:type rdf:Property ;
    rdfs:label 'Retention Schedule Status' ;
    rdfs:comment 'Current status of this retention schedule rule (active, superseded, pending approval, archived).' ;
    rdfs:domain ind:RetentionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retentionTriggerEvent rdf:type rdf:Property ;
    rdfs:label 'Retention Trigger Event' ;
    rdfs:comment 'The business event that starts the retention period clock (e.g., policy issue date, policy termination date, claim settlement date, contract expiration date, last activity date, document creation date, regulatory filing date, audit completion date). [ENUM-REF-CANDIDATE: policy_issue_date|policy_termination_date|claim_settlement_date|contract_expiration_date|last_activity_date|document_creation_date|regulatory_filing_date|audit_completion_date — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:RetentionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialHandlingInstructions rdf:type rdf:Property ;
    rdfs:label 'Special Handling Instructions' ;
    rdfs:comment 'Additional instructions for handling, storing, or destroying documents of this type that go beyond standard procedures (e.g., witness required for destruction, off-site storage mandated, encryption required).' ;
    rdfs:domain ind:RetentionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:versionControlRequired rdf:type rdf:Property ;
    rdfs:label 'Version Control Required' ;
    rdfs:comment 'Indicates whether version history must be maintained for documents of this type throughout the retention period.' ;
    rdfs:domain ind:RetentionSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:amlKycRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Aml Kyc Required Flag' ;
    rdfs:comment 'Indicates whether this ACORD form is used for Anti-Money Laundering (AML) and Know Your Customer (KYC) compliance purposes, requiring enhanced due diligence and verification.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:eDeliveryEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'E Delivery Eligible Flag' ;
    rdfs:comment 'Indicates whether this ACORD form is eligible for electronic delivery to policyholders or agents, subject to e-delivery consent requirements.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:electronicSignatureAllowedFlag rdf:type rdf:Property ;
    rdfs:label 'Electronic Signature Allowed Flag' ;
    rdfs:comment 'Indicates whether electronic signatures are permitted on this ACORD form per regulatory requirements and ACORD standards. True if e-signatures are allowed, False if wet signatures are required.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:formCategory rdf:type rdf:Property ;
    rdfs:label 'Form Category' ;
    rdfs:comment 'The high-level category or classification of the form within the document management taxonomy (e.g., application, endorsement, disclosure, medical, financial). [ENUM-REF-CANDIDATE: application|endorsement|disclosure|medical|financial|claim|service_request|regulatory_filing — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:LifeInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:formDescription rdf:type rdf:Property ;
    rdfs:label 'Form Description' ;
    rdfs:comment 'Detailed description of the ACORD form\'s purpose, content, and usage instructions. Provides context for document indexing and form selection during business processes.' ;
    rdfs:domain ind:LifeInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:formLanguage rdf:type rdf:Property ;
    rdfs:label 'Form Language' ;
    rdfs:comment 'The language in which the ACORD form is published, using three-letter ISO 639-2 language codes (e.g., ENG for English, SPA for Spanish, FRA for French).' ;
    rdfs:domain ind:AcordForm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:formName rdf:type rdf:Property ;
    rdfs:label 'Form Name' ;
    rdfs:comment 'The official descriptive name of the ACORD form (e.g., Application for Life Insurance, Beneficiary Designation Form, Attending Physician Statement).' ;
    rdfs:domain ind:LifeInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:formNumber rdf:type rdf:Property ;
    rdfs:label 'Form Number' ;
    rdfs:comment 'The official ACORD form number designation (e.g., ACORD 103, ACORD 301, ACORD 1). This is the industry-standard identifier for the form.' ;
    rdfs:domain ind:LifeInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:formPurpose rdf:type rdf:Property ;
    rdfs:label 'Form Purpose' ;
    rdfs:comment 'The primary business purpose or use case for the ACORD form within the insurance lifecycle (e.g., application, change request, claim submission, beneficiary designation). [ENUM-REF-CANDIDATE: application|change_request|claim|beneficiary_designation|underwriting|policy_service|reinsurance — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:AcordForm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:formStatus rdf:type rdf:Property ;
    rdfs:label 'Form Status' ;
    rdfs:comment 'The current lifecycle status of the ACORD form version in the reference catalog (e.g., active, superseded, deprecated, pending approval, withdrawn).' ;
    rdfs:domain ind:LifeInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:formTemplateUrl rdf:type rdf:Property ;
    rdfs:label 'Form Template Url' ;
    rdfs:comment 'The URL or file path to the digital template of the ACORD form in the document management system. Used for form retrieval and printing.' ;
    rdfs:domain ind:AcordForm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:formVersion rdf:type rdf:Property ;
    rdfs:label 'Form Version' ;
    rdfs:comment 'The version identifier of the ACORD form, typically in YYYY/MM format indicating the publication date of the form version.' ;
    rdfs:domain ind:AcordForm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hipaaProtectedFlag rdf:type rdf:Property ;
    rdfs:label 'Hipaa Protected Flag' ;
    rdfs:comment 'Indicates whether this ACORD form contains Protected Health Information (PHI) subject to HIPAA privacy and security requirements. True if the form collects or displays PHI.' ;
    rdfs:domain ind:AcordForm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastReviewedDate rdf:type rdf:Property ;
    rdfs:label 'Last Reviewed Date' ;
    rdfs:comment 'The date on which this ACORD form record was last reviewed for accuracy, compliance, and currency by the document management or compliance team.' ;
    rdfs:domain ind:AcordForm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mandatoryFieldsList rdf:type rdf:Property ;
    rdfs:label 'Mandatory Fields List' ;
    rdfs:comment 'Comma-separated list of field names or identifiers that are mandatory for completion on this ACORD form. Used for validation during New Business (NB) processing and Not In Good Order (NIGO) tracking.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nigoTrackingEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Nigo Tracking Enabled Flag' ;
    rdfs:comment 'Indicates whether this ACORD form is subject to Not In Good Order (NIGO) tracking during New Business (NB) application processing. True if incomplete or incorrect submissions should be flagged for follow-up.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryApprovalNumber rdf:type rdf:Property ;
    rdfs:label 'Regulatory Approval Number' ;
    rdfs:comment 'The approval or filing number assigned by the state Department of Insurance (DOI) or regulatory body for this ACORD form version. Used for regulatory compliance tracking.' ;
    rdfs:domain ind:AcordForm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stateSpecificFlag rdf:type rdf:Property ;
    rdfs:label 'State Specific Flag' ;
    rdfs:comment 'Indicates whether this ACORD form has state-specific variants or modifications required by individual state Departments of Insurance. True if state-specific versions exist, False if the form is uniform across all jurisdictions.' ;
    rdfs:domain ind:LifeInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supersededByFormNumber rdf:type rdf:Property ;
    rdfs:label 'Superseded By Form Number' ;
    rdfs:comment 'The ACORD form number that supersedes or replaces this form version. Populated when a form is deprecated or superseded by a newer version.' ;
    rdfs:domain ind:AcordForm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signerPartyId rdf:type rdf:Property ;
    rdfs:label 'Signer Party Id' ;
    rdfs:comment 'Reference to the party (person or organization) who executed the signature.' ;
    rdfs:domain ind:Signature ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:auditTrailUrl rdf:type rdf:Property ;
    rdfs:label 'Audit Trail Url' ;
    rdfs:comment 'The URL or file path to the complete audit trail document generated by the e-signature platform, containing all signature events, timestamps, and authentication details.' ;
    rdfs:domain ind:Signature ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authenticationMethod rdf:type rdf:Property ;
    rdfs:label 'Authentication Method' ;
    rdfs:comment 'The method used to authenticate the signer\'s identity before signature execution (email verification, SMS code, knowledge-based authentication, biometric, multi-factor authentication, or none for wet ink).' ;
    rdfs:domain ind:Signature ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificateReference rdf:type rdf:Property ;
    rdfs:label 'Certificate Reference' ;
    rdfs:comment 'The unique identifier of the digital certificate used for certificate-based digital signatures. Null for non-certificate-based signatures.' ;
    rdfs:domain ind:Signature ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentToElectronicSignature rdf:type rdf:Property ;
    rdfs:label 'Consent To Electronic Signature' ;
    rdfs:comment 'Indicates whether the signer provided explicit consent to use electronic signatures as required by ESIGN Act Section 101(c). True if consent was given, False otherwise.' ;
    rdfs:domain ind:Signature ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:declineReason rdf:type rdf:Property ;
    rdfs:label 'Decline Reason' ;
    rdfs:comment 'The reason provided by the signer for declining to sign the document. Null if signature was not declined.' ;
    rdfs:domain ind:LifeInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviceType rdf:type rdf:Property ;
    rdfs:label 'Device Type' ;
    rdfs:comment 'The type of device used to execute the e-signature (e.g., desktop, mobile, tablet, signature pad). Null for wet ink signatures.' ;
    rdfs:domain ind:Signature ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:esignaturePlatform rdf:type rdf:Property ;
    rdfs:label 'Esignature Platform' ;
    rdfs:comment 'The e-signature platform or vendor used to capture the electronic signature (e.g., DocuSign, Adobe Sign, OneSpan, Silanis, internal platform). Null for wet ink signatures.' ;
    rdfs:domain ind:Signature ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expirationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Expiration Timestamp' ;
    rdfs:comment 'The date and time when the signature request expires if not completed. Used to enforce time-bound signature workflows.' ;
    rdfs:domain ind:Signature ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:geolocationLatitude rdf:type rdf:Property ;
    rdfs:label 'Geolocation Latitude' ;
    rdfs:comment 'The latitude coordinate where the e-signature was executed, if captured by the platform. Used for compliance and fraud detection.' ;
    rdfs:domain ind:Signature ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:geolocationLongitude rdf:type rdf:Property ;
    rdfs:label 'Geolocation Longitude' ;
    rdfs:comment 'The longitude coordinate where the e-signature was executed, if captured by the platform. Used for compliance and fraud detection.' ;
    rdfs:domain ind:Signature ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:imageUrl rdf:type rdf:Property ;
    rdfs:label 'Image Url' ;
    rdfs:comment 'The URL or file path to the stored signature image (scanned wet ink or captured electronic signature graphic). Used for document imaging and audit purposes.' ;
    rdfs:domain ind:Signature ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalValidityFlag rdf:type rdf:Property ;
    rdfs:label 'Legal Validity Flag' ;
    rdfs:comment 'Indicates whether the signature meets legal validity requirements per applicable state e-signature laws (ESIGN Act, UETA) and internal compliance rules. True if valid, False if deficient.' ;
    rdfs:domain ind:Signature ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:notaryCommissionNumber rdf:type rdf:Property ;
    rdfs:label 'Notary Commission Number' ;
    rdfs:comment 'The commission number of the notary public who notarized the signature, if applicable. Required for certain policy types and beneficiary changes.' ;
    rdfs:domain ind:Signature ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notaryExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Notary Expiration Date' ;
    rdfs:comment 'The expiration date of the notary public\'s commission. Used to validate that the notarization was performed by a currently commissioned notary.' ;
    rdfs:domain ind:Signature ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:notaryState rdf:type rdf:Property ;
    rdfs:label 'Notary State' ;
    rdfs:comment 'The two-letter US state code where the notary public is commissioned (e.g., CA, NY, TX). Null if signature was not notarized.' ;
    rdfs:domain ind:Signature ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reminderCount rdf:type rdf:Property ;
    rdfs:label 'Reminder Count' ;
    rdfs:comment 'The number of reminder notifications sent to the signer before the signature was completed or expired. Used for workflow analytics.' ;
    rdfs:domain ind:Signature ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:requestSentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Request Sent Timestamp' ;
    rdfs:comment 'The date and time when the signature request was sent to the signer (for e-signature workflows). Null for wet ink signatures.' ;
    rdfs:domain ind:Signature ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sequence rdf:type rdf:Property ;
    rdfs:label 'Sequence' ;
    rdfs:comment 'The order in which this signature was required or executed within a multi-party signing workflow (e.g., 1 for applicant, 2 for agent, 3 for witness).' ;
    rdfs:domain ind:LifeInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:signatureMethod rdf:type rdf:Property ;
    rdfs:label 'Signature Method' ;
    rdfs:comment 'The method used to capture the signature: wet ink (physical), electronic (e-signature platform), digital (certificate-based), biometric (fingerprint/retina), or voice.' ;
    rdfs:domain ind:Signature ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signerFullName rdf:type rdf:Property ;
    rdfs:label 'Signer Full Name' ;
    rdfs:comment 'The full legal name of the individual or authorized representative who signed the document.' ;
    rdfs:domain ind:Signature ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signerRole rdf:type rdf:Property ;
    rdfs:label 'Signer Role' ;
    rdfs:comment 'The capacity in which the signer executed the signature (applicant, policy owner, insured, beneficiary, agent, witness, notary, guardian, trustee, or power of attorney). [ENUM-REF-CANDIDATE: applicant|owner|insured|beneficiary|agent|witness|notary|guardian|trustee|power_of_attorney — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Signature ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:voidedReason rdf:type rdf:Property ;
    rdfs:label 'Voided Reason' ;
    rdfs:comment 'The reason why the signature was voided or invalidated after execution. Null if signature was not voided.' ;
    rdfs:domain ind:Signature ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:voidedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Voided Timestamp' ;
    rdfs:comment 'The date and time when the signature was voided. Null if signature was not voided.' ;
    rdfs:domain ind:Signature ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:witnessName rdf:type rdf:Property ;
    rdfs:label 'Witness Name' ;
    rdfs:comment 'The full name of the witness who observed the signature execution, if a witness was required. Null if no witness was present.' ;
    rdfs:domain ind:Signature ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:witnessSignatureTimestamp rdf:type rdf:Property ;
    rdfs:label 'Witness Signature Timestamp' ;
    rdfs:comment 'The date and time when the witness signed to attest to the signature execution. Null if no witness was present.' ;
    rdfs:domain ind:Signature ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:assignedQueue rdf:type rdf:Property ;
    rdfs:label 'Assigned Queue' ;
    rdfs:comment 'The work queue to which this workflow instance is currently assigned for processing (e.g., underwriting queue, claims review queue, imaging queue).' ;
    rdfs:domain ind:Workflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:completedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Completed Timestamp' ;
    rdfs:comment 'The date and time when the workflow instance reached its final completion state.' ;
    rdfs:domain ind:Workflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:currentStage rdf:type rdf:Property ;
    rdfs:label 'Current Stage' ;
    rdfs:comment 'The specific stage or step within the workflow where the document currently resides (e.g., initial review, medical underwriting, final approval, imaging, indexing).' ;
    rdfs:domain ind:Workflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Entry Timestamp' ;
    rdfs:comment 'The date and time when the document entered the current workflow stage.' ;
    rdfs:domain ind:Workflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:imagingSystemReference rdf:type rdf:Property ;
    rdfs:label 'Imaging System Reference' ;
    rdfs:comment 'External reference identifier from the document imaging system (e.g., OnBase, FileNet) used for cross-system reconciliation.' ;
    rdfs:domain ind:Workflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initiatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Initiated Timestamp' ;
    rdfs:comment 'The date and time when the workflow instance was first created and initiated.' ;
    rdfs:domain ind:Workflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:priorStage rdf:type rdf:Property ;
    rdfs:label 'Prior Stage' ;
    rdfs:comment 'The immediately preceding stage in the workflow, used for tracking progression and enabling rollback if needed.' ;
    rdfs:domain ind:Workflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityControlStatus rdf:type rdf:Property ;
    rdfs:label 'Quality Control Status' ;
    rdfs:comment 'The outcome of quality control review for imaging and indexing accuracy, indicating whether the work meets quality standards.' ;
    rdfs:domain ind:Workflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityControlTimestamp rdf:type rdf:Property ;
    rdfs:label 'Quality Control Timestamp' ;
    rdfs:comment 'The date and time when quality control review was completed for this workflow instance.' ;
    rdfs:domain ind:Workflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:slaBreachFlag rdf:type rdf:Property ;
    rdfs:label 'Sla Breach Flag' ;
    rdfs:comment 'Indicator of whether the workflow has exceeded its SLA due date without completion.' ;
    rdfs:domain ind:Workflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:slaBreachTimestamp rdf:type rdf:Property ;
    rdfs:label 'Sla Breach Timestamp' ;
    rdfs:comment 'The date and time when the SLA breach occurred (when the workflow exceeded its due date).' ;
    rdfs:domain ind:Workflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sourceChannel rdf:type rdf:Property ;
    rdfs:label 'Source Channel' ;
    rdfs:comment 'The origination channel through which the document entered the system (e.g., mail room, fax, scan station, digital upload, email). [ENUM-REF-CANDIDATE: mail_room|fax|scan_station|digital_upload|email|portal|mobile_app|api|edi — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Workflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalDocumentsIndexed rdf:type rdf:Property ;
    rdfs:label 'Total Documents Indexed' ;
    rdfs:comment 'The total number of individual documents indexed within this workflow instance (a single workflow may contain multiple documents).' ;
    rdfs:domain ind:Workflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalPagesScanned rdf:type rdf:Property ;
    rdfs:label 'Total Pages Scanned' ;
    rdfs:comment 'The total number of pages scanned during the imaging process for this document workflow.' ;
    rdfs:domain ind:Workflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:workflowNumber rdf:type rdf:Property ;
    rdfs:label 'Workflow Number' ;
    rdfs:comment 'Business-facing unique identifier for the workflow instance, used for tracking and reference.' ;
    rdfs:domain ind:Workflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workflowStatus rdf:type rdf:Property ;
    rdfs:label 'Workflow Status' ;
    rdfs:comment 'Current lifecycle status of the workflow instance indicating its position in the processing pipeline. [ENUM-REF-CANDIDATE: initiated|in_progress|pending_review|approved|rejected|on_hold|escalated|completed|cancelled|archived — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Workflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workflowType rdf:type rdf:Property ;
    rdfs:label 'Workflow Type' ;
    rdfs:comment 'Classification of the workflow based on the business process it supports (e.g., new business processing, claims document review, policy servicing, regulatory filing). [ENUM-REF-CANDIDATE: new_business_processing|claims_document_review|policy_servicing|regulatory_filing|underwriting_review|annuity_processing|reinsurance_submission|imaging_indexing|quality_control|exception_handling — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Workflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supersededByTemplateId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Template Id' ;
    rdfs:comment 'Reference to the newer template version that replaces this template when it becomes deprecated.' ;
    rdfs:domain ind:Template ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Template .

ind:applicableJurisdictions rdf:type rdf:Property ;
    rdfs:label 'Applicable Jurisdictions' ;
    rdfs:comment 'Comma-separated list of state or jurisdiction codes (two-letter abbreviations) where this template is approved for use.' ;
    rdfs:domain ind:Template ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authoringSystem rdf:type rdf:Property ;
    rdfs:label 'Authoring System' ;
    rdfs:comment 'Name of the system or platform used to create and maintain this template (e.g., Policy Administration System, Document Composition Engine).' ;
    rdfs:domain ind:Template ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:doiApprovalNumber rdf:type rdf:Property ;
    rdfs:label 'Doi Approval Number' ;
    rdfs:comment 'Official approval or filing number assigned by the Department of Insurance for tracking regulatory compliance.' ;
    rdfs:domain ind:Template ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:doiApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Doi Approval Status' ;
    rdfs:comment 'Current regulatory approval status from the Department of Insurance for jurisdictions requiring pre-approval.' ;
    rdfs:domain ind:Template ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filePath rdf:type rdf:Property ;
    rdfs:label 'File Path' ;
    rdfs:comment 'Storage location or URL reference to the physical template file in the document management system.' ;
    rdfs:domain ind:Template ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:format rdf:type rdf:Property ;
    rdfs:label 'Format' ;
    rdfs:comment 'Technical file format of the template used for document generation and rendering.' ;
    rdfs:domain ind:Template ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:generationEngine rdf:type rdf:Property ;
    rdfs:label 'Generation Engine' ;
    rdfs:comment 'Name of the document generation engine or service that processes this template to produce final documents.' ;
    rdfs:domain ind:Template ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productTypeApplicability rdf:type rdf:Property ;
    rdfs:label 'Product Type Applicability' ;
    rdfs:comment 'Comma-separated list of specific product types (WL, UL, IUL, VUL, Term, SPIA, FIA) for which this template is applicable.' ;
    rdfs:domain ind:Template ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryApprovalRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Approval Required Flag' ;
    rdfs:comment 'Indicates whether this template requires explicit Department of Insurance (DOI) approval before use.' ;
    rdfs:domain ind:LifeInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:templateCategory rdf:type rdf:Property ;
    rdfs:label 'Template Category' ;
    rdfs:comment 'High-level classification of the template type indicating its primary business function. [ENUM-REF-CANDIDATE: policy_contract|illustration|disclosure|correspondence|application|claim_form|rider|endorsement — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Template ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:templateCode rdf:type rdf:Property ;
    rdfs:label 'Template Code' ;
    rdfs:comment 'Business identifier code for the template used for external reference and system integration.' ;
    rdfs:domain ind:Template ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:templateDescription rdf:type rdf:Property ;
    rdfs:label 'Template Description' ;
    rdfs:comment 'Detailed description of the template\'s purpose, usage context, and content structure.' ;
    rdfs:domain ind:Template ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:templateName rdf:type rdf:Property ;
    rdfs:label 'Template Name' ;
    rdfs:comment 'Human-readable name of the document template describing its purpose and content.' ;
    rdfs:domain ind:Template ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:templateStatus rdf:type rdf:Property ;
    rdfs:label 'Template Status' ;
    rdfs:comment 'Current lifecycle status of the template indicating its approval state and usability. [ENUM-REF-CANDIDATE: draft|pending_approval|approved|active|inactive|deprecated|superseded — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Template ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:templateType rdf:type rdf:Property ;
    rdfs:label 'Template Type' ;
    rdfs:comment 'Specific sub-classification within the template category providing granular template purpose identification. [ENUM-REF-CANDIDATE: policy_declaration|policy_schedule|benefit_summary|premium_notice|lapse_notice|reinstatement_form|beneficiary_change|APS_request|claim_proof|death_claim|surrender_form|1035_exchange|annual_statement|tax_reporting|compliance_disclosure — promote to reference product]' ;
    rdfs:domain ind:Template ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usageCount rdf:type rdf:Property ;
    rdfs:label 'Usage Count' ;
    rdfs:comment 'Total number of documents generated from this template since its effective date, used for tracking template utilization.' ;
    rdfs:domain ind:Template ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:variableDataFieldsList rdf:type rdf:Property ;
    rdfs:label 'Variable Data Fields List' ;
    rdfs:comment 'Comma-separated list of all variable data field placeholders embedded in the template that are dynamically populated during generation.' ;
    rdfs:domain ind:Template ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chartOfAccountsId rdf:type rdf:Property ;
    rdfs:label 'Chart Of Accounts Id' ;
    rdfs:comment 'Foreign key linking to finance.chart_of_accounts. Business justification: general_ledger IS the instance of a chart_of_accounts account with balances. All master data attributes (account_name, account_type, normal_balance, hierarchy, classifications, flags, etc.) should com' ;
    rdfs:domain ind:LifeInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ChartOfAccounts .

ind:accountCode rdf:type rdf:Property ;
    rdfs:label 'Account Code' ;
    rdfs:comment 'The unique account code from the chart of accounts (COA). Serves as the primary business identifier for the GL account. Typically 4-10 digit numeric code following the enterprise COA structure.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:functionalCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Functional Currency Code' ;
    rdfs:comment 'The three-letter ISO 4217 functional currency code for the legal entity. Used for currency translation and consolidation under ASC 830.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modifiedBy rdf:type rdf:Property ;
    rdfs:label 'Modified By' ;
    rdfs:comment 'The user ID or system identifier that last modified this general ledger account record. Supports accountability and audit trail requirements.' ;
    rdfs:domain ind:LifeInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productLineCode rdf:type rdf:Property ;
    rdfs:label 'Product Line Code' ;
    rdfs:comment 'The insurance product line associated with this account (e.g., \'WL\' for Whole Life, \'UL\' for Universal Life, \'SPIA\' for Single Premium Immediate Annuity). Enables product-level profitability analysis.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemKey rdf:type rdf:Property ;
    rdfs:label 'Source System Key' ;
    rdfs:comment 'The natural key or unique identifier for this account in the source system. Enables traceability back to the originating system of record.' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversedEntryJournalEntryId rdf:type rdf:Property ;
    rdfs:label 'Reversed Entry Journal Entry Id' ;
    rdfs:comment 'Reference to the original journal entry that this entry reverses. Populated when this entry is a reversing entry, creating an audit trail back to the original transaction.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:JournalEntry .

ind:accountingBasis rdf:type rdf:Property ;
    rdfs:label 'Accounting Basis' ;
    rdfs:comment 'The accounting framework under which this journal entry is recorded. SAP = Statutory Accounting Principles (regulatory), GAAP = Generally Accepted Accounting Principles (US GAAP), IFRS17 = International Financial Reporting Standards 17 (insurance contracts), TAX = Tax basis reporting.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:batchNumber rdf:type rdf:Property ;
    rdfs:label 'Batch Number' ;
    rdfs:comment 'Identifier for the batch or group of journal entries processed together. Used for bulk posting operations, system-generated entries from upstream processes, and batch-level reconciliation.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterCode rdf:type rdf:Property ;
    rdfs:label 'Cost Center Code' ;
    rdfs:comment 'Code identifying the organizational cost center responsible for this journal entry. Used for management reporting, budget vs. actual variance analysis, and expense allocation.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditAmount rdf:type rdf:Property ;
    rdfs:label 'Credit Amount' ;
    rdfs:comment 'The total credit amount for this journal entry header. In double-entry accounting, this must equal debit_amount to maintain balance. Represents increases to liability, equity, and revenue accounts or decreases to asset and expense accounts.' ;
    rdfs:domain ind:LifeInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:debitAmount rdf:type rdf:Property ;
    rdfs:label 'Debit Amount' ;
    rdfs:comment 'The total debit amount for this journal entry header. In double-entry accounting, this must equal credit_amount to maintain balance. Represents increases to asset and expense accounts or decreases to liability, equity, and revenue accounts.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:entryCategory rdf:type rdf:Property ;
    rdfs:label 'Entry Category' ;
    rdfs:comment 'High-level business classification of the journal entry purpose. Examples: Premium Revenue, DAC Amortization, Reserve Movement, Claim Payment, Commission Accrual, Investment Income, Intercompany Settlement, Reinsurance Cession, Policy Acquisition Cost, Benefit Payment, Surrender Processing, LDTI Adjustment, PBR Reserve Entry.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entryDate rdf:type rdf:Property ;
    rdfs:label 'Entry Date' ;
    rdfs:comment 'The calendar date on which the journal entry was created or recorded in the system. May differ from posting_date for adjusting or backdated entries.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:entryNumber rdf:type rdf:Property ;
    rdfs:label 'Entry Number' ;
    rdfs:comment 'Business-facing unique journal entry number assigned by the general ledger system. Used for external audit trails and financial close documentation.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entryStatus rdf:type rdf:Property ;
    rdfs:label 'Entry Status' ;
    rdfs:comment 'Current workflow status of the journal entry. Draft = in preparation, Pending Approval = submitted for review, Approved = authorized but not yet posted, Posted = committed to general ledger, Reversed = entry has been reversed, Rejected = not approved for posting.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entryType rdf:type rdf:Property ;
    rdfs:label 'Entry Type' ;
    rdfs:comment 'Classification of the journal entry based on its purpose in the accounting cycle. Standard = routine operational entries, Adjusting = period-end accruals and deferrals, Reversing = automatic reversal of prior period adjusting entries, Closing = period-end closing entries, Opening = beginning of period entries, Reclassification = reallocation between accounts.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fiscalYear rdf:type rdf:Property ;
    rdfs:label 'Fiscal Year' ;
    rdfs:comment 'The fiscal year to which this journal entry belongs. Used for annual financial statement preparation and multi-year comparative reporting.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:functionalCurrencyCredit rdf:type rdf:Property ;
    rdfs:label 'Functional Currency Credit' ;
    rdfs:comment 'The credit amount converted to the company\'s functional currency (typically USD) using the applicable exchange rate. Used for consolidated financial reporting when original entry is in a foreign currency.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:functionalCurrencyDebit rdf:type rdf:Property ;
    rdfs:label 'Functional Currency Debit' ;
    rdfs:comment 'The debit amount converted to the company\'s functional currency (typically USD) using the applicable exchange rate. Used for consolidated financial reporting when original entry is in a foreign currency.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ifrs17MeasurementModel rdf:type rdf:Property ;
    rdfs:label 'Ifrs17 Measurement Model' ;
    rdfs:comment 'The IFRS 17 measurement model applied to this journal entry for insurance contract accounting. GMM = General Measurement Model (building block approach), PAA = Premium Allocation Approach (simplified for short-duration contracts), VFA = Variable Fee Approach (for participating contracts with investment components).' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:intercompanyEntityCode rdf:type rdf:Property ;
    rdfs:label 'Intercompany Entity Code' ;
    rdfs:comment 'Code identifying the counterparty legal entity for intercompany transactions. Used for intercompany reconciliation and consolidated financial statement elimination entries. Populated only when intercompany_indicator is True.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:intercompanyIndicator rdf:type rdf:Property ;
    rdfs:label 'Intercompany Indicator' ;
    rdfs:comment 'Flag indicating whether this journal entry involves intercompany transactions between legal entities within the insurance group. True = entry requires intercompany elimination for consolidated reporting, False = intra-entity entry.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:journalEntryDescription rdf:type rdf:Property ;
    rdfs:label 'Journal Entry Description' ;
    rdfs:comment 'Detailed narrative description of the journal entry purpose, business rationale, and supporting documentation references. Used for audit trails, financial close documentation, and regulatory examinations.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ldtiIndicator rdf:type rdf:Property ;
    rdfs:label 'Ldti Indicator' ;
    rdfs:comment 'Flag indicating whether this journal entry is related to FASB ASU 2018-12 Long Duration Targeted Improvements (LDTI) accounting changes. True = entry is part of LDTI implementation (e.g., transition adjustments, updated DAC amortization, market risk benefit remeasurement), False = standard entry not impacted by LDTI.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pbrIndicator rdf:type rdf:Property ;
    rdfs:label 'Pbr Indicator' ;
    rdfs:comment 'Flag indicating whether this journal entry relates to Principle-Based Reserving (PBR) calculations under VM-20 and VM-21. True = entry records PBR reserves, stochastic reserve adjustments, or deterministic reserve calculations, False = entry not related to PBR.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:postedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Posted Timestamp' ;
    rdfs:comment 'The system timestamp when the journal entry was committed to the general ledger. Used for audit trails and to track financial close process timing.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:journalEntryLineId rdf:type rdf:Property ;
    rdfs:label 'Journal Entry Line Id' ;
    rdfs:comment 'Unique identifier for the journal entry line item. Primary key for the journal entry line product.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reversedLineJournalEntryLineId rdf:type rdf:Property ;
    rdfs:label 'Reversed Line Journal Entry Line Id' ;
    rdfs:comment 'Reference to the original journal entry line that this entry reverses, if applicable. Creates audit trail for corrections and reversals.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:JournalEntryLine .

ind:supportingDocumentId rdf:type rdf:Property ;
    rdfs:label 'Supporting Document Id' ;
    rdfs:comment 'Foreign key linking to document.document. Business justification: Individual GL line items require specific supporting documents (invoices, contracts, actuarial reports) for substantiation during account reconciliation and variance investigation. Auditors trace line' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Document .

ind:debitCreditIndicator rdf:type rdf:Property ;
    rdfs:label 'Debit Credit Indicator' ;
    rdfs:comment 'Indicates whether this line item is a debit or credit entry. Fundamental accounting classification for double-entry bookkeeping.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:functionalCurrencyAmount rdf:type rdf:Property ;
    rdfs:label 'Functional Currency Amount' ;
    rdfs:comment 'The monetary amount of this journal entry line in the functional currency of the legal entity. This is the primary amount used for statutory and GAAP reporting.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:intercompanyFlag rdf:type rdf:Property ;
    rdfs:label 'Intercompany Flag' ;
    rdfs:comment 'Boolean flag indicating whether this journal entry line represents an intercompany transaction that must be eliminated during consolidation.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:intercompanyPartnerCode rdf:type rdf:Property ;
    rdfs:label 'Intercompany Partner Code' ;
    rdfs:comment 'Code identifying the intercompany partner legal entity for intercompany transactions. Used for intercompany reconciliation and elimination entries.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:journalEntryType rdf:type rdf:Property ;
    rdfs:label 'Journal Entry Type' ;
    rdfs:comment 'Classification of the journal entry type: standard (routine operational entries), adjusting (period-end adjustments), closing (year-end closing entries), reversing (entries that reverse in the next period), reclassification (reclassifying between accounts), or elimination (intercompany elimination entries).' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:journalSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Journal Source System' ;
    rdfs:comment 'The source system or module that originated this journal entry line (e.g., policy administration, claims, billing, actuarial, investment management). Enables source system reconciliation and audit trail.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineDescription rdf:type rdf:Property ;
    rdfs:label 'Line Description' ;
    rdfs:comment 'Detailed textual description of the business purpose and nature of this journal entry line item. Provides context for financial statement users and auditors.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineNumber rdf:type rdf:Property ;
    rdfs:label 'Line Number' ;
    rdfs:comment 'Sequential line number within the journal entry. Determines the ordering and display sequence of line items within a single journal entry.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reportingCurrencyAmount rdf:type rdf:Property ;
    rdfs:label 'Reporting Currency Amount' ;
    rdfs:comment 'The monetary amount of this journal entry line translated into the reporting currency for consolidated financial reporting purposes.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reportingCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Reporting Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code representing the reporting currency for consolidated financial statements (typically the parent company currency).' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:soxControlFlag rdf:type rdf:Property ;
    rdfs:label 'Sox Control Flag' ;
    rdfs:comment 'Boolean flag indicating whether this journal entry line is subject to SOX internal control testing and certification requirements.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:transactionReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Transaction Reference Number' ;
    rdfs:comment 'Reference number or identifier from the source transaction system that originated this journal entry line. Enables drill-back to source transaction detail.' ;
    rdfs:domain ind:JournalEntryLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountSubtype rdf:type rdf:Property ;
    rdfs:label 'Account Subtype' ;
    rdfs:comment 'Secondary classification providing additional granularity within the account type (e.g., current asset, fixed asset, long-term liability, operating expense).' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalRequiredIndicator rdf:type rdf:Property ;
    rdfs:label 'Approval Required Indicator' ;
    rdfs:comment 'Flag indicating whether changes to this account definition require formal approval workflow due to materiality, regulatory impact, or SOX controls.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:budgetIndicator rdf:type rdf:Property ;
    rdfs:label 'Budget Indicator' ;
    rdfs:comment 'Flag indicating whether this account participates in the annual budgeting process and budget vs. actual variance reporting.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cashFlowStatementCategory rdf:type rdf:Property ;
    rdfs:label 'Cash Flow Statement Category' ;
    rdfs:comment 'The section of the cash flow statement (operating, investing, or financing activities) where transactions in this account are classified.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chartOfAccountsDescription rdf:type rdf:Property ;
    rdfs:label 'Chart Of Accounts Description' ;
    rdfs:comment 'Extended business description of the account\'s purpose, usage guidelines, and the types of transactions that should be posted to this account.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chartOfAccountsStatus rdf:type rdf:Property ;
    rdfs:label 'Chart Of Accounts Status' ;
    rdfs:comment 'Current lifecycle status of the chart of accounts entry. Active accounts are available for posting; inactive accounts are retained for historical reporting but closed to new transactions.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterRequiredIndicator rdf:type rdf:Property ;
    rdfs:label 'Cost Center Required Indicator' ;
    rdfs:comment 'Flag indicating whether a cost center dimension is required when posting transactions to this account for expense tracking and allocation.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:externalReportingCode rdf:type rdf:Property ;
    rdfs:label 'External Reporting Code' ;
    rdfs:comment 'The mapping code used to translate this internal account to external regulatory reporting formats (NAIC Annual Statement, SEC 10-K, state insurance department filings).' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialStatementLine rdf:type rdf:Property ;
    rdfs:label 'Financial Statement Line' ;
    rdfs:comment 'The specific line item on the financial statement (balance sheet, income statement, cash flow statement) where this account\'s balance is reported.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gaapClassification rdf:type rdf:Property ;
    rdfs:label 'Gaap Classification' ;
    rdfs:comment 'The classification of this account under US GAAP for external financial reporting and SEC filings.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ifrs17Classification rdf:type rdf:Property ;
    rdfs:label 'Ifrs17 Classification' ;
    rdfs:comment 'The classification of this account under IFRS 17 insurance contracts standard for international financial reporting. Includes insurance finance income/expense designation.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:normalBalance rdf:type rdf:Property ;
    rdfs:label 'Normal Balance' ;
    rdfs:comment 'Indicates whether the account normally carries a debit or credit balance. Assets and expenses typically have debit balances; liabilities, equity, and revenue have credit balances.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentAccountCode rdf:type rdf:Property ;
    rdfs:label 'Parent Account Code' ;
    rdfs:comment 'The account code of the parent account in the chart of accounts hierarchy. Used to build roll-up structures for financial reporting and consolidation.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postingAllowedIndicator rdf:type rdf:Property ;
    rdfs:label 'Posting Allowed Indicator' ;
    rdfs:comment 'Flag indicating whether direct journal entry postings are allowed to this account. Summary accounts typically do not allow direct posting.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:productLineRequiredIndicator rdf:type rdf:Property ;
    rdfs:label 'Product Line Required Indicator' ;
    rdfs:comment 'Flag indicating whether a product line dimension is required when posting transactions to this account for product profitability analysis.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rbcLineMapping rdf:type rdf:Property ;
    rdfs:label 'Rbc Line Mapping' ;
    rdfs:comment 'The specific line item on the NAIC Risk-Based Capital calculation where this account\'s balance is reported for regulatory capital adequacy assessment.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reconciliationFrequency rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Frequency' ;
    rdfs:comment 'The required frequency for formal reconciliation of this account balance to supporting documentation or sub-ledgers.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reconciliationRequiredIndicator rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Required Indicator' ;
    rdfs:comment 'Flag indicating whether this account requires formal balance sheet reconciliation as part of the monthly or quarterly financial close process.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rollupIndicator rdf:type rdf:Property ;
    rdfs:label 'Rollup Indicator' ;
    rdfs:comment 'Flag indicating whether this is a summary/rollup account that aggregates balances from child accounts, or a detail/posting account that receives direct journal entries.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sapClassification rdf:type rdf:Property ;
    rdfs:label 'Sap Classification' ;
    rdfs:comment 'The classification of this account under NAIC Statutory Accounting Principles for regulatory financial reporting to state insurance departments.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:soxControlIndicator rdf:type rdf:Property ;
    rdfs:label 'Sox Control Indicator' ;
    rdfs:comment 'Flag indicating whether this account is subject to enhanced Sarbanes-Oxley Act (SOX) internal controls and audit procedures due to materiality or risk.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:taxReportingCategory rdf:type rdf:Property ;
    rdfs:label 'Tax Reporting Category' ;
    rdfs:comment 'The classification of this account for federal and state tax return preparation and IRS reporting under IRC Section 7702 and other tax regulations.' ;
    rdfs:domain ind:ChartOfAccounts ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentCostCenterId rdf:type rdf:Property ;
    rdfs:label 'Parent Cost Center Id' ;
    rdfs:comment 'Reference to the parent cost center in the organizational hierarchy. Supports roll-up reporting and hierarchical expense allocation. Null for top-level cost centers.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostCenter .

ind:annualBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Annual Budget Amount' ;
    rdfs:comment 'Total annual budget allocated to this cost center for the current fiscal year. Used for budget vs. actual variance reporting.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Budget Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the budget amount. Supports multi-currency budget management.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetEntityFlag rdf:type rdf:Property ;
    rdfs:label 'Budget Entity Flag' ;
    rdfs:comment 'Indicates whether this cost center is a budget-holding entity with its own budget allocation and variance tracking. True if budget is assigned at this level.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:costCenterDescription rdf:type rdf:Property ;
    rdfs:label 'Cost Center Description' ;
    rdfs:comment 'Detailed description of the cost center\'s purpose, scope, and responsibilities within the organizational structure.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterName rdf:type rdf:Property ;
    rdfs:label 'Cost Center Name' ;
    rdfs:comment 'Full descriptive name of the cost center for reporting and identification purposes.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterStatus rdf:type rdf:Property ;
    rdfs:label 'Cost Center Status' ;
    rdfs:comment 'Current lifecycle status of the cost center. Only active cost centers accept expense postings.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterType rdf:type rdf:Property ;
    rdfs:label 'Cost Center Type' ;
    rdfs:comment 'Classification of the cost center by functional category. Determines expense allocation rules and reporting hierarchy.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dacEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Dac Eligible Flag' ;
    rdfs:comment 'Indicates whether expenses posted to this cost center are eligible for deferral as acquisition costs under GAAP ASC 944 and LDTI standards. True if DAC-eligible.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gaapExpenseCategory rdf:type rdf:Property ;
    rdfs:label 'Gaap Expense Category' ;
    rdfs:comment 'GAAP financial statement expense category for this cost center. Used for ASC 944 and LDTI reporting.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:intercompanySettlementFlag rdf:type rdf:Property ;
    rdfs:label 'Intercompany Settlement Flag' ;
    rdfs:comment 'Indicates whether expenses from this cost center require intercompany settlement and elimination entries. True if intercompany settlement applies.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sapExpenseExhibit rdf:type rdf:Property ;
    rdfs:label 'Sap Expense Exhibit' ;
    rdfs:comment 'NAIC Annual Statement expense exhibit line item to which expenses from this cost center are reported for statutory accounting purposes.' ;
    rdfs:domain ind:CostCenter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:soxControlledFlag rdf:type rdf:Property ;
    rdfs:label 'Sox Controlled Flag' ;
    rdfs:comment 'Indicates whether this cost center is subject to SOX internal control requirements for financial close and reporting. True if SOX-controlled.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:parentLegalEntityId rdf:type rdf:Property ;
    rdfs:label 'Parent Legal Entity Id' ;
    rdfs:comment 'Reference to the immediate parent legal entity in the holding company organizational hierarchy. Null for the ultimate parent holding company.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LegalEntity .

ind:primaryUltimateParentEntityLegalEntityId rdf:type rdf:Property ;
    rdfs:label 'Primary Ultimate Parent Entity Legal Entity Id' ;
    rdfs:comment 'Reference to the top-level parent entity in the holding company structure for consolidated reporting purposes.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LegalEntity .

ind:consolidationMethod rdf:type rdf:Property ;
    rdfs:label 'Consolidation Method' ;
    rdfs:comment 'The accounting method used to consolidate this entity into the parent holding company financial statements.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entityStatus rdf:type rdf:Property ;
    rdfs:label 'Entity Status' ;
    rdfs:comment 'Current operational and legal status of the entity within the holding company structure.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entityType rdf:type rdf:Property ;
    rdfs:label 'Entity Type' ;
    rdfs:comment 'Classification of the legal entity based on its primary business function within the holding company structure.' ;
    rdfs:domain ind:LifeInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:finraMemberFlag rdf:type rdf:Property ;
    rdfs:label 'Finra Member Flag' ;
    rdfs:comment 'Indicates whether this entity is a FINRA member broker-dealer subject to FINRA oversight and compliance requirements.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:functionalCurrency rdf:type rdf:Property ;
    rdfs:label 'Functional Currency' ;
    rdfs:comment 'Three-letter ISO currency code representing the primary currency in which the entity conducts its business operations and maintains its books and records.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gaapReportingEntityFlag rdf:type rdf:Property ;
    rdfs:label 'Gaap Reporting Entity Flag' ;
    rdfs:comment 'Indicates whether this entity prepares standalone GAAP financial statements or is included only in consolidated GAAP reporting.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ifrs17ReportingEntityFlag rdf:type rdf:Property ;
    rdfs:label 'Ifrs17 Reporting Entity Flag' ;
    rdfs:comment 'Indicates whether this entity is subject to IFRS 17 insurance contracts accounting standard for international financial reporting.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:incorporationDate rdf:type rdf:Property ;
    rdfs:label 'Incorporation Date' ;
    rdfs:comment 'The date on which the legal entity was incorporated or established under applicable law.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:intercompanyEliminationGroup rdf:type rdf:Property ;
    rdfs:label 'Intercompany Elimination Group' ;
    rdfs:comment 'Code identifying the group of entities for which intercompany transactions and balances must be eliminated during consolidation.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalEntityName rdf:type rdf:Property ;
    rdfs:label 'Legal Entity Name' ;
    rdfs:comment 'The full legal name of the entity as registered with regulatory authorities and appearing on statutory filings.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leiCode rdf:type rdf:Property ;
    rdfs:label 'Lei Code' ;
    rdfs:comment '20-character alphanumeric Legal Entity Identifier code issued by a Local Operating Unit under the Global LEI System for financial transaction reporting and regulatory compliance.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leiRegistrationDate rdf:type rdf:Property ;
    rdfs:label 'Lei Registration Date' ;
    rdfs:comment 'The date on which the LEI code was initially registered for this entity.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:leiRenewalDate rdf:type rdf:Property ;
    rdfs:label 'Lei Renewal Date' ;
    rdfs:comment 'The date by which the LEI code must be renewed to maintain active status.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:licenseEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'License Effective Date' ;
    rdfs:comment 'The date on which the regulatory license or certificate of authority became effective.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:licenseExpirationDate rdf:type rdf:Property ;
    rdfs:label 'License Expiration Date' ;
    rdfs:comment 'The date on which the regulatory license or certificate of authority expires, if applicable.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:primaryRegulator rdf:type rdf:Property ;
    rdfs:label 'Primary Regulator' ;
    rdfs:comment 'Name of the primary regulatory body with oversight authority over this entity (e.g., state insurance department, SEC, FINRA).' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rbcFilingEntityFlag rdf:type rdf:Property ;
    rdfs:label 'Rbc Filing Entity Flag' ;
    rdfs:comment 'Indicates whether this entity is required to file Risk-Based Capital reports with state insurance regulators.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:registeredAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Registered Address Line1' ;
    rdfs:comment 'First line of the legal registered address of the entity as filed with regulatory authorities.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registeredAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Registered Address Line2' ;
    rdfs:comment 'Second line of the legal registered address (suite, floor, building name, etc.).' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registeredCity rdf:type rdf:Property ;
    rdfs:label 'Registered City' ;
    rdfs:comment 'City of the legal registered address.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registeredCountry rdf:type rdf:Property ;
    rdfs:label 'Registered Country' ;
    rdfs:comment 'Three-letter ISO country code of the legal registered address.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registeredPostalCode rdf:type rdf:Property ;
    rdfs:label 'Registered Postal Code' ;
    rdfs:comment 'Postal or ZIP code of the legal registered address.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registeredState rdf:type rdf:Property ;
    rdfs:label 'Registered State' ;
    rdfs:comment 'State or province of the legal registered address.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryLicenseNumber rdf:type rdf:Property ;
    rdfs:label 'Regulatory License Number' ;
    rdfs:comment 'Primary license or certificate of authority number issued by the domicile state or primary regulator.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingCurrency rdf:type rdf:Property ;
    rdfs:label 'Reporting Currency' ;
    rdfs:comment 'Three-letter ISO currency code representing the currency used for external financial reporting and regulatory filings.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapReportingEntityFlag rdf:type rdf:Property ;
    rdfs:label 'Sap Reporting Entity Flag' ;
    rdfs:comment 'Indicates whether this entity is required to prepare statutory financial statements under SAP for state insurance department filing.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:secRegistrantFlag rdf:type rdf:Property ;
    rdfs:label 'Sec Registrant Flag' ;
    rdfs:comment 'Indicates whether this entity is registered with the SEC and subject to SEC reporting requirements for variable products or as a publicly traded entity.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:soxScopeEntityFlag rdf:type rdf:Property ;
    rdfs:label 'Sox Scope Entity Flag' ;
    rdfs:comment 'Indicates whether this entity is within the scope of SOX internal control testing and certification requirements.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:actuarialAssumptionSetId rdf:type rdf:Property ;
    rdfs:label 'Actuarial Assumption Set Id' ;
    rdfs:comment 'Reference to the actuarial assumption set used for DAC amortization calculations, including mortality, lapse, expense, and interest rate assumptions.' ;
    rdfs:domain ind:DacAsset ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AssumptionSet .

ind:decisionId rdf:type rdf:Property ;
    rdfs:label 'Decision Id' ;
    rdfs:comment 'Foreign key linking to underwriting.decision. Business justification: DAC capitalization under ASC 944/LDTI is triggered by the approved underwriting decision. Finance must trace each DAC asset to the originating decision for SOX audit trails, LDTI cohort assignment, an' ;
    rdfs:domain ind:LifeInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Decision .

ind:actualAmortizationAmount rdf:type rdf:Property ;
    rdfs:label 'Actual Amortization Amount' ;
    rdfs:comment 'Actual amortization expense recognized in the current accounting period. May differ from scheduled due to experience adjustments, policy lapses, or surrenders.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cumulativeAmortizationBalance rdf:type rdf:Property ;
    rdfs:label 'Cumulative Amortization Balance' ;
    rdfs:comment 'Total cumulative amortization recognized from policy issuance through the current accounting period.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dacAssetStatus rdf:type rdf:Property ;
    rdfs:label 'Dac Asset Status' ;
    rdfs:comment 'Current lifecycle status of the DAC asset. Active indicates ongoing amortization; Fully Amortized indicates complete amortization; Impaired indicates recognized impairment; Terminated indicates policy lapse or surrender.' ;
    rdfs:domain ind:DacAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dacCapitalizedAmount rdf:type rdf:Property ;
    rdfs:label 'Dac Capitalized Amount' ;
    rdfs:comment 'Total amount of acquisition costs capitalized as a DAC asset at policy issuance or acquisition. Includes commissions, underwriting costs, policy issuance expenses, and other directly attributable costs.' ;
    rdfs:domain ind:DacAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:externalAuditReviewedFlag rdf:type rdf:Property ;
    rdfs:label 'External Audit Reviewed Flag' ;
    rdfs:comment 'Flag indicating whether this DAC asset has been reviewed by external auditors in the current audit cycle.' ;
    rdfs:domain ind:DacAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gaapReportingBasis rdf:type rdf:Property ;
    rdfs:label 'Gaap Reporting Basis' ;
    rdfs:comment 'Accounting reporting basis under which this DAC asset is recorded. US GAAP follows FASB ASC 944; IFRS follows IFRS 17; Statutory follows NAIC SAP.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ifrs17AcquisitionCashFlowAsset rdf:type rdf:Property ;
    rdfs:label 'Ifrs17 Acquisition Cash Flow Asset' ;
    rdfs:comment 'Insurance acquisition cash flow asset recognized under IFRS 17 for acquisition costs directly attributable to a group of insurance contracts.' ;
    rdfs:domain ind:DacAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ifrs17AcquisitionCashFlowRelease rdf:type rdf:Property ;
    rdfs:label 'Ifrs17 Acquisition Cash Flow Release' ;
    rdfs:comment 'Amount of insurance acquisition cash flow asset released to profit or loss in the current period under IFRS 17.' ;
    rdfs:domain ind:DacAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:impairmentIndicatorFlag rdf:type rdf:Property ;
    rdfs:label 'Impairment Indicator Flag' ;
    rdfs:comment 'Flag indicating whether an impairment indicator exists for this DAC asset. True if adverse experience, policy lapses, or other factors suggest the asset may not be recoverable.' ;
    rdfs:domain ind:DacAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:impairmentLossAmount rdf:type rdf:Property ;
    rdfs:label 'Impairment Loss Amount' ;
    rdfs:comment 'Impairment loss recognized in the current period if the DAC asset is determined to be unrecoverable.' ;
    rdfs:domain ind:DacAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastAmortizationDate rdf:type rdf:Property ;
    rdfs:label 'Last Amortization Date' ;
    rdfs:comment 'Date of the most recent amortization transaction for this DAC asset.' ;
    rdfs:domain ind:DacAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ldtiCohortGroupingKey rdf:type rdf:Property ;
    rdfs:label 'Ldti Cohort Grouping Key' ;
    rdfs:comment 'Composite key identifying the LDTI cohort grouping for this DAC asset. Cohorts are defined by product type, issue year, underwriting class, and other contract characteristics.' ;
    rdfs:domain ind:DacAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledAmortizationAmount rdf:type rdf:Property ;
    rdfs:label 'Scheduled Amortization Amount' ;
    rdfs:comment 'Planned or scheduled amortization amount for the current accounting period based on the amortization method and actuarial assumptions.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shadowDacAdjustment rdf:type rdf:Property ;
    rdfs:label 'Shadow Dac Adjustment' ;
    rdfs:comment 'Shadow DAC adjustment for unrealized gains or losses on available-for-sale securities or other comprehensive income items that affect DAC amortization under GAAP.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unamortizedDacBalance rdf:type rdf:Property ;
    rdfs:label 'Unamortized Dac Balance' ;
    rdfs:comment 'Remaining unamortized DAC asset balance as of the accounting period end. Calculated as capitalized amount minus cumulative amortization.' ;
    rdfs:domain ind:DacAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vobaAmortizationAmount rdf:type rdf:Property ;
    rdfs:label 'Voba Amortization Amount' ;
    rdfs:comment 'Amortization expense recognized in the current period for the VOBA component of the DAC asset.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vobaComponentAmount rdf:type rdf:Property ;
    rdfs:label 'Voba Component Amount' ;
    rdfs:comment 'Value of Business Acquired component included in the DAC asset, arising from business combinations or block acquisitions. Amortized separately from internally generated DAC.' ;
    rdfs:domain ind:DacAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dacAmortizationId rdf:type rdf:Property ;
    rdfs:label 'Dac Amortization Id' ;
    rdfs:comment 'Primary key for dac_amortization' ;
    rdfs:domain ind:DacAmortization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:adjustmentDescription rdf:type rdf:Property ;
    rdfs:label 'Adjustment Description' ;
    rdfs:comment 'Detailed narrative description of the reason for any adjustment or variance from scheduled amortization, providing audit trail and business context.' ;
    rdfs:domain ind:DacAmortization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amortizationDate rdf:type rdf:Property ;
    rdfs:label 'Amortization Date' ;
    rdfs:comment 'The specific date on which the DAC amortization was posted to the general ledger.' ;
    rdfs:domain ind:DacAmortization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fiscalQuarter rdf:type rdf:Property ;
    rdfs:label 'Fiscal Quarter' ;
    rdfs:comment 'The fiscal quarter (1-4) to which this DAC amortization entry belongs, used for quarterly financial reporting.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gaapAmortizationAmount rdf:type rdf:Property ;
    rdfs:label 'Gaap Amortization Amount' ;
    rdfs:comment 'The DAC amortization amount calculated under GAAP accounting standards (FASB ASC 944), used for financial statement reporting.' ;
    rdfs:domain ind:DacAmortization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ifrs17AmortizationAmount rdf:type rdf:Property ;
    rdfs:label 'Ifrs17 Amortization Amount' ;
    rdfs:comment 'The insurance acquisition cash flow amortization amount under IFRS 17 accounting standard, representing the release of acquisition costs allocated to the contractual service margin.' ;
    rdfs:domain ind:DacAmortization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:remainingDacBalance rdf:type rdf:Property ;
    rdfs:label 'Remaining Dac Balance' ;
    rdfs:comment 'The unamortized DAC asset balance remaining on the balance sheet after this period\'s amortization. Calculated as original DAC less cumulative amortization.' ;
    rdfs:domain ind:DacAmortization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sapAmortizationAmount rdf:type rdf:Property ;
    rdfs:label 'Sap Amortization Amount' ;
    rdfs:comment 'The DAC amortization amount calculated under Statutory Accounting Principles for regulatory reporting to state insurance departments. SAP typically expenses acquisition costs immediately rather than deferring them.' ;
    rdfs:domain ind:DacAmortization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actuarialSignOffDate rdf:type rdf:Property ;
    rdfs:label 'Actuarial Sign Off Date' ;
    rdfs:comment 'The date when the appointed actuary signed off on the reserve calculation, certifying its adequacy and compliance with statutory requirements.' ;
    rdfs:domain ind:StatutoryReserve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:appointedActuaryName rdf:type rdf:Property ;
    rdfs:label 'Appointed Actuary Name' ;
    rdfs:comment 'The name of the appointed actuary who certified the reserve adequacy for this reporting period. Required for NAIC actuarial opinion filing.' ;
    rdfs:domain ind:StatutoryReserve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bookingDate rdf:type rdf:Property ;
    rdfs:label 'Booking Date' ;
    rdfs:comment 'The date when the statutory reserve was booked in the general ledger by the finance team. Represents the official finance record date.' ;
    rdfs:domain ind:StatutoryReserve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:carvmReserveAmount rdf:type rdf:Property ;
    rdfs:label 'Carvm Reserve Amount' ;
    rdfs:comment 'The CARVM reserve component for annuity contracts calculated using Commissioners Annuity Reserve Valuation Method. Null if not applicable to the product line.' ;
    rdfs:domain ind:StatutoryReserve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cohortIdentifier rdf:type rdf:Property ;
    rdfs:label 'Cohort Identifier' ;
    rdfs:comment 'Identifier for the policy cohort grouping used for reserve aggregation. Cohorts are typically defined by issue year, product type, and underwriting class for reserve modeling purposes.' ;
    rdfs:domain ind:StatutoryReserve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crvmReserveAmount rdf:type rdf:Property ;
    rdfs:label 'Crvm Reserve Amount' ;
    rdfs:comment 'The CRVM reserve component for life insurance policies calculated using Commissioners Reserve Valuation Method. Null if not applicable to the product line.' ;
    rdfs:domain ind:StatutoryReserve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deficiencyReserveAmount rdf:type rdf:Property ;
    rdfs:label 'Deficiency Reserve Amount' ;
    rdfs:comment 'Additional reserve held when the statutory reserve basis produces a reserve lower than the net premium reserve, ensuring reserve adequacy. Required under NAIC guidelines when deficiency exists.' ;
    rdfs:domain ind:StatutoryReserve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exhibitLineNumber rdf:type rdf:Property ;
    rdfs:label 'Exhibit Line Number' ;
    rdfs:comment 'The specific line number on the NAIC annual statement exhibit (Exhibit 5, 6, 7, or 8) where this reserve is reported. Used for regulatory filing reconciliation.' ;
    rdfs:domain ind:StatutoryReserve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:managementApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Management Approval Date' ;
    rdfs:comment 'The date when management approved the statutory reserve amount for booking in the general ledger. Part of the SOX-controlled financial close process.' ;
    rdfs:domain ind:StatutoryReserve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:netStatutoryReserveAmount rdf:type rdf:Property ;
    rdfs:label 'Net Statutory Reserve Amount' ;
    rdfs:comment 'The net statutory reserve amount after reinsurance ceded, calculated as statutory_reserve_amount minus reinsurance_ceded_reserve_amount. This is the net position reported on the balance sheet.' ;
    rdfs:domain ind:StatutoryReserve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pbrReserveAmount rdf:type rdf:Property ;
    rdfs:label 'Pbr Reserve Amount' ;
    rdfs:comment 'The PBR reserve component calculated per VM-20 (life) or VM-21 (variable annuity) for policies subject to principle-based reserving. Null if policy is not subject to PBR.' ;
    rdfs:domain ind:StatutoryReserve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rbcContributionAmount rdf:type rdf:Property ;
    rdfs:label 'Rbc Contribution Amount' ;
    rdfs:comment 'The contribution of this reserve to the company\'s Risk-Based Capital (RBC) calculation. Used for regulatory capital adequacy assessment under NAIC RBC framework.' ;
    rdfs:domain ind:StatutoryReserve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reinsuranceCededReserveAmount rdf:type rdf:Property ;
    rdfs:label 'Reinsurance Ceded Reserve Amount' ;
    rdfs:comment 'The portion of statutory reserve ceded to reinsurers under reinsurance treaties. Reduces the net statutory reserve position of the ceding company.' ;
    rdfs:domain ind:StatutoryReserve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reserveAdequacyMargin rdf:type rdf:Property ;
    rdfs:label 'Reserve Adequacy Margin' ;
    rdfs:comment 'The margin held above the minimum statutory reserve requirement to ensure reserve adequacy under adverse scenarios. Part of PBR stochastic reserve calculations.' ;
    rdfs:domain ind:StatutoryReserve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reserveBasisCode rdf:type rdf:Property ;
    rdfs:label 'Reserve Basis Code' ;
    rdfs:comment 'The statutory reserve methodology basis. Values: PBR (Principle-Based Reserving per VM-20/VM-21), CRVM (Commissioners Reserve Valuation Method for life), CARVM (Commissioners Annuity Reserve Valuation Method), NET_PREMIUM (Net Premium Reserve), MODIFIED_RESERVE (Modified Reserve Method).' ;
    rdfs:domain ind:StatutoryReserve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reserveCalculationMethodDescription rdf:type rdf:Property ;
    rdfs:label 'Reserve Calculation Method Description' ;
    rdfs:comment 'Detailed description of the reserve calculation methodology applied, including any company-specific adjustments or assumptions beyond standard statutory methods.' ;
    rdfs:domain ind:StatutoryReserve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reserveCategory rdf:type rdf:Property ;
    rdfs:label 'Reserve Category' ;
    rdfs:comment 'High-level reserve category for NAIC annual statement exhibit classification. Values: LIFE (life insurance reserves), ANNUITY (annuity reserves), ACCIDENT_HEALTH (accident and health reserves), DEPOSIT_TYPE (deposit-type contract reserves).' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stateOfDomicileCode rdf:type rdf:Property ;
    rdfs:label 'State Of Domicile Code' ;
    rdfs:comment 'Two-letter US state code representing the state of domicile for the legal entity holding this reserve. Determines which state Department of Insurance has primary regulatory authority.' ;
    rdfs:domain ind:StatutoryReserve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxReserveAmount rdf:type rdf:Property ;
    rdfs:label 'Tax Reserve Amount' ;
    rdfs:comment 'The reserve amount calculated for federal income tax purposes under IRC Section 807. May differ from statutory reserve due to different valuation methods and assumptions.' ;
    rdfs:domain ind:StatutoryReserve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:valuationInterestRate rdf:type rdf:Property ;
    rdfs:label 'Valuation Interest Rate' ;
    rdfs:comment 'The statutory valuation interest rate used for discounting future cash flows in reserve calculations, expressed as a decimal (e.g., 0.0350 for 3.50%). Prescribed by state law and NAIC guidelines.' ;
    rdfs:domain ind:StatutoryReserve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualExperienceEffectAmount rdf:type rdf:Property ;
    rdfs:label 'Actual Experience Effect Amount' ;
    rdfs:comment 'The financial impact on the reserve balance resulting from actual experience differing from expected assumptions (e.g., actual mortality vs. expected mortality).' ;
    rdfs:domain ind:GaapReserve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assumptionChangeEffectAmount rdf:type rdf:Property ;
    rdfs:label 'Assumption Change Effect Amount' ;
    rdfs:comment 'The financial impact (increase or decrease) on the reserve balance resulting from changes in actuarial assumptions during the reporting period, as required by LDTI disclosure.' ;
    rdfs:domain ind:GaapReserve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cashFlowAssumptionVersion rdf:type rdf:Property ;
    rdfs:label 'Cash Flow Assumption Version' ;
    rdfs:comment 'Version identifier for the set of actuarial assumptions (mortality, lapse, expense, etc.) used to project future cash flows for this reserve calculation.' ;
    rdfs:domain ind:GaapReserve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dacAssetAmount rdf:type rdf:Property ;
    rdfs:label 'Dac Asset Amount' ;
    rdfs:comment 'The deferred acquisition cost asset balance associated with this contract group, amortized over the life of the contracts under GAAP.' ;
    rdfs:domain ind:GaapReserve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:discountRatePercentage rdf:type rdf:Property ;
    rdfs:label 'Discount Rate Percentage' ;
    rdfs:comment 'The discount rate percentage applied to calculate the net present value of future policy benefits, expressed as a decimal (e.g., 0.04500 for 4.5%).' ;
    rdfs:domain ind:GaapReserve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:discountRateType rdf:type rdf:Property ;
    rdfs:label 'Discount Rate Type' ;
    rdfs:comment 'The type of discount rate applied to calculate the present value of future cash flows. LOCKED_IN=original cohort rate locked at issue, UPPER_MEDIUM_GRADE=current upper-medium grade fixed income instrument rate, CURRENT_MARKET=current market observable rate.' ;
    rdfs:domain ind:GaapReserve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expenseAssumptionPerPolicy rdf:type rdf:Property ;
    rdfs:label 'Expense Assumption Per Policy' ;
    rdfs:comment 'The assumed annual maintenance expense per policy used in the cash flow projections for this reserve calculation.' ;
    rdfs:domain ind:GaapReserve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:externalAuditReviewFlag rdf:type rdf:Property ;
    rdfs:label 'External Audit Review Flag' ;
    rdfs:comment 'Indicates whether this reserve balance has been reviewed and validated by external auditors as part of the annual financial statement audit.' ;
    rdfs:domain ind:GaapReserve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gaapVsStatutoryDifferenceAmount rdf:type rdf:Property ;
    rdfs:label 'Gaap Vs Statutory Difference Amount' ;
    rdfs:comment 'The difference between the GAAP reserve balance and the corresponding statutory reserve balance for the same contract group, used for reconciliation and regulatory reporting.' ;
    rdfs:domain ind:GaapReserve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lapseRateAssumptionPercentage rdf:type rdf:Property ;
    rdfs:label 'Lapse Rate Assumption Percentage' ;
    rdfs:comment 'The assumed annual lapse (policy termination) rate used in the cash flow projections for this reserve calculation, expressed as a decimal.' ;
    rdfs:domain ind:GaapReserve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ldtiCohortYear rdf:type rdf:Property ;
    rdfs:label 'Ldti Cohort Year' ;
    rdfs:comment 'The calendar year in which the insurance contracts were issued, used for LDTI cohort grouping under FASB ASC 944-40.' ;
    rdfs:domain ind:GaapReserve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ldtiTransitionAdjustmentAmount rdf:type rdf:Property ;
    rdfs:label 'Ldti Transition Adjustment Amount' ;
    rdfs:comment 'The cumulative adjustment to the reserve balance resulting from the transition to LDTI accounting standards (ASU 2018-12), typically recorded as a cumulative effect adjustment to retained earnings.' ;
    rdfs:domain ind:GaapReserve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mrbFairValueAmount rdf:type rdf:Property ;
    rdfs:label 'Mrb Fair Value Amount' ;
    rdfs:comment 'The fair value measurement of market risk benefits (e.g., GMDB, GMIB, GMWB) embedded in variable annuity and variable life contracts, measured at fair value under LDTI.' ;
    rdfs:domain ind:GaapReserve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mrbInstrumentCreditRiskAdjustment rdf:type rdf:Property ;
    rdfs:label 'Mrb Instrument Credit Risk Adjustment' ;
    rdfs:comment 'The adjustment to MRB fair value reflecting the company\'s own credit risk (non-performance risk) as required under fair value measurement guidance.' ;
    rdfs:domain ind:GaapReserve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:premiumDeficiencyReserveAmount rdf:type rdf:Property ;
    rdfs:label 'Premium Deficiency Reserve Amount' ;
    rdfs:comment 'Additional reserve established when a loss recognition event is identified (i.e., when the present value of expected future cash flows exceeds the existing reserve plus anticipated future premiums).' ;
    rdfs:domain ind:GaapReserve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reserveAdequacyTestDate rdf:type rdf:Property ;
    rdfs:label 'Reserve Adequacy Test Date' ;
    rdfs:comment 'The date when the most recent reserve adequacy test was performed.' ;
    rdfs:domain ind:GaapReserve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reserveAdequacyTestStatus rdf:type rdf:Property ;
    rdfs:label 'Reserve Adequacy Test Status' ;
    rdfs:comment 'The result of the most recent reserve adequacy testing (loss recognition testing) performed to ensure reserves are sufficient to cover expected future obligations.' ;
    rdfs:domain ind:GaapReserve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reserveCalculationMethod rdf:type rdf:Property ;
    rdfs:label 'Reserve Calculation Method' ;
    rdfs:comment 'The actuarial methodology used to calculate the reserve balance (e.g., net premium method, gross premium method, benefit reserve method, fair value measurement).' ;
    rdfs:domain ind:GaapReserve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:soxControlCertificationFlag rdf:type rdf:Property ;
    rdfs:label 'Sox Control Certification Flag' ;
    rdfs:comment 'Indicates whether this reserve balance has been certified under SOX internal controls for financial reporting accuracy and completeness.' ;
    rdfs:domain ind:GaapReserve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:groupingPolicyDocumentId rdf:type rdf:Property ;
    rdfs:label 'Grouping Policy Document Id' ;
    rdfs:comment 'Foreign key linking to document.document. Business justification: IFRS 17 contract grouping decisions require documented policies, cohort definitions, and onerous contract assessments. IFRS 17 disclosure preparation and audit depend on linking contract groups to sup' ;
    rdfs:domain ind:Ifrs17ContractGroup ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Document .

ind:reinsuranceContractGroupId rdf:type rdf:Property ;
    rdfs:label 'Reinsurance Contract Group Id' ;
    rdfs:comment 'Reference to the reinsurance contract group held that covers this direct insurance contract group, if applicable.' ;
    rdfs:domain ind:Ifrs17ContractGroup ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Ifrs17ContractGroup .

ind:closingCsmBalance rdf:type rdf:Property ;
    rdfs:label 'Closing Csm Balance' ;
    rdfs:comment 'The unearned profit component at the end of the reporting period after all movements including release, interest accretion, and adjustments.' ;
    rdfs:domain ind:Ifrs17ContractGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:closingFcfEstimate rdf:type rdf:Property ;
    rdfs:label 'Closing Fcf Estimate' ;
    rdfs:comment 'The present value of future cash flows at the end of the reporting period after all movements and adjustments.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contractBoundaryAssessment rdf:type rdf:Property ;
    rdfs:label 'Contract Boundary Assessment' ;
    rdfs:comment 'Description of the contract boundary determination, identifying the point at which the entity has the practical ability to reassess risks and can set a price that reflects those risks.' ;
    rdfs:domain ind:Ifrs17ContractGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractGroupCode rdf:type rdf:Property ;
    rdfs:label 'Contract Group Code' ;
    rdfs:comment 'Business identifier code for the contract group used in financial reporting and actuarial systems.' ;
    rdfs:domain ind:Ifrs17ContractGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coveragePeriod rdf:type rdf:Property ;
    rdfs:label 'Coverage Period' ;
    rdfs:comment 'Indicates whether this measurement relates to the liability for remaining coverage or the liability for incurred claims.' ;
    rdfs:domain ind:Ifrs17ContractGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coverageUnitsClosing rdf:type rdf:Property ;
    rdfs:label 'Coverage Units Closing' ;
    rdfs:comment 'The quantity of coverage units at the end of the period after adjustments for service provided and changes in expected coverage.' ;
    rdfs:domain ind:Ifrs17ContractGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coverageUnitsOpening rdf:type rdf:Property ;
    rdfs:label 'Coverage Units Opening' ;
    rdfs:comment 'The quantity of coverage units at the beginning of the period, used to determine the pattern of CSM release. Coverage units represent the quantity of service provided by the contracts.' ;
    rdfs:domain ind:Ifrs17ContractGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:csmAssumptionChangeImpact rdf:type rdf:Property ;
    rdfs:label 'Csm Assumption Change Impact' ;
    rdfs:comment 'Adjustments to CSM resulting from changes in estimates of future cash flows relating to future service, excluding changes in financial assumptions when the entity has chosen to disaggregate insurance finance income or expense.' ;
    rdfs:domain ind:Ifrs17ContractGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:csmCurrencyExchangeImpact rdf:type rdf:Property ;
    rdfs:label 'Csm Currency Exchange Impact' ;
    rdfs:comment 'The effect of changes in foreign exchange rates on the CSM for contracts denominated in foreign currencies.' ;
    rdfs:domain ind:Ifrs17ContractGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:csmExperienceVariance rdf:type rdf:Property ;
    rdfs:label 'Csm Experience Variance' ;
    rdfs:comment 'Adjustments to CSM for differences between expected and actual cash flows relating to future service.' ;
    rdfs:domain ind:Ifrs17ContractGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:csmInterestAccretion rdf:type rdf:Property ;
    rdfs:label 'Csm Interest Accretion' ;
    rdfs:comment 'The interest accreted on the CSM balance during the period using discount rates determined at initial recognition.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:csmNewBusinessAddition rdf:type rdf:Property ;
    rdfs:label 'Csm New Business Addition' ;
    rdfs:comment 'The CSM arising from new contracts added to the group during the period.' ;
    rdfs:domain ind:Ifrs17ContractGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:csmReleaseAmount rdf:type rdf:Property ;
    rdfs:label 'Csm Release Amount' ;
    rdfs:comment 'The amount of CSM recognized as insurance revenue in the current period based on coverage units provided.' ;
    rdfs:domain ind:Ifrs17ContractGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:derecognitionDate rdf:type rdf:Property ;
    rdfs:label 'Derecognition Date' ;
    rdfs:comment 'The date when the contract group was derecognized from the statement of financial position, when all rights and obligations are extinguished or transferred.' ;
    rdfs:domain ind:Ifrs17ContractGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:discountRateClosing rdf:type rdf:Property ;
    rdfs:label 'Discount Rate Closing' ;
    rdfs:comment 'The discount rate applied to the fulfilment cash flows at the end of the reporting period.' ;
    rdfs:domain ind:Ifrs17ContractGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:discountRateOpening rdf:type rdf:Property ;
    rdfs:label 'Discount Rate Opening' ;
    rdfs:comment 'The discount rate applied to the fulfilment cash flows at the beginning of the reporting period, reflecting the time value of money and financial risk.' ;
    rdfs:domain ind:Ifrs17ContractGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ifrs17ContractGroupStatus rdf:type rdf:Property ;
    rdfs:label 'Ifrs17 Contract Group Status' ;
    rdfs:comment 'The current lifecycle status of the contract group: active (in force), closed (no longer accepting new contracts but existing contracts remain), or derecognized (fully extinguished).' ;
    rdfs:domain ind:Ifrs17ContractGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initialRecognitionDate rdf:type rdf:Property ;
    rdfs:label 'Initial Recognition Date' ;
    rdfs:comment 'The date when the contract group was first recognized in the financial statements, typically the earliest of: beginning of coverage period, first payment due, or when the group becomes onerous.' ;
    rdfs:domain ind:Ifrs17ContractGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:insuranceFinanceIncomeExpense rdf:type rdf:Property ;
    rdfs:label 'Insurance Finance Income Expense' ;
    rdfs:comment 'The change in the carrying amount of the group of insurance contracts arising from the time value of money, financial risk, and changes in financial risk.' ;
    rdfs:domain ind:Ifrs17ContractGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:insuranceRevenueRecognized rdf:type rdf:Property ;
    rdfs:label 'Insurance Revenue Recognized' ;
    rdfs:comment 'The amount of insurance revenue recognized in profit or loss during the period, comprising the release of CSM, risk adjustment, and expected incurred claims.' ;
    rdfs:domain ind:Ifrs17ContractGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:insuranceServiceExpense rdf:type rdf:Property ;
    rdfs:label 'Insurance Service Expense' ;
    rdfs:comment 'The total insurance service expenses recognized in profit or loss, including incurred claims, other incurred expenses, amortization of insurance acquisition cash flows, and losses on onerous contracts.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lossComponentClosing rdf:type rdf:Property ;
    rdfs:label 'Loss Component Closing' ;
    rdfs:comment 'The closing balance of the loss component for onerous contract groups after movements during the period.' ;
    rdfs:domain ind:Ifrs17ContractGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lossComponentOpening rdf:type rdf:Property ;
    rdfs:label 'Loss Component Opening' ;
    rdfs:comment 'The opening balance of the loss component for onerous contract groups. Represents the extent to which the fulfilment cash flows exceed the carrying amount of the liability for remaining coverage.' ;
    rdfs:domain ind:Ifrs17ContractGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:measurementModel rdf:type rdf:Property ;
    rdfs:label 'Measurement Model' ;
    rdfs:comment 'The IFRS 17 measurement model applied to this contract group: General Measurement Model (GMM), Premium Allocation Approach (PAA), or Variable Fee Approach (VFA) for direct participating contracts.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ociAmount rdf:type rdf:Property ;
    rdfs:label 'Oci Amount' ;
    rdfs:comment 'The portion of insurance finance income or expense recognized in other comprehensive income when the entity has elected to disaggregate insurance finance income or expense.' ;
    rdfs:domain ind:Ifrs17ContractGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ociPlAllocationElection rdf:type rdf:Property ;
    rdfs:label 'Oci Pl Allocation Election' ;
    rdfs:comment 'The accounting policy choice for presenting insurance finance income or expense: entirely in profit or loss, or disaggregated between profit or loss and OCI.' ;
    rdfs:domain ind:Ifrs17ContractGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:openingCsmBalance rdf:type rdf:Property ;
    rdfs:label 'Opening Csm Balance' ;
    rdfs:comment 'The unearned profit component at the beginning of the reporting period. Represents the unearned profit the entity will recognize as it provides services under the insurance contracts.' ;
    rdfs:domain ind:Ifrs17ContractGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:openingFcfEstimate rdf:type rdf:Property ;
    rdfs:label 'Opening Fcf Estimate' ;
    rdfs:comment 'The present value of future cash flows at the beginning of the reporting period. Comprises estimates of future cash flows, discount rate adjustment, and risk adjustment for non-financial risk.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:riskAdjustmentClosing rdf:type rdf:Property ;
    rdfs:label 'Risk Adjustment Closing' ;
    rdfs:comment 'The compensation the entity requires for bearing the uncertainty about the amount and timing of cash flows from non-financial risk at the end of the period.' ;
    rdfs:domain ind:Ifrs17ContractGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:riskAdjustmentOpening rdf:type rdf:Property ;
    rdfs:label 'Risk Adjustment Opening' ;
    rdfs:comment 'The compensation the entity requires for bearing the uncertainty about the amount and timing of cash flows from non-financial risk at the beginning of the period.' ;
    rdfs:domain ind:Ifrs17ContractGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:riskAdjustmentRelease rdf:type rdf:Property ;
    rdfs:label 'Risk Adjustment Release' ;
    rdfs:comment 'The amount of risk adjustment recognized in profit or loss as the entity is released from risk during the period.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transitionApproach rdf:type rdf:Property ;
    rdfs:label 'Transition Approach' ;
    rdfs:comment 'The transition method applied when IFRS 17 was first adopted for this contract group: full retrospective application, modified retrospective approach, or fair value approach.' ;
    rdfs:domain ind:Ifrs17ContractGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ifrs17MeasurementId rdf:type rdf:Property ;
    rdfs:label 'Ifrs17 Measurement Id' ;
    rdfs:comment 'Unique identifier for the IFRS 17 measurement record.' ;
    rdfs:domain ind:Ifrs17Measurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actuarialReportDocumentId rdf:type rdf:Property ;
    rdfs:label 'Actuarial Report Document Id' ;
    rdfs:comment 'Foreign key linking to document.document. Business justification: CSM releases and risk adjustment changes require supporting actuarial reports and assumption change documentation. Quarterly IFRS 17 measurement and disclosure processes depend on linking measurements' ;
    rdfs:domain ind:Ifrs17Measurement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Document .

ind:acquisitionExpense rdf:type rdf:Property ;
    rdfs:label 'Acquisition Expense' ;
    rdfs:comment 'Expenses incurred during the reporting period for acquiring new insurance contracts, including commissions and underwriting costs.' ;
    rdfs:domain ind:Ifrs17Measurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assumptionChangeImpact rdf:type rdf:Property ;
    rdfs:label 'Assumption Change Impact' ;
    rdfs:comment 'The total impact on the insurance contract liability from changes in actuarial assumptions during the reporting period.' ;
    rdfs:domain ind:Ifrs17Measurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:closingCsm rdf:type rdf:Property ;
    rdfs:label 'Closing Csm' ;
    rdfs:comment 'The closing balance of the Contractual Service Margin at the end of the reporting period.' ;
    rdfs:domain ind:Ifrs17Measurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:closingRiskAdjustment rdf:type rdf:Property ;
    rdfs:label 'Closing Risk Adjustment' ;
    rdfs:comment 'The closing balance of the risk adjustment for non-financial risk at the end of the reporting period.' ;
    rdfs:domain ind:Ifrs17Measurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cohortYear rdf:type rdf:Property ;
    rdfs:label 'Cohort Year' ;
    rdfs:comment 'The year in which the insurance contracts in this group were initially recognized, used for cohort-based measurement under IFRS 17.' ;
    rdfs:domain ind:Ifrs17Measurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:coverageUnits rdf:type rdf:Property ;
    rdfs:label 'Coverage Units' ;
    rdfs:comment 'The quantity of coverage units provided during the reporting period, used to allocate CSM release. Coverage units reflect the quantity of benefits provided under the insurance contracts.' ;
    rdfs:domain ind:Ifrs17Measurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:csmAssumptionChange rdf:type rdf:Property ;
    rdfs:label 'Csm Assumption Change' ;
    rdfs:comment 'Adjustment to CSM arising from changes in estimates of future cash flows that relate to future service (e.g., changes in mortality, lapse, expense assumptions).' ;
    rdfs:domain ind:Ifrs17Measurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:csmExperienceAdjustment rdf:type rdf:Property ;
    rdfs:label 'Csm Experience Adjustment' ;
    rdfs:comment 'Adjustment to CSM arising from differences between actual experience and previous estimates (experience variances) that relate to future service.' ;
    rdfs:domain ind:Ifrs17Measurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:csmReleaseForService rdf:type rdf:Property ;
    rdfs:label 'Csm Release For Service' ;
    rdfs:comment 'The amount of CSM released to profit or loss as insurance revenue during the reporting period, reflecting the insurance service provided.' ;
    rdfs:domain ind:Ifrs17Measurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:experienceVariance rdf:type rdf:Property ;
    rdfs:label 'Experience Variance' ;
    rdfs:comment 'The difference between actual experience and previous estimates during the reporting period, recognized immediately in profit or loss for past service.' ;
    rdfs:domain ind:Ifrs17Measurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:financeOciComponent rdf:type rdf:Property ;
    rdfs:label 'Finance Oci Component' ;
    rdfs:comment 'The portion of insurance finance income or expense recognized in other comprehensive income (OCI) during the reporting period, when the entity elects the OCI option.' ;
    rdfs:domain ind:Ifrs17Measurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:financePlComponent rdf:type rdf:Property ;
    rdfs:label 'Finance Pl Component' ;
    rdfs:comment 'The portion of insurance finance income or expense recognized in profit or loss during the reporting period.' ;
    rdfs:domain ind:Ifrs17Measurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:incurredClaims rdf:type rdf:Property ;
    rdfs:label 'Incurred Claims' ;
    rdfs:comment 'The amount of claims incurred during the reporting period, including claims paid and changes in claims liabilities.' ;
    rdfs:domain ind:Ifrs17Measurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:insuranceFinanceExpense rdf:type rdf:Property ;
    rdfs:label 'Insurance Finance Expense' ;
    rdfs:comment 'Finance expense recognized during the reporting period from the unwinding of discount on insurance contract liabilities and changes in discount rates.' ;
    rdfs:domain ind:Ifrs17Measurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:insuranceFinanceIncome rdf:type rdf:Property ;
    rdfs:label 'Insurance Finance Income' ;
    rdfs:comment 'Finance income recognized during the reporting period from the unwinding of discount on insurance contract liabilities and changes in discount rates.' ;
    rdfs:domain ind:Ifrs17Measurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:insuranceRevenue rdf:type rdf:Property ;
    rdfs:label 'Insurance Revenue' ;
    rdfs:comment 'Total insurance revenue recognized in profit or loss during the reporting period, comprising CSM release, risk adjustment release, and expected claims and expenses.' ;
    rdfs:domain ind:Ifrs17Measurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lossComponent rdf:type rdf:Property ;
    rdfs:label 'Loss Component' ;
    rdfs:comment 'The loss component balance for onerous contract groups, tracked separately to determine the allocation of subsequent changes in fulfilment cash flows.' ;
    rdfs:domain ind:Ifrs17Measurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:measurementStatus rdf:type rdf:Property ;
    rdfs:label 'Measurement Status' ;
    rdfs:comment 'The status of this measurement record in the financial close process: Draft (work in progress), Preliminary (under review), Final (approved for reporting), or Restated (corrected after initial reporting).' ;
    rdfs:domain ind:Ifrs17Measurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:onerousContractLoss rdf:type rdf:Property ;
    rdfs:label 'Onerous Contract Loss' ;
    rdfs:comment 'Loss recognized immediately in profit or loss when a group of insurance contracts becomes onerous (i.e., the fulfilment cash flows exceed any remaining CSM).' ;
    rdfs:domain ind:Ifrs17Measurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:openingCsm rdf:type rdf:Property ;
    rdfs:label 'Opening Csm' ;
    rdfs:comment 'The opening balance of the Contractual Service Margin at the beginning of the reporting period. CSM represents the unearned profit that will be recognized as insurance revenue over the coverage period.' ;
    rdfs:domain ind:Ifrs17Measurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:openingRiskAdjustment rdf:type rdf:Property ;
    rdfs:label 'Opening Risk Adjustment' ;
    rdfs:comment 'The opening balance of the risk adjustment for non-financial risk at the beginning of the reporting period. Risk adjustment represents the compensation required for bearing uncertainty about the amount and timing of cash flows.' ;
    rdfs:domain ind:Ifrs17Measurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reinsuranceHeldCsm rdf:type rdf:Property ;
    rdfs:label 'Reinsurance Held Csm' ;
    rdfs:comment 'The CSM for reinsurance contracts held, representing the unearned benefit from reinsurance coverage.' ;
    rdfs:domain ind:Ifrs17Measurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reinsuranceHeldFcf rdf:type rdf:Property ;
    rdfs:label 'Reinsurance Held Fcf' ;
    rdfs:comment 'The present value of future cash flows for reinsurance contracts held, representing the reinsurance asset or liability.' ;
    rdfs:domain ind:Ifrs17Measurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reinsuranceHeldRiskAdjustment rdf:type rdf:Property ;
    rdfs:label 'Reinsurance Held Risk Adjustment' ;
    rdfs:comment 'The risk adjustment for non-financial risk on reinsurance contracts held.' ;
    rdfs:domain ind:Ifrs17Measurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:riskAdjustmentChange rdf:type rdf:Property ;
    rdfs:label 'Risk Adjustment Change' ;
    rdfs:comment 'Change in risk adjustment during the period due to changes in estimates of non-financial risk.' ;
    rdfs:domain ind:Ifrs17Measurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:filingDocumentId rdf:type rdf:Property ;
    rdfs:label 'Filing Document Id' ;
    rdfs:comment 'Foreign key linking to document.document. Business justification: RBC filings require supporting schedules, investment listings, and reinsurance attestations filed with state regulators. Annual RBC filing and regulatory compliance depend on linking calculations to f' ;
    rdfs:domain ind:RbcCalculation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Document .

ind:actionLevelTrigger rdf:type rdf:Property ;
    rdfs:label 'Action Level Trigger' ;
    rdfs:comment 'Indicates which regulatory action level threshold has been triggered based on the RBC ratio (no_action, company_action, regulatory_action, authorized_control, mandatory_control).' ;
    rdfs:domain ind:RbcCalculation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditOpinion rdf:type rdf:Property ;
    rdfs:label 'Audit Opinion' ;
    rdfs:comment 'The auditor\'s opinion on the RBC calculation if reviewed (unqualified, qualified, adverse, disclaimer, not_audited).' ;
    rdfs:domain ind:RbcCalculation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditorReviewedFlag rdf:type rdf:Property ;
    rdfs:label 'Auditor Reviewed Flag' ;
    rdfs:comment 'Indicates whether the RBC calculation has been reviewed by external auditors as part of the financial statement audit.' ;
    rdfs:domain ind:RbcCalculation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:authorizedControlLevelRbc rdf:type rdf:Property ;
    rdfs:label 'Authorized Control Level Rbc' ;
    rdfs:comment 'The authorized control level RBC amount. Represents the minimum capital threshold below which regulatory control is authorized.' ;
    rdfs:domain ind:RbcCalculation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:c0AssetRiskAffiliates rdf:type rdf:Property ;
    rdfs:label 'C0 Asset Risk Affiliates' ;
    rdfs:comment 'RBC charge for asset risk related to investments in affiliates and subsidiaries.' ;
    rdfs:domain ind:RbcCalculation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:c1AssetRiskEquity rdf:type rdf:Property ;
    rdfs:label 'C1 Asset Risk Equity' ;
    rdfs:comment 'RBC charge for asset risk on equity investments and common stock.' ;
    rdfs:domain ind:RbcCalculation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:c1AssetRiskFixedIncome rdf:type rdf:Property ;
    rdfs:label 'C1 Asset Risk Fixed Income' ;
    rdfs:comment 'RBC charge for asset default risk on fixed income securities (bonds, mortgages).' ;
    rdfs:domain ind:RbcCalculation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:c1AssetRiskOther rdf:type rdf:Property ;
    rdfs:label 'C1 Asset Risk Other' ;
    rdfs:comment 'RBC charge for asset risk on other invested assets not classified elsewhere.' ;
    rdfs:domain ind:RbcCalculation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:c1AssetRiskRealEstate rdf:type rdf:Property ;
    rdfs:label 'C1 Asset Risk Real Estate' ;
    rdfs:comment 'RBC charge for asset risk on real estate holdings and property investments.' ;
    rdfs:domain ind:RbcCalculation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:c2InsuranceRisk rdf:type rdf:Property ;
    rdfs:label 'C2 Insurance Risk' ;
    rdfs:comment 'RBC charge for underwriting and pricing risk related to insurance liabilities and reserves.' ;
    rdfs:domain ind:RbcCalculation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:c3InterestRateRisk rdf:type rdf:Property ;
    rdfs:label 'C3 Interest Rate Risk' ;
    rdfs:comment 'RBC charge for interest rate and asset-liability mismatch risk.' ;
    rdfs:domain ind:RbcCalculation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:c3MarketRisk rdf:type rdf:Property ;
    rdfs:label 'C3 Market Risk' ;
    rdfs:comment 'RBC charge for market risk on variable annuity guarantees and other market-sensitive products.' ;
    rdfs:domain ind:RbcCalculation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:c4BusinessRisk rdf:type rdf:Property ;
    rdfs:label 'C4 Business Risk' ;
    rdfs:comment 'RBC charge for general business risk including administrative expenses and guaranty fund assessments.' ;
    rdfs:domain ind:RbcCalculation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:calculationType rdf:type rdf:Property ;
    rdfs:label 'Calculation Type' ;
    rdfs:comment 'Type of RBC calculation based on insurance line of business (life, property/casualty, health).' ;
    rdfs:domain ind:RbcCalculation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:companyActionLevelRbc rdf:type rdf:Property ;
    rdfs:label 'Company Action Level Rbc' ;
    rdfs:comment 'The company action level RBC amount. Represents the threshold at which the company must submit a corrective action plan.' ;
    rdfs:domain ind:RbcCalculation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:covarianceAdjustment rdf:type rdf:Property ;
    rdfs:label 'Covariance Adjustment' ;
    rdfs:comment 'Adjustment factor applied to recognize diversification benefits across risk categories using the NAIC covariance formula.' ;
    rdfs:domain ind:RbcCalculation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:filedWithRegulatorFlag rdf:type rdf:Property ;
    rdfs:label 'Filed With Regulator Flag' ;
    rdfs:comment 'Indicates whether this RBC calculation has been officially filed with the state insurance regulator.' ;
    rdfs:domain ind:RbcCalculation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mandatoryControlLevelRbc rdf:type rdf:Property ;
    rdfs:label 'Mandatory Control Level Rbc' ;
    rdfs:comment 'The mandatory control level RBC amount. Represents the threshold at which the regulator must place the company under regulatory control.' ;
    rdfs:domain ind:RbcCalculation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:orsaAlignmentFlag rdf:type rdf:Property ;
    rdfs:label 'Orsa Alignment Flag' ;
    rdfs:comment 'Indicates whether this RBC calculation aligns with the company\'s ORSA capital assessment and risk management framework.' ;
    rdfs:domain ind:RbcCalculation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rbcRatio rdf:type rdf:Property ;
    rdfs:label 'Rbc Ratio' ;
    rdfs:comment 'The ratio of Total Adjusted Capital to Authorized Control Level RBC, expressed as a percentage. Key metric for regulatory capital adequacy.' ;
    rdfs:domain ind:RbcCalculation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatorJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Regulator Jurisdiction' ;
    rdfs:comment 'The state or jurisdiction code of the primary insurance regulator (e.g., NY, CA, TX).' ;
    rdfs:domain ind:RbcCalculation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryActionLevelRbc rdf:type rdf:Property ;
    rdfs:label 'Regulatory Action Level Rbc' ;
    rdfs:comment 'The regulatory action level RBC amount. Represents the threshold at which the regulator may take corrective action.' ;
    rdfs:domain ind:RbcCalculation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reportingQuarter rdf:type rdf:Property ;
    rdfs:label 'Reporting Quarter' ;
    rdfs:comment 'The quarter within the reporting year (1-4). Null for annual-only calculations.' ;
    rdfs:domain ind:RbcCalculation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reportingYear rdf:type rdf:Property ;
    rdfs:label 'Reporting Year' ;
    rdfs:comment 'The calendar year for which RBC is being reported.' ;
    rdfs:domain ind:RbcCalculation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalAdjustedCapital rdf:type rdf:Property ;
    rdfs:label 'Total Adjusted Capital' ;
    rdfs:comment 'Total adjusted capital available to support risk. Calculated as statutory capital and surplus plus other adjustments per NAIC formula.' ;
    rdfs:domain ind:RbcCalculation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalRbcAfterCovariance rdf:type rdf:Property ;
    rdfs:label 'Total Rbc After Covariance' ;
    rdfs:comment 'Total RBC requirement after applying the covariance adjustment for diversification.' ;
    rdfs:domain ind:RbcCalculation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalRbcBeforeCovariance rdf:type rdf:Property ;
    rdfs:label 'Total Rbc Before Covariance' ;
    rdfs:comment 'Sum of all RBC risk components (C-0 through C-4) before applying the covariance adjustment.' ;
    rdfs:domain ind:RbcCalculation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trendTestResult rdf:type rdf:Property ;
    rdfs:label 'Trend Test Result' ;
    rdfs:comment 'Result of the RBC trend test comparing current year to prior year capital adequacy (pass, fail, not_applicable).' ;
    rdfs:domain ind:RbcCalculation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxProvisionId rdf:type rdf:Property ;
    rdfs:label 'Tax Provision Id' ;
    rdfs:comment 'Unique identifier for the income tax provision record. Primary key for the tax provision entity.' ;
    rdfs:domain ind:TaxProvision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:taxComplianceTestId rdf:type rdf:Property ;
    rdfs:label 'Tax Compliance Test Id' ;
    rdfs:comment 'Foreign key linking to policy.tax_compliance_test. Business justification: Tax provision IRC 7702 adjustment field is directly driven by policy-level compliance test results (MEC status, 7-pay limits). Finance tax teams reference compliance test records when computing irc_77' ;
    rdfs:domain ind:LifeInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TaxComplianceTest .

ind:auditStatus rdf:type rdf:Property ;
    rdfs:label 'Audit Status' ;
    rdfs:comment 'Current status of tax authority audit or examination for this tax period. Tracks IRS or state tax authority review lifecycle.' ;
    rdfs:domain ind:TaxProvision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentTaxExpense rdf:type rdf:Property ;
    rdfs:label 'Current Tax Expense' ;
    rdfs:comment 'The portion of total income tax expense attributable to taxes currently payable or refundable for the reporting period. Represents cash tax impact.' ;
    rdfs:domain ind:TaxProvision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dacTemporaryDifference rdf:type rdf:Property ;
    rdfs:label 'Dac Temporary Difference' ;
    rdfs:comment 'Temporary difference arising from DAC capitalization for GAAP versus immediate deduction for tax. Major source of deferred tax liability for life insurance companies.' ;
    rdfs:domain ind:TaxProvision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deferredTaxExpense rdf:type rdf:Property ;
    rdfs:label 'Deferred Tax Expense' ;
    rdfs:comment 'The portion of total income tax expense attributable to changes in deferred tax assets and liabilities. Positive values represent expense; negative values represent benefit.' ;
    rdfs:domain ind:TaxProvision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dtaBalance rdf:type rdf:Property ;
    rdfs:label 'Dta Balance' ;
    rdfs:comment 'Total deferred tax asset balance as of the reporting period end. Represents future tax benefits from temporary differences, NOL carryforwards, and tax credit carryforwards.' ;
    rdfs:domain ind:TaxProvision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dtlBalance rdf:type rdf:Property ;
    rdfs:label 'Dtl Balance' ;
    rdfs:comment 'Total deferred tax liability balance as of the reporting period end. Represents future tax obligations from temporary differences such as accelerated depreciation and DAC capitalization.' ;
    rdfs:domain ind:TaxProvision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:effectiveTaxRate rdf:type rdf:Property ;
    rdfs:label 'Effective Tax Rate' ;
    rdfs:comment 'The ratio of total income tax expense to pretax income, expressed as a decimal (e.g., 0.2100 for 21%). Key metric for tax efficiency analysis and rate reconciliation disclosure.' ;
    rdfs:domain ind:TaxProvision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:externalAuditorReviewedFlag rdf:type rdf:Property ;
    rdfs:label 'External Auditor Reviewed Flag' ;
    rdfs:comment 'Indicates whether this tax provision has been reviewed by external auditors as part of financial statement audit procedures.' ;
    rdfs:domain ind:TaxProvision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:foreignTaxExpense rdf:type rdf:Property ;
    rdfs:label 'Foreign Tax Expense' ;
    rdfs:comment 'Income tax expense attributable to foreign jurisdictions. Includes taxes paid to foreign governments on international operations and investments.' ;
    rdfs:domain ind:TaxProvision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:irc7702Adjustment rdf:type rdf:Property ;
    rdfs:label 'Irc 7702 Adjustment' ;
    rdfs:comment 'Tax provision adjustment related to IRC Section 7702 life insurance contract qualification testing. Ensures products meet tax-favored treatment requirements.' ;
    rdfs:domain ind:TaxProvision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ldtiTaxImpact rdf:type rdf:Property ;
    rdfs:label 'Ldti Tax Impact' ;
    rdfs:comment 'Tax provision impact from FASB ASU 2018-12 LDTI implementation. Captures deferred tax effects of changes in insurance liability measurement and DAC amortization.' ;
    rdfs:domain ind:TaxProvision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netDeferredTaxPosition rdf:type rdf:Property ;
    rdfs:label 'Net Deferred Tax Position' ;
    rdfs:comment 'Net deferred tax asset or liability, calculated as DTA balance minus DTL balance. Positive values indicate net asset; negative values indicate net liability.' ;
    rdfs:domain ind:TaxProvision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nolCarryforward rdf:type rdf:Property ;
    rdfs:label 'Nol Carryforward' ;
    rdfs:comment 'Tax net operating loss carryforward available to offset future taxable income. Generates deferred tax asset based on expected utilization and statutory tax rate.' ;
    rdfs:domain ind:TaxProvision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:permanentDifferenceAdjustment rdf:type rdf:Property ;
    rdfs:label 'Permanent Difference Adjustment' ;
    rdfs:comment 'Tax provision impact from permanent book-tax differences that do not reverse over time (e.g., tax-exempt interest, non-deductible expenses, dividends received deduction).' ;
    rdfs:domain ind:TaxProvision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pretaxIncome rdf:type rdf:Property ;
    rdfs:label 'Pretax Income' ;
    rdfs:comment 'Income before income taxes per GAAP financial statements. Used as the base for effective tax rate calculation.' ;
    rdfs:domain ind:TaxProvision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:provisionDate rdf:type rdf:Property ;
    rdfs:label 'Provision Date' ;
    rdfs:comment 'The date on which the tax provision was calculated and recorded. Represents the business event timestamp for this tax calculation.' ;
    rdfs:domain ind:TaxProvision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:provisionMethod rdf:type rdf:Property ;
    rdfs:label 'Provision Method' ;
    rdfs:comment 'The methodology used to calculate the tax provision for interim periods. Discrete method treats each period independently; annual effective rate method estimates full-year rate.' ;
    rdfs:domain ind:TaxProvision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:provisionStatus rdf:type rdf:Property ;
    rdfs:label 'Provision Status' ;
    rdfs:comment 'Current lifecycle status of the tax provision record. Tracks progression from initial draft through final audited state.' ;
    rdfs:domain ind:TaxProvision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateChangeImpact rdf:type rdf:Property ;
    rdfs:label 'Rate Change Impact' ;
    rdfs:comment 'Impact on deferred tax balances from changes in enacted tax rates. Requires remeasurement of deferred tax assets and liabilities at new rates.' ;
    rdfs:domain ind:TaxProvision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reserveTemporaryDifference rdf:type rdf:Property ;
    rdfs:label 'Reserve Temporary Difference' ;
    rdfs:comment 'Temporary difference between GAAP insurance reserves and tax reserves. Reflects differences in reserve calculation methodologies between financial reporting and tax compliance.' ;
    rdfs:domain ind:TaxProvision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:returnToProvisionAdjustment rdf:type rdf:Property ;
    rdfs:label 'Return To Provision Adjustment' ;
    rdfs:comment 'Adjustment to reconcile prior period tax provision estimates to actual amounts reported on filed tax returns. Recorded when tax returns are finalized.' ;
    rdfs:domain ind:TaxProvision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reviewedBy rdf:type rdf:Property ;
    rdfs:label 'Reviewed By' ;
    rdfs:comment 'Name or identifier of the senior tax professional who reviewed and approved this tax provision. Required for segregation of duties.' ;
    rdfs:domain ind:TaxProvision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:soxControlCertification rdf:type rdf:Property ;
    rdfs:label 'Sox Control Certification' ;
    rdfs:comment 'Indicates whether this tax provision has been reviewed and certified under SOX Section 404 internal control requirements. Required for public companies.' ;
    rdfs:domain ind:TaxProvision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:stateTaxExpense rdf:type rdf:Property ;
    rdfs:label 'State Tax Expense' ;
    rdfs:comment 'Income tax expense attributable to state and local jurisdictions. Tracked separately from federal tax for rate reconciliation and multi-state tax planning.' ;
    rdfs:domain ind:TaxProvision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:statutoryTaxRate rdf:type rdf:Property ;
    rdfs:label 'Statutory Tax Rate' ;
    rdfs:comment 'The federal statutory corporate income tax rate applicable to the reporting period (e.g., 0.2100 for 21% under IRC Section 11). Starting point for effective tax rate reconciliation.' ;
    rdfs:domain ind:TaxProvision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taxCreditCarryforward rdf:type rdf:Property ;
    rdfs:label 'Tax Credit Carryforward' ;
    rdfs:comment 'Tax credits available to reduce future tax liabilities, including general business credits, foreign tax credits, and alternative minimum tax credits. Generates deferred tax asset.' ;
    rdfs:domain ind:TaxProvision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taxReturnFiledFlag rdf:type rdf:Property ;
    rdfs:label 'Tax Return Filed Flag' ;
    rdfs:comment 'Indicates whether the tax return for this period has been filed with tax authorities. True when return is filed; False when provision is estimated.' ;
    rdfs:domain ind:TaxProvision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:totalTaxExpense rdf:type rdf:Property ;
    rdfs:label 'Total Tax Expense' ;
    rdfs:comment 'Total income tax expense for the period, calculated as the sum of current tax expense and deferred tax expense. Reported on the GAAP income statement.' ;
    rdfs:domain ind:TaxProvision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unrealizedGainTemporaryDifference rdf:type rdf:Property ;
    rdfs:label 'Unrealized Gain Temporary Difference' ;
    rdfs:comment 'Temporary difference from unrealized gains and losses on investments recognized in GAAP financial statements but not yet taxable. Includes available-for-sale securities and fair value adjustments.' ;
    rdfs:domain ind:TaxProvision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:utpReserve rdf:type rdf:Property ;
    rdfs:label 'Utp Reserve' ;
    rdfs:comment 'Reserve for unrecognized tax benefits under ASC 740-10 (formerly FIN 48). Represents tax positions that do not meet the more-likely-than-not recognition threshold.' ;
    rdfs:domain ind:TaxProvision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:valuationAllowance rdf:type rdf:Property ;
    rdfs:label 'Valuation Allowance' ;
    rdfs:comment 'Contra-asset account reducing deferred tax assets to the amount that is more-likely-than-not to be realized. Reflects management judgment on future taxable income sufficiency.' ;
    rdfs:domain ind:TaxProvision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:treatyDocumentId rdf:type rdf:Property ;
    rdfs:label 'Treaty Document Id' ;
    rdfs:comment 'Foreign key linking to document.document. Business justification: Reinsurance recoverables require treaty documents, bordereaux, and collateral agreements for collectibility assessment. Quarterly reinsurance accounting and credit risk assessment depend on linking re' ;
    rdfs:domain ind:ReinsuranceRecoverable ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Document .

ind:allowanceForUncollectible rdf:type rdf:Property ;
    rdfs:label 'Allowance For Uncollectible' ;
    rdfs:comment 'The estimated amount of the gross recoverable that may not be collectible due to reinsurer credit risk, recorded as a contra-asset.' ;
    rdfs:domain ind:ReinsuranceRecoverable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:collateralHeldAmount rdf:type rdf:Property ;
    rdfs:label 'Collateral Held Amount' ;
    rdfs:comment 'The total value of collateral held to secure the recoverable, including letters of credit, trust accounts, and funds withheld.' ;
    rdfs:domain ind:ReinsuranceRecoverable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:daysOutstanding rdf:type rdf:Property ;
    rdfs:label 'Days Outstanding' ;
    rdfs:comment 'The number of calendar days the recoverable has been outstanding since it became due for payment.' ;
    rdfs:domain ind:ReinsuranceRecoverable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ifrs17CsmImpact rdf:type rdf:Property ;
    rdfs:label 'Ifrs17 Csm Impact' ;
    rdfs:comment 'The impact of this recoverable on the Contractual Service Margin under IFRS 17 accounting for insurance contracts.' ;
    rdfs:domain ind:ReinsuranceRecoverable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netRecoverableAmount rdf:type rdf:Property ;
    rdfs:label 'Net Recoverable Amount' ;
    rdfs:comment 'The net recoverable balance after deducting the allowance for uncollectible reinsurance from the gross recoverable amount.' ;
    rdfs:domain ind:ReinsuranceRecoverable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recoverableType rdf:type rdf:Property ;
    rdfs:label 'Recoverable Type' ;
    rdfs:comment 'Classification of the recoverable by its nature: ceded reserve, ceded claim payment, ceded premium refund, ceded benefit, or ceded commission.' ;
    rdfs:domain ind:ReinsuranceRecoverable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapExhibitLine rdf:type rdf:Property ;
    rdfs:label 'Sap Exhibit Line' ;
    rdfs:comment 'The specific line item on the NAIC Annual Statement Schedule F or other exhibit where this recoverable is reported.' ;
    rdfs:domain ind:ReinsuranceRecoverable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryInPlanId rdf:type rdf:Property ;
    rdfs:label 'Primary In Plan Id' ;
    rdfs:comment 'Reference to the insurance product definition that governs this policy contract.' ;
    rdfs:domain ind:InForcePolicy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Plan .

ind:variableSeparateAccountId rdf:type rdf:Property ;
    rdfs:label 'Variable Separate Account Id' ;
    rdfs:comment 'Foreign key linking to investment.separate_account. Business justification: Variable life and variable annuity policies are legally and regulatorily required to identify their backing separate account (SEC registration, prospectus delivery, NAIC separate account reporting). R' ;
    rdfs:domain ind:InForcePolicy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SeparateAccount .

ind:writingAgencyId rdf:type rdf:Property ;
    rdfs:label 'Writing Agency Id' ;
    rdfs:comment 'Foreign key linking to agent.agency. Business justification: Policies are placed through agencies, not just individual producers. Carriers track the writing agency for agency-level commission statements, E&O coverage verification at issue, agency production rep' ;
    rdfs:domain ind:InForcePolicy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Agency .

ind:writingAppointmentId rdf:type rdf:Property ;
    rdfs:label 'Writing Appointment Id' ;
    rdfs:comment 'Foreign key linking to agent.appointment. Business justification: State DOI regulations require carriers to verify the writing producer held an active appointment in the state of issue at policy issuance. Linking the policy to the specific appointment record support' ;
    rdfs:domain ind:InForcePolicy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Appointment .

ind:gptCvatElection rdf:type rdf:Property ;
    rdfs:label 'Gpt Cvat Election' ;
    rdfs:comment 'The IRC Section 7702 test elected at policy issue to determine life insurance qualification. GPT=Guideline Premium Test with guideline single and level premium limits, CVAT=Cash Value Accumulation Test with cash value corridor requirements.' ;
    rdfs:domain ind:InForcePolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jurisdictionState rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction State' ;
    rdfs:comment 'The two-letter US state code where the policy was issued and is subject to regulatory oversight. Determines applicable insurance laws and regulations.' ;
    rdfs:domain ind:InForcePolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mecStatusFlag rdf:type rdf:Property ;
    rdfs:label 'Mec Status Flag' ;
    rdfs:comment 'Indicates whether the policy has been classified as a Modified Endowment Contract under IRC Section 7702A due to premium payments exceeding the 7-pay test. True=MEC status, distributions subject to LIFO tax treatment and 10% penalty.' ;
    rdfs:domain ind:LifeInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:modalPremium rdf:type rdf:Property ;
    rdfs:label 'Modal Premium' ;
    rdfs:comment 'The scheduled premium amount due per billing mode (monthly, quarterly, semi-annual, annual). Does not include additional premium payments or adjustments.' ;
    rdfs:domain ind:InForcePolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:policyCurrency rdf:type rdf:Property ;
    rdfs:label 'Policy Currency' ;
    rdfs:comment 'The three-letter ISO 4217 currency code in which all policy values, premiums, and benefits are denominated (e.g., USD, CAD, EUR).' ;
    rdfs:domain ind:InForcePolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyStatus rdf:type rdf:Property ;
    rdfs:label 'Policy Status' ;
    rdfs:comment 'Current lifecycle status of the policy contract. ACTIVE=in-force and premium-paying, LAPSED=terminated due to non-payment, SURRENDERED=voluntarily terminated by owner, MATURED=reached maturity date, DEATH_CLAIM=claim filed on insured death, FREE_LOOK=within free-look cancellation period, GRACE_PERIOD=premium overdue but within grace period. [ENUM-REF-CANDIDATE: ACTIVE|LAPSED|SURRENDERED|MATURED|DEATH_CLAIM|FREE_LOOK|GRACE_PERIOD — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:InForcePolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accumulatedPremiumAmount rdf:type rdf:Property ;
    rdfs:label 'Accumulated Premium Amount' ;
    rdfs:comment 'The cumulative sum of all premiums paid into the policy from inception through the valuation date. Used for MEC testing and tax compliance.' ;
    rdfs:domain ind:Value ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:adminFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Admin Fee Amount' ;
    rdfs:comment 'The administrative or policy fee deducted from the account value during the most recent billing cycle prior to the valuation date.' ;
    rdfs:domain ind:Value ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:avAmount rdf:type rdf:Property ;
    rdfs:label 'Av Amount' ;
    rdfs:comment 'The gross account value of the policy before any surrender charges or loan deductions. Represents accumulated premiums plus interest credits less cost of insurance and fees.' ;
    rdfs:domain ind:Value ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coiChargeAmount rdf:type rdf:Property ;
    rdfs:label 'Coi Charge Amount' ;
    rdfs:comment 'The cost of insurance charge deducted from the account value during the most recent billing cycle prior to the valuation date.' ;
    rdfs:domain ind:Value ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cvatComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Cvat Compliance Flag' ;
    rdfs:comment 'Indicates whether the policy is in compliance with the Cash Value Accumulation Test under IRC Section 7702. True if compliant, False if failed. Alternative to GPT for tax qualification.' ;
    rdfs:domain ind:Value ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dividendAccumulationBalance rdf:type rdf:Property ;
    rdfs:label 'Dividend Accumulation Balance' ;
    rdfs:comment 'The balance of policyholder dividends left on deposit with the insurer, earning interest. Available for withdrawal or to pay premiums.' ;
    rdfs:domain ind:Value ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fundAllocationTotal rdf:type rdf:Property ;
    rdfs:label 'Fund Allocation Total' ;
    rdfs:comment 'The total value of all sub-account or fund allocations for variable or indexed products. Should reconcile to account value for variable universal life (VUL) policies.' ;
    rdfs:domain ind:Value ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gptComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Gpt Compliance Flag' ;
    rdfs:comment 'Indicates whether the policy is in compliance with the Guideline Premium Test under IRC Section 7702. True if compliant, False if failed. Critical for tax-qualified life insurance status.' ;
    rdfs:domain ind:Value ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:guaranteedMinimumValue rdf:type rdf:Property ;
    rdfs:label 'Guaranteed Minimum Value' ;
    rdfs:comment 'The guaranteed minimum cash value or account value as of the valuation date, per policy guarantees. Cannot fall below this floor regardless of performance.' ;
    rdfs:domain ind:Value ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastPremiumPaymentDate rdf:type rdf:Property ;
    rdfs:label 'Last Premium Payment Date' ;
    rdfs:comment 'The date of the most recent premium payment received prior to or on the valuation date. Used for lapse monitoring and grace period calculations.' ;
    rdfs:domain ind:Value ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:loanBalanceAmount rdf:type rdf:Property ;
    rdfs:label 'Loan Balance Amount' ;
    rdfs:comment 'The outstanding principal balance of all policy loans as of the valuation date. Reduces cash surrender value and may affect death benefit.' ;
    rdfs:domain ind:Value ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:loanInterestAccruedAmount rdf:type rdf:Property ;
    rdfs:label 'Loan Interest Accrued Amount' ;
    rdfs:comment 'The accrued but unpaid interest on outstanding policy loans as of the valuation date. Typically capitalized into loan balance if unpaid.' ;
    rdfs:domain ind:Value ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nextBillingDate rdf:type rdf:Property ;
    rdfs:label 'Next Billing Date' ;
    rdfs:comment 'The next scheduled date on which premium is due or policy charges will be deducted. Critical for billing system integration and lapse prevention.' ;
    rdfs:domain ind:Value ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paidUpAdditionsValue rdf:type rdf:Property ;
    rdfs:label 'Paid Up Additions Value' ;
    rdfs:comment 'The accumulated value of paid-up additional insurance purchased with dividends or excess premiums. Increases both cash value and death benefit.' ;
    rdfs:domain ind:Value ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:policyAnniversaryDate rdf:type rdf:Property ;
    rdfs:label 'Policy Anniversary Date' ;
    rdfs:comment 'The annual anniversary date of the policy, used for age changes, rate adjustments, and anniversary-based policy actions.' ;
    rdfs:domain ind:Value ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:premiumYtdAmount rdf:type rdf:Property ;
    rdfs:label 'Premium Ytd Amount' ;
    rdfs:comment 'The cumulative amount of premiums received during the current calendar year through the valuation date. Used for MEC testing and premium tracking.' ;
    rdfs:domain ind:Value ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:riderChargeAmount rdf:type rdf:Property ;
    rdfs:label 'Rider Charge Amount' ;
    rdfs:comment 'The total charges for all active policy riders (ADB, AWL, LTC, etc.) deducted during the most recent billing cycle prior to the valuation date.' ;
    rdfs:domain ind:Value ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:surrenderChargeEndDate rdf:type rdf:Property ;
    rdfs:label 'Surrender Charge End Date' ;
    rdfs:comment 'The date on which the surrender charge period expires and no further surrender charges will be assessed. Null if surrender charges have already expired.' ;
    rdfs:domain ind:Value ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:valuationBasisCode rdf:type rdf:Property ;
    rdfs:label 'Valuation Basis Code' ;
    rdfs:comment 'The accounting or regulatory basis under which these policy values were calculated. STAT=Statutory (SAP), GAAP=US GAAP, IFRS=IFRS 17, TAX=Tax basis.' ;
    rdfs:domain ind:Value ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:withdrawalYtdAmount rdf:type rdf:Property ;
    rdfs:label 'Withdrawal Ytd Amount' ;
    rdfs:comment 'The cumulative amount of partial withdrawals taken from the policy during the current calendar year through the valuation date. Used for tax reporting and withdrawal limit tracking.' ;
    rdfs:domain ind:Value ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:endorsementDocumentId rdf:type rdf:Property ;
    rdfs:label 'Endorsement Document Id' ;
    rdfs:comment 'Foreign key linking to document.document. Business justification: Rider additions generate endorsement documents that are legal amendments to the base policy contract, required for state DOI filing and policyholder delivery. Direct FK links the rider record to its e' ;
    rdfs:domain ind:Rider ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Document .

ind:primaryPolicyInForcePolicyId rdf:type rdf:Property ;
    rdfs:label 'Primary Policy In Force Policy Id' ;
    rdfs:comment 'Reference to the base policy contract to which this rider is attached. A policy may have multiple riders.' ;
    rdfs:domain ind:Rider ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InForcePolicy .

ind:benefitPeriodMonths rdf:type rdf:Property ;
    rdfs:label 'Benefit Period Months' ;
    rdfs:comment 'The maximum duration (in months) for which benefits will be paid once triggered. Common for disability income and long-term care riders. Null if benefit is a lump sum or lifetime benefit.' ;
    rdfs:domain ind:Rider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:benefitTriggerCondition rdf:type rdf:Property ;
    rdfs:label 'Benefit Trigger Condition' ;
    rdfs:comment 'The specific condition or event that must occur for the rider benefit to be payable. Examples: accidental death, disability, critical illness diagnosis, inability to perform ADLs (Activities of Daily Living), account value depletion, etc.' ;
    rdfs:domain ind:Rider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cashValue rdf:type rdf:Property ;
    rdfs:label 'Cash Value' ;
    rdfs:comment 'The accumulated cash value or account value associated with this rider, if applicable. Some riders (e.g., paid-up additions riders) accumulate cash value. Null for term riders or pure protection riders. Expressed in policy currency.' ;
    rdfs:domain ind:Rider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costOfInsuranceRate rdf:type rdf:Property ;
    rdfs:label 'Cost Of Insurance Rate' ;
    rdfs:comment 'The per-unit cost of insurance rate applied to the rider face amount to calculate the rider charge. Common for universal life and variable universal life riders. Expressed as a rate per thousand of coverage.' ;
    rdfs:domain ind:Rider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:eliminationPeriodDays rdf:type rdf:Property ;
    rdfs:label 'Elimination Period Days' ;
    rdfs:comment 'The waiting period (in days) from the date of a qualifying event until benefits begin to be paid. Common for disability income and long-term care riders. Zero or null if no elimination period applies.' ;
    rdfs:domain ind:Rider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:guaranteedInsurabilityFlag rdf:type rdf:Property ;
    rdfs:label 'Guaranteed Insurability Flag' ;
    rdfs:comment 'Indicates whether this rider includes a guaranteed insurability option, allowing the policyholder to increase coverage at specified intervals without additional underwriting. True if option is included, False otherwise.' ;
    rdfs:domain ind:LifeInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:loanOutstandingAmount rdf:type rdf:Property ;
    rdfs:label 'Loan Outstanding Amount' ;
    rdfs:comment 'The outstanding loan amount taken against this riders cash value, if loans are permitted. Expressed in policy currency. Null or zero if no loan exists.' ;
    rdfs:domain ind:Rider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:premiumAmount rdf:type rdf:Property ;
    rdfs:label 'Premium Amount' ;
    rdfs:comment 'The premium charged for this specific rider on this policy, calculated based on rider premium_basis, insured age, risk class, and face amount. This is the actual premium for this policy-rider instance.' ;
    rdfs:domain ind:LifeInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:premiumFrequency rdf:type rdf:Property ;
    rdfs:label 'Premium Frequency' ;
    rdfs:comment 'Frequency at which the rider premium is charged. Annual: once per year. Semi-annual: twice per year. Quarterly: four times per year. Monthly: twelve times per year. Single: one-time premium payment.' ;
    rdfs:domain ind:Rider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ratingPercentage rdf:type rdf:Property ;
    rdfs:label 'Rating Percentage' ;
    rdfs:comment 'Additional premium percentage applied for substandard underwriting risk. Expressed as a percentage (e.g., 25.00 means 25% additional premium). Null or zero for standard and preferred classes.' ;
    rdfs:domain ind:Rider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reinsuranceCededFlag rdf:type rdf:Property ;
    rdfs:label 'Reinsurance Ceded Flag' ;
    rdfs:comment 'Indicates whether the risk for this rider has been ceded to a reinsurer. True if reinsured, False if retained. Used for risk management and financial reporting.' ;
    rdfs:domain ind:Rider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:surrenderCharge rdf:type rdf:Property ;
    rdfs:label 'Surrender Charge' ;
    rdfs:comment 'The penalty or charge applied if the rider is surrendered or terminated early. Common for riders with cash value or guaranteed benefits. Expressed in policy currency. Null if no surrender charge applies.' ;
    rdfs:domain ind:Rider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:withdrawalPercentage rdf:type rdf:Property ;
    rdfs:label 'Withdrawal Percentage' ;
    rdfs:comment 'The maximum annual withdrawal percentage allowed under a GMWB (Guaranteed Minimum Withdrawal Benefit) rider without penalty. Expressed as a percentage of the benefit base (e.g., 5.00 means 5% per year).' ;
    rdfs:domain ind:Rider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:statusHistoryId rdf:type rdf:Property ;
    rdfs:label 'Status History Id' ;
    rdfs:comment 'Unique identifier for each policy status transition record. Primary key for the policy status history audit log.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:statusJournalEntryId rdf:type rdf:Property ;
    rdfs:label 'Status Journal Entry Id' ;
    rdfs:comment 'Foreign key linking to finance.journal_entry. Business justification: Policy status changes (lapse, termination) trigger reserve release journal entries. Finance teams reconcile reserve releases to specific lapse events for statutory reserve adequacy reporting and LDTI ' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:JournalEntry .

ind:statusNoticeDocumentId rdf:type rdf:Property ;
    rdfs:label 'Status Notice Document Id' ;
    rdfs:comment 'Foreign key linking to document.document. Business justification: Policy status changes (lapse, grace period, reinstatement eligibility) trigger mandatory regulatory notices (grace period notices, lapse notices) required by state insurance codes. Direct FK links the' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Document .

ind:freeLookCancellationRequestDate rdf:type rdf:Property ;
    rdfs:label 'Free Look Cancellation Request Date' ;
    rdfs:comment 'Date when the policyholder requested cancellation during the free-look period. Null if no free-look cancellation occurred.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:freeLookPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Free Look Period End Date' ;
    rdfs:comment 'Date when the free-look period expires. Typically 10-30 days after start date per state DOI requirements. Policyholder may cancel without penalty before this date.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:freeLookPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Free Look Period Start Date' ;
    rdfs:comment 'Date when the free-look period began. Typically starts on policy delivery or issue date. Null if not applicable to this transition.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:freeLookRefundAmount rdf:type rdf:Property ;
    rdfs:label 'Free Look Refund Amount' ;
    rdfs:comment 'Total amount refunded to the policyholder upon free-look cancellation. Typically includes all premiums paid minus any policy charges per state regulations.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:freeLookRefundDisbursementDate rdf:type rdf:Property ;
    rdfs:label 'Free Look Refund Disbursement Date' ;
    rdfs:comment 'Date when the free-look refund was actually disbursed to the policyholder. Null if no refund occurred.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:freeLookRefundMethod rdf:type rdf:Property ;
    rdfs:label 'Free Look Refund Method' ;
    rdfs:comment 'Method used to refund the premium during free-look cancellation. Null if no refund occurred.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryReportingFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reporting Flag' ;
    rdfs:comment 'Indicates whether this status transition must be included in regulatory reporting to state DOI or NAIC. True if reportable, False otherwise.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reinstatementEligibilityExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Reinstatement Eligibility Expiry Date' ;
    rdfs:comment 'Date after which the policy is no longer eligible for reinstatement. Typically 3-5 years after lapse date per policy terms and state regulations.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reversalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Reversal Timestamp' ;
    rdfs:comment 'Timestamp when this status transition was reversed. Null if no reversal occurred.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sourceTransactionCode rdf:type rdf:Property ;
    rdfs:label 'Source Transaction Code' ;
    rdfs:comment 'Identifier of the upstream transaction that triggered this status transition. Examples: billing transaction ID, claim ID, underwriting decision ID. Enables traceability to originating event.' ;
    rdfs:domain ind:Policy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceTransactionType rdf:type rdf:Property ;
    rdfs:label 'Source Transaction Type' ;
    rdfs:comment 'Type of transaction that triggered this status transition. Provides context for the originating business event. [ENUM-REF-CANDIDATE: premium_payment|claim_submission|underwriting_decision|policy_amendment|reinstatement_application|surrender_request|maturity_event|death_notification|free_look_cancellation|system_batch — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transitionApprovalRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Transition Approval Required Flag' ;
    rdfs:comment 'Indicates whether this status transition required supervisory or underwriting approval. True if approval was required, False otherwise.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:transitionApprovedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Transition Approved Timestamp' ;
    rdfs:comment 'Timestamp when the status transition was approved. Null if no approval was required or if pending approval.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:transitionReasonCode rdf:type rdf:Property ;
    rdfs:label 'Transition Reason Code' ;
    rdfs:comment 'Standardized code indicating why the status transition occurred. Examples: lapse for non-payment, reinstatement, surrender, death claim, maturity, conversion, rescission, free-look cancellation, grace period expiry, premium payment received, underwriting approval, policy issued.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transitionReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Transition Reason Description' ;
    rdfs:comment 'Detailed narrative explanation of the reason for the status transition. Provides business context beyond the reason code.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transitionTriggeredBySystem rdf:type rdf:Property ;
    rdfs:label 'Transition Triggered By System' ;
    rdfs:comment 'Name of the system that triggered the status transition. Examples: Policy Administration System, Billing System, Claims System, Underwriting Workbench, Manual Entry.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transitionTriggeredByUserName rdf:type rdf:Property ;
    rdfs:label 'Transition Triggered By User Name' ;
    rdfs:comment 'Full name of the user who initiated the status transition. Denormalized for audit trail completeness. Null if transition was system-automated.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:designationDocumentId rdf:type rdf:Property ;
    rdfs:label 'Designation Document Id' ;
    rdfs:comment 'Foreign key linking to document.document. Business justification: Beneficiary designation changes require executed designation forms as legal documents governing death benefit distribution. Direct FK links the beneficiary record to its governing designation document' ;
    rdfs:domain ind:PolicyBeneficiary ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Document .

ind:designationAmount rdf:type rdf:Property ;
    rdfs:label 'Designation Amount' ;
    rdfs:comment 'Fixed dollar amount designated to this beneficiary, used when the beneficiary receives a specific amount rather than a percentage. Null if percentage-based designation is used.' ;
    rdfs:domain ind:PolicyBeneficiary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:designationEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Designation Effective Date' ;
    rdfs:comment 'Date on which this beneficiary designation became effective. Corresponds to the policy issue date for original designations or the change request approval date for subsequent changes.' ;
    rdfs:domain ind:PolicyBeneficiary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:designationEndDate rdf:type rdf:Property ;
    rdfs:label 'Designation End Date' ;
    rdfs:comment 'Date on which this beneficiary designation was terminated or superseded by a new designation. Null for currently active beneficiary designations.' ;
    rdfs:domain ind:PolicyBeneficiary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fullName rdf:type rdf:Property ;
    rdfs:label 'Full Name' ;
    rdfs:comment 'The complete legal name of the beneficiary as it should appear on death benefit or annuity payout documentation. For trust beneficiaries, this is the full legal name of the trust.' ;
    rdfs:domain ind:PolicyBeneficiary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isMinor rdf:type rdf:Property ;
    rdfs:label 'Is Minor' ;
    rdfs:comment 'Boolean flag indicating whether the beneficiary is a minor (under age 18 or state-specific age of majority). True if minor, False if adult. Determines whether guardian or custodian designation is required.' ;
    rdfs:domain ind:PolicyBeneficiary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRevocable rdf:type rdf:Property ;
    rdfs:label 'Is Revocable' ;
    rdfs:comment 'Boolean flag indicating whether the beneficiary designation can be changed by the policy owner without the beneficiary consent. True if revocable (can be changed), False if irrevocable (requires beneficiary consent to change).' ;
    rdfs:domain ind:PolicyBeneficiary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:suffix rdf:type rdf:Property ;
    rdfs:label 'Suffix' ;
    rdfs:comment 'Generational or professional suffix appended to the beneficiary name (e.g., Jr., Sr., II, III).' ;
    rdfs:domain ind:LifeInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trustDateEstablished rdf:type rdf:Property ;
    rdfs:label 'Trust Date Established' ;
    rdfs:comment 'Date the trust was legally established. Used for trust qualification verification and estate planning documentation. Null for non-trust beneficiaries.' ;
    rdfs:domain ind:PolicyBeneficiary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:trustName rdf:type rdf:Property ;
    rdfs:label 'Trust Name' ;
    rdfs:comment 'Full legal name of the trust when the beneficiary is an Irrevocable Life Insurance Trust (ILIT) or other trust entity. Null for individual beneficiaries.' ;
    rdfs:domain ind:LifeInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trusteeName rdf:type rdf:Property ;
    rdfs:label 'Trustee Name' ;
    rdfs:comment 'Name of the trustee responsible for administering the trust and receiving death benefit proceeds on behalf of trust beneficiaries. Null for non-trust beneficiaries.' ;
    rdfs:domain ind:LifeInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownerId rdf:type rdf:Property ;
    rdfs:label 'Owner Id' ;
    rdfs:comment 'Unique identifier for the policy ownership record. Primary key for the policy owner association entity.' ;
    rdfs:domain ind:Owner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ownerCollateralAssigneePartyId rdf:type rdf:Property ;
    rdfs:label 'Owner Collateral Assignee Party Id' ;
    rdfs:comment 'Reference to the party (typically a lender or financial institution) who holds the collateral assignment interest in the policy. Null if collateral_assignment_flag is False.' ;
    rdfs:domain ind:Owner ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:ownerPoaPartyId rdf:type rdf:Property ;
    rdfs:label 'Owner Poa Party Id' ;
    rdfs:comment 'Reference to the party who holds power of attorney authority to act on behalf of the owner. Null if power_of_attorney_flag is False.' ;
    rdfs:domain ind:Owner ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:insurableInterestVerifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Insurable Interest Verified Flag' ;
    rdfs:comment 'Indicates whether insurable interest between the owner and insured was verified at policy issuance or ownership transfer. True = insurable interest documented and verified; False = not verified. Required for STOLI prevention and regulatory compliance.' ;
    rdfs:domain ind:Owner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:noticePreference rdf:type rdf:Property ;
    rdfs:label 'Notice Preference' ;
    rdfs:comment 'Preferred method for delivering policy notices, statements, and communications to the owner. Mail = postal mail; Email = electronic delivery; Portal = online customer portal; Agent = through agent/producer.' ;
    rdfs:domain ind:Owner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownershipSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Ownership Source System' ;
    rdfs:comment 'Name of the source policy administration system or platform that originated this ownership record (e.g., FAST, Sapiens LifePro, Oracle Insurance). Used for data lineage and reconciliation.' ;
    rdfs:domain ind:Owner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownershipSourceSystemCode rdf:type rdf:Property ;
    rdfs:label 'Ownership Source System Code' ;
    rdfs:comment 'Unique identifier for this ownership record in the source policy administration system. Used for data lineage, reconciliation, and bidirectional synchronization.' ;
    rdfs:domain ind:Owner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:powerOfAttorneyFlag rdf:type rdf:Property ;
    rdfs:label 'Power Of Attorney Flag' ;
    rdfs:comment 'Indicates whether a power of attorney arrangement is in place allowing another party to act on behalf of the owner for policy servicing transactions. True = POA is active; False = no POA.' ;
    rdfs:domain ind:Owner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sanctionsScreeningDate rdf:type rdf:Property ;
    rdfs:label 'Sanctions Screening Date' ;
    rdfs:comment 'Date when the most recent sanctions screening was performed for the policy owner. Null if sanctions_screening_status is not_screened.' ;
    rdfs:domain ind:Owner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sanctionsScreeningStatus rdf:type rdf:Property ;
    rdfs:label 'Sanctions Screening Status' ;
    rdfs:comment 'Result of screening the policy owner against OFAC and other sanctions lists. Clear = no match found; Match = potential match requires review; Pending = screening in progress; Not Screened = screening not yet performed.' ;
    rdfs:domain ind:Owner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxReportingOwnerFlag rdf:type rdf:Property ;
    rdfs:label 'Tax Reporting Owner Flag' ;
    rdfs:comment 'Indicates whether this owner is the designated party for IRS tax reporting purposes (1099-R, 1099-INT). True = this owner receives tax forms; False = not the tax reporting owner. Critical for IRC Section 7702 and 72 compliance.' ;
    rdfs:domain ind:Owner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:policyReinstatementId rdf:type rdf:Property ;
    rdfs:label 'Policy Reinstatement Id' ;
    rdfs:comment 'Unique identifier for the policy reinstatement record. Primary key for the policy reinstatement entity.' ;
    rdfs:domain ind:PolicyReinstatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:adverseActionNoticeSentDate rdf:type rdf:Property ;
    rdfs:label 'Adverse Action Notice Sent Date' ;
    rdfs:comment 'Date the adverse action notice was sent to the applicant following a denial or rated decision. Required for regulatory compliance.' ;
    rdfs:domain ind:PolicyReinstatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:applicationChannel rdf:type rdf:Property ;
    rdfs:label 'Application Channel' ;
    rdfs:comment 'Channel through which the reinstatement application was submitted. Supports channel performance analysis and customer experience tracking.' ;
    rdfs:domain ind:PolicyReinstatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contestablePeriodRestartFlag rdf:type rdf:Property ;
    rdfs:label 'Contestable Period Restart Flag' ;
    rdfs:comment 'Indicates whether the two-year contestable period restarts from the reinstatement effective date. Impacts claims adjudication and fraud investigation rights.' ;
    rdfs:domain ind:PolicyReinstatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:csvAtLapseAmount rdf:type rdf:Property ;
    rdfs:label 'Csv At Lapse Amount' ;
    rdfs:comment 'Cash surrender value of the policy at the time of lapse. May be applied toward back premiums or returned to policyholder based on policy provisions.' ;
    rdfs:domain ind:PolicyReinstatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:evidenceOfInsurabilityRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Evidence Of Insurability Required Flag' ;
    rdfs:comment 'Indicates whether the applicant must provide evidence of continued insurability for reinstatement. Typically required if lapse exceeded a threshold period.' ;
    rdfs:domain ind:Policy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:feeAmount rdf:type rdf:Property ;
    rdfs:label 'Fee Amount' ;
    rdfs:comment 'Administrative fee charged for processing the reinstatement application. May vary by policy type and jurisdiction.' ;
    rdfs:domain ind:LifeInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:healthStatementAttestationDate rdf:type rdf:Property ;
    rdfs:label 'Health Statement Attestation Date' ;
    rdfs:comment 'Date the applicant signed and attested to the accuracy of the health statement. Legal date for representation and warranty purposes.' ;
    rdfs:domain ind:PolicyReinstatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:healthStatementReceivedDate rdf:type rdf:Property ;
    rdfs:label 'Health Statement Received Date' ;
    rdfs:comment 'Date the completed health statement was received from the applicant. Tracks compliance with evidence of insurability requirements.' ;
    rdfs:domain ind:PolicyReinstatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:healthStatementRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Health Statement Required Flag' ;
    rdfs:comment 'Indicates whether the applicant must complete a health statement questionnaire. Standard requirement for reinstatements beyond the grace period.' ;
    rdfs:domain ind:PolicyReinstatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:loanBalanceAtLapseAmount rdf:type rdf:Property ;
    rdfs:label 'Loan Balance At Lapse Amount' ;
    rdfs:comment 'Outstanding policy loan balance at the time of lapse. Must be repaid or reinstated along with the policy.' ;
    rdfs:domain ind:PolicyReinstatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentReceivedDate rdf:type rdf:Property ;
    rdfs:label 'Payment Received Date' ;
    rdfs:comment 'Date the reinstatement payment was received by the company. Key date for determining when reinstatement can be processed.' ;
    rdfs:domain ind:PolicyReinstatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:processingDurationDays rdf:type rdf:Property ;
    rdfs:label 'Processing Duration Days' ;
    rdfs:comment 'Number of calendar days from application receipt to final decision. Key performance indicator for operational efficiency and customer experience.' ;
    rdfs:domain ind:Policy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reinstatementStatus rdf:type rdf:Property ;
    rdfs:label 'Reinstatement Status' ;
    rdfs:comment 'Current status of the reinstatement application in the workflow. Tracks progression from initial application through final decision.' ;
    rdfs:domain ind:PolicyReinstatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:suicideExclusionRestartFlag rdf:type rdf:Property ;
    rdfs:label 'Suicide Exclusion Restart Flag' ;
    rdfs:comment 'Indicates whether the suicide exclusion period restarts from the reinstatement effective date. Impacts death benefit eligibility for suicide claims.' ;
    rdfs:domain ind:PolicyReinstatement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:resultingAnnuityContractId rdf:type rdf:Property ;
    rdfs:label 'Resulting Annuity Contract Id' ;
    rdfs:comment 'Foreign key linking to annuity.annuity_contract. Business justification: Surrendered life policies frequently roll into annuities via 1035 tax-free exchanges. Surrender processing tracks the resulting annuity contract for tax reporting (Form 1099-R coordination), customer ' ;
    rdfs:domain ind:Policy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Contract .

ind:chargeAmount rdf:type rdf:Property ;
    rdfs:label 'Charge Amount' ;
    rdfs:comment 'Surrender charge assessed against the gross amount per the policy or contract schedule. Recovers deferred acquisition costs (DAC) and early termination expenses.' ;
    rdfs:domain ind:Surrender ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:csvAmountUsed rdf:type rdf:Property ;
    rdfs:label 'Csv Amount Used' ;
    rdfs:comment 'Cash Surrender Value amount applied to fund the nonforfeiture benefit (extended term or reduced paid-up insurance) or automatic premium loan. Represents the policy equity consumed by the nonforfeiture transaction.' ;
    rdfs:domain ind:Surrender ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:disbursementDate rdf:type rdf:Property ;
    rdfs:label 'Disbursement Date' ;
    rdfs:comment 'Date the net surrender proceeds were disbursed to the policyholder, beneficiary, or receiving financial institution.' ;
    rdfs:domain ind:Policy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:disbursementMethod rdf:type rdf:Property ;
    rdfs:label 'Disbursement Method' ;
    rdfs:comment 'Method by which net surrender proceeds were disbursed to the policyholder or receiving institution: check (mailed check), EFT (electronic funds transfer), wire transfer (same-day wire), 1035 direct transfer (trustee-to-trustee transfer for tax-free exchange), ACH (automated clearing house transfer).' ;
    rdfs:domain ind:Policy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:form1099rIndicator rdf:type rdf:Property ;
    rdfs:label 'Form 1099r Indicator' ;
    rdfs:comment 'Indicates whether this surrender transaction requires IRS Form 1099-R reporting for taxable distributions from life insurance, annuities, pensions, or retirement plans. True if 1099-R reporting is required; false otherwise.' ;
    rdfs:domain ind:Surrender ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mvaAmount rdf:type rdf:Property ;
    rdfs:label 'Mva Amount' ;
    rdfs:comment 'Market Value Adjustment applied to fixed indexed annuities (FIA) or fixed annuities with MVA riders. Positive value indicates upward adjustment; negative value indicates downward adjustment based on interest rate movements since contract issue.' ;
    rdfs:domain ind:Surrender ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:naicComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Naic Compliance Flag' ;
    rdfs:comment 'Indicates whether this surrender transaction complies with NAIC Standard Nonforfeiture Law requirements for minimum cash values, nonforfeiture options, and grace period provisions. True if compliant; false if exception or waiver applies.' ;
    rdfs:domain ind:Surrender ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:netProceeds rdf:type rdf:Property ;
    rdfs:label 'Net Proceeds' ;
    rdfs:comment 'Net amount payable to the policyholder or contract owner after deducting surrender charges, market value adjustments, outstanding policy loans, and tax withholding from the gross amount.' ;
    rdfs:domain ind:Surrender ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nonforfeitureElectionDate rdf:type rdf:Property ;
    rdfs:label 'Nonforfeiture Election Date' ;
    rdfs:comment 'Date the policyholder elected or the insurer applied the default nonforfeiture option. Applicable when policy lapses without premium payment and nonforfeiture provisions are triggered.' ;
    rdfs:domain ind:Surrender ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nonforfeitureOptionType rdf:type rdf:Property ;
    rdfs:label 'Nonforfeiture Option Type' ;
    rdfs:comment 'Nonforfeiture benefit option elected or defaulted upon policy lapse or surrender: cash surrender (CSV payout), extended term insurance (CSV purchases term coverage for original face amount), reduced paid-up insurance (CSV purchases reduced permanent coverage), automatic premium loan (CSV funds overdue premiums), or none (no nonforfeiture benefit applicable).' ;
    rdfs:domain ind:Surrender ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outstandingLoanAmount rdf:type rdf:Property ;
    rdfs:label 'Outstanding Loan Amount' ;
    rdfs:comment 'Outstanding policy loan principal and accrued interest deducted from the gross surrender value at the time of surrender. Applies to life insurance policies with loan provisions.' ;
    rdfs:domain ind:Surrender ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:processingDate rdf:type rdf:Property ;
    rdfs:label 'Processing Date' ;
    rdfs:comment 'Date the surrender transaction was processed and posted to the policy administration system, updating policy status, values, and accounting ledgers.' ;
    rdfs:domain ind:Surrender ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:receivingCarrierName rdf:type rdf:Property ;
    rdfs:label 'Receiving Carrier Name' ;
    rdfs:comment 'Name of the receiving insurance carrier or financial institution for 1035 exchange transactions. Populated when the surrender is part of a tax-free policy exchange.' ;
    rdfs:domain ind:Surrender ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivingPolicyNumber rdf:type rdf:Property ;
    rdfs:label 'Receiving Policy Number' ;
    rdfs:comment 'Policy or contract number at the receiving carrier for 1035 exchange transactions. Links the surrendered policy to the replacement contract.' ;
    rdfs:domain ind:Surrender ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reducedPaidUpStatus rdf:type rdf:Property ;
    rdfs:label 'Reduced Paid Up Status' ;
    rdfs:comment 'Current status of the reduced paid-up policy resulting from the nonforfeiture election: active (coverage in force), lapsed (coverage terminated), matured (endowment matured), surrendered (subsequently surrendered for remaining CSV).' ;
    rdfs:domain ind:Surrender ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxableGainAmount rdf:type rdf:Property ;
    rdfs:label 'Taxable Gain Amount' ;
    rdfs:comment 'Taxable gain portion of the surrender distribution calculated as the excess of the amount received over the cost basis (premiums paid less prior distributions). Reported on IRS Form 1099-R.' ;
    rdfs:domain ind:Surrender ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:originationValuationId rdf:type rdf:Property ;
    rdfs:label 'Origination Valuation Id' ;
    rdfs:comment 'Foreign key linking to investment.valuation. Business justification: Maximum policy loan amount is determined by the CSV, which is derived from the investment valuation at loan origination. Recording the specific valuation snapshot used supports loan origination audit ' ;
    rdfs:domain ind:Loan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Valuation .

ind:accruedInterestBalance rdf:type rdf:Property ;
    rdfs:label 'Accrued Interest Balance' ;
    rdfs:comment 'Total interest accrued on the loan that has not been paid or capitalized into principal.' ;
    rdfs:domain ind:Loan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:closureReason rdf:type rdf:Property ;
    rdfs:label 'Closure Reason' ;
    rdfs:comment 'Reason the loan was closed. Full_repayment indicates borrower paid off loan; offset_death_claim indicates loan was deducted from death benefit; offset_surrender indicates loan was deducted from surrender proceeds; policy_lapse indicates policy lapsed due to loan exceeding CSV; loan_forgiveness indicates loan was forgiven (rare, typically taxable event).' ;
    rdfs:domain ind:Loan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collateralCsvAmount rdf:type rdf:Property ;
    rdfs:label 'Collateral Csv Amount' ;
    rdfs:comment 'Cash Surrender Value (CSV) of the policy at the time of loan origination, representing the maximum collateral available to secure the loan.' ;
    rdfs:domain ind:Loan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:interestCapitalizationDate rdf:type rdf:Property ;
    rdfs:label 'Interest Capitalization Date' ;
    rdfs:comment 'Date on which accrued interest was capitalized (added to principal balance), typically occurring annually on the policy anniversary if interest remains unpaid.' ;
    rdfs:domain ind:Loan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:interestCreditingFrequency rdf:type rdf:Property ;
    rdfs:label 'Interest Crediting Frequency' ;
    rdfs:comment 'Frequency at which interest is calculated and added to the accrued interest balance.' ;
    rdfs:domain ind:Loan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastInterestPostingDate rdf:type rdf:Property ;
    rdfs:label 'Last Interest Posting Date' ;
    rdfs:comment 'Most recent date on which interest was calculated and posted to the accrued interest balance.' ;
    rdfs:domain ind:Loan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastRepaymentAmount rdf:type rdf:Property ;
    rdfs:label 'Last Repayment Amount' ;
    rdfs:comment 'Amount of the most recent repayment transaction. Null if no repayments have been made.' ;
    rdfs:domain ind:Loan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastRepaymentDate rdf:type rdf:Property ;
    rdfs:label 'Last Repayment Date' ;
    rdfs:comment 'Date of the most recent repayment transaction applied to this loan. Null if no repayments have been made.' ;
    rdfs:domain ind:Loan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:loanType rdf:type rdf:Property ;
    rdfs:label 'Loan Type' ;
    rdfs:comment 'Classification of the policy loan. Standard loans are borrower-initiated; Automatic Premium Loan (APL) loans are triggered when premium payment fails and policy has sufficient CSV; systematic loans are recurring scheduled loans; emergency loans are expedited loans for urgent needs.' ;
    rdfs:domain ind:Loan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumLoanAmount rdf:type rdf:Property ;
    rdfs:label 'Maximum Loan Amount' ;
    rdfs:comment 'Maximum amount that can be borrowed against the policy, typically a percentage of CSV (e.g., 90% of CSV) as defined in the policy contract.' ;
    rdfs:domain ind:Loan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nextScheduledRepaymentDate rdf:type rdf:Property ;
    rdfs:label 'Next Scheduled Repayment Date' ;
    rdfs:comment 'Date of the next scheduled loan repayment, if a repayment schedule is in place. Null if no repayment schedule exists or loan is fully repaid.' ;
    rdfs:domain ind:Loan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:offsetAmountAtClaim rdf:type rdf:Property ;
    rdfs:label 'Offset Amount At Claim' ;
    rdfs:comment 'Total loan balance (principal plus accrued interest) that was deducted from the death benefit when a claim was paid. Null if policy has not resulted in a death claim.' ;
    rdfs:domain ind:Loan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:offsetAmountAtSurrender rdf:type rdf:Property ;
    rdfs:label 'Offset Amount At Surrender' ;
    rdfs:comment 'Total loan balance (principal plus accrued interest) that was deducted from the cash surrender value when the policy was surrendered. Null if policy has not been surrendered.' ;
    rdfs:domain ind:Loan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:repaymentScheduleType rdf:type rdf:Property ;
    rdfs:label 'Repayment Schedule Type' ;
    rdfs:comment 'Type of repayment schedule established for the loan. None indicates no scheduled repayments (loan repaid at death or surrender); monthly/quarterly/annual indicate regular scheduled payments; custom indicates a non-standard repayment plan.' ;
    rdfs:domain ind:Loan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledRepaymentAmount rdf:type rdf:Property ;
    rdfs:label 'Scheduled Repayment Amount' ;
    rdfs:comment 'Amount of each scheduled repayment installment, if a repayment schedule is in place. Null if no repayment schedule exists.' ;
    rdfs:domain ind:Loan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taxReportingYear rdf:type rdf:Property ;
    rdfs:label 'Tax Reporting Year' ;
    rdfs:comment 'Tax year in which a taxable event related to this loan must be reported to the IRS (e.g., when loan causes policy to become a Modified Endowment Contract (MEC) or when loan is forgiven at lapse).' ;
    rdfs:domain ind:Policy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:taxableEventFlag rdf:type rdf:Property ;
    rdfs:label 'Taxable Event Flag' ;
    rdfs:comment 'Indicates whether this loan has triggered a taxable event requiring IRS reporting (e.g., loan on a MEC policy, loan forgiveness at lapse). True if taxable event occurred; False otherwise.' ;
    rdfs:domain ind:Loan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:toCsvRatio rdf:type rdf:Property ;
    rdfs:label 'To Csv Ratio' ;
    rdfs:comment 'Ratio of total outstanding loan balance to current policy CSV, expressed as a decimal. Used to monitor loan collateralization and lapse risk. A ratio approaching 1.0 indicates high lapse risk.' ;
    rdfs:domain ind:Loan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalOutstandingBalance rdf:type rdf:Property ;
    rdfs:label 'Total Outstanding Balance' ;
    rdfs:comment 'Combined outstanding principal and accrued interest balance. This is the amount that would be deducted from death benefit or surrender value.' ;
    rdfs:domain ind:Loan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalRepaymentsToDate rdf:type rdf:Property ;
    rdfs:label 'Total Repayments To Date' ;
    rdfs:comment 'Cumulative amount of all repayments (principal and interest) made on this loan since origination.' ;
    rdfs:domain ind:Loan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dividendId rdf:type rdf:Property ;
    rdfs:label 'Dividend Id' ;
    rdfs:comment 'Unique identifier for the dividend record. Primary key for the dividend product.' ;
    rdfs:domain ind:Dividend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accumulatedBalance rdf:type rdf:Property ;
    rdfs:label 'Accumulated Balance' ;
    rdfs:comment 'The current balance of dividends left on deposit with the company when the accumulate-at-interest option is elected. Includes principal and accrued interest.' ;
    rdfs:domain ind:Dividend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:accumulatedInterestRate rdf:type rdf:Property ;
    rdfs:label 'Accumulated Interest Rate' ;
    rdfs:comment 'The annual interest rate credited to accumulated dividends left on deposit. Expressed as a decimal (e.g., 0.0350 for 3.50%). Rate may be guaranteed or declared annually.' ;
    rdfs:domain ind:Dividend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:accumulatedInterestYtd rdf:type rdf:Property ;
    rdfs:label 'Accumulated Interest Ytd' ;
    rdfs:comment 'The interest credited to accumulated dividends during the current policy year. Used for tax reporting and policy value reconciliation.' ;
    rdfs:domain ind:Dividend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:apportionmentMethod rdf:type rdf:Property ;
    rdfs:label 'Apportionment Method' ;
    rdfs:comment 'The actuarial method used to allocate divisible surplus to this policy. CONTRIBUTION = contribution method; THREE_FACTOR = mortality, interest, expense factors; EXPERIENCE = experience rating; ASSET_SHARE = asset share method.' ;
    rdfs:domain ind:Dividend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cashPaymentAmount rdf:type rdf:Property ;
    rdfs:label 'Cash Payment Amount' ;
    rdfs:comment 'The amount paid in cash to the policyholder when the cash dividend option is elected. May differ from declared amount if partial amounts are applied to other options.' ;
    rdfs:domain ind:Dividend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cashPaymentDate rdf:type rdf:Property ;
    rdfs:label 'Cash Payment Date' ;
    rdfs:comment 'The date on which the cash dividend payment was issued or electronically transferred to the policyholder. Used for cash flow tracking and reconciliation.' ;
    rdfs:domain ind:Dividend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cashPaymentMethod rdf:type rdf:Property ;
    rdfs:label 'Cash Payment Method' ;
    rdfs:comment 'The method used to disburse the cash dividend payment. CHECK = paper check; ACH = automated clearing house; WIRE = wire transfer; EFT = electronic funds transfer.' ;
    rdfs:domain ind:Dividend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:declarationDate rdf:type rdf:Property ;
    rdfs:label 'Declaration Date' ;
    rdfs:comment 'The date on which the board of directors or authorized committee formally declared the dividend for the policy year. Represents the official authorization date.' ;
    rdfs:domain ind:Dividend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:declaredAmount rdf:type rdf:Property ;
    rdfs:label 'Declared Amount' ;
    rdfs:comment 'The total dividend amount declared for the policy for the dividend year, expressed in the policy currency. Represents the policyholder\'s share of divisible surplus before any option election.' ;
    rdfs:domain ind:Dividend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dividendStatus rdf:type rdf:Property ;
    rdfs:label 'Dividend Status' ;
    rdfs:comment 'Current processing status of the dividend. DECLARED = authorized but not yet processed; PENDING = awaiting option election; PAID = cash payment issued; APPLIED = applied per elected option; FORFEITED = lost due to lapse; REVERSED = reversed due to policy adjustment.' ;
    rdfs:domain ind:Dividend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expenseFactor rdf:type rdf:Property ;
    rdfs:label 'Expense Factor' ;
    rdfs:comment 'The expense component of the dividend calculation. Represents the policyholder\'s share of favorable expense experience relative to pricing assumptions.' ;
    rdfs:domain ind:Dividend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:illustrationFlag rdf:type rdf:Property ;
    rdfs:label 'Illustration Flag' ;
    rdfs:comment 'Indicates whether this dividend amount was used in a policy illustration. True if included in an illustration provided to the policyholder; false otherwise. Used for compliance tracking.' ;
    rdfs:domain ind:Dividend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:interestFactor rdf:type rdf:Property ;
    rdfs:label 'Interest Factor' ;
    rdfs:comment 'The investment earnings component of the dividend calculation. Represents the policyholder\'s share of investment income exceeding guaranteed rates.' ;
    rdfs:domain ind:Dividend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:loanReductionAmount rdf:type rdf:Property ;
    rdfs:label 'Loan Reduction Amount' ;
    rdfs:comment 'The amount of the dividend applied to reduce the outstanding policy loan balance when the loan reduction option is elected. Reduces principal and/or accrued loan interest.' ;
    rdfs:domain ind:Dividend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mortalityFactor rdf:type rdf:Property ;
    rdfs:label 'Mortality Factor' ;
    rdfs:comment 'The mortality component of the dividend calculation. Represents the policyholder\'s share of favorable mortality experience for the dividend year.' ;
    rdfs:domain ind:Dividend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:optionCode rdf:type rdf:Property ;
    rdfs:label 'Option Code' ;
    rdfs:comment 'The dividend option elected by the policyholder. CASH = cash payment; PREM_RED = premium reduction; PUA = paid-up additions; ACCUM = accumulate at interest; OYT = one-year term insurance; LOAN_RED = loan reduction.' ;
    rdfs:domain ind:Dividend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:optionEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Option Effective Date' ;
    rdfs:comment 'The date on which the elected dividend option becomes effective. May differ from declaration date if the policyholder changes their election within the allowed window.' ;
    rdfs:domain ind:Dividend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:oytCoverageAmount rdf:type rdf:Property ;
    rdfs:label 'Oyt Coverage Amount' ;
    rdfs:comment 'The face amount of one-year term insurance purchased with the dividend when the OYT option is elected. Provides temporary additional death benefit for one policy year.' ;
    rdfs:domain ind:Dividend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:oytPremiumPaid rdf:type rdf:Property ;
    rdfs:label 'Oyt Premium Paid' ;
    rdfs:comment 'The portion of the dividend used to purchase the one-year term coverage. Represents the cost of the temporary insurance benefit.' ;
    rdfs:domain ind:Dividend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:premiumReductionAmount rdf:type rdf:Property ;
    rdfs:label 'Premium Reduction Amount' ;
    rdfs:comment 'The amount of the dividend applied to reduce the next premium due when the premium reduction option is elected. Reduces the net premium payable by the policyholder.' ;
    rdfs:domain ind:Dividend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:processingTimestamp rdf:type rdf:Property ;
    rdfs:label 'Processing Timestamp' ;
    rdfs:comment 'The date and time when the dividend record was processed by the policy administration system. Represents the system processing event, distinct from business effective dates.' ;
    rdfs:domain ind:Dividend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:puaCashValue rdf:type rdf:Property ;
    rdfs:label 'Pua Cash Value' ;
    rdfs:comment 'The cash surrender value of the paid-up additions purchased with this dividend. Contributes to the total policy cash value and is available for loans or surrender.' ;
    rdfs:domain ind:Dividend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:puaFaceAmount rdf:type rdf:Property ;
    rdfs:label 'Pua Face Amount' ;
    rdfs:comment 'The face amount of paid-up additional insurance purchased with the dividend when the PUA option is elected. Represents incremental death benefit added to the base policy.' ;
    rdfs:domain ind:Dividend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scaleVersion rdf:type rdf:Property ;
    rdfs:label 'Scale Version' ;
    rdfs:comment 'The version identifier of the dividend scale used to calculate this dividend. Links to the actuarial dividend scale table and supports audit trail for rate changes.' ;
    rdfs:domain ind:Dividend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemRecordCode rdf:type rdf:Property ;
    rdfs:label 'Source System Record Code' ;
    rdfs:comment 'The unique identifier of this dividend record in the source policy administration system. Enables traceability back to the system of record.' ;
    rdfs:domain ind:Dividend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialDividendFlag rdf:type rdf:Property ;
    rdfs:label 'Special Dividend Flag' ;
    rdfs:comment 'Indicates whether this is a special or extraordinary dividend declared outside the normal annual dividend cycle. True for special dividends; false for regular annual dividends.' ;
    rdfs:domain ind:Dividend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:terminalDividendFlag rdf:type rdf:Property ;
    rdfs:label 'Terminal Dividend Flag' ;
    rdfs:comment 'Indicates whether this is a terminal dividend paid upon policy maturity, death claim, or surrender. True for terminal dividends; false for annual dividends.' ;
    rdfs:domain ind:Dividend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:year rdf:type rdf:Property ;
    rdfs:label 'Year' ;
    rdfs:comment 'The policy year or calendar year for which the dividend was declared. Represents the experience period underlying the dividend calculation.' ;
    rdfs:domain ind:Dividend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:taxComplianceDocumentId rdf:type rdf:Property ;
    rdfs:label 'Tax Compliance Document Id' ;
    rdfs:comment 'Foreign key linking to document.document. Business justification: IRC 7702 and MEC test results require mandatory policyholder notification documents (MEC notices, corridor test disclosures) under IRS regulations. Direct FK links the compliance test record to its ge' ;
    rdfs:domain ind:TaxComplianceTest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Document .

ind:taxComplianceJournalEntryId rdf:type rdf:Property ;
    rdfs:label 'Tax Compliance Journal Entry Id' ;
    rdfs:comment 'Foreign key linking to finance.journal_entry. Business justification: MEC reclassification events (IRC 7702 test failures) generate journal entries for deferred tax adjustments and IRS Form 1099-R reporting. Finance must trace MEC determination events to their GL impact' ;
    rdfs:domain ind:TaxComplianceTest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:JournalEntry .

ind:accountValueAtTest rdf:type rdf:Property ;
    rdfs:label 'Account Value At Test' ;
    rdfs:comment 'The policy account value (gross cash value before surrender charges) at the time the MEC test was performed. Relevant for universal life and variable universal life products.' ;
    rdfs:domain ind:TaxComplianceTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cashValueAccumulationLimit rdf:type rdf:Property ;
    rdfs:label 'Cash Value Accumulation Limit' ;
    rdfs:comment 'The maximum cash value the policy can accumulate under the Cash Value Accumulation Test (CVAT) without violating IRC 7702 life insurance definition. Only applicable if CVAT election was made.' ;
    rdfs:domain ind:TaxComplianceTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cashValueAtTest rdf:type rdf:Property ;
    rdfs:label 'Cash Value At Test' ;
    rdfs:comment 'The policy cash surrender value at the time the MEC test was performed. Used in corridor test calculations and CVAT limit assessments.' ;
    rdfs:domain ind:TaxComplianceTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:corridorTestResult rdf:type rdf:Property ;
    rdfs:label 'Corridor Test Result' ;
    rdfs:comment 'Result of the corridor test which ensures the death benefit maintains a minimum ratio to the cash value. Required for policies to maintain life insurance tax treatment under IRC 7702.' ;
    rdfs:domain ind:TaxComplianceTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deathBenefitAtTest rdf:type rdf:Property ;
    rdfs:label 'Death Benefit At Test' ;
    rdfs:comment 'The policy death benefit amount in effect at the time the MEC test was performed. Death benefit is a key input to the 7-pay premium limit calculation.' ;
    rdfs:domain ind:TaxComplianceTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:definitionElection rdf:type rdf:Property ;
    rdfs:label 'Definition Election' ;
    rdfs:comment 'The IRC Section 7702 definition of life insurance elected by the policyholder at issuance. GPT uses guideline premiums and cash value corridor; CVAT uses cash value accumulation limits. This election is irrevocable.' ;
    rdfs:domain ind:TaxComplianceTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exchangedPolicyMecStatus rdf:type rdf:Property ;
    rdfs:label 'Exchanged Policy Mec Status' ;
    rdfs:comment 'If this policy was acquired through a 1035 exchange, this field captures the MEC status of the original exchanged policy. MEC status is preserved in 1035 exchanges.' ;
    rdfs:domain ind:TaxComplianceTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:form1099rReportable rdf:type rdf:Property ;
    rdfs:label 'Form 1099r Reportable' ;
    rdfs:comment 'Indicates whether distributions from this policy are reportable on IRS Form 1099-R due to MEC status. MEC distributions are subject to income tax and potential early withdrawal penalties.' ;
    rdfs:domain ind:TaxComplianceTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:guidelineLevelPremium rdf:type rdf:Property ;
    rdfs:label 'Guideline Level Premium' ;
    rdfs:comment 'The maximum level annual premium that can be paid into the policy under the Guideline Premium Test (GPT) without violating IRC 7702 life insurance definition. Only applicable if GPT election was made.' ;
    rdfs:domain ind:LifeInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:guidelineSinglePremium rdf:type rdf:Property ;
    rdfs:label 'Guideline Single Premium' ;
    rdfs:comment 'The maximum single premium that can be paid into the policy under the Guideline Premium Test (GPT) without violating IRC 7702 life insurance definition. Only applicable if GPT election was made.' ;
    rdfs:domain ind:LifeInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:irsReportingFlag rdf:type rdf:Property ;
    rdfs:label 'Irs Reporting Flag' ;
    rdfs:comment 'Indicates whether this MEC test result requires reporting to the IRS. True if the policy became a MEC or if a material change occurred that affects tax treatment.' ;
    rdfs:domain ind:TaxComplianceTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:materialChangeDate rdf:type rdf:Property ;
    rdfs:label 'Material Change Date' ;
    rdfs:comment 'The date on which a material change event occurred, triggering a new 7-pay test period. Null if no material change has occurred.' ;
    rdfs:domain ind:TaxComplianceTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:materialChangeEventType rdf:type rdf:Property ;
    rdfs:label 'Material Change Event Type' ;
    rdfs:comment 'The type of material change event that triggered a new MEC test. Material changes reset the 7-pay test period. If no material change occurred, this field is set to \'none\'.' ;
    rdfs:domain ind:TaxComplianceTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overrideTimestamp rdf:type rdf:Property ;
    rdfs:label 'Override Timestamp' ;
    rdfs:comment 'The date and time when the MEC test result was manually overridden. Null if no override occurred.' ;
    rdfs:domain ind:TaxComplianceTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:policyYearAtTest rdf:type rdf:Property ;
    rdfs:label 'Policy Year At Test' ;
    rdfs:comment 'The policy year (anniversary year) in which the MEC test was performed. Relevant for tracking the 7-pay test period which spans the first seven policy years or until a material change.' ;
    rdfs:domain ind:TaxComplianceTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:priorMecStatus rdf:type rdf:Property ;
    rdfs:label 'Prior Mec Status' ;
    rdfs:comment 'The MEC status of the policy before this test was performed. Used to track status changes and identify when a policy first became a MEC. Set to \'not applicable\' for initial issuance tests.' ;
    rdfs:domain ind:TaxComplianceTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testCalculationMethod rdf:type rdf:Property ;
    rdfs:label 'Test Calculation Method' ;
    rdfs:comment 'The actuarial methodology and assumptions used to calculate the 7-pay premium limit and other test thresholds. May reference specific assumption sets or calculation standards.' ;
    rdfs:domain ind:TaxComplianceTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testDate rdf:type rdf:Property ;
    rdfs:label 'Test Date' ;
    rdfs:comment 'The date on which the MEC test was performed. This may be at policy issuance or upon a material change event.' ;
    rdfs:domain ind:TaxComplianceTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:testNotes rdf:type rdf:Property ;
    rdfs:label 'Test Notes' ;
    rdfs:comment 'Free-form notes and comments regarding the MEC test, including any special circumstances, assumptions, or actuarial judgments applied during the calculation.' ;
    rdfs:domain ind:TaxComplianceTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testStatus rdf:type rdf:Property ;
    rdfs:label 'Test Status' ;
    rdfs:comment 'The processing status of the MEC test. Indicates whether the test calculation has been completed, is pending actuarial review, failed due to data issues, or was manually overridden.' ;
    rdfs:domain ind:TaxComplianceTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testType rdf:type rdf:Property ;
    rdfs:label 'Test Type' ;
    rdfs:comment 'The type of MEC test performed. The 7-pay test is the primary test under IRC 7702A to determine if cumulative premiums paid exceed the 7-pay premium limit.' ;
    rdfs:domain ind:TaxComplianceTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fundAllocationId rdf:type rdf:Property ;
    rdfs:label 'Fund Allocation Id' ;
    rdfs:comment 'Unique identifier for each policy fund allocation record. Primary key for the policy fund allocation entity.' ;
    rdfs:domain ind:FundAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:allocationAmount rdf:type rdf:Property ;
    rdfs:label 'Allocation Amount' ;
    rdfs:comment 'For dollar-based allocations (e.g., DCA programs), the fixed dollar amount allocated to this fund per period. Null for percentage-based allocations.' ;
    rdfs:domain ind:FundAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allocationApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Allocation Approval Date' ;
    rdfs:comment 'Date when the allocation instruction was approved and accepted by the policy administration system, completing validation and compliance checks.' ;
    rdfs:domain ind:FundAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:allocationEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Allocation Effective Date' ;
    rdfs:comment 'Date when this fund allocation instruction became effective and began applying to premium payments or account value rebalancing.' ;
    rdfs:domain ind:FundAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:allocationRequestDate rdf:type rdf:Property ;
    rdfs:label 'Allocation Request Date' ;
    rdfs:comment 'Date when the allocation change was requested by the policyholder or advisor. May differ from effective date due to processing time or future-dated instructions.' ;
    rdfs:domain ind:FundAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:allocationSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Allocation Sequence Number' ;
    rdfs:comment 'Sequential ordering number for multiple fund allocations within the same policy and allocation type. Used for processing priority and display ordering.' ;
    rdfs:domain ind:FundAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:allocationSource rdf:type rdf:Property ;
    rdfs:label 'Allocation Source' ;
    rdfs:comment 'Origin of this allocation instruction: policyholder-elected, system default, advisor-recommended, or automated program-driven.' ;
    rdfs:domain ind:FundAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationTerminationDate rdf:type rdf:Property ;
    rdfs:label 'Allocation Termination Date' ;
    rdfs:comment 'Date when this allocation instruction was terminated or superseded by a new allocation. Null for currently active allocations.' ;
    rdfs:domain ind:FundAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:allocationTerminationReason rdf:type rdf:Property ;
    rdfs:label 'Allocation Termination Reason' ;
    rdfs:comment 'Reason why this allocation instruction was terminated. Null for active allocations.' ;
    rdfs:domain ind:FundAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationType rdf:type rdf:Property ;
    rdfs:label 'Allocation Type' ;
    rdfs:comment 'Type of allocation instruction: premium_allocation (applies to new premium payments), account_value_rebalance (periodic rebalancing of existing AV), transfer (one-time fund transfer), systematic_rebalance (automated periodic rebalancing), dollar_cost_averaging (DCA program allocation).' ;
    rdfs:domain ind:FundAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fundCategory rdf:type rdf:Property ;
    rdfs:label 'Fund Category' ;
    rdfs:comment 'High-level investment category classification of the fund for reporting and risk management purposes. [ENUM-REF-CANDIDATE: equity|fixed_income|balanced|money_market|index|specialty|guaranteed|alternative — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:FundAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fundRiskRating rdf:type rdf:Property ;
    rdfs:label 'Fund Risk Rating' ;
    rdfs:comment 'Risk profile classification of the investment fund used for suitability assessment and portfolio construction.' ;
    rdfs:domain ind:FundAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:indexSegmentEndDate rdf:type rdf:Property ;
    rdfs:label 'Index Segment End Date' ;
    rdfs:comment 'For IUL and FIA products, the end date of the current index crediting segment or term when index gains/losses are calculated and credited.' ;
    rdfs:domain ind:FundAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:indexSegmentStartDate rdf:type rdf:Property ;
    rdfs:label 'Index Segment Start Date' ;
    rdfs:comment 'For IUL and FIA products, the start date of the current index crediting segment or term. Used to track index performance measurement periods.' ;
    rdfs:domain ind:FundAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:indexSegmentTermYears rdf:type rdf:Property ;
    rdfs:label 'Index Segment Term Years' ;
    rdfs:comment 'Length of the index crediting term in years (e.g., 1, 2, 5, 7) for IUL and FIA products. Determines the measurement period for index performance.' ;
    rdfs:domain ind:FundAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastRebalanceDate rdf:type rdf:Property ;
    rdfs:label 'Last Rebalance Date' ;
    rdfs:comment 'Date when the most recent automatic or manual rebalancing of account value to target allocation percentages was executed.' ;
    rdfs:domain ind:FundAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:minimumAllocationPercentage rdf:type rdf:Property ;
    rdfs:label 'Minimum Allocation Percentage' ;
    rdfs:comment 'Minimum percentage that must be maintained in this fund per product rules or regulatory requirements. Used for compliance validation during allocation changes.' ;
    rdfs:domain ind:FundAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mortalityAndExpenseRiskCharge rdf:type rdf:Property ;
    rdfs:label 'Mortality And Expense Risk Charge' ;
    rdfs:comment 'Annual M&E risk charge assessed against this fund allocation for variable products, expressed as a decimal (e.g., 0.0125 for 1.25%). Covers insurance guarantees and administrative expenses.' ;
    rdfs:domain ind:FundAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nextRebalanceDate rdf:type rdf:Property ;
    rdfs:label 'Next Rebalance Date' ;
    rdfs:comment 'Scheduled date for the next automatic rebalancing transaction based on the rebalancing frequency. Null if no automatic rebalancing is configured.' ;
    rdfs:domain ind:FundAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assignedAmount rdf:type rdf:Property ;
    rdfs:label 'Assigned Amount' ;
    rdfs:comment 'For collateral assignments, the maximum dollar amount of the loan or debt secured by the policy. Null for absolute assignments.' ;
    rdfs:domain ind:Assignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assignedPercentage rdf:type rdf:Property ;
    rdfs:label 'Assigned Percentage' ;
    rdfs:comment 'Percentage of policy benefits assigned to the assignee. Typically 100% for absolute assignments, may be partial for collateral assignments.' ;
    rdfs:domain ind:Assignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assigneeAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Assignee Address Line1' ;
    rdfs:comment 'Primary street address line for the assignee, used for legal notices and correspondence.' ;
    rdfs:domain ind:Assignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assigneeAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Assignee Address Line2' ;
    rdfs:comment 'Secondary address line (suite, apartment, floor) for the assignee.' ;
    rdfs:domain ind:Assignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assigneeCity rdf:type rdf:Property ;
    rdfs:label 'Assignee City' ;
    rdfs:comment 'City of the assignee\'s address.' ;
    rdfs:domain ind:Assignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assigneeCountry rdf:type rdf:Property ;
    rdfs:label 'Assignee Country' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the assignee\'s address.' ;
    rdfs:domain ind:Assignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assigneeEmail rdf:type rdf:Property ;
    rdfs:label 'Assignee Email' ;
    rdfs:comment 'Primary email address for assignee correspondence and notifications.' ;
    rdfs:domain ind:Assignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assigneeName rdf:type rdf:Property ;
    rdfs:label 'Assignee Name' ;
    rdfs:comment 'Full legal name of the individual, financial institution, employer, or trust receiving the assignment rights.' ;
    rdfs:domain ind:Assignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assigneePhone rdf:type rdf:Property ;
    rdfs:label 'Assignee Phone' ;
    rdfs:comment 'Primary contact phone number for the assignee.' ;
    rdfs:domain ind:Assignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assigneePostalCode rdf:type rdf:Property ;
    rdfs:label 'Assignee Postal Code' ;
    rdfs:comment 'Postal or ZIP code of the assignee\'s address.' ;
    rdfs:domain ind:Assignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assigneeState rdf:type rdf:Property ;
    rdfs:label 'Assignee State' ;
    rdfs:comment 'State or province code of the assignee\'s address.' ;
    rdfs:domain ind:Assignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assigneeTin rdf:type rdf:Property ;
    rdfs:label 'Assignee Tin' ;
    rdfs:comment 'Tax identification number (SSN or EIN) of the assignee for IRS reporting and identity verification.' ;
    rdfs:domain ind:Assignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assigneeType rdf:type rdf:Property ;
    rdfs:label 'Assignee Type' ;
    rdfs:comment 'Classification of the assignee entity: individual person, financial institution (bank, lender), employer (for group policy assignments), trust (ILIT or other), or other entity type.' ;
    rdfs:domain ind:Assignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentNumber rdf:type rdf:Property ;
    rdfs:label 'Assignment Number' ;
    rdfs:comment 'Business-facing unique identifier for the assignment, often used in correspondence and legal documents.' ;
    rdfs:domain ind:Assignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentType rdf:type rdf:Property ;
    rdfs:label 'Assignment Type' ;
    rdfs:comment 'Type of assignment: absolute (full transfer of ownership rights) or collateral (security interest for a loan).' ;
    rdfs:domain ind:Assignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:irrevocableFlag rdf:type rdf:Property ;
    rdfs:label 'Irrevocable Flag' ;
    rdfs:comment 'Indicates whether the assignment is irrevocable (true) or revocable (false). Irrevocable assignments cannot be changed without assignee consent.' ;
    rdfs:domain ind:Assignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lenderLoanReference rdf:type rdf:Property ;
    rdfs:label 'Lender Loan Reference' ;
    rdfs:comment 'External loan or account number from the lending institution, used to correlate the assignment with the underlying debt obligation.' ;
    rdfs:domain ind:Assignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notaryPublicName rdf:type rdf:Property ;
    rdfs:label 'Notary Public Name' ;
    rdfs:comment 'Name of the notary public who notarized the assignment document, if applicable.' ;
    rdfs:domain ind:Assignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:premiumPaymentResponsibility rdf:type rdf:Property ;
    rdfs:label 'Premium Payment Responsibility' ;
    rdfs:comment 'Party responsible for paying policy premiums under the assignment: owner (policy owner retains responsibility), assignee (assignee assumes premium payments), or shared (split responsibility).' ;
    rdfs:domain ind:Assignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordingDate rdf:type rdf:Property ;
    rdfs:label 'Recording Date' ;
    rdfs:comment 'Date on which the assignment was officially recorded in the insurer\'s policy administration system.' ;
    rdfs:domain ind:Assignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:releaseDate rdf:type rdf:Property ;
    rdfs:label 'Release Date' ;
    rdfs:comment 'Date on which the assignment was released or terminated, returning full rights to the policy owner. Null if assignment is still active.' ;
    rdfs:domain ind:Assignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:collateralAssignmentLenderName rdf:type rdf:Property ;
    rdfs:label 'Collateral Assignment Lender Name' ;
    rdfs:comment 'For collateral assignment requests, the name of the lending institution or creditor to whom the policy death benefit is assigned as collateral security. Business-confidential financial relationship data.' ;
    rdfs:domain ind:ServiceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conversionCreditAmount rdf:type rdf:Property ;
    rdfs:label 'Conversion Credit Amount' ;
    rdfs:comment 'For conversion requests, the monetary credit or value transferred from the original policy to the new converted policy. Represents accumulated value or conversion privilege benefit.' ;
    rdfs:domain ind:ServiceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:conversionPrivilegeExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Conversion Privilege Expiry Date' ;
    rdfs:comment 'For conversion requests, the last date the policyholder can exercise their contractual conversion privilege without evidence of insurability. Critical for conversion window tracking.' ;
    rdfs:domain ind:ServiceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:conversionSourcePolicyType rdf:type rdf:Property ;
    rdfs:label 'Conversion Source Policy Type' ;
    rdfs:comment 'For conversion requests, the original policy type being converted from. Typically YRT (Yearly Renewable Term) or term life insurance converting to permanent coverage.' ;
    rdfs:domain ind:ServiceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conversionTargetPolicyType rdf:type rdf:Property ;
    rdfs:label 'Conversion Target Policy Type' ;
    rdfs:comment 'For conversion requests, the new policy type being converted to. Typically permanent life insurance products (WL, UL, IUL, VUL).' ;
    rdfs:domain ind:ServiceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endorsementNumber rdf:type rdf:Property ;
    rdfs:label 'Endorsement Number' ;
    rdfs:comment 'Sequential endorsement identifier for formal contractual amendments to the policy. Null for administrative changes that do not constitute contractual modifications.' ;
    rdfs:domain ind:ServiceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evidenceOfInsurabilityWaivedFlag rdf:type rdf:Property ;
    rdfs:label 'Evidence Of Insurability Waived Flag' ;
    rdfs:comment 'For conversion requests, indicates whether medical underwriting and evidence of insurability requirements were waived under the conversion privilege. True if waived, False if evidence required.' ;
    rdfs:domain ind:Policy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:exchange1035Type rdf:type rdf:Property ;
    rdfs:label 'Exchange 1035 Type' ;
    rdfs:comment 'For 1035 exchange requests, the type of tax-free exchange under IRC Section 1035. Determines permissible exchange paths and tax treatment.' ;
    rdfs:domain ind:ServiceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exchangeAmountTransferred rdf:type rdf:Property ;
    rdfs:label 'Exchange Amount Transferred' ;
    rdfs:comment 'For 1035 exchange requests, the total cash surrender value or account value transferred from the surrendering policy to the new policy. Represents the gross exchange proceeds.' ;
    rdfs:domain ind:ServiceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:irsForm1035AttestationFlag rdf:type rdf:Property ;
    rdfs:label 'Irs Form 1035 Attestation Flag' ;
    rdfs:comment 'For 1035 exchange requests, indicates whether the policyholder has signed and submitted IRS Form 1035 attesting to the tax-free exchange. Required for regulatory compliance and tax reporting.' ;
    rdfs:domain ind:ServiceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:newPolicyReference rdf:type rdf:Property ;
    rdfs:label 'New Policy Reference' ;
    rdfs:comment 'For conversion requests, the policy number or reference of the newly issued converted policy. Links the conversion service request to the resulting new policy contract.' ;
    rdfs:domain ind:ServiceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:newValue rdf:type rdf:Property ;
    rdfs:label 'New Value' ;
    rdfs:comment 'The value of the policy attribute after the service request change. Combined with prior_value, creates complete before-and-after audit trail.' ;
    rdfs:domain ind:ServiceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priorValue rdf:type rdf:Property ;
    rdfs:label 'Prior Value' ;
    rdfs:comment 'The value of the policy attribute before the service request change. Provides full audit trail of all contractual and administrative modifications for regulatory compliance.' ;
    rdfs:domain ind:ServiceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reinstatementEvidenceRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Reinstatement Evidence Required Flag' ;
    rdfs:comment 'For reinstatement requests, indicates whether evidence of insurability (medical underwriting) is required to reinstate the lapsed policy. Depends on lapse duration and policy provisions.' ;
    rdfs:domain ind:ServiceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reinstatementPremiumAmount rdf:type rdf:Property ;
    rdfs:label 'Reinstatement Premium Amount' ;
    rdfs:comment 'For reinstatement requests, the total premium amount (including back premiums, interest, and fees) required to reinstate a lapsed policy. Must be paid to restore coverage.' ;
    rdfs:domain ind:ServiceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:requestChannel rdf:type rdf:Property ;
    rdfs:label 'Request Channel' ;
    rdfs:comment 'Channel or interface through which the service request was submitted. Supports channel analytics and customer experience optimization. [ENUM-REF-CANDIDATE: phone|web_portal|agent|mail|email|fax|in_person — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ServiceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestNumber rdf:type rdf:Property ;
    rdfs:label 'Request Number' ;
    rdfs:comment 'Business-facing unique identifier for the service request, endorsement, or administrative change. Used for customer and agent communication and tracking.' ;
    rdfs:domain ind:ServiceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestStatus rdf:type rdf:Property ;
    rdfs:label 'Request Status' ;
    rdfs:comment 'Current lifecycle status of the service request. NIGO (Not In Good Order) indicates incomplete or deficient submission requiring additional information or correction. [ENUM-REF-CANDIDATE: received|in_review|pending_documents|completed|nigo|cancelled|rejected — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ServiceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestType rdf:type rdf:Property ;
    rdfs:label 'Request Type' ;
    rdfs:comment 'Classification of the policy service request or endorsement type. Includes administrative changes (address, beneficiary, ownership, premium mode, face amount, dividend option, name, duplicate contract), contractual amendments (rider addition/removal, collateral assignment), policy reinstatements, term-to-permanent conversions, and IRC Section 1035 tax-free exchanges. [ENUM-REF-CANDIDATE: address_change|beneficiary_change|ownership_change|premium_mode_change|face_amount_change|dividend_option_change|name_change|duplicate_policy_contract|rider_addition|rider_removal|collateral_assignment|reinstatement|conversion|1035_exchange — 14 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ServiceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surrenderingCarrierName rdf:type rdf:Property ;
    rdfs:label 'Surrendering Carrier Name' ;
    rdfs:comment 'For 1035 exchange requests, the name of the insurance carrier whose policy is being surrendered and exchanged. Required for IRS Form 1035 reporting.' ;
    rdfs:domain ind:ServiceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surrenderingPolicyNumber rdf:type rdf:Property ;
    rdfs:label 'Surrendering Policy Number' ;
    rdfs:comment 'For 1035 exchange requests, the policy number of the contract being surrendered at the external carrier. Required for exchange processing and IRS reporting.' ;
    rdfs:domain ind:ServiceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amlRiskScore rdf:type rdf:Property ;
    rdfs:label 'Aml Risk Score' ;
    rdfs:comment 'Anti-Money Laundering (AML) risk score (0-100) based on applicant profile, premium amount, payment source, and geographic risk factors. High scores trigger enhanced due diligence.' ;
    rdfs:domain ind:Underwriting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicationNumber rdf:type rdf:Property ;
    rdfs:label 'Application Number' ;
    rdfs:comment 'Externally-known business identifier for the application, typically printed on application forms and used in agent/customer communications.' ;
    rdfs:domain ind:Application ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicationStatus rdf:type rdf:Property ;
    rdfs:label 'Application Status' ;
    rdfs:comment 'Current workflow status of the application in the underwriting process. NIGO (Not In Good Order) indicates incomplete or deficient submission requiring correction before underwriting can proceed. [ENUM-REF-CANDIDATE: submitted|nigo|in_underwriting|pending_requirements|approved|declined|withdrawn|postponed — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Application ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decisionReason rdf:type rdf:Property ;
    rdfs:label 'Decision Reason' ;
    rdfs:comment 'Detailed explanation of the underwriting decision, including specific medical, financial, or lifestyle factors that influenced the risk classification or declination.' ;
    rdfs:domain ind:Application ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialUnderwritingRequired rdf:type rdf:Property ;
    rdfs:label 'Financial Underwriting Required' ;
    rdfs:comment 'Indicates whether financial underwriting is required to verify the applicants income, net worth, and financial justification for the requested coverage amount.' ;
    rdfs:domain ind:Application ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:flatExtraAmount rdf:type rdf:Property ;
    rdfs:label 'Flat Extra Amount' ;
    rdfs:comment 'Additional flat premium per thousand of coverage applied for specific temporary or permanent risks (e.g., hazardous occupation, avocation). Expressed as dollars per thousand of face amount.' ;
    rdfs:domain ind:LifeInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:medicalExamRequired rdf:type rdf:Property ;
    rdfs:label 'Medical Exam Required' ;
    rdfs:comment 'Indicates whether a paramedical examination is required based on face amount, age, and preliminary health questions.' ;
    rdfs:domain ind:Underwriting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:replacementIndicator rdf:type rdf:Property ;
    rdfs:label 'Replacement Indicator' ;
    rdfs:comment 'Indicates whether this application involves replacement of existing life insurance or annuity coverage, triggering additional suitability and disclosure requirements.' ;
    rdfs:domain ind:Application ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:stoliRiskScore rdf:type rdf:Property ;
    rdfs:label 'Stoli Risk Score' ;
    rdfs:comment 'Automated risk score (0-100) assessing the likelihood that this application represents Stranger-Originated Life Insurance (STOLI), an illegal or unethical arrangement where investors initiate policies on individuals with no insurable interest.' ;
    rdfs:domain ind:Underwriting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:medicalRiskClassId rdf:type rdf:Property ;
    rdfs:label 'Medical Risk Class Id' ;
    rdfs:comment 'Foreign key linking to underwriting.risk_class. Business justification: The underwriting risk assessment assigns a medical risk classification to the applicant. The existing medical_risk_classification STRING column stores a denormalized value. Replacing it with a FK to t' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RiskClass .

ind:apsReviewNotes rdf:type rdf:Property ;
    rdfs:label 'Aps Review Notes' ;
    rdfs:comment 'Detailed underwriter notes documenting findings from the APS review, including significant medical conditions, treatment history, and clinical observations relevant to risk assessment.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:apsReviewOutcome rdf:type rdf:Property ;
    rdfs:label 'Aps Review Outcome' ;
    rdfs:comment 'Summary outcome of the Attending Physician Statement review. Captures the underwriter\'s assessment of medical records obtained from the applicant\'s treating physicians.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentDate rdf:type rdf:Property ;
    rdfs:label 'Assessment Date' ;
    rdfs:comment 'Date when the formal risk assessment was completed and the underwriting decision was rendered.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assessmentNumber rdf:type rdf:Property ;
    rdfs:label 'Assessment Number' ;
    rdfs:comment 'Business-facing unique identifier for the risk assessment, typically displayed to underwriters and used in correspondence.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentStatus rdf:type rdf:Property ;
    rdfs:label 'Assessment Status' ;
    rdfs:comment 'Current lifecycle status of the risk assessment workflow. Tracks progression from initial submission through final underwriting decision. [ENUM-REF-CANDIDATE: pending|in_progress|completed|approved|declined|referred|suspended — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Assessment Timestamp' ;
    rdfs:comment 'Precise timestamp when the risk assessment was finalized in the underwriting workbench system. Captures the exact moment of decision for audit and SLA tracking.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:assessmentType rdf:type rdf:Property ;
    rdfs:label 'Assessment Type' ;
    rdfs:comment 'Classification of the risk assessment based on the triggering event. Distinguishes between new business (NB) underwriting, policy change underwriting, and other assessment scenarios.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:automatedRulesEngineDecision rdf:type rdf:Property ;
    rdfs:label 'Automated Rules Engine Decision' ;
    rdfs:comment 'Initial decision rendered by the underwriting workbench automated rules engine. Straight-through processing (STP) cases receive auto-approve; complex cases are referred to manual underwriter review.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:aviationHazardRating rdf:type rdf:Property ;
    rdfs:label 'Aviation Hazard Rating' ;
    rdfs:comment 'Risk rating assigned for aviation-related activities. Evaluates frequency and type of flying (private pilot, commercial, military, recreational) and associated mortality risk.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:avocationHazardRating rdf:type rdf:Property ;
    rdfs:label 'Avocation Hazard Rating' ;
    rdfs:comment 'Risk rating assigned for hazardous hobbies and recreational activities (e.g., skydiving, scuba diving, rock climbing, racing). Assesses additional mortality risk beyond standard underwriting.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:buildChartResult rdf:type rdf:Property ;
    rdfs:label 'Build Chart Result' ;
    rdfs:comment 'Outcome of the height-weight-age build chart evaluation. Assesses whether the applicant\'s body mass index (BMI) falls within acceptable underwriting guidelines.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessInsuranceJustification rdf:type rdf:Property ;
    rdfs:label 'Business Insurance Justification' ;
    rdfs:comment 'Type of business insurance arrangement justifying the coverage. Applicable when the policy is owned by or benefits a business entity (e.g., key person insurance, buy-sell agreement funding).' ;
    rdfs:domain ind:Underwriting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:existingCoverageInforceAmount rdf:type rdf:Property ;
    rdfs:label 'Existing Coverage Inforce Amount' ;
    rdfs:comment 'Total death benefit amount of all existing life insurance policies currently in force on the applicant across all carriers. Used to assess total coverage and detect potential over-insurance.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:financialRiskClassification rdf:type rdf:Property ;
    rdfs:label 'Financial Risk Classification' ;
    rdfs:comment 'Financial underwriting decision outcome. Indicates whether the requested coverage amount is financially justified based on income, net worth, existing coverage, and insurable interest.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialStatementReviewNotes rdf:type rdf:Property ;
    rdfs:label 'Financial Statement Review Notes' ;
    rdfs:comment 'Underwriter notes documenting the review of financial statements, tax returns, and other financial documentation. Captures income verification, net worth assessment, and financial justification for coverage.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:humanLifeValueAmount rdf:type rdf:Property ;
    rdfs:label 'Human Life Value Amount' ;
    rdfs:comment 'Calculated human life value representing the present value of the insured\'s future earnings potential. Used to justify the requested death benefit amount in financial underwriting.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:incomeReplacementMultiple rdf:type rdf:Property ;
    rdfs:label 'Income Replacement Multiple' ;
    rdfs:comment 'Ratio of requested death benefit to annual income. Used to assess whether the coverage amount is reasonable relative to the applicant\'s income. Typical guidelines range from 10x to 25x annual income.' ;
    rdfs:domain ind:Underwriting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:insurableInterestDetermination rdf:type rdf:Property ;
    rdfs:label 'Insurable Interest Determination' ;
    rdfs:comment 'Underwriter\'s determination of whether the applicant has a valid insurable interest in the insured\'s life. Required to prevent speculative life insurance purchases.' ;
    rdfs:domain ind:Underwriting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lifeSettlementBrokerInvolvementFlag rdf:type rdf:Property ;
    rdfs:label 'Life Settlement Broker Involvement Flag' ;
    rdfs:comment 'Indicates whether a life settlement broker was involved in the application process. Life settlement broker involvement at policy inception is a strong STOLI indicator.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:manualReviewRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Manual Review Required Flag' ;
    rdfs:comment 'Indicates whether manual underwriter review is required. Set to true when the automated rules engine refers the case or when additional evidence is needed.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:medicalRiskScore rdf:type rdf:Property ;
    rdfs:label 'Medical Risk Score' ;
    rdfs:comment 'Quantitative medical underwriting risk score representing mortality and morbidity risk. Calculated from build chart results, APS review, MIB findings, and medical evidence. Higher scores indicate higher risk.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mibFindingsSummary rdf:type rdf:Property ;
    rdfs:label 'Mib Findings Summary' ;
    rdfs:comment 'Summary of findings from the MIB inquiry, including any codes or alerts that indicate prior medical conditions, insurance applications, or underwriting decisions.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mibInquiryDate rdf:type rdf:Property ;
    rdfs:label 'Mib Inquiry Date' ;
    rdfs:comment 'Date when the MIB inquiry was submitted and results were received.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mibInquiryPerformedFlag rdf:type rdf:Property ;
    rdfs:label 'Mib Inquiry Performed Flag' ;
    rdfs:comment 'Indicates whether an MIB inquiry was performed as part of the underwriting process. MIB provides information on prior insurance applications and medical history.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:premiumFinancingFlag rdf:type rdf:Property ;
    rdfs:label 'Premium Financing Flag' ;
    rdfs:comment 'Indicates whether the policy premiums will be financed through a third-party loan. Premium financing with non-recourse loans is a common STOLI indicator.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reinsuranceCessionRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Reinsurance Cession Required Flag' ;
    rdfs:comment 'Indicates whether the NAR exceeds the company\'s retention limit and requires reinsurance cession. Triggers automatic or facultative reinsurance placement workflow.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reinsuranceType rdf:type rdf:Property ;
    rdfs:label 'Reinsurance Type' ;
    rdfs:comment 'Type of reinsurance arrangement applicable to this risk. Automatic reinsurance applies to standard risks within treaty limits; facultative reinsurance requires individual case submission for substandard or jumbo risks.' ;
    rdfs:domain ind:Underwriting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siuReferralFlag rdf:type rdf:Property ;
    rdfs:label 'Siu Referral Flag' ;
    rdfs:comment 'Indicates whether the application was referred to the Special Investigations Unit for fraud investigation. SIU referrals occur when STOLI, fraud, or other suspicious activity is detected.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:stoliDetermination rdf:type rdf:Property ;
    rdfs:label 'Stoli Determination' ;
    rdfs:comment 'Final determination of whether the application constitutes a STOLI arrangement. Confirmed STOLI cases result in application decline and potential regulatory reporting.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stoliInvestigationStatus rdf:type rdf:Property ;
    rdfs:label 'Stoli Investigation Status' ;
    rdfs:comment 'Status of the STOLI investigation workflow. Tracks the progression of compliance review when STOLI indicators are present.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:declineReasonCategory rdf:type rdf:Property ;
    rdfs:label 'Decline Reason Category' ;
    rdfs:comment 'High-level category for decline or postpone decisions: medical (health impairments), financial (insufficient income/net worth), lifestyle (hazardous avocations), legal (criminal history), fraud (misrepresentation), or other. Applicable only to decline/postpone risk classes.' ;
    rdfs:domain ind:RiskClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:flatExtraDurationMonths rdf:type rdf:Property ;
    rdfs:label 'Flat Extra Duration Months' ;
    rdfs:comment 'Duration in months for which the flat extra charge applies. Null for permanent flat extras or when flat extra is not applicable.' ;
    rdfs:domain ind:Underwriting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:flatExtraPerThousand rdf:type rdf:Property ;
    rdfs:label 'Flat Extra Per Thousand' ;
    rdfs:comment 'Additional premium charge per thousand dollars of coverage (e.g., $2.50 per $1,000 of death benefit (DB)) applied for temporary or permanent extra risk. Used for occupational hazards, avocations, or medical impairments. Null if not applicable.' ;
    rdfs:domain ind:Underwriting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:genderApplicability rdf:type rdf:Property ;
    rdfs:label 'Gender Applicability' ;
    rdfs:comment 'Gender for which this risk class applies: male, female, unisex (gender-neutral pricing), or all (applies to all genders).' ;
    rdfs:domain ind:Underwriting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:morbidityMultiplier rdf:type rdf:Property ;
    rdfs:label 'Morbidity Multiplier' ;
    rdfs:comment 'Numeric multiplier applied to standard morbidity rates for disability income (DI) and long-term care (LTC) products. Standard class = 1.00; preferred < 1.00; substandard > 1.00.' ;
    rdfs:domain ind:RiskClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mortalityMultiplier rdf:type rdf:Property ;
    rdfs:label 'Mortality Multiplier' ;
    rdfs:comment 'Numeric multiplier applied to standard mortality rates for this risk class. Standard class = 1.00; preferred classes < 1.00; substandard classes > 1.00. Used in premium rate calculation and actuarial valuation.' ;
    rdfs:domain ind:RiskClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:productLineApplicability rdf:type rdf:Property ;
    rdfs:label 'Product Line Applicability' ;
    rdfs:comment 'Comma-separated list of product lines to which this risk class applies (e.g., Term Life, Whole Life (WL), Universal Life (UL), Indexed Universal Life (IUL), Variable Universal Life (VUL), Fixed Indexed Annuity (FIA), Single Premium Immediate Annuity (SPIA), Disability Income (DI), Long-Term Care (LTC)).' ;
    rdfs:domain ind:LifeInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryApprovalRequired rdf:type rdf:Property ;
    rdfs:label 'Regulatory Approval Required' ;
    rdfs:comment 'Flag indicating whether state insurance department approval is required before using this risk class. True if approval needed; false otherwise.' ;
    rdfs:domain ind:Underwriting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:riskClassCategory rdf:type rdf:Property ;
    rdfs:label 'Risk Class Category' ;
    rdfs:comment 'High-level category grouping for the risk classification: preferred (super-preferred and preferred), standard (standard plus and standard), substandard (table ratings and flat extras), decline, postpone, or rated.' ;
    rdfs:domain ind:RiskClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskClassCode rdf:type rdf:Property ;
    rdfs:label 'Risk Class Code' ;
    rdfs:comment 'Short alphanumeric code representing the risk classification (e.g., PP, PREF, STD, TABLE_A, DECLINE). Used as the business identifier for underwriting decisioning and system integration.' ;
    rdfs:domain ind:RiskClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskClassDescription rdf:type rdf:Property ;
    rdfs:label 'Risk Class Description' ;
    rdfs:comment 'Detailed description of the risk classification criteria, underwriting guidelines, and applicability conditions for this risk class.' ;
    rdfs:domain ind:RiskClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskClassName rdf:type rdf:Property ;
    rdfs:label 'Risk Class Name' ;
    rdfs:comment 'Full descriptive name of the risk classification category (e.g., Preferred Plus, Standard, Substandard Table B, Decline).' ;
    rdfs:domain ind:RiskClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskClassStatus rdf:type rdf:Property ;
    rdfs:label 'Risk Class Status' ;
    rdfs:comment 'Current lifecycle status of the risk class: active (in use), inactive (not currently used), pending approval (awaiting regulatory approval), deprecated (replaced by newer class), or suspended (temporarily not available).' ;
    rdfs:domain ind:RiskClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tableRatingCode rdf:type rdf:Property ;
    rdfs:label 'Table Rating Code' ;
    rdfs:comment 'Substandard table rating designation (Table A through P, or Table 1 through 16). Each table represents an incremental mortality increase (typically 25% per table). Null for non-table-rated classes.' ;
    rdfs:domain ind:RiskClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tableRatingFactor rdf:type rdf:Property ;
    rdfs:label 'Table Rating Factor' ;
    rdfs:comment 'Numeric factor corresponding to the table rating (e.g., Table A = 1.25, Table B = 1.50). Used to calculate substandard premium adjustments. Null for non-table-rated classes.' ;
    rdfs:domain ind:LifeInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:underwritingMethod rdf:type rdf:Property ;
    rdfs:label 'Underwriting Method' ;
    rdfs:comment 'Underwriting approach used to assign this risk class: full underwriting (medical exams, Attending Physician Statement (APS), Medical Information Bureau (MIB) checks), simplified issue (health questions only), guaranteed issue (no health questions), accelerated underwriting (data-driven, minimal evidence), or automated underwriting (rules engine-based).' ;
    rdfs:domain ind:Underwriting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facultativeReinsurerId rdf:type rdf:Property ;
    rdfs:label 'Facultative Reinsurer Id' ;
    rdfs:comment 'Reference to the facultative reinsurer if facultative reinsurance was placed. Null for automatic reinsurance or retained cases.' ;
    rdfs:domain ind:Decision ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Reinsurer .

ind:rulesEngineOutputId rdf:type rdf:Property ;
    rdfs:label 'Rules Engine Output Id' ;
    rdfs:comment 'Foreign key linking to underwriting.rules_engine_output. Business justification: The underwriting decision is directly informed by the automated rules engine output. Linking decision.rules_engine_output_id → rules_engine_output provides direct traceability from the formal decision' ;
    rdfs:domain ind:Underwriting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RulesEngineOutput .

ind:amlReviewCompleted rdf:type rdf:Property ;
    rdfs:label 'Aml Review Completed' ;
    rdfs:comment 'Indicates whether Anti-Money Laundering (AML) review was completed as part of the underwriting process. True if AML review was performed, False otherwise.' ;
    rdfs:domain ind:Decision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:approvedFaceAmount rdf:type rdf:Property ;
    rdfs:label 'Approved Face Amount' ;
    rdfs:comment 'The total death benefit amount approved by underwriting. May differ from the applied-for amount if the underwriter reduced coverage.' ;
    rdfs:domain ind:Decision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvedPremiumAmount rdf:type rdf:Property ;
    rdfs:label 'Approved Premium Amount' ;
    rdfs:comment 'The total premium amount approved for the policy, including any table ratings, flat extras, and rider premiums.' ;
    rdfs:domain ind:Decision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:apsOrdered rdf:type rdf:Property ;
    rdfs:label 'Aps Ordered' ;
    rdfs:comment 'Indicates whether an Attending Physician Statement (APS) was ordered from the applicants physician as part of the underwriting evidence requirements. True if APS was ordered, False otherwise.' ;
    rdfs:domain ind:Decision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:decisionMethod rdf:type rdf:Property ;
    rdfs:label 'Decision Method' ;
    rdfs:comment 'The underwriting method used to reach the decision. Automated Rules Engine indicates decision made by algorithmic rules without human intervention. Manual Underwriting indicates full human review. Hybrid indicates combination of automated and manual review. Accelerated Underwriting indicates streamlined process using data analytics. Simplified Issue indicates minimal underwriting with limited evidence.' ;
    rdfs:domain ind:Decision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decisionNumber rdf:type rdf:Property ;
    rdfs:label 'Decision Number' ;
    rdfs:comment 'Business-facing unique decision number or case reference used in underwriting workbench and communications.' ;
    rdfs:domain ind:Decision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decisionStatus rdf:type rdf:Property ;
    rdfs:label 'Decision Status' ;
    rdfs:comment 'Current status of the underwriting decision. Final indicates the decision is authoritative and binding. Interim indicates a preliminary decision subject to further review. Pending Review indicates decision awaiting supervisory approval. Overridden indicates decision was superseded by a subsequent decision. Withdrawn indicates decision was retracted.' ;
    rdfs:domain ind:Decision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decisionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Decision Timestamp' ;
    rdfs:comment 'The precise date and time the underwriting decision was finalized and committed to the system.' ;
    rdfs:domain ind:Decision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:decisionType rdf:type rdf:Property ;
    rdfs:label 'Decision Type' ;
    rdfs:comment 'The formal underwriting decision outcome. Approved Standard indicates acceptance at standard rates. Approved Rated indicates acceptance with table rating. Approved with Exclusion indicates acceptance with specific exclusion riders. Approved with Flat Extra indicates acceptance with additional per-thousand charge. Postponed indicates decision deferred pending additional information. Declined indicates application rejected. Referred to Facultative Reinsurance indicates case requires facultative reinsurance review. [ENUM-REF-CANDIDATE: Approved Standard|Approved Rated|Approved with Exclusion|Approved with Flat Extra|Postponed|Declined|Referred to Facultative Reinsurance — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Decision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:declineReasonCode rdf:type rdf:Property ;
    rdfs:label 'Decline Reason Code' ;
    rdfs:comment 'Standardized code indicating the primary reason for declining the application. Null if the application was not declined. Used for regulatory reporting and adverse action notices.' ;
    rdfs:domain ind:Decision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:declineReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Decline Reason Description' ;
    rdfs:comment 'Detailed explanation of the reason for declining the application. Null if the application was not declined. Must comply with adverse action notice requirements.' ;
    rdfs:domain ind:Decision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exclusionDescription rdf:type rdf:Property ;
    rdfs:label 'Exclusion Description' ;
    rdfs:comment 'Detailed description of the specific conditions, activities, or causes of death excluded from coverage under the exclusion rider. Null if no exclusions apply.' ;
    rdfs:domain ind:Underwriting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exclusionRiderApplied rdf:type rdf:Property ;
    rdfs:label 'Exclusion Rider Applied' ;
    rdfs:comment 'Indicates whether one or more exclusion riders were applied to the policy as a condition of approval. True if exclusions apply, False otherwise.' ;
    rdfs:domain ind:Decision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:financialUnderwritingCompleted rdf:type rdf:Property ;
    rdfs:label 'Financial Underwriting Completed' ;
    rdfs:comment 'Indicates whether financial underwriting review was completed to assess the applicants financial capacity and insurable interest. True if financial underwriting was performed, False otherwise.' ;
    rdfs:domain ind:Decision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mibInquiryCompleted rdf:type rdf:Property ;
    rdfs:label 'Mib Inquiry Completed' ;
    rdfs:comment 'Indicates whether a Medical Information Bureau (MIB) inquiry was performed as part of the underwriting process. True if MIB check was completed, False otherwise.' ;
    rdfs:domain ind:Decision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:postponeReason rdf:type rdf:Property ;
    rdfs:label 'Postpone Reason' ;
    rdfs:comment 'Explanation of why the underwriting decision was postponed, including what additional information or evidence is required. Null if the decision was not postponed.' ;
    rdfs:domain ind:Decision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postponeReviewDate rdf:type rdf:Property ;
    rdfs:label 'Postpone Review Date' ;
    rdfs:comment 'The scheduled date for re-review of a postponed application. Null if the decision was not postponed.' ;
    rdfs:domain ind:Decision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reinsuranceRequired rdf:type rdf:Property ;
    rdfs:label 'Reinsurance Required' ;
    rdfs:comment 'Indicates whether reinsurance placement is required for this policy based on retention limits and risk characteristics. True if reinsurance is needed, False otherwise.' ;
    rdfs:domain ind:Decision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supervisoryApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Supervisory Approval Date' ;
    rdfs:comment 'The date supervisory approval was granted. Null if supervisory approval was not required or not yet obtained.' ;
    rdfs:domain ind:Decision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:supervisoryApprovalRequired rdf:type rdf:Property ;
    rdfs:label 'Supervisory Approval Required' ;
    rdfs:comment 'Indicates whether the underwriting decision requires supervisory or senior underwriter approval before becoming final. True if approval is required, False otherwise.' ;
    rdfs:domain ind:LifeInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:evidenceRequirementId rdf:type rdf:Property ;
    rdfs:label 'Evidence Requirement Id' ;
    rdfs:comment 'Unique identifier for the evidence requirement record. Primary key for the evidence requirement entity.' ;
    rdfs:domain ind:Underwriting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EvidenceRequirement .

ind:receivedDocumentId rdf:type rdf:Property ;
    rdfs:label 'Received Document Id' ;
    rdfs:comment 'Foreign key linking to document.document. Business justification: In life insurance underwriting, each evidence requirement (APS, labs, exam) is fulfilled by a received document stored in the DMS. This FK directly links the requirement to its fulfilling document, en' ;
    rdfs:domain ind:EvidenceRequirement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Document .

ind:bloodPressureDiastolic rdf:type rdf:Property ;
    rdfs:label 'Blood Pressure Diastolic' ;
    rdfs:comment 'Diastolic blood pressure reading in mmHg from paramedical examination.' ;
    rdfs:domain ind:Underwriting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bloodPressureSystolic rdf:type rdf:Property ;
    rdfs:label 'Blood Pressure Systolic' ;
    rdfs:comment 'Systolic blood pressure reading in mmHg from paramedical examination.' ;
    rdfs:domain ind:Underwriting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:completionStatus rdf:type rdf:Property ;
    rdfs:label 'Completion Status' ;
    rdfs:comment 'Indicates whether the evidence item is complete and sufficient for underwriting decision or requires additional information.' ;
    rdfs:domain ind:EvidenceRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evidenceCostAmount rdf:type rdf:Property ;
    rdfs:label 'Evidence Cost Amount' ;
    rdfs:comment 'Cost incurred by the insurance company to obtain this evidence from the vendor or provider.' ;
    rdfs:domain ind:EvidenceRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:evidenceStatus rdf:type rdf:Property ;
    rdfs:label 'Evidence Status' ;
    rdfs:comment 'Current workflow status of the evidence requirement within the underwriting workbench.' ;
    rdfs:domain ind:EvidenceRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:examDate rdf:type rdf:Property ;
    rdfs:label 'Exam Date' ;
    rdfs:comment 'Date when the paramedical examination was conducted. Applicable for paramedical exam evidence type.' ;
    rdfs:domain ind:EvidenceRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:examLocation rdf:type rdf:Property ;
    rdfs:label 'Exam Location' ;
    rdfs:comment 'Physical location or address where the paramedical examination was performed.' ;
    rdfs:domain ind:EvidenceRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:followUpActionDescription rdf:type rdf:Property ;
    rdfs:label 'Follow Up Action Description' ;
    rdfs:comment 'Description of the follow-up action required, such as ordering additional tests or requesting clarification from the physician.' ;
    rdfs:domain ind:EvidenceRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:followUpActionRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Follow Up Action Required Flag' ;
    rdfs:comment 'Indicates whether additional follow-up action or supplementary evidence is required based on the review of this evidence.' ;
    rdfs:domain ind:Underwriting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:heightInches rdf:type rdf:Property ;
    rdfs:label 'Height Inches' ;
    rdfs:comment 'Applicant height measured in inches during paramedical examination.' ;
    rdfs:domain ind:Underwriting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hipaaAuthorizationDate rdf:type rdf:Property ;
    rdfs:label 'Hipaa Authorization Date' ;
    rdfs:comment 'Date when the applicant signed the HIPAA authorization form.' ;
    rdfs:domain ind:Underwriting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:hipaaAuthorizationReceivedFlag rdf:type rdf:Property ;
    rdfs:label 'Hipaa Authorization Received Flag' ;
    rdfs:comment 'Indicates whether HIPAA authorization was received from the applicant to obtain medical evidence.' ;
    rdfs:domain ind:Underwriting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:labResultsSummary rdf:type rdf:Property ;
    rdfs:label 'Lab Results Summary' ;
    rdfs:comment 'Summary of laboratory test results from blood and urine specimens. Contains key findings and abnormal values.' ;
    rdfs:domain ind:Underwriting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:medicalConditionsDisclosed rdf:type rdf:Property ;
    rdfs:label 'Medical Conditions Disclosed' ;
    rdfs:comment 'Free-text summary of medical conditions disclosed in the evidence (APS, exam reports). Contains diagnoses, symptoms, and health history.' ;
    rdfs:domain ind:Underwriting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:medicationsList rdf:type rdf:Property ;
    rdfs:label 'Medications List' ;
    rdfs:comment 'List of current and past medications documented in the evidence, including dosages and frequencies.' ;
    rdfs:domain ind:EvidenceRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mibApplicantConsentFlag rdf:type rdf:Property ;
    rdfs:label 'Mib Applicant Consent Flag' ;
    rdfs:comment 'Indicates whether the applicant provided consent for MIB inquiry as required by FCRA.' ;
    rdfs:domain ind:EvidenceRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mibConditionCodes rdf:type rdf:Property ;
    rdfs:label 'Mib Condition Codes' ;
    rdfs:comment 'MIB condition codes indicating medical conditions or risk factors disclosed in prior applications.' ;
    rdfs:domain ind:EvidenceRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mibFollowUpRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Mib Follow Up Required Flag' ;
    rdfs:comment 'Indicates whether the MIB response requires additional follow-up investigation or evidence.' ;
    rdfs:domain ind:EvidenceRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mibMemberCode rdf:type rdf:Property ;
    rdfs:label 'Mib Member Code' ;
    rdfs:comment 'MIB member code identifying the insurance company submitting the inquiry.' ;
    rdfs:domain ind:Underwriting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mibResponseCodes rdf:type rdf:Property ;
    rdfs:label 'Mib Response Codes' ;
    rdfs:comment 'Comma-separated list of MIB response codes returned from the inquiry, indicating prior insurance applications and medical conditions.' ;
    rdfs:domain ind:EvidenceRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mibSubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Mib Submission Date' ;
    rdfs:comment 'Date when the MIB inquiry was submitted. Applicable for MIB inquiry evidence type.' ;
    rdfs:domain ind:EvidenceRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:orderedDate rdf:type rdf:Property ;
    rdfs:label 'Ordered Date' ;
    rdfs:comment 'Date when the evidence requirement was ordered from the vendor or provider.' ;
    rdfs:domain ind:EvidenceRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:physicianName rdf:type rdf:Property ;
    rdfs:label 'Physician Name' ;
    rdfs:comment 'Full name of the attending physician for APS evidence type. Applicable only when evidence_type is APS.' ;
    rdfs:domain ind:Underwriting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:physicianNpi rdf:type rdf:Property ;
    rdfs:label 'Physician Npi' ;
    rdfs:comment 'Ten-digit National Provider Identifier for the attending physician. Applicable for APS evidence.' ;
    rdfs:domain ind:Underwriting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:physicianPracticeName rdf:type rdf:Property ;
    rdfs:label 'Physician Practice Name' ;
    rdfs:comment 'Name of the medical practice or facility where the attending physician practices. Applicable for APS evidence.' ;
    rdfs:domain ind:Underwriting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pulseRate rdf:type rdf:Property ;
    rdfs:label 'Pulse Rate' ;
    rdfs:comment 'Pulse rate in beats per minute recorded during paramedical examination.' ;
    rdfs:domain ind:Underwriting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:relevanceScore rdf:type rdf:Property ;
    rdfs:label 'Relevance Score' ;
    rdfs:comment 'Quantitative score (0.00 to 1.00) indicating how relevant this document was to the underwriting decision. Used to prioritize critical evidence and support audit trails. Explicitly identified in detection phase relationship data.' ;
    rdfs:domain ind:EvidenceRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reviewNotes rdf:type rdf:Property ;
    rdfs:label 'Review Notes' ;
    rdfs:comment 'Underwriter notes documenting findings from this specific document review, including key observations, red flags identified, or clarifications needed. These notes are specific to the document-assessment pairing.' ;
    rdfs:domain ind:LifeInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewTimestamp rdf:type rdf:Property ;
    rdfs:label 'Review Timestamp' ;
    rdfs:comment 'Precise timestamp when the document review was completed and recorded in the underwriting workbench.' ;
    rdfs:domain ind:EvidenceRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:reviewedDate rdf:type rdf:Property ;
    rdfs:label 'Reviewed Date' ;
    rdfs:comment 'Date when the underwriter completed review of the evidence.' ;
    rdfs:domain ind:EvidenceRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:specimenCollectionStatus rdf:type rdf:Property ;
    rdfs:label 'Specimen Collection Status' ;
    rdfs:comment 'Status of biological specimen collection (blood, urine) for laboratory testing.' ;
    rdfs:domain ind:EvidenceRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:treatmentHistory rdf:type rdf:Property ;
    rdfs:label 'Treatment History' ;
    rdfs:comment 'Summary of medical treatments, procedures, and interventions documented in the evidence.' ;
    rdfs:domain ind:EvidenceRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:underwriterReviewNotes rdf:type rdf:Property ;
    rdfs:label 'Underwriter Review Notes' ;
    rdfs:comment 'Free-text notes and observations recorded by the underwriter during evidence review. Contains risk assessment commentary and decision rationale.' ;
    rdfs:domain ind:Underwriting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:weightPounds rdf:type rdf:Property ;
    rdfs:label 'Weight Pounds' ;
    rdfs:comment 'Applicant weight measured in pounds during paramedical examination.' ;
    rdfs:domain ind:Underwriting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:apsRecordId rdf:type rdf:Property ;
    rdfs:label 'Aps Record Id' ;
    rdfs:comment 'Primary key for aps_record' ;
    rdfs:domain ind:ApsRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:apsCostAmount rdf:type rdf:Property ;
    rdfs:label 'Aps Cost Amount' ;
    rdfs:comment 'Cost incurred to obtain the APS from the physician or vendor.' ;
    rdfs:domain ind:ApsRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:apsCostCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Aps Cost Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the APS cost amount.' ;
    rdfs:domain ind:ApsRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:apsStatus rdf:type rdf:Property ;
    rdfs:label 'Aps Status' ;
    rdfs:comment 'Current status of the APS request in the underwriting workflow.' ;
    rdfs:domain ind:ApsRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:apsType rdf:type rdf:Property ;
    rdfs:label 'Aps Type' ;
    rdfs:comment 'Type of APS requested based on underwriting requirements (full medical history, abbreviated summary, or targeted inquiry).' ;
    rdfs:domain ind:ApsRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coveragePeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Coverage Period End Date' ;
    rdfs:comment 'End date of the period for which medical history was requested in the APS.' ;
    rdfs:domain ind:ApsRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:coveragePeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Coverage Period Start Date' ;
    rdfs:comment 'Start date of the period for which medical history was requested in the APS.' ;
    rdfs:domain ind:ApsRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:firstVisitDate rdf:type rdf:Property ;
    rdfs:label 'First Visit Date' ;
    rdfs:comment 'Date of the insured\'s first visit to the attending physician as documented in the APS.' ;
    rdfs:domain ind:ApsRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:followUpNotes rdf:type rdf:Property ;
    rdfs:label 'Follow Up Notes' ;
    rdfs:comment 'Notes describing the nature of follow-up required or actions taken.' ;
    rdfs:domain ind:ApsRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:followUpRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Follow Up Required Flag' ;
    rdfs:comment 'Indicates whether additional follow-up or clarification is required from the physician after initial APS review.' ;
    rdfs:domain ind:ApsRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastVisitDate rdf:type rdf:Property ;
    rdfs:label 'Last Visit Date' ;
    rdfs:comment 'Date of the insured\'s most recent visit to the attending physician as documented in the APS.' ;
    rdfs:domain ind:ApsRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:medicationsPrescribed rdf:type rdf:Property ;
    rdfs:label 'Medications Prescribed' ;
    rdfs:comment 'List of medications currently or previously prescribed to the insured as documented in the APS.' ;
    rdfs:domain ind:ApsRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:physicianAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Physician Address Line1' ;
    rdfs:comment 'Street address line 1 of the attending physician practice.' ;
    rdfs:domain ind:ApsRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:physicianCity rdf:type rdf:Property ;
    rdfs:label 'Physician City' ;
    rdfs:comment 'City where the attending physician practice is located.' ;
    rdfs:domain ind:ApsRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:physicianContactPhone rdf:type rdf:Property ;
    rdfs:label 'Physician Contact Phone' ;
    rdfs:comment 'Primary contact phone number for the attending physician or practice.' ;
    rdfs:domain ind:ApsRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:physicianPostalCode rdf:type rdf:Property ;
    rdfs:label 'Physician Postal Code' ;
    rdfs:comment 'Postal or ZIP code of the attending physician practice.' ;
    rdfs:domain ind:ApsRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:physicianSpecialty rdf:type rdf:Property ;
    rdfs:label 'Physician Specialty' ;
    rdfs:comment 'Medical specialty of the attending physician (e.g., Cardiology, Oncology, Internal Medicine).' ;
    rdfs:domain ind:ApsRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:physicianState rdf:type rdf:Property ;
    rdfs:label 'Physician State' ;
    rdfs:comment 'State or province where the attending physician practice is located.' ;
    rdfs:domain ind:ApsRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prognosisNotes rdf:type rdf:Property ;
    rdfs:label 'Prognosis Notes' ;
    rdfs:comment 'Physician\'s prognosis or outlook for the insured\'s health condition as documented in the APS.' ;
    rdfs:domain ind:ApsRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewCompletedDate rdf:type rdf:Property ;
    rdfs:label 'Review Completed Date' ;
    rdfs:comment 'Date when the underwriter completed the review of the APS.' ;
    rdfs:domain ind:LifeInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:riskClassificationImpact rdf:type rdf:Property ;
    rdfs:label 'Risk Classification Impact' ;
    rdfs:comment 'Impact of the APS findings on the applicant\'s risk classification (e.g., standard, substandard, rated, decline).' ;
    rdfs:domain ind:ApsRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:treatmentHistorySummary rdf:type rdf:Property ;
    rdfs:label 'Treatment History Summary' ;
    rdfs:comment 'Summary of treatments, procedures, surgeries, or therapies documented in the APS.' ;
    rdfs:domain ind:ApsRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adverseActionRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Adverse Action Required Flag' ;
    rdfs:comment 'Indicates whether the MIB inquiry results will contribute to an adverse underwriting decision requiring FCRA-compliant adverse action notice to the applicant.' ;
    rdfs:domain ind:MibInquiry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:applicantConsentFlag rdf:type rdf:Property ;
    rdfs:label 'Applicant Consent Flag' ;
    rdfs:comment 'Indicates whether the applicant provided written consent for the MIB inquiry as required by FCRA and state insurance regulations. Must be true for inquiry to proceed.' ;
    rdfs:domain ind:MibInquiry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:conditionCodes rdf:type rdf:Property ;
    rdfs:label 'Condition Codes' ;
    rdfs:comment 'Comma-separated list of MIB condition codes returned in the response. Each code represents a medical condition, impairment, or underwriting factor previously reported to MIB by member companies. Confidential medical information.' ;
    rdfs:domain ind:MibInquiry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discrepancyDescription rdf:type rdf:Property ;
    rdfs:label 'Discrepancy Description' ;
    rdfs:comment 'Detailed description of any discrepancies found between the application and MIB records. Documents the nature and severity of non-disclosure or inconsistencies. Confidential underwriting information.' ;
    rdfs:domain ind:MibInquiry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discrepancyDetectedFlag rdf:type rdf:Property ;
    rdfs:label 'Discrepancy Detected Flag' ;
    rdfs:comment 'Indicates whether the MIB inquiry revealed discrepancies between the applicants stated medical history and the MIB records. True triggers additional investigation for potential non-disclosure or fraud.' ;
    rdfs:domain ind:MibInquiry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:errorCode rdf:type rdf:Property ;
    rdfs:label 'Error Code' ;
    rdfs:comment 'Error code returned by MIB if the inquiry failed or encountered issues. Used for troubleshooting and retry logic.' ;
    rdfs:domain ind:MibInquiry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:errorMessage rdf:type rdf:Property ;
    rdfs:label 'Error Message' ;
    rdfs:comment 'Detailed error message returned by MIB if the inquiry failed. Provides context for technical troubleshooting.' ;
    rdfs:domain ind:MibInquiry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:followUpActionType rdf:type rdf:Property ;
    rdfs:label 'Follow Up Action Type' ;
    rdfs:comment 'The type of follow-up action required based on the MIB response. Specifies what additional underwriting evidence or investigation is needed.' ;
    rdfs:domain ind:MibInquiry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hitIndicator rdf:type rdf:Property ;
    rdfs:label 'Hit Indicator' ;
    rdfs:comment 'Indicates whether the MIB inquiry returned any records for the applicant. True means prior insurance applications or medical conditions were found in the MIB database.' ;
    rdfs:domain ind:MibInquiry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inquiryDate rdf:type rdf:Property ;
    rdfs:label 'Inquiry Date' ;
    rdfs:comment 'The date when the MIB inquiry request was submitted to the Medical Information Bureau. This is the business event date for the inquiry transaction.' ;
    rdfs:domain ind:MibInquiry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:inquiryMethod rdf:type rdf:Property ;
    rdfs:label 'Inquiry Method' ;
    rdfs:comment 'The technical method used to submit the MIB inquiry. Indicates the integration channel between the underwriting system and MIB.' ;
    rdfs:domain ind:MibInquiry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inquiryStatus rdf:type rdf:Property ;
    rdfs:label 'Inquiry Status' ;
    rdfs:comment 'Current status of the MIB inquiry in its lifecycle. Tracks the inquiry from submission through response receipt.' ;
    rdfs:domain ind:MibInquiry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inquiryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Inquiry Timestamp' ;
    rdfs:comment 'The precise timestamp when the MIB inquiry request was submitted, including time zone. Used for audit trail and SLA tracking.' ;
    rdfs:domain ind:MibInquiry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:inquiryType rdf:type rdf:Property ;
    rdfs:label 'Inquiry Type' ;
    rdfs:comment 'The type of underwriting transaction triggering the MIB inquiry. Determines the scope and purpose of the medical history check.' ;
    rdfs:domain ind:MibInquiry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mibResponseCode rdf:type rdf:Property ;
    rdfs:label 'Mib Response Code' ;
    rdfs:comment 'The primary response code returned by MIB indicating the outcome of the inquiry. Standard codes include hit/no-hit, error conditions, and data quality flags.' ;
    rdfs:domain ind:MibInquiry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mostRecentReportDate rdf:type rdf:Property ;
    rdfs:label 'Most Recent Report Date' ;
    rdfs:comment 'The date of the most recent MIB record found for the applicant. Helps underwriters assess the recency and relevance of prior medical information.' ;
    rdfs:domain ind:MibInquiry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:numberOfRecordsFound rdf:type rdf:Property ;
    rdfs:label 'Number Of Records Found' ;
    rdfs:comment 'The count of prior insurance application records found in the MIB database for this applicant. Indicates the extent of prior underwriting history.' ;
    rdfs:domain ind:MibInquiry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:responseReceivedDate rdf:type rdf:Property ;
    rdfs:label 'Response Received Date' ;
    rdfs:comment 'The date when the MIB response was received by the insurance company. Used to calculate turnaround time and SLA compliance.' ;
    rdfs:domain ind:MibInquiry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:responseReceivedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Response Received Timestamp' ;
    rdfs:comment 'The precise timestamp when the MIB response was received, including time zone. Used for detailed audit trail and performance monitoring.' ;
    rdfs:domain ind:MibInquiry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:transactionReference rdf:type rdf:Property ;
    rdfs:label 'Transaction Reference' ;
    rdfs:comment 'The unique transaction identifier assigned by MIB for this inquiry. Used for reconciliation, support requests, and audit trail.' ;
    rdfs:domain ind:MibInquiry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:underwriterNotes rdf:type rdf:Property ;
    rdfs:label 'Underwriter Notes' ;
    rdfs:comment 'Free-text notes entered by the underwriter regarding their analysis of the MIB inquiry results. May include interpretation of condition codes, follow-up plans, or risk assessment observations. Confidential underwriting work product.' ;
    rdfs:domain ind:MibInquiry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:underwriterReviewStatus rdf:type rdf:Property ;
    rdfs:label 'Underwriter Review Status' ;
    rdfs:comment 'Current status of the underwriters review of the MIB inquiry results. Tracks the progression of manual underwriting analysis.' ;
    rdfs:domain ind:MibInquiry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:abnormalFindingsFlag rdf:type rdf:Property ;
    rdfs:label 'Abnormal Findings Flag' ;
    rdfs:comment 'Indicates whether any abnormal findings were identified during the examination or in laboratory results. True if abnormalities detected.' ;
    rdfs:domain ind:ParamedicalExam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:abnormalFindingsSummary rdf:type rdf:Property ;
    rdfs:label 'Abnormal Findings Summary' ;
    rdfs:comment 'Summary description of any abnormal findings identified during the examination or in laboratory results. Used for underwriting risk assessment.' ;
    rdfs:domain ind:ParamedicalExam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bloodSpecimenCollectedFlag rdf:type rdf:Property ;
    rdfs:label 'Blood Specimen Collected Flag' ;
    rdfs:comment 'Indicates whether a blood specimen was successfully collected during the examination. True if collected, False if not.' ;
    rdfs:domain ind:ParamedicalExam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:bloodSpecimenCollectionDate rdf:type rdf:Property ;
    rdfs:label 'Blood Specimen Collection Date' ;
    rdfs:comment 'Date when the blood specimen was collected. May differ from exam date if specimen was collected separately.' ;
    rdfs:domain ind:ParamedicalExam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:bmi rdf:type rdf:Property ;
    rdfs:label 'Bmi' ;
    rdfs:comment 'Calculated Body Mass Index based on height and weight measurements. Key indicator for mortality risk classification.' ;
    rdfs:domain ind:ParamedicalExam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cancellationNotes rdf:type rdf:Property ;
    rdfs:label 'Cancellation Notes' ;
    rdfs:comment 'Additional details explaining why the examination was cancelled. Null if exam was completed.' ;
    rdfs:domain ind:ParamedicalExam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cancellationReasonCode rdf:type rdf:Property ;
    rdfs:label 'Cancellation Reason Code' ;
    rdfs:comment 'Code indicating the reason why the examination was cancelled, if applicable. Null if exam was completed.' ;
    rdfs:domain ind:ParamedicalExam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:examCompletedDate rdf:type rdf:Property ;
    rdfs:label 'Exam Completed Date' ;
    rdfs:comment 'Date when the paramedical examination was actually conducted and completed by the examiner.' ;
    rdfs:domain ind:ParamedicalExam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:examCostAmount rdf:type rdf:Property ;
    rdfs:label 'Exam Cost Amount' ;
    rdfs:comment 'Total cost charged by the vendor for conducting the paramedical examination. Used for expense tracking and vendor reconciliation.' ;
    rdfs:domain ind:ParamedicalExam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:examCostCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Exam Cost Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the examination cost amount.' ;
    rdfs:domain ind:ParamedicalExam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:examLocationAddress rdf:type rdf:Property ;
    rdfs:label 'Exam Location Address' ;
    rdfs:comment 'Full street address where the paramedical examination was conducted.' ;
    rdfs:domain ind:ParamedicalExam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:examLocationCity rdf:type rdf:Property ;
    rdfs:label 'Exam Location City' ;
    rdfs:comment 'City where the paramedical examination was conducted.' ;
    rdfs:domain ind:ParamedicalExam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:examLocationPostalCode rdf:type rdf:Property ;
    rdfs:label 'Exam Location Postal Code' ;
    rdfs:comment 'Postal code (ZIP code) of the location where the paramedical examination was conducted.' ;
    rdfs:domain ind:ParamedicalExam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:examLocationState rdf:type rdf:Property ;
    rdfs:label 'Exam Location State' ;
    rdfs:comment 'State or province where the paramedical examination was conducted. Two-letter state code.' ;
    rdfs:domain ind:ParamedicalExam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:examLocationType rdf:type rdf:Property ;
    rdfs:label 'Exam Location Type' ;
    rdfs:comment 'Type of location where the paramedical examination was conducted (e.g., applicant\'s home, office, clinic, mobile unit).' ;
    rdfs:domain ind:ParamedicalExam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:examOrderedDate rdf:type rdf:Property ;
    rdfs:label 'Exam Ordered Date' ;
    rdfs:comment 'Date when the paramedical examination was ordered by the underwriter. Marks the start of the evidence fulfillment workflow.' ;
    rdfs:domain ind:ParamedicalExam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:examReceivedDate rdf:type rdf:Property ;
    rdfs:label 'Exam Received Date' ;
    rdfs:comment 'Date when the completed examination results were received by the insurance company from the vendor.' ;
    rdfs:domain ind:ParamedicalExam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:examScheduledDate rdf:type rdf:Property ;
    rdfs:label 'Exam Scheduled Date' ;
    rdfs:comment 'Date when the paramedical examination appointment was scheduled with the proposed insured.' ;
    rdfs:domain ind:ParamedicalExam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:examinerLicenseNumber rdf:type rdf:Property ;
    rdfs:label 'Examiner License Number' ;
    rdfs:comment 'Professional license number of the paramedical examiner, if applicable. Used for credential verification.' ;
    rdfs:domain ind:ParamedicalExam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:examinerNotes rdf:type rdf:Property ;
    rdfs:label 'Examiner Notes' ;
    rdfs:comment 'Free-text notes and observations recorded by the paramedical examiner during the examination. May include behavioral observations or environmental factors.' ;
    rdfs:domain ind:ParamedicalExam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:labCliaNumber rdf:type rdf:Property ;
    rdfs:label 'Lab Clia Number' ;
    rdfs:comment 'CLIA certification number of the laboratory that processed the specimens. Required for regulatory compliance.' ;
    rdfs:domain ind:ParamedicalExam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:labName rdf:type rdf:Property ;
    rdfs:label 'Lab Name' ;
    rdfs:comment 'Name of the laboratory facility that processed the blood and urine specimens.' ;
    rdfs:domain ind:ParamedicalExam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:labResultsReceivedDate rdf:type rdf:Property ;
    rdfs:label 'Lab Results Received Date' ;
    rdfs:comment 'Date when laboratory test results were received from the testing facility.' ;
    rdfs:domain ind:ParamedicalExam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:labResultsReceivedFlag rdf:type rdf:Property ;
    rdfs:label 'Lab Results Received Flag' ;
    rdfs:comment 'Indicates whether laboratory test results have been received from the testing facility. True if received, False if pending.' ;
    rdfs:domain ind:ParamedicalExam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:urineSpecimenCollectedFlag rdf:type rdf:Property ;
    rdfs:label 'Urine Specimen Collected Flag' ;
    rdfs:comment 'Indicates whether a urine specimen was successfully collected during the examination. True if collected, False if not.' ;
    rdfs:domain ind:ParamedicalExam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:urineSpecimenCollectionDate rdf:type rdf:Property ;
    rdfs:label 'Urine Specimen Collection Date' ;
    rdfs:comment 'Date when the urine specimen was collected. May differ from exam date if specimen was collected separately.' ;
    rdfs:domain ind:ParamedicalExam ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:recommendedRiskClassId rdf:type rdf:Property ;
    rdfs:label 'Recommended Risk Class Id' ;
    rdfs:comment 'Reference to the risk classification recommended by the rules engine based on automated evaluation of mortality and morbidity risk factors.' ;
    rdfs:domain ind:RulesEngineOutput ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RiskClass .

ind:applicantAge rdf:type rdf:Property ;
    rdfs:label 'Applicant Age' ;
    rdfs:comment 'Age of the primary applicant at the time of rules engine evaluation. Critical factor in mortality risk assessment and risk classification.' ;
    rdfs:domain ind:RulesEngineOutput ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:applicantGender rdf:type rdf:Property ;
    rdfs:label 'Applicant Gender' ;
    rdfs:comment 'Gender of the primary applicant. Used in mortality table selection and risk classification where permitted by state regulations.' ;
    rdfs:domain ind:RulesEngineOutput ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:automatedDecision rdf:type rdf:Property ;
    rdfs:label 'Automated Decision' ;
    rdfs:comment 'The automated underwriting decision recommendation generated by the rules engine. Approve indicates auto-approval eligibility, decline indicates auto-decline, refer indicates human review required, pend indicates additional information needed.' ;
    rdfs:domain ind:RulesEngineOutput ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calculatedNarAmount rdf:type rdf:Property ;
    rdfs:label 'Calculated Nar Amount' ;
    rdfs:comment 'The net amount at risk (NAR) calculated by the rules engine, representing the insurer\'s exposure (typically death benefit minus reserve or cash value).' ;
    rdfs:domain ind:RulesEngineOutput ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:evaluationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Evaluation Timestamp' ;
    rdfs:comment 'Date and time when the rules engine evaluation was executed. Represents the business event time of automated decisioning.' ;
    rdfs:domain ind:RulesEngineOutput ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:evidenceRequirementsMetFlag rdf:type rdf:Property ;
    rdfs:label 'Evidence Requirements Met Flag' ;
    rdfs:comment 'Indicates whether all required underwriting evidence (Attending Physician Statement (APS), Medical Information Bureau (MIB) reports, lab results, financial documents) has been received and evaluated by the rules engine.' ;
    rdfs:domain ind:RulesEngineOutput ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:financialUnderwritingRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Financial Underwriting Required Flag' ;
    rdfs:comment 'Indicates whether the rules engine determined that enhanced financial underwriting is required based on coverage amount, income verification needs, or STOLI risk indicators.' ;
    rdfs:domain ind:RulesEngineOutput ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mibCodesFound rdf:type rdf:Property ;
    rdfs:label 'Mib Codes Found' ;
    rdfs:comment 'Comma-separated list of MIB codes identified during the MIB check. MIB codes represent medical conditions or risk factors from prior insurance applications.' ;
    rdfs:domain ind:RulesEngineOutput ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recommendedFlatExtraPerThousand rdf:type rdf:Property ;
    rdfs:label 'Recommended Flat Extra Per Thousand' ;
    rdfs:comment 'Flat extra premium per thousand dollars of coverage recommended by the rules engine for specific impairments or occupational hazards.' ;
    rdfs:domain ind:RulesEngineOutput ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recommendedTableRating rdf:type rdf:Property ;
    rdfs:label 'Recommended Table Rating' ;
    rdfs:comment 'Table rating (A through P or STD for standard) recommended by the rules engine for substandard risk pricing. Each letter represents an incremental mortality charge.' ;
    rdfs:domain ind:RulesEngineOutput ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reinsuranceRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Reinsurance Required Flag' ;
    rdfs:comment 'Indicates whether the rules engine determined that facultative or automatic reinsurance placement is required based on retention limits and risk characteristics.' ;
    rdfs:domain ind:RulesEngineOutput ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:retentionLimitExceededFlag rdf:type rdf:Property ;
    rdfs:label 'Retention Limit Exceeded Flag' ;
    rdfs:comment 'Indicates whether the application exceeds the company\'s retention limit, triggering reinsurance requirements. True means the risk exceeds internal capacity.' ;
    rdfs:domain ind:RulesEngineOutput ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ruleExecutionDurationMs rdf:type rdf:Property ;
    rdfs:label 'Rule Execution Duration Ms' ;
    rdfs:comment 'Total execution time in milliseconds for the rules engine evaluation. Used for performance monitoring and STP rate optimization.' ;
    rdfs:domain ind:RulesEngineOutput ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rulesEngineOutputStatus rdf:type rdf:Property ;
    rdfs:label 'Rules Engine Output Status' ;
    rdfs:comment 'Current status of this rules engine output record. Active indicates the current evaluation; superseded indicates a newer evaluation exists; archived indicates historical record retention.' ;
    rdfs:domain ind:RulesEngineOutput ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rulesEngineVersion rdf:type rdf:Property ;
    rdfs:label 'Rules Engine Version' ;
    rdfs:comment 'Version identifier of the automated underwriting rules engine that performed the evaluation (e.g., 2.5.1). Critical for audit trail and reproducibility of automated decisions.' ;
    rdfs:domain ind:RulesEngineOutput ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rulesFailedCount rdf:type rdf:Property ;
    rdfs:label 'Rules Failed Count' ;
    rdfs:comment 'Number of rules that evaluated to a fail outcome, indicating non-compliance with automated underwriting criteria.' ;
    rdfs:domain ind:RulesEngineOutput ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rulesFiredCount rdf:type rdf:Property ;
    rdfs:label 'Rules Fired Count' ;
    rdfs:comment 'Total number of individual rules that were triggered and evaluated during this rules engine run.' ;
    rdfs:domain ind:RulesEngineOutput ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rulesPassedCount rdf:type rdf:Property ;
    rdfs:label 'Rules Passed Count' ;
    rdfs:comment 'Number of rules that evaluated to a pass outcome, indicating compliance with automated underwriting criteria.' ;
    rdfs:domain ind:RulesEngineOutput ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rulesReferCount rdf:type rdf:Property ;
    rdfs:label 'Rules Refer Count' ;
    rdfs:comment 'Number of rules that evaluated to a refer outcome, requiring human underwriter review and manual decisioning.' ;
    rdfs:domain ind:RulesEngineOutput ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:stpEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Stp Eligible Flag' ;
    rdfs:comment 'Indicates whether the application qualifies for straight-through processing (STP) based on rules engine evaluation. True means the application can be auto-approved without human intervention.' ;
    rdfs:domain ind:RulesEngineOutput ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ruleId rdf:type rdf:Property ;
    rdfs:label 'Rule Id' ;
    rdfs:comment 'Primary key for rule' ;
    rdfs:domain ind:Underwriting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Rule .

ind:declineThresholdDescription rdf:type rdf:Property ;
    rdfs:label 'Decline Threshold Description' ;
    rdfs:comment 'Textual description of the conditions under which the rule triggers an automatic decline or decline recommendation. Specifies severity levels, combinations of risk factors, or absolute contraindications. Null if rule does not trigger declines.' ;
    rdfs:domain ind:Rule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evidenceRequirement rdf:type rdf:Property ;
    rdfs:label 'Evidence Requirement' ;
    rdfs:comment 'Comma-separated list of additional underwriting evidence required when this rule is triggered (e.g., APS, paramedical exam, EKG, blood profile, urine test, MIB report, motor vehicle report, financial statements). Null if no additional evidence required.' ;
    rdfs:domain ind:Rule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:faceAmountThresholdMax rdf:type rdf:Property ;
    rdfs:label 'Face Amount Threshold Max' ;
    rdfs:comment 'Maximum policy face amount (death benefit) for which this rule applies. Defines the upper face amount boundary for rule applicability. Null if no maximum threshold.' ;
    rdfs:domain ind:Rule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:faceAmountThresholdMin rdf:type rdf:Property ;
    rdfs:label 'Face Amount Threshold Min' ;
    rdfs:comment 'Minimum policy face amount (death benefit) for which this rule applies. Supports face-amount-based underwriting tiers (e.g., simplified issue up to $250,000, full underwriting above). Null if no minimum threshold.' ;
    rdfs:domain ind:Rule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:flatExtraPerThousandMax rdf:type rdf:Property ;
    rdfs:label 'Flat Extra Per Thousand Max' ;
    rdfs:comment 'Maximum flat extra premium charge per thousand dollars of face amount. Defines the upper bound of the flat extra surcharge. Null if rule does not use flat extras.' ;
    rdfs:domain ind:Rule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:flatExtraPerThousandMin rdf:type rdf:Property ;
    rdfs:label 'Flat Extra Per Thousand Min' ;
    rdfs:comment 'Minimum flat extra premium charge per thousand dollars of face amount, expressed in dollars. Used for temporary or permanent extra mortality charges. Null if rule does not use flat extras.' ;
    rdfs:domain ind:Rule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:icd10CodeMapping rdf:type rdf:Property ;
    rdfs:label 'Icd10 Code Mapping' ;
    rdfs:comment 'ICD-10 diagnosis code(s) associated with the medical impairment. Supports integration with Attending Physician Statements (APS) and medical records. Multiple codes may be comma-separated. Null for non-medical rules.' ;
    rdfs:domain ind:Rule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impairmentCode rdf:type rdf:Property ;
    rdfs:label 'Impairment Code' ;
    rdfs:comment 'Standard code identifying a specific medical impairment or health condition (e.g., DIAB2 for Type 2 Diabetes, CAD for Coronary Artery Disease). Used for medical underwriting and impairment rating. Null for non-medical rules.' ;
    rdfs:domain ind:Rule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:logicDescription rdf:type rdf:Property ;
    rdfs:label 'Logic Description' ;
    rdfs:comment 'Detailed textual description of the rule logic, conditions, and decision criteria. Explains how the rule evaluates applicant data and what actions it triggers. Critical for underwriter training and audit compliance.' ;
    rdfs:domain ind:Rule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:narCalculationImpact rdf:type rdf:Property ;
    rdfs:label 'Nar Calculation Impact' ;
    rdfs:comment 'Describes how this rule affects the Net Amount at Risk (NAR) calculation. NAR is the death benefit minus the policy cash value or account value. Rules that increase mortality risk typically increase NAR exposure.' ;
    rdfs:domain ind:Rule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:owner rdf:type rdf:Property ;
    rdfs:label 'Owner' ;
    rdfs:comment 'Name or identifier of the business unit, underwriting team, or individual responsible for maintaining and updating this rule. Supports governance and accountability.' ;
    rdfs:domain ind:Rule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reinsuranceCessionImpact rdf:type rdf:Property ;
    rdfs:label 'Reinsurance Cession Impact' ;
    rdfs:comment 'Indicates how this rule affects reinsurance placement decisions: automatic (ceded under automatic treaty), facultative (requires facultative reinsurance submission), retained (risk retained by direct writer), or none (no reinsurance impact).' ;
    rdfs:domain ind:Rule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:smokerStatusApplicability rdf:type rdf:Property ;
    rdfs:label 'Smoker Status Applicability' ;
    rdfs:comment 'Indicates whether the rule applies to smokers, non-smokers, or all applicants. Supports tobacco-use-specific underwriting criteria and rating adjustments.' ;
    rdfs:domain ind:Rule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardRatingAction rdf:type rdf:Property ;
    rdfs:label 'Standard Rating Action' ;
    rdfs:comment 'Default underwriting action prescribed by the rule: standard (no extra premium), table rating (mortality multiplier), flat extra (per-thousand charge), decline (application rejected), or refer (escalate to senior underwriter or medical director).' ;
    rdfs:domain ind:Rule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tableRatingRangeMax rdf:type rdf:Property ;
    rdfs:label 'Table Rating Range Max' ;
    rdfs:comment 'Maximum table rating (A through P) for the impairment or risk factor. Defines the upper bound of mortality surcharge. Null if rule does not use table ratings.' ;
    rdfs:domain ind:Rule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tableRatingRangeMin rdf:type rdf:Property ;
    rdfs:label 'Table Rating Range Min' ;
    rdfs:comment 'Minimum table rating (A through P) for the impairment or risk factor. Table ratings represent mortality multipliers (e.g., Table B = 150% of standard mortality). Null if rule does not use table ratings.' ;
    rdfs:domain ind:Rule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:underwritingMethodApplicability rdf:type rdf:Property ;
    rdfs:label 'Underwriting Method Applicability' ;
    rdfs:comment 'Specifies the underwriting method(s) to which this rule applies: full underwriting (medical exams, APS), simplified issue (health questions only), guaranteed issue (no health questions), accelerated underwriting (automated data sources), or all methods.' ;
    rdfs:domain ind:Rule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialUwReviewId rdf:type rdf:Property ;
    rdfs:label 'Financial Uw Review Id' ;
    rdfs:comment 'Unique identifier for the financial underwriting review record.' ;
    rdfs:domain ind:LifeInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FinancialUwReview .

ind:appliedCoverageAmount rdf:type rdf:Property ;
    rdfs:label 'Applied Coverage Amount' ;
    rdfs:comment 'The total face amount of life insurance coverage requested by the applicant in the application.' ;
    rdfs:domain ind:FinancialUwReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvedCoverageAmount rdf:type rdf:Property ;
    rdfs:label 'Approved Coverage Amount' ;
    rdfs:comment 'The maximum face amount of coverage approved by financial underwriting, which may be less than the applied amount if reduced.' ;
    rdfs:domain ind:FinancialUwReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:businessOwnershipPercentage rdf:type rdf:Property ;
    rdfs:label 'Business Ownership Percentage' ;
    rdfs:comment 'Percentage of business ownership held by the applicant, relevant for key person and buy-sell insurance justification.' ;
    rdfs:domain ind:FinancialUwReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:businessValuationAmount rdf:type rdf:Property ;
    rdfs:label 'Business Valuation Amount' ;
    rdfs:comment 'Fair market value of the business entity for which business insurance is being purchased.' ;
    rdfs:domain ind:FinancialUwReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:existingInforceAmount rdf:type rdf:Property ;
    rdfs:label 'Existing Inforce Amount' ;
    rdfs:comment 'Total face amount of existing life insurance coverage currently in force on the applicant across all carriers.' ;
    rdfs:domain ind:FinancialUwReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:financialDecision rdf:type rdf:Property ;
    rdfs:label 'Financial Decision' ;
    rdfs:comment 'Final outcome of the financial underwriting review regarding coverage amount justification.' ;
    rdfs:domain ind:FinancialUwReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialReviewNotes rdf:type rdf:Property ;
    rdfs:label 'Financial Review Notes' ;
    rdfs:comment 'Detailed underwriter notes documenting the financial analysis, findings, concerns, and rationale for the financial underwriting decision.' ;
    rdfs:domain ind:FinancialUwReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialStatementReviewed rdf:type rdf:Property ;
    rdfs:label 'Financial Statement Reviewed' ;
    rdfs:comment 'Indicates whether formal financial statements (tax returns, balance sheets, income statements) were reviewed as part of the financial underwriting process.' ;
    rdfs:domain ind:FinancialUwReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:financialStatementType rdf:type rdf:Property ;
    rdfs:label 'Financial Statement Type' ;
    rdfs:comment 'Type of financial documentation reviewed during the underwriting process.' ;
    rdfs:domain ind:FinancialUwReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:humanLifeValue rdf:type rdf:Property ;
    rdfs:label 'Human Life Value' ;
    rdfs:comment 'Calculated economic value of the applicant\'s future earnings potential, typically using present value of future income streams.' ;
    rdfs:domain ind:FinancialUwReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:liquidAssets rdf:type rdf:Property ;
    rdfs:label 'Liquid Assets' ;
    rdfs:comment 'Value of applicant\'s liquid assets including cash, savings, money market accounts, and readily marketable securities.' ;
    rdfs:domain ind:FinancialUwReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overInsuranceIndicator rdf:type rdf:Property ;
    rdfs:label 'Over Insurance Indicator' ;
    rdfs:comment 'Flag indicating whether the requested coverage amount appears excessive relative to the applicant\'s financial situation and insurable interest.' ;
    rdfs:domain ind:FinancialUwReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reviewDurationDays rdf:type rdf:Property ;
    rdfs:label 'Review Duration Days' ;
    rdfs:comment 'Number of calendar days elapsed from review start to completion, used for cycle time analysis.' ;
    rdfs:domain ind:FinancialUwReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reviewNumber rdf:type rdf:Property ;
    rdfs:label 'Review Number' ;
    rdfs:comment 'Business identifier for the financial underwriting review, typically system-generated or manually assigned.' ;
    rdfs:domain ind:LifeInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stoliRedFlags rdf:type rdf:Property ;
    rdfs:label 'Stoli Red Flags' ;
    rdfs:comment 'Specific indicators or red flags identified that suggest potential STOLI activity, such as premium financing, third-party involvement, or unusual beneficiary arrangements.' ;
    rdfs:domain ind:FinancialUwReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stoliRiskIndicator rdf:type rdf:Property ;
    rdfs:label 'Stoli Risk Indicator' ;
    rdfs:comment 'Assessment of the risk that this application represents a STOLI or investor-originated life insurance scheme lacking legitimate insurable interest.' ;
    rdfs:domain ind:FinancialUwReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalCoverageAmount rdf:type rdf:Property ;
    rdfs:label 'Total Coverage Amount' ;
    rdfs:comment 'Sum of applied coverage amount and existing in-force amount, representing total insurance exposure.' ;
    rdfs:domain ind:FinancialUwReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalLiabilities rdf:type rdf:Property ;
    rdfs:label 'Total Liabilities' ;
    rdfs:comment 'Sum of all applicant\'s outstanding debts including mortgages, loans, credit card balances, and other obligations.' ;
    rdfs:domain ind:FinancialUwReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reinsurancePlacementId rdf:type rdf:Property ;
    rdfs:label 'Reinsurance Placement Id' ;
    rdfs:comment 'Unique identifier for the reinsurance placement record. Primary key for this entity.' ;
    rdfs:domain ind:ReinsurancePlacement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:automaticBindingConfirmationDate rdf:type rdf:Property ;
    rdfs:label 'Automatic Binding Confirmation Date' ;
    rdfs:comment 'Date the automatic treaty binding was confirmed for this placement. Null for facultative placements.' ;
    rdfs:domain ind:ReinsurancePlacement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:caseSummary rdf:type rdf:Property ;
    rdfs:label 'Case Summary' ;
    rdfs:comment 'Brief narrative summary of the underwriting case submitted to the facultative reinsurer, including key risk factors, medical findings, and financial underwriting highlights. Null for automatic placements.' ;
    rdfs:domain ind:ReinsurancePlacement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cedingRiskClassCode rdf:type rdf:Property ;
    rdfs:label 'Ceding Risk Class Code' ;
    rdfs:comment 'Risk class code assigned by the ceding company underwriter. Denormalized for reporting and comparison with reinsurer risk class.' ;
    rdfs:domain ind:ReinsurancePlacement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cessionAmount rdf:type rdf:Property ;
    rdfs:label 'Cession Amount' ;
    rdfs:comment 'Amount of NAR ceded to reinsurer(s). Calculated as NAR minus retention limit for risks exceeding retention. Zero if within retention.' ;
    rdfs:domain ind:ReinsurancePlacement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:facultativeAcceptanceDate rdf:type rdf:Property ;
    rdfs:label 'Facultative Acceptance Date' ;
    rdfs:comment 'Date the ceding company accepted the facultative reinsurer offer. Null for automatic placements or declined offers.' ;
    rdfs:domain ind:ReinsurancePlacement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:facultativeOfferExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Facultative Offer Expiration Date' ;
    rdfs:comment 'Date by which the facultative reinsurer offer must be accepted. Null for automatic placements or if no offer received.' ;
    rdfs:domain ind:ReinsurancePlacement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:facultativeOfferReceivedDate rdf:type rdf:Property ;
    rdfs:label 'Facultative Offer Received Date' ;
    rdfs:comment 'Date the reinsurer offer was received for facultative placement. Null for automatic placements or if no offer received.' ;
    rdfs:domain ind:ReinsurancePlacement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:facultativeSubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Facultative Submission Date' ;
    rdfs:comment 'Date the facultative reinsurance case was submitted to reinsurer(s). Null for automatic placements.' ;
    rdfs:domain ind:ReinsurancePlacement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:financialEvidenceTransmitted rdf:type rdf:Property ;
    rdfs:label 'Financial Evidence Transmitted' ;
    rdfs:comment 'Indicates whether financial underwriting evidence (tax returns, financial statements, net worth documentation) was transmitted to the facultative reinsurer. True if transmitted, false otherwise. Null for automatic placements.' ;
    rdfs:domain ind:ReinsurancePlacement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:insuredAge rdf:type rdf:Property ;
    rdfs:label 'Insured Age' ;
    rdfs:comment 'Age of the primary insured at the time of underwriting. Used to determine retention limits and reinsurance rates.' ;
    rdfs:domain ind:ReinsurancePlacement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:medicalEvidenceTransmitted rdf:type rdf:Property ;
    rdfs:label 'Medical Evidence Transmitted' ;
    rdfs:comment 'Indicates whether medical evidence (APS, paramedical exam, lab results) was transmitted to the facultative reinsurer. True if transmitted, false otherwise. Null for automatic placements.' ;
    rdfs:domain ind:ReinsurancePlacement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:placementEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Placement Effective Date' ;
    rdfs:comment 'Date the reinsurance coverage becomes effective. Typically aligns with policy issue date.' ;
    rdfs:domain ind:ReinsurancePlacement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:placementStatus rdf:type rdf:Property ;
    rdfs:label 'Placement Status' ;
    rdfs:comment 'Current workflow status of the reinsurance placement: pending (awaiting submission), submitted (sent to reinsurer), under_review (reinsurer evaluating), offered (reinsurer made offer), accepted (offer accepted), declined (reinsurer declined or offer rejected), bound (placement finalized), cancelled (placement withdrawn). [ENUM-REF-CANDIDATE: pending|submitted|under_review|offered|accepted|declined|bound|cancelled — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ReinsurancePlacement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:placementType rdf:type rdf:Property ;
    rdfs:label 'Placement Type' ;
    rdfs:comment 'Type of reinsurance placement: automatic (treaty-based, automatic binding), facultative (case-by-case submission), hybrid (partial automatic, partial facultative), declined (no reinsurer accepted), or not_required (within retention).' ;
    rdfs:domain ind:ReinsurancePlacement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reinsurerDecision rdf:type rdf:Property ;
    rdfs:label 'Reinsurer Decision' ;
    rdfs:comment 'Final decision rendered by the reinsurer: approved_standard (accepted at standard rates), approved_substandard (accepted with ratings/extras), declined (rejected), postponed (deferred pending additional information), counter_offer (alternative terms proposed).' ;
    rdfs:domain ind:ReinsurancePlacement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reinsurerExclusions rdf:type rdf:Property ;
    rdfs:label 'Reinsurer Exclusions' ;
    rdfs:comment 'Text description of any coverage exclusions imposed by the reinsurer (e.g., aviation exclusion, hazardous activity exclusion). Null if no exclusions.' ;
    rdfs:domain ind:ReinsurancePlacement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reinsurerFlatExtraDurationMonths rdf:type rdf:Property ;
    rdfs:label 'Reinsurer Flat Extra Duration Months' ;
    rdfs:comment 'Duration in months for which the reinsurer flat extra premium applies. Null if permanent or no flat extra.' ;
    rdfs:domain ind:ReinsurancePlacement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reinsurerFlatExtraPerThousand rdf:type rdf:Property ;
    rdfs:label 'Reinsurer Flat Extra Per Thousand' ;
    rdfs:comment 'Flat extra premium per thousand dollars of coverage charged by the reinsurer for substandard risks. Zero if no flat extra applied.' ;
    rdfs:domain ind:ReinsurancePlacement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reinsurerRiskClassCode rdf:type rdf:Property ;
    rdfs:label 'Reinsurer Risk Class Code' ;
    rdfs:comment 'Risk class code assigned by the reinsurer. May differ from ceding company risk class for facultative placements. Null for automatic placements where reinsurer accepts ceding company classification.' ;
    rdfs:domain ind:ReinsurancePlacement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reinsurerTableRating rdf:type rdf:Property ;
    rdfs:label 'Reinsurer Table Rating' ;
    rdfs:comment 'Table rating assigned by the reinsurer (e.g., Table B, Table D). Indicates substandard risk classification. Null if standard risk.' ;
    rdfs:domain ind:ReinsurancePlacement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evidenceReviewId rdf:type rdf:Property ;
    rdfs:label 'Evidence Review Id' ;
    rdfs:comment 'Foreign key linking to underwriting.evidence_review. Business justification: Exclusion riders are frequently recommended directly from evidence review findings (evidence_review.exclusion_rider_recommended = TRUE). Linking exclusion_rider.evidence_review_id → evidence_review pr' ;
    rdfs:domain ind:LifeInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EvidenceReview .

ind:underwritingDecisionId rdf:type rdf:Property ;
    rdfs:label 'Underwriting Decision Id' ;
    rdfs:comment 'Reference to the underwriting decision that resulted in this exclusion rider being required as a condition of approval.' ;
    rdfs:domain ind:LifeInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Decision .

ind:apsReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Aps Reference Number' ;
    rdfs:comment 'Reference number of the Attending Physician Statement (APS) or medical evidence that documented the condition or risk leading to this exclusion rider.' ;
    rdfs:domain ind:ExclusionRider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimsNotificationText rdf:type rdf:Property ;
    rdfs:label 'Claims Notification Text' ;
    rdfs:comment 'Standardized text to be displayed to claims examiners when a claim is filed on a policy with this exclusion rider, alerting them to verify the cause of death against the exclusion terms.' ;
    rdfs:domain ind:ExclusionRider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:excludedCauseOfDeath rdf:type rdf:Property ;
    rdfs:label 'Excluded Cause Of Death' ;
    rdfs:comment 'Specific cause of death or medical condition excluded from death benefit payment (e.g., \'death resulting from aviation activities\', \'death due to pre-existing heart condition\').' ;
    rdfs:domain ind:ExclusionRider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exclusionRiderCode rdf:type rdf:Property ;
    rdfs:label 'Exclusion Rider Code' ;
    rdfs:comment 'Standard code identifying the type of exclusion rider (e.g., AVN for aviation, WAR for war exclusion, DIS for specific disease exclusion).' ;
    rdfs:domain ind:ExclusionRider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exclusionRiderName rdf:type rdf:Property ;
    rdfs:label 'Exclusion Rider Name' ;
    rdfs:comment 'Standard name of the exclusion rider as filed with regulatory authorities and printed on the policy contract.' ;
    rdfs:domain ind:ExclusionRider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exclusionRiderStatus rdf:type rdf:Property ;
    rdfs:label 'Exclusion Rider Status' ;
    rdfs:comment 'Current status of this exclusion rider: active (currently in force on the policy), removed (removed following review or policy change), expired (reached expiration date), superseded (replaced by a different exclusion or policy change).' ;
    rdfs:domain ind:ExclusionRider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exclusionScope rdf:type rdf:Property ;
    rdfs:label 'Exclusion Scope' ;
    rdfs:comment 'Scope of the exclusion: death_benefit_only (excludes only death benefit for specified cause), all_benefits (excludes all policy benefits), specific_rider (excludes benefits under a specific rider such as Accidental Death Benefit (ADB) or waiver of premium).' ;
    rdfs:domain ind:ExclusionRider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exclusionType rdf:type rdf:Property ;
    rdfs:label 'Exclusion Type' ;
    rdfs:comment 'Category of exclusion: aviation (piloting, skydiving), avocation (hazardous hobbies), medical_condition (specific disease or condition), occupational_hazard (dangerous occupation), war_military (war, military service), geographic_region (travel to high-risk areas).' ;
    rdfs:domain ind:ExclusionRider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:medicalDirectorApprovalFlag rdf:type rdf:Property ;
    rdfs:label 'Medical Director Approval Flag' ;
    rdfs:comment 'Indicates whether this exclusion rider required and received approval from the company medical director. True if medical director approval was obtained.' ;
    rdfs:domain ind:ExclusionRider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:narImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Nar Impact Flag' ;
    rdfs:comment 'Indicates whether this exclusion rider affects the Net Amount at Risk (NAR) calculation for reinsurance cession and Cost of Insurance (COI) rate determination. True if NAR calculation is impacted.' ;
    rdfs:domain ind:ExclusionRider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:permanenceIndicator rdf:type rdf:Property ;
    rdfs:label 'Permanence Indicator' ;
    rdfs:comment 'Indicates whether the exclusion is permanent for the life of the policy, reviewable after a specified period, or conditional based on future evidence or circumstances.' ;
    rdfs:domain ind:ExclusionRider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:premiumImpactAmount rdf:type rdf:Property ;
    rdfs:label 'Premium Impact Amount' ;
    rdfs:comment 'Dollar amount of premium reduction (if any) resulting from the application of this exclusion rider. Positive values indicate premium savings to the policyholder due to reduced coverage.' ;
    rdfs:domain ind:ExclusionRider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatoryFilingReference rdf:type rdf:Property ;
    rdfs:label 'Regulatory Filing Reference' ;
    rdfs:comment 'Reference number of the state insurance department filing that approved this exclusion rider form for use in the applicable jurisdiction.' ;
    rdfs:domain ind:ExclusionRider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reinsuranceAcceptanceStatus rdf:type rdf:Property ;
    rdfs:label 'Reinsurance Acceptance Status' ;
    rdfs:comment 'Status of reinsurer acceptance of this exclusion rider: not_applicable (no reinsurance notification required), pending (awaiting reinsurer response), accepted (reinsurer accepted exclusion), rejected (reinsurer rejected exclusion), modified (reinsurer proposed alternative terms).' ;
    rdfs:domain ind:ExclusionRider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reinsuranceNotificationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Reinsurance Notification Required Flag' ;
    rdfs:comment 'Indicates whether the reinsurer must be notified of this exclusion rider per the reinsurance treaty terms. True if notification is required.' ;
    rdfs:domain ind:ExclusionRider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:removalDate rdf:type rdf:Property ;
    rdfs:label 'Removal Date' ;
    rdfs:comment 'Date on which this exclusion rider was removed from the policy following a successful review or policy change. Null if the exclusion is still in force.' ;
    rdfs:domain ind:ExclusionRider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:removalReason rdf:type rdf:Property ;
    rdfs:label 'Removal Reason' ;
    rdfs:comment 'Reason for removal of this exclusion rider (e.g., \'improved health confirmed by updated APS\', \'cessation of excluded activity\', \'policy anniversary review\').' ;
    rdfs:domain ind:ExclusionRider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewCriteria rdf:type rdf:Property ;
    rdfs:label 'Review Criteria' ;
    rdfs:comment 'Specific criteria or evidence required for review of this exclusion (e.g., \'clean medical records for 5 years\', \'cessation of aviation activities\', \'updated Attending Physician Statement (APS)\').' ;
    rdfs:domain ind:ExclusionRider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Review Eligible Flag' ;
    rdfs:comment 'Indicates whether this exclusion rider is eligible for future review and potential removal based on improved health or changed circumstances. True if reviewable, False if permanent.' ;
    rdfs:domain ind:ExclusionRider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cashValueOption rdf:type rdf:Property ;
    rdfs:label 'Cash Value Option' ;
    rdfs:comment 'Boolean flag indicating whether this product plan includes a cash value accumulation component. True for permanent life insurance and annuities; false for term life and pure protection products.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contestabilityPeriodYears rdf:type rdf:Property ;
    rdfs:label 'Contestability Period Years' ;
    rdfs:comment 'The number of years from policy issue during which the insurer can contest claims based on material misrepresentation in the application. Typically 2 years per state regulation.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:distributionChannelAvailability rdf:type rdf:Property ;
    rdfs:label 'Distribution Channel Availability' ;
    rdfs:comment 'Comma-separated list of distribution channels through which this product plan can be sold (e.g., career_agent, independent_broker, bank_channel, direct_to_consumer, worksite). Used in agent authorization and commission calculation. [ENUM-REF-CANDIDATE: career_agent|independent_broker|bank_channel|direct_to_consumer|worksite|bga|mga — promote to reference product]' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:freeLookPeriodDays rdf:type rdf:Property ;
    rdfs:label 'Free Look Period Days' ;
    rdfs:comment 'The number of days after policy delivery during which the policyholder can cancel the policy for a full refund. Varies by state regulation, typically 10-30 days.' ;
    rdfs:domain ind:LifeInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:gptCorridorFactor rdf:type rdf:Property ;
    rdfs:label 'Gpt Corridor Factor' ;
    rdfs:comment 'The corridor factor used in the Guideline Premium Test calculation to ensure IRC 7702 compliance. Defines the minimum death benefit relative to cash value at each attained age.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:guaranteedIssue rdf:type rdf:Property ;
    rdfs:label 'Guaranteed Issue' ;
    rdfs:comment 'Boolean flag indicating whether this product plan is available on a guaranteed issue basis without medical underwriting. Used in underwriting workbench and new business processing.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:illustrationSoftwareCode rdf:type rdf:Property ;
    rdfs:label 'Illustration Software Code' ;
    rdfs:comment 'The code identifying the illustration software configuration used to generate policy illustrations for this product plan. Used in point-of-sale systems and agent tools.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceType rdf:type rdf:Property ;
    rdfs:label 'Insurance Type' ;
    rdfs:comment 'The specific insurance product type code. WL (Whole Life), UL (Universal Life), IUL (Indexed Universal Life), VUL (Variable Universal Life), YRT (Yearly Renewable Term), FIA (Fixed Indexed Annuity), SPIA (Single Premium Immediate Annuity), GMAB (Guaranteed Minimum Accumulation Benefit), GMDB (Guaranteed Minimum Death Benefit), GMIB (Guaranteed Minimum Income Benefit), GMWB (Guaranteed Minimum Withdrawal Benefit), DI (Disability Income). [ENUM-REF-CANDIDATE: WL|UL|IUL|VUL|YRT|FIA|SPIA|GMAB|GMDB|GMIB|GMWB|DI — 12 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:irc7702Compliant rdf:type rdf:Property ;
    rdfs:label 'Irc 7702 Compliant' ;
    rdfs:comment 'Boolean flag indicating whether the product plan is designed to comply with IRC Section 7702 life insurance tax qualification requirements including cash value accumulation test and guideline premium test.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:loanProvision rdf:type rdf:Property ;
    rdfs:label 'Loan Provision' ;
    rdfs:comment 'Boolean flag indicating whether policyholders can take loans against the cash value of this product plan. Used in policy servicing and customer service operations.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maximumPremiumAmount rdf:type rdf:Property ;
    rdfs:label 'Maximum Premium Amount' ;
    rdfs:comment 'The maximum premium amount allowed for this product plan without triggering MEC status or requiring special approval. Used in new business validation and IRC 7702 compliance testing.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumPremiumAmount rdf:type rdf:Property ;
    rdfs:label 'Minimum Premium Amount' ;
    rdfs:comment 'The minimum premium amount required for this product plan, typically expressed as annual premium equivalent. Used in new business validation and underwriting.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:naicProductTypeCode rdf:type rdf:Property ;
    rdfs:label 'Naic Product Type Code' ;
    rdfs:comment 'The three-digit NAIC product type code used for statutory reporting and regulatory filings. Required for Annual Statement Schedule T reporting.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:participatingProduct rdf:type rdf:Property ;
    rdfs:label 'Participating Product' ;
    rdfs:comment 'Boolean flag indicating whether this product plan is a participating policy eligible to receive dividends based on company experience. Used in actuarial valuation and policyholder communications.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:planCode rdf:type rdf:Property ;
    rdfs:label 'Plan Code' ;
    rdfs:comment 'The externally-known unique alphanumeric code identifying this product plan across all systems and distribution channels. Used in policy administration, underwriting, and billing systems.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planDescription rdf:type rdf:Property ;
    rdfs:label 'Plan Description' ;
    rdfs:comment 'Detailed description of the product plan including key features, benefits, and target market. Used for agent training and customer education materials.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planName rdf:type rdf:Property ;
    rdfs:label 'Plan Name' ;
    rdfs:comment 'The full marketing and legal name of the product plan as it appears in policy documents, illustrations, and customer communications.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:premiumModeOptions rdf:type rdf:Property ;
    rdfs:label 'Premium Mode Options' ;
    rdfs:comment 'Comma-separated list of premium payment frequency options available for this product plan (e.g., annual, semi_annual, quarterly, monthly, single). Used in billing system configuration. [ENUM-REF-CANDIDATE: annual|semi_annual|quarterly|monthly|single|flexible — promote to reference product]' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productFamily rdf:type rdf:Property ;
    rdfs:label 'Product Family' ;
    rdfs:comment 'The product family grouping used for portfolio management, profitability analysis, and strategic planning. Examples include term life family, universal life family, fixed annuity family.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profitabilityTargetIrr rdf:type rdf:Property ;
    rdfs:label 'Profitability Target Irr' ;
    rdfs:comment 'The target internal rate of return for this product plan used in pricing and profitability analysis. Expressed as a decimal (e.g., 0.1200 for 12.00%). Business-confidential metric.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reinstatementPeriodMonths rdf:type rdf:Property ;
    rdfs:label 'Reinstatement Period Months' ;
    rdfs:comment 'The number of months after policy lapse during which the policyholder can reinstate the policy without new underwriting. Typically 3-5 years per state regulation.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reinsuranceTreatyCode rdf:type rdf:Property ;
    rdfs:label 'Reinsurance Treaty Code' ;
    rdfs:comment 'The code identifying the reinsurance treaty under which this product plan is ceded. Used in reinsurance management system for cession processing and bordereaux reporting.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retirementReason rdf:type rdf:Property ;
    rdfs:label 'Retirement Reason' ;
    rdfs:comment 'The business or regulatory reason for retiring this product plan. Used in product lifecycle management and strategic planning.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:simplifiedIssue rdf:type rdf:Property ;
    rdfs:label 'Simplified Issue' ;
    rdfs:comment 'Boolean flag indicating whether this product plan uses simplified underwriting with limited health questions and no medical exam. Used in underwriting workbench and new business processing.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:stateApprovalCount rdf:type rdf:Property ;
    rdfs:label 'State Approval Count' ;
    rdfs:comment 'The number of US states and territories in which this product plan has received regulatory approval for sale. Used in distribution planning and compliance monitoring.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:suicideExclusionPeriodYears rdf:type rdf:Property ;
    rdfs:label 'Suicide Exclusion Period Years' ;
    rdfs:comment 'The number of years from policy issue during which death by suicide results in limited or no death benefit payment. Typically 2 years per state regulation.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:surrenderChargeSchedule rdf:type rdf:Property ;
    rdfs:label 'Surrender Charge Schedule' ;
    rdfs:comment 'Reference to the surrender charge schedule identifier that defines the penalty structure for early policy termination. Used in policy servicing and cash surrender value calculations.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:underwritingClassEligibility rdf:type rdf:Property ;
    rdfs:label 'Underwriting Class Eligibility' ;
    rdfs:comment 'Comma-separated list of underwriting risk classes eligible for this product plan (e.g., preferred_plus, preferred, standard, substandard). Used in underwriting workbench and rate table selection. [ENUM-REF-CANDIDATE: preferred_plus|preferred|standard|substandard|table_rated|declined — promote to reference product]' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:replacementPlanVersionId rdf:type rdf:Property ;
    rdfs:label 'Replacement Plan Version Id' ;
    rdfs:comment 'Reference to the successor plan version that replaces this retired version. Supports product migration and agent guidance. Null if no direct replacement exists.' ;
    rdfs:domain ind:PlanVersion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PlanVersion .

ind:approvedByAuthority rdf:type rdf:Property ;
    rdfs:label 'Approved By Authority' ;
    rdfs:comment 'Name of the regulatory authority that approved this version (e.g., New York Department of Financial Services, California Department of Insurance). Supports multi-state product tracking.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closedBlockIndicator rdf:type rdf:Property ;
    rdfs:label 'Closed Block Indicator' ;
    rdfs:comment 'Flag indicating whether this plan version is part of a closed block for statutory accounting and reserve segregation. True when the version is closed to new business and subject to closed block reporting requirements.' ;
    rdfs:domain ind:PlanVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:closedBlockTransitionDate rdf:type rdf:Property ;
    rdfs:label 'Closed Block Transition Date' ;
    rdfs:comment 'Date when this plan version was formally designated as a closed block for statutory accounting purposes. Triggers specific reserve calculation and reporting requirements under SAP (Statutory Accounting Principles).' ;
    rdfs:domain ind:PlanVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:communicationPlanReference rdf:type rdf:Property ;
    rdfs:label 'Communication Plan Reference' ;
    rdfs:comment 'Identifier or description of the stakeholder communication strategy for this version change. Documents agent bulletins, policyholder notices, and internal training materials associated with the version transition.' ;
    rdfs:domain ind:PlanVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionChannelEligibility rdf:type rdf:Property ;
    rdfs:label 'Distribution Channel Eligibility' ;
    rdfs:comment 'Comma-separated list of authorized distribution channels for this plan version. Examples: career_agent, independent_broker, bank_channel, direct_to_consumer, worksite, brokerage_general_agency. Governs product availability across sales channels.' ;
    rdfs:domain ind:PlanVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedNbvPerPolicy rdf:type rdf:Property ;
    rdfs:label 'Expected Nbv Per Policy' ;
    rdfs:comment 'Projected new business value per policy for this plan version based on actuarial pricing assumptions. Represents the present value of future profits at issue. Confidential metric used for product portfolio management and sales incentive design.' ;
    rdfs:domain ind:PlanVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gptCompliant rdf:type rdf:Property ;
    rdfs:label 'Gpt Compliant' ;
    rdfs:comment 'Indicates whether this plan version satisfies the Guideline Premium Test under IRC Section 7702. One of two tests (GPT or Cash Value Accumulation Test) required for life insurance tax qualification.' ;
    rdfs:domain ind:PlanVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inforceContinuationPolicy rdf:type rdf:Property ;
    rdfs:label 'Inforce Continuation Policy' ;
    rdfs:comment 'Strategy for managing existing policies after version retirement. Full servicing maintains all policy features; limited servicing restricts certain transactions; closed block segregates reserves; reinsured transfers risk; sold indicates block sale to another carrier.' ;
    rdfs:domain ind:PlanVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastNewBusinessDate rdf:type rdf:Property ;
    rdfs:label 'Last New Business Date' ;
    rdfs:comment 'Final date on which new policies may be issued under this plan version. Critical for product retirement and closed-block management. Typically precedes or coincides with superseded date.' ;
    rdfs:domain ind:PlanVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mecRiskIndicator rdf:type rdf:Property ;
    rdfs:label 'Mec Risk Indicator' ;
    rdfs:comment 'Flag indicating whether this plan version design carries elevated risk of MEC classification under the 7-pay test. True when premium structure or cash value accumulation patterns approach MEC thresholds.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pbrApplicable rdf:type rdf:Property ;
    rdfs:label 'Pbr Applicable' ;
    rdfs:comment 'Indicates whether this plan version is subject to Principle-Based Reserving under VM-20 (Valuation Manual Section 20). Determines reserve calculation methodology and actuarial opinion requirements.' ;
    rdfs:domain ind:PlanVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rateTableReference rdf:type rdf:Property ;
    rdfs:label 'Rate Table Reference' ;
    rdfs:comment 'Identifier or name of the premium rate table set associated with this plan version. Links to actuarial rate tables for premium calculation, cost of insurance charges, and benefit pricing.' ;
    rdfs:domain ind:PlanVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retirementAnnouncementDate rdf:type rdf:Property ;
    rdfs:label 'Retirement Announcement Date' ;
    rdfs:comment 'Date when the company publicly announced the retirement of this plan version. Supports agent communication and customer notification timelines. Null for non-retired versions.' ;
    rdfs:domain ind:PlanVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:riderEligibility rdf:type rdf:Property ;
    rdfs:label 'Rider Eligibility' ;
    rdfs:comment 'Comma-separated list of rider codes or names that may be attached to policies issued under this plan version. Examples: ADB (Accidental Death Benefit), WP (Waiver of Premium), GMDB (Guaranteed Minimum Death Benefit), LTC (Long-Term Care). Governs product configuration options.' ;
    rdfs:domain ind:PlanVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:underwritingClassStructure rdf:type rdf:Property ;
    rdfs:label 'Underwriting Class Structure' ;
    rdfs:comment 'Description of the risk classification framework for this plan version. Documents available underwriting classes such as Preferred Plus, Preferred, Standard Plus, Standard, Rated, and any substandard table ratings. Supports rate table selection and pricing.' ;
    rdfs:domain ind:PlanVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:versionDescription rdf:type rdf:Property ;
    rdfs:label 'Version Description' ;
    rdfs:comment 'Narrative summary of this plan version including key features, target market, competitive positioning, and material changes from prior versions. Supports product training and agent sales materials.' ;
    rdfs:domain ind:PlanVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:benefitCeilingValue rdf:type rdf:Property ;
    rdfs:label 'Benefit Ceiling Value' ;
    rdfs:comment 'Maximum benefit amount payable under this benefit structure, regardless of performance or other factors. Null if no ceiling applies.' ;
    rdfs:domain ind:BenefitStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:benefitFloorValue rdf:type rdf:Property ;
    rdfs:label 'Benefit Floor Value' ;
    rdfs:comment 'Minimum benefit amount guaranteed under this benefit structure, regardless of performance or other factors. Null if no floor applies.' ;
    rdfs:domain ind:BenefitStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:benefitFormulaParameters rdf:type rdf:Property ;
    rdfs:label 'Benefit Formula Parameters' ;
    rdfs:comment 'Structured representation of the mathematical formula and parameters used to calculate benefit amounts, including variables, coefficients, and calculation rules.' ;
    rdfs:domain ind:BenefitStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:benefitStructureCode rdf:type rdf:Property ;
    rdfs:label 'Benefit Structure Code' ;
    rdfs:comment 'Business-assigned unique code identifying this benefit structure configuration across systems and distribution channels.' ;
    rdfs:domain ind:BenefitStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:benefitStructureDescription rdf:type rdf:Property ;
    rdfs:label 'Benefit Structure Description' ;
    rdfs:comment 'Detailed description of the benefit structure configuration, including key features, limitations, and business purpose.' ;
    rdfs:domain ind:BenefitStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:benefitStructureName rdf:type rdf:Property ;
    rdfs:label 'Benefit Structure Name' ;
    rdfs:comment 'Human-readable name of the benefit structure configuration for business user identification and reporting.' ;
    rdfs:domain ind:BenefitStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:benefitStructureStatus rdf:type rdf:Property ;
    rdfs:label 'Benefit Structure Status' ;
    rdfs:comment 'Current lifecycle status of the benefit structure configuration: active (available for sale), inactive (temporarily unavailable), pending approval (awaiting regulatory approval), or retired (permanently discontinued).' ;
    rdfs:domain ind:BenefitStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cashValueAccumulationMethod rdf:type rdf:Property ;
    rdfs:label 'Cash Value Accumulation Method' ;
    rdfs:comment 'For permanent life products: method by which cash value accumulates — fixed interest (WL), indexed crediting (IUL), variable investment (VUL), or not applicable for term/annuity/DI products.' ;
    rdfs:domain ind:BenefitStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coiStructure rdf:type rdf:Property ;
    rdfs:label 'Coi Structure' ;
    rdfs:comment 'For UL/IUL/VUL products: structure of cost of insurance charges — level (fixed), increasing (rises over time), attained age (based on current age), or not applicable for term/WL/annuity/DI products.' ;
    rdfs:domain ind:BenefitStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:csvCalculationBasis rdf:type rdf:Property ;
    rdfs:label 'Csv Calculation Basis' ;
    rdfs:comment 'For permanent life products: formula or methodology used to calculate cash surrender value, including surrender charge schedules and interest crediting rules.' ;
    rdfs:domain ind:BenefitStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:diBenefitOffsetRules rdf:type rdf:Property ;
    rdfs:label 'Di Benefit Offset Rules' ;
    rdfs:comment 'For DI products: description of rules governing how other income sources (Social Security, workers compensation, other group disability) offset or reduce the DI benefit payable.' ;
    rdfs:domain ind:BenefitStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:diBenefitPeriod rdf:type rdf:Property ;
    rdfs:label 'Di Benefit Period' ;
    rdfs:comment 'For DI products: maximum duration for which disability benefits are payable — 2-year, 5-year, to age 65, to age 67, lifetime, or not applicable for life/annuity products.' ;
    rdfs:domain ind:BenefitStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:diColaAvailable rdf:type rdf:Property ;
    rdfs:label 'Di Cola Available' ;
    rdfs:comment 'For DI products: indicates whether cost of living adjustment (COLA) rider is available to increase benefits during claim period.' ;
    rdfs:domain ind:BenefitStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:diColaRatePercent rdf:type rdf:Property ;
    rdfs:label 'Di Cola Rate Percent' ;
    rdfs:comment 'For DI products with COLA: annual percentage rate at which benefits increase during claim period (e.g., 3.00 for 3% annual increase). Null if COLA not available.' ;
    rdfs:domain ind:BenefitStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:diDisabilityDefinition rdf:type rdf:Property ;
    rdfs:label 'Di Disability Definition' ;
    rdfs:comment 'For DI products: definition of disability used to determine benefit eligibility — own occupation, any occupation, modified own occupation, or not applicable for life/annuity products.' ;
    rdfs:domain ind:BenefitStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:diEliminationPeriodDays rdf:type rdf:Property ;
    rdfs:label 'Di Elimination Period Days' ;
    rdfs:comment 'For DI products: number of days the insured must be disabled before benefits begin (common values: 30, 60, 90, 180, 365 days). Null for life/annuity products.' ;
    rdfs:domain ind:BenefitStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:diMonthlyBenefitMaximum rdf:type rdf:Property ;
    rdfs:label 'Di Monthly Benefit Maximum' ;
    rdfs:comment 'For DI products: maximum monthly benefit amount payable under this benefit structure. Null for life/annuity products.' ;
    rdfs:domain ind:BenefitStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:diPartialDisabilityAvailable rdf:type rdf:Property ;
    rdfs:label 'Di Partial Disability Available' ;
    rdfs:comment 'For DI products: indicates whether partial disability benefit provision is included in this benefit structure.' ;
    rdfs:domain ind:BenefitStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:diResidualDisabilityAvailable rdf:type rdf:Property ;
    rdfs:label 'Di Residual Disability Available' ;
    rdfs:comment 'For DI products: indicates whether residual disability benefit provision is included in this benefit structure.' ;
    rdfs:domain ind:BenefitStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:diReturnToWorkIncentive rdf:type rdf:Property ;
    rdfs:label 'Di Return To Work Incentive' ;
    rdfs:comment 'For DI products: indicates whether return-to-work incentive provisions are included to encourage rehabilitation and return to employment.' ;
    rdfs:domain ind:BenefitStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:diSocialInsuranceSubstitute rdf:type rdf:Property ;
    rdfs:label 'Di Social Insurance Substitute' ;
    rdfs:comment 'For DI products: indicates whether social insurance substitute benefit is included to provide additional income if Social Security disability benefits are denied.' ;
    rdfs:domain ind:BenefitStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dividendOption rdf:type rdf:Property ;
    rdfs:label 'Dividend Option' ;
    rdfs:comment 'For participating whole life products: policyholder election for dividend treatment — cash, reduce premium, paid-up additions, accumulate at interest, one-year term insurance, or not applicable for non-participating products.' ;
    rdfs:domain ind:BenefitStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gmabAvailable rdf:type rdf:Property ;
    rdfs:label 'Gmab Available' ;
    rdfs:comment 'For annuity products: indicates whether guaranteed minimum accumulation benefit (GMAB) rider is available.' ;
    rdfs:domain ind:BenefitStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gmdbType rdf:type rdf:Property ;
    rdfs:label 'Gmdb Type' ;
    rdfs:comment 'For annuity products: type of guaranteed minimum death benefit — return of premium, highest anniversary value, earnings protection, or not applicable for life/DI products.' ;
    rdfs:domain ind:BenefitStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gmibAvailable rdf:type rdf:Property ;
    rdfs:label 'Gmib Available' ;
    rdfs:comment 'For annuity products: indicates whether guaranteed minimum income benefit (GMIB) rider is available.' ;
    rdfs:domain ind:BenefitStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gmwbAvailable rdf:type rdf:Property ;
    rdfs:label 'Gmwb Available' ;
    rdfs:comment 'For annuity products: indicates whether guaranteed minimum withdrawal benefit (GMWB) rider is available.' ;
    rdfs:domain ind:BenefitStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:irc7702TestType rdf:type rdf:Property ;
    rdfs:label 'Irc 7702 Test Type' ;
    rdfs:comment 'For life products: the IRC 7702 test method used for tax qualification — guideline premium test (GPT) or cash value accumulation test (CVAT). Not applicable for annuity/DI products.' ;
    rdfs:domain ind:BenefitStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ltcAccelerationAvailable rdf:type rdf:Property ;
    rdfs:label 'Ltc Acceleration Available' ;
    rdfs:comment 'For life and annuity products: indicates whether long-term care (LTC) benefit acceleration rider is available.' ;
    rdfs:domain ind:BenefitStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nonforfeitureOptionCashSurrender rdf:type rdf:Property ;
    rdfs:label 'Nonforfeiture Option Cash Surrender' ;
    rdfs:comment 'For permanent life products: indicates whether cash surrender value (CSV) nonforfeiture option is available if policy is surrendered.' ;
    rdfs:domain ind:BenefitStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nonforfeitureOptionExtendedTerm rdf:type rdf:Property ;
    rdfs:label 'Nonforfeiture Option Extended Term' ;
    rdfs:comment 'For permanent life products: indicates whether extended term insurance nonforfeiture option is available if policy lapses.' ;
    rdfs:domain ind:BenefitStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nonforfeitureOptionReducedPaidUp rdf:type rdf:Property ;
    rdfs:label 'Nonforfeiture Option Reduced Paid Up' ;
    rdfs:comment 'For permanent life products: indicates whether reduced paid-up insurance nonforfeiture option is available if policy lapses.' ;
    rdfs:domain ind:BenefitStructure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:acceleratedBenefitFlag rdf:type rdf:Property ;
    rdfs:label 'Accelerated Benefit Flag' ;
    rdfs:comment 'Indicates whether this rider provides accelerated death benefit (ADB) that pays out a portion of the death benefit while the insured is living due to terminal illness, chronic illness, or critical illness.' ;
    rdfs:domain ind:RiderDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:commissionScheduleCode rdf:type rdf:Property ;
    rdfs:label 'Commission Schedule Code' ;
    rdfs:comment 'Code identifying the commission schedule applicable to this rider for agent compensation. Links to commission management system for first-year and renewal commission calculations.' ;
    rdfs:domain ind:RiderDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costOfInsuranceImpact rdf:type rdf:Property ;
    rdfs:label 'Cost Of Insurance Impact' ;
    rdfs:comment 'Describes how this rider affects the base policy Cost of Insurance charges. Additive adds to base COI. Multiplicative applies a factor to base COI. Separate COI indicates rider has independent COI charges. None indicates no COI impact (flat premium rider).' ;
    rdfs:domain ind:RiderDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:illustrationRequired rdf:type rdf:Property ;
    rdfs:label 'Illustration Required' ;
    rdfs:comment 'Indicates whether this rider must be included in policy illustrations provided to customers at point of sale. Driven by NAIC illustration requirements and product complexity.' ;
    rdfs:domain ind:RiderDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ltcQualifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Ltc Qualified Flag' ;
    rdfs:comment 'Indicates whether this rider qualifies as a tax-qualified long-term care rider under IRC Section 7702B and HIPAA. Qualified LTC riders provide tax-advantaged benefits for ADL (Activities of Daily Living) impairment.' ;
    rdfs:domain ind:RiderDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maximumBenefitAmount rdf:type rdf:Property ;
    rdfs:label 'Maximum Benefit Amount' ;
    rdfs:comment 'Maximum dollar amount of benefit payable under this rider, if applicable. Null for riders with no maximum cap. Used for underwriting and risk assessment.' ;
    rdfs:domain ind:RiderDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mecImpact rdf:type rdf:Property ;
    rdfs:label 'Mec Impact' ;
    rdfs:comment 'Indicates whether adding this rider can cause the base policy to become a Modified Endowment Contract under IRC Section 7702A. None indicates no MEC impact. Potential indicates MEC testing required. Always indicates rider will trigger MEC status.' ;
    rdfs:domain ind:RiderDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:medicalEvidenceRequired rdf:type rdf:Property ;
    rdfs:label 'Medical Evidence Required' ;
    rdfs:comment 'Indicates whether medical evidence (APS - Attending Physician Statement, paramedical exam, lab tests) is required for rider issuance. Drives underwriting workflow and requirements.' ;
    rdfs:domain ind:RiderDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:minimumBenefitAmount rdf:type rdf:Property ;
    rdfs:label 'Minimum Benefit Amount' ;
    rdfs:comment 'Minimum dollar amount of benefit required for this rider to be issued. Used for underwriting and product eligibility validation.' ;
    rdfs:domain ind:RiderDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:predecessorRiderCode rdf:type rdf:Property ;
    rdfs:label 'Predecessor Rider Code' ;
    rdfs:comment 'Rider code of the previous version or predecessor rider that this rider replaces. Used for product genealogy tracking and policy conversion analysis. Null for new riders with no predecessor.' ;
    rdfs:domain ind:RiderDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:premiumBasis rdf:type rdf:Property ;
    rdfs:label 'Premium Basis' ;
    rdfs:comment 'Method by which rider premium is calculated. Per thousand charges premium per $1,000 of coverage. Flat rate charges a fixed dollar amount. Percentage of premium charges as a percentage of base policy premium. Percentage of benefit charges as a percentage of rider benefit amount. Included indicates no additional premium (rider is bundled).' ;
    rdfs:domain ind:RiderDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnOfPremiumFlag rdf:type rdf:Property ;
    rdfs:label 'Return Of Premium Flag' ;
    rdfs:comment 'Indicates whether this rider provides return of premium benefits, refunding premiums paid if the insured survives to a specified age or term end.' ;
    rdfs:domain ind:RiderDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:riderCategory rdf:type rdf:Property ;
    rdfs:label 'Rider Category' ;
    rdfs:comment 'Indicates whether the rider is optional (customer-elected), mandatory (required for certain product configurations), or automatic (included by default without additional premium).' ;
    rdfs:domain ind:RiderDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riderDefinitionDescription rdf:type rdf:Property ;
    rdfs:label 'Rider Definition Description' ;
    rdfs:comment 'Detailed business description of the rider benefits, coverage, and purpose. Used for agent training, customer communications, and product documentation.' ;
    rdfs:domain ind:RiderDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riderDefinitionStatus rdf:type rdf:Property ;
    rdfs:label 'Rider Definition Status' ;
    rdfs:comment 'Current lifecycle status of the rider definition. Active riders are available for new business. Discontinued riders remain for in-force policy servicing but are not available for new sales.' ;
    rdfs:domain ind:RiderDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riderExpiryAge rdf:type rdf:Property ;
    rdfs:label 'Rider Expiry Age' ;
    rdfs:comment 'Age at which rider coverage automatically terminates. Common for term riders and certain living benefit riders. Null for riders with no age-based expiry.' ;
    rdfs:domain ind:RiderDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:riderName rdf:type rdf:Property ;
    rdfs:label 'Rider Name' ;
    rdfs:comment 'Full business name of the rider as it appears on policy documents and customer communications.' ;
    rdfs:domain ind:RiderDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surrenderChargeApplicable rdf:type rdf:Property ;
    rdfs:label 'Surrender Charge Applicable' ;
    rdfs:comment 'Indicates whether surrender charges apply if the rider is terminated or the policy is surrendered. Relevant for riders with significant acquisition costs or DAC (Deferred Acquisition Cost).' ;
    rdfs:domain ind:RiderDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:underwritingClassRequired rdf:type rdf:Property ;
    rdfs:label 'Underwriting Class Required' ;
    rdfs:comment 'Indicates whether this rider requires underwriting classification (preferred, standard, substandard) or is issued on a guaranteed basis without medical underwriting.' ;
    rdfs:domain ind:RiderDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:predecessorRateTablePremiumRateTableId rdf:type rdf:Property ;
    rdfs:label 'Predecessor Rate Table Premium Rate Table Id' ;
    rdfs:comment 'Reference to the previous version of this rate table that this version supersedes, enabling rate table lineage tracking.' ;
    rdfs:domain ind:PremiumRateTable ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PremiumRateTable .

ind:attainedAgeMax rdf:type rdf:Property ;
    rdfs:label 'Attained Age Max' ;
    rdfs:comment 'Maximum attained age (in years) for which rates in this table apply, often the maturity age of the policy.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:attainedAgeMin rdf:type rdf:Property ;
    rdfs:label 'Attained Age Min' ;
    rdfs:comment 'Minimum attained age (in years) for which rates in this table apply, relevant for COI and mortality charge schedules.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:faceAmountBandMax rdf:type rdf:Property ;
    rdfs:label 'Face Amount Band Max' ;
    rdfs:comment 'Maximum face amount (death benefit) for which this rate table applies, defining the upper bound of the coverage band.' ;
    rdfs:domain ind:PremiumRateTable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:faceAmountBandMin rdf:type rdf:Property ;
    rdfs:label 'Face Amount Band Min' ;
    rdfs:comment 'Minimum face amount (death benefit) for which this rate table applies, defining the lower bound of the coverage band.' ;
    rdfs:domain ind:PremiumRateTable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:guaranteedFlag rdf:type rdf:Property ;
    rdfs:label 'Guaranteed Flag' ;
    rdfs:comment 'Indicates whether the rates in this table are contractually guaranteed and cannot be changed by the insurer.' ;
    rdfs:domain ind:PremiumRateTable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastUpdatedByUser rdf:type rdf:Property ;
    rdfs:label 'Last Updated By User' ;
    rdfs:comment 'User ID or name of the actuarial analyst or system user who last modified this rate table record.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mortalityTableBasis rdf:type rdf:Property ;
    rdfs:label 'Mortality Table Basis' ;
    rdfs:comment 'The underlying mortality table standard used as the basis for this rate table (e.g., 2001 CSO, 2017 CSO, 1983 GAM, Annuity 2000).' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateBasisDescription rdf:type rdf:Property ;
    rdfs:label 'Rate Basis Description' ;
    rdfs:comment 'Detailed description of the actuarial basis, assumptions, and methodology used to derive the rates in this table.' ;
    rdfs:domain ind:PremiumRateTable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Rate Effective Date' ;
    rdfs:comment 'Date from which this rate table becomes effective for new business and in-force policies as applicable.' ;
    rdfs:domain ind:PremiumRateTable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rateExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Rate Expiration Date' ;
    rdfs:comment 'Date on which this rate table is no longer effective for new business, nullable for tables with indefinite applicability.' ;
    rdfs:domain ind:PremiumRateTable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ratePerUnit rdf:type rdf:Property ;
    rdfs:label 'Rate Per Unit' ;
    rdfs:comment 'Premium rate per unit of coverage (e.g., per $1,000 of face amount for traditional life products).' ;
    rdfs:domain ind:PremiumRateTable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rateScheduleType rdf:type rdf:Property ;
    rdfs:label 'Rate Schedule Type' ;
    rdfs:comment 'Classification of the rate schedule indicating whether rates are guaranteed maximum, current, illustrative, or other contractual basis.' ;
    rdfs:domain ind:PremiumRateTable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateTableCode rdf:type rdf:Property ;
    rdfs:label 'Rate Table Code' ;
    rdfs:comment 'Unique business identifier for the rate table used in policy administration systems and actuarial systems (e.g., 2017CSO_NS_M_UL, COI_PREF_F_IUL).' ;
    rdfs:domain ind:PremiumRateTable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateTableName rdf:type rdf:Property ;
    rdfs:label 'Rate Table Name' ;
    rdfs:comment 'Human-readable descriptive name of the rate table (e.g., \'2017 CSO Non-Smoker Male Universal Life\', \'Preferred Female COI Schedule\').' ;
    rdfs:domain ind:PremiumRateTable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateTableNotes rdf:type rdf:Property ;
    rdfs:label 'Rate Table Notes' ;
    rdfs:comment 'Free-form notes or comments regarding special conditions, exceptions, or usage instructions for this rate table.' ;
    rdfs:domain ind:PremiumRateTable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateTableStatus rdf:type rdf:Property ;
    rdfs:label 'Rate Table Status' ;
    rdfs:comment 'Current lifecycle status of the rate table (Active, Inactive, Pending Approval, Superseded, Withdrawn).' ;
    rdfs:domain ind:PremiumRateTable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateVersionNumber rdf:type rdf:Property ;
    rdfs:label 'Rate Version Number' ;
    rdfs:comment 'Version number of this rate table, incremented when rates are revised or updated.' ;
    rdfs:domain ind:PremiumRateTable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:predecessorScheduleCoiRateScheduleId rdf:type rdf:Property ;
    rdfs:label 'Predecessor Schedule Coi Rate Schedule Id' ;
    rdfs:comment 'Reference to the previous version of this COI rate schedule, if this schedule is a revision or update. Null for initial versions.' ;
    rdfs:domain ind:CoiRateSchedule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CoiRateSchedule .

ind:actuarialNotes rdf:type rdf:Property ;
    rdfs:label 'Actuarial Notes' ;
    rdfs:comment 'Free-text field for actuarial comments, assumptions, or special considerations related to this COI rate schedule.' ;
    rdfs:domain ind:CoiRateSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:illustrationUsageFlag rdf:type rdf:Property ;
    rdfs:label 'Illustration Usage Flag' ;
    rdfs:comment 'Indicates whether this COI rate schedule is approved for use in policy illustrations shown to prospective buyers. True if approved for illustrations, false if for internal use only.' ;
    rdfs:domain ind:CoiRateSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isCurrentRate rdf:type rdf:Property ;
    rdfs:label 'Is Current Rate' ;
    rdfs:comment 'Indicates whether this schedule represents the current COI rates being charged to policyholders. True for current rate schedules, false for guaranteed or historical rates.' ;
    rdfs:domain ind:CoiRateSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isGuaranteedMaximum rdf:type rdf:Property ;
    rdfs:label 'Is Guaranteed Maximum' ;
    rdfs:comment 'Indicates whether this schedule represents the guaranteed maximum COI rates contractually promised in the policy. True for guaranteed maximum schedules, false for current or other rate types.' ;
    rdfs:domain ind:CoiRateSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:profitabilityTier rdf:type rdf:Property ;
    rdfs:label 'Profitability Tier' ;
    rdfs:comment 'Classification of the expected profitability of policies using this COI rate schedule, used for product management and pricing strategy.' ;
    rdfs:domain ind:CoiRateSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateAdjustmentFactor rdf:type rdf:Property ;
    rdfs:label 'Rate Adjustment Factor' ;
    rdfs:comment 'A multiplier applied to base mortality rates to derive the final COI rates in this schedule. Used for substandard risk classes or experience-based adjustments.' ;
    rdfs:domain ind:CoiRateSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rateGuaranteePeriodYears rdf:type rdf:Property ;
    rdfs:label 'Rate Guarantee Period Years' ;
    rdfs:comment 'The number of years for which the COI rates in this schedule are guaranteed not to increase, if applicable. Null indicates no guarantee period.' ;
    rdfs:domain ind:CoiRateSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ratePerThousandNar rdf:type rdf:Property ;
    rdfs:label 'Rate Per Thousand Nar' ;
    rdfs:comment 'The monthly COI rate expressed per $1,000 of net amount at risk. This is the core pricing element used in policy administration to calculate monthly COI charges.' ;
    rdfs:domain ind:CoiRateSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:retirementDate rdf:type rdf:Property ;
    rdfs:label 'Retirement Date' ;
    rdfs:comment 'The date on which this COI rate schedule was retired from active use and is no longer available for new policies. Null indicates the schedule is still active.' ;
    rdfs:domain ind:CoiRateSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:stateApprovalJurisdiction rdf:type rdf:Property ;
    rdfs:label 'State Approval Jurisdiction' ;
    rdfs:comment 'Two-letter state code indicating the insurance department jurisdiction that approved this COI rate schedule for use.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stateFilingNumber rdf:type rdf:Property ;
    rdfs:label 'State Filing Number' ;
    rdfs:comment 'The official filing number assigned by the state insurance department for this COI rate schedule approval.' ;
    rdfs:domain ind:CoiRateSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualProfitMargin rdf:type rdf:Property ;
    rdfs:label 'Actual Profit Margin' ;
    rdfs:comment 'Actual achieved profit margin percentage for in-force business in this underwriting class, based on most recent financial close. Compared against target margin to assess pricing adequacy and competitive position. Null if insufficient in-force experience. Confidential business metric.' ;
    rdfs:domain ind:UnderwritingClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ageBandMaximum rdf:type rdf:Property ;
    rdfs:label 'Age Band Maximum' ;
    rdfs:comment 'Maximum issue age (in years) for which this underwriting class is available. Null if no maximum restriction. Preferred classes often have lower maximum ages than standard classes due to underwriting complexity at advanced ages.' ;
    rdfs:domain ind:UnderwritingClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ageBandMinimum rdf:type rdf:Property ;
    rdfs:label 'Age Band Minimum' ;
    rdfs:comment 'Minimum issue age (in years) for which this underwriting class is available. Null if no minimum restriction. Used to enforce product design rules and underwriting guidelines during new business processing.' ;
    rdfs:domain ind:UnderwritingClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approvedStatesList rdf:type rdf:Property ;
    rdfs:label 'Approved States List' ;
    rdfs:comment 'Comma-separated list of two-letter state codes where this underwriting class is approved for use (e.g., CA,NY,TX,FL). Maintained for quick jurisdiction eligibility checks during new business processing and agent quoting.' ;
    rdfs:domain ind:UnderwritingClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cashValueAccumulationTestFactor rdf:type rdf:Property ;
    rdfs:label 'Cash Value Accumulation Test Factor' ;
    rdfs:comment 'Actuarial factor used in IRC Section 7702 Cash Value Accumulation Test for this underwriting class. Alternative to GPT for determining tax qualification. Used primarily for traditional whole life and universal life products.' ;
    rdfs:domain ind:UnderwritingClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:classCategory rdf:type rdf:Property ;
    rdfs:label 'Class Category' ;
    rdfs:comment 'High-level risk category grouping for the underwriting class. Preferred classes represent lowest mortality risk, standard represents average risk, substandard represents elevated risk requiring table ratings, and declined represents uninsurable risk.' ;
    rdfs:domain ind:UnderwritingClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:classCode rdf:type rdf:Property ;
    rdfs:label 'Class Code' ;
    rdfs:comment 'Short alphanumeric code representing the underwriting class (e.g., PPNT, PNT, SPNT, SNT, PT, ST, TBL-A through TBL-P). Used as the business identifier across policy administration, underwriting, and reinsurance systems.' ;
    rdfs:domain ind:UnderwritingClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:className rdf:type rdf:Property ;
    rdfs:label 'Class Name' ;
    rdfs:comment 'Full descriptive name of the underwriting class (e.g., Preferred Plus Non-Tobacco, Standard Tobacco, Table D). Human-readable label used in policy documents, illustrations, and agent-facing systems.' ;
    rdfs:domain ind:UnderwritingClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eligibilityCriteriaSummary rdf:type rdf:Property ;
    rdfs:label 'Eligibility Criteria Summary' ;
    rdfs:comment 'High-level summary of the health, lifestyle, and risk criteria required to qualify for this underwriting class (e.g., excellent health, no tobacco use, normal BMI, no adverse family history, no hazardous occupations). Detailed criteria maintained in underwriting rules engine; this field provides business-user-facing overview.' ;
    rdfs:domain ind:UnderwritingClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:experienceStudyMortalityRatio rdf:type rdf:Property ;
    rdfs:label 'Experience Study Mortality Ratio' ;
    rdfs:comment 'Most recent actual-to-expected mortality ratio from company experience studies for policies in this underwriting class. Ratio less than 1.0 indicates better-than-expected mortality; greater than 1.0 indicates worse. Used for pricing reviews and reserve adequacy testing. Null if insufficient experience data.' ;
    rdfs:domain ind:UnderwritingClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:faceAmountMaximum rdf:type rdf:Property ;
    rdfs:label 'Face Amount Maximum' ;
    rdfs:comment 'Maximum death benefit face amount allowed for this underwriting class under automatic underwriting or treaty reinsurance. Amounts above this threshold may require facultative reinsurance or senior underwriter approval. Null if no maximum.' ;
    rdfs:domain ind:UnderwritingClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:faceAmountMinimum rdf:type rdf:Property ;
    rdfs:label 'Face Amount Minimum' ;
    rdfs:comment 'Minimum death benefit face amount required to qualify for this underwriting class. Expressed in policy currency (typically USD). Preferred classes often require higher minimums to justify underwriting expense. Null if no minimum.' ;
    rdfs:domain ind:UnderwritingClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:genderSpecificFlag rdf:type rdf:Property ;
    rdfs:label 'Gender Specific Flag' ;
    rdfs:comment 'Indicates whether this underwriting class has gender-specific mortality assumptions and premium rates. True if separate male/female rates apply; False if unisex or gender-neutral. Some states mandate unisex rating; this flag supports compliance.' ;
    rdfs:domain ind:UnderwritingClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:guidelinePremiumTestFactor rdf:type rdf:Property ;
    rdfs:label 'Guideline Premium Test Factor' ;
    rdfs:comment 'Actuarial factor used in IRC Section 7702 Guideline Premium Test calculations for this underwriting class. Derived from mortality assumptions and interest rates. Used to determine maximum premium corridor and prevent Modified Endowment Contract (MEC) violations.' ;
    rdfs:domain ind:UnderwritingClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inforcePolicyCount rdf:type rdf:Property ;
    rdfs:label 'Inforce Policy Count' ;
    rdfs:comment 'Current number of active policies in this underwriting class as of most recent valuation date. Used for experience credibility assessment, reserve calculations, and portfolio risk management. Confidential business metric.' ;
    rdfs:domain ind:UnderwritingClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastExperienceStudyDate rdf:type rdf:Property ;
    rdfs:label 'Last Experience Study Date' ;
    rdfs:comment 'Date of the most recent actuarial experience study that included mortality analysis for this underwriting class. Experience studies typically performed annually or biennially. Used to assess data recency for pricing and reserving decisions.' ;
    rdfs:domain ind:UnderwritingClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mortalityLoadingFactor rdf:type rdf:Property ;
    rdfs:label 'Mortality Loading Factor' ;
    rdfs:comment 'Multiplicative factor applied to base mortality rates for this underwriting class. Preferred classes have factors less than 1.0 (e.g., 0.75), standard classes typically 1.0, substandard classes greater than 1.0 (e.g., Table A = 1.25, Table B = 1.50). Used in actuarial reserve calculations and COI determination.' ;
    rdfs:domain ind:UnderwritingClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:newBusinessVolumeLastYear rdf:type rdf:Property ;
    rdfs:label 'New Business Volume Last Year' ;
    rdfs:comment 'Number of new policies issued in this underwriting class during the most recent calendar year. Used to assess class popularity, distribution effectiveness, and underwriting capacity planning. Confidential business metric.' ;
    rdfs:domain ind:UnderwritingClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:premiumLoadingPercentage rdf:type rdf:Property ;
    rdfs:label 'Premium Loading Percentage' ;
    rdfs:comment 'Percentage adjustment applied to base premium rates for this underwriting class. Expressed as a percentage (e.g., -15.00 for preferred discount, +50.00 for Table B surcharge). Used in premium billing calculations and policy illustrations.' ;
    rdfs:domain ind:UnderwritingClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:principleBasedReservingCategory rdf:type rdf:Property ;
    rdfs:label 'Principle Based Reserving Category' ;
    rdfs:comment 'Risk category assignment for this underwriting class under NAIC Valuation Manual VM-20 Principle-Based Reserving framework. Determines stochastic modeling requirements, deterministic reserve floors, and capital requirements. High-risk classes require more extensive modeling.' ;
    rdfs:domain ind:UnderwritingClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profitabilityTargetMargin rdf:type rdf:Property ;
    rdfs:label 'Profitability Target Margin' ;
    rdfs:comment 'Target profit margin percentage for new business issued in this underwriting class, expressed as percentage of premium or present value of profits. Used in product pricing, performance monitoring, and strategic planning. Confidential business metric.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reinsuranceEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Reinsurance Eligible Flag' ;
    rdfs:comment 'Indicates whether policies issued in this underwriting class are eligible for automatic reinsurance cession under treaty terms. Some substandard classes or experimental classes may require facultative reinsurance or may be retained 100% by the ceding company.' ;
    rdfs:domain ind:UnderwritingClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reinsuranceRetentionLimit rdf:type rdf:Property ;
    rdfs:label 'Reinsurance Retention Limit' ;
    rdfs:comment 'Maximum Net Amount at Risk (NAR) the company will retain for policies in this underwriting class before ceding to reinsurers. Expressed in policy currency (typically USD). Null if class is not reinsurance-eligible or retention varies by treaty.' ;
    rdfs:domain ind:UnderwritingClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:supersededByClassCode rdf:type rdf:Property ;
    rdfs:label 'Superseded By Class Code' ;
    rdfs:comment 'Class code of the underwriting class that replaced this class, if status is superseded. Used to maintain historical lineage and support policy conversion or re-rating initiatives. Null if class is still active or was withdrawn without replacement.' ;
    rdfs:domain ind:UnderwritingClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:underwritingClassStatus rdf:type rdf:Property ;
    rdfs:label 'Underwriting Class Status' ;
    rdfs:comment 'Current lifecycle status of the underwriting class. Active classes are available for new business. Pending approval classes are filed but awaiting state approval. Inactive/withdrawn classes are no longer offered. Superseded classes have been replaced by a newer version.' ;
    rdfs:domain ind:UnderwritingClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalDocumentId rdf:type rdf:Property ;
    rdfs:label 'Approval Document Id' ;
    rdfs:comment 'Foreign key linking to document.document. Business justification: State approvals reference official approval letters, objection correspondence, and DOI examiner documents. Real business process: regulatory compliance verification and audit trail require linking app' ;
    rdfs:domain ind:StateApproval ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Document .

ind:filingId rdf:type rdf:Property ;
    rdfs:label 'Filing Id' ;
    rdfs:comment 'Foreign key linking to product.filing. Business justification: A state_approval is the outcome of a regulatory filing submitted to a state Department of Insurance. The state_approval table currently stores filing_reference_number as a STRING, which is a denormali' ;
    rdfs:domain ind:Product ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Filing .

ind:actuarialMemorandumReference rdf:type rdf:Property ;
    rdfs:label 'Actuarial Memorandum Reference' ;
    rdfs:comment 'Reference identifier for the actuarial memorandum supporting this filing, including rate justification, reserve adequacy, and compliance with state actuarial standards.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalConditions rdf:type rdf:Property ;
    rdfs:label 'Approval Conditions' ;
    rdfs:comment 'Any special conditions, requirements, or stipulations imposed by the state DOI as part of the approval. Must be satisfied for continued sale in the jurisdiction.' ;
    rdfs:domain ind:StateApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalNumber rdf:type rdf:Property ;
    rdfs:label 'Approval Number' ;
    rdfs:comment 'Official approval number or reference issued by the state DOI upon approval. Used for compliance documentation and audit trails.' ;
    rdfs:domain ind:StateApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionChannelRestrictions rdf:type rdf:Property ;
    rdfs:label 'Distribution Channel Restrictions' ;
    rdfs:comment 'State-specific restrictions on which distribution channels (career agents, brokers, banks, direct-to-consumer) are permitted to sell this product in this jurisdiction.' ;
    rdfs:domain ind:StateApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:doiExaminerCorrespondence rdf:type rdf:Property ;
    rdfs:label 'Doi Examiner Correspondence' ;
    rdfs:comment 'Reference to all correspondence exchanged with the state DOI examiner, including information requests, clarifications, and responses. Links to document management system.' ;
    rdfs:domain ind:StateApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filingType rdf:type rdf:Property ;
    rdfs:label 'Filing Type' ;
    rdfs:comment 'Classification of the regulatory filing indicating the nature of the submission: new product introduction, rate revision, form amendment, rider addition, benefit modification, or product withdrawal.' ;
    rdfs:domain ind:LifeInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:finraReviewRequired rdf:type rdf:Property ;
    rdfs:label 'Finra Review Required' ;
    rdfs:comment 'Indicates whether this product requires FINRA advertising and sales material review due to variable product features and broker-dealer distribution.' ;
    rdfs:domain ind:StateApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:illustrationActuaryCertificationRequired rdf:type rdf:Property ;
    rdfs:label 'Illustration Actuary Certification Required' ;
    rdfs:comment 'Indicates whether state regulations require actuarial certification of policy illustrations for this product. Applies to products with non-guaranteed elements.' ;
    rdfs:domain ind:StateApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:irc7702ComplianceConfirmed rdf:type rdf:Property ;
    rdfs:label 'Irc 7702 Compliance Confirmed' ;
    rdfs:comment 'Indicates whether the product design has been confirmed to meet IRC Section 7702 life insurance tax qualification requirements. Critical for tax-advantaged treatment.' ;
    rdfs:domain ind:StateApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nonforfeitureOptionsApproved rdf:type rdf:Property ;
    rdfs:label 'Nonforfeiture Options Approved' ;
    rdfs:comment 'State-approved nonforfeiture options available to policyholders upon lapse or surrender, including cash surrender value (CSV), reduced paid-up insurance, and extended term insurance.' ;
    rdfs:domain ind:StateApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:objectionHistory rdf:type rdf:Property ;
    rdfs:label 'Objection History' ;
    rdfs:comment 'Narrative log of all objections, questions, or concerns raised by the state DOI examiner during the review process, including dates and resolution status.' ;
    rdfs:domain ind:StateApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyLoanProvisionsApproved rdf:type rdf:Property ;
    rdfs:label 'Policy Loan Provisions Approved' ;
    rdfs:comment 'Indicates whether state-approved policy loan provisions are included in this product for this jurisdiction. True if policy loans are available per state requirements.' ;
    rdfs:domain ind:StateApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rateGuaranteePeriodMonths rdf:type rdf:Property ;
    rdfs:label 'Rate Guarantee Period Months' ;
    rdfs:comment 'Number of months for which premium rates are guaranteed as approved by the state. Applicable to term life and other products with rate guarantee provisions.' ;
    rdfs:domain ind:StateApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:replacementRegulationsApply rdf:type rdf:Property ;
    rdfs:label 'Replacement Regulations Apply' ;
    rdfs:comment 'Indicates whether state replacement regulations apply to this product, requiring specific disclosures and procedures when replacing existing coverage.' ;
    rdfs:domain ind:StateApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:secFilingReference rdf:type rdf:Property ;
    rdfs:label 'Sec Filing Reference' ;
    rdfs:comment 'SEC filing reference number for variable products requiring securities registration. Null for non-variable products not subject to SEC oversight.' ;
    rdfs:domain ind:StateApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:secFilingRequired rdf:type rdf:Property ;
    rdfs:label 'Sec Filing Required' ;
    rdfs:comment 'Indicates whether this product requires SEC registration and filing due to variable product features (VUL, variable annuities). True for variable products subject to securities regulation.' ;
    rdfs:domain ind:StateApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:stateSpecificExclusions rdf:type rdf:Property ;
    rdfs:label 'State Specific Exclusions' ;
    rdfs:comment 'State-mandated or state-specific policy exclusions, limitations, or restrictions that differ from the base product design. Critical for policy administration compliance.' ;
    rdfs:domain ind:StateApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stateSpecificRidersApproved rdf:type rdf:Property ;
    rdfs:label 'State Specific Riders Approved' ;
    rdfs:comment 'Comma-separated list of optional riders and benefits approved for attachment to this product in this state, including form numbers and effective dates.' ;
    rdfs:domain ind:StateApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submittedFormsList rdf:type rdf:Property ;
    rdfs:label 'Submitted Forms List' ;
    rdfs:comment 'Comma-separated list of all policy forms, riders, rate schedules, and amendments included in this filing submission. References document management system for full form text.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetStates rdf:type rdf:Property ;
    rdfs:label 'Target States' ;
    rdfs:comment 'Comma-separated list of all US state and territory codes where this filing was submitted. Used for multi-state filing coordination and tracking.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:underwritingClassRestrictions rdf:type rdf:Property ;
    rdfs:label 'Underwriting Class Restrictions' ;
    rdfs:comment 'State-specific restrictions or requirements on underwriting classes, rate bands, or risk classification methods approved for this product in this jurisdiction.' ;
    rdfs:domain ind:StateApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supersededByFilingId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Filing Id' ;
    rdfs:comment 'Reference to a subsequent filing that supersedes or replaces this filing, creating a version chain for product filing history.' ;
    rdfs:domain ind:Filing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Filing .

ind:actualReviewDurationDays rdf:type rdf:Property ;
    rdfs:label 'Actual Review Duration Days' ;
    rdfs:comment 'The actual number of calendar days from filing submission to final approval or rejection, used for process improvement and future estimation.' ;
    rdfs:domain ind:Filing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approvalCorrespondenceReference rdf:type rdf:Property ;
    rdfs:label 'Approval Correspondence Reference' ;
    rdfs:comment 'Document reference or identifier for the official approval letter or correspondence from the regulatory authority confirming the filing approval.' ;
    rdfs:domain ind:Filing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedReviewDurationDays rdf:type rdf:Property ;
    rdfs:label 'Estimated Review Duration Days' ;
    rdfs:comment 'The estimated number of calendar days for regulatory review based on state-specific timelines and filing complexity.' ;
    rdfs:domain ind:Filing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:irc7702ComplianceCertification rdf:type rdf:Property ;
    rdfs:label 'Irc 7702 Compliance Certification' ;
    rdfs:comment 'Indicates whether the filing includes certification that the product design complies with IRC Section 7702 life insurance tax qualification requirements (guideline premium test or cash value accumulation test).' ;
    rdfs:domain ind:Filing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:objectionDescription rdf:type rdf:Property ;
    rdfs:label 'Objection Description' ;
    rdfs:comment 'Detailed narrative of the regulatory objections, deficiencies, or concerns raised by the Department of Insurance or SEC regarding this filing.' ;
    rdfs:domain ind:Filing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:objectionIssuedDate rdf:type rdf:Property ;
    rdfs:label 'Objection Issued Date' ;
    rdfs:comment 'The date on which the regulatory authority issued an objection, deficiency letter, or request for additional information regarding this filing.' ;
    rdfs:domain ind:Filing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:objectionResponseDate rdf:type rdf:Property ;
    rdfs:label 'Objection Response Date' ;
    rdfs:comment 'The date on which the company submitted its formal response to regulatory objections or deficiency letters.' ;
    rdfs:domain ind:Filing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:priority rdf:type rdf:Property ;
    rdfs:label 'Priority' ;
    rdfs:comment 'Business priority assigned to this filing for internal tracking and resource allocation: expedited for time-sensitive launches, standard for routine filings, low for non-critical updates.' ;
    rdfs:domain ind:Filing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateFilingJustification rdf:type rdf:Property ;
    rdfs:label 'Rate Filing Justification' ;
    rdfs:comment 'Narrative explanation and business rationale for the proposed rates, including competitive positioning, experience data, and actuarial assumptions.' ;
    rdfs:domain ind:Filing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referenceNumber rdf:type rdf:Property ;
    rdfs:label 'Reference Number' ;
    rdfs:comment 'The externally-known unique reference number assigned to this regulatory filing by the company or filing system.' ;
    rdfs:domain ind:Filing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:secFileNumber rdf:type rdf:Property ;
    rdfs:label 'Sec File Number' ;
    rdfs:comment 'The SEC registration file number for variable products (e.g., 333-XXXXXX for Securities Act registration, 811-XXXXX for Investment Company Act registration).' ;
    rdfs:domain ind:Filing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:secRegistrationRequired rdf:type rdf:Property ;
    rdfs:label 'Sec Registration Required' ;
    rdfs:comment 'Indicates whether this product is a variable product requiring SEC registration and prospectus filing under the Securities Act of 1933 and Investment Company Act of 1940.' ;
    rdfs:domain ind:Filing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:withdrawalReason rdf:type rdf:Property ;
    rdfs:label 'Withdrawal Reason' ;
    rdfs:comment 'Business rationale for voluntarily withdrawing the filing, such as market conditions, strategic pivot, or inability to address regulatory concerns.' ;
    rdfs:domain ind:Filing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceDocumentId rdf:type rdf:Property ;
    rdfs:label 'Compliance Document Id' ;
    rdfs:comment 'Foreign key linking to document.document. Business justification: IRC 7702 compliance parameters are backed by authoritative IRS guidance documents, determination letters, and private letter rulings. Actuarial and compliance teams must trace each parameter set to it' ;
    rdfs:domain ind:Irc7702Parameter ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Document .

ind:actuarialCertificationFlag rdf:type rdf:Property ;
    rdfs:label 'Actuarial Certification Flag' ;
    rdfs:comment 'Indicates whether a qualified actuary has certified that these IRC 7702 parameters comply with IRS requirements and are actuarially sound. True indicates certification is on file. Actuarial certification is required for product filings and regulatory compliance.' ;
    rdfs:domain ind:Irc7702Parameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:catchUpContributionLimit rdf:type rdf:Property ;
    rdfs:label 'Catch Up Contribution Limit' ;
    rdfs:comment 'The additional annual contribution amount permitted for participants age 50 and older under IRC Section 414(v). For 2024, the catch-up limit is $7,500 for 401(k) plans and $1,000 for IRAs. Catch-up contributions allow older workers to accelerate retirement savings.' ;
    rdfs:domain ind:Irc7702Parameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:complianceReviewDate rdf:type rdf:Property ;
    rdfs:label 'Compliance Review Date' ;
    rdfs:comment 'The date the most recent compliance review of these IRC 7702 parameters was completed. Compliance reviews ensure parameters remain aligned with current IRS guidance and state regulations. Typically performed annually or when significant tax law changes occur.' ;
    rdfs:domain ind:Irc7702Parameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:complianceReviewerName rdf:type rdf:Property ;
    rdfs:label 'Compliance Reviewer Name' ;
    rdfs:comment 'Name of the compliance officer or actuary who performed the most recent review of these IRC 7702 parameters. Provides accountability and audit trail for compliance certification.' ;
    rdfs:domain ind:Irc7702Parameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contributionLimitAnnual rdf:type rdf:Property ;
    rdfs:label 'Contribution Limit Annual' ;
    rdfs:comment 'The maximum annual contribution amount permitted under IRC rules for this qualified plan type. For 2024, 401(k) elective deferrals are limited to $23,000, IRA contributions to $7,000, with catch-up contributions allowed for participants age 50+. Limits are indexed annually for inflation.' ;
    rdfs:domain ind:Irc7702Parameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:corridorPercentage rdf:type rdf:Property ;
    rdfs:label 'Corridor Percentage' ;
    rdfs:comment 'The minimum death benefit as a percentage of cash value required to maintain life insurance tax qualification under IRC 7702. The corridor percentage decreases as the insured\'s attained age increases. For example, at age 40 the corridor might be 250%, meaning death benefit must be at least 2.5 times cash value.' ;
    rdfs:domain ind:Irc7702Parameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costBasisRecoveryMethod rdf:type rdf:Property ;
    rdfs:label 'Cost Basis Recovery Method' ;
    rdfs:comment 'The method used to determine the taxable and non-taxable portions of distributions when the contract has both pre-tax and after-tax basis. Pro-rata method allocates each distribution proportionally between basis and earnings. FIFO (first-in, first-out) treats basis as distributed first. LIFO (last-in, first-out) treats earnings as distributed first. Specific identification allows the taxpayer to designate which dollars are distributed.' ;
    rdfs:domain ind:Irc7702Parameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defaultWithholdingRate rdf:type rdf:Property ;
    rdfs:label 'Default Withholding Rate' ;
    rdfs:comment 'The default federal income tax withholding rate applied to distributions if the payee does not make an election. For eligible rollover distributions from qualified plans, the mandatory rate is 20%. For periodic payments, the default is based on withholding tables. For non-periodic payments, the default is 10%.' ;
    rdfs:domain ind:Irc7702Parameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:definitionTestType rdf:type rdf:Property ;
    rdfs:label 'Definition Test Type' ;
    rdfs:comment 'The IRC 7702 test selected to qualify the product as life insurance for tax purposes. CVAT (Cash Value Accumulation Test) compares cash value to net single premium. GPT (Guideline Premium Test) limits premiums to guideline single premium and guideline level premium amounts. The insurer must elect one test at policy issue and cannot change it.' ;
    rdfs:domain ind:Irc7702Parameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:determinationLetterDate rdf:type rdf:Property ;
    rdfs:label 'Determination Letter Date' ;
    rdfs:comment 'The date the IRS issued a determination letter confirming the qualified status of the plan. Determination letters provide assurance that a plan\'s form (plan document) complies with IRC requirements. The IRS discontinued the determination letter program for individually designed plans in 2017 but continues it for pre-approved plans.' ;
    rdfs:domain ind:Irc7702Parameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:directRolloverOptionFlag rdf:type rdf:Property ;
    rdfs:label 'Direct Rollover Option Flag' ;
    rdfs:comment 'Indicates whether the plan offers a direct rollover option, allowing the participant to transfer an eligible rollover distribution directly to another qualified plan or IRA without taking constructive receipt. Direct rollovers avoid the mandatory 20% withholding that applies to indirect rollovers from qualified plans.' ;
    rdfs:domain ind:Irc7702Parameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:earlyWithdrawalPenaltyRate rdf:type rdf:Property ;
    rdfs:label 'Early Withdrawal Penalty Rate' ;
    rdfs:comment 'The IRS penalty rate applied to early distributions from qualified plans and IRAs. Generally 10% of the taxable amount for distributions before age 59½, unless an exception applies (disability, death, substantially equal periodic payments, first-time home purchase, qualified education expenses, etc.).' ;
    rdfs:domain ind:Irc7702Parameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:erisaApplicabilityFlag rdf:type rdf:Property ;
    rdfs:label 'Erisa Applicability Flag' ;
    rdfs:comment 'Indicates whether the Employee Retirement Income Security Act of 1974 applies to this product plan. True for employer-sponsored qualified plans (401(k), 403(b), defined benefit plans). False for individual IRAs, governmental plans, and church plans. ERISA imposes fiduciary standards, reporting requirements, and participant protections.' ;
    rdfs:domain ind:Irc7702Parameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ircSectionCode rdf:type rdf:Property ;
    rdfs:label 'Irc Section Code' ;
    rdfs:comment 'The applicable IRC section governing tax qualification for this product plan. IRC 7702 defines life insurance for tax purposes, 7702A covers MEC testing, 72 covers annuity taxation, 401/403/408 cover qualified plans and IRAs, and ERISA covers employee benefit plan requirements. [ENUM-REF-CANDIDATE: 7702|7702A|72|401|403|408|ERISA — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Irc7702Parameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:irsGuidanceReference rdf:type rdf:Property ;
    rdfs:label 'Irs Guidance Reference' ;
    rdfs:comment 'Citation to the specific IRS guidance, revenue ruling, revenue procedure, notice, or announcement that governs these tax parameters. Examples: Rev. Rul. 2009-13 (corridor percentages), Notice 2008-42 (7702 interest rates), Rev. Proc. 2021-20 (mortality tables). Provides traceability to authoritative IRS sources.' ;
    rdfs:domain ind:Irc7702Parameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastUpdatedDate rdf:type rdf:Property ;
    rdfs:label 'Last Updated Date' ;
    rdfs:comment 'The date these IRC 7702 parameter records were last updated in the system. Used for audit trail and change tracking. Updates may occur when IRS guidance changes, when errors are corrected, or when product filings are amended.' ;
    rdfs:domain ind:Irc7702Parameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:naicModelRegulationReference rdf:type rdf:Property ;
    rdfs:label 'Naic Model Regulation Reference' ;
    rdfs:comment 'Citation to the NAIC Model Regulation that governs the implementation of IRC 7702 requirements at the state level. The NAIC Standard Nonforfeiture Law and Model Variable Annuity Regulation incorporate IRC 7702 requirements. States adopt NAIC models with variations.' ;
    rdfs:domain ind:Irc7702Parameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parameterVersionNumber rdf:type rdf:Property ;
    rdfs:label 'Parameter Version Number' ;
    rdfs:comment 'Version number for this set of IRC 7702 parameters. Incremented each time parameters are updated. Supports historical tracking and ensures policies issued under prior versions retain their original parameters.' ;
    rdfs:domain ind:Irc7702Parameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:privateLetterRulingNumber rdf:type rdf:Property ;
    rdfs:label 'Private Letter Ruling Number' ;
    rdfs:comment 'The IRS Private Letter Ruling number, if the insurer obtained a ruling on the tax treatment of this product plan. PLRs provide written guidance from the IRS on the tax consequences of a specific transaction. Format is typically YYYYWWXXX (year, week, sequence). PLRs are binding only for the taxpayer who requested them but provide insight into IRS positions.' ;
    rdfs:domain ind:Irc7702Parameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualificationType rdf:type rdf:Property ;
    rdfs:label 'Qualification Type' ;
    rdfs:comment 'The tax qualification status of the product plan. Qualified products receive favorable tax treatment under IRC sections 401/403/408. Non-qualified products do not meet qualified plan requirements. Modified endowment contracts (MEC) are life insurance policies that fail the seven-pay test under IRC 7702A. Tax-deferred products allow earnings to accumulate without current taxation. Taxable products have no special tax treatment.' ;
    rdfs:domain ind:Irc7702Parameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rmdApplicabilityFlag rdf:type rdf:Property ;
    rdfs:label 'Rmd Applicability Flag' ;
    rdfs:comment 'Indicates whether Required Minimum Distributions under IRC Section 401(a)(9) apply to this product plan. True for qualified plans, traditional IRAs, and tax-deferred annuities. RMDs must begin by April 1 of the year following the year the participant reaches age 73 (as of 2023, per SECURE 2.0 Act). False for Roth IRAs and non-qualified products.' ;
    rdfs:domain ind:Irc7702Parameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rolloverEligibilityFlag rdf:type rdf:Property ;
    rdfs:label 'Rollover Eligibility Flag' ;
    rdfs:comment 'Indicates whether distributions from this product plan are eligible for tax-free rollover to another qualified plan or IRA under IRC Section 402(c). True for most qualified plan distributions and traditional IRA distributions. False for required minimum distributions, hardship withdrawals, substantially equal periodic payments, and certain other distributions.' ;
    rdfs:domain ind:Irc7702Parameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:stateVariationNotes rdf:type rdf:Property ;
    rdfs:label 'State Variation Notes' ;
    rdfs:comment 'Free-text notes describing any state-specific variations in the application of IRC 7702 parameters. While IRC 7702 is federal law, states may impose additional requirements or interpretations through insurance regulations. Documents any state-by-state differences in product filing requirements or tax treatment.' ;
    rdfs:domain ind:Irc7702Parameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tamraComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Tamra Compliance Flag' ;
    rdfs:comment 'Indicates whether the product plan complies with TAMRA 1988 requirements for MEC testing under IRC 7702A. TAMRA introduced the seven-pay test and material change rules. True indicates the product design and administration procedures meet TAMRA compliance standards.' ;
    rdfs:domain ind:Irc7702Parameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:taxDisclosureRequirement rdf:type rdf:Property ;
    rdfs:label 'Tax Disclosure Requirement' ;
    rdfs:comment 'Description of the tax disclosure obligations the insurer must provide to policyholders. Includes required notices about tax consequences of distributions, rollovers, MEC status, and withholding elections. Disclosures must be provided at policy issue, at distribution, and when material changes occur.' ;
    rdfs:domain ind:Irc7702Parameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxReportingCode rdf:type rdf:Property ;
    rdfs:label 'Tax Reporting Code' ;
    rdfs:comment 'The IRS form code used to report distributions, interest, or contributions for this product plan. 1099-R reports distributions from pensions, annuities, retirement plans, IRAs, and life insurance contracts. 1099-INT reports interest income. 1099-MISC reports miscellaneous income. 5498 reports IRA contributions. W-2 reports wages for employer-sponsored plans.' ;
    rdfs:domain ind:Irc7702Parameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:withholdingRequirementType rdf:type rdf:Property ;
    rdfs:label 'Withholding Requirement Type' ;
    rdfs:comment 'The type of federal income tax withholding required for distributions from this product plan. Mandatory withholding applies to eligible rollover distributions from qualified plans (20% default). Optional withholding allows the payee to elect withholding. Exempt distributions have no withholding requirement. Backup withholding (24%) applies when the payee fails to provide a valid TIN.' ;
    rdfs:domain ind:Irc7702Parameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationMaximumPct rdf:type rdf:Property ;
    rdfs:label 'Allocation Maximum Pct' ;
    rdfs:comment 'Maximum percentage of account value that can be allocated to this strategy, expressed as a decimal (e.g., 1.0000 for 100% maximum, or 0.5000 for 50% cap). Null if no maximum.' ;
    rdfs:domain ind:CreditingStrategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allocationMinimumPct rdf:type rdf:Property ;
    rdfs:label 'Allocation Minimum Pct' ;
    rdfs:comment 'Minimum percentage of account value that must be allocated to this strategy if selected, expressed as a decimal (e.g., 0.0500 for 5% minimum). Null if no minimum.' ;
    rdfs:domain ind:CreditingStrategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditingMethod rdf:type rdf:Property ;
    rdfs:label 'Crediting Method' ;
    rdfs:comment 'The calculation methodology used to determine interest credits: annual point-to-point (index change over 12 months), monthly average (average of monthly index values), monthly sum (sum of monthly changes), participation rate (percentage of index gain), or declared rate (fixed interest rate set by insurer).' ;
    rdfs:domain ind:CreditingStrategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:declaredRate rdf:type rdf:Property ;
    rdfs:label 'Declared Rate' ;
    rdfs:comment 'Fixed interest rate declared by the insurer for fixed account strategies, expressed as a decimal (e.g., 0.0325 for 3.25%). Null for indexed strategies.' ;
    rdfs:domain ind:CreditingStrategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:guaranteedMinimumRate rdf:type rdf:Property ;
    rdfs:label 'Guaranteed Minimum Rate' ;
    rdfs:comment 'Contractually guaranteed minimum interest rate over the life of the contract, expressed as a decimal (e.g., 0.0100 for 1.00% guaranteed minimum). Required by state insurance regulations.' ;
    rdfs:domain ind:CreditingStrategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hedgingCostBasis rdf:type rdf:Property ;
    rdfs:label 'Hedging Cost Basis' ;
    rdfs:comment 'Internal description of the derivative hedging strategy and cost structure used by the insurer to support this crediting strategy. Used for actuarial pricing and profitability analysis.' ;
    rdfs:domain ind:CreditingStrategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:historicalAverageCreditRate rdf:type rdf:Property ;
    rdfs:label 'Historical Average Credit Rate' ;
    rdfs:comment 'Average interest rate credited over the historical performance period of this strategy, expressed as a decimal. Used for performance reporting and disclosure. Null for newly launched strategies.' ;
    rdfs:domain ind:CreditingStrategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:illustrationRate rdf:type rdf:Property ;
    rdfs:label 'Illustration Rate' ;
    rdfs:comment 'Interest rate used for policy illustration and sales projection purposes, expressed as a decimal (e.g., 0.0500 for 5.00%). Must comply with NAIC illustration actuary guidelines.' ;
    rdfs:domain ind:CreditingStrategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:indexCalculationMethod rdf:type rdf:Property ;
    rdfs:label 'Index Calculation Method' ;
    rdfs:comment 'Detailed description of how the index value is calculated, including whether dividends are included, averaging methodology, and any adjustments applied (e.g., price return only, total return, equal-weighted).' ;
    rdfs:domain ind:CreditingStrategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:indexType rdf:type rdf:Property ;
    rdfs:label 'Index Type' ;
    rdfs:comment 'The market index or benchmark underlying the crediting strategy (e.g., S&P 500, Russell 2000, MSCI EAFE, Nasdaq 100, blended composite, or FIXED for non-indexed strategies). [ENUM-REF-CANDIDATE: SP500|RUSSELL2000|MSCI_EAFE|NASDAQ100|BLENDED|FIXED|CUSTOM — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CreditingStrategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:performanceLookbackStartDate rdf:type rdf:Property ;
    rdfs:label 'Performance Lookback Start Date' ;
    rdfs:comment 'Start date of the historical performance period used to calculate average credit rates and backtested results for disclosure purposes.' ;
    rdfs:domain ind:CreditingStrategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rateLockPeriodMonths rdf:type rdf:Property ;
    rdfs:label 'Rate Lock Period Months' ;
    rdfs:comment 'Number of months for which the current cap, participation, or spread rates are guaranteed before potential adjustment. Null if rates are guaranteed for contract life.' ;
    rdfs:domain ind:CreditingStrategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:renewalRateAdjustmentFlag rdf:type rdf:Property ;
    rdfs:label 'Renewal Rate Adjustment Flag' ;
    rdfs:comment 'Indicates whether cap, participation, or spread rates are subject to adjustment at renewal periods. True if rates may be adjusted, False if rates are guaranteed for the contract term.' ;
    rdfs:domain ind:CreditingStrategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:resetFrequency rdf:type rdf:Property ;
    rdfs:label 'Reset Frequency' ;
    rdfs:comment 'Frequency at which index values are measured and interest is credited: annual (12-month period), monthly (1-month period), biennial (24-month period), or custom.' ;
    rdfs:domain ind:CreditingStrategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strategyAvailabilityStatus rdf:type rdf:Property ;
    rdfs:label 'Strategy Availability Status' ;
    rdfs:comment 'Current availability status of the crediting strategy: active (available for new and existing allocations), suspended (existing allocations continue but no new allocations), closed (no longer available), pending_approval (awaiting regulatory approval).' ;
    rdfs:domain ind:CreditingStrategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strategyCode rdf:type rdf:Property ;
    rdfs:label 'Strategy Code' ;
    rdfs:comment 'Short alphanumeric code uniquely identifying the crediting strategy within the product line (e.g., SP500_PTP, RUS2K_MA, FIXED_DCA).' ;
    rdfs:domain ind:CreditingStrategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strategyDescription rdf:type rdf:Property ;
    rdfs:label 'Strategy Description' ;
    rdfs:comment 'Detailed business description of the crediting strategy, including how it works, risk/reward profile, and suitability considerations for policyholder education and disclosure.' ;
    rdfs:domain ind:CreditingStrategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strategyName rdf:type rdf:Property ;
    rdfs:label 'Strategy Name' ;
    rdfs:comment 'Full business name of the crediting strategy as presented to policyholders and agents (e.g., S&P 500 Annual Point-to-Point with Cap, Fixed Account Declared Rate).' ;
    rdfs:domain ind:CreditingStrategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strategyNotes rdf:type rdf:Property ;
    rdfs:label 'Strategy Notes' ;
    rdfs:comment 'Free-form text field for internal notes, special instructions, or additional context about this crediting strategy (e.g., pricing assumptions, competitive positioning, distribution channel restrictions).' ;
    rdfs:domain ind:CreditingStrategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strategyRankOrder rdf:type rdf:Property ;
    rdfs:label 'Strategy Rank Order' ;
    rdfs:comment 'Display order or ranking of this strategy in policyholder materials, agent tools, and online portals. Lower numbers appear first.' ;
    rdfs:domain ind:CreditingStrategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:strategyType rdf:type rdf:Property ;
    rdfs:label 'Strategy Type' ;
    rdfs:comment 'High-level classification of the crediting strategy: indexed (linked to market index), fixed (declared rate), or hybrid (combination).' ;
    rdfs:domain ind:CreditingStrategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetMarketSegment rdf:type rdf:Property ;
    rdfs:label 'Target Market Segment' ;
    rdfs:comment 'Description of the intended policyholder demographic or risk profile for whom this strategy is designed (e.g., conservative investors seeking downside protection, growth-oriented accumulators, income-focused retirees).' ;
    rdfs:domain ind:CreditingStrategy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:predecessorScheduleChargeScheduleId rdf:type rdf:Property ;
    rdfs:label 'Predecessor Schedule Charge Schedule Id' ;
    rdfs:comment 'Reference to the previous version of this charge schedule if this is a revision. NULL for the initial version. Enables lineage tracking and historical analysis.' ;
    rdfs:domain ind:ChargeSchedule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ChargeSchedule .

ind:chargeAmountFlat rdf:type rdf:Property ;
    rdfs:label 'Charge Amount Flat' ;
    rdfs:comment 'Fixed dollar amount of the charge when charge_basis is flat_dollar. Used for per-policy administrative fees or fixed withdrawal processing fees. NULL for percentage-based charges.' ;
    rdfs:domain ind:ChargeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:chargeCapAmount rdf:type rdf:Property ;
    rdfs:label 'Charge Cap Amount' ;
    rdfs:comment 'Maximum dollar amount that can be charged under this schedule, regardless of the calculated charge. Used to limit total charges on high-value policies. NULL if no cap applies.' ;
    rdfs:domain ind:ChargeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:chargeFloorAmount rdf:type rdf:Property ;
    rdfs:label 'Charge Floor Amount' ;
    rdfs:comment 'Minimum dollar amount that will be charged under this schedule, regardless of the calculated charge. Used to ensure minimum cost recovery. NULL if no floor applies.' ;
    rdfs:domain ind:ChargeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:chargeScheduleCode rdf:type rdf:Property ;
    rdfs:label 'Charge Schedule Code' ;
    rdfs:comment 'Unique business identifier for the charge schedule. Used in policy administration systems and illustrations to reference specific charge structures.' ;
    rdfs:domain ind:ChargeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chargeScheduleName rdf:type rdf:Property ;
    rdfs:label 'Charge Schedule Name' ;
    rdfs:comment 'Human-readable name of the charge schedule for business user identification and reporting purposes.' ;
    rdfs:domain ind:ChargeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chargeScheduleStatus rdf:type rdf:Property ;
    rdfs:label 'Charge Schedule Status' ;
    rdfs:comment 'Current lifecycle status of the charge schedule. Active schedules are in use for new business; pending approval schedules are awaiting regulatory approval; approved schedules are ready for use; inactive schedules are no longer offered; superseded schedules have been replaced by newer versions.' ;
    rdfs:domain ind:ChargeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chargeType rdf:type rdf:Property ;
    rdfs:label 'Charge Type' ;
    rdfs:comment 'Classification of the charge or fee. Surrender charges are back-end loads applied when policies are surrendered; premium loads are front-end charges on premium payments; admin fees are per-policy or per-unit charges; M&E charges are mortality and expense risk charges for variable products; fund management fees are investment management charges; withdrawal fees apply to partial withdrawals.' ;
    rdfs:domain ind:ChargeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competitivePositioning rdf:type rdf:Property ;
    rdfs:label 'Competitive Positioning' ;
    rdfs:comment 'Strategic market positioning of this charge schedule. Premium indicates higher charges with enhanced features; competitive indicates market-rate charges; value indicates lower charges for cost-conscious segments. Confidential business strategy.' ;
    rdfs:domain ind:ChargeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentChargeRate rdf:type rdf:Property ;
    rdfs:label 'Current Charge Rate' ;
    rdfs:comment 'The current charge rate being applied to in-force policies. Must be less than or equal to the guaranteed charge rate. For percentage-based charges, expressed as a decimal. For flat charges, expressed in dollars. This rate may be adjusted by the company within guaranteed limits.' ;
    rdfs:domain ind:ChargeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dacTaxTreatment rdf:type rdf:Property ;
    rdfs:label 'Dac Tax Treatment' ;
    rdfs:comment 'Tax treatment of this charge for Deferred Acquisition Cost purposes under IRC Section 848. Indicates whether the charge is capitalized and amortized, immediately expensed, or not subject to DAC tax rules.' ;
    rdfs:domain ind:ChargeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:freeWithdrawalPercentage rdf:type rdf:Property ;
    rdfs:label 'Free Withdrawal Percentage' ;
    rdfs:comment 'The percentage of account value (AV) or cash surrender value (CSV) that can be withdrawn annually without incurring surrender charges. Commonly 10% for annuities. Expressed as a decimal (e.g., 0.10 for 10%). NULL if no free withdrawal provision exists.' ;
    rdfs:domain ind:ChargeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gaapRevenueRecognition rdf:type rdf:Property ;
    rdfs:label 'Gaap Revenue Recognition' ;
    rdfs:comment 'GAAP revenue recognition method for this charge under FASB ASC 944 and LDTI (Long Duration Targeted Improvements). Indicates whether revenue is recognized immediately, deferred, or recognized over the coverage period.' ;
    rdfs:domain ind:ChargeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guaranteedChargeRate rdf:type rdf:Property ;
    rdfs:label 'Guaranteed Charge Rate' ;
    rdfs:comment 'The maximum charge rate guaranteed in the policy contract. This is the contractual ceiling that cannot be exceeded. For percentage-based charges, expressed as a decimal (e.g., 0.0125 for 1.25%). For flat charges, expressed in dollars.' ;
    rdfs:domain ind:ChargeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:illustrationDisclosureRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Illustration Disclosure Required Flag' ;
    rdfs:comment 'Indicates whether this charge must be explicitly disclosed in policy illustrations and sales materials. True if disclosure is required by regulation or company policy; False otherwise.' ;
    rdfs:domain ind:ChargeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mvaApplicableFlag rdf:type rdf:Property ;
    rdfs:label 'Mva Applicable Flag' ;
    rdfs:comment 'Indicates whether a Market Value Adjustment applies to surrenders or withdrawals under this charge schedule. MVA adjusts the surrender value based on interest rate movements. True if MVA applies; False otherwise.' ;
    rdfs:domain ind:LifeInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:statutoryAccountingTreatment rdf:type rdf:Property ;
    rdfs:label 'Statutory Accounting Treatment' ;
    rdfs:comment 'Statutory accounting treatment of this charge under NAIC Statutory Accounting Principles. Determines how the charge impacts statutory surplus and Risk-Based Capital (RBC) calculations.' ;
    rdfs:domain ind:ChargeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waiverCondition rdf:type rdf:Property ;
    rdfs:label 'Waiver Condition' ;
    rdfs:comment 'Condition under which surrender charges or other fees are waived. Common waivers include nursing home confinement, terminal illness diagnosis, total disability, death of the owner/annuitant, or unemployment. \'none\' indicates no waiver provisions.' ;
    rdfs:domain ind:ChargeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waiverWaitingPeriodDays rdf:type rdf:Property ;
    rdfs:label 'Waiver Waiting Period Days' ;
    rdfs:comment 'Number of days that must elapse after the waiver condition is met before the charge waiver takes effect. Common for nursing home or disability waivers (e.g., 90 days). NULL if no waiting period applies.' ;
    rdfs:domain ind:ChargeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryPredecessorFormId rdf:type rdf:Property ;
    rdfs:label 'Primary Predecessor Form Id' ;
    rdfs:comment 'Reference to the previous version of this form that this edition supersedes. Enables form version lineage tracking and historical policy servicing. Nullable for initial form versions.' ;
    rdfs:domain ind:Form ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Form .

ind:baseFormFlag rdf:type rdf:Property ;
    rdfs:label 'Base Form Flag' ;
    rdfs:comment 'Indicates whether this is a base policy form that serves as the primary contract document, as opposed to a rider, endorsement, or supplementary form.' ;
    rdfs:domain ind:Form ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:editionDate rdf:type rdf:Property ;
    rdfs:label 'Edition Date' ;
    rdfs:comment 'The official edition or version date of the form as printed on the document. This date identifies the specific version of the form and is critical for regulatory compliance and policy administration.' ;
    rdfs:domain ind:Form ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:formType rdf:type rdf:Property ;
    rdfs:label 'Form Type' ;
    rdfs:comment 'Classification of the form document type. Categorizes whether this is a base policy form, application form, rider form, amendment endorsement, disclosure form, or other contract document type.' ;
    rdfs:domain ind:Form ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:illustrationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Illustration Required Flag' ;
    rdfs:comment 'Indicates whether a policy illustration conforming to NAIC Life Insurance Illustrations Model Regulation must accompany this form during the sales process.' ;
    rdfs:domain ind:Form ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mandatoryFlag rdf:type rdf:Property ;
    rdfs:label 'Mandatory Flag' ;
    rdfs:comment 'Indicates whether this form must be included with every policy issuance for the associated product, or if it is optional based on customer election or underwriting decisions.' ;
    rdfs:domain ind:Product ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:printSequence rdf:type rdf:Property ;
    rdfs:label 'Print Sequence' ;
    rdfs:comment 'The order in which this form should appear in the policy document package when multiple forms are assembled for delivery to the policyholder.' ;
    rdfs:domain ind:Form ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:prospectusRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Prospectus Required Flag' ;
    rdfs:comment 'Indicates whether a prospectus must be delivered to the customer along with this form at point of sale, as required for variable insurance products.' ;
    rdfs:domain ind:Form ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:usageNotes rdf:type rdf:Property ;
    rdfs:label 'Usage Notes' ;
    rdfs:comment 'Operational guidance and special instructions for when and how to use this form. May include underwriting rules, state-specific requirements, or system processing notes.' ;
    rdfs:domain ind:Form ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prospectusDocumentId rdf:type rdf:Property ;
    rdfs:label 'Prospectus Document Id' ;
    rdfs:comment 'Foreign key linking to document.document. Business justification: Variable life and annuity separate account funds require SEC-registered prospectus documents for suitability review, compliance, and policyholder disclosure. The fund\'s prospectus_reference is a denor' ;
    rdfs:domain ind:SeparateAccountFund ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Document .

ind:availabilityStatus rdf:type rdf:Property ;
    rdfs:label 'Availability Status' ;
    rdfs:comment 'Indicates whether the fund is currently available for policyholder selection within variable products. Restricted funds may be available only to existing investors; discontinued funds are closed to all new and additional investments.' ;
    rdfs:domain ind:SeparateAccountFund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closedToNewDate rdf:type rdf:Property ;
    rdfs:label 'Closed To New Date' ;
    rdfs:comment 'Date when the fund was closed to new allocations while continuing to service existing investments. Used to track fund capacity management decisions.' ;
    rdfs:domain ind:SeparateAccountFund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dollarCostAveragingEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Dollar Cost Averaging Eligible Flag' ;
    rdfs:comment 'Indicates whether this fund is eligible for automatic dollar cost averaging programs where systematic transfers are made from a stable value fund into this investment option over time.' ;
    rdfs:domain ind:SeparateAccountFund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:expenseRatioPercent rdf:type rdf:Property ;
    rdfs:label 'Expense Ratio Percent' ;
    rdfs:comment 'Annual fund operating expense ratio expressed as a percentage of average net assets, representing the cost charged to policyholders for fund management, administrative services, and other operational expenses.' ;
    rdfs:domain ind:SeparateAccountFund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fundDescription rdf:type rdf:Property ;
    rdfs:label 'Fund Description' ;
    rdfs:comment 'Detailed narrative description of the fund\'s investment strategy, holdings, risk profile, and suitability for different investor types. Used in policyholder communications and prospectus materials.' ;
    rdfs:domain ind:SeparateAccountFund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fundFamily rdf:type rdf:Property ;
    rdfs:label 'Fund Family' ;
    rdfs:comment 'Name of the investment management company or fund family that manages the separate account fund (e.g., Fidelity, Vanguard, BlackRock, PIMCO).' ;
    rdfs:domain ind:SeparateAccountFund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fundStatus rdf:type rdf:Property ;
    rdfs:label 'Fund Status' ;
    rdfs:comment 'Current operational status of the separate account fund indicating availability for new allocations and existing account management. Active funds accept new investments; closed funds maintain existing positions but accept no new money; liquidating funds are winding down.' ;
    rdfs:domain ind:SeparateAccountFund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investmentStyle rdf:type rdf:Property ;
    rdfs:label 'Investment Style' ;
    rdfs:comment 'Investment management style or approach employed by the fund manager, indicating whether the fund follows active management, passive indexing, growth-oriented, or value-oriented strategies.' ;
    rdfs:domain ind:SeparateAccountFund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumAllocationPercent rdf:type rdf:Property ;
    rdfs:label 'Maximum Allocation Percent' ;
    rdfs:comment 'Maximum percentage of total account value that may be allocated to this fund, used to enforce diversification limits and manage concentration risk in policyholder portfolios.' ;
    rdfs:domain ind:SeparateAccountFund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maximumTransfersPerYear rdf:type rdf:Property ;
    rdfs:label 'Maximum Transfers Per Year' ;
    rdfs:comment 'Maximum number of transfers allowed into or out of this fund within a calendar year, enforced to prevent excessive trading and market timing.' ;
    rdfs:domain ind:SeparateAccountFund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minimumAllocationPercent rdf:type rdf:Property ;
    rdfs:label 'Minimum Allocation Percent' ;
    rdfs:comment 'Minimum percentage of total account value that must be allocated to this fund if the policyholder chooses to invest in it. Used to enforce diversification requirements and operational minimums.' ;
    rdfs:domain ind:SeparateAccountFund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumInitialInvestmentAmount rdf:type rdf:Property ;
    rdfs:label 'Minimum Initial Investment Amount' ;
    rdfs:comment 'Minimum dollar amount required for the initial allocation to this fund when a policyholder first selects it as an investment option.' ;
    rdfs:domain ind:SeparateAccountFund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:morningstarCategory rdf:type rdf:Property ;
    rdfs:label 'Morningstar Category' ;
    rdfs:comment 'Morningstar fund classification category used for peer group comparison and performance benchmarking (e.g., Large Blend, Intermediate Bond, Foreign Large Growth).' ;
    rdfs:domain ind:SeparateAccountFund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:morningstarRating rdf:type rdf:Property ;
    rdfs:label 'Morningstar Rating' ;
    rdfs:comment 'Morningstar\'s proprietary star rating for the fund (1-5 stars), based on risk-adjusted returns relative to peer funds. Used for fund selection and marketing materials.' ;
    rdfs:domain ind:SeparateAccountFund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:mortalityExpenseChargePercent rdf:type rdf:Property ;
    rdfs:label 'Mortality Expense Charge Percent' ;
    rdfs:comment 'Mortality and expense risk charge assessed by the insurance company on variable product separate account values, covering insurance guarantees and administrative costs. Expressed as an annual percentage of account value.' ;
    rdfs:domain ind:SeparateAccountFund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:navCalculationFrequency rdf:type rdf:Property ;
    rdfs:label 'Nav Calculation Frequency' ;
    rdfs:comment 'Frequency at which the fund\'s net asset value per unit is calculated and published, determining how often policyholder account values are updated.' ;
    rdfs:domain ind:SeparateAccountFund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:performanceInceptionDate rdf:type rdf:Property ;
    rdfs:label 'Performance Inception Date' ;
    rdfs:comment 'Date from which fund performance is calculated and reported. May differ from fund inception date if the fund underwent reorganization or name change.' ;
    rdfs:domain ind:SeparateAccountFund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rebalancingEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Rebalancing Eligible Flag' ;
    rdfs:comment 'Indicates whether this fund can be included in automatic portfolio rebalancing programs that periodically adjust allocations back to target percentages.' ;
    rdfs:domain ind:SeparateAccountFund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:predecessorRuleSuitabilityRuleId rdf:type rdf:Property ;
    rdfs:label 'Predecessor Rule Suitability Rule Id' ;
    rdfs:comment 'Reference to the previous version of this suitability rule that this version supersedes. Enables rule lineage tracking.' ;
    rdfs:domain ind:SuitabilityRule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SuitabilityRule .

ind:bestInterestObligationLevel rdf:type rdf:Property ;
    rdfs:label 'Best Interest Obligation Level' ;
    rdfs:comment 'The level of care and diligence standard required when recommending this product. Determines the depth of analysis and documentation required.' ;
    rdfs:domain ind:SuitabilityRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investmentExperienceRequired rdf:type rdf:Property ;
    rdfs:label 'Investment Experience Required' ;
    rdfs:comment 'Minimum level of investment experience or financial sophistication required for the customer to be suitable for this product. Relevant for variable and indexed products.' ;
    rdfs:domain ind:SuitabilityRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investmentObjectiveAlignment rdf:type rdf:Property ;
    rdfs:label 'Investment Objective Alignment' ;
    rdfs:comment 'Pipe-separated list of customer investment objectives that align with this product (e.g., INCOME|GROWTH|PRESERVATION|LEGACY). [ENUM-REF-CANDIDATE: INCOME|GROWTH|PRESERVATION|LEGACY|TAX_DEFERRAL|ESTATE_PLANNING|RETIREMENT_INCOME — promote to reference product]' ;
    rdfs:domain ind:SuitabilityRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:liquidityNeedsAssessmentRequired rdf:type rdf:Property ;
    rdfs:label 'Liquidity Needs Assessment Required' ;
    rdfs:comment 'Indicates whether a formal assessment of the customer\'s liquidity needs is required before recommending this product. True for products with significant surrender charges or restricted access.' ;
    rdfs:domain ind:SuitabilityRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maximumAge rdf:type rdf:Property ;
    rdfs:label 'Maximum Age' ;
    rdfs:comment 'Maximum age of the customer for this product to be considered suitable. Part of age-based suitability criteria.' ;
    rdfs:domain ind:SuitabilityRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maximumPremiumAsPercentOfIncome rdf:type rdf:Property ;
    rdfs:label 'Maximum Premium As Percent Of Income' ;
    rdfs:comment 'Maximum allowable premium payment as a percentage of the customer\'s annual income for suitability purposes. Prevents over-commitment of resources.' ;
    rdfs:domain ind:SuitabilityRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maximumPremiumAsPercentOfNetWorth rdf:type rdf:Property ;
    rdfs:label 'Maximum Premium As Percent Of Net Worth' ;
    rdfs:comment 'Maximum allowable premium payment as a percentage of the customer\'s net worth for suitability purposes. Particularly relevant for single-premium annuities.' ;
    rdfs:domain ind:SuitabilityRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumAge rdf:type rdf:Property ;
    rdfs:label 'Minimum Age' ;
    rdfs:comment 'Minimum age of the customer for this product to be considered suitable. Part of age-based suitability criteria.' ;
    rdfs:domain ind:SuitabilityRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minimumAnnualIncome rdf:type rdf:Property ;
    rdfs:label 'Minimum Annual Income' ;
    rdfs:comment 'Minimum annual income threshold required for the customer to meet suitability criteria for this product. Expressed in USD.' ;
    rdfs:domain ind:SuitabilityRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumInvestmentHorizonYears rdf:type rdf:Property ;
    rdfs:label 'Minimum Investment Horizon Years' ;
    rdfs:comment 'Minimum investment time horizon in years required for suitability. Critical for products with surrender charges or long-term accumulation features.' ;
    rdfs:domain ind:SuitabilityRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minimumLiquidNetWorth rdf:type rdf:Property ;
    rdfs:label 'Minimum Liquid Net Worth' ;
    rdfs:comment 'Minimum liquid net worth (assets easily convertible to cash) required for suitability. Critical for annuity products with surrender charges. Expressed in USD.' ;
    rdfs:domain ind:SuitabilityRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumNetWorth rdf:type rdf:Property ;
    rdfs:label 'Minimum Net Worth' ;
    rdfs:comment 'Minimum net worth threshold required for the customer to meet suitability criteria for this product. Expressed in USD.' ;
    rdfs:domain ind:SuitabilityRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:productComplexityClassification rdf:type rdf:Property ;
    rdfs:label 'Product Complexity Classification' ;
    rdfs:comment 'Classification of the product complexity level for suitability assessment purposes. Determines the depth of suitability analysis required.' ;
    rdfs:domain ind:SuitabilityRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:replacementTransactionFlag rdf:type rdf:Property ;
    rdfs:label 'Replacement Transaction Flag' ;
    rdfs:comment 'Indicates whether this suitability rule applies specifically to replacement transactions (1035 exchanges or policy replacements), which have heightened suitability requirements.' ;
    rdfs:domain ind:SuitabilityRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiredDisclosureDocuments rdf:type rdf:Property ;
    rdfs:label 'Required Disclosure Documents' ;
    rdfs:comment 'Comma-separated list of disclosure document codes that must be provided to the customer before sale (e.g., prospectus, buyer\'s guide, product illustration, Form CRS).' ;
    rdfs:domain ind:SuitabilityRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskToleranceRequired rdf:type rdf:Property ;
    rdfs:label 'Risk Tolerance Required' ;
    rdfs:comment 'The minimum risk tolerance profile required for the customer to be suitable for this product. Aligns with customer risk assessment.' ;
    rdfs:domain ind:SuitabilityRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleVersionNumber rdf:type rdf:Property ;
    rdfs:label 'Rule Version Number' ;
    rdfs:comment 'Version number of this suitability rule configuration. Incremented when rule parameters are updated to maintain audit trail.' ;
    rdfs:domain ind:SuitabilityRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:seniorInvestorProtectionFlag rdf:type rdf:Property ;
    rdfs:label 'Senior Investor Protection Flag' ;
    rdfs:comment 'Indicates whether enhanced suitability protections for senior investors (typically age 65+) apply to this product under state or federal regulations.' ;
    rdfs:domain ind:SuitabilityRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:stateSpecificOverrideFlag rdf:type rdf:Property ;
    rdfs:label 'State Specific Override Flag' ;
    rdfs:comment 'Indicates whether this rule represents a state-specific override of the default national suitability rule for the product.' ;
    rdfs:domain ind:SuitabilityRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:suitabilityQuestionnaireRequired rdf:type rdf:Property ;
    rdfs:label 'Suitability Questionnaire Required' ;
    rdfs:comment 'Indicates whether a formal suitability questionnaire must be completed and documented before recommending this product.' ;
    rdfs:domain ind:SuitabilityRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:taxStatusEligibility rdf:type rdf:Property ;
    rdfs:label 'Tax Status Eligibility' ;
    rdfs:comment 'Pipe-separated list of customer tax status categories for which this product is suitable (e.g., QUALIFIED|NON_QUALIFIED|IRA|ROTH_IRA). [ENUM-REF-CANDIDATE: QUALIFIED|NON_QUALIFIED|IRA|ROTH_IRA|401K|403B|SEP|SIMPLE — promote to reference product]' ;
    rdfs:domain ind:SuitabilityRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryPredecessorRateActionId rdf:type rdf:Property ;
    rdfs:label 'Primary Predecessor Rate Action Id' ;
    rdfs:comment 'Reference to the previous rate action that this action supersedes or modifies. Null if this is the first rate action for the product block.' ;
    rdfs:domain ind:RateAction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RateAction .

ind:actuarialJustification rdf:type rdf:Property ;
    rdfs:label 'Actuarial Justification' ;
    rdfs:comment 'Detailed actuarial rationale and supporting analysis for the rate action. Includes references to experience studies, mortality trends, expense analysis, or investment performance that justify the change.' ;
    rdfs:domain ind:RateAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:advanceNoticePeriodDays rdf:type rdf:Property ;
    rdfs:label 'Advance Notice Period Days' ;
    rdfs:comment 'Number of days advance notice provided to policyholders before the rate action becomes effective. Required by state regulations and policy contracts.' ;
    rdfs:domain ind:RateAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:announcementDate rdf:type rdf:Property ;
    rdfs:label 'Announcement Date' ;
    rdfs:comment 'Date when the rate action was announced to internal stakeholders, distribution channels, and policyholders.' ;
    rdfs:domain ind:RateAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:approvedByUser rdf:type rdf:Property ;
    rdfs:label 'Approved By User' ;
    rdfs:comment 'User identifier or name of the individual who provided internal approval for this rate action. Used for audit trail and accountability.' ;
    rdfs:domain ind:RateAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:averageRateChangePercent rdf:type rdf:Property ;
    rdfs:label 'Average Rate Change Percent' ;
    rdfs:comment 'Average percentage change in rates across all affected policies. Positive values indicate increases, negative values indicate decreases. Expressed as a decimal (e.g., 0.0500 for 5.00% increase).' ;
    rdfs:domain ind:RateAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:communicationMethod rdf:type rdf:Property ;
    rdfs:label 'Communication Method' ;
    rdfs:comment 'Primary method used to communicate the rate action to policyholders. May include direct mail, email, policy statement insert, agent notification, website posting, or multiple channels.' ;
    rdfs:domain ind:RateAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:communicationSentDate rdf:type rdf:Property ;
    rdfs:label 'Communication Sent Date' ;
    rdfs:comment 'Date when policyholder communications regarding this rate action were sent or initiated.' ;
    rdfs:domain ind:RateAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:financialImpactEstimate rdf:type rdf:Property ;
    rdfs:label 'Financial Impact Estimate' ;
    rdfs:comment 'Estimated annual financial impact of this rate action on company revenues or expenses. Expressed in USD. Positive values indicate revenue increase or expense decrease, negative values indicate revenue decrease or expense increase.' ;
    rdfs:domain ind:RateAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:guaranteedRateFlag rdf:type rdf:Property ;
    rdfs:label 'Guaranteed Rate Flag' ;
    rdfs:comment 'Indicates whether the new rates established by this action are guaranteed (cannot be changed further) or non-guaranteed (subject to future adjustment). True if guaranteed, False if non-guaranteed.' ;
    rdfs:domain ind:RateAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:impactedFaceAmountTotal rdf:type rdf:Property ;
    rdfs:label 'Impacted Face Amount Total' ;
    rdfs:comment 'Total face amount (death benefit) across all policies affected by this rate action. Expressed in USD. Used for financial impact analysis.' ;
    rdfs:domain ind:RateAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:irc7702ImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Irc 7702 Impact Flag' ;
    rdfs:comment 'Indicates whether this rate action has potential impact on IRC Section 7702 life insurance tax qualification. True if the action may affect guideline premium test (GPT) or cash value accumulation test (CVAT) compliance, False otherwise.' ;
    rdfs:domain ind:RateAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:optOutAvailableFlag rdf:type rdf:Property ;
    rdfs:label 'Opt Out Available Flag' ;
    rdfs:comment 'Indicates whether policyholders have the option to opt out of the rate action (e.g., by surrendering the policy or converting to a different product). True if opt-out is available, False otherwise.' ;
    rdfs:domain ind:RateAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:optOutDeadlineDate rdf:type rdf:Property ;
    rdfs:label 'Opt Out Deadline Date' ;
    rdfs:comment 'Last date by which policyholders can exercise their opt-out option if available. Null if no opt-out is available.' ;
    rdfs:domain ind:RateAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:policyholderCommunicationPlanReference rdf:type rdf:Property ;
    rdfs:label 'Policyholder Communication Plan Reference' ;
    rdfs:comment 'Reference identifier to the communication plan document detailing how policyholders will be notified of this rate action. Links to document management system.' ;
    rdfs:domain ind:RateAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profitabilityImpactDescription rdf:type rdf:Property ;
    rdfs:label 'Profitability Impact Description' ;
    rdfs:comment 'Narrative description of the expected impact on product profitability, including effects on internal rate of return (IRR), new business value (NBV), and embedded value.' ;
    rdfs:domain ind:RateAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateActionCode rdf:type rdf:Property ;
    rdfs:label 'Rate Action Code' ;
    rdfs:comment 'Unique business code identifying this rate action event. Used for operational reference and reporting.' ;
    rdfs:domain ind:RateAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateActionName rdf:type rdf:Property ;
    rdfs:label 'Rate Action Name' ;
    rdfs:comment 'Descriptive name of the rate action event for business user identification and reporting purposes.' ;
    rdfs:domain ind:RateAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateActionStatus rdf:type rdf:Property ;
    rdfs:label 'Rate Action Status' ;
    rdfs:comment 'Current lifecycle status of the rate action. Tracks progression from draft through regulatory approval to implementation. [ENUM-REF-CANDIDATE: DRAFT|PENDING_APPROVAL|APPROVED|FILED|EFFECTIVE|WITHDRAWN|CANCELLED — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:RateAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateActionType rdf:type rdf:Property ;
    rdfs:label 'Rate Action Type' ;
    rdfs:comment 'Classification of the rate action event. Indicates the type of rate or charge being modified: Cost of Insurance (COI) rate changes, credited interest rate adjustments, expense charge modifications, dividend scale changes, mortality table updates, or premium rate adjustments.' ;
    rdfs:domain ind:RateAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateChangeDirection rdf:type rdf:Property ;
    rdfs:label 'Rate Change Direction' ;
    rdfs:comment 'Overall direction of the rate change. Increase indicates rates are going up (higher cost to policyholders), Decrease indicates rates are going down, Mixed indicates some rates increase while others decrease, No Change indicates administrative action without rate impact.' ;
    rdfs:domain ind:RateAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reinsuranceImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Reinsurance Impact Flag' ;
    rdfs:comment 'Indicates whether this rate action affects reinsurance treaties or cession calculations. True if reinsurance agreements must be updated or renegotiated, False otherwise.' ;
    rdfs:domain ind:RateAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reinsuranceTreatyReference rdf:type rdf:Property ;
    rdfs:label 'Reinsurance Treaty Reference' ;
    rdfs:comment 'Reference identifier to the reinsurance treaty or treaties affected by this rate action. Null if no reinsurance impact.' ;
    rdfs:domain ind:RateAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guardianPartyId rdf:type rdf:Property ;
    rdfs:label 'Guardian Party Id' ;
    rdfs:comment 'Self-referencing FK on party (guardian_party_id)' ;
    rdfs:domain ind:Party ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:deceasedDate rdf:type rdf:Property ;
    rdfs:label 'Deceased Date' ;
    rdfs:comment 'Date of death for the party. Populated when party_status transitions to deceased. Triggers death benefit processing, annuity death benefit calculations, and beneficiary claim adjudication. Null for living parties. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:Party ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:deceasedVerifiedDate rdf:type rdf:Property ;
    rdfs:label 'Deceased Verified Date' ;
    rdfs:comment 'Date the party death was officially verified through death certificate, Social Security Death Master File (DMF), or other authoritative source. Used for death benefit claim processing and audit trail. Null for living parties. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:Party ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:entityFormationDate rdf:type rdf:Property ;
    rdfs:label 'Entity Formation Date' ;
    rdfs:comment 'Date the legal entity (corporation, partnership, association) was formed or registered with the state. Null for individual and trust party types. Used for entity age verification and legal entity validation. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:Party ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:grantorName rdf:type rdf:Property ;
    rdfs:label 'Grantor Name' ;
    rdfs:comment 'Name of the grantor (settlor) who established the trust. Populated only when party_type is trust. Used for grantor trust tax rules, insurable interest verification, and estate planning documentation.' ;
    rdfs:domain ind:Party ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partyNumber rdf:type rdf:Property ;
    rdfs:label 'Party Number' ;
    rdfs:comment 'Business-facing unique identifier for the party. Human-readable reference number used in correspondence, customer service, and external communications.' ;
    rdfs:domain ind:Party ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partyStatus rdf:type rdf:Property ;
    rdfs:label 'Party Status' ;
    rdfs:comment 'Current lifecycle status of the party. Active indicates normal operational state. Deceased triggers death benefit processing. Incapacitated may require guardian or power of attorney. Sanctioned indicates OFAC or regulatory restriction. Fraud_flagged indicates suspected fraudulent activity requiring investigation.' ;
    rdfs:domain ind:Party ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partyType rdf:type rdf:Property ;
    rdfs:label 'Party Type' ;
    rdfs:comment 'Classification of the party entity. Distinguishes between natural persons (individual) and legal entities (trust, corporation, partnership, association, estate). Drives downstream processing rules for identity verification, tax reporting, and regulatory compliance.' ;
    rdfs:domain ind:Party ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:residencyCountry rdf:type rdf:Property ;
    rdfs:label 'Residency Country' ;
    rdfs:comment 'Country of tax residency for the party. Three-letter ISO 3166-1 alpha-3 country code. Determines tax reporting obligations, withholding requirements, and regulatory jurisdiction. May differ from citizenship_country for expatriates and foreign residents.' ;
    rdfs:domain ind:Party ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemPartyCode rdf:type rdf:Property ;
    rdfs:label 'Source System Party Code' ;
    rdfs:comment 'Unique identifier for the party in the source operational system. Used for cross-system reconciliation, data lineage tracking, and bidirectional synchronization between lakehouse and operational systems.' ;
    rdfs:domain ind:Party ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trustEin rdf:type rdf:Property ;
    rdfs:label 'Trust Ein' ;
    rdfs:comment 'Employer Identification Number (EIN) assigned to the trust by the IRS. Populated only when party_type is trust. Used for tax reporting (1099-R, 1042-S) and IRS TIN matching. Masked or tokenized in storage per PII compliance.' ;
    rdfs:domain ind:Party ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trustEstablishmentDate rdf:type rdf:Property ;
    rdfs:label 'Trust Establishment Date' ;
    rdfs:comment 'Date the trust was legally established or executed. Populated only when party_type is trust. Used for trust age calculations, grantor trust rules, and estate planning compliance. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:Party ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:trustType rdf:type rdf:Property ;
    rdfs:label 'Trust Type' ;
    rdfs:comment 'Classification of the trust entity. ILIT (Irrevocable Life Insurance Trust) for life insurance ownership. Revocable_living for revocable living trusts. CRT (Charitable Remainder Trust), GRAT (Grantor Retained Annuity Trust), QPRT (Qualified Personal Residence Trust) for specialized estate planning trusts. Null for non-trust party types.' ;
    rdfs:domain ind:Policyholder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorAssumptionDetailId rdf:type rdf:Property ;
    rdfs:label 'Prior Assumption Detail Id' ;
    rdfs:comment 'Self-referencing FK on assumption_detail (prior_assumption_detail_id)' ;
    rdfs:domain ind:AssumptionDetail ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AssumptionDetail .

ind:assumptionDetailStatus rdf:type rdf:Property ;
    rdfs:label 'Assumption Detail Status' ;
    rdfs:comment 'Current lifecycle status of this assumption detail record. Indicates whether the assumption is in draft, actively used in valuations, superseded by a newer version, retired, or under review.' ;
    rdfs:domain ind:AssumptionDetail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assumptionSubtype rdf:type rdf:Property ;
    rdfs:label 'Assumption Subtype' ;
    rdfs:comment 'Granular subtype within the assumption type. Examples: qx (mortality rate), lapse_rate, disability_incidence, per_policy_expense, credited_rate, credibility_weight. Provides additional specificity for the assumption being modeled.' ;
    rdfs:domain ind:AssumptionDetail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assumptionType rdf:type rdf:Property ;
    rdfs:label 'Assumption Type' ;
    rdfs:comment 'Type discriminator indicating the category of assumption this detail record represents. Determines which dimensional attributes are applicable and how the rate value should be interpreted.' ;
    rdfs:domain ind:AssumptionDetail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:experienceAdjustmentFactor rdf:type rdf:Property ;
    rdfs:label 'Experience Adjustment Factor' ;
    rdfs:comment 'Multiplicative adjustment factor applied to base assumption rates based on company experience studies. Values greater than 1 increase the base rate; values less than 1 decrease it. Null if no experience adjustment is applied.' ;
    rdfs:domain ind:AssumptionDetail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:faceAmountBand rdf:type rdf:Property ;
    rdfs:label 'Face Amount Band' ;
    rdfs:comment 'Face amount band or size category for which this assumption rate applies. Examples: 0-50k, 50k-100k, 100k-250k, 250k-500k, 500k+. Used for size-based lapse and expense segmentation. Null if assumption is size-neutral.' ;
    rdfs:domain ind:AssumptionDetail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issueAgeBand rdf:type rdf:Property ;
    rdfs:label 'Issue Age Band' ;
    rdfs:comment 'Issue age band for which this assumption rate applies. Examples: 18-30, 31-40, 41-50, 51-60, 61-70, 71+. Used for issue-age-based segmentation in lapse and mortality assumptions. Null if assumption is issue-age-neutral.' ;
    rdfs:domain ind:AssumptionDetail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marginPercentage rdf:type rdf:Property ;
    rdfs:label 'Margin Percentage' ;
    rdfs:comment 'Margin percentage added to the base assumption for conservatism or profit loading. Expressed as a percentage. Used in pricing and reserve calculations to provide cushion above best-estimate assumptions.' ;
    rdfs:domain ind:Actuarial ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rateUnit rdf:type rdf:Property ;
    rdfs:label 'Rate Unit' ;
    rdfs:comment 'Unit of measure for the rate_value. Clarifies whether the value is a percentage, decimal fraction, currency amount, per-thousand rate, per-policy amount, or per-unit cost.' ;
    rdfs:domain ind:AssumptionDetail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateValue rdf:type rdf:Property ;
    rdfs:label 'Rate Value' ;
    rdfs:comment 'The numeric assumption value for this detail record. Interpretation depends on assumption_type: mortality qx, lapse percentage, expense dollar amount, interest rate percentage, credibility factor. Supports high precision for actuarial calculations.' ;
    rdfs:domain ind:AssumptionDetail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reopenedContestabilityReviewId rdf:type rdf:Property ;
    rdfs:label 'Reopened Contestability Review Id' ;
    rdfs:comment 'Self-referencing FK on contestability_review (reopened_contestability_review_id)' ;
    rdfs:domain ind:ContestabilityReview ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ContestabilityReview .

ind:actualFactDiscovered rdf:type rdf:Property ;
    rdfs:label 'Actual Fact Discovered' ;
    rdfs:comment 'The true fact or condition discovered during investigation that contradicts the applicant response.' ;
    rdfs:domain ind:ContestabilityReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appealDeadlineDate rdf:type rdf:Property ;
    rdfs:label 'Appeal Deadline Date' ;
    rdfs:comment 'Final date by which the beneficiary may file an appeal of the contestability review decision.' ;
    rdfs:domain ind:ContestabilityReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:appealFiledFlag rdf:type rdf:Property ;
    rdfs:label 'Appeal Filed Flag' ;
    rdfs:comment 'Indicates whether the beneficiary or policyholder has filed an appeal of the rescission decision.' ;
    rdfs:domain ind:ContestabilityReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:applicantResponse rdf:type rdf:Property ;
    rdfs:label 'Applicant Response' ;
    rdfs:comment 'The answer provided by the applicant on the insurance application that is under contestability review.' ;
    rdfs:domain ind:ContestabilityReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicationQuestionNumber rdf:type rdf:Property ;
    rdfs:label 'Application Question Number' ;
    rdfs:comment 'Reference to the specific question number on the insurance application where misrepresentation occurred.' ;
    rdfs:domain ind:ContestabilityReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:apsReviewedFlag rdf:type rdf:Property ;
    rdfs:label 'Aps Reviewed Flag' ;
    rdfs:comment 'Indicates whether attending physician statements were obtained and reviewed as part of the contestability investigation.' ;
    rdfs:domain ind:ContestabilityReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:beneficiaryNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Beneficiary Notification Date' ;
    rdfs:comment 'Date when the beneficiary or claimant was formally notified of the contestability review outcome and rescission decision.' ;
    rdfs:domain ind:LifeInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:claimDenialAmount rdf:type rdf:Property ;
    rdfs:label 'Claim Denial Amount' ;
    rdfs:comment 'Death benefit or claim amount that is being denied as a result of the rescission decision.' ;
    rdfs:domain ind:ContestabilityReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contestabilityPeriodDays rdf:type rdf:Property ;
    rdfs:label 'Contestability Period Days' ;
    rdfs:comment 'Number of days elapsed between policy issue date and date of loss, used to confirm contestability eligibility (typically within 730 days).' ;
    rdfs:domain ind:ContestabilityReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:evidenceSource rdf:type rdf:Property ;
    rdfs:label 'Evidence Source' ;
    rdfs:comment 'Primary source of evidence that substantiated the material misrepresentation finding. [ENUM-REF-CANDIDATE: aps|mib|prescription_database|dmv_records|criminal_records|financial_records|social_media|witness_statement|other — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:LifeInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalReviewDate rdf:type rdf:Property ;
    rdfs:label 'Legal Review Date' ;
    rdfs:comment 'Date when legal counsel completed their review of the contestability case.' ;
    rdfs:domain ind:ContestabilityReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:legalReviewRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Legal Review Required Flag' ;
    rdfs:comment 'Indicates whether the contestability case requires review and approval by the legal department before final decision.' ;
    rdfs:domain ind:ContestabilityReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:materialMisrepresentationFoundFlag rdf:type rdf:Property ;
    rdfs:label 'Material Misrepresentation Found Flag' ;
    rdfs:comment 'Indicates whether the investigation identified material misrepresentation or concealment of facts in the application that would have affected underwriting.' ;
    rdfs:domain ind:ContestabilityReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:medicalDirectorReviewFlag rdf:type rdf:Property ;
    rdfs:label 'Medical Director Review Flag' ;
    rdfs:comment 'Indicates whether the case was escalated to the medical director for clinical assessment of the misrepresentation materiality.' ;
    rdfs:domain ind:ContestabilityReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mibDiscrepancyFoundFlag rdf:type rdf:Property ;
    rdfs:label 'Mib Discrepancy Found Flag' ;
    rdfs:comment 'Indicates whether the MIB check revealed information inconsistent with the application.' ;
    rdfs:domain ind:ContestabilityReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:misrepresentationCategory rdf:type rdf:Property ;
    rdfs:label 'Misrepresentation Category' ;
    rdfs:comment 'Classification of the type of material misrepresentation discovered during the contestability review. [ENUM-REF-CANDIDATE: medical_history|tobacco_use|occupation|hazardous_activities|financial_information|criminal_history|other_insurance|none — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ContestabilityReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:misrepresentationDescription rdf:type rdf:Property ;
    rdfs:label 'Misrepresentation Description' ;
    rdfs:comment 'Detailed narrative describing the specific facts, omissions, or false statements identified as material misrepresentation.' ;
    rdfs:domain ind:ContestabilityReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:premiumRefundAmount rdf:type rdf:Property ;
    rdfs:label 'Premium Refund Amount' ;
    rdfs:comment 'Total amount of premiums paid that will be refunded to the policyholder or estate if rescission is approved.' ;
    rdfs:domain ind:ContestabilityReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:premiumRefundCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Premium Refund Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the premium refund amount.' ;
    rdfs:domain ind:ContestabilityReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rescissionDecision rdf:type rdf:Property ;
    rdfs:label 'Rescission Decision' ;
    rdfs:comment 'Final decision rendered by the company regarding policy rescission following contestability review.' ;
    rdfs:domain ind:ContestabilityReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rescissionEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Rescission Effective Date' ;
    rdfs:comment 'Date from which the policy is deemed void ab initio (from the beginning) if rescission is approved, typically the original policy issue date.' ;
    rdfs:domain ind:ContestabilityReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rescissionRecommendedFlag rdf:type rdf:Property ;
    rdfs:label 'Rescission Recommended Flag' ;
    rdfs:comment 'Indicates whether the investigator recommends rescinding the policy contract based on material misrepresentation findings.' ;
    rdfs:domain ind:ContestabilityReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reviewInitiatedDate rdf:type rdf:Property ;
    rdfs:label 'Review Initiated Date' ;
    rdfs:comment 'Date when the contestability review was formally opened and investigation began.' ;
    rdfs:domain ind:ContestabilityReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reviewTriggerReason rdf:type rdf:Property ;
    rdfs:label 'Review Trigger Reason' ;
    rdfs:comment 'Primary reason or business rule that triggered the contestability review investigation. [ENUM-REF-CANDIDATE: automatic_contestability|fraud_indicator|mib_discrepancy|aps_discrepancy|underwriting_red_flag|siu_referral|large_claim_amount|early_death — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ContestabilityReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stateDoiNotificationDate rdf:type rdf:Property ;
    rdfs:label 'State Doi Notification Date' ;
    rdfs:comment 'Date when the state insurance department was notified of the rescission decision.' ;
    rdfs:domain ind:ContestabilityReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:stateDoiNotificationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'State Doi Notification Required Flag' ;
    rdfs:comment 'Indicates whether state insurance department notification is required for this rescission action per regulatory requirements.' ;
    rdfs:domain ind:ContestabilityReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:underwritingDecisionImpact rdf:type rdf:Property ;
    rdfs:label 'Underwriting Decision Impact' ;
    rdfs:comment 'Assessment of how the discovered misrepresentation would have affected the original underwriting decision had the true facts been known.' ;
    rdfs:domain ind:ContestabilityReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:withinContestabilityFlag rdf:type rdf:Property ;
    rdfs:label 'Within Contestability Flag' ;
    rdfs:comment 'Indicates whether the claim occurred within the statutory two-year contestability period from policy issue date.' ;
    rdfs:domain ind:ContestabilityReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:conversionId rdf:type rdf:Property ;
    rdfs:label 'Conversion Id' ;
    rdfs:comment 'Unique identifier for the policy conversion transaction. Primary key for the policy conversion record.' ;
    rdfs:domain ind:Conversion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:conversionInForcePolicyId rdf:type rdf:Property ;
    rdfs:label 'Conversion In Force Policy Id' ;
    rdfs:comment 'Reference to the original term life policy being converted. Links to the source policy record in the in-force policy table.' ;
    rdfs:domain ind:Conversion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InForcePolicy .

ind:conversionNewPolicyInForcePolicyId rdf:type rdf:Property ;
    rdfs:label 'Conversion New Policy In Force Policy Id' ;
    rdfs:comment 'Reference to the newly issued permanent policy resulting from the conversion. Links to the target policy record in the in-force policy table.' ;
    rdfs:domain ind:Conversion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InForcePolicy .

ind:conversionProcessingAgentProducerId rdf:type rdf:Property ;
    rdfs:label 'Conversion Processing Agent Producer Id' ;
    rdfs:comment 'Reference to the internal user or system agent who processed the conversion transaction. Used for audit and workflow tracking.' ;
    rdfs:domain ind:Conversion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Producer .

ind:conversionProducerId rdf:type rdf:Property ;
    rdfs:label 'Conversion Producer Id' ;
    rdfs:comment 'Reference to the agent or producer who facilitated the conversion. Links to the producer record in the agent management system.' ;
    rdfs:domain ind:Conversion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Producer .

ind:originalConversionId rdf:type rdf:Property ;
    rdfs:label 'Original Conversion Id' ;
    rdfs:comment 'Self-referencing FK on conversion (original_conversion_id)' ;
    rdfs:domain ind:Conversion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Conversion .

ind:targetPlanId rdf:type rdf:Property ;
    rdfs:label 'Target Plan Id' ;
    rdfs:comment 'Foreign key linking to product.plan. Business justification: Conversion records the target plan a policy converts to. Linking conversion to the target plan_id enables conversion privilege validation against plan eligibility rules, new policy issuance workflow, ' ;
    rdfs:domain ind:Conversion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Plan .

ind:approvalRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Approval Required Flag' ;
    rdfs:comment 'Indicates whether managerial or underwriting approval is required for this conversion. True if the conversion requires special authorization beyond standard processing.' ;
    rdfs:domain ind:LifeInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:attainedAgeAtConversion rdf:type rdf:Property ;
    rdfs:label 'Attained Age At Conversion' ;
    rdfs:comment 'The insureds age at the time of conversion. Used for underwriting and pricing calculations for the new permanent policy.' ;
    rdfs:domain ind:Conversion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:channel rdf:type rdf:Property ;
    rdfs:label 'Channel' ;
    rdfs:comment 'The distribution channel through which the conversion request was initiated. Indicates how the policyholder submitted the conversion request.' ;
    rdfs:domain ind:Conversion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conversionNumber rdf:type rdf:Property ;
    rdfs:label 'Conversion Number' ;
    rdfs:comment 'Unique business transaction number assigned to this conversion event. Used for tracking and reference in policy administration systems.' ;
    rdfs:domain ind:Conversion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conversionStatus rdf:type rdf:Property ;
    rdfs:label 'Conversion Status' ;
    rdfs:comment 'Current lifecycle status of the conversion transaction. Tracks the conversion through its workflow from initial request to final completion. [ENUM-REF-CANDIDATE: pending|approved|in_progress|completed|cancelled|rejected|suspended — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Conversion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conversionType rdf:type rdf:Property ;
    rdfs:label 'Conversion Type' ;
    rdfs:comment 'Classification of the conversion based on the contractual provision being exercised. Indicates whether this is a standard contractual right or a special conversion offer.' ;
    rdfs:domain ind:Conversion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:newPolicyNumber rdf:type rdf:Property ;
    rdfs:label 'New Policy Number' ;
    rdfs:comment 'The policy number of the newly issued permanent policy. Business identifier for the converted policy.' ;
    rdfs:domain ind:Conversion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:newPremiumMode rdf:type rdf:Property ;
    rdfs:label 'New Premium Mode' ;
    rdfs:comment 'The payment frequency selected for the new permanent policy. Indicates how often premiums will be paid on the converted policy.' ;
    rdfs:domain ind:Conversion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:newTableRating rdf:type rdf:Property ;
    rdfs:label 'New Table Rating' ;
    rdfs:comment 'Any table rating or substandard rating applied to the new permanent policy. Expressed as a percentage or table letter indicating additional mortality risk.' ;
    rdfs:domain ind:Conversion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:newUnderwritingClass rdf:type rdf:Property ;
    rdfs:label 'New Underwriting Class' ;
    rdfs:comment 'The underwriting risk class assigned to the new permanent policy. Determines the premium rate structure for the converted policy.' ;
    rdfs:domain ind:Conversion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalFaceAmount rdf:type rdf:Property ;
    rdfs:label 'Original Face Amount' ;
    rdfs:comment 'Death benefit face amount of the original term policy at the time of conversion. Represents the coverage amount being converted.' ;
    rdfs:domain ind:Conversion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:originalIssueAge rdf:type rdf:Property ;
    rdfs:label 'Original Issue Age' ;
    rdfs:comment 'The insureds age when the original term policy was issued. May be used for pricing if the conversion is on an original-age basis.' ;
    rdfs:domain ind:Conversion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:originalPolicyNumber rdf:type rdf:Property ;
    rdfs:label 'Original Policy Number' ;
    rdfs:comment 'The policy number of the original term life policy being converted. Business identifier for the source policy.' ;
    rdfs:domain ind:Conversion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalProductType rdf:type rdf:Property ;
    rdfs:label 'Original Product Type' ;
    rdfs:comment 'Type of term life insurance product being converted. Identifies the specific term product category of the source policy.' ;
    rdfs:domain ind:Conversion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:privilegeExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Privilege Expiry Date' ;
    rdfs:comment 'The last date on which the policyholder can exercise the conversion privilege under the original term policy. After this date, the conversion right expires.' ;
    rdfs:domain ind:Conversion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:primaryTrusteePartyId rdf:type rdf:Property ;
    rdfs:label 'Primary Trustee Party Id' ;
    rdfs:comment 'Reference to the party record for the current trustee of the trust.' ;
    rdfs:domain ind:Trust ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:successorTrustId rdf:type rdf:Property ;
    rdfs:label 'Successor Trust Id' ;
    rdfs:comment 'Self-referencing FK on trust (successor_trust_id)' ;
    rdfs:domain ind:Trust ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Trust .

ind:trustGrantorPartyId rdf:type rdf:Property ;
    rdfs:label 'Trust Grantor Party Id' ;
    rdfs:comment 'Reference to the party record for the grantor of the trust.' ;
    rdfs:domain ind:Trust ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:trustPartyId rdf:type rdf:Property ;
    rdfs:label 'Trust Party Id' ;
    rdfs:comment 'Reference to the party master record representing this trust entity in the party system.' ;
    rdfs:domain ind:Trust ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:beneficialOwnerDisclosed rdf:type rdf:Property ;
    rdfs:label 'Beneficial Owner Disclosed' ;
    rdfs:comment 'Indicates whether the beneficial owners of the trust (individuals with 25% or greater ownership or control) have been identified and disclosed per CDD requirements.' ;
    rdfs:domain ind:Trust ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:documentVerificationDate rdf:type rdf:Property ;
    rdfs:label 'Document Verification Date' ;
    rdfs:comment 'The date the trust document was verified and approved for policy ownership.' ;
    rdfs:domain ind:Trust ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:documentVerified rdf:type rdf:Property ;
    rdfs:label 'Document Verified' ;
    rdfs:comment 'Indicates whether the trust document has been reviewed and verified by underwriting or legal for policy ownership purposes.' ;
    rdfs:domain ind:Trust ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ein rdf:type rdf:Property ;
    rdfs:label 'Ein' ;
    rdfs:comment 'The IRS-issued Employer Identification Number (Tax ID) for the trust entity, required for tax reporting and policy ownership.' ;
    rdfs:domain ind:Trust ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:establishmentDate rdf:type rdf:Property ;
    rdfs:label 'Establishment Date' ;
    rdfs:comment 'The date the trust was legally established or executed, as documented in the trust instrument.' ;
    rdfs:domain ind:Trust ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:governingLawJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Governing Law Jurisdiction' ;
    rdfs:comment 'The legal jurisdiction whose laws govern the interpretation and administration of the trust, which may differ from the state of formation.' ;
    rdfs:domain ind:Trust ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revocableFlag rdf:type rdf:Property ;
    rdfs:label 'Revocable Flag' ;
    rdfs:comment 'Indicates whether the trust is revocable (can be modified or terminated by the grantor) or irrevocable (cannot be changed without beneficiary consent).' ;
    rdfs:domain ind:Trust ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sourceSystemTrustCode rdf:type rdf:Property ;
    rdfs:label 'Source System Trust Code' ;
    rdfs:comment 'The unique identifier for this trust entity in the source operational system.' ;
    rdfs:domain ind:Trust ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stateOfFormation rdf:type rdf:Property ;
    rdfs:label 'State Of Formation' ;
    rdfs:comment 'The U.S. state or jurisdiction under whose laws the trust was established and is governed.' ;
    rdfs:domain ind:Trust ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stoliReviewStatus rdf:type rdf:Property ;
    rdfs:label 'Stoli Review Status' ;
    rdfs:comment 'Current status of STOLI compliance review for this trust ownership.' ;
    rdfs:domain ind:Trust ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:successorTrusteeName rdf:type rdf:Property ;
    rdfs:label 'Successor Trustee Name' ;
    rdfs:comment 'The full legal name of the designated successor trustee who will assume trustee responsibilities upon the current trustee\'s resignation, incapacity, or death.' ;
    rdfs:domain ind:Trust ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trustNumber rdf:type rdf:Property ;
    rdfs:label 'Trust Number' ;
    rdfs:comment 'Business identifier assigned to the trust for external reference and correspondence.' ;
    rdfs:domain ind:Trust ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trustStatus rdf:type rdf:Property ;
    rdfs:label 'Trust Status' ;
    rdfs:comment 'Current lifecycle status of the trust entity in the system.' ;
    rdfs:domain ind:Trust ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deathCertificateDocumentId rdf:type rdf:Property ;
    rdfs:label 'Death Certificate Document Id' ;
    rdfs:comment 'Foreign key linking to document.document. Business justification: Claims processing and regulatory compliance require direct retrieval of the death certificate document from the death_verification record. death_verification tracks death_certificate_received_flag and' ;
    rdfs:domain ind:DeathVerification ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Document .

ind:reverificationDeathVerificationId rdf:type rdf:Property ;
    rdfs:label 'Reverification Death Verification Id' ;
    rdfs:comment 'Self-referencing FK on death_verification (reverification_death_verification_id)' ;
    rdfs:domain ind:DeathVerification ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DeathVerification .

ind:apsReceivedFlag rdf:type rdf:Property ;
    rdfs:label 'Aps Received Flag' ;
    rdfs:comment 'Indicates whether an Attending Physician Statement was obtained to verify death and cause.' ;
    rdfs:domain ind:DeathVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:beneficiaryNotifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Beneficiary Notified Flag' ;
    rdfs:comment 'Indicates whether the designated beneficiaries have been notified of the death and claim process.' ;
    rdfs:domain ind:DeathVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:causeOfDeath rdf:type rdf:Property ;
    rdfs:label 'Cause Of Death' ;
    rdfs:comment 'Primary cause of death as documented on the death certificate or medical records.' ;
    rdfs:domain ind:DeathVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimInitiatedFlag rdf:type rdf:Property ;
    rdfs:label 'Claim Initiated Flag' ;
    rdfs:comment 'Indicates whether a death benefit claim has been initiated as a result of this verification.' ;
    rdfs:domain ind:DeathVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:coronerReportFlag rdf:type rdf:Property ;
    rdfs:label 'Coroner Report Flag' ;
    rdfs:comment 'Indicates whether a coroner or medical examiner report was obtained, typically for accidental or suspicious deaths.' ;
    rdfs:domain ind:DeathVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deathCertificateIssueDate rdf:type rdf:Property ;
    rdfs:label 'Death Certificate Issue Date' ;
    rdfs:comment 'Date when the death certificate was officially issued by the vital records authority.' ;
    rdfs:domain ind:DeathVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:deathCertificateIssuingState rdf:type rdf:Property ;
    rdfs:label 'Death Certificate Issuing State' ;
    rdfs:comment 'US state or jurisdiction that issued the death certificate.' ;
    rdfs:domain ind:DeathVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deathCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Death Certificate Number' ;
    rdfs:comment 'Official certificate number from the issuing vital records authority.' ;
    rdfs:domain ind:DeathVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deathDateSource rdf:type rdf:Property ;
    rdfs:label 'Death Date Source' ;
    rdfs:comment 'Source document or system that provided the death date information. [ENUM-REF-CANDIDATE: death_certificate|dmf|obituary|family_report|physician|coroner|hospital|funeral_home — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:DeathVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dmfMatchDate rdf:type rdf:Property ;
    rdfs:label 'Dmf Match Date' ;
    rdfs:comment 'Date when the DMF match was identified during proactive screening.' ;
    rdfs:domain ind:DeathVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dmfMatchFlag rdf:type rdf:Property ;
    rdfs:label 'Dmf Match Flag' ;
    rdfs:comment 'Indicates whether the insured was found in the Social Security Death Master File.' ;
    rdfs:domain ind:DeathVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dmfMatchScore rdf:type rdf:Property ;
    rdfs:label 'Dmf Match Score' ;
    rdfs:comment 'Confidence score of the DMF match based on SSN, name, and date of birth matching algorithms, expressed as a percentage.' ;
    rdfs:domain ind:DeathVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mannerOfDeath rdf:type rdf:Property ;
    rdfs:label 'Manner Of Death' ;
    rdfs:comment 'Classification of how the death occurred, used for underwriting and claims adjudication purposes.' ;
    rdfs:domain ind:DeathVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:obituaryPublicationDate rdf:type rdf:Property ;
    rdfs:label 'Obituary Publication Date' ;
    rdfs:comment 'Date when the obituary was published or posted.' ;
    rdfs:domain ind:DeathVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:obituarySource rdf:type rdf:Property ;
    rdfs:label 'Obituary Source' ;
    rdfs:comment 'Publication or online source where the obituary was found (e.g., newspaper name, funeral home website).' ;
    rdfs:domain ind:DeathVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:obituaryVerifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Obituary Verified Flag' ;
    rdfs:comment 'Indicates whether an obituary notice was found and verified as part of the death verification process.' ;
    rdfs:domain ind:DeathVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:placeOfDeath rdf:type rdf:Property ;
    rdfs:label 'Place Of Death' ;
    rdfs:comment 'Location where the death occurred (e.g., hospital, home, nursing facility, hospice).' ;
    rdfs:domain ind:DeathVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:placeOfDeathCity rdf:type rdf:Property ;
    rdfs:label 'Place Of Death City' ;
    rdfs:comment 'City where the death occurred.' ;
    rdfs:domain ind:DeathVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:placeOfDeathCountry rdf:type rdf:Property ;
    rdfs:label 'Place Of Death Country' ;
    rdfs:comment 'Country where the death occurred, using 3-letter ISO country code.' ;
    rdfs:domain ind:DeathVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:placeOfDeathState rdf:type rdf:Property ;
    rdfs:label 'Place Of Death State' ;
    rdfs:comment 'State or jurisdiction where the death occurred.' ;
    rdfs:domain ind:DeathVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proactiveSearchFlag rdf:type rdf:Property ;
    rdfs:label 'Proactive Search Flag' ;
    rdfs:comment 'Indicates whether this death was discovered through proactive DMF screening rather than beneficiary notification.' ;
    rdfs:domain ind:DeathVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:thirdPartyVerificationService rdf:type rdf:Property ;
    rdfs:label 'Third Party Verification Service' ;
    rdfs:comment 'Name of the external service provider used for death verification (e.g., Lexis Nexis, Accurint, Veris).' ;
    rdfs:domain ind:DeathVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationConfidenceLevel rdf:type rdf:Property ;
    rdfs:label 'Verification Confidence Level' ;
    rdfs:comment 'Overall confidence level in the death verification based on quality and quantity of evidence obtained.' ;
    rdfs:domain ind:DeathVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supersededSurrenderChargeId rdf:type rdf:Property ;
    rdfs:label 'Superseded Surrender Charge Id' ;
    rdfs:comment 'Self-referencing FK on surrender_charge (superseded_surrender_charge_id)' ;
    rdfs:domain ind:SurrenderCharge ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SurrenderCharge .

ind:chargeApplicationMethod rdf:type rdf:Property ;
    rdfs:label 'Charge Application Method' ;
    rdfs:comment 'Method by which surrender charges are applied to withdrawals (e.g., pro-rata across all withdrawals, only on amounts exceeding free withdrawal limit, or tiered based on withdrawal amount).' ;
    rdfs:domain ind:SurrenderCharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chargeCalculationBasis rdf:type rdf:Property ;
    rdfs:label 'Charge Calculation Basis' ;
    rdfs:comment 'The basis upon which the surrender charge is calculated (e.g., current account value, premium paid, or withdrawal amount).' ;
    rdfs:domain ind:SurrenderCharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cumulativeFreeWithdrawalFlag rdf:type rdf:Property ;
    rdfs:label 'Cumulative Free Withdrawal Flag' ;
    rdfs:comment 'Indicates whether unused free withdrawal amounts from prior years can be carried forward and used in subsequent years.' ;
    rdfs:domain ind:SurrenderCharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:freeWithdrawalBasis rdf:type rdf:Property ;
    rdfs:label 'Free Withdrawal Basis' ;
    rdfs:comment 'The basis upon which the free withdrawal amount is calculated (e.g., account value, premium paid, or benefit base).' ;
    rdfs:domain ind:SurrenderCharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mvaFormulaCode rdf:type rdf:Property ;
    rdfs:label 'Mva Formula Code' ;
    rdfs:comment 'Code identifying the specific formula or calculation method used to determine the market value adjustment.' ;
    rdfs:domain ind:SurrenderCharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mvaIndexType rdf:type rdf:Property ;
    rdfs:label 'Mva Index Type' ;
    rdfs:comment 'The interest rate index or benchmark used to calculate the market value adjustment (e.g., 10-Year Treasury, LIBOR).' ;
    rdfs:domain ind:SurrenderCharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:periodYears rdf:type rdf:Property ;
    rdfs:label 'Period Years' ;
    rdfs:comment 'Total number of years during which surrender charges apply to the contract.' ;
    rdfs:domain ind:SurrenderCharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rate rdf:type rdf:Property ;
    rdfs:label 'Rate' ;
    rdfs:comment 'The percentage rate applied to calculate the surrender charge for this contract year, expressed as a decimal (e.g., 0.0800 for 8%).' ;
    rdfs:domain ind:SurrenderCharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:waiverAnnuitizationFlag rdf:type rdf:Property ;
    rdfs:label 'Waiver Annuitization Flag' ;
    rdfs:comment 'Indicates whether surrender charges are waived if the contract is annuitized according to the available payout options.' ;
    rdfs:domain ind:SurrenderCharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:waiverDeathFlag rdf:type rdf:Property ;
    rdfs:label 'Waiver Death Flag' ;
    rdfs:comment 'Indicates whether surrender charges are waived upon the death of the owner or annuitant.' ;
    rdfs:domain ind:SurrenderCharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:waiverDisabilityFlag rdf:type rdf:Property ;
    rdfs:label 'Waiver Disability Flag' ;
    rdfs:comment 'Indicates whether surrender charges are waived if the owner becomes disabled, subject to policy terms.' ;
    rdfs:domain ind:SurrenderCharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:waiverLtcFlag rdf:type rdf:Property ;
    rdfs:label 'Waiver Ltc Flag' ;
    rdfs:comment 'Indicates whether surrender charges are waived if the owner qualifies for long-term care benefits under the contract.' ;
    rdfs:domain ind:SurrenderCharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:waiverNursingHomeFlag rdf:type rdf:Property ;
    rdfs:label 'Waiver Nursing Home Flag' ;
    rdfs:comment 'Indicates whether surrender charges are waived if the owner is confined to a nursing home for a specified period.' ;
    rdfs:domain ind:SurrenderCharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:waiverRmdFlag rdf:type rdf:Property ;
    rdfs:label 'Waiver Rmd Flag' ;
    rdfs:comment 'Indicates whether surrender charges are waived for withdrawals taken to satisfy IRS required minimum distribution requirements.' ;
    rdfs:domain ind:SurrenderCharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:waiverTerminalIllnessFlag rdf:type rdf:Property ;
    rdfs:label 'Waiver Terminal Illness Flag' ;
    rdfs:comment 'Indicates whether surrender charges are waived if the owner is diagnosed with a terminal illness.' ;
    rdfs:domain ind:SurrenderCharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:waiverUnemploymentFlag rdf:type rdf:Property ;
    rdfs:label 'Waiver Unemployment Flag' ;
    rdfs:comment 'Indicates whether surrender charges are waived if the owner becomes involuntarily unemployed.' ;
    rdfs:domain ind:SurrenderCharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:primarySupersededByRegulationStateRegulationId rdf:type rdf:Property ;
    rdfs:label 'Primary Superseded By Regulation State Regulation Id' ;
    rdfs:comment 'Reference to the newer state regulation that replaces this regulation, if applicable. Null if not superseded.' ;
    rdfs:domain ind:StateRegulation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StateRegulation .

ind:acceleratedDeathBenefitRegulationFlag rdf:type rdf:Property ;
    rdfs:label 'Accelerated Death Benefit Regulation Flag' ;
    rdfs:comment 'Indicates whether the state has specific regulations governing accelerated death benefit riders. True if ADB regulations apply, False if not.' ;
    rdfs:domain ind:StateRegulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:bestInterestStandardFlag rdf:type rdf:Property ;
    rdfs:label 'Best Interest Standard Flag' ;
    rdfs:comment 'Indicates whether the state has adopted a best interest standard for annuity sales (similar to Regulation Best Interest). True if best interest standard applies, False if not.' ;
    rdfs:domain ind:StateRegulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contestabilityPeriodMonths rdf:type rdf:Property ;
    rdfs:label 'Contestability Period Months' ;
    rdfs:comment 'Number of months during which the insurer may contest a life insurance policy for material misrepresentation, as mandated by state law. Typically 24 months but may vary by state.' ;
    rdfs:domain ind:StateRegulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:formFilingMethod rdf:type rdf:Property ;
    rdfs:label 'Form Filing Method' ;
    rdfs:comment 'State-mandated method for submitting and approving policy forms (prior approval required before use, file and use after DOI review, use and file with post-use notification, no filing required).' ;
    rdfs:domain ind:StateRegulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:illustrationRegulationFlag rdf:type rdf:Property ;
    rdfs:label 'Illustration Regulation Flag' ;
    rdfs:comment 'Indicates whether the state has specific regulations governing life insurance policy illustrations. True if illustration rules apply, False if not.' ;
    rdfs:domain ind:StateRegulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:insurableInterestRequirement rdf:type rdf:Property ;
    rdfs:label 'Insurable Interest Requirement' ;
    rdfs:comment 'State-specific definition and requirements for establishing insurable interest in life insurance transactions. Describes when insurable interest must exist (at inception, at death, etc.).' ;
    rdfs:domain ind:StateRegulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interestRateGuaranteeMinimum rdf:type rdf:Property ;
    rdfs:label 'Interest Rate Guarantee Minimum' ;
    rdfs:comment 'State-mandated minimum guaranteed interest rate for cash value accumulation in life insurance and annuity products. Expressed as a decimal (e.g., 0.0200 for 2%).' ;
    rdfs:domain ind:StateRegulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:longTermCarePartnershipFlag rdf:type rdf:Property ;
    rdfs:label 'Long Term Care Partnership Flag' ;
    rdfs:comment 'Indicates whether the state participates in the Long-Term Care Partnership Program, allowing policyholders to protect assets while qualifying for Medicaid. True if partnership state, False if not.' ;
    rdfs:domain ind:StateRegulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:minimumCashSurrenderValuePercentage rdf:type rdf:Property ;
    rdfs:label 'Minimum Cash Surrender Value Percentage' ;
    rdfs:comment 'State-mandated minimum cash surrender value as a percentage of premiums paid or reserves, as required by nonforfeiture laws. Null if no state-specific requirement.' ;
    rdfs:domain ind:StateRegulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumDeathBenefitAmount rdf:type rdf:Property ;
    rdfs:label 'Minimum Death Benefit Amount' ;
    rdfs:comment 'State-mandated minimum death benefit amount for life insurance policies issued in the jurisdiction. Null if no state-specific minimum applies.' ;
    rdfs:domain ind:StateRegulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nonforfeitureMethod rdf:type rdf:Property ;
    rdfs:label 'Nonforfeiture Method' ;
    rdfs:comment 'State-mandated method for calculating nonforfeiture values (Commissioners Reserve Valuation Method, Commissioners Extended Term Method, Cash Surrender Value Method).' ;
    rdfs:domain ind:StateRegulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nonforfeitureRequirementFlag rdf:type rdf:Property ;
    rdfs:label 'Nonforfeiture Requirement Flag' ;
    rdfs:comment 'Indicates whether the state mandates nonforfeiture benefits (cash surrender value, reduced paid-up insurance, extended term insurance) for this product type. True if required, False if not.' ;
    rdfs:domain ind:StateRegulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rateFilingMethod rdf:type rdf:Property ;
    rdfs:label 'Rate Filing Method' ;
    rdfs:comment 'State-mandated method for submitting and approving insurance rates (prior approval required before use, file and use after DOI review, use and file with post-use notification, no filing required).' ;
    rdfs:domain ind:StateRegulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulationDescription rdf:type rdf:Property ;
    rdfs:label 'Regulation Description' ;
    rdfs:comment 'Detailed description of the state-specific regulatory requirement, including key provisions, applicability conditions, and compliance obligations.' ;
    rdfs:domain ind:StateRegulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulationStatus rdf:type rdf:Property ;
    rdfs:label 'Regulation Status' ;
    rdfs:comment 'Current lifecycle status of the state regulation (active, superseded by newer regulation, pending approval, withdrawn).' ;
    rdfs:domain ind:StateRegulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulationType rdf:type rdf:Property ;
    rdfs:label 'Regulation Type' ;
    rdfs:comment 'Category of state-specific insurance regulation (policy form approval, rate filing requirements, nonforfeiture standards, free look period, grace period, replacement regulations).' ;
    rdfs:domain ind:StateRegulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:replacementNoticeRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Replacement Notice Required Flag' ;
    rdfs:comment 'Indicates whether the state requires written notice to the existing insurer when a policy replacement is proposed. True if notice required, False if not.' ;
    rdfs:domain ind:StateRegulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:replacementRegulationFlag rdf:type rdf:Property ;
    rdfs:label 'Replacement Regulation Flag' ;
    rdfs:comment 'Indicates whether the state has specific regulations governing policy replacement transactions (1035 exchanges, internal replacements). True if state has replacement rules, False if not.' ;
    rdfs:domain ind:StateRegulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:serffFilingRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Serff Filing Required Flag' ;
    rdfs:comment 'Indicates whether the state requires rate and form filings to be submitted through the NAIC SERFF system. True if SERFF required, False if alternative methods allowed.' ;
    rdfs:domain ind:StateRegulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:stoliProhibitionFlag rdf:type rdf:Property ;
    rdfs:label 'Stoli Prohibition Flag' ;
    rdfs:comment 'Indicates whether the state has enacted specific prohibitions against stranger-originated life insurance transactions. True if STOLI prohibited, False if not.' ;
    rdfs:domain ind:StateRegulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:suicideExclusionPeriodMonths rdf:type rdf:Property ;
    rdfs:label 'Suicide Exclusion Period Months' ;
    rdfs:comment 'Number of months during which death by suicide is excluded from life insurance coverage, as mandated by state law. Typically 24 months but may vary by state.' ;
    rdfs:domain ind:StateRegulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:suitabilityReviewRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Suitability Review Required Flag' ;
    rdfs:comment 'Indicates whether the state mandates suitability reviews and documentation for annuity sales. True if suitability review required, False if not.' ;
    rdfs:domain ind:StateRegulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:variableProductRegistrationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Variable Product Registration Required Flag' ;
    rdfs:comment 'Indicates whether the state requires separate registration or approval for variable life and variable annuity products beyond standard form filing. True if additional registration required, False if not.' ;
    rdfs:domain ind:StateRegulation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:baseMortalityTableId rdf:type rdf:Property ;
    rdfs:label 'Base Mortality Table Id' ;
    rdfs:comment 'Self-referencing FK on mortality_table (base_mortality_table_id)' ;
    rdfs:domain ind:MortalityTable ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MortalityTable .

ind:gaapCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Gaap Compliant Flag' ;
    rdfs:comment 'Indicates whether the mortality table is acceptable for use under US GAAP accounting, including Long Duration Targeted Improvements (LDTI) under ASC 944. True if compliant, False otherwise.' ;
    rdfs:domain ind:MortalityTable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:genderBasis rdf:type rdf:Property ;
    rdfs:label 'Gender Basis' ;
    rdfs:comment 'Gender segmentation approach used in the mortality table: male (male-only rates), female (female-only rates), unisex (blended rates), gender_distinct (separate male/female rates within same table), or composite (weighted average).' ;
    rdfs:domain ind:MortalityTable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ifrs17CompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Ifrs17 Compliant Flag' ;
    rdfs:comment 'Indicates whether the mortality table is suitable for use under IFRS 17 insurance contract accounting standards. True if compliant, False otherwise.' ;
    rdfs:domain ind:MortalityTable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:predecessorTableCode rdf:type rdf:Property ;
    rdfs:label 'Predecessor Table Code' ;
    rdfs:comment 'Code of the mortality table that this table supersedes or replaces. Null if this is an original table with no predecessor. Provides backward lineage tracking.' ;
    rdfs:domain ind:MortalityTable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Sap Compliant Flag' ;
    rdfs:comment 'Indicates whether the mortality table is prescribed or permitted for use under Statutory Accounting Principles (SAP) for regulatory financial reporting. True if compliant, False otherwise.' ;
    rdfs:domain ind:MortalityTable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:selectPeriodYears rdf:type rdf:Property ;
    rdfs:label 'Select Period Years' ;
    rdfs:comment 'Number of years in the select period during which mortality rates reflect the impact of recent underwriting. After the select period, rates transition to ultimate rates. Null if the table has no select period (ultimate-only table).' ;
    rdfs:domain ind:MortalityTable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:smokerClass rdf:type rdf:Property ;
    rdfs:label 'Smoker Class' ;
    rdfs:comment 'Smoking status segmentation in the mortality table: smoker (tobacco users), non_smoker (non-tobacco users), aggregate (blended rates), preferred_non_smoker (best non-smoker class), standard_non_smoker (standard non-smoker class), or tobacco_user (broader tobacco definition).' ;
    rdfs:domain ind:MortalityTable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supersededByTableCode rdf:type rdf:Property ;
    rdfs:label 'Superseded By Table Code' ;
    rdfs:comment 'Code of the mortality table that replaces this table. Null if the table has not been superseded. Used to track table version lineage and ensure proper transition to updated tables.' ;
    rdfs:domain ind:MortalityTable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tableCode rdf:type rdf:Property ;
    rdfs:label 'Table Code' ;
    rdfs:comment 'Standardized code identifier for the mortality table (e.g., CSO2017, VBT2015, 2001CSO). Used as the business key for referencing the table in actuarial systems.' ;
    rdfs:domain ind:MortalityTable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tableName rdf:type rdf:Property ;
    rdfs:label 'Table Name' ;
    rdfs:comment 'Full descriptive name of the mortality table (e.g., 2017 Commissioners Standard Ordinary Mortality Table, 2015 Valuation Basic Table).' ;
    rdfs:domain ind:MortalityTable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tableStatus rdf:type rdf:Property ;
    rdfs:label 'Table Status' ;
    rdfs:comment 'Current lifecycle status of the mortality table: active (currently in use), superseded (replaced by newer table), archived (historical reference only), pending_approval (awaiting regulatory or actuarial approval), or withdrawn (no longer valid).' ;
    rdfs:domain ind:MortalityTable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tableType rdf:type rdf:Property ;
    rdfs:label 'Table Type' ;
    rdfs:comment 'Classification of the mortality table by its intended actuarial use: valuation (statutory reserve calculations), pricing (product development), underwriting (risk assessment), experience (company-specific studies), reinsurance (treaty pricing), or illustration (sales projections).' ;
    rdfs:domain ind:MortalityTable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ultimateAgeMax rdf:type rdf:Property ;
    rdfs:label 'Ultimate Age Max' ;
    rdfs:comment 'Maximum attained age covered by the ultimate mortality rates in the table. Represents the oldest age for which mortality rates are defined, typically 100, 110, or 120.' ;
    rdfs:domain ind:MortalityTable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ultimateAgeMin rdf:type rdf:Property ;
    rdfs:label 'Ultimate Age Min' ;
    rdfs:comment 'Minimum attained age covered by the ultimate mortality rates in the table. Typically the age at which select period ends or the youngest age in an ultimate-only table.' ;
    rdfs:domain ind:MortalityTable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:priorSarFilingId rdf:type rdf:Property ;
    rdfs:label 'Prior Sar Filing Id' ;
    rdfs:comment 'Self-referencing FK on sar_filing (prior_sar_filing_id)' ;
    rdfs:domain ind:SarFiling ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SarFiling .

ind:sarDocumentId rdf:type rdf:Property ;
    rdfs:label 'Sar Document Id' ;
    rdfs:comment 'Foreign key linking to document.document. Business justification: SAR filings are formal FinCEN documents with narrative descriptions and supporting evidence required by BSA/AML regulations. Critical for AML regulatory reporting and FinCEN submission tracking in Lif' ;
    rdfs:domain ind:SarFiling ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Document .

ind:acknowledgmentDate rdf:type rdf:Property ;
    rdfs:label 'Acknowledgment Date' ;
    rdfs:comment 'Date when FinCEN acknowledged receipt of the SAR filing. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:SarFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:confidentialityFlag rdf:type rdf:Property ;
    rdfs:label 'Confidentiality Flag' ;
    rdfs:comment 'Indicates that this SAR filing is subject to strict confidentiality requirements under the Bank Secrecy Act. Always True for SAR filings.' ;
    rdfs:domain ind:SarFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fincenBsaNumber rdf:type rdf:Property ;
    rdfs:label 'Fincen Bsa Number' ;
    rdfs:comment 'Unique identifier assigned by FinCEN upon successful submission of the SAR. Also known as the BSA Identifier or acknowledgment number.' ;
    rdfs:domain ind:SarFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lawEnforcementContactFlag rdf:type rdf:Property ;
    rdfs:label 'Law Enforcement Contact Flag' ;
    rdfs:comment 'Indicates whether law enforcement has been contacted regarding this suspicious activity. True if contacted, False otherwise.' ;
    rdfs:domain ind:SarFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:narrativeDescription rdf:type rdf:Property ;
    rdfs:label 'Narrative Description' ;
    rdfs:comment 'Detailed narrative description of the suspicious activity, including facts, circumstances, and reasons for suspicion. This is the core content of the SAR filing.' ;
    rdfs:domain ind:SarFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorSarReference rdf:type rdf:Property ;
    rdfs:label 'Prior Sar Reference' ;
    rdfs:comment 'Reference to a prior SAR filing if this is a continuing, corrected, or amended SAR. Contains the FinCEN BSA ID of the prior SAR.' ;
    rdfs:domain ind:SarFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subjectAddress rdf:type rdf:Property ;
    rdfs:label 'Subject Address' ;
    rdfs:comment 'Full address of the subject involved in the suspicious activity.' ;
    rdfs:domain ind:SarFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baseScenarioSetId rdf:type rdf:Property ;
    rdfs:label 'Base Scenario Set Id' ;
    rdfs:comment 'Self-referencing FK on scenario_set (base_scenario_set_id)' ;
    rdfs:domain ind:ScenarioSet ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ScenarioSet .

ind:confidenceLevel rdf:type rdf:Property ;
    rdfs:label 'Confidence Level' ;
    rdfs:comment 'Statistical confidence level for scenario set results, expressed as a decimal (e.g., 0.9500 for 95% confidence). Used in CTE (Conditional Tail Expectation) calculations.' ;
    rdfs:domain ind:ScenarioSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditSpreadModel rdf:type rdf:Property ;
    rdfs:label 'Credit Spread Model' ;
    rdfs:comment 'Name of the credit spread model used for corporate bond scenarios in the set.' ;
    rdfs:domain ind:ScenarioSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:economicScenarioGenerator rdf:type rdf:Property ;
    rdfs:label 'Economic Scenario Generator' ;
    rdfs:comment 'Name or identifier of the economic scenario generator software or model used to produce this scenario set (e.g., Conning, Milliman GEMS, Moody\'s RiskIntegrity).' ;
    rdfs:domain ind:ScenarioSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equityModel rdf:type rdf:Property ;
    rdfs:label 'Equity Model' ;
    rdfs:comment 'Name of the equity return model used in the scenario set (e.g., Geometric Brownian Motion, Regime-Switching).' ;
    rdfs:domain ind:ScenarioSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:esgVersion rdf:type rdf:Property ;
    rdfs:label 'Esg Version' ;
    rdfs:comment 'Version number or release identifier of the economic scenario generator used.' ;
    rdfs:domain ind:ScenarioSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicScope rdf:type rdf:Property ;
    rdfs:label 'Geographic Scope' ;
    rdfs:comment 'Geographic market or region for which the scenario set is calibrated, using 3-letter country codes or scope descriptors.' ;
    rdfs:domain ind:ScenarioSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interestRateModel rdf:type rdf:Property ;
    rdfs:label 'Interest Rate Model' ;
    rdfs:comment 'Name of the interest rate model used in the scenario set (e.g., Cox-Ingersoll-Ross, Hull-White, Black-Karasinski).' ;
    rdfs:domain ind:ScenarioSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:meanReversionParameter rdf:type rdf:Property ;
    rdfs:label 'Mean Reversion Parameter' ;
    rdfs:comment 'Mean reversion speed parameter used in interest rate or economic models, if applicable.' ;
    rdfs:domain ind:ScenarioSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:modelingPurpose rdf:type rdf:Property ;
    rdfs:label 'Modeling Purpose' ;
    rdfs:comment 'Primary business purpose for which this scenario set is designed: valuation, pricing, forecasting, capital planning, risk management, or regulatory reporting.' ;
    rdfs:domain ind:ScenarioSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectionHorizonYears rdf:type rdf:Property ;
    rdfs:label 'Projection Horizon Years' ;
    rdfs:comment 'Number of years into the future that scenarios in this set project, representing the modeling time horizon.' ;
    rdfs:domain ind:ScenarioSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:riskNeutralFlag rdf:type rdf:Property ;
    rdfs:label 'Risk Neutral Flag' ;
    rdfs:comment 'Indicates whether the scenario set uses risk-neutral (market-consistent) assumptions (True) or real-world assumptions (False).' ;
    rdfs:domain ind:ScenarioSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scenarioSetCode rdf:type rdf:Property ;
    rdfs:label 'Scenario Set Code' ;
    rdfs:comment 'Business identifier code for the scenario set, used for external reference and reporting.' ;
    rdfs:domain ind:ScenarioSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scenarioSetDescription rdf:type rdf:Property ;
    rdfs:label 'Scenario Set Description' ;
    rdfs:comment 'Detailed description of the scenario set including its purpose, assumptions, and intended use cases.' ;
    rdfs:domain ind:ScenarioSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scenarioSetName rdf:type rdf:Property ;
    rdfs:label 'Scenario Set Name' ;
    rdfs:comment 'Human-readable name of the scenario set describing its purpose or use case.' ;
    rdfs:domain ind:ScenarioSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scenarioSetStatus rdf:type rdf:Property ;
    rdfs:label 'Scenario Set Status' ;
    rdfs:comment 'Current lifecycle status of the scenario set: draft (under development), approved (validated but not yet active), active (in production use), archived (historical reference), deprecated (no longer recommended), or under review (validation in progress).' ;
    rdfs:domain ind:ScenarioSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seedValue rdf:type rdf:Property ;
    rdfs:label 'Seed Value' ;
    rdfs:comment 'Random number generator seed value used to produce stochastic scenarios, enabling reproducibility of results.' ;
    rdfs:domain ind:ScenarioSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:stochasticTrialCount rdf:type rdf:Property ;
    rdfs:label 'Stochastic Trial Count' ;
    rdfs:comment 'Number of stochastic trials or paths generated for stochastic scenario sets. Null for deterministic scenarios.' ;
    rdfs:domain ind:ScenarioSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tailPercentile rdf:type rdf:Property ;
    rdfs:label 'Tail Percentile' ;
    rdfs:comment 'Percentile threshold for tail risk analysis (e.g., 0.9000 for 90th percentile), used in CTE and stress testing.' ;
    rdfs:domain ind:ScenarioSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:timeStepFrequency rdf:type rdf:Property ;
    rdfs:label 'Time Step Frequency' ;
    rdfs:comment 'Frequency of time steps within scenario projections: monthly, quarterly, annual, or daily intervals.' ;
    rdfs:domain ind:ScenarioSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationStatus rdf:type rdf:Property ;
    rdfs:label 'Validation Status' ;
    rdfs:comment 'Current status of independent model validation for this scenario set.' ;
    rdfs:domain ind:ScenarioSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:volatilityAssumption rdf:type rdf:Property ;
    rdfs:label 'Volatility Assumption' ;
    rdfs:comment 'Base volatility assumption used in stochastic modeling, expressed as a decimal (e.g., 0.1500 for 15% volatility).' ;
    rdfs:domain ind:ScenarioSet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:primaryTerminationProducerId rdf:type rdf:Property ;
    rdfs:label 'Primary Termination Producer Id' ;
    rdfs:comment 'Identifier of the agent whose contract or appointment is being terminated.' ;
    rdfs:domain ind:TerminationEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Producer .

ind:reinstatedTerminationEventId rdf:type rdf:Property ;
    rdfs:label 'Reinstated Termination Event Id' ;
    rdfs:comment 'Self-referencing FK on termination_event (reinstated_termination_event_id)' ;
    rdfs:domain ind:TerminationEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TerminationEvent .

ind:terminationDocumentId rdf:type rdf:Property ;
    rdfs:label 'Termination Document Id' ;
    rdfs:comment 'Foreign key linking to document.document. Business justification: Termination events generate regulatory documents including FINRA U5 filings, state termination notices, and severance agreements. Regulators and compliance teams require direct linkage between the ter' ;
    rdfs:domain ind:TerminationEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Document .

ind:bookOfBusinessTransferIndicator rdf:type rdf:Property ;
    rdfs:label 'Book Of Business Transfer Indicator' ;
    rdfs:comment 'Boolean flag indicating whether the agent\'s book of business (client policies) is being transferred to another agent.' ;
    rdfs:domain ind:TerminationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:bookTransferEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Book Transfer Effective Date' ;
    rdfs:comment 'The date on which the book of business transfer to the successor agent becomes effective.' ;
    rdfs:domain ind:TerminationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:commissionPayoutStatus rdf:type rdf:Property ;
    rdfs:label 'Commission Payout Status' ;
    rdfs:comment 'Status of outstanding commission payments owed to the agent at the time of termination.' ;
    rdfs:domain ind:TerminationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractEndDate rdf:type rdf:Property ;
    rdfs:label 'Contract End Date' ;
    rdfs:comment 'The final date of the agent\'s contract or appointment, which may differ from the termination effective date in cases of notice periods.' ;
    rdfs:domain ind:TerminationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:exitInterviewCompletedIndicator rdf:type rdf:Property ;
    rdfs:label 'Exit Interview Completed Indicator' ;
    rdfs:comment 'Boolean flag indicating whether an exit interview was conducted with the agent as part of the termination process.' ;
    rdfs:domain ind:TerminationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:exitInterviewDate rdf:type rdf:Property ;
    rdfs:label 'Exit Interview Date' ;
    rdfs:comment 'The date on which the exit interview with the terminated agent was conducted.' ;
    rdfs:domain ind:TerminationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:finalCommissionPayoutDate rdf:type rdf:Property ;
    rdfs:label 'Final Commission Payout Date' ;
    rdfs:comment 'The date on which the final commission payment was or will be issued to the terminated agent.' ;
    rdfs:domain ind:TerminationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:finraFormU5FiledDate rdf:type rdf:Property ;
    rdfs:label 'Finra Form U5 Filed Date' ;
    rdfs:comment 'The date on which FINRA Form U5 (Uniform Termination Notice for Securities Industry Registration) was filed for this agent termination.' ;
    rdfs:domain ind:TerminationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:finraReportableIndicator rdf:type rdf:Property ;
    rdfs:label 'Finra Reportable Indicator' ;
    rdfs:comment 'Boolean flag indicating whether this termination must be reported to FINRA due to the agent\'s registration for variable product sales.' ;
    rdfs:domain ind:TerminationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:forCauseIndicator rdf:type rdf:Property ;
    rdfs:label 'For Cause Indicator' ;
    rdfs:comment 'Boolean flag indicating whether the termination was for cause (due to misconduct, policy violation, or performance failure) versus without cause.' ;
    rdfs:domain ind:TerminationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:initiatingPartyName rdf:type rdf:Property ;
    rdfs:label 'Initiating Party Name' ;
    rdfs:comment 'Name of the specific individual or department that initiated the termination process.' ;
    rdfs:domain ind:TerminationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryReportableIndicator rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reportable Indicator' ;
    rdfs:comment 'Boolean flag indicating whether this termination event must be reported to state insurance departments or regulatory authorities.' ;
    rdfs:domain ind:TerminationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rehireEligibleIndicator rdf:type rdf:Property ;
    rdfs:label 'Rehire Eligible Indicator' ;
    rdfs:comment 'Boolean flag indicating whether the terminated agent is eligible for future rehire or reappointment with the company.' ;
    rdfs:domain ind:TerminationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:severanceAmount rdf:type rdf:Property ;
    rdfs:label 'Severance Amount' ;
    rdfs:comment 'Total monetary severance payment provided to the agent upon termination, if applicable.' ;
    rdfs:domain ind:TerminationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:severanceEligibleIndicator rdf:type rdf:Property ;
    rdfs:label 'Severance Eligible Indicator' ;
    rdfs:comment 'Boolean flag indicating whether the agent is eligible for severance pay or benefits as part of the termination.' ;
    rdfs:domain ind:TerminationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:terminationEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Termination Effective Date' ;
    rdfs:comment 'The date on which the agent termination becomes legally and operationally effective, marking the end of the agent\'s active status.' ;
    rdfs:domain ind:TerminationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:terminationNotes rdf:type rdf:Property ;
    rdfs:label 'Termination Notes' ;
    rdfs:comment 'Internal confidential notes and comments regarding the termination event, including any special circumstances or follow-up actions required.' ;
    rdfs:domain ind:TerminationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminationNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Termination Notification Date' ;
    rdfs:comment 'The date on which the agent was formally notified of the termination decision.' ;
    rdfs:domain ind:TerminationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:terminationNumber rdf:type rdf:Property ;
    rdfs:label 'Termination Number' ;
    rdfs:comment 'Business-facing unique identifier for the termination event, used in correspondence and reporting.' ;
    rdfs:domain ind:TerminationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminationRequestDate rdf:type rdf:Property ;
    rdfs:label 'Termination Request Date' ;
    rdfs:comment 'The date on which the termination was initially requested or initiated, either by the agent or the company.' ;
    rdfs:domain ind:TerminationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:terminationStatus rdf:type rdf:Property ;
    rdfs:label 'Termination Status' ;
    rdfs:comment 'Current workflow status of the termination event indicating its stage in the termination process.' ;
    rdfs:domain ind:TerminationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentDocumentTypeId rdf:type rdf:Property ;
    rdfs:label 'Parent Document Type Id' ;
    rdfs:comment 'Self-referencing FK on document_type (parent_document_type_id)' ;
    rdfs:domain ind:Type ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Type .

ind:customerFacingFlag rdf:type rdf:Property ;
    rdfs:label 'Customer Facing Flag' ;
    rdfs:comment 'Indicates whether this document type is typically sent to or received from customers, agents, or external parties.' ;
    rdfs:domain ind:Type ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:defaultMimeType rdf:type rdf:Property ;
    rdfs:label 'Default Mime Type' ;
    rdfs:comment 'Standard MIME type for the typical file format used for this document type (e.g., application/pdf for PDF documents).' ;
    rdfs:domain ind:Type ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disclosureType rdf:type rdf:Property ;
    rdfs:label 'Disclosure Type' ;
    rdfs:comment 'Classification of disclosure requirements associated with this document type for regulatory compliance tracking.' ;
    rdfs:domain ind:Type ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentTypeCategory rdf:type rdf:Property ;
    rdfs:label 'Document Type Category' ;
    rdfs:comment 'High-level classification of the document type grouping similar documents together for organizational and retrieval purposes.' ;
    rdfs:domain ind:Type ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentTypeCode rdf:type rdf:Property ;
    rdfs:label 'Document Type Code' ;
    rdfs:comment 'Short alphanumeric code uniquely identifying the document type (e.g., POL_APP for policy application, ILLUS for illustration, APS for attending physician statement). Used as business identifier in operational systems.' ;
    rdfs:domain ind:Type ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentTypeDescription rdf:type rdf:Property ;
    rdfs:label 'Document Type Description' ;
    rdfs:comment 'Detailed business description explaining the purpose, usage, and context of the document type.' ;
    rdfs:domain ind:Type ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentTypeName rdf:type rdf:Property ;
    rdfs:label 'Document Type Name' ;
    rdfs:comment 'Full descriptive name of the document type (e.g., Policy Application, Beneficiary Change Form, Annual Statement).' ;
    rdfs:domain ind:Type ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentTypeStatus rdf:type rdf:Property ;
    rdfs:label 'Document Type Status' ;
    rdfs:comment 'Current lifecycle status of the document type indicating whether it is actively used in business operations.' ;
    rdfs:domain ind:Type ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eSignatureAllowedFlag rdf:type rdf:Property ;
    rdfs:label 'E Signature Allowed Flag' ;
    rdfs:comment 'Indicates whether electronic signatures are legally acceptable for this document type under ESIGN Act and state regulations.' ;
    rdfs:domain ind:Type ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:imagingRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Imaging Required Flag' ;
    rdfs:comment 'Indicates whether physical copies of this document type must be scanned and stored in the document imaging system.' ;
    rdfs:domain ind:Type ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Required Flag' ;
    rdfs:comment 'Indicates whether this document type is mandated by state Department of Insurance (DOI) or federal regulations.' ;
    rdfs:domain ind:Type ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:retentionTrigger rdf:type rdf:Property ;
    rdfs:label 'Retention Trigger' ;
    rdfs:comment 'The business event that starts the retention period clock (e.g., policy termination date, claim closure date).' ;
    rdfs:domain ind:Type ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stateFilingRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'State Filing Required Flag' ;
    rdfs:comment 'Indicates whether this document type must be filed with state Department of Insurance for approval before use.' ;
    rdfs:domain ind:Type ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:templateAvailableFlag rdf:type rdf:Property ;
    rdfs:label 'Template Available Flag' ;
    rdfs:comment 'Indicates whether a standard template exists for generating this document type in document composition systems.' ;
    rdfs:domain ind:Type ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:versionControlRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Version Control Required Flag' ;
    rdfs:comment 'Indicates whether this document type requires formal version tracking and audit trail of changes.' ;
    rdfs:domain ind:Type ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:followUpEvidenceReviewId rdf:type rdf:Property ;
    rdfs:label 'Follow Up Evidence Review Id' ;
    rdfs:comment 'Self-referencing FK on evidence_review (follow_up_evidence_review_id)' ;
    rdfs:domain ind:EvidenceReview ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EvidenceReview .

ind:evidenceReceivedDate rdf:type rdf:Property ;
    rdfs:label 'Evidence Received Date' ;
    rdfs:comment 'Date when the evidence document or report was received by the underwriting department.' ;
    rdfs:domain ind:EvidenceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:evidenceTypeCode rdf:type rdf:Property ;
    rdfs:label 'Evidence Type Code' ;
    rdfs:comment 'Type of underwriting evidence being reviewed. APS=Attending Physician Statement, MIB=Medical Information Bureau report, LAB=Laboratory results, EKG=Electrocardiogram, PARA=Paramedical exam, MVR=Motor Vehicle Record.' ;
    rdfs:domain ind:EvidenceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exclusionRiderRecommended rdf:type rdf:Property ;
    rdfs:label 'Exclusion Rider Recommended' ;
    rdfs:comment 'Indicates whether an exclusion rider is recommended based on the evidence findings.' ;
    rdfs:domain ind:EvidenceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:facultativeReinsuranceRequired rdf:type rdf:Property ;
    rdfs:label 'Facultative Reinsurance Required' ;
    rdfs:comment 'Indicates whether facultative reinsurance placement is required for this case based on evidence review.' ;
    rdfs:domain ind:EvidenceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:icdCode rdf:type rdf:Property ;
    rdfs:label 'Icd Code' ;
    rdfs:comment 'ICD-10 diagnosis code associated with the medical condition identified in the evidence.' ;
    rdfs:domain ind:EvidenceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:medicalConditionIdentified rdf:type rdf:Property ;
    rdfs:label 'Medical Condition Identified' ;
    rdfs:comment 'Primary medical condition or finding identified in the evidence that impacts underwriting decision.' ;
    rdfs:domain ind:EvidenceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:medicalDirectorReviewRequired rdf:type rdf:Property ;
    rdfs:label 'Medical Director Review Required' ;
    rdfs:comment 'Indicates whether the evidence requires escalation to the medical director for expert clinical review.' ;
    rdfs:domain ind:EvidenceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mibCodeIdentified rdf:type rdf:Property ;
    rdfs:label 'Mib Code Identified' ;
    rdfs:comment 'MIB code identified in the evidence that indicates a specific medical or non-medical risk factor.' ;
    rdfs:domain ind:EvidenceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:peerReviewCompletionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Peer Review Completion Timestamp' ;
    rdfs:comment 'Date and time when the peer review was completed.' ;
    rdfs:domain ind:EvidenceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:peerReviewRequired rdf:type rdf:Property ;
    rdfs:label 'Peer Review Required' ;
    rdfs:comment 'Indicates whether a peer review by another underwriter is required for quality assurance purposes.' ;
    rdfs:domain ind:EvidenceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:qualityScore rdf:type rdf:Property ;
    rdfs:label 'Quality Score' ;
    rdfs:comment 'Quality score assigned to the evidence document based on completeness, legibility, and relevance (scale 1-10).' ;
    rdfs:domain ind:EvidenceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ratingActionRecommended rdf:type rdf:Property ;
    rdfs:label 'Rating Action Recommended' ;
    rdfs:comment 'Underwriting rating action recommended based on the evidence review findings.' ;
    rdfs:domain ind:EvidenceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reinsuranceReferralRequired rdf:type rdf:Property ;
    rdfs:label 'Reinsurance Referral Required' ;
    rdfs:comment 'Indicates whether the case must be referred to reinsurance based on evidence findings and retention limits.' ;
    rdfs:domain ind:EvidenceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reviewCompletionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Review Completion Timestamp' ;
    rdfs:comment 'Date and time when the evidence review was completed.' ;
    rdfs:domain ind:EvidenceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:reviewOutcome rdf:type rdf:Property ;
    rdfs:label 'Review Outcome' ;
    rdfs:comment 'Overall outcome of the evidence review from an underwriting perspective.' ;
    rdfs:domain ind:EvidenceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewPriority rdf:type rdf:Property ;
    rdfs:label 'Review Priority' ;
    rdfs:comment 'Priority level assigned to this evidence review based on business rules and case characteristics.' ;
    rdfs:domain ind:EvidenceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Review Start Timestamp' ;
    rdfs:comment 'Date and time when the underwriter began reviewing the evidence.' ;
    rdfs:domain ind:EvidenceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:riskImpactAssessment rdf:type rdf:Property ;
    rdfs:label 'Risk Impact Assessment' ;
    rdfs:comment 'Assessment of how the evidence findings impact the overall mortality or morbidity risk evaluation.' ;
    rdfs:domain ind:EvidenceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tableRatingValue rdf:type rdf:Property ;
    rdfs:label 'Table Rating Value' ;
    rdfs:comment 'Numeric table rating value recommended (e.g., Table 2, Table 4) if table rating action is recommended.' ;
    rdfs:domain ind:EvidenceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:turnaroundTimeHours rdf:type rdf:Property ;
    rdfs:label 'Turnaround Time Hours' ;
    rdfs:comment 'Total time in hours from evidence receipt to review completion, used for service level monitoring.' ;
    rdfs:domain ind:EvidenceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:planRiderEligibilityId rdf:type rdf:Property ;
    rdfs:label 'Plan Rider Eligibility Id' ;
    rdfs:comment 'Primary key for the plan_rider_eligibility association' ;
    rdfs:domain ind:PlanRiderEligibility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:eligibleBaseProductTypes rdf:type rdf:Property ;
    rdfs:label 'Eligible Base Product Types' ;
    rdfs:comment 'Comma-separated list of base product types (WL, UL, IUL, VUL, YRT, FIA, SPIA) to which this rider can be attached. Defines product compatibility rules. [ENUM-REF-CANDIDATE: WL|UL|IUL|VUL|YRT|FIA|SPIA|GMAB|GMDB|GMIB|GMWB|DI — promote to reference product] [Moved from rider_definition: This comma-separated string on rider_definition is a coarse approximation of plan-level eligibility. With the plan_rider_eligibility association table providing precise plan-by-plan eligibility records, this denormalized field becomes redundant and should be deprecated. The association table supersedes it with proper granularity, effective dating, and mandatory/optional designation.]' ;
    rdfs:domain ind:PlanRiderEligibility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riderSequenceOrder rdf:type rdf:Property ;
    rdfs:label 'Rider Sequence Order' ;
    rdfs:comment 'The display and processing sequence order of this rider relative to other riders on the same base plan. Used by illustration software and policy administration systems to order riders consistently on policy documents and admin screens.' ;
    rdfs:domain ind:PlanRiderEligibility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:stateAvailabilityOverride rdf:type rdf:Property ;
    rdfs:label 'State Availability Override' ;
    rdfs:comment 'Comma-separated list of state codes where this plan-rider combination has availability that differs from the rider definition\'s general state availability. Allows plan-specific state eligibility rules to override the rider-level defaults.' ;
    rdfs:domain ind:PlanRiderEligibility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planUnderwritingEligibilityId rdf:type rdf:Property ;
    rdfs:label 'Plan Underwriting Eligibility Id' ;
    rdfs:comment 'Primary key for the plan_underwriting_eligibility association' ;
    rdfs:domain ind:PlanUnderwritingEligibility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:eligibilityOverrideCriteria rdf:type rdf:Property ;
    rdfs:label 'Eligibility Override Criteria' ;
    rdfs:comment 'Plan-specific override to the standard underwriting class eligibility criteria defined on the underwriting_class record. Captures additional or modified health, lifestyle, or risk requirements that apply only when this class is used with this plan. Null if no override applies.' ;
    rdfs:domain ind:PlanUnderwritingEligibility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumFaceAmountOverride rdf:type rdf:Property ;
    rdfs:label 'Minimum Face Amount Override' ;
    rdfs:comment 'Plan-specific minimum death benefit face amount required to qualify for this underwriting class under this plan. Overrides the class-level face_amount_minimum when set. Null if the class-level default applies without modification.' ;
    rdfs:domain ind:PlanUnderwritingEligibility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stateSpecificRestrictions rdf:type rdf:Property ;
    rdfs:label 'State Specific Restrictions' ;
    rdfs:comment 'Comma-separated list of two-letter state codes where this plan-class combination is restricted or prohibited, beyond the general state approvals on either the plan or the underwriting class. Captures regulatory filing outcomes specific to this combination.' ;
    rdfs:domain ind:PlanUnderwritingEligibility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleExecutionResultId rdf:type rdf:Property ;
    rdfs:label 'Rule Execution Result Id' ;
    rdfs:comment 'Primary key for the rule_execution_result association' ;
    rdfs:domain ind:RuleExecutionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:declineReasonCodes rdf:type rdf:Property ;
    rdfs:label 'Decline Reason Codes' ;
    rdfs:comment 'Comma-separated list of reason codes for rules that triggered an automated decline recommendation. Used for adverse action notices and regulatory compliance. [Moved from rules_engine_output: This comma-separated string on rules_engine_output is a denormalized encoding of individual rule FAIL outcomes. Each decline reason code corresponds to a specific rule that fired with a FAIL result. The correct model is one rule_execution_result record per fired rule with result=FAIL, making this field redundant and replaceable by querying the association table.]' ;
    rdfs:domain ind:RuleExecutionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:executionSequence rdf:type rdf:Property ;
    rdfs:label 'Execution Sequence' ;
    rdfs:comment 'The ordinal position in which this rule was evaluated within the rules engine execution. Critical for audit and debugging purposes, as rule execution order can affect downstream rule conditions in chained rule logic.' ;
    rdfs:domain ind:RuleExecutionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:firedFlag rdf:type rdf:Property ;
    rdfs:label 'Fired Flag' ;
    rdfs:comment 'Indicates whether this rule actually triggered (fired) during the evaluation. A rule may be in scope for an evaluation but not fire if its preconditions were not met. Distinguishes between rules that were evaluated and rules that actively influenced the decision.' ;
    rdfs:domain ind:RuleExecutionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:referReasonCodes rdf:type rdf:Property ;
    rdfs:label 'Refer Reason Codes' ;
    rdfs:comment 'Comma-separated list of reason codes for rules that triggered a refer outcome, requiring human underwriter review. Each code represents a specific underwriting concern or exception. [Moved from rules_engine_output: This comma-separated string on rules_engine_output is a denormalized encoding of individual rule REFER outcomes. Each refer reason code corresponds to a specific rule that fired with a REFER result. The correct model is one rule_execution_result record per fired rule with result=REFER, making this field redundant and replaceable by querying the association table.]' ;
    rdfs:domain ind:RuleExecutionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:result rdf:type rdf:Property ;
    rdfs:label 'Result' ;
    rdfs:comment 'The outcome of evaluating this specific rule within this evaluation. PASS indicates the applicant met the rule criteria, FAIL indicates a decline trigger, REFER indicates the rule routed the case to a human underwriter, NOT_APPLICABLE indicates the rule was loaded but conditions for firing were not met.' ;
    rdfs:domain ind:RuleExecutionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:score rdf:type rdf:Property ;
    rdfs:label 'Score' ;
    rdfs:comment 'Numeric score or weight contributed by this rule to the overall evaluation. Used in scoring-based rules engines where individual rule contributions are summed or weighted to produce the final automated decision recommendation.' ;
    rdfs:domain ind:RuleExecutionResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .
