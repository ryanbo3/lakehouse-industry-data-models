ind:persistencyRatio rdf:type rdf:Property ;
    rdfs:label 'Persistency Ratio' ;
    rdfs:comment 'Ratio of policies remaining in force to total policies issued, measuring retention performance. Calculated as (policies in force / policies issued) for the producers book of business.' ;
    rdfs:domain ind:ProductionActivity ;
    rdf:type owl:DatatypeProperty ;
