ind:firstYearPremiumAmount rdf:type rdf:Property ;
    rdfs:label 'First Year Premium Amount' ;
    rdfs:comment 'Total first-year premium amount for new business placed during this period.' ;
    rdfs:domain ind:ProductionActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:issuedPolicyCount rdf:type rdf:Property ;
    rdfs:label 'Issued Policy Count' ;
    rdfs:comment 'Total number of policies issued and placed by the producer during this period.' ;
    rdfs:domain ind:ProductionActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:iulCount rdf:type rdf:Property ;
    rdfs:label 'Iul Count' ;
    rdfs:comment 'Number of indexed universal life insurance policies issued during this period.' ;
    rdfs:domain ind:ProductionActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:iulPremiumAmount rdf:type rdf:Property ;
    rdfs:label 'Iul Premium Amount' ;
    rdfs:comment 'Total premium amount for indexed universal life insurance policies issued during this period.' ;
    rdfs:domain ind:ProductionActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lapseCount rdf:type rdf:Property ;
    rdfs:label 'Lapse Count' ;
    rdfs:comment 'Number of policies that lapsed during this period from the producers book of business.' ;
