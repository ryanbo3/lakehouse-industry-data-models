    rdfs:comment 'Indicator of whether the producer passed or failed the training course.' ;
    rdfs:domain ind:ProducerTraining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:passingScoreRequired rdf:type rdf:Property ;
    rdfs:label 'Passing Score Required' ;
    rdfs:comment 'Minimum score or percentage required to pass the training course.' ;
    rdfs:domain ind:ProducerTraining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:renewalRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Renewal Required Flag' ;
    rdfs:comment 'Boolean flag indicating whether this training requires periodic renewal or retaking.' ;
