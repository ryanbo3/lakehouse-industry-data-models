    rdfs:comment 'Reference to the producer (agent, broker, BGA, MGA, GA) who generated this production activity.' ;
    rdfs:domain ind:ProductionActivity ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Producer .

ind:activityPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Activity Period End Date' ;
    rdfs:comment 'The end date of the reporting period for this production activity record.' ;
    rdfs:domain ind:ProductionActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:activityPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Activity Period Start Date' ;
    rdfs:comment 'The start date of the reporting period for this production activity record (weekly, monthly, or quarterly).' ;
    rdfs:domain ind:ProductionActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:activityStatus rdf:type rdf:Property ;
    rdfs:label 'Activity Status' ;
    rdfs:comment 'Current status of this production activity record in the reporting workflow (draft, submitted, approved, or finalized).' ;
    rdfs:domain ind:ProductionActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:annuityCount rdf:type rdf:Property ;
    rdfs:label 'Annuity Count' ;
    rdfs:comment 'Number of annuity contracts issued during this period.' ;
    rdfs:domain ind:ProductionActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:annuityPremiumAmount rdf:type rdf:Property ;
    rdfs:label 'Annuity Premium Amount' ;
    rdfs:comment 'Total premium amount for annuity contracts issued during this period.' ;
    rdfs:domain ind:ProductionActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bonusEarnedAmount rdf:type rdf:Property ;
    rdfs:label 'Bonus Earned Amount' ;
    rdfs:comment 'Total bonus amount earned by the producer during this period for meeting production targets or incentive qualifications.' ;
    rdfs:domain ind:ProductionActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:commissionEarnedAmount rdf:type rdf:Property ;
    rdfs:label 'Commission Earned Amount' ;
    rdfs:comment 'Total commission amount earned by the producer during this period based on production activity.' ;
    rdfs:domain ind:ProductionActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:conservationRate rdf:type rdf:Property ;
    rdfs:label 'Conservation Rate' ;
    rdfs:comment 'Percentage of premium retained after accounting for lapses and surrenders. Measures the producers ability to conserve business.' ;
    rdfs:domain ind:ProductionActivity ;
    rdf:type owl:DatatypeProperty ;
