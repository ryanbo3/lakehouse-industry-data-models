ind:placementRate rdf:type rdf:Property ;
    rdfs:label 'Placement Rate' ;
    rdfs:comment 'Ratio of issued policies to submitted applications, measuring the producers effectiveness in converting applications to issued policies.' ;
    rdfs:domain ind:ProductionActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:renewalPremiumAmount rdf:type rdf:Property ;
    rdfs:label 'Renewal Premium Amount' ;
    rdfs:comment 'Total renewal premium amount collected on existing policies serviced by the producer during this period.' ;
    rdfs:domain ind:ProductionActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:submittedApplicationCount rdf:type rdf:Property ;
    rdfs:label 'Submitted Application Count' ;
    rdfs:comment 'Total number of new business applications submitted by the producer during this period.' ;
    rdfs:domain ind:ProductionActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:termLifeCount rdf:type rdf:Property ;
    rdfs:label 'Term Life Count' ;
    rdfs:comment 'Number of term life insurance policies issued during this period.' ;
