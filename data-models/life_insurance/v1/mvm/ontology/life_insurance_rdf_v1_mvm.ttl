    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nigoCount rdf:type rdf:Property ;
    rdfs:label 'Nigo Count' ;
    rdfs:comment 'Number of applications submitted that were Not In Good Order (incomplete or missing required information) during this period.' ;
    rdfs:domain ind:ProductionActivity ;
    rdf:type owl:DatatypeProperty ;
