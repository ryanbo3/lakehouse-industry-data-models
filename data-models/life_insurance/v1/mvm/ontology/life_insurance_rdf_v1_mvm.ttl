    rdfs:comment 'Cost or fee paid for the training course in USD. Single-currency business operates in USD.' ;
    rdfs:domain ind:ProducerTraining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trainingCourseCode rdf:type rdf:Property ;
    rdfs:label 'Training Course Code' ;
    rdfs:comment 'Unique code identifying the training course or program.' ;
    rdfs:domain ind:ProducerTraining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingCourseName rdf:type rdf:Property ;
    rdfs:label 'Training Course Name' ;
    rdfs:comment 'Full name of the training course or certification program.' ;
    rdfs:domain ind:ProducerTraining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingDeliveryMethod rdf:type rdf:Property ;
    rdfs:label 'Training Delivery Method' ;
    rdfs:comment 'Method by which the training was delivered to the producer.' ;
    rdfs:domain ind:ProducerTraining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingDurationHours rdf:type rdf:Property ;
    rdfs:label 'Training Duration Hours' ;
    rdfs:comment 'Total duration of the training course in hours.' ;
    rdfs:domain ind:ProducerTraining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trainingExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Training Expiration Date' ;
    rdfs:comment 'Date when the training certification or credit expires and renewal or retaking is required.' ;
    rdfs:domain ind:Agent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:trainingNotes rdf:type rdf:Property ;
    rdfs:label 'Training Notes' ;
    rdfs:comment 'Free-form notes or comments related to the producer\'s training record, including special circumstances or observations.' ;
    rdfs:domain ind:ProducerTraining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingProviderCode rdf:type rdf:Property ;
    rdfs:label 'Training Provider Code' ;
    rdfs:comment 'Unique code identifying the training provider or vendor.' ;
    rdfs:domain ind:ProducerTraining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingStartDate rdf:type rdf:Property ;
    rdfs:label 'Training Start Date' ;
    rdfs:comment 'Date the producer began the training course.' ;
    rdfs:domain ind:ProducerTraining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:trainingStatus rdf:type rdf:Property ;
    rdfs:label 'Training Status' ;
    rdfs:comment 'Current status of the producer\'s participation in the training course.' ;
    rdfs:domain ind:ProducerTraining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingType rdf:type rdf:Property ;
    rdfs:label 'Training Type' ;
    rdfs:comment 'Classification of the training program indicating whether it is mandatory, elective, certification-based, continuing education, product-specific, or compliance-related.' ;
    rdfs:domain ind:ProducerTraining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waiverApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Waiver Approval Date' ;
    rdfs:comment 'Date the training waiver was approved.' ;
    rdfs:domain ind:ProducerTraining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:waiverApprovedBy rdf:type rdf:Property ;
    rdfs:label 'Waiver Approved By' ;
    rdfs:comment 'Name or identifier of the person or authority who approved the training waiver.' ;
    rdfs:domain ind:ProducerTraining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waiverGrantedFlag rdf:type rdf:Property ;
    rdfs:label 'Waiver Granted Flag' ;
    rdfs:comment 'Boolean flag indicating whether a waiver was granted exempting the producer from this training requirement.' ;
    rdfs:domain ind:ProducerTraining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:producerProductAuthId rdf:type rdf:Property ;
    rdfs:label 'Producer Product Auth Id' ;
    rdfs:comment 'Unique identifier for the producer product authorization record.' ;
    rdfs:domain ind:LifeInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProducerProductAuth .

ind:authorizationApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Authorization Approval Date' ;
    rdfs:comment 'The date on which the producer\'s authorization to sell this product was approved by the carrier.' ;
    rdfs:domain ind:ProducerProductAuth ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:authorizationEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Authorization Effective Date' ;
    rdfs:comment 'The date on which the producer\'s authorization to sell this product becomes effective.' ;
    rdfs:domain ind:ProducerProductAuth ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:authorizationExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Authorization Expiration Date' ;
    rdfs:comment 'The date on which the producer\'s authorization to sell this product expires. Null indicates no expiration (perpetual authorization).' ;
    rdfs:domain ind:ProducerProductAuth ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:authorizationNotes rdf:type rdf:Property ;
    rdfs:label 'Authorization Notes' ;
    rdfs:comment 'Free-form notes regarding special conditions, restrictions, or comments related to this product authorization.' ;
    rdfs:domain ind:ProducerProductAuth ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorizationNumber rdf:type rdf:Property ;
    rdfs:label 'Authorization Number' ;
    rdfs:comment 'Unique authorization number or certificate number issued for this producer-product authorization.' ;
    rdfs:domain ind:ProducerProductAuth ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorizedStates rdf:type rdf:Property ;
    rdfs:label 'Authorized States' ;
    rdfs:comment 'Comma-separated list of state codes where the producer is authorized to sell this product. Null if authorization applies to all states where producer is licensed.' ;
    rdfs:domain ind:ProducerProductAuth ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:finraSeriesLicenseRequired rdf:type rdf:Property ;
    rdfs:label 'Finra Series License Required' ;
    rdfs:comment 'Comma-separated list of FINRA series licenses required to sell this product (e.g., Series 6, Series 7, Series 63, Series 65). Null if no FINRA registration required.' ;
    rdfs:domain ind:ProducerProductAuth ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumCaseSizeAmount rdf:type rdf:Property ;
    rdfs:label 'Maximum Case Size Amount' ;
    rdfs:comment 'Maximum policy face amount or premium amount that the producer is authorized to write for this product without special approval. Null if no maximum applies.' ;
    rdfs:domain ind:ProducerProductAuth ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumCaseSizeAmount rdf:type rdf:Property ;
    rdfs:label 'Minimum Case Size Amount' ;
    rdfs:comment 'Minimum policy face amount or premium amount that the producer is authorized to write for this product. Null if no minimum applies.' ;
    rdfs:domain ind:ProducerProductAuth ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overrideCommissionEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Override Commission Eligible Flag' ;
    rdfs:comment 'Indicates whether the producer is eligible to receive override commissions on downline sales of this product. True for producers with hierarchy management responsibilities (BGAs, MGAs, GAs); False for individual producers.' ;
    rdfs:domain ind:ProducerProductAuth ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:posSystemIntegrationFlag rdf:type rdf:Property ;
    rdfs:label 'Pos System Integration Flag' ;
    rdfs:comment 'Indicates whether this authorization is integrated with the Point of Sale system for real-time product availability filtering. True if POS integration active; False if manual authorization verification required.' ;
    rdfs:domain ind:ProducerProductAuth ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiredTrainingCode rdf:type rdf:Property ;
    rdfs:label 'Required Training Code' ;
    rdfs:comment 'Code identifying the mandatory training program that must be completed before the producer can sell this product.' ;
    rdfs:domain ind:ProducerProductAuth ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restrictedStates rdf:type rdf:Property ;
    rdfs:label 'Restricted States' ;
    rdfs:comment 'Comma-separated list of state codes where the producer is explicitly restricted from selling this product despite having a general license.' ;
    rdfs:domain ind:ProducerProductAuth ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revocationReasonCode rdf:type rdf:Property ;
    rdfs:label 'Revocation Reason Code' ;
    rdfs:comment 'Code indicating the reason for authorization revocation (e.g., compliance violation, performance deficiency, voluntary surrender, license termination).' ;
    rdfs:domain ind:ProducerProductAuth ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revocationReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Revocation Reason Description' ;
    rdfs:comment 'Detailed description of the reason for authorization revocation.' ;
    rdfs:domain ind:ProducerProductAuth ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stateSpecificAuthorizationFlag rdf:type rdf:Property ;
    rdfs:label 'State Specific Authorization Flag' ;
    rdfs:comment 'Indicates whether this authorization is subject to state-specific restrictions or overrides. True if state-level authorization rules apply; False if authorization is uniform across all states.' ;
    rdfs:domain ind:ProducerProductAuth ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:suspensionEndDate rdf:type rdf:Property ;
    rdfs:label 'Suspension End Date' ;
    rdfs:comment 'The date on which a temporary suspension of this product authorization is scheduled to end. Null if suspension is indefinite or authorization not suspended.' ;
    rdfs:domain ind:ProducerProductAuth ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:suspensionStartDate rdf:type rdf:Property ;
    rdfs:label 'Suspension Start Date' ;
    rdfs:comment 'The date on which a temporary suspension of this product authorization began. Null if authorization has not been suspended.' ;
    rdfs:domain ind:ProducerProductAuth ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:trainingComplianceStatus rdf:type rdf:Property ;
    rdfs:label 'Training Compliance Status' ;
    rdfs:comment 'Current compliance status of the producer\'s training requirements for this product. Compliant indicates all training current; non-compliant indicates training deficiency; pending indicates training in progress; expired indicates certification lapsed.' ;
    rdfs:domain ind:ProducerProductAuth ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionActivityId rdf:type rdf:Property ;
    rdfs:label 'Production Activity Id' ;
    rdfs:comment 'Unique identifier for the production activity record. Primary key for this table.' ;
    rdfs:domain ind:ProductionActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryProductionProducerId rdf:type rdf:Property ;
