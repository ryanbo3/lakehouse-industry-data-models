    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimsReprocessFlag rdf:type rdf:Property ;
    rdfs:label 'Claims Reprocess Flag' ;
    rdfs:comment 'True if the enrollment change requires downstream claims to be re-processed.' ;
    rdfs:domain ind:Transaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:coveragePeriodType rdf:type rdf:Property ;
    rdfs:label 'Coverage Period Type' ;
    rdfs:comment 'Indicates whether the coverage is continuous, intermittent, or contains a gap.' ;
    rdfs:domain ind:Transaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentComment rdf:type rdf:Property ;
    rdfs:label 'Enrollment Comment' ;
    rdfs:comment 'Free-form text field for notes or comments entered by the processor.' ;
    rdfs:domain ind:Transaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentOrigin rdf:type rdf:Property ;
    rdfs:label 'Enrollment Origin' ;
    rdfs:comment 'Channel through which the enrollment was initiated.' ;
    rdfs:domain ind:Transaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentTransactionNumber rdf:type rdf:Property ;
    rdfs:label 'Enrollment Transaction Number' ;
    rdfs:comment 'External business identifier assigned to the enrollment transaction, used for tracking and reference.' ;
    rdfs:domain ind:Transaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventTimestamp rdf:type rdf:Property ;
    rdfs:label 'Event Timestamp' ;
    rdfs:comment 'Exact date-time when the enrollment event occurred in the source system.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:financialImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Financial Impact Flag' ;
    rdfs:comment 'True when the enrollment change has a direct impact on premium billing or financial reporting.' ;
    rdfs:domain ind:Transaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gracePeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Grace Period End Date' ;
    rdfs:comment 'Date when the applicable grace period expires.' ;
    rdfs:domain ind:Transaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:grossAmount rdf:type rdf:Property ;
    rdfs:label 'Gross Amount' ;
    rdfs:comment 'Total premium amount before any adjustments for the enrollment period.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:healthPlanType rdf:type rdf:Property ;
    rdfs:label 'Health Plan Type' ;
    rdfs:comment 'Classification of the health plan (e.g., HMO, PPO, EPO, POS, HDHP).' ;
    rdfs:domain ind:Transaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isGracePeriod rdf:type rdf:Property ;
    rdfs:label 'Is Grace Period' ;
    rdfs:comment 'True if the enrollment is being processed within a grace period after termination.' ;
    rdfs:domain ind:Transaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:netAmount rdf:type rdf:Property ;
    rdfs:label 'Net Amount' ;
    rdfs:comment 'Final premium amount after adjustments, representing the amount to be billed.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:originalTerminationReference rdf:type rdf:Property ;
    rdfs:label 'Original Termination Reference' ;
    rdfs:comment 'Reference to the prior termination transaction that is being reinstated.' ;
    rdfs:domain ind:Transaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:processingStatus rdf:type rdf:Property ;
    rdfs:label 'Processing Status' ;
    rdfs:comment 'Current processing stage of the transaction within the enrollment workflow.' ;
    rdfs:domain ind:Transaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reactivationDate rdf:type rdf:Property ;
    rdfs:label 'Reactivation Date' ;
    rdfs:comment 'Effective date of coverage reactivation for reinstatement events.' ;
    rdfs:domain ind:Transaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryReportingFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reporting Flag' ;
    rdfs:comment 'Indicates whether this transaction must be reported to a regulatory body (e.g., CMS, NAIC).' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:transactionSource rdf:type rdf:Property ;
    rdfs:label 'Transaction Source' ;
    rdfs:comment 'Source of the enrollment transaction record, e.g., EDI 834 feed, web portal, batch load, or API.' ;
    rdfs:domain ind:Transaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionStatus rdf:type rdf:Property ;
    rdfs:label 'Transaction Status' ;
    rdfs:comment 'Current lifecycle status of the enrollment transaction.' ;
    rdfs:domain ind:Transaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventId rdf:type rdf:Property ;
    rdfs:label 'Event Id' ;
    rdfs:comment 'System-generated unique identifier for each enrollment event record.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Event .

ind:groupPlanOfferingId rdf:type rdf:Property ;
    rdfs:label 'Group Plan Offering Id' ;
    rdfs:comment 'Foreign key linking to employer.group_plan_offering. Business justification: Event tracking reports must reference the exact plan offering the change relates to for employer-level reporting.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GroupPlanOffering .

ind:actorType rdf:type rdf:Property ;
    rdfs:label 'Actor Type' ;
    rdfs:comment 'Classifies the party that triggered the event.' ;
    rdfs:domain ind:Event ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventDescription rdf:type rdf:Property ;
    rdfs:label 'Event Description' ;
    rdfs:comment 'Free-text narrative providing additional context for the event.' ;
    rdfs:domain ind:Event ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventSource rdf:type rdf:Property ;
    rdfs:label 'Event Source' ;
    rdfs:comment 'System or interface that generated the event record.' ;
    rdfs:domain ind:Event ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventType rdf:type rdf:Property ;
    rdfs:label 'Event Type' ;
    rdfs:comment 'Categorizes the nature of the state transition (e.g., submitted, approved).' ;
    rdfs:domain ind:Enrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isManual rdf:type rdf:Property ;
    rdfs:label 'Is Manual' ;
    rdfs:comment 'Indicates whether the event was entered manually (True) or generated automatically (False).' ;
    rdfs:domain ind:Event ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:newStatus rdf:type rdf:Property ;
    rdfs:label 'New Status' ;
    rdfs:comment 'Enrollment status after the event was applied.' ;
    rdfs:domain ind:Event ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:previousStatus rdf:type rdf:Property ;
    rdfs:label 'Previous Status' ;
    rdfs:comment 'Enrollment status before the event was applied.' ;
    rdfs:domain ind:Event ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appealReference rdf:type rdf:Property ;
    rdfs:label 'Appeal Reference' ;
    rdfs:comment 'Reference number of any appeal filed against a denial.' ;
    rdfs:domain ind:QualifyingLifeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cmsSepOutcome rdf:type rdf:Property ;
    rdfs:label 'Cms Sep Outcome' ;
    rdfs:comment 'Result of the CMS SEP eligibility determination.' ;
    rdfs:domain ind:QualifyingLifeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:denialReason rdf:type rdf:Property ;
    rdfs:label 'Denial Reason' ;
    rdfs:comment 'Explanation why the SEP request was denied, if applicable.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentationType rdf:type rdf:Property ;
    rdfs:label 'Documentation Type' ;
    rdfs:comment 'Type of supporting document submitted for the event.' ;
    rdfs:domain ind:QualifyingLifeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventDate rdf:type rdf:Property ;
    rdfs:label 'Event Date' ;
    rdfs:comment 'Calendar date on which the qualifying life event occurred.' ;
    rdfs:domain ind:QualifyingLifeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qualifyingLifeEventStatus rdf:type rdf:Property ;
    rdfs:label 'Qualifying Life Event Status' ;
    rdfs:comment 'Overall lifecycle status of the qualifying life event record.' ;
    rdfs:domain ind:QualifyingLifeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sepCategoryCode rdf:type rdf:Property ;
    rdfs:label 'Sep Category Code' ;
    rdfs:comment 'CMS-defined code that classifies the SEP category for the qualifying life event.' ;
    rdfs:domain ind:QualifyingLifeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sepWindowEnd rdf:type rdf:Property ;
    rdfs:label 'Sep Window End' ;
    rdfs:comment 'Last date the special enrollment period (SEP) is open for this event.' ;
    rdfs:domain ind:QualifyingLifeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sepWindowStart rdf:type rdf:Property ;
    rdfs:label 'Sep Window Start' ;
    rdfs:comment 'First date the special enrollment period (SEP) is open for this event.' ;
    rdfs:domain ind:QualifyingLifeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sepWindowStatus rdf:type rdf:Property ;
    rdfs:label 'Sep Window Status' ;
    rdfs:comment 'Current state of the SEP window based on dates and actions.' ;
    rdfs:domain ind:QualifyingLifeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:openEnrollmentPeriodId rdf:type rdf:Property ;
    rdfs:label 'Open Enrollment Period Id' ;
    rdfs:comment 'Primary key for open_enrollment_period' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OpenEnrollmentPeriod .

ind:policyDocumentId rdf:type rdf:Property ;
    rdfs:label 'Policy Document Id' ;
    rdfs:comment 'Foreign key linking to compliance.policy_document. Business justification: Each OEP is governed by a specific policy document defining enrollment rules, eligibility criteria, and procedures (especially for state-specific exchanges). Compliance teams must link OEPs to their g' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PolicyDocument .

ind:eligibilitySegment rdf:type rdf:Property ;
    rdfs:label 'Eligibility Segment' ;
    rdfs:comment 'Population segment eligible for this enrollment period (e.g., group, individual, Medicare).' ;
    rdfs:domain ind:OpenEnrollmentPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentCutoffTime rdf:type rdf:Property ;
    rdfs:label 'Enrollment Cutoff Time' ;
    rdfs:comment 'Daily cut-off time (in local time) after which submissions on the deadline date are rejected.' ;
    rdfs:domain ind:OpenEnrollmentPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:enrollmentDeadlineDate rdf:type rdf:Property ;
    rdfs:label 'Enrollment Deadline Date' ;
    rdfs:comment 'Final calendar date by which all enrollment submissions must be received.' ;
    rdfs:domain ind:OpenEnrollmentPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:exchangeType rdf:type rdf:Property ;
    rdfs:label 'Exchange Type' ;
    rdfs:comment 'Marketplace or exchange through which the enrollment is offered.' ;
    rdfs:domain ind:OpenEnrollmentPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isAnnual rdf:type rdf:Property ;
    rdfs:label 'Is Annual' ;
    rdfs:comment 'True if the enrollment period recurs each year on the same schedule.' ;
    rdfs:domain ind:OpenEnrollmentPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRetrospectiveAllowed rdf:type rdf:Property ;
    rdfs:label 'Is Retrospective Allowed' ;
    rdfs:comment 'True if members may submit enrollment changes that become effective prior to the submission date.' ;
    rdfs:domain ind:OpenEnrollmentPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:openEnrollmentPeriodStatus rdf:type rdf:Property ;
    rdfs:label 'Open Enrollment Period Status' ;
    rdfs:comment 'Current lifecycle status of the enrollment window.' ;
    rdfs:domain ind:OpenEnrollmentPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:periodCode rdf:type rdf:Property ;
    rdfs:label 'Period Code' ;
    rdfs:comment 'Short alphanumeric code that uniquely identifies the enrollment window across systems.' ;
    rdfs:domain ind:OpenEnrollmentPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:periodName rdf:type rdf:Property ;
    rdfs:label 'Period Name' ;
    rdfs:comment 'Descriptive name of the enrollment window, e.g., "2025 Individual Marketplace OE".' ;
    rdfs:domain ind:OpenEnrollmentPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:volumeActual rdf:type rdf:Property ;
    rdfs:label 'Volume Actual' ;
    rdfs:comment 'Actual count of enrollments captured within the window.' ;
    rdfs:domain ind:OpenEnrollmentPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:volumeTarget rdf:type rdf:Property ;
    rdfs:label 'Volume Target' ;
    rdfs:comment 'Planned number of enrollments the organization aims to achieve during the window.' ;
    rdfs:domain ind:OpenEnrollmentPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:volumeTargetMet rdf:type rdf:Property ;
    rdfs:label 'Volume Target Met' ;
    rdfs:comment 'Indicates whether the actual enrollment volume met or exceeded the target.' ;
    rdfs:domain ind:OpenEnrollmentPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:eligibilityVerificationId rdf:type rdf:Property ;
    rdfs:label 'Eligibility Verification Id' ;
    rdfs:comment 'Primary key for eligibility_verification' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EligibilityVerification .

ind:authorizationNumber rdf:type rdf:Property ;
    rdfs:label 'Authorization Number' ;
    rdfs:comment 'Authorization number returned when prior authorization is required.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:benefitLimit rdf:type rdf:Property ;
    rdfs:label 'Benefit Limit' ;
    rdfs:comment 'Maximum dollar amount allowed for the queried benefit.' ;
    rdfs:domain ind:EligibilityVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:benefitRemaining rdf:type rdf:Property ;
    rdfs:label 'Benefit Remaining' ;
    rdfs:comment 'Remaining dollar amount of the benefit available.' ;
    rdfs:domain ind:EligibilityVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:benefitUsed rdf:type rdf:Property ;
    rdfs:label 'Benefit Used' ;
    rdfs:comment 'Dollar amount of the benefit already utilized in the current period.' ;
    rdfs:domain ind:EligibilityVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deductibleRemaining rdf:type rdf:Property ;
    rdfs:label 'Deductible Remaining' ;
    rdfs:comment 'Member\'s remaining deductible balance for the benefit period.' ;
    rdfs:domain ind:EligibilityVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:errorCode rdf:type rdf:Property ;
    rdfs:label 'Error Code' ;
    rdfs:comment 'Technical or business error code returned in a failed eligibility response.' ;
    rdfs:domain ind:EligibilityVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:errorDescription rdf:type rdf:Property ;
    rdfs:label 'Error Description' ;
    rdfs:comment 'Human-readable description of the error condition.' ;
    rdfs:domain ind:EligibilityVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inquiryReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Inquiry Reference Number' ;
    rdfs:comment 'External reference number assigned by the source system (e.g., Availity) for the eligibility request.' ;
    rdfs:domain ind:EligibilityVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inquiryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Inquiry Timestamp' ;
    rdfs:comment 'Date-time when the eligibility request was sent to the payer.' ;
    rdfs:domain ind:EligibilityVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:memberIdentifierType rdf:type rdf:Property ;
    rdfs:label 'Member Identifier Type' ;
    rdfs:comment 'Type of identifier supplied for the member (SSN, MRN, or internal member ID).' ;
    rdfs:domain ind:EligibilityVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oopRemaining rdf:type rdf:Property ;
    rdfs:label 'Oop Remaining' ;
    rdfs:comment 'Remaining out-of-pocket amount before maximum OOP is reached.' ;
    rdfs:domain ind:EligibilityVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:responseMessage rdf:type rdf:Property ;
    rdfs:label 'Response Message' ;
    rdfs:comment 'Free-form message returned by the payer providing additional context.' ;
    rdfs:domain ind:EligibilityVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseTimeSeconds rdf:type rdf:Property ;
    rdfs:label 'Response Time Seconds' ;
    rdfs:comment 'Elapsed time between request and response, measured in seconds.' ;
    rdfs:domain ind:EligibilityVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:responseTimestamp rdf:type rdf:Property ;
    rdfs:label 'Response Timestamp' ;
    rdfs:comment 'Date-time when the eligibility response was received.' ;
    rdfs:domain ind:EligibilityVerification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:planElectionId rdf:type rdf:Property ;
    rdfs:label 'Plan Election Id' ;
    rdfs:comment 'Foreign key linking to enrollment.plan_election. Business justification: A COBRA election results in a specific plan election — the member selects a plan to continue under COBRA continuation coverage. Linking cobra_election to plan_election connects the COBRA administrativ' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PlanElection .

ind:businessIdentifier rdf:type rdf:Property ;
    rdfs:label 'Business Identifier' ;
    rdfs:comment 'External reference number or code used by the business to identify the election.' ;
    rdfs:domain ind:CobraElection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:classificationOrType rdf:type rdf:Property ;
    rdfs:label 'Classification Or Type' ;
    rdfs:comment 'Category of the agreement; identifies it as a COBRA continuation election.' ;
    rdfs:domain ind:CobraElection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cobraPremiumAmount rdf:type rdf:Property ;
    rdfs:label 'Cobra Premium Amount' ;
    rdfs:comment 'Monthly premium amount for COBRA coverage (typically 102% of the full premium).' ;
    rdfs:domain ind:CobraElection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dependentCount rdf:type rdf:Property ;
    rdfs:label 'Dependent Count' ;
    rdfs:comment 'Count of dependents included in the COBRA election.' ;
    rdfs:domain ind:CobraElection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:earlyTerminationFlag rdf:type rdf:Property ;
    rdfs:label 'Early Termination Flag' ;
    rdfs:comment 'Indicates if the COBRA coverage was terminated before the scheduled end date.' ;
    rdfs:domain ind:CobraElection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:earlyTerminationNoticeSentFlag rdf:type rdf:Property ;
    rdfs:label 'Early Termination Notice Sent Flag' ;
    rdfs:comment 'True when an early termination notice has been sent to the member.' ;
    rdfs:domain ind:CobraElection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:electionDecision rdf:type rdf:Property ;
    rdfs:label 'Election Decision' ;
    rdfs:comment 'Member\'s decision regarding COBRA continuation coverage.' ;
    rdfs:domain ind:CobraElection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:electionNoticeSentFlag rdf:type rdf:Property ;
    rdfs:label 'Election Notice Sent Flag' ;
    rdfs:comment 'True when the election notice has been dispatched to the member.' ;
    rdfs:domain ind:CobraElection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:electionStatus rdf:type rdf:Property ;
    rdfs:label 'Election Status' ;
    rdfs:comment 'Current status of the COBRA election process.' ;
    rdfs:domain ind:CobraElection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastPaymentDate rdf:type rdf:Property ;
    rdfs:label 'Last Payment Date' ;
    rdfs:comment 'Date of the most recent premium payment received for the COBRA coverage.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:noticeDateElection rdf:type rdf:Property ;
    rdfs:label 'Notice Date Election' ;
    rdfs:comment 'Date the election-specific notice (reminder) was sent to the member.' ;
    rdfs:domain ind:CobraElection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:noticeDateInitial rdf:type rdf:Property ;
    rdfs:label 'Notice Date Initial' ;
    rdfs:comment 'Date the initial COBRA continuation coverage notice was sent to the member.' ;
    rdfs:domain ind:CobraElection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:noticeDeadline rdf:type rdf:Property ;
    rdfs:label 'Notice Deadline' ;
    rdfs:comment 'Last date by which the member must elect COBRA coverage.' ;
    rdfs:domain ind:CobraElection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qualifyingEventDate rdf:type rdf:Property ;
    rdfs:label 'Qualifying Event Date' ;
    rdfs:comment 'Date on which the qualifying event occurred.' ;
    rdfs:domain ind:CobraElection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qualifyingEventType rdf:type rdf:Property ;
    rdfs:label 'Qualifying Event Type' ;
    rdfs:comment 'Type of qualifying event that triggered COBRA eligibility.' ;
    rdfs:domain ind:CobraElection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordAuditCreated rdf:type rdf:Property ;
    rdfs:label 'Record Audit Created' ;
    rdfs:comment 'Timestamp when the COBRA election record was first created in the data lake.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:recordAuditUpdated rdf:type rdf:Property ;
    rdfs:label 'Record Audit Updated' ;
    rdfs:comment 'Timestamp of the most recent update to the COBRA election record.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:subsidyAmount rdf:type rdf:Property ;
    rdfs:label 'Subsidy Amount' ;
    rdfs:comment 'Monetary amount of the subsidy applied to the premium.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:subsidyEligibilityFlag rdf:type rdf:Property ;
    rdfs:label 'Subsidy Eligibility Flag' ;
    rdfs:comment 'Indicates whether the member qualifies for an ARP COBRA subsidy.' ;
    rdfs:domain ind:CobraElection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:subsidyType rdf:type rdf:Property ;
    rdfs:label 'Subsidy Type' ;
    rdfs:comment 'Type of subsidy applied to the COBRA premium.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contributionStrategyId rdf:type rdf:Property ;
    rdfs:label 'Contribution Strategy Id' ;
    rdfs:comment 'Foreign key linking to employer.contribution_strategy. Business justification: The contribution strategy governs employee/employer premium split for each plan election, directly driving payroll deduction setup and ACA affordability testing. A health insurance domain expert expec' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ContributionStrategy .

ind:priorPlanElectionId rdf:type rdf:Property ;
    rdfs:label 'Prior Plan Election Id' ;
    rdfs:comment 'Reference to the previous election record when this election is a change or reinstatement.' ;
    rdfs:domain ind:PlanElection ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PlanElection .

ind:cobraEligibilityEndDate rdf:type rdf:Property ;
