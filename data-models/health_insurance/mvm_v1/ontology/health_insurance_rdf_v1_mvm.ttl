    rdfs:domain ind:MemberRiskScore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskScoreNotes rdf:type rdf:Property ;
    rdfs:label 'Risk Score Notes' ;
    rdfs:comment 'Free-text field for any additional commentary or observations.' ;
    rdfs:domain ind:MemberRiskScore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskScoreSource rdf:type rdf:Property ;
    rdfs:label 'Risk Score Source' ;
    rdfs:comment 'Data source used to generate the score.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskScoreStatus rdf:type rdf:Property ;
    rdfs:label 'Risk Score Status' ;
    rdfs:comment 'Current processing status of the risk score.' ;
    rdfs:domain ind:MemberRiskScore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskScoreType rdf:type rdf:Property ;
    rdfs:label 'Risk Score Type' ;
    rdfs:comment 'Indicates whether the score is projected (prospective), derived from current data (concurrent), or the final CMS-published value.' ;
    rdfs:domain ind:MemberRiskScore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskScoreValue rdf:type rdf:Property ;
    rdfs:label 'Risk Score Value' ;
    rdfs:comment 'Numeric RAF score calculated for the member (e.g., 1.2345).' ;
    rdfs:domain ind:MemberRiskScore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scoreComponents rdf:type rdf:Property ;
    rdfs:label 'Score Components' ;
    rdfs:comment 'Delimited list or JSON string of component scores (e.g., HCC contributions, demographic adjustments).' ;
    rdfs:domain ind:MemberRiskScore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scoreEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Score Effective Date' ;
    rdfs:comment 'Date on which the risk score becomes effective for payment calculations.' ;
    rdfs:domain ind:MemberRiskScore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scoreVariance rdf:type rdf:Property ;
    rdfs:label 'Score Variance' ;
    rdfs:comment 'Numeric difference between the plan-calculated score and the CMS-published score.' ;
    rdfs:domain ind:MemberRiskScore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceCategory rdf:type rdf:Property ;
    rdfs:label 'Variance Category' ;
    rdfs:comment 'Root-cause classification for any variance between plan and CMS scores.' ;
    rdfs:domain ind:MemberRiskScore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hccMappingId rdf:type rdf:Property ;
    rdfs:label 'Hcc Mapping Id' ;
    rdfs:comment 'Primary key for hcc_mapping' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:HccMapping .

ind:ageAdjustmentFactor rdf:type rdf:Property ;
    rdfs:label 'Age Adjustment Factor' ;
    rdfs:comment 'Multiplier adjusting the HCC coefficient based on member age.' ;
    rdfs:domain ind:HccMapping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coefficient rdf:type rdf:Property ;
    rdfs:label 'Coefficient' ;
    rdfs:comment 'Weighting coefficient used in RAF score calculations for the HCC.' ;
    rdfs:domain ind:HccMapping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:demographicAdjustmentFactor rdf:type rdf:Property ;
    rdfs:label 'Demographic Adjustment Factor' ;
    rdfs:comment 'Factor adjusting the HCC weight for demographic characteristics (age, gender, etc.).' ;
    rdfs:domain ind:HccMapping ;
    rdf:type owl:DatatypeProperty ;
