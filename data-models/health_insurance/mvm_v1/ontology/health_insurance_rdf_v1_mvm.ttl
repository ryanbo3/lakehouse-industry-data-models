    rdfs:range xsd:date .

ind:riskClassification rdf:type rdf:Property ;
    rdfs:label 'Risk Classification' ;
    rdfs:comment 'Overall risk classification assigned to the applicant.' ;
    rdfs:domain ind:RiskUnderwritingCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskUnderwritingCaseStatus rdf:type rdf:Property ;
    rdfs:label 'Risk Underwriting Case Status' ;
    rdfs:comment 'Current lifecycle status of the underwriting case.' ;
    rdfs:domain ind:RiskUnderwritingCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalMemberMonths rdf:type rdf:Property ;
    rdfs:label 'Total Member Months' ;
    rdfs:comment 'Aggregate member-months for the group applicant during the rating period.' ;
    rdfs:domain ind:RiskUnderwritingCase ;
