    rdfs:range xsd:string .

ind:measureCode rdf:type rdf:Property ;
    rdfs:label 'Measure Code' ;
    rdfs:comment 'Official NCQA code that uniquely identifies the measure.' ;
    rdfs:domain ind:HedisMeasure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measureDenominatorLogic rdf:type rdf:Property ;
    rdfs:label 'Measure Denominator Logic' ;
    rdfs:comment 'Detailed logical expression or algorithm used to compute the denominator.' ;
    rdfs:domain ind:HedisMeasure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measureDescription rdf:type rdf:Property ;
    rdfs:label 'Measure Description' ;
    rdfs:comment 'Full textual description of what the measure evaluates.' ;
    rdfs:domain ind:HedisMeasure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measureDomain rdf:type rdf:Property ;
    rdfs:label 'Measure Domain' ;
    rdfs:comment 'High-level domain of the measure (e.g., effectiveness of care, access/availability, utilization).' ;
    rdfs:domain ind:HedisMeasure ;
