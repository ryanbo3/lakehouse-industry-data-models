ind:paDecisionId rdf:type rdf:Property ;
    rdfs:label 'Pa Decision Id' ;
    rdfs:comment 'Foreign key linking to utilization.pa_decision. Business justification: Appeal cases contesting PA denials require direct access to the PA decision record to review clinical rationale, criteria version, and denial reason category. ERISA and ACA mandate that appeal reviewe' ;
    rdfs:domain ind:HealthInsurance ;
