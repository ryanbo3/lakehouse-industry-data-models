ind:premiumPaymentId rdf:type rdf:Property ;
    rdfs:label 'Premium Payment Id' ;
    rdfs:comment 'Foreign key linking to billing.premium_payment. Business justification: Needed for Payment Appeal workflow; links the appeal case to the exact payment being contested, supporting regulatory reporting of disputed payments.' ;
    rdfs:domain ind:HealthInsurance ;
