    rdfs:range xsd:string .

ind:measureExclusionLogic rdf:type rdf:Property ;
    rdfs:label 'Measure Exclusion Logic' ;
    rdfs:comment 'Detailed logical expression defining exclusions from the denominator.' ;
    rdfs:domain ind:HedisMeasure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measureLastReviewedDate rdf:type rdf:Property ;
    rdfs:label 'Measure Last Reviewed Date' ;
    rdfs:comment 'Date when the measure definition was last reviewed for accuracy.' ;
    rdfs:domain ind:HedisMeasure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:measureLastUpdatedBy rdf:type rdf:Property ;
    rdfs:label 'Measure Last Updated By' ;
    rdfs:comment 'User or system that performed the most recent update.' ;
