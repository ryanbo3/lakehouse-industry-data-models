    rdfs:comment 'Period (e.g., FY2024) used for rating calculations.' ;
    rdfs:domain ind:RiskUnderwritingCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reinsuranceFlag rdf:type rdf:Property ;
