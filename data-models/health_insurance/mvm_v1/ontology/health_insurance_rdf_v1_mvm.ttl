ind:diseaseInteractionGroup rdf:type rdf:Property ;
    rdfs:label 'Disease Interaction Group' ;
    rdfs:comment 'Identifier for a group of diagnoses that have interaction effects.' ;
    rdfs:domain ind:HccMapping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:genderAdjustmentFactor rdf:type rdf:Property ;
    rdfs:label 'Gender Adjustment Factor' ;
    rdfs:comment 'Multiplier adjusting the HCC coefficient based on member gender.' ;
    rdfs:domain ind:HccMapping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hccCode rdf:type rdf:Property ;
    rdfs:label 'Hcc Code' ;
    rdfs:comment 'CMS-assigned HCC identifier linked to the diagnosis.' ;
