    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stateAgency rdf:type rdf:Property ;
    rdfs:label 'State Agency' ;
    rdfs:comment 'Two-letter code of the state Medicaid agency governing the eligibility.' ;
    rdfs:domain ind:MedicaidEligibility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stateMedicaidNumber rdf:type rdf:Property ;
