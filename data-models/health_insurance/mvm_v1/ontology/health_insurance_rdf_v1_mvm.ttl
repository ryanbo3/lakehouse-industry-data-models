    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskScorePercentile rdf:type rdf:Property ;
    rdfs:label 'Risk Score Percentile' ;
    rdfs:comment 'Member\'s risk score percentile compared to the plan population.' ;
