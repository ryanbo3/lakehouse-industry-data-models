    rdfs:domain ind:PremiumInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceType rdf:type rdf:Property ;
    rdfs:label 'Invoice Type' ;
    rdfs:comment 'Classification of the invoice based on the recipient and billing arrangement.' ;
    rdfs:domain ind:PremiumInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isEligibleForSubsidy rdf:type rdf:Property ;
    rdfs:label 'Is Eligible For Subsidy' ;
    rdfs:comment 'Flag indicating whether the member/group qualifies for a premium subsidy.' ;
    rdfs:domain ind:HealthInsurance ;
