    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measureName rdf:type rdf:Property ;
    rdfs:label 'Measure Name' ;
    rdfs:comment 'Descriptive name of the HEDIS quality measure.' ;
    rdfs:domain ind:HedisMeasure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measureNationalBenchmark rdf:type rdf:Property ;
    rdfs:label 'Measure National Benchmark' ;
    rdfs:comment 'National average performance for the measure (percentage).' ;
    rdfs:domain ind:HedisMeasure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:measureNotes rdf:type rdf:Property ;
    rdfs:label 'Measure Notes' ;
    rdfs:comment 'Free-form notes or comments about the measure.' ;
    rdfs:domain ind:HedisMeasure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measureNumeratorLogic rdf:type rdf:Property ;
    rdfs:label 'Measure Numerator Logic' ;
    rdfs:comment 'Detailed logical expression or algorithm used to compute the numerator.' ;
    rdfs:domain ind:HedisMeasure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measureOwner rdf:type rdf:Property ;
    rdfs:label 'Measure Owner' ;
    rdfs:comment 'Business unit or team responsible for the measure.' ;
    rdfs:domain ind:HedisMeasure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measureRelatedRaf rdf:type rdf:Property ;
    rdfs:label 'Measure Related Raf' ;
    rdfs:comment 'Comma-separated list of Risk Adjustment Factor (RAF) variables linked to the measure.' ;
    rdfs:domain ind:HedisMeasure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measureReportingFrequency rdf:type rdf:Property ;
    rdfs:label 'Measure Reporting Frequency' ;
    rdfs:comment 'How often the measure is reported (annual, semi-annual, quarterly).' ;
    rdfs:domain ind:HedisMeasure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measureScoringMethod rdf:type rdf:Property ;
    rdfs:label 'Measure Scoring Method' ;
    rdfs:comment 'Method used to calculate the final score (e.g., rate, percentage, binary).' ;
    rdfs:domain ind:HedisMeasure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measureStarRatingImpact rdf:type rdf:Property ;
    rdfs:label 'Measure Star Rating Impact' ;
    rdfs:comment 'Explanation of how the measure influences Medicare Star Ratings.' ;
    rdfs:domain ind:HedisMeasure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measureStateBenchmark rdf:type rdf:Property ;
    rdfs:label 'Measure State Benchmark' ;
    rdfs:comment 'State-level average performance for the measure (percentage).' ;
    rdfs:domain ind:HedisMeasure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:measureStatus rdf:type rdf:Property ;
    rdfs:label 'Measure Status' ;
    rdfs:comment 'Current lifecycle status of the measure.' ;
    rdfs:domain ind:HedisMeasure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measureUrl rdf:type rdf:Property ;
    rdfs:label 'Measure Url' ;
    rdfs:comment 'Link to the official documentation or specification for the measure.' ;
    rdfs:domain ind:HedisMeasure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementYear rdf:type rdf:Property ;
    rdfs:label 'Measurement Year' ;
    rdfs:comment 'Calendar year for which the measure is defined.' ;
    rdfs:domain ind:HedisMeasure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:numeratorDefinition rdf:type rdf:Property ;
    rdfs:label 'Numerator Definition' ;
    rdfs:comment 'Exact definition of the numerator component of the measure.' ;
    rdfs:domain ind:HedisMeasure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retirementDate rdf:type rdf:Property ;
    rdfs:label 'Retirement Date' ;
    rdfs:comment 'Date when the measure was retired or superseded (null if still active).' ;
    rdfs:domain ind:HedisMeasure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:hedisResultId rdf:type rdf:Property ;
    rdfs:label 'Hedis Result Id' ;
    rdfs:comment 'System-generated unique identifier for each HEDIS result record.' ;
    rdfs:domain ind:HedisResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accreditationSurveyId rdf:type rdf:Property ;
    rdfs:label 'Accreditation Survey Id' ;
    rdfs:comment 'Foreign key linking to compliance.accreditation_survey. Business justification: HEDIS results are submitted as evidence during NCQA accreditation surveys. Compliance officers must trace which hedis_results supported a specific accreditation_survey. This is a core NCQA accreditati' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AccreditationSurvey .

ind:sourceClaimLineId rdf:type rdf:Property ;
    rdfs:label 'Source Claim Line Id' ;
    rdfs:comment 'Foreign key linking to claim.line. Business justification: HEDIS numerator criteria are met by specific claim service lines (e.g., a mammogram claim line satisfying Breast Cancer Screening measure). NCQA HEDIS audit requires structured traceability from resul' ;
    rdfs:domain ind:HedisResult ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Line .

ind:auditCreated rdf:type rdf:Property ;
    rdfs:label 'Audit Created' ;
    rdfs:comment 'Timestamp when the HEDIS result record was first created in the lakehouse.' ;
    rdfs:domain ind:HedisResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:auditUpdated rdf:type rdf:Property ;
    rdfs:label 'Audit Updated' ;
    rdfs:comment 'Timestamp of the most recent update to the HEDIS result record.' ;
    rdfs:domain ind:HedisResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:dataSource rdf:type rdf:Property ;
    rdfs:label 'Data Source' ;
    rdfs:comment 'Origin of the data used to determine the HEDIS result.' ;
    rdfs:domain ind:HedisResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:denominatorCriteriaMet rdf:type rdf:Property ;
    rdfs:label 'Denominator Criteria Met' ;
    rdfs:comment 'Indicates whether the member satisfied the denominator condition (typically eligibility).' ;
    rdfs:domain ind:HedisResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:measureCategory rdf:type rdf:Property ;
    rdfs:label 'Measure Category' ;
    rdfs:comment 'Category grouping of the measure (e.g., preventive, chronic).' ;
    rdfs:domain ind:HedisResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measureScore rdf:type rdf:Property ;
    rdfs:label 'Measure Score' ;
    rdfs:comment 'Numeric score assigned to the member for the measure (if applicable).' ;
    rdfs:domain ind:HedisResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:measureType rdf:type rdf:Property ;
    rdfs:label 'Measure Type' ;
    rdfs:comment 'Classification of the measure as process, outcome, or structure.' ;
    rdfs:domain ind:HedisResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measureVersion rdf:type rdf:Property ;
    rdfs:label 'Measure Version' ;
    rdfs:comment 'Version or edition of the measure as published by NCQA.' ;
    rdfs:domain ind:HedisResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:numeratorCriteriaMet rdf:type rdf:Property ;
    rdfs:label 'Numerator Criteria Met' ;
    rdfs:comment 'Indicates whether the member satisfied the numerator condition for the measure.' ;
    rdfs:domain ind:HedisResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:resultTimestamp rdf:type rdf:Property ;
    rdfs:label 'Result Timestamp' ;
    rdfs:comment 'Date and time when the HEDIS result was calculated.' ;
    rdfs:domain ind:HedisResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sourceRecordType rdf:type rdf:Property ;
    rdfs:label 'Source Record Type' ;
    rdfs:comment 'Type of the source record that supplied data for the result.' ;
    rdfs:domain ind:HedisResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cahpsSurveyId rdf:type rdf:Property ;
