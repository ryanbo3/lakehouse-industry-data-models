    rdfs:range xsd:boolean .

ind:networkGeographyRegion rdf:type rdf:Property ;
    rdfs:label 'Network Geography Region' ;
    rdfs:comment 'Geographic region code (e.g., Northeast, Midwest) where the network operates.' ;
    rdfs:domain ind:NetworkConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:networkProviderCount rdf:type rdf:Property ;
    rdfs:label 'Network Provider Count' ;
    rdfs:comment 'Total number of active providers participating in the network for the plan.' ;
