ind:householdSize rdf:type rdf:Property ;
    rdfs:label 'Household Size' ;
    rdfs:comment 'Number of individuals in the member\'s household used for eligibility calculations.' ;
    rdfs:domain ind:MedicaidEligibility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:incomeAmount rdf:type rdf:Property ;
    rdfs:label 'Income Amount' ;
    rdfs:comment 'Reported annual income used for eligibility calculation.' ;
    rdfs:domain ind:MedicaidEligibility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:incomeVerificationStatus rdf:type rdf:Property ;
    rdfs:label 'Income Verification Status' ;
    rdfs:comment 'Result of the income verification process for eligibility.' ;
    rdfs:domain ind:MedicaidEligibility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastUpdateTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Update Timestamp' ;
    rdfs:comment 'Timestamp of the most recent modification to the eligibility record.' ;
    rdfs:domain ind:MedicaidEligibility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:medicaidProgramType rdf:type rdf:Property ;
    rdfs:label 'Medicaid Program Type' ;
    rdfs:comment 'Type of Medicaid program the member is enrolled in.' ;
    rdfs:domain ind:MedicaidEligibility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:medicalNeedFlag rdf:type rdf:Property ;
    rdfs:label 'Medical Need Flag' ;
    rdfs:comment 'Indicates whether the member qualifies based on medical need criteria.' ;
    rdfs:domain ind:MedicaidEligibility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:redeterminationDueDate rdf:type rdf:Property ;
