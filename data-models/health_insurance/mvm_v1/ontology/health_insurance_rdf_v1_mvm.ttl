    rdfs:range xsd:string .

ind:networkCoverageType rdf:type rdf:Property ;
    rdfs:label 'Network Coverage Type' ;
    rdfs:comment 'Extent of coverage provided by the network for the plan (full, partial, or none).' ;
    rdfs:domain ind:NetworkConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:networkDesignation rdf:type rdf:Property ;
    rdfs:label 'Network Designation' ;
    rdfs:comment 'Overall designation of the network relative to the plan (in-network, out-of-network, or partial).' ;
