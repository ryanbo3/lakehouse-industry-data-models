    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Contact .

ind:groupDivisionId rdf:type rdf:Property ;
    rdfs:label 'Group Division Id' ;
    rdfs:comment 'Foreign key linking to employer.group_division. Business justification: Subscribers (employees) belong to a specific employer group division, which determines their benefit eligibility, contribution amounts, and plan offerings. HR/benefits administration requires division' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GroupDivision .

ind:primaryCareCoordinatorId rdf:type rdf:Property ;
    rdfs:label 'Primary Care Coordinator Id' ;
    rdfs:comment 'Foreign key linking to care.care_coordinator. Business justification: Primary Care Coordinator Assignment: case-management reports need each subscriber linked to their assigned care coordinator.' ;
    rdfs:domain ind:Subscriber ;
    rdf:type owl:ObjectProperty ;
