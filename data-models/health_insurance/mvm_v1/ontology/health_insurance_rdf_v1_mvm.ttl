ind:aggregateAttachmentFactor rdf:type rdf:Property ;
    rdfs:label 'Aggregate Attachment Factor' ;
    rdfs:comment 'Percentage of aggregate losses that must be reached before the reinsurer pays.' ;
    rdfs:domain ind:ReinsuranceArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:attachmentPoint rdf:type rdf:Property ;
    rdfs:label 'Attachment Point' ;
    rdfs:comment 'Loss amount threshold at which the reinsurer begins to pay.' ;
    rdfs:domain ind:ReinsuranceArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:attachmentPointCurrency rdf:type rdf:Property ;
    rdfs:label 'Attachment Point Currency' ;
    rdfs:comment 'ISO 4217 currency code for the attachment point amount.' ;
    rdfs:domain ind:ReinsuranceArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:corridorPercentage rdf:type rdf:Property ;
    rdfs:label 'Corridor Percentage' ;
    rdfs:comment 'Percentage range defining the corridor where losses are shared between insurer and reinsurer.' ;
    rdfs:domain ind:ReinsuranceArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lobCoverage rdf:type rdf:Property ;
    rdfs:label 'Lob Coverage' ;
    rdfs:comment 'Business line(s) to which the reinsurance treaty applies.' ;
    rdfs:domain ind:ReinsuranceArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumLiability rdf:type rdf:Property ;
    rdfs:label 'Maximum Liability' ;
    rdfs:comment 'Upper limit of the reinsurer\'s liability under the treaty.' ;
    rdfs:domain ind:ReinsuranceArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maximumRecoveryLimit rdf:type rdf:Property ;
    rdfs:label 'Maximum Recovery Limit' ;
    rdfs:comment 'Cap on the total amount the insurer can recover from the reinsurer.' ;
    rdfs:domain ind:ReinsuranceArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:premiumCeded rdf:type rdf:Property ;
    rdfs:label 'Premium Ceded' ;
    rdfs:comment 'Premium amount transferred to the reinsurer for the treaty.' ;
    rdfs:domain ind:ReinsuranceArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reinsuranceArrangementStatus rdf:type rdf:Property ;
    rdfs:label 'Reinsurance Arrangement Status' ;
    rdfs:comment 'Current lifecycle state of the reinsurance treaty.' ;
    rdfs:domain ind:ReinsuranceArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reinsurerName rdf:type rdf:Property ;
    rdfs:label 'Reinsurer Name' ;
    rdfs:comment 'Legal name of the reinsurer party to the arrangement.' ;
    rdfs:domain ind:ReinsuranceArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specificDeductible rdf:type rdf:Property ;
    rdfs:label 'Specific Deductible' ;
    rdfs:comment 'Deductible applied to each individual claim under a specific stop-loss treaty.' ;
    rdfs:domain ind:ReinsuranceArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stopLossDeductible rdf:type rdf:Property ;
    rdfs:label 'Stop Loss Deductible' ;
    rdfs:comment 'Deductible applied before stop-loss coverage becomes payable.' ;
    rdfs:domain ind:ReinsuranceArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:treatyTerms rdf:type rdf:Property ;
    rdfs:label 'Treaty Terms' ;
    rdfs:comment 'Narrative description of the treaty\'s contractual terms and conditions.' ;
    rdfs:domain ind:ReinsuranceArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:treatyType rdf:type rdf:Property ;
    rdfs:label 'Treaty Type' ;
    rdfs:comment 'Type of reinsurance treaty governing the risk transfer.' ;
    rdfs:domain ind:ReinsuranceArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reinsuranceClaimId rdf:type rdf:Property ;
    rdfs:label 'Reinsurance Claim Id' ;
    rdfs:comment 'System-generated unique identifier for the reinsurance claim record.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ReinsuranceClaim .

ind:treatingFacilityId rdf:type rdf:Property ;
    rdfs:label 'Treating Facility Id' ;
    rdfs:comment 'Foreign key linking to provider.facility. Business justification: Stop-loss and reinsurance recovery analysis requires identifying which facility generated the catastrophic cost event. Health plans track facility-level reinsurance claim concentration for network str' ;
    rdfs:domain ind:ReinsuranceClaim ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Facility .

ind:treatingProviderId rdf:type rdf:Property ;
    rdfs:label 'Treating Provider Id' ;
    rdfs:comment 'Foreign key linking to provider.provider_provider. Business justification: Reinsurance recovery analysis requires identifying which provider generated the catastrophic cost triggering stop-loss. Health plans and reinsurers track treating providers on large claims for network' ;
    rdfs:domain ind:ReinsuranceClaim ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Provider .

ind:acknowledgmentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Acknowledgment Timestamp' ;
    rdfs:comment 'Date and time when the reinsurer acknowledged receipt of the claim.' ;
    rdfs:domain ind:ReinsuranceClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:attachmentPointAmount rdf:type rdf:Property ;
    rdfs:label 'Attachment Point Amount' ;
    rdfs:comment 'Attachment point amount applied to the loss before reinsurance coverage kicks in.' ;
    rdfs:domain ind:ReinsuranceClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:claimType rdf:type rdf:Property ;
    rdfs:label 'Claim Type' ;
    rdfs:comment 'Type of reinsurance claim: stop-loss (aggregate) or specific loss.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimantType rdf:type rdf:Property ;
    rdfs:label 'Claimant Type' ;
    rdfs:comment 'Indicates whether the claimant is an individual member or an employer group.' ;
    rdfs:domain ind:ReinsuranceClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coveredEndDate rdf:type rdf:Property ;
    rdfs:label 'Covered End Date' ;
    rdfs:comment 'End date of the coverage period for which the loss occurred.' ;
    rdfs:domain ind:ReinsuranceClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:coveredStartDate rdf:type rdf:Property ;
    rdfs:label 'Covered Start Date' ;
    rdfs:comment 'Start date of the coverage period for which the loss occurred.' ;
    rdfs:domain ind:ReinsuranceClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isAggregated rdf:type rdf:Property ;
    rdfs:label 'Is Aggregated' ;
    rdfs:comment 'Indicates whether this claim aggregates multiple underlying losses (true) or represents a single loss (false).' ;
    rdfs:domain ind:ReinsuranceClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lossCategory rdf:type rdf:Property ;
    rdfs:label 'Loss Category' ;
    rdfs:comment 'Category of loss underlying the claim.' ;
    rdfs:domain ind:ReinsuranceClaim ;
