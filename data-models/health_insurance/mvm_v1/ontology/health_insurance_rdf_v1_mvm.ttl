ind:totalQuestions rdf:type rdf:Property ;
    rdfs:label 'Total Questions' ;
    rdfs:comment 'Total number of questions in the questionnaire.' ;
    rdfs:domain ind:Hra ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:conditionRegistryId rdf:type rdf:Property ;
    rdfs:label 'Condition Registry Id' ;
    rdfs:comment 'System-generated unique identifier for each condition registry record.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ConditionRegistry .

ind:confirmingProviderId rdf:type rdf:Property ;
    rdfs:label 'Confirming Provider Id' ;
    rdfs:comment 'Foreign key linking to provider.provider_provider. Business justification: Conditions in the registry are confirmed by a specific provider for HCC coding and risk adjustment. CMS risk adjustment and RADV audit requirements mandate knowing which provider confirmed each condit' ;
    rdfs:domain ind:ConditionRegistry ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Provider .

ind:medicalPolicyId rdf:type rdf:Property ;
    rdfs:label 'Medical Policy Id' ;
    rdfs:comment 'Foreign key linking to utilization.medical_policy. Business justification: Condition registry entries drive medical policy applicability for PA decisions and coverage determinations. UM reviewers reference the condition registry to validate which medical policies apply to a ' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MedicalPolicy .

ind:sourceDiagnosisId rdf:type rdf:Property ;
    rdfs:label 'Source Diagnosis Id' ;
    rdfs:comment 'Foreign key linking to claim.diagnosis. Business justification: Condition registry population from claims is a core chronic disease identification process. When a condition is identified via a claim diagnosis (ICD code), the registry entry must reference the origi' ;
    rdfs:domain ind:ConditionRegistry ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Diagnosis .

ind:sourcePharmacyClaimId rdf:type rdf:Property ;
    rdfs:label 'Source Pharmacy Claim Id' ;
    rdfs:comment 'Foreign key linking to pharmacy.pharmacy_claim. Business justification: Claims-based condition identification: a specific pharmacy claim (e.g., insulin, antidiabetic) triggers or confirms a condition registry entry. HEDIS and risk adjustment auditors must trace which phar' ;
    rdfs:domain ind:ConditionRegistry ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PharmacyClaim .

ind:sourceProcedureId rdf:type rdf:Property ;
    rdfs:label 'Source Procedure Id' ;
    rdfs:comment 'Foreign key linking to claim.procedure. Business justification: Conditions are confirmed via procedure evidence (e.g., dialysis procedure confirming ESRD). The condition registry must trace back to the originating claim procedure for HCC risk adjustment audits and' ;
    rdfs:domain ind:ConditionRegistry ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Procedure .

ind:activeFlag rdf:type rdf:Property ;
    rdfs:label 'Active Flag' ;
    rdfs:comment 'Indicates whether the condition is currently active for the member.' ;
    rdfs:domain ind:ConditionRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:conditionCategory rdf:type rdf:Property ;
    rdfs:label 'Condition Category' ;
    rdfs:comment 'Business classification of the condition (e.g., HCC-mapped, HEDIS chronic, behavioral health).' ;
    rdfs:domain ind:ConditionRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionCode rdf:type rdf:Property ;
    rdfs:label 'Condition Code' ;
    rdfs:comment 'Standard ICD-10 diagnosis code representing the clinical condition.' ;
    rdfs:domain ind:ConditionRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionDescription rdf:type rdf:Property ;
    rdfs:label 'Condition Description' ;
    rdfs:comment 'Human-readable description of the condition.' ;
    rdfs:domain ind:ConditionRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confirmationStatus rdf:type rdf:Property ;
    rdfs:label 'Confirmation Status' ;
    rdfs:comment 'Current confirmation state of the condition record.' ;
    rdfs:domain ind:ConditionRegistry ;
    rdf:type owl:DatatypeProperty ;
