    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assessmentStatus rdf:type rdf:Property ;
    rdfs:label 'Assessment Status' ;
    rdfs:comment 'Current processing status of the assessment record.' ;
    rdfs:domain ind:Hra ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentVersion rdf:type rdf:Property ;
    rdfs:label 'Assessment Version' ;
    rdfs:comment 'Version identifier of the assessment questionnaire used.' ;
