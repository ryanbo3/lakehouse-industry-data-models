# RDFS Schema for Business: Health Insurance

@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix ind: <http://datamodel.lakehouse.org/business/health_insurance#> .

# --- Root Business Class ---
ind:Business rdf:type rdfs:Class ;
    rdfs:label 'Business' ;
    rdfs:comment 'Root class for all business entities' .

# --- Specific Business: Health Insurance ---
ind:HealthInsurance rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Business ;
    rdfs:label 'Health Insurance' ;
    rdfs:comment 'Health Insurance is a critical sector providing medical, dental, and vision coverage to individuals, employers, and government beneficiaries, managing care networks and wellness programs to ensure accessible and affordable healthcare.' .

# --- Domain Classes ---
ind:Member rdf:type rdfs:Class ;
    rdfs:subClassOf ind:HealthInsurance ;
    rdfs:label 'Member' ;
    rdfs:comment 'Single source of truth for all insured individuals — members, subscribers, dependents, and beneficiaries across commercial, Medicare, Medicaid, and CHIP lines of business. Owns member demographics, PII/PHI identity, eligibility status, LOB assignment, COBRA continuants, household relationships, and member lifecycle events. All other domains reference member identity via FK. Supports HIPAA privacy obligations and CMS enrollment reporting.' .

ind:Enrollment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:HealthInsurance ;
    rdfs:label 'Enrollment' ;
    rdfs:comment 'Manages the end-to-end enrollment and eligibility lifecycle — open enrollment, special enrollment periods, qualifying life events, 834 EDI transactions, effective dates, terminations, reinstatements, and retroactive adjustments. Owns eligibility spans, coverage periods, and enrollment event history. Interfaces with CMS EDPS/RAPS for government program enrollment and supports 270/271 real-time eligibility verification.' .

ind:Plan rdf:type rdfs:Class ;
    rdfs:subClassOf ind:HealthInsurance ;
    rdfs:label 'Plan' ;
    rdfs:comment 'Single source of truth for all health plan products and benefit designs — HMO, PPO, EPO, POS, HDHP, QHP, and government plans (Medicare Advantage, Medicaid). Owns benefit structures, cost-sharing rules (deductibles, copays, coinsurance, OOP, MOOP), formulary tiers, SBC documents, plan-year configurations, and regulatory classifications. Supports ACA compliance, CMS plan submissions, and benefits configuration in core administration platforms (Facets, QNXT).' .

ind:Provider rdf:type rdfs:Class ;
    rdfs:subClassOf ind:HealthInsurance ;
    rdfs:label 'Provider' ;
    rdfs:comment 'Authoritative domain for all healthcare providers — physicians, hospitals, clinics, ancillary providers, facilities, and DME suppliers. Owns NPI-based provider identity, specialty taxonomy codes, licensure, practice locations, participation status, and provider directory information. Supports provider directory accuracy mandates (CMS, NCQA) and serves as the SSOT for provider identity. Source system: Cactus or ProviderSource.' .

ind:Claim rdf:type rdfs:Class ;
    rdfs:subClassOf ind:HealthInsurance ;
    rdfs:label 'Claim' ;
    rdfs:comment 'Core transactional domain for all medical, dental, vision, and behavioral health claims — professional (837P), institutional (837I), and dental (837D). Owns claim header and line detail, diagnosis codes (ICD), procedure codes (CPT/HCPCS), DRG assignments, adjudication decisions, EOB generation, COB processing, adjustments, denials, and LAE tracking. Interfaces with EDI clearinghouses (Availity, Change Healthcare) and supports IBNR reserving and MLR reporting.' .

ind:Pharmacy rdf:type rdfs:Class ;
    rdfs:subClassOf ind:HealthInsurance ;
    rdfs:label 'Pharmacy' ;
    rdfs:comment 'Manages pharmacy benefit administration — formulary design, drug tier assignments, NDC-level drug master, MAC/AWP/WAC pricing, retail and mail-order dispensing, specialty pharmacy, and pharmacy claim adjudication. Owns PBM contract terms, step therapy and quantity limit rules, drug utilization review (DUR) outcomes, and prior authorization for specialty drugs. Interfaces with RxClaim or Argus PBM systems and supports CMS Part D reporting.' .

ind:Billing rdf:type rdfs:Class ;
    rdfs:subClassOf ind:HealthInsurance ;
    rdfs:label 'Billing' ;
    rdfs:comment 'Single source of truth for premium billing and revenue collection — group invoicing, individual premium statements, payment processing, grace periods, retroactive adjustments, premium reconciliation, refunds, and collections. Owns APR rate structures, PMPM calculations, subsidy and APTC tracking for ACA members, and accounts receivable. Supports CMS premium remittance and state DOI financial reporting. Source system: HealthEdge or custom billing platform.' .

ind:Utilization rdf:type rdfs:Class ;
    rdfs:subClassOf ind:HealthInsurance ;
    rdfs:label 'Utilization' ;
    rdfs:comment 'Manages utilization management (UM) and prior authorization (PA) workflows — inpatient concurrent review, retrospective review, medical necessity determination, peer-to-peer processes, and UM turnaround time compliance. Owns PA requests, clinical criteria application (InterQual, MCG), authorization decisions, length-of-stay benchmarks, and denial reasons. Supports NCQA UM accreditation standards and state PA reform mandates. Source system: InterQual or MCG.' .

ind:Care rdf:type rdfs:Class ;
    rdfs:subClassOf ind:HealthInsurance ;
    rdfs:label 'Care' ;
    rdfs:comment 'Manages care management, disease management, and case management programs — chronic condition registries, care gaps, care plans, population health stratification, high-risk member outreach, and health risk assessments (HRA). Owns HCC/RAF-relevant clinical data, HEDIS measure tracking, CAHPS survey results, SNF/DME post-acute coordination, and care coordinator assignments. Source system: Casenet TruCare or Altruista. Distinct from utilization which owns UM/PA authorization workflows.' .

ind:Network rdf:type rdfs:Class ;
    rdfs:subClassOf ind:HealthInsurance ;
    rdfs:label 'Network' ;
    rdfs:comment 'Owns provider network configurations, tier assignments, in-network/out-of-network designations, geographic access standards, network adequacy metrics, and service area configurations. Manages ACO and VBC arrangement participation, network-to-plan associations, network directories, and CMS network adequacy filings. Distinct from provider identity (provider domain) and contract terms (contract domain); network owns the structural relationship between providers and plan networks.' .

ind:Employer rdf:type rdfs:Class ;
    rdfs:subClassOf ind:HealthInsurance ;
    rdfs:label 'Employer' ;
    rdfs:comment 'Manages employer group accounts — the B2B commercial customers who sponsor health coverage for their employees. Owns group demographics, SIC classification, group size, ASO/fully-insured funding arrangements, ERISA status, GFC controls, employer-subscriber relationships, contribution strategies, renewal dates, and participation requirements. Supports group billing aggregation, renewal management, and broker/TPA associations. Source system: Facets or QNXT group management module.' .

ind:Contract rdf:type rdfs:Class ;
    rdfs:subClassOf ind:HealthInsurance ;
    rdfs:label 'Contract' ;
    rdfs:comment 'Manages provider contracts, reimbursement agreements, capitation arrangements, fee schedules, value-based care (VBC) contracts, ACO agreements, risk-sharing models, contract terms, amendments, and contract lifecycle. Tracks contract effective dates, rate tables, and payment methodologies (fee-for-service, capitation, bundled payments). SSOT for all contractual and reimbursement terms between the health plan and providers.' .

ind:Appeal rdf:type rdfs:Class ;
    rdfs:subClassOf ind:HealthInsurance ;
    rdfs:label 'Appeal' ;
    rdfs:comment 'Manages member and provider appeals and grievances including claim denials, coverage disputes, utilization management appeals, external review requests, and state fair hearing processes. Tracks appeal status, resolution timelines, overturn rates, and compliance with state and federal appeal rights (ACA, ERISA). Distinct from compliance (which owns regulatory audit and reporting) and utilization (which owns initial authorization decisions).' .

ind:Risk rdf:type rdfs:Class ;
    rdfs:subClassOf ind:HealthInsurance ;
    rdfs:label 'Risk' ;
    rdfs:comment 'Manages actuarial risk assessment, underwriting, and risk adjustment programs — RAF scoring, HCC mapping, RAPS/EDPS submissions to CMS, RBC calculations, IBNR reserve estimation, and rate-setting inputs. Owns risk scores at the member level, underwriting decisions for group and individual markets, reinsurance/stop-loss arrangements, and premium rate development. Source system: Milliman MG-ALFA and actuarial models.' .

ind:Compliance rdf:type rdfs:Class ;
    rdfs:subClassOf ind:HealthInsurance ;
    rdfs:label 'Compliance' ;
    rdfs:comment 'Manages regulatory compliance obligations — HIPAA privacy and security (OCR), ACA market conduct, CMS audit readiness, state DOI filings, NCQA/URAC accreditation, SOC reporting, fraud waste and abuse (FWA) monitoring, and PHI breach notification. Owns regulatory submission calendars, audit findings, corrective action plans (CAPs), compliance attestations, and MLR compliance tracking. Supports ERISA filings and state fair hearing coordination.' .

# --- Data Product Classes (Tables) ---
ind:DrugMaster rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Pharmacy ;
    rdfs:label 'Drug Master' ;
    rdfs:comment 'Authoritative NDC-level drug master record for all covered pharmaceutical products. Captures National Drug Code (NDC), drug name, generic name, brand name, manufacturer, dosage form, strength, route of administration, drug class, controlled substance schedule, FDA approval status, and therapeutic equivalence codes (AB-rated/biosimilar). Includes generic substitution relationships and the full therapeutic classification hierarchy: ATC (Anatomical Therapeutic Chemical) code, GPI (Generic Product Identifier) prefix, pharmacological category, therapeutic class, therapeutic subclass, class name, and subclass name. This is the SSOT for all drug identity, classification, equivalence, and therapeutic hierarchy data used across formulary, claims, DUR, rebate contracting, HEDIS pharmacy measures, and PBM adjudication. Sourced from First Databank/Medi-Span drug database feeds.' .

ind:Formulary rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Pharmacy ;
    rdfs:label 'Formulary' ;
    rdfs:comment 'Master record for each formulary (drug benefit list) offered by the health plan. Defines the formulary name, effective date range, line of business (LOB), plan year, formulary type (open/closed/tiered), PBM contract reference, and regulatory filing status. A formulary is the SSOT for which drugs are covered under a given benefit design and is required for CMS Part D compliance.' .

ind:FormularyDrugTier rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Pharmacy ;
    rdfs:label 'Formulary Drug Tier' ;
    rdfs:comment 'Association entity linking a specific drug (NDC) to a formulary with its assigned tier, cost-sharing rules, coverage status, and all utilization management (UM) controls. UM controls owned by this product include: quantity limits (max quantity per fill/time period, dosage form restrictions, clinical basis), step therapy protocols (fail-first drug sequences, required step drugs, step sequence, clinical rationale, override criteria), prior authorization flags, and specialty drug designation. Captures effective date range for each tier assignment and each UM control configuration. This is the single operational record that drives member cost-sharing and UM edits at point of sale, and is the SSOT for CMS formulary file submissions including formulary, QL, ST, and PA extract files.' .

ind:DrugPricing rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Pharmacy ;
    rdfs:label 'Drug Pricing' ;
    rdfs:comment 'NDC-level drug pricing record capturing AWP (Average Wholesale Price), WAC (Wholesale Acquisition Cost), MAC (Maximum Allowable Cost), and RBP (Reference Based Pricing) values sourced from PBM pricing files. Includes effective date, pricing source, unit of measure, package size, price type, MAC list name, and MAC list methodology reference. Used for claim adjudication, cost-sharing calculation, and pharmacy reimbursement. MAC list grouping attributes are included directly on pricing records for governance and PBM contract compliance. Sourced from RxClaim or Argus PBM pricing feeds and First Databank/Medi-Span pricing updates.' .

ind:PharmacyClaim rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Pharmacy ;
    rdfs:label 'Pharmacy Claim' ;
    rdfs:comment 'Core transactional record for each pharmacy claim submitted and adjudicated through the PBM system (RxClaim or Argus). Header captures: claim number, member ID, prescriber NPI, dispensing pharmacy NPI, NDC, days supply, quantity dispensed, fill date, adjudication date, claim status, reject codes, ingredient cost, dispensing fee, copay, coinsurance, deductible applied, plan paid amount, and coordination of benefits (COB) details. Line-level detail supports multi-ingredient compound claims and COB line splits: line sequence, per-ingredient NDC, ingredient cost, dispensing fee, sales tax, incentive amount, other payer amount, patient pay amount, and basis of cost determination. Supports NCPDP D.0 transaction standards, 835 remittance, CMS Part D encounter data submissions (EDPS/RAPS), 340B claim identification for duplicate discount prevention, and pharmacy audit trail requirements. This is the SSOT for all pharmacy claim header and line-level transactional data within the pharmacy domain.' .

ind:ClaimLine rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Pharmacy ;
    rdfs:label 'Claim Line' ;
    rdfs:comment 'Line-level detail for pharmacy claims supporting multi-ingredient compound claims and coordination of benefits (COB) line splits. Captures line sequence, NDC, ingredient cost, dispensing fee, sales tax, incentive amount, other payer amount, patient pay amount, and basis of cost determination. Enables granular adjudication audit trails and compound drug cost analysis.' .

ind:PriorAuthorization rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Pharmacy ;
    rdfs:label 'Prior Authorization' ;
    rdfs:comment 'Prior authorization (PA) record for specialty and non-preferred drugs requiring clinical review before dispensing. Captures PA request date, requesting prescriber NPI, member ID, drug NDC, diagnosis codes (ICD), clinical criteria applied (InterQual/MCG), authorization status (approved/denied/pending), approved quantity, approved days supply, effective date range, and denial reason codes. Interfaces with the Utilization Management system and supports CMS Part D PA reporting.' .

ind:DurAlert rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Pharmacy ;
    rdfs:label 'Dur Alert' ;
    rdfs:comment 'Drug Utilization Review (DUR) alert record generated during pharmacy claim adjudication. Captures DUR alert type (drug-drug interaction, drug-disease, duplicate therapy, high dose, early refill), severity level, alert code (NCPDP DUR codes), prescriber NPI, dispensing pharmacy NPI, member ID, drug NDC, professional service code, result of service code, and adjudication outcome. Supports prospective and retrospective DUR programs and CMS Part D DUR reporting.' .

ind:DispensingPharmacy rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Pharmacy ;
    rdfs:label 'Dispensing Pharmacy' ;
    rdfs:comment 'Master record for retail, mail-order, and specialty pharmacies participating in the PBM network. Captures pharmacy identity: NPI, NCPDP provider ID, pharmacy name, chain/independent flag, pharmacy type (retail/mail/specialty/long-term care/compounding), address, phone, DEA number, state license. Captures network participation and contractual reimbursement terms: network tier (preferred/standard/specialty), network participation status, dispensing fee schedule, ingredient cost reimbursement basis (AWP discount/MAC/WAC), contract type (direct/PBM-administered), contract effective date range, performance requirements, audit provisions, mail-order fulfillment capabilities (cold chain certification, signature requirements), and per-pharmacy or per-chain contract variations. This is the SSOT for pharmacy provider identity, network participation, and all pharmacy-level reimbursement contract terms within the pharmacy domain; detailed credentialing lives in the provider/credential domains.' .

ind:PbmContract rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Pharmacy ;
    rdfs:label 'Pbm Contract' ;
    rdfs:comment 'Master record for PBM (Pharmacy Benefit Manager) contracts governing the relationship between the health plan and the PBM (e.g., RxClaim, Argus). Captures contract name, PBM vendor, contract type (ASO/full-risk/carve-out), effective date range, rebate guarantee terms, dispensing fee schedules, MAC list reference, performance guarantees, audit rights, and LOB scope. This is the SSOT for PBM contractual terms within the pharmacy domain.' .

ind:ProviderContract rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Contract ;
    rdfs:label 'Provider Contract' ;
    rdfs:comment 'Master record for all contractual agreements between the health plan and providers (physicians, hospitals, clinics, ancillary providers, DME suppliers), including formal contracts, Letters of Agreement (LOAs), Letters of Intent (LOIs), single-case agreements (SCAs), and out-of-network gap-fill arrangements. Captures contract type (fee-for-service, capitation, bundled payment, VBC/ACO, LOA, SCA), contract status, effective and termination dates, line of business (LOB) applicability, TPA/ASO designations, auto-renewal flags, contract tier, owning network, template reference, payment methodology classification, and service scope definitions (covered/excluded service categories, CPT/HCPCS ranges, revenue code ranges, DRG ranges, carve-out indicators, inclusion/exclusion flags). SSOT for all provider reimbursement agreements, interim arrangements, and contracted service scope. Sourced from Provider Management System (Cactus/ProviderSource) and Core Administration Platform (Facets/QNXT).' .

ind:Party rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Contract ;
    rdfs:label 'Party' ;
    rdfs:comment 'Identifies all parties bound by a provider contract — the health plan entity, the contracting provider (individual NPI or organizational NPI), group practice, IPA, ACO, or hospital system. Tracks party role (payer, provider, delegated entity), NPI, TIN, legal entity name, signatory authority, and party effective dates. Supports multi-party and delegated contracting arrangements.' .

ind:Term rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Contract ;
    rdfs:label 'Term' ;
    rdfs:comment 'Defines the specific terms, conditions, obligations, and reimbursement policies within a provider contract. Captures term type (payment methodology, exclusivity, termination clause, audit rights, hold-harmless, indemnification, confidentiality, HIPAA BAA, reimbursement rule), term text, effective date, expiration date, and whether the term is negotiable or standard boilerplate. For reimbursement rule terms: captures policy sub-type (multiple procedure reduction, bilateral procedure, assistant surgeon, global surgery, unbundling rules, place-of-service differential), applicable CPT/HCPCS ranges, reduction percentage, and LOB applicability. Enables granular tracking of contractual obligations, compliance checkpoints, and reimbursement adjudication rules. Bridges contract terms to claims adjudication logic in Facets/QNXT.' .

ind:Amendment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Contract ;
    rdfs:label 'Amendment' ;
    rdfs:comment 'Tracks all formal amendments, addenda, and modifications to an existing provider contract. Captures amendment number, amendment type (rate change, term modification, LOB addition, network tier change), effective date, reason for amendment, negotiation outcome, approval status, and the specific contract sections modified. Maintains full amendment history for audit and compliance purposes.' .

ind:FeeSchedule rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Contract ;
    rdfs:label 'Fee Schedule' ;
    rdfs:comment 'Master fee schedule defining reimbursement rates for covered services under a provider contract. Captures fee schedule name, version, effective and termination dates, payment basis (% of Medicare, % of billed charges, flat rate, RVU-based), geographic modifier applicability, LOB scope, and fee schedule type (professional, institutional, ancillary, DME, lab). SSOT for all fee-for-service reimbursement rates. Sourced from Facets/QNXT Benefits Configuration.' .

ind:FeeScheduleRate rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Contract ;
    rdfs:label 'Fee Schedule Rate' ;
    rdfs:comment 'Line-level reimbursement rates within a fee schedule. Each record defines the allowed amount or rate for a specific procedure code (CPT/HCPCS), revenue code, DRG, or service category. Captures procedure code, modifier, place of service, allowed amount, MAC/AWP/WAC reference, RBP rate, effective date, and rate derivation method. Enables adjudication systems to price claims against contracted rates.' .

ind:CapitationArrangement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Contract ;
    rdfs:label 'Capitation Arrangement' ;
    rdfs:comment 'Defines capitation payment arrangements where providers receive a fixed PMPM (Per Member Per Month) payment to cover a defined scope of services. Captures capitation rate, covered service categories, risk pool participation, stop-loss thresholds, carve-out services, attributed member population criteria, LOB applicability, and payment frequency. Supports HMO and managed care capitation models.' .

ind:CapitationPayment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Contract ;
    rdfs:label 'Capitation Payment' ;
    rdfs:comment 'Transactional record of each capitation payment disbursed to a provider under a capitation arrangement. Captures payment period (month/year), attributed member count, PMPM rate applied, gross payment amount, adjustments (retroactive enrollment changes, risk pool settlements, stop-loss recoveries), net payment amount, payment date, payment status, and remittance advice reference. Feeds accounts payable, provider remittance reporting (835 ERA), and contract financial summary reconciliation.' .

ind:VbcContract rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Contract ;
    rdfs:label 'Vbc Contract' ;
    rdfs:comment 'Master record for Value-Based Care (VBC) contracts, ACO agreements, risk-sharing arrangements, and bundled payment programs. Captures VBC model type (shared savings, shared risk, full capitation, bundled payment, pay-for-performance), ACO/IPA entity details, and reconciliation status. Includes performance period definitions with performance year, benchmark expenditure target, actual expenditure, quality score, shared savings or loss amount, reconciliation status, settlement date, minimum savings rate (MSR), maximum shared savings/loss rate, and quality gate requirements (HEDIS/STAR measure targets). For bundled payment models, captures episode definitions including episode type (joint replacement, cardiac surgery, maternity), trigger event (procedure code, DRG), episode window (days pre/post trigger), target price, included/excluded services, reconciliation methodology, and quality metrics. Supports CMS MSSP, BPCI-A, and commercial ACO/VBC reporting. SSOT for all VBC, risk-sharing, episode-based payment contractual structures, performance period tracking, bundled episode definitions, and year-over-year performance trend analysis.' .

ind:VbcPerformancePeriod rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Contract ;
    rdfs:label 'Vbc Performance Period' ;
    rdfs:comment 'Defines the measurement and reconciliation periods within a VBC contract. Captures performance year, benchmark expenditure target, actual expenditure, quality score, shared savings or loss amount, reconciliation status, and settlement date. Tracks year-over-year performance trends and supports CMS MSSP and commercial ACO reporting requirements.' .

ind:ReimbursementPolicy rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Contract ;
    rdfs:label 'Reimbursement Policy' ;
    rdfs:comment 'Defines payer reimbursement policies that govern how claims are adjudicated against contracted rates. Captures policy type (multiple procedure reduction, bilateral procedure, assistant surgeon, global surgery, unbundling rules, place-of-service differential), applicable CPT/HCPCS ranges, reduction percentage, effective date, and LOB applicability. Bridges contract terms to claims adjudication logic in Facets/QNXT.' .

ind:ServiceScope rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Contract ;
    rdfs:label 'Service Scope' ;
    rdfs:comment 'Defines the scope of covered services included or excluded under a specific provider contract. Captures service category (inpatient, outpatient, professional, ancillary, behavioral health, DME, SNF), CPT/HCPCS code ranges, revenue code ranges, DRG ranges, inclusion/exclusion flag, carve-out indicator, and applicable LOB. Determines which services are reimbursable under the contract.' .

ind:DelegationAgreement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Contract ;
    rdfs:label 'Delegation Agreement' ;
    rdfs:comment 'Manages delegation agreements where the health plan delegates specific functions (credentialing, UM, claims payment, member services) to an IPA, ACO, TPA, or medical group. Captures delegated function type, delegating entity, delegate entity, oversight requirements, audit frequency, performance standards, NCQA/URAC delegation standards compliance, and delegation effective dates. Required for NCQA accreditation and CMS oversight.' .

ind:IncentiveArrangement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Contract ;
    rdfs:label 'Incentive Arrangement' ;
    rdfs:comment 'Unified record for all performance-linked financial arrangements within provider contracts — including pay-for-performance (P4P) bonuses, quality withholds, risk withholds, shared savings distributions, performance guarantees, SLA commitments, and penalty/incentive structures. Captures arrangement type (bonus, withhold, shared savings, performance guarantee, penalty, SLA), quality measure set (HEDIS, STAR, CAHPS, custom), performance threshold tiers, withhold percentage and release criteria (quality, utilization, shared risk), withhold pool type, target metric and measurement methodology, maximum incentive or penalty amount, total withheld amount, amount released, amount forfeited, measurement period, payout schedule, earned/forfeited status, settlement date, and reporting frequency. Supports VBC quality gate enforcement, HMO/IPA withhold models, pay-for-performance programs, and provider engagement programs. SSOT for all performance-linked financial commitments in provider contracts.' .

ind:ContractNetworkParticipation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Contract ;
    rdfs:label 'Contract Network Participation' ;
    rdfs:comment 'Association entity linking a provider contract to specific network configurations, defining which provider networks the contract covers. Captures network ID reference, participation tier (tier 1, tier 2, preferred, standard, narrow), in-network effective and termination dates, out-of-network flag, geographic service area, product line applicability (commercial, Medicare Advantage, Medicaid, exchange/QHP), and participation status (active, pending, terminated). Bridges the contract domain to the network domain for directory accuracy and claims adjudication network matching.' .

ind:ProviderNetwork rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Network ;
    rdfs:label 'Provider Network' ;
    rdfs:comment 'Master entity representing a named provider network — the structural grouping of providers under a specific network product (e.g., HMO Narrow Network, PPO Broad Network, Medicare Advantage Network). Owns network identity, network type (HMO, PPO, EPO, POS), line of business association, effective/termination dates, geographic footprint, CMS network ID, NCQA accreditation status, and tier classification. SSOT for network identity — distinct from plan (benefit design), provider (provider identity), and contract (reimbursement terms).' .

ind:Tier rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Network ;
    rdfs:label 'Tier' ;
    rdfs:comment 'Defines the tier structure within a provider network — Tier 1 (preferred/lowest cost-share), Tier 2 (standard), Tier 3 (specialty/higher cost-share), and out-of-network designations. Captures tier name, tier rank, cost-share differential rules, member-facing display label, and applicability by specialty or facility type. Used to drive member cost-sharing calculations and EOB generation. Distinct from contract fee schedules (owned by contract domain).' .

ind:NetworkProvider rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Network ;
    rdfs:label 'Network Provider' ;
    rdfs:comment 'Association entity representing the participation of a specific provider (NPI) within a specific provider network, capturing in-network status, effective and termination dates, tier assignment, accepting-new-patients flag, telehealth availability, panel status (open/closed), panel capacity, and credentialing linkage. This is the SSOT for the structural relationship between a provider and a network — distinct from provider identity (provider domain), contract terms (contract domain), and ACO-specific participation (aco_provider). Supports provider directory publication, CMS network adequacy filings, and member eligibility verification.' .

ind:PlanAssociation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Network ;
    rdfs:label 'Plan Association' ;
    rdfs:comment 'Association entity linking a provider network to one or more health plan products, capturing the effective period, LOB, market segment (individual, small group, large group, Medicare, Medicaid), and whether the network is the primary or supplemental network for that plan. Enables plan-to-network resolution for eligibility verification (270/271 EDI) and claims adjudication routing. Owned by the network domain as the structural bridge between network configurations and plan offerings.' .

ind:NetworkServiceArea rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Network ;
    rdfs:label 'Network Service Area' ;
    rdfs:comment 'Defines the geographic service area for a provider network — the counties, ZIP codes, or metropolitan statistical areas (MSAs) where the network is available and where members must reside to enroll. Captures state, county FIPS code, ZIP code, service area type (county-based, ZIP-based), CMS service area ID, effective dates, and whether the area is approved for QHP/Medicare Advantage enrollment. Critical for CMS network adequacy filings and state DOI market conduct compliance.' .

ind:AdequacyStandard rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Network ;
    rdfs:label 'Adequacy Standard' ;
    rdfs:comment 'Reference entity defining all network compliance standards by specialty, facility type, and geographic area — encompassing time-distance standards (e.g., 30 miles/30 minutes for PCPs), provider-to-member ratios, appointment access wait-time standards (routine, urgent, preventive, behavioral health), after-hours availability requirements, and telehealth equivalency rules. Captures regulatory source (CMS, state DOI, NCQA, URAC), standard category (time-distance, provider-ratio, appointment-access, after-hours, telehealth-equivalency), specialty category, geographic classification (urban, suburban, rural, frontier), maximum wait time in days, threshold values, and after-hours availability flag. This is the single source of truth for all network adequacy and access compliance standards — both geographic access (time-distance, ratios) and appointment access (wait times, after-hours). Used to evaluate compliance in adequacy assessments, access surveys, and CMS/state regulatory filings.' .

ind:AdequacyAssessment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Network ;
    rdfs:label 'Adequacy Assessment' ;
    rdfs:comment 'Transactional record of a network compliance evaluation — including network adequacy assessments, access surveys, mystery shopper studies, and gap identification. Captures assessment type (adequacy, access-survey, mystery-shopper), assessment date, regulatory submission type (CMS, state DOI), specialty/facility type evaluated, provider counts, member-to-provider ratios, time-distance compliance results, wait-time measurements, survey method (member survey, secret shopper call), appointment type requested, telehealth offered flag, and overall compliance outcome. Includes detail-level gap findings as child records: specific specialty or facility type shortfalls within a geographic area, gap severity, number of providers available vs. required, remediation actions taken, and resolution status. Supports CMS network adequacy filings, NCQA HEDIS access measures (Getting Care Quickly), CAHPS survey supplementation, and targeted network development. This is the SSOT for all network compliance evaluations and their associated gap findings.' .

ind:AdequacyGap rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Network ;
    rdfs:label 'Adequacy Gap' ;
    rdfs:comment 'Captures individual network adequacy gaps identified during an adequacy assessment — specific specialty or facility type shortfalls within a geographic area that fail to meet the applicable adequacy standard. Records gap type, affected specialty, geographic area, number of providers available vs. required, gap severity, remediation action taken (e.g., provider recruitment, access plan exception), and resolution status. Enables targeted network development and regulatory gap closure tracking.' .

ind:ProviderDirectory rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Network ;
    rdfs:label 'Provider Directory' ;
    rdfs:comment 'Published provider directory record representing the member-facing view of a provider\'s network participation, including full verification lifecycle tracking. Captures provider name, specialty, practice location, phone, accepting-new-patients status, telehealth availability, languages spoken, accessibility features (ADA compliance), last verified date, and directory publication channel (online, print, API). Embeds complete verification history as child records — including verification method (outbound call, online attestation, EHR/HIE data match, claims-based inference), verification date, verified fields (address, phone, accepting-new-patients, specialty), verification outcome (confirmed, updated, unable to reach), and verifying agent/system. Supports CMS directory accuracy requirements (42 CFR 422.111), No Surprises Act compliance, the 90-day directory update mandate, and quarterly verification tracking. This is the SSOT for member-facing directory data and its verification audit trail.' .

ind:VbcArrangement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Network ;
    rdfs:label 'Vbc Arrangement' ;
    rdfs:comment 'Master entity representing Value-Based Care (VBC) programs and their participation arrangements — covering both program design (program type, sponsoring entity, quality measure set, risk model, benchmark methodology) and specific ACO/VBC participation instances (ACO name, CMS ACO ID, arrangement dates, shared savings/risk terms, participating provider groups). Supports MSSP, Next Gen, REACH, commercial P4P, episode-based payment, and capitation models. Records may represent a program definition (template) or a specific arrangement instance (participation record), distinguished by record type. Owned by the network domain as the structural participation record — financial settlement terms are owned by the contract domain.' .

ind:Exception rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Network ;
    rdfs:label 'Exception' ;
    rdfs:comment 'Transactional record of a network adequacy exception or access plan filed with a regulator when a network cannot meet standard adequacy thresholds in a specific geographic area or specialty. Captures exception type (time-distance waiver, rural exception, access plan), affected network, specialty, geographic area, regulatory body (CMS, state DOI), filing date, approval status, approved exception terms, and expiration date. Supports CMS HPMS exception filings and state DOI access plan submissions.' .

ind:AccessStandard rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Network ;
    rdfs:label 'Access Standard' ;
    rdfs:comment 'Reference entity defining appointment access and availability standards for the network — capturing standard type (routine, urgent, preventive, behavioral health), specialty category, maximum wait time in days, after-hours availability requirement, telehealth equivalency flag, and the regulatory or accreditation source (NCQA, URAC, state DOI, CMS). Distinct from adequacy_standard (which governs time-distance and provider-to-member ratios) — access_standard governs appointment availability and wait time compliance.' .

ind:VbcProgram rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Network ;
    rdfs:label 'Vbc Program' ;
    rdfs:comment 'Master entity representing a Value-Based Care (VBC) program design — the template or program structure under which ACO arrangements, pay-for-performance contracts, and shared savings models are organized. Captures program name, program type (MSSP, REACH, commercial P4P, episode-based payment, capitation), sponsoring entity (CMS, state Medicaid, commercial), program year, quality measure set, risk model (upside-only, two-sided), and benchmark methodology. Distinct from aco_arrangement (which is a specific participation instance) — vbc_program is the program definition.' .

ind:Provider rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Provider ;
    rdfs:label 'Provider Provider' ;
    rdfs:comment 'Core master entity representing all healthcare providers — physicians, hospitals, clinics, ancillary providers, facilities, DME suppliers, and behavioral health providers. Serves as the NPI-based SSOT for provider identity across the enterprise. Stores individual (Type 1 NPI) and organizational (Type 2 NPI) provider records sourced from Cactus or ProviderSource. Includes provider type, taxonomy code, primary specialty, DEA number, UPIN, TIN/EIN, gender, languages spoken (with proficiency), cultural competency certifications, contact information for key operational contacts (credentialing, billing, office manager), malpractice coverage status flag, board certification summary status, and provider status flags. Supports CMS provider directory accuracy mandates, NCQA credentialing standards, and CLAS standards for language access.' .

ind:Specialty rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Provider ;
    rdfs:label 'Specialty' ;
    rdfs:comment 'Tracks all specialty and sub-specialty designations for a provider, including primary and secondary specialties, NUCC taxonomy codes, board certification details, certification body, certification date, expiration date, and specialty-level credentialing status. A provider may hold multiple specialties across different taxonomies. Supports network adequacy analysis by specialty and HEDIS measure attribution.' .

ind:PracticeLocation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Provider ;
    rdfs:label 'Practice Location' ;
    rdfs:comment 'Represents a physical or virtual practice location where a provider delivers care. Captures address (street, city, state, ZIP+4), county, FIPS code, geolocation (lat/long), phone, fax, office hours, accessibility features (ADA compliance, wheelchair access), telehealth availability, accepting new patients flag by location, patient age/population restrictions, and location type (office, hospital, urgent care, telehealth-only). Supports CMS provider directory accuracy requirements, network adequacy geographic access standards (time/distance), and member-facing provider search. A provider may have multiple practice locations; each location may serve multiple providers.' .

ind:License rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Provider ;
    rdfs:label 'License' ;
    rdfs:comment 'Single source of truth for all professional licenses, certifications, and regulatory registrations held by a provider. Covers state medical licenses (MD, DO, NP, PA, RN, LCSW, LPC, etc.), DEA controlled substance registrations (including authorized schedules II-V and registration state), CDS (state-level controlled dangerous substance) permits, state pharmacy licenses, and other regulatory registrations. Stores license/registration type, issuing authority (state medical board, state nursing board, DEA, CMS, state pharmacy board), license or registration number, authorized schedules (for DEA/CDS), issue date, expiration date, renewal date, status (active, suspended, revoked, expired, surrendered, pending renewal), disciplinary action flags, disciplinary action details, and primary source verification (PSV) date and source. Supports NCQA credentialing standards for PSV, multi-state licensure tracking via Interstate Medical Licensure Compact, controlled substance prescribing authorization, pharmacy benefit management workflows, and state-specific scope-of-practice validation.' .

ind:ProviderAffiliation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Provider ;
    rdfs:label 'Provider Affiliation' ;
    rdfs:comment 'Captures the organizational affiliations of individual providers — medical group memberships, IPA affiliations, ACO participation, health system relationships, and hospital associations. Stores affiliation type, affiliated organization (group practice or facility reference), affiliation start and end dates, department, role, and active status. Supports provider directory accuracy, network configuration, claims routing logic, and understanding of provider-to-organization hierarchies. For hospital-based providers, captures the association with the facility where the provider practices.' .

ind:GroupPractice rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Provider ;
    rdfs:label 'Group Practice' ;
    rdfs:comment 'Represents a medical group, physician organization, IPA, or multi-specialty group practice as a distinct business entity with its own Type 2 NPI and TIN. Stores group name, group NPI, TIN/EIN, group type (solo practice, group practice, IPA, FQHC, RHC), primary specialty, address, phone, CMS certification number, and group size. Serves as the organizational parent for individual provider affiliations and supports group-level contracting and network participation.' .

ind:Facility rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Provider ;
    rdfs:label 'Facility' ;
    rdfs:comment 'Master record for healthcare facilities — hospitals, SNFs, ASCs, FQHCs, RHCs, behavioral health facilities, home health agencies, hospices, dialysis centers, and DME suppliers. Stores facility name, facility type, CMS certification number (CCN), Medicare/Medicaid certification status, accreditation body (Joint Commission, DNV, CIHQ), accreditation expiration, bed count, trauma level, teaching hospital status, critical access hospital designation, CLIA number, and facility NPI. Distinct from individual provider records; supports institutional claims (837I) routing, network adequacy facility-type analysis, and CMS Star Rating facility attribution. Serves as the organizational anchor for hospital privilege tracking.' .

ind:DirectoryEntry rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Provider ;
    rdfs:label 'Directory Entry' ;
    rdfs:comment 'Published provider directory record representing the consumer-facing view of a provider\'s participation in a specific health plan and network. Captures provider display name, accepting new patients status, languages spoken, telehealth availability, network tier, plan participation, directory publication date, last verified date, and directory accuracy attestation status. Supports CMS and state DOI provider directory accuracy mandates (no-surprise billing, network adequacy). Distinct from the internal provider master — this is the published, plan-specific directory entry.' .

ind:ExclusionScreening rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Provider ;
    rdfs:label 'Exclusion Screening' ;
    rdfs:comment 'Tracks the periodic OIG/SAM exclusion screening events performed against the provider roster. Records screening date, screening source (OIG LEIE, SAM.gov, state Medicaid exclusion list), provider NPI screened, screening result (clear, match found, potential match), match details, resolution action, and screened by. Supports monthly CMS-required exclusion screening compliance, audit trail for regulatory examinations, and Medicaid/Medicare program integrity requirements.' .

ind:DeaRegistration rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Provider ;
    rdfs:label 'Dea Registration' ;
    rdfs:comment 'Tracks Drug Enforcement Administration (DEA) registration records for providers authorized to prescribe controlled substances. Stores DEA registration number, DEA schedules authorized (II, III, IV, V), registration state, issue date, expiration date, registration status (active, expired, revoked, surrendered), and primary source verification date. Required for NCQA credentialing standards for prescribing providers and supports pharmacy benefit management and prior authorization workflows.' .

ind:HealthPlan rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Plan ;
    rdfs:label 'Health Plan' ;
    rdfs:comment 'Master catalog of all health plan products offered by the insurer — HMO, PPO, EPO, POS, HDHP, QHP, Medicare Advantage, and Medicaid managed care plans. Serves as the SSOT for plan identity, plan type classification, line of business (LOB), market segment (individual, small group, large group, Medicare, Medicaid), regulatory classification, CMS plan ID, HIOS plan ID, plan-year lifecycle, and provider network configuration (network ID, tiered network designations, access type, out-of-network coverage rules, network adequacy standards). Foundational entity for all benefit configuration, enrollment, and claims adjudication in Facets/QNXT.' .

ind:BenefitPackage rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Plan ;
    rdfs:label 'Benefit Package' ;
    rdfs:comment 'Defines the structured benefit package associated with a health plan and plan year, grouping all covered services into a coherent benefit design. Captures package name, effective dates, plan-year, benefit tier (Bronze, Silver, Gold, Platinum for ACA QHPs), actuarial value percentage, metal tier classification, embedded vs. aggregate deductible design, and full pharmacy benefit configuration — PBM vendor, formulary ID, retail vs. mail-order copay differentials, specialty pharmacy requirements, 90-day supply rules, mandatory generic substitution flags, specialty drug management programs, and retail/mail-order/specialty pharmacy network designations. One health plan may have multiple benefit packages across plan years. Sourced from benefits administration and PBM integration (RxClaim/Argus).' .

ind:Benefit rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Plan ;
    rdfs:label 'Benefit' ;
    rdfs:comment 'Granular catalog of individual covered benefits within a benefit package — medical, dental, vision, behavioral health, pharmacy, DME, SNF, home health, preventive, wellness, and ancillary services. Each benefit record captures the benefit category, CPT/HCPCS service category, coverage type (in-network, out-of-network), and serves as the anchor for child-level structures: benefit limits (visit limits, day limits, dollar limits as child arrays), exclusions and non-covered service rules (as child arrays), ACA Essential Health Benefit (EHB) classification, wellness/preventive mandate flags, and prior authorization requirement indicators. Directly drives claims adjudication rules in Facets/QNXT. Sub-entities modeled as child arrays: benefit_limit (limit_type, limit_value, limit_period, accumulation_rule), benefit_exclusion (exclusion_type, exclusion_code, exclusion_reason), and benefit_authorization_flag (auth_required, auth_type, review_level).' .

ind:CostShareRule rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Plan ;
    rdfs:label 'Cost Share Rule' ;
    rdfs:comment 'Defines cost-sharing parameters for a specific benefit within a benefit package — deductibles, copays, coinsurance rates, out-of-pocket maximums (MOOP), and accumulator threshold definitions. Captures in-network vs. out-of-network differentials, individual vs. family tier logic, embedded vs. aggregate deductible flags, HSA-compatibility indicators for HDHP plans, cost-share tier (preventive exempt, before-deductible, after-deductible), and whether cost share applies before or after deductible satisfaction. Authoritative source for member cost-sharing design used in EOB generation and claims adjudication configuration.' .

ind:Year rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Plan ;
    rdfs:label 'Year' ;
    rdfs:comment 'Defines the plan year configuration for each health plan — plan year start and end dates, open enrollment window, special enrollment period rules, grace period duration, run-out period, and plan year type (calendar year vs. non-calendar year). Governs accumulator reset logic, benefit renewal, and premium rate effective dates. Supports ACA plan year compliance and CMS reporting requirements.' .

ind:Rate rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Plan ;
    rdfs:label 'Rate' ;
    rdfs:comment 'Premium rate table for each health plan by rating factors — age band, geographic rating area, tobacco use, plan year, and market segment (individual, small group, large group). Captures the base rate, age-rated premium, family tier premium (employee only, employee + spouse, employee + child, family), rating area code, effective and termination dates, and rate filing reference. Supports premium billing, quoting, and DOI rate filing compliance. Sourced from actuarial rate-setting and pricing systems.' .

ind:PlanServiceArea rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Plan ;
    rdfs:label 'Plan Service Area' ;
    rdfs:comment 'Defines the geographic service area in which a health plan is authorized to enroll members and provide coverage. Captures the service area name, state, county, zip code inclusions/exclusions, CMS service area ID, effective dates, and regulatory approval status. Required for CMS QHP submissions, Medicare Advantage service area filings, and state DOI market conduct compliance. Governs member eligibility for plan enrollment based on residence.' .

ind:HsaHraConfig rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Plan ;
    rdfs:label 'Hsa Hra Config' ;
    rdfs:comment 'Configuration record for tax-advantaged health accounts associated with a health plan — HSA (Health Savings Account), HRA (Health Reimbursement Arrangement), FSA (Flexible Spending Account), and LPFSA (Limited Purpose FSA). Captures IRS minimum deductible threshold, IRS out-of-pocket maximum threshold (per IRS Revenue Procedure annual updates), employer contribution amount, employee contribution limit, catch-up contribution eligibility (age 55+), rollover rules (HSA unlimited, HRA employer-defined, FSA $610 carryover limit), use-it-or-lose-it flag, grace period option, plan year alignment, and HSA trustee/custodian information. Ensures HDHP plans meet IRS Section 223 HSA eligibility requirements and supports benefits administration integration with HSA custodians (Optum Bank, Fidelity, HealthEquity).' .

ind:RxBenefitConfig rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Plan ;
    rdfs:label 'Rx Benefit Config' ;
    rdfs:comment 'Pharmacy benefit configuration record linking a health plan to its PBM formulary and defining pharmacy-specific cost-sharing rules — retail vs. mail-order copay differentials, specialty pharmacy requirements, 90-day supply rules, mandatory generic substitution flags, and specialty drug management programs. Captures the PBM vendor, formulary ID, retail network type, mail-order network, specialty pharmacy network, and drug management program flags. Sourced from RxClaim/Argus PBM integration.' .

ind:NetworkConfig rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Plan ;
    rdfs:label 'Network Config' ;
    rdfs:comment 'Associates a health plan with its provider network configuration — defining which provider networks are in-network for the plan, tiered network designations (Tier 1 preferred, Tier 2 standard), out-of-network coverage rules, and network adequacy standards. Captures the network ID, network tier, access type (HMO closed, PPO open, EPO exclusive), out-of-network benefit flag, and effective dates. Links the plan domain to the network domain for claims adjudication and member directory services.' .

ind:Subscriber rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Member ;
    rdfs:label 'Subscriber' ;
    rdfs:comment 'Core master entity representing the primary insured individual (subscriber/policyholder) who holds the health insurance contract. Captures full demographic identity including SSN, date of birth, gender, marital status, language preference, race/ethnicity (for HEDIS/CMS reporting), tobacco use status, disability status, and Medicare/Medicaid beneficiary identifiers. Serves as the SSOT for subscriber identity across commercial, Medicare Advantage, Medicaid, and CHIP lines of business. All dependent, eligibility, and benefit records reference this entity. Supports HIPAA PHI/PII obligations, CMS enrollment reporting, and X12 834 subscriber loop requirements.' .

ind:Dependent rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Member ;
    rdfs:label 'Dependent' ;
    rdfs:comment 'Master entity representing individuals covered under a subscriber\'s health plan — spouses, domestic partners, children, and other qualifying dependents. Tracks relationship type to subscriber, dependent sequence number, student status, disability status, age-out eligibility rules, and CHIP/Medicaid eligibility indicators. Maintains its own demographic profile including DOB, gender, SSN, and language preference. Supports dependent verification workflows, age-out processing, and CMS CHIP enrollment reporting. Each dependent record is linked to a subscriber and an enrollment span.' .

ind:Identity rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Member ;
    rdfs:label 'Identity' ;
    rdfs:comment 'Authoritative identity resolution record for each unique insured individual (subscriber or dependent) assigned a unique member ID by the health plan. Stores the plan-assigned member ID (MBI for Medicare, Medicaid ID, commercial member ID), cross-reference IDs from source systems (Facets member ID, QNXT ID), alternate IDs (SSN hash, external subscriber ID from employer), and identity verification status. Manages member ID history and superseded IDs. This is the enterprise golden record for member identity used by all downstream domains (claims, pharmacy, care management) to resolve member identity.' .

ind:Address rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Member ;
    rdfs:label 'Address' ;
    rdfs:comment 'Manages all physical and mailing addresses associated with a member, including home address, mailing address, temporary address, and employer address. Tracks address type, effective and termination dates, address verification status (USPS CASS-certified), county FIPS code, census tract, and geographic coordinates for network adequacy analysis. Supports multiple concurrent addresses with priority ranking. Used for premium billing, EOB mailing, provider directory access, and CMS geographic reporting. Maintains address history for audit and compliance purposes.' .

ind:Contact rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Member ;
    rdfs:label 'Contact' ;
    rdfs:comment 'Single source of truth for all member contact information and addresses. Manages physical and mailing addresses (home, mailing, temporary, employer), phone numbers (home, mobile, work), email addresses, and fax numbers. Tracks contact type, address type, effective and termination dates, address verification status (USPS CASS-certified), county FIPS code, census tract, geographic coordinates for network adequacy analysis, opt-in/opt-out status per channel (SMS, email, robocall), TCPA consent flags, and preferred contact method and language. Supports multiple concurrent addresses with priority ranking. Used for premium billing, EOB mailing, provider directory access, CMS geographic reporting, member services outreach, care management communications, and CAHPS survey administration. Maintains full address and contact history for audit and compliance purposes.' .

ind:MemberEligibilitySpan rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Member ;
    rdfs:label 'Member Eligibility Span' ;
    rdfs:comment 'Core transactional entity representing a continuous period of health plan eligibility for a member. Captures effective date, termination date, termination reason code, plan ID, benefit package, group/employer ID, subscriber relationship code, premium amount, and eligibility source (834 EDI, manual entry, CMS enrollment file). Tracks eligibility status (active, terminated, suspended, COBRA), retroactive eligibility adjustments, and gap-in-coverage periods. The SSOT for answering \'Is this member eligible on date X?\' — used by claims adjudication, pharmacy, and provider eligibility verification (270/271 transactions).' .

ind:CobraContinuant rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Member ;
    rdfs:label 'Cobra Continuant' ;
    rdfs:comment 'Manages COBRA continuation coverage records for members who have lost employer-sponsored coverage due to qualifying events. Tracks qualifying event type (termination, reduction in hours, divorce, death, Medicare entitlement, dependent status loss), COBRA election date, election deadline, coverage start and end dates, maximum coverage period (18/29/36 months), premium amount (102% of group rate), payment status, and exhaustion date. Supports COBRA notice generation, election tracking, premium payment monitoring, and qualifying event triggering for the billing domain.' .

ind:PcpAssignment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Member ;
    rdfs:label 'Pcp Assignment' ;
    rdfs:comment 'Tracks Primary Care Provider (PCP) assignments for members enrolled in HMO, POS, and other gatekeeper plan types. Records assigned PCP NPI, PCP effective and termination dates, assignment type (member-selected, auto-assigned, plan-assigned), PCP change reason, PCP panel status at time of assignment, and PCP network tier. Manages PCP change request history and auto-assignment rules for newborns and new enrollees. Used for care coordination, referral authorization, capitation payment calculation, and HEDIS PCP attribution. Integrates with provider and network domains.' .

ind:CobRecord rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Member ;
    rdfs:label 'Cob Record' ;
    rdfs:comment 'Coordination of Benefits (COB) record tracking a member\'s other insurance coverage to prevent duplicate payment and ensure correct primary/secondary/tertiary payer sequencing. Captures other carrier name, other carrier member ID, other carrier group number, policy type (commercial, Medicare, Medicaid, auto, workers comp), COB order (primary/secondary/tertiary), effective and termination dates, birthday rule applicability, and COB verification date. Supports COB inquiry workflows, subrogation identification, and Medicare Secondary Payer (MSP) compliance. Used by claims adjudication for COB calculation.' .

ind:Consent rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Member ;
    rdfs:label 'Consent' ;
    rdfs:comment 'Manages member consent and authorization records required under HIPAA Privacy Rule and state privacy laws. Tracks consent type (PHI disclosure authorization, ROI — Release of Information, marketing opt-in, research participation, care management program enrollment consent, advance directive), consent status (active, revoked, expired), consent date, expiration date, authorized recipient, scope of disclosure, revocation date, and consent collection method (written, electronic, verbal with attestation). Supports HIPAA minimum necessary standard, 42 CFR Part 2 (substance abuse), and state mental health privacy requirements.' .

ind:Disenrollment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Member ;
    rdfs:label 'Disenrollment' ;
    rdfs:comment 'Captures the formal disenrollment event when a member voluntarily or involuntarily terminates health plan coverage. Records disenrollment effective date, disenrollment reason code (voluntary termination, non-payment of premium, loss of eligibility, plan termination, death, fraud, relocation out of service area), disenrollment request date, source of disenrollment (member request, employer group, CMS, state Medicaid agency), notice sent date, and appeal rights notification. Supports CMS disenrollment reporting for Medicare Advantage, Medicaid managed care disenrollment rules, and COBRA qualifying event triggering.' .

ind:EnrollmentEligibilitySpan rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Enrollment ;
    rdfs:label 'Enrollment Eligibility Span' ;
    rdfs:comment 'Core master record representing a member\'s continuous coverage period under a specific health plan, including benefit year boundaries, deductible/OOP accumulator reset dates, and MOOP thresholds. Captures effective date, termination date, coverage type, line of business (commercial, Medicare, Medicaid), plan code, subscriber relationship, eligibility status, and benefit period attributes. This is the authoritative SSOT for \'is this member covered?\' and \'what benefit period applies?\' at any point in time. One enrollment_transaction may produce one or more eligibility_spans. Sourced from Facets/QNXT enrollment module and CMS EDPS for government programs.' .

ind:Transaction rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Enrollment ;
    rdfs:label 'Transaction' ;
    rdfs:comment 'Transactional record capturing every enrollment action for a member — initial enrollment, re-enrollment, plan change, disenrollment (voluntary/involuntary termination), reinstatement, and retroactive adjustment. Tracks enrollment source, enrollment period type (open enrollment, SEP, auto-enrollment), effective date, submitted date, processing status, and transaction-type-specific attributes: termination reason/last day of coverage/grace period status for disenrollments; original termination reference/reinstatement effective date/approving authority for reinstatements; adjusted dates/financial impact flag/claims reprocessing trigger for retro adjustments. One enrollment_transaction may produce one or more eligibility_spans. Sourced from Facets/QNXT and 834 EDI transactions via Availity/Change Healthcare.' .

ind:Event rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Enrollment ;
    rdfs:label 'Event' ;
    rdfs:comment 'Granular audit log of every state transition in the enrollment lifecycle — submitted, pended, approved, rejected, effectuated, terminated, reinstated, retroactively adjusted. Each event captures the triggering action, actor (member, employer, CMS, system), timestamp, reason code, and before/after state. Supports regulatory audit trails required by CMS, state DOI, and HIPAA administrative simplification. Distinct from enrollment_transaction (which is the business action) — this is the immutable event history of that action\'s processing lifecycle.' .

ind:QualifyingLifeEvent rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Enrollment ;
    rdfs:label 'Qualifying Life Event' ;
    rdfs:comment 'Master record of a qualifying life event (QLE) that triggers a special enrollment period (SEP), including the full SEP verification lifecycle. Captures event type (marriage, birth, loss of coverage, relocation, divorce, adoption), event date, SEP window open/close dates, CMS SEP category codes, submitted documentation type and artifacts (birth certificate, marriage license, loss of coverage letter), verification status, verifier ID, verification date, CMS SEP verification outcome, pend/denial reason, and appeal reference. This is the authoritative SSOT for both QLE registration and SEP verification — no separate verification record exists. Required for ACA compliance, CMS SEP eligibility determinations, and SEP integrity program compliance. Sourced from Facets/QNXT pend workflow and member portal document uploads.' .

ind:OpenEnrollmentPeriod rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Enrollment ;
    rdfs:label 'Open Enrollment Period' ;
    rdfs:comment 'Master record defining each open enrollment window — annual employer group OE, ACA marketplace OE, Medicare Annual Enrollment Period (AEP), and Medicaid continuous enrollment periods. Captures period start/end dates, eligible population segment, LOB, exchange type (SHOP, individual marketplace, off-exchange), and enrollment volume targets. Used to govern when enrollment_records are accepted without a QLE. Sourced from CMS plan year calendars and employer group contracts.' .

ind:EligibilityVerification rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Enrollment ;
    rdfs:label 'Eligibility Verification' ;
    rdfs:comment 'Transactional record of real-time 270/271 eligibility verification requests and responses. Captures requesting provider NPI, member identifier used, inquiry date/time, response status, coverage details returned, deductible/OOP balances returned, and response time SLA. Supports provider-facing eligibility verification at point of care. Sourced from Availity/Change Healthcare 270/271 gateway and Facets real-time eligibility API.' .

ind:CobraElection rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Enrollment ;
    rdfs:label 'Cobra Election' ;
    rdfs:comment 'Master record tracking COBRA continuation coverage elections for members who have lost group health coverage due to a qualifying event (termination, reduction in hours, divorce, death, aging off dependent). Captures qualifying event type, election notice date, election deadline, election status, COBRA premium amount (102% of full premium), coverage start/end dates, subsidy eligibility (ARP COBRA subsidy), and COBRA-specific notice tracking (initial notice, election notice, early termination notice). Governed by ERISA Section 601-608 and DOL COBRA regulations. Sourced from Facets/QNXT COBRA module.' .

ind:PlanElection rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Enrollment ;
    rdfs:label 'Plan Election' ;
    rdfs:comment 'Master record of a subscriber\'s specific plan selection, coverage tier, and covered member roster during an enrollment or plan change event. Captures elected plan ID, coverage tier (employee-only, employee+spouse, employee+children, family), effective date, prior plan reference, premium contribution split (employer vs. employee), HSA/HRA/FSA election flag, dental/vision rider elections, and the roster of covered individuals with their relationship codes, age-out dates, and COBRA continuation eligibility. References member domain for person identity — this product owns the enrollment-specific election and roster, not the person demographics. Represents the member\'s choice artifact — distinct from eligibility_span (the resulting coverage). Sourced from Facets/QNXT benefits election module.' .

ind:MedicaidEligibility rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Enrollment ;
    rdfs:label 'Medicaid Eligibility' ;
    rdfs:comment 'Master record tracking Medicaid and CHIP eligibility determinations for members enrolled in managed Medicaid plans. Captures Medicaid eligibility category (MAGI, SSI, CHIP, dual-eligible), state Medicaid ID, eligibility determination date, redetermination due date, income verification status, household size, FPL percentage, and dual-eligible Medicare coordination flag. Interfaces with state Medicaid agency eligibility systems and CMS EDPS. Sourced from state 834 files and Facets Medicaid module.' .

ind:MedicareEntitlement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Enrollment ;
    rdfs:label 'Medicare Entitlement' ;
    rdfs:comment 'Master record capturing Medicare entitlement and enrollment details for members in Medicare Advantage (MA) and Part D plans. Captures Medicare Beneficiary Identifier (MBI), Part A/B entitlement dates, MA enrollment effective date, Part D enrollment effective date, Low Income Subsidy (LIS) status, Extra Help level, IRMAA status, and CMS contract/PBP assignment. Sourced from CMS MARx system data and EDPS enrollment confirmations.' .

ind:ExchangeEnrollment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Enrollment ;
    rdfs:label 'Exchange Enrollment' ;
    rdfs:comment 'Master record for enrollments originating from ACA health insurance exchanges — Federally Facilitated Marketplace (FFM), State-Based Marketplaces (SBM), and SHOP exchange. Captures exchange transaction ID, marketplace plan ID (HIOS ID), APTC amount and reconciliation status, CSR variant, eligibility determination reference, effectuation status, 1095-A reporting flag, and premium payment effectuation deadline. Interfaces with CMS FFM enrollment data feeds. Critical for ACA compliance, APTC reconciliation with IRS, and annual 1095-A generation. Sourced from Availity/Change Healthcare exchange gateway and CMS 834 files.' .

ind:MemberRiskScore rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Risk ;
    rdfs:label 'Member Risk Score' ;
    rdfs:comment 'Authoritative member-level risk score record and reconciliation tracker. Captures RAF (Risk Adjustment Factor) scores, HCC (Hierarchical Condition Category) mappings, CMS reconciliation outcomes, and plan-vs-CMS variance analysis. Stores prospective and concurrent RAF scores derived from actuarial models and encounter data, including score effective dates, payment year, model version (CMS-HCC, RxHCC, HHS-HCC, PACE), score components, CMS submission status, plan-calculated vs. CMS-published RAF variance, root cause category (missing diagnoses, HCC hierarchy differences, demographic factors), corrective actions, and resubmission references. Core SSOT for member-level risk in Medicare Advantage, ACA, and Medicaid risk adjustment programs. Subsumes RAF reconciliation tracking.' .

ind:HccMapping rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Risk ;
    rdfs:label 'Hcc Mapping' ;
    rdfs:comment 'Maps ICD-10 diagnosis codes to Hierarchical Condition Categories (HCCs) per CMS model version. Stores the ICD-to-HCC crosswalk, HCC hierarchy relationships (parent/child HCC hierarchies), coefficient values by model year, disease interaction flags, and demographic adjustment factors. Supports RAF score calculation, RAPS/EDPS submission validation, and RADV audit defense. Reference entity managed per CMS annual model updates (V24, V28 transition). Source: CMS annual HCC model release files.' .

ind:RapsSubmission rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Risk ;
    rdfs:label 'Raps Submission' ;
    rdfs:comment 'Tracks Risk Adjustment Processing System (RAPS) submissions to CMS for Medicare Advantage risk adjustment. Captures submission batch ID, submission date, plan contract number, payment year, record counts, accepted/rejected record counts, CMS acknowledgment status, and error disposition. Each record represents a RAPS batch transaction submitted via the CMS RAPS gateway. Source: Milliman MG-ALFA and EDI gateway.' .

ind:CmsSubmission rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Risk ;
    rdfs:label 'Cms Submission' ;
    rdfs:comment 'Tracks CMS risk adjustment data submissions for Medicare Advantage via both RAPS (Risk Adjustment Processing System) and EDPS (Encounter Data Processing System) channels. Captures submission batch ID, submission type (RAPS/EDPS), submission date, contract/PBP number, payment year, service year, encounter type, record counts, accepted/rejected counts, CMS acknowledgment status, error disposition, and RAPS-to-EDPS transition compliance flags. Each record represents a batch transaction submitted to CMS for risk adjustment processing. Supports RADV audit readiness and CMS reconciliation. Note: This product should be renamed to cms_submission after the RAPS+EDPS merge.' .

ind:RiskUnderwritingCase rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Risk ;
    rdfs:label 'Risk Underwriting Case' ;
    rdfs:comment 'Represents an underwriting decision record for group or individual market applicants, including the group-level risk profile used in underwriting evaluation and renewal rating. Captures underwriting case number, applicant type (group/individual/small group/large group), LOB, underwriting tier, risk classification, medical underwriting status, final decision (approved/declined/rated), effective date, underwriter ID, decision rationale, and applicable underwriting rules/criteria. For group cases, includes aggregate risk profile: rating period, total member months, age/gender distribution index, morbidity factor, industry risk factor, prior year claims PMPM, expected claims PMPM, large claimant count, chronic condition prevalence rates, and overall group risk score. Supports fully-insured and self-insured (ASO) underwriting workflows, group renewal underwriting, and stop-loss pricing.' .

ind:ReinsuranceArrangement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Risk ;
    rdfs:label 'Reinsurance Arrangement' ;
    rdfs:comment 'Master record for reinsurance and stop-loss arrangements protecting the health plan against catastrophic or excess losses. Captures treaty type (quota share, excess of loss, aggregate stop-loss, specific stop-loss), reinsurer name, attachment point, specific deductible amount, aggregate attachment factor and amount, corridor percentage, maximum liability, coinsurance percentage, maximum recovery limit, premium ceded, effective and expiration dates, LOB coverage, and treaty terms. Includes stop-loss threshold parameters for self-insured employer groups. Supports both individual specific stop-loss and aggregate stop-loss for self-insured groups.' .

ind:ReinsuranceClaim rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Risk ;
    rdfs:label 'Reinsurance Claim' ;
    rdfs:comment 'Transactional record of reinsurance recoveries and stop-loss claims submitted to reinsurers. Captures reinsurance claim number, arrangement reference, claimant (member or group), covered period, total incurred amount, attachment point applied, recoverable amount, submission date, reinsurer acknowledgment, payment received date, and recovery status. Tracks both specific and aggregate stop-loss recovery transactions.' .

ind:Program rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Care ;
    rdfs:label 'Program' ;
    rdfs:comment 'Master registry of all care management, disease management, and case management programs offered by the health plan — including chronic condition programs (diabetes, CHF, COPD, asthma), complex case management, maternity management, behavioral health programs, and population health initiatives. Tracks program type, eligibility criteria, clinical protocols, accreditation standards (NCQA/URAC), program status, and line-of-business applicability. Source: Casenet TruCare or Altruista program configuration.' .

ind:CareEnrollment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Care ;
    rdfs:label 'Care Enrollment' ;
    rdfs:comment 'Tracks member enrollment into specific care management, disease management, or case management programs — capturing enrollment date, disenrollment date, enrollment source (outreach, referral, self-referral, claims-triggered, HRA-triggered), consent status, program tier, enrollment status, and acuity level. Represents the active participation record linking a member to a care program. Coordinator assignment details are maintained on the care_coordinator product. Distinct from health plan enrollment (owned by the enrollment domain). Source: Casenet TruCare or Altruista.' .

ind:CarePlan rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Care ;
    rdfs:label 'Care Plan' ;
    rdfs:comment 'Individualized care plan created for a member enrolled in a care or case management program — documenting clinical and behavioral goals (goal description, category, target value, target date, status: active/achieved/abandoned, progress notes), interventions, barriers to care, target dates, care coordinator assignments, plan status, and clinical/progress notes. Goals are modeled as embedded detail records within the care plan with independent status tracking, enabling multi-dimensional progress measurement across clinical, behavioral, and SDOH goal categories. Single source of truth for all care plan goal lifecycle management. Supports longitudinal tracking of member health outcomes. Aligns with NCQA care management standards and CMS chronic care management (CCM) requirements. Source: Casenet TruCare or Altruista.' .

ind:PlanGoal rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Care ;
    rdfs:label 'Plan Goal' ;
    rdfs:comment 'Individual clinical or behavioral goals defined within a member care plan — including goal description, goal category (clinical, behavioral, social determinants), target value, target date, goal status (active, achieved, abandoned), and progress notes. Each goal has its own lifecycle independent of the parent care plan, enabling granular tracking of member progress across multiple care dimensions.' .

ind:Gap rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Care ;
    rdfs:label 'Gap' ;
    rdfs:comment 'Registry of identified care gaps for members — preventive services, chronic condition management measures, and HEDIS-aligned quality measures that have not been completed (e.g., HbA1c testing, mammography, colorectal cancer screening, medication adherence). Tracks gap type, HEDIS measure code, gap open date, gap close date, closure method (claim, supplemental data, attestation), and gap status. Core to HEDIS performance and Star Ratings improvement programs.' .

ind:Coordinator rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Care ;
    rdfs:label 'Coordinator' ;
    rdfs:comment 'Master record for care coordinators, case managers, disease management nurses, and health coaches — capturing demographics, credentials (RN, LCSW, CHW), certifications (CCM, ACM), caseload capacity, specialty focus areas, assigned LOB, active status, and supervisor hierarchy. Single source of truth for coordinator-to-member assignment history including assignment date, assignment type (primary, backup, specialist), assignment reason, caseload weight, assignment status, reassignment/handoff tracking, and continuity-of-care documentation. Enables caseload management, workload balancing, continuity-of-care reporting, and coordinator performance analytics. Source: Casenet TruCare or Altruista workforce configuration.' .

ind:CoordinatorAssignment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Care ;
    rdfs:label 'Coordinator Assignment' ;
    rdfs:comment 'Assignment record linking a care coordinator to a specific member care enrollment or case — capturing assignment date, assignment type (primary, backup, specialist), assignment reason, caseload weight, and assignment status. Tracks the full history of coordinator-to-member assignments including reassignments and handoffs. Enables caseload management, workload balancing, and continuity-of-care reporting.' .

ind:MemberOutreach rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Care ;
    rdfs:label 'Member Outreach' ;
    rdfs:comment 'Records of outreach activities conducted by care coordinators or automated systems to engage high-risk members in care management programs — including outreach date, outreach channel (phone, mail, SMS, portal), outreach purpose (program enrollment, care gap closure, HRA completion, medication adherence), outcome (reached, left voicemail, refused, enrolled), and follow-up requirements. Supports population health engagement tracking and HEDIS outreach documentation.' .

ind:Hra rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Care ;
    rdfs:label 'Hra' ;
    rdfs:comment 'Health Risk Assessment (HRA) and Social Determinants of Health (SDOH) screening records completed by members — capturing assessment date, assessment type (HRA, SDOH screening), assessment version, screening tool (plan-specific HRA, AHC HRSN, PRAPARE, Hunger Vital Sign), completion channel (portal, phone, mail), risk score, risk tier (low, moderate, high, very high), identified health risks, SDOH domain flags (food insecurity, housing instability, transportation, social isolation, financial strain, education), community resource referrals, recommended programs, and assessment status. Includes the versioned questionnaire catalog (question text, category, response type, scoring weight) and individual member responses with clinical flag triggers. Single source of truth for all member health risk and SDOH assessments. HRAs are a CMS-required data element for Medicare Advantage plans and drive care program enrollment and risk stratification. SDOH screenings support CMS health equity requirements and NCQA SDOH standards. Source: Casenet TruCare or Altruista.' .

ind:ConditionRegistry rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Care ;
    rdfs:label 'Condition Registry' ;
    rdfs:comment 'Chronic condition registry identifying members with specific diagnosed conditions — including ICD-10 condition code, condition category (HCC-mapped, HEDIS chronic condition, behavioral health), identification method (claims-based, EHR, provider attestation, HRA), identification date, confirmation status, and active/inactive flag. Serves as the authoritative clinical condition roster within the care domain for care program targeting, population health stratification, and HEDIS measure eligibility determination. References the risk domain for authoritative HCC/RAF scoring. Source: Casenet TruCare or Altruista clinical data.' .

ind:HedisMeasure rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Care ;
    rdfs:label 'Hedis Measure' ;
    rdfs:comment 'Reference catalog of HEDIS (Healthcare Effectiveness Data and Information Set) quality measures maintained by NCQA — including measure ID, measure name, measure domain (effectiveness of care, access/availability, utilization), measurement year, eligible population criteria, numerator definition, denominator definition, exclusion criteria, and data collection methodology (administrative, hybrid, survey). Authoritative reference for HEDIS performance tracking and Star Ratings.' .

ind:HedisResult rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Care ;
    rdfs:label 'Hedis Result' ;
    rdfs:comment 'Single source of truth for HEDIS (Healthcare Effectiveness Data and Information Set) quality measure definitions and member-level compliance results. Contains the authoritative NCQA-published measure catalog (measure ID, name, domain: effectiveness of care/access/availability/utilization, measurement year, eligible population criteria, numerator/denominator definitions, exclusion criteria, data collection methodology: administrative/hybrid/survey) and member-level results indicating whether each member met numerator criteria for a given measurement year. Tracks data source (claim, lab, supplemental, medical record), compliance status (compliant, non-compliant, excluded), and hybrid audit trail. Aggregated to produce plan-level HEDIS rates submitted to NCQA for Star Ratings, accreditation, and quality bonus payments.' .

ind:CahpsSurvey rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Care ;
    rdfs:label 'Cahps Survey' ;
    rdfs:comment 'CAHPS (Consumer Assessment of Healthcare Providers and Systems) survey administration and response records — capturing survey type (Health Plan CAHPS, Medicare CAHPS, PCMH CAHPS), survey year, administration method (mail, phone, mixed), member sampling frame, survey vendor, response status, overall satisfaction score, and individual member responses by question with composite score contribution flags. CAHPS results feed directly into CMS Star Ratings and NCQA accreditation. Enables drill-down analysis of member experience drivers across CAHPS domains (getting needed care, getting care quickly, doctor communication, customer service). Source: Survey vendor data.' .

ind:MemberRiskTier rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Care ;
    rdfs:label 'Member Risk Tier' ;
    rdfs:comment 'Member-level risk tier assignment and population health stratification — containing population segment definitions (segment name, stratification model: predictive risk model/HCC-based/claims-based, risk tier bands: low/rising risk/high/catastrophic, inclusion criteria, recommended care program, PMPM cost band, effective date) and member-specific tier assignments (risk score, assignment date, assignment method: automated model/manual override/clinical review, next reassessment date). Single source of truth for both population segment configuration and member-level risk tier history. Tracks risk tier changes over time to support longitudinal population health management and care program targeting. Distinct from CMS RAF scores (owned by the risk domain) — this covers all LOBs and internal stratification models. Source: Casenet TruCare or Altruista population health module.' .

ind:SdohAssessment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Care ;
    rdfs:label 'Sdoh Assessment' ;
    rdfs:comment 'Social Determinants of Health (SDOH) assessment records capturing non-clinical factors affecting member health outcomes — including assessment date, SDOH domain (food insecurity, housing instability, transportation, social isolation, financial strain, education), screening tool used (AHC HRSN, PRAPARE, Hunger Vital Sign), risk level, referral to community resource made flag, and follow-up status. Supports CMS health equity requirements, NCQA SDOH standards, and targeted care management interventions.' .

ind:Grievance rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Appeal ;
    rdfs:label 'Grievance' ;
    rdfs:comment 'Master record for all member and provider grievances — formal expressions of dissatisfaction with health plan decisions, service quality, or administrative actions that do not contest a specific adverse benefit determination. Distinct from appeals (which contest specific ABDs) per CMS and state DOI classification rules. Tracks grievance type (quality of care, access, billing, customer service, provider behavior), filing party, filing channel, acknowledgment date, investigation findings, resolution date, resolution type, regulatory classification (CMS CTM categories for Medicare, state DOI categories for commercial), and case notes. SSOT for grievance identity and lifecycle in the appeal domain. Supports ACA, Medicare Part C/D CTM, and state DOI grievance reporting requirements.' .

ind:Case rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Appeal ;
    rdfs:label 'Case' ;
    rdfs:comment 'Core master record for every formal appeal filed by a member, provider, or authorized representative contesting an adverse benefit determination (ABD). Captures appeal type (first-level internal, second-level internal, expedited, external independent review, state fair hearing), regulatory tier (ACA, ERISA, Medicare Part C/D, Medicaid/CHIP), line-of-business classification, and appeal level tracking for multi-level appeal processes. Includes filing details (channel, filing party type, receipt timestamp, filing method, completeness determination, expedited trigger, supporting documentation checklist), resolution details (decision type — upheld, overturned, partially overturned, withdrawn, dismissed, remanded — decision rationale, clinical criteria applied, decision author NPI or committee ID, decision date, effective date of benefit change, member/provider notification date), and overturn reason. Also tracks expedited appeal attributes (clinical urgency basis, 72-hour clock, treating provider attestation) when applicable. Primary SSOT for appeal identity, filing, resolution, and outcome in the appeal domain. Serves as the binding record of plan decision for regulatory reporting, HEDIS measurement, downstream claim reprocessing triggers, and benefit restoration workflows.' .

ind:AdverseDetermination rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Appeal ;
    rdfs:label 'Adverse Determination' ;
    rdfs:comment 'Records every adverse benefit determination (ABD) issued by the health plan — the triggering event for member and provider appeal rights. Captures determination type (denial, reduction, termination, non-authorization), basis for denial (medical necessity, benefit exclusion, out-of-network, experimental), clinical criteria applied (InterQual/MCG guideline version), issuing reviewer NPI, determination date, effective date, and the specific claim, authorization, or enrollment action being denied. Links to the originating claim or prior authorization in the claim and utilization domains. Owned by the appeal domain as the formal adverse action record.' .

ind:Review rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Appeal ;
    rdfs:label 'Review' ;
    rdfs:comment 'Tracks each discrete review action performed on an appeal case — first-level clinical review, second-level peer review, medical director review, and committee review. Captures reviewer identity (NPI for clinical reviewers), reviewer specialty, review type, review date, review outcome, clinical rationale, criteria applied (ICD/CPT codes reviewed, DRG, InterQual/MCG criteria version), and whether the review was conducted by a reviewer not involved in the original adverse determination. Supports NCQA and URAC reviewer independence requirements.' .

ind:ExternalReview rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Appeal ;
    rdfs:label 'External Review' ;
    rdfs:comment 'Manages Independent Medical Review (IMR) and External Independent Review Organization (IRO) requests — the federally mandated external review process under ACA §2719 and state external review laws. Tracks IRO assignment, IRO accreditation status, case transmission date, IRO decision date, IRO decision (uphold/overturn), IRO clinical rationale, binding determination flag, and plan compliance action taken. Distinct from internal appeal reviews. Supports CMS external review reporting and state DOI compliance.' .

ind:Timeline rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Appeal ;
    rdfs:label 'Timeline' ;
    rdfs:comment 'Tracks all regulatory and contractual deadline milestones for each appeal case — acknowledgment due date, decision due date, expedited decision due date, extension notification date, and actual completion dates. Captures regulatory clock type (ACA, ERISA, Medicare Part C/D, Medicaid, state DOI), clock start event, clock pause events, compliance status (on-time, late, extended), and SLA breach details (days overdue, root cause category, corrective action, self-report flag) when milestones are missed. Drives proactive SLA management, regulatory timeliness reporting to CMS and state DOIs, and breach tracking for quality improvement programs.' .

ind:Document rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Appeal ;
    rdfs:label 'Document' ;
    rdfs:comment 'Manages all documents associated with an appeal or grievance case — member-submitted evidence, medical records, EOB copies, denial letters, acknowledgment letters, decision letters, IRO submissions, hearing transcripts, and peer-to-peer review notes. Tracks document type, document source, receipt date, document format, storage reference (BLOB/S3 path), PHI classification, redaction status, retention period (7-10 years per CMS and state DOI requirements), and whether the document was considered in the review decision. Supports HIPAA PHI handling requirements, regulatory record retention obligations, and litigation hold compliance.' .

ind:Communication rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Appeal ;
    rdfs:label 'Communication' ;
    rdfs:comment 'Records all outbound and inbound communications related to appeal and grievance cases — acknowledgment letters, extension notices, decision letters (NOA/NOAD), Notice of Appeal Rights, member rights notices, requests for additional information, and member/provider responses. Tracks communication type, communication channel (mail, phone, secure portal, fax), sent/received date, recipient type, language, accessibility accommodation (large print, Braille, interpreter), regulatory notice compliance flag, regulatory basis, delivery confirmation, and returned mail tracking. Supports ACA §2719, ERISA §503, and state DOI member notice requirements.' .

ind:CoverageDispute rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Appeal ;
    rdfs:label 'Coverage Dispute' ;
    rdfs:comment 'Master record for coverage disputes — formal disagreements between members, providers, or employer groups and the health plan regarding benefit interpretation, plan exclusions, coordination of benefits (COB) determinations, or subrogation decisions. Captures dispute type (benefit interpretation, COB, subrogation, network status, formulary exception), disputing party, disputed benefit or service, plan position, and resolution outcome. For COB disputes, additionally captures other carrier information, COB rule applied (birthday rule, NAIC COB model), disputed payer order, coordination amount, and inter-plan communication records. Supports ERISA plan document interpretation, NAIC COB model law compliance, and state DOI market conduct requirements.' .

ind:IroOrganization rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Appeal ;
    rdfs:label 'Iro Organization' ;
    rdfs:comment 'Master reference for Independent Review Organizations (IROs) and external review entities contracted or approved to conduct external independent reviews. Captures IRO name, URAC/NCQA accreditation status, accreditation expiration date, state approval status (by state), specialty capabilities, conflict-of-interest attestation date, contract effective dates, and assignment rotation methodology. Required for ACA §2719 external review compliance and state external review law adherence. Distinct from the provider and contract domains — IROs are specialized regulatory entities, not clinical providers.' .

ind:PremiumInvoice rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Billing ;
    rdfs:label 'Premium Invoice' ;
    rdfs:comment 'Core billing document representing a premium invoice or statement issued to an employer group, individual member (IFP/ACA marketplace direct-pay), COBRA qualified beneficiary, or government sponsor for a specific billing period. Captures invoice number, billing period start/end, total premium due, subsidy/APTC amounts applied, net amount due, invoice status (draft, issued, paid, partially paid, void, delinquent), due date, document type (group list-bill invoice, group self-bill invoice, individual member statement, COBRA invoice, government remittance request), delivery method (mail, email, member portal), line-of-business (LOB), statement-specific fields for IFP direct-pay members (statement number, member reference, plan name, statement delivery preference), and source system reference from HealthEdge or custom billing platform. SSOT for ALL premium billing documents — both group invoices and individual member statements — in the billing domain.' .

ind:InvoiceLine rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Billing ;
    rdfs:label 'Invoice Line' ;
    rdfs:comment 'Line-item detail within a premium invoice, representing a single member or subscriber coverage charge for a billing period. Captures member/subscriber reference, plan code, coverage tier (EE, EE+SP, EE+CH, FAM), rate type, gross premium, employer contribution, employee contribution, APTC subsidy amount, CSR adjustment, retroactive adjustment indicator, and effective coverage dates. Supports PMPM-level billing reconciliation.' .

ind:PremiumPayment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Billing ;
    rdfs:label 'Premium Payment' ;
    rdfs:comment 'Records an actual payment received against a premium invoice, capturing payment date, payment amount, payment method (ACH, check, wire, credit card, EFT), payment reference number, payer type (employer group, individual member, CMS, state Medicaid agency), applied invoice reference, unapplied/suspense balance, NSF/return indicator, reconciliation status, and full suspense management lifecycle (suspense status, suspense reason code — unidentified payer, amount mismatch, duplicate payment, missing invoice reference — received amount, receipt date, payer name, payer account reference, assigned resolver, resolution due date, resolution outcome — applied to invoice, refunded, written off — resolution date). Payments in suspense status are tracked inline with complete resolution workflow rather than in a separate suspense entity. SSOT for all inbound premium cash receipts including suspense items, their investigation, and resolution lifecycle.' .

ind:PaymentAllocation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Billing ;
    rdfs:label 'Payment Allocation' ;
    rdfs:comment 'Association and reconciliation entity linking premium payments to invoice lines, tracking line-level allocation, and managing periodic premium reconciliation outcomes. For allocation: captures allocated amount, allocation date, allocation type (standard, partial, overpayment, suspense resolution), and line-level reconciliation status. Supports many-to-many payment-to-invoice matching and enables accurate accounts receivable aging. For periodic reconciliation: captures reconciliation period, total billed, total collected, total adjustments, variance amount, variance reason, reconciliation status (open, in review, approved, closed), approver reference, and reconciliation type (monthly, quarterly, annual). Supports MLR calculation inputs, financial close processes, CMS premium reconciliation, and end-to-end premium reconciliation from individual line-level allocation through period-level summary and variance analysis. SSOT for all payment allocation and premium reconciliation in the billing domain.' .

ind:Account rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Billing ;
    rdfs:label 'Account' ;
    rdfs:comment 'Master billing account representing the financial relationship between the health plan and a billing entity — employer group, individual subscriber, or government program (Medicare, Medicaid, CHIP). Captures account number, account type, billing frequency (monthly, quarterly, annual), billing method (self-bill, list-bill, direct-bill), payment terms, auto-pay enrollment, current balance, credit limit, account status, assigned billing representative, billing cycle configuration (cycle type — monthly/quarterly/semi-annual/annual, invoice generation date, payment due date, grace period days, next/last invoice dates, auto-renewal flag, billing calendar reference), and registered payment methods (payment method type — ACH/EFT, check, wire transfer, credit card, debit card, HSA/FSA — with masked/tokenized bank routing and account numbers, card last four digits, card expiration date, auto-pay authorization flag, authorization date and reference, active/inactive status per method, PCI-DSS compliant storage). SSOT for billing account identity, billing cycle configuration, and authorized payment methods.' .

ind:PremiumRate rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Billing ;
    rdfs:label 'Premium Rate' ;
    rdfs:comment 'Defines the APR (Annual Premium Rate) and PMPM rate structures for a plan, coverage tier, rating area, and effective date range, including the parent rate schedule configuration that governs how rates are structured and applied. Captures rate schedule name, rating method (community rated, age-rated, composite rated, experience rated), market segment, plan code, coverage tier, rating area, age band (for ACA age-rated plans), tobacco surcharge rate and rules, wellness discount rate and rules, employer contribution rate, employee contribution rate, COBRA rate (active employee rate + 2% admin fee), family tier structure, rate effective/expiration dates, state DOI rate filing reference number, rating area reference, and regulatory filing metadata. SSOT for all premium calculation inputs, rate schedule configurations, rate filing metadata, and rate structure definitions used in invoice generation.' .

ind:GracePeriod rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Billing ;
    rdfs:label 'Grace Period' ;
    rdfs:comment 'Tracks the grace period status for a billing account or member when premium payment is overdue. Captures grace period start date, grace period end date (typically 30 days for individual/ACA, 31 days for group), grace period type (ACA APTC grace period is 90 days), triggering invoice reference, current grace period day count, termination warning issued flag, and resolution outcome (paid, terminated, reinstated). Required for ACA compliance and state DOI reporting.' .

ind:RetroAdjustment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Billing ;
    rdfs:label 'Retro Adjustment' ;
    rdfs:comment 'Captures retroactive premium adjustments and billing disputes resulting from enrollment changes, eligibility corrections, rate corrections, COB updates, or contested billing amounts applied to prior billing periods. Records adjustment type (add, term, rate change, tier change, dispute credit, dispute correction), original billing period, adjustment amount (positive or negative), reason code, dispute tracking fields (dispute type — invoice amount, payment misapplication, rate error, retro adjustment, APTC discrepancy — disputed amount, dispute open date, dispute status — open, under review, resolved, escalated — resolution type — credit issued, invoice corrected, upheld — resolution date, resolution notes), authorization reference, and resulting invoice or credit memo reference. SSOT for all retroactive billing adjustments and billing dispute resolution in the billing domain. Critical for accurate premium reconciliation, dispute lifecycle management, and financial reporting.' .

ind:AptcSubsidy rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Billing ;
    rdfs:label 'Aptc Subsidy' ;
    rdfs:comment 'Tracks Advance Premium Tax Credit (APTC) and Cost-Sharing Reduction (CSR) subsidy amounts for ACA marketplace members. Captures member reference, QHP plan code, marketplace exchange ID, APTC monthly amount, CSR variant level (73%, 87%, 94%), annual APTC cap, year-to-date APTC applied, subsidy effective date, subsidy termination date, and CMS reconciliation status. Required for ACA Section 1401/1402 compliance and CMS premium remittance reporting.' .

ind:Cycle rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Billing ;
    rdfs:label 'Cycle' ;
    rdfs:comment 'Defines the billing cycle configuration for a billing account or group, specifying billing frequency, invoice generation date, payment due date, grace period days, billing method, and cycle status. Captures cycle type (monthly, quarterly, semi-annual, annual), next invoice date, last invoice date, auto-renewal flag, and billing calendar reference. Drives the automated invoice generation schedule in HealthEdge.' .

ind:PaymentMethod rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Billing ;
    rdfs:label 'Payment Method' ;
    rdfs:comment 'Master record of authorized payment methods registered for a billing account, capturing payment method type (ACH/EFT, check, wire transfer, credit card, debit card, HSA/FSA), bank routing number (masked), bank account number (masked/tokenized), card last four digits, card expiration date, auto-pay authorization flag, authorization date, authorization reference, and active/inactive status. Supports PCI-DSS compliant payment processing.' .

ind:RateSchedule rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Billing ;
    rdfs:label 'Rate Schedule' ;
    rdfs:comment 'Defines the rate schedule configuration governing how premium rates are structured and applied for a plan year, market segment, and rating methodology. Captures rate schedule name, rating method (community rated, age-rated, composite rated, experience rated), effective date, expiration date, rating area reference, tobacco surcharge rules, wellness discount rules, family tier structure, and regulatory filing reference (state DOI rate filing number). Parent configuration for premium_rate records.' .

ind:RegulatoryObligation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Regulatory Obligation' ;
    rdfs:comment 'Master record for each regulatory obligation the health plan must fulfill — HIPAA Privacy/Security Rules, ACA market conduct requirements, CMS Medicare/Medicaid mandates, state DOI filings, NCQA/URAC accreditation standards, ERISA requirements, SOC reporting obligations, and state Medicaid fair hearing compliance. Captures the governing body, regulatory framework, obligation type, effective date, jurisdiction, frequency, accountable business owner, compliance status, and obligation risk score (likelihood × impact of non-compliance). Includes tracking of state fair hearing obligations for Medicaid adverse benefit determinations under 42 CFR §438.400. Serves as the authoritative registry of all compliance requirements and the anchor entity linking to submissions, attestations, policies, and corrective actions that demonstrate adherence.' .

ind:RegulatorySubmission rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Regulatory Submission' ;
    rdfs:comment 'Transactional record for each regulatory filing or submission — from scheduled deadline through actual filing. Captures submission type, regulatory body, due date, lead time days, reminder schedule, submission date, filing period, submission method (EDI, portal, paper), status (scheduled, draft, submitted, accepted, rejected), and confirmation identifiers. Covers CMS annual notices, state DOI rate filings, NAIC financial statements, NCQA accreditation submissions, OCR breach notifications, MLR rebate filings, ACA marketplace submissions, and ERISA filings (Form 5500, Summary Annual Report, Summary Plan Description, COBRA notices, QMCSO responses). Supports the annual regulatory calendar view used by compliance officers to manage deadlines across CMS, state DOIs, NCQA, OCR, ERISA, and DOL obligations. Links to the regulatory obligation it satisfies.' .

ind:AuditEngagement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Audit Engagement' ;
    rdfs:comment 'Master record for each formal audit or examination conducted by or against the health plan — CMS program audits (RADV, Part C/D), state DOI market conduct examinations, OCR HIPAA investigations, NCQA accreditation surveys, SOC 2 audits, internal compliance audits, and external financial audits. Captures audit type, auditing body, audit scope, audit period, lead auditor, engagement start/end dates, status, and overall audit outcome. Includes detailed finding tracking: finding type (condition, cause, effect), severity level (critical, significant, minor), regulatory citation, finding description, affected business area, root cause analysis, recommended remediation, and finding status through the lifecycle from identification through remediation and closure. Serves as the authoritative registry of all audit engagements and their findings.' .

ind:AuditFinding rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Audit Finding' ;
    rdfs:comment 'Transactional record for each finding, deficiency, or observation identified during an audit engagement. Captures finding type (condition, cause, effect), severity level (critical, significant, minor), regulatory citation, finding description, affected business area, root cause analysis, and recommended remediation. Links to the parent audit engagement and drives the corrective action plan (CAP) process. Tracks finding status through the lifecycle from identification through remediation and closure.' .

ind:CorrectiveActionPlan rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Corrective Action Plan' ;
    rdfs:comment 'Master record for each Corrective Action Plan (CAP) developed in response to audit findings, regulatory violations, or accreditation deficiencies. Captures the triggering finding or violation, CAP type, remediation strategy, responsible owner, target completion date, and implementation status. Includes granular milestone tracking with individual action items, assigned owners, planned/actual completion dates, milestone status, evidence artifacts, and reviewer sign-off for each milestone. Tracks the full CAP lifecycle from submission to regulatory body through milestone completion, validation, and closure. Critical for CMS audit readiness and NCQA accreditation maintenance.' .

ind:CapMilestone rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Cap Milestone' ;
    rdfs:comment 'Transactional record tracking individual milestones and action items within a Corrective Action Plan (CAP). Captures milestone description, assigned owner, planned completion date, actual completion date, milestone status, evidence artifacts, and reviewer sign-off. Enables granular tracking of CAP progress and supports regulatory reporting on remediation timelines. Links to the parent CAP and provides the audit trail required by CMS, state DOIs, and NCQA for CAP validation.' .

ind:BreachIncident rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Breach Incident' ;
    rdfs:comment 'Master record for each PHI (Protected Health Information) breach incident identified under HIPAA Breach Notification Rule (45 CFR §164.400–414). Captures breach discovery date, breach type (unauthorized access, theft, loss, improper disposal), affected PHI categories, number of individuals affected, breach cause, business associate involvement, risk assessment outcome, and notification obligations triggered. Includes full notification tracking: notification type (individual, HHS/OCR, media, state AG), notification method (mail, email, substitute notice), notification date, recipient count, content version, and delivery confirmation. Drives the 60-day OCR notification workflow and annual breach report to HHS. Critical for HIPAA compliance and OCR audit readiness.' .

ind:HipaaPrivacyRequest rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Hipaa Privacy Request' ;
    rdfs:comment 'Transactional record for HIPAA privacy operations — member privacy rights requests and PHI disclosure tracking. Covers access requests (right to access PHI), amendment requests, accounting of disclosures, restriction requests, and confidential communication requests under 45 CFR §164.500. Captures request type, member identifier, request receipt date, response due date, response date, request disposition (granted, denied, partially granted), denial reason, and appeal status. Includes PHI disclosure logging: disclosure date, recipient organization, recipient type (public health authority, law enforcement, research, legal), purpose of disclosure, PHI categories disclosed, and disclosure authorization basis. Excludes treatment, payment, and healthcare operations disclosures per HIPAA exemptions. Tracks compliance with HIPAA response timelines and supports OCR audit documentation.' .

ind:Baa rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Baa' ;
    rdfs:comment 'Master record for each Business Associate Agreement (BAA) executed with vendors, TPAs, PBMs, clearinghouses, and other entities that handle PHI on behalf of the health plan under HIPAA (45 CFR §164.308). Captures business associate name, agreement effective date, expiration date, PHI use permissions, security obligations, breach notification requirements, subcontractor provisions, termination clauses, and agreement status. Serves as the authoritative registry of all BAAs and supports HIPAA compliance audits and vendor risk management.' .

ind:FwaCase rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Fwa Case' ;
    rdfs:comment 'Master record for each Fraud, Waste, and Abuse (FWA) investigation — from initial referral intake through case disposition. Captures referral source (claim edits, data mining, tip line, law enforcement, employee reports), referral date, allegation description, supporting evidence references, triage outcome, case type (fraud, waste, abuse), subject type (member, provider, employer group), case open date, investigation status, assigned investigator, estimated financial exposure, recovery amount, and case disposition (substantiated, unsubstantiated, referred to law enforcement, civil monetary penalty). Supports CMS FWA program requirements, state insurance fraud bureau reporting, and annual FWA reporting to CMS.' .

ind:FwaReferral rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Fwa Referral' ;
    rdfs:comment 'Transactional record for each FWA referral received by the Special Investigations Unit (SIU) from internal detection systems, employees, members, providers, or external agencies. Captures referral source, referral date, subject identifier, referral type, allegation description, supporting evidence references, triage outcome, and linkage to the resulting FWA case if opened. Tracks the intake and triage workflow for all FWA allegations and supports CMS annual FWA reporting requirements.' .

ind:MlrCalculation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Mlr Calculation' ;
    rdfs:comment 'Medical Loss Ratio (MLR) calculation and rebate processing record per ACA Section 2718 requirements. Captures reporting year, market segment, LOB, incurred claims, quality improvement expenses, earned premium, MLR percentage, rebate determination, rebate amount, and disbursement tracking.' .

ind:AccreditationProgram rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Accreditation Program' ;
    rdfs:comment 'Master record for each accreditation program the health plan participates in — NCQA Health Plan Accreditation, URAC Health Plan Accreditation, NCQA HEDIS, CAHPS survey programs, and CMS Star Ratings. Captures accrediting body, program name, accreditation type, current status (accredited, provisional, denied), accreditation level, effective/expiration dates, accountable business owner, and applicable standards/measures with benchmark thresholds. Includes full survey/review cycle tracking: survey type (initial, renewal, focused), survey date range, surveyor team, scope, preliminary findings, final score/rating, accreditation decision, and conditions or recommendations. Serves as the authoritative registry of all accreditation relationships and their evaluation history.' .

ind:AccreditationSurvey rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Accreditation Survey' ;
    rdfs:comment 'Transactional record for each accreditation survey or review cycle conducted by NCQA, URAC, or CMS. Captures survey type (initial, renewal, focused), survey date range, surveyor team, survey scope, preliminary findings, final score or rating, accreditation decision, and conditions or recommendations. Links to the parent accreditation program and drives corrective action planning for deficiencies identified during the survey. Tracks the full survey lifecycle from scheduling through final determination.' .

ind:PolicyDocument rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Policy Document' ;
    rdfs:comment 'Master record for each internal compliance policy, procedure, or SOP — including version history and review tracking. Covers HIPAA privacy/security policies, FWA program policies, ACA compliance procedures, credentialing policies, and claims adjudication standards. Captures policy name, category, owner, effective date, version number, approval status, regulatory citations, and distribution scope. Tracks periodic reviews with review date, reviewer, review type (annual, triggered, regulatory change), outcome (approved, revised, retired), revision summary, next review date, and approver sign-off. Serves as the authoritative policy registry supporting NCQA, URAC, and CMS audit readiness.' .

ind:Group rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Employer ;
    rdfs:label 'Group' ;
    rdfs:comment 'Master record for employer group accounts — the B2B commercial customers who sponsor health coverage for their employees. Captures group demographics, legal entity name, tax ID (EIN), SIC/NAICS industry classification, group size tier, historical headcount and enrollment counts by coverage tier (EO/ES/EC/EF) tracked at monthly intervals for ACA small/large group market classification, line of business (LOB), funding arrangement (fully-insured vs ASO), ERISA status, domicile state, effective and termination dates, group financial control (GFC) identifiers, and complete lifecycle status transitions (prospect, active, suspended, terminated, reinstated) with status history. Single source of truth for employer group identity, size classification, headcount history, and status history.' .

ind:GroupLocation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Employer ;
    rdfs:label 'Group Location' ;
    rdfs:comment 'Physical and mailing addresses associated with an employer group, including headquarters, billing address, and satellite office locations. Tracks address type, street, city, state, ZIP+4, county FIPS code, and effective date range. Supports geographic rating, state regulatory filings, and premium billing address routing.' .

ind:GroupContact rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Employer ;
    rdfs:label 'Group Contact' ;
    rdfs:comment 'Authorized contacts associated with an employer group, including HR administrators, benefits coordinators, payroll contacts, and executive sponsors. Captures contact role type, name, title, phone, email, preferred communication channel, and authorization level for enrollment and billing transactions.' .

ind:GroupDivision rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Employer ;
    rdfs:label 'Group Division' ;
    rdfs:comment 'Organizational sub-units within an employer group — divisions, subsidiaries, cost centers, or departments — that have distinct benefit configurations, billing aggregation, or eligibility rules. Tracks division name, division code, parent group reference, effective dates, and whether the division is a separate billing entity. Supports multi-site and multi-subsidiary group structures in Facets.' .

ind:GroupPlanOffering rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Employer ;
    rdfs:label 'Group Plan Offering' ;
    rdfs:comment 'The set of health plan products offered by an employer group to its eligible employees during a plan year — the single source of truth for what plans are available, how the employer contributes, and what participation rules apply. Captures which QHP, HMO, PPO, EPO, HDHP, dental, and vision plans are available; employer contribution strategy per plan including contribution type (flat dollar, percentage of premium, tiered by coverage tier), employee-only vs family contribution amounts, HSA/HRA employer seed amounts, and contribution effective date ranges; minimum participation percentage, minimum enrolled headcount, waiver eligibility criteria (e.g., spousal coverage waivers), measurement period, and participation compliance status; and the open enrollment window linkage. Consolidates contribution strategies and participation requirements as attributes of the plan offering. Links employer groups to the plan catalog and drives the enrollment eligibility matrix, premium billing split calculations, and ACA affordability compliance testing.' .

ind:ContributionStrategy rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Employer ;
    rdfs:label 'Contribution Strategy' ;
    rdfs:comment 'Employer contribution rules defining how much the employer pays toward employee and dependent premiums for each offered plan. Captures contribution type (flat dollar, percentage of premium, tiered by coverage tier), employee-only vs family contribution amounts, HSA/HRA employer seed amounts, and effective date ranges. Supports premium billing split calculations and ACA affordability compliance testing.' .

ind:GroupRenewal rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Employer ;
    rdfs:label 'Group Renewal' ;
    rdfs:comment 'Annual renewal lifecycle record and single source of truth for all group configuration changes — both at renewal and between renewal cycles. Captures renewal effective date, prior year vs renewal year premium rates, rate change percentage, benefit modifications, participation requirement outcomes, renewal status (pending, proposed, accepted, declined), and retention outcome. Also captures mid-year and off-cycle amendments including amendment type (benefit change, plan add/drop, contribution change, address update, contact change), amendment effective date, reason code, approval status, and before/after values of changed attributes. Consolidates group amendments as lifecycle events within the renewal record — amendments are tracked against the current plan year\'s renewal. Provides complete audit trail for group retention management, regulatory compliance, and configuration change history.' .

ind:ParticipationRequirement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Employer ;
    rdfs:label 'Participation Requirement' ;
    rdfs:comment 'Minimum participation rules that an employer group must satisfy to maintain group coverage eligibility. Captures minimum participation percentage, minimum enrolled headcount, waiver eligibility criteria (e.g., spousal coverage waivers), measurement period, and compliance status. Used during underwriting, renewal, and open enrollment to validate group eligibility for continued coverage.' .

ind:BrokerAssignment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Employer ;
    rdfs:label 'Broker Assignment' ;
    rdfs:comment 'Association between an employer group and its licensed broker(s) or general agent(s), capturing the broker NPN, agency name, commission arrangement type, commission rate, effective and termination dates, and primary vs secondary broker designation. Supports broker compensation processing, group servicing accountability, and regulatory disclosure requirements.' .

ind:TpaArrangement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Employer ;
    rdfs:label 'Tpa Arrangement' ;
    rdfs:comment 'Third Party Administrator (TPA) and Administrative Services Only (ASO) arrangement record for self-funded employer groups — the single source of truth for all ASO/self-funded configuration. Captures TPA entity name, TPA NPI/tax ID, ASO contract reference; administrative fee schedule components by service type (claims processing, network access, care management, PBM, utilization review) with PMPM rates, effective dates, and contractual fee caps; stop-loss (excess loss) insurance configuration including stop-loss carrier name, policy number, specific deductible (individual attachment point), aggregate deductible, aggregate corridor, lasering provisions with member-level laser amounts, stop-loss premium, covered benefits scope, and stop-loss policy effective/expiration dates; and overall arrangement effective dates. Consolidates ASO fee schedules and stop-loss policies as sub-configurations of the TPA arrangement, aligned with Facets/QNXT ASO module patterns. Drives ASO revenue recognition in the finance domain and self-funded group financial risk management.' .

ind:OpenEnrollmentWindow rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Employer ;
    rdfs:label 'Open Enrollment Window' ;
    rdfs:comment 'Scheduled open enrollment windows defined by an employer group during which employees may elect, change, or waive coverage. Captures enrollment period type (annual open enrollment, new hire window, COBRA election), start and end dates, eligible plan offerings, enrollment method (online portal, paper, EDI 834), and enrollment completion status. Drives eligibility event processing in the enrollment domain.' .

ind:EmployerUnderwritingCase rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Employer ;
    rdfs:label 'Employer Underwriting Case' ;
    rdfs:comment 'Underwriting evaluation record and single source of truth for the complete risk assessment process from submission through rating through quote generation through decision for a new or renewing employer group. Tracks case submission date, group census data, prior carrier loss experience, medical underwriting status, risk tier assignment, manual rate basis; rating factors including age/gender composite factors, geographic area rating factors, industry risk factors, experience rating credibility weights, ACA-compliant rating adjustments, and actuarial basis documentation; underwriting decision (approved, declined, modified); and premium rate quotes with proposed rates by plan, coverage tier, and rating area, quote effective and expiration dates, rating methodology (community rated, experience rated, blended), proposed PMPM rates, total group premium estimate, and quote status (draft, presented, accepted, expired). Consolidates rating factors and rate quotes as stages within the underwriting case lifecycle. Links to the risk domain for RAF and HCC-based risk scoring at the group level. Supports the sales and renewal pipeline.' .

ind:RateQuote rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Employer ;
    rdfs:label 'Rate Quote' ;
    rdfs:comment 'Premium rate quote issued to a prospective or renewing employer group, capturing proposed rates by plan, coverage tier, and rating area. Includes quote effective date, expiration date, rating methodology (community rated, experience rated, blended), proposed PMPM rates, total group premium estimate, and quote status (draft, presented, accepted, expired). Supports the sales and renewal pipeline.' .

ind:PaRequest rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Utilization ;
    rdfs:label 'Pa Request' ;
    rdfs:comment 'Core master entity representing a prior authorization (PA) request submitted by a provider or member for a proposed service, procedure, drug, or admission. Captures requesting provider NPI, member ID, requested service codes (CPT/HCPCS/ICD), urgency type (standard, expedited, urgent), submission channel (portal, fax, phone, EDI 278), submission timestamp, current PA status, and full status transition history. Also tracks additional information requests (AIRs) issued during review — information type requested, requested-from party, due date, received date, and TAT clock extension impact. Authoritative SSOT for all PA requests, their status lifecycle, and associated documentation requests.' .

ind:PaDecision rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Utilization ;
    rdfs:label 'Pa Decision' ;
    rdfs:comment 'Transactional record capturing the authorization decision and underlying medical necessity determination rendered on a PA request. Stores decision date, decision type (approved, denied, partially approved, pended, withdrawn), clinical criteria applied (InterQual/MCG criteria set, version, effective date), criteria met/not met flag, clinical rationale narrative, ICD diagnosis codes supporting the determination, deciding reviewer NPI and credentials (MD, RN, PharmD), denial reason code and category (medical necessity, administrative, benefit exclusion, out-of-network, experimental/investigational), denial regulatory citation, appeal eligibility flag, and effective authorization period (start/end dates). Each PA request may have one or more decision records reflecting amendments, P2P reversals, or appeal overrides. Serves as the single evidentiary record for NCQA audits, state DOI market conduct exams, and denial defense.' .

ind:AuthServiceLine rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Utilization ;
    rdfs:label 'Auth Service Line' ;
    rdfs:comment 'Line-item detail for each service, procedure, or drug authorized within a PA request. Captures CPT/HCPCS code, ICD diagnosis code, authorized quantity, authorized units of service, service category (inpatient, outpatient, DME, pharmacy, behavioral health), place of service, authorized facility NPI, and approved date range. Supports partial approvals where only a subset of requested services are authorized.' .

ind:ConcurrentReview rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Utilization ;
    rdfs:label 'Concurrent Review' ;
    rdfs:comment 'Manages inpatient concurrent review records for admitted members — the ongoing UM review process evaluating continued medical necessity during a hospital stay. Captures admission date, current and approved length of stay (LOS), LOS benchmarks by DRG (geometric/arithmetic mean LOS, plan-specific target, outlier threshold, benchmark source — CMS, Milliman, plan actuarial), next review date, clinical reviewer NPI, InterQual/MCG criteria version applied, continued stay justification. Includes integrated discharge planning: planned discharge date, discharge destination (home, SNF, LTAC, home health, hospice), post-acute services authorized, barriers to discharge, social work involvement, care coordinator assigned, actual discharge date, and readmission risk score. Links to the originating PA request, UM case, and inpatient admission.' .

ind:RetrospectiveReview rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Utilization ;
    rdfs:label 'Retrospective Review' ;
    rdfs:comment 'Records retrospective (post-service) UM reviews conducted when prior authorization was not obtained before service delivery. Captures service date, review initiation date, clinical documentation received date, medical necessity outcome, denial or approval result, and applicable state retro-review deadline compliance flag. Supports NCQA UM accreditation standards for retrospective review turnaround time (TAT) compliance.' .

ind:UmCase rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Utilization ;
    rdfs:label 'Um Case' ;
    rdfs:comment 'Master entity representing a utilization management (UM) case — the overarching workflow container grouping all UM activities (PA requests, concurrent reviews, retrospective reviews, P2P reviews, appeals) for a single member episode of care. Captures case type (inpatient, outpatient, behavioral health, DME, pharmacy), case open/close dates, assigned UM nurse or case manager, episode of care identifier, primary diagnosis, and case disposition. Enables end-to-end UM workflow tracking, workload management, and NCQA UM accreditation reporting.' .

ind:UmReviewer rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Utilization ;
    rdfs:label 'Um Reviewer' ;
    rdfs:comment 'Master entity for UM clinical reviewers — nurses, medical directors, and physician advisors who conduct UM and PA reviews. Captures reviewer NPI (if applicable), reviewer name, credential type (RN, MD, PharmD, LCSW), specialty, active status, state licensure details, URAC/NCQA reviewer qualification status, assigned review queues, and delegation authority level. Distinct from the provider domain — this entity represents internal plan staff performing UM functions.' .

ind:InpatientAdmission rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Utilization ;
    rdfs:label 'Inpatient Admission' ;
    rdfs:comment 'UM-managed inpatient admission record for admissions subject to concurrent review. Captures admitting facility NPI, admitting physician NPI, admission date, admission type (elective, urgent, emergent), primary admitting diagnosis (ICD), DRG assignment, expected LOS, actual discharge date, discharge disposition (home, SNF, rehab, expired), and payer authorization status. Serves as the anchor for concurrent review workflows and LOS benchmark comparisons. Distinct from the claim domain\'s institutional claim — this is the clinical/UM view of the admission, not the billing view.' .

ind:UmProgram rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Utilization ;
    rdfs:label 'Um Program' ;
    rdfs:comment 'Master reference for the health plan\'s UM program configurations — the formal UM program definitions required by NCQA, URAC, and state DOI. Captures program name, program type (inpatient UM, outpatient UM, behavioral health UM, pharmacy UM, specialty drug UM), applicable lines of business, clinical criteria set assigned (InterQual/MCG version and effective date), review type scope, NCQA/URAC accreditation compliance status by standard category (TAT, criteria, notification, delegation, P2P), accreditation survey dates, and current gap analysis. Governs which services require PA and which clinical criteria apply.' .

ind:PaRequiredService rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Utilization ;
    rdfs:label 'Pa Required Service' ;
    rdfs:comment 'Unified reference master defining PA requirements, exemptions, and gold card overrides by service, provider, plan, and line of business. Captures CPT/HCPCS code or service category, plan ID, line of business (commercial, Medicare Advantage, Medicaid), effective date, PA required/exempt flag, exemption type (state mandate, CMS requirement, gold card, plan policy), PA type (standard, expedited, concurrent), applicable clinical criteria set, regulatory citation, and provider specialty exemption criteria. For gold card entries: provider NPI, gold card effective/expiration dates, approval rate threshold met, qualifying performance period, and revocation reason. Drives PA intake routing, provider-facing PA requirement lookups, state PA reform compliance, and gold card mandate tracking.' .

ind:Header rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Claim ;
    rdfs:label 'Header' ;
    rdfs:comment 'Core master record and lifecycle hub for every submitted health insurance claim — professional (CMS-1500/837P), institutional (UB-04/837I), dental (ADA/837D), and behavioral health. Captures claim-level identifiers (ICN), claim type, bill type, place of service, financial totals (billed/allowed/paid), adjudication status with full status transition history (prior status, new status, timestamp, reason, changed-by), service dates, COB indicator, LOB, plan and member identifiers, provider NPIs (rendering, billing, facility, attending, referring), DRG assignment, admission details, claim source (EDI/paper/portal), adjustment linkage, pend/suspend reason tracking, SLA monitoring dates, and HIPAA compliance flags. Serves as the central hub linking all claim-related detail records.' .

ind:Line rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Claim ;
    rdfs:label 'Line' ;
    rdfs:comment 'Line-level detail for each service rendered within a claim. Captures line number, CPT/HCPCS procedure code, procedure modifier codes (up to 4), revenue code (institutional), service date, units of service, billed amount per line, allowed amount, paid amount, copay amount, coinsurance amount, deductible amount, COB paid amount, line status, denial reason code, remark codes, place of service code, rendering provider NPI at line level, NDC code (for drug lines), quantity qualifier, anesthesia minutes, emergency indicator, EPSDT indicator, family planning indicator, and prior authorization number.' .

ind:Diagnosis rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Claim ;
    rdfs:label 'Diagnosis' ;
    rdfs:comment 'Diagnosis code assignments at the claim level supporting ICD-10-CM coding. Captures claim ICN, diagnosis sequence number, ICD version (ICD-10/ICD-9), diagnosis code, diagnosis description, diagnosis type (principal, admitting, external cause, other), POA (Present on Admission) indicator, HCC category mapping, chronic condition flag, and diagnosis qualifier. Supports DRG grouping, risk adjustment (HCC/RAF), HEDIS measure attribution, and clinical analytics.' .

ind:Procedure rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Claim ;
    rdfs:label 'Procedure' ;
    rdfs:comment 'Procedure code assignments at the claim header level (distinct from line-level CPT). Captures principal procedure code (ICD-10-PCS for inpatient), procedure date, procedure sequence, surgeon NPI, procedure qualifier, and secondary procedure codes. Supports DRG assignment, surgical case management, and inpatient utilization analytics. Primarily applicable to 837I institutional claims.' .

ind:Adjudication rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Claim ;
    rdfs:label 'Adjudication' ;
    rdfs:comment 'Authoritative record of the adjudication decision for each claim and claim line, capturing the full pre-payment processing lifecycle including all clinical and administrative edit results. Includes adjudication status (paid/denied/pended/suspended/voided), auto-adjudication flag, adjudicator ID, benefit plan applied, accumulator impacts (deductible/OOP), COB processing results, allowed amount calculation method (fee schedule/MAC/RBP/capitation), network status, medical necessity determination, and final disposition. Captures granular edit-level results (NCCI/OCE/LCD/NCD/plan-specific/timely filing/duplicate) with edit code, edit description, pass/fail/bypass/override outcomes per line, bypass reason, and override authority. Supports coding compliance, payment accuracy, and CMS edit mandate adherence.' .

ind:Eob rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Claim ;
    rdfs:label 'Eob' ;
    rdfs:comment 'Explanation of Benefits document record generated for members and providers following claim adjudication. Captures EOB document ID, EOB type (member/provider), generation date, delivery method (mail/portal/EDI 835), member ID, subscriber ID, claim ICN, service dates, provider name, billed amount, allowed amount, plan paid amount, member responsibility (deductible, copay, coinsurance, non-covered), COB adjustment, denial reason summary, remark codes, appeal rights language version, SBC reference, and EOB suppression flag. Supports member transparency and ACA SBC compliance.' .

ind:Adjustment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Claim ;
    rdfs:label 'Adjustment' ;
    rdfs:comment 'Single source of truth for all post-adjudication corrections, recoveries, and audit findings — including claim adjustments, voids, reprocessing events, overpayment identification and recovery, and post-payment audit results for payment integrity and FWA detection. Captures adjustment type (void/replacement/corrected/retroactive), overpayment type (duplicate payment/incorrect rate/ineligible member/billing error/fraud), audit type (post-payment/prepayment/clinical/coding/billing), audit source (internal/RAC/OIG/provider self-disclosure), financial impact (original vs adjusted amounts, net adjustment, overpayment amount, recovery amounts, demand lifecycle), initiator, CMS 60-day overpayment rule compliance, recovery method (offset/check/installment), recovery status, and resolution status. Supports payment integrity programs, CMS RAC audit compliance, and regulatory overpayment reporting.' .

ind:Denial rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Claim ;
    rdfs:label 'Denial' ;
    rdfs:comment 'Authoritative record of claim and claim line denials, capturing denial reason codes, clinical rationale, and resolution tracking. Includes denial ID, claim ICN, line number (if line-level denial), denial date, denial type (clinical, administrative, technical, COB, timely filing), CARC code, RARC code, denial reason description, clinical criteria applied (InterQual/MCG), medical necessity determination, denial letter generated flag, appeal eligibility flag, appeal deadline date, denial override flag, override reason, and resolution status. Supports appeals workflow, regulatory reporting, and denial management analytics.' .

ind:Cob rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Claim ;
    rdfs:label 'Cob' ;
    rdfs:comment 'Coordination of Benefits processing record for claims involving multiple payers. Captures COB record ID, claim ICN, primary payer ID, primary payer name, primary payer paid amount, primary payer allowed amount, primary payer denial reason, secondary payer ID, COB processing order, COB method (standard/non-duplication/maintenance of benefits), other insurance type (employer group/Medicare/Medicaid/auto/workers comp), Medicare as secondary payer (MSP) indicator, MSP type, crossover claim flag, Medicaid crossover indicator, and net liability after COB. Supports accurate secondary adjudication and CMS MSP compliance.' .

ind:Payment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Claim ;
    rdfs:label 'Payment' ;
    rdfs:comment 'Single source of truth for all claim payment disbursements and electronic remittance advice (835 ERA) transmitted to providers and members. Captures payee information (NPI/TIN/member ID), payment amount, payment date, payment method (EFT/check/virtual card/capitation offset), check/EFT trace number, payment status lifecycle (issued/cleared/voided/returned/stopped), 835 transaction control number, clearinghouse ID (Availity, Change Healthcare), CARC/RARC adjustment codes at claim level, claim-level payment detail, reconciliation status, and GL posting reference. Consolidates provider remittance advice and claim payment into a single authoritative record for payment reconciliation, cash posting, and provider inquiry resolution.' .

ind:Accumulator rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Claim ;
    rdfs:label 'Accumulator' ;
    rdfs:comment 'Member-level benefit accumulator ledger tracking deductibles, out-of-pocket maximums (MOOP), visit limits, and other benefit thresholds applied during claims adjudication. Captures current balances (accumulated amount, remaining balance, benefit limit) by member, benefit period, accumulator type, LOB, plan, and network tier, plus the full transaction-level audit trail of credits, debits, reversals, and resets applied by each claim event. Supports real-time adjudication decisions, ACA MOOP compliance, and member cost-sharing transparency.' .

ind:Team rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Care ;
    rdfs:label 'Team' ;
    rdfs:comment 'Multi-disciplinary care team composition for members enrolled in care management programs — documenting team members by role (PCP, specialist, behavioral health provider, pharmacist, social worker, community health worker), their NPI or staff ID, team role start/end dates, lead coordinator designation, and communication preferences. Supports NCQA care management standards requiring documented care team composition, CMS chronic care management (CCM) billing requirements, and care coordination across clinical and non-clinical team members. Enables care team roster reporting, role gap identification, and team-based care analytics.' .

ind:MedicalPolicy rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Utilization ;
    rdfs:label 'Medical Policy' ;
    rdfs:comment 'Master reference for medical policies and clinical criteria used in utilization management decisions — including medical necessity criteria, clinical guidelines, evidence-based medicine references, and policy effective dates. Captures policy ID, policy name, clinical category, applicable CPT/HCPCS codes, review criteria source (InterQual, MCG, internal), and version history.' .

ind:ParAgreement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Network ;
    rdfs:label 'Par Agreement' ;
    rdfs:comment 'Provider participation agreement record — the formal agreement a provider signs to participate in a network. Captures agreement type (individual, group), signature date, effective date, termination provisions, and agreement version. Distinct from the broader provider_contract which covers reimbursement terms.' .

ind:ExpeditedReview rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Appeal ;
    rdfs:label 'Expedited Review' ;
    rdfs:comment 'Tracks expedited appeal review requests where standard timeframes could jeopardize the members life, health, or ability to regain maximum function. Captures expedited request reason, clinical urgency classification, shortened decision timeline, and expedited notification requirements per CMS and state regulations.' .

ind:Outcome rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Appeal ;
    rdfs:label 'Outcome' ;
    rdfs:comment 'Records the final disposition and outcome of an appeal case after all levels of review are exhausted — including overturn, uphold, partial overturn, and withdrawn outcomes. Captures outcome date, outcome type, financial impact (claim amount restored), member notification date, and downstream action triggers (claim reprocessing, authorization issuance).' .

ind:MemberEnrollment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Member ;
    rdfs:label 'Member Enrollment' ;
    rdfs:comment 'This association product represents the enrollment contract between a subscriber and a care program. It captures enrollment-specific data such as enrollment number, status, effective dates, type, and reason. Each record links one subscriber to one care program.. Existence Justification: Subscribers can enroll in multiple care programs and each care program can have many subscribers. The enrollment is an operational record that is created, updated, and deleted by staff and includes attributes such as enrollment dates, status, type, and reason. The business treats enrollment as a distinct entity (Enrollment) that is queried and reported on.' .

ind:Offering rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Plan ;
    rdfs:label 'Offering' ;
    rdfs:comment 'This association product represents the contract between a health plan and an employer group. It captures the specific terms of the offering, such as contribution rules, enrollment windows, and status, linking one health_plan to one employer_group.. Existence Justification: An employer group can be offered multiple health plans and a health plan can be offered to multiple employer groups. The contract between them (the plan offering) is actively created, updated, and terminated by business users and carries its own attributes such as effective dates, contribution rules, and status.' .

ind:ProviderNetworkParticipation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Provider ;
    rdfs:label 'Provider Network Participation' ;
    rdfs:comment 'Represents the contractual participation of a healthcare facility in a provider network. Each record links one facility to one network and stores attributes that describe the nature of that participation.. Existence Justification: A healthcare facility can belong to multiple provider networks simultaneously, and each provider network includes many facilities. The relationship is actively managed (contracts/agreements) and carries attributes such as participation status and effective/termination dates.' .

ind:Policy rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Member ;
    rdfs:label 'Policy' ;
    rdfs:comment 'Master reference table for policy. Referenced by policy_id.' .

ind:Payer rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Claim ;
    rdfs:label 'Payer' ;
    rdfs:comment 'Master reference table for payer. Referenced by primary_payer_id.' .

ind:Broker rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Employer ;
    rdfs:label 'Broker' ;
    rdfs:comment 'Master reference table for broker. Referenced by broker_id.' .

ind:ClinicalCriteria rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Utilization ;
    rdfs:label 'Clinical Criteria' ;
    rdfs:comment 'Master reference table for clinical_criteria. Referenced by clinical_criteria_id.' .

ind:ScoreHccContribution rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Risk ;
    rdfs:label 'Score Hcc Contribution' ;
    rdfs:comment 'This association product represents the actuarial contribution event between a member_risk_score and an hcc_mapping. It captures the per-HCC contribution to a member\'s RAF score for a given payment year and model version, including the weighted coefficient amount, primary HCC designation, and effective period. Each record links one member_risk_score to one hcc_mapping and carries attributes that exist only in the context of this specific contribution — essential for RAPS/EDPS submission accuracy, CMS RADV audit defense, and RAF variance root-cause analysis.. Existence Justification: In Medicare Advantage risk adjustment, a member\'s RAF score is mathematically computed as the sum of coefficients from ALL applicable HCC codes that map to the member\'s diagnoses. A single member_risk_score record aggregates contributions from multiple HCC mappings (e.g., HCC 85 + HCC 96 + HCC 108), and a single HCC mapping (e.g., HCC 85 — Congestive Heart Failure) contributes to the risk scores of every member diagnosed with that condition. This is not an analytical correlation — it is an operationally managed actuarial construct that health plans actively track for RAPS/EDPS submission accuracy, CMS audit defense (RADV), and variance reconciliation. The business explicitly names this concept \'risk score HCC contribution\' and tracks per-contribution data (contribution weight, score contribution amount, effective date, primary HCC flag) that belongs to neither the score record nor the HCC mapping alone.' .

ind:TeamEnrollmentAssignment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Care ;
    rdfs:label 'Team Enrollment Assignment' ;
    rdfs:comment 'This association product represents the Assignment between care.team and care.care_enrollment. It captures the operational record of a multi-disciplinary care team being assigned to manage a specific member care enrollment, including the assignment lifecycle (dates, status) and the team\'s functional role for that enrollment. Each record links one team to one care enrollment with attributes that exist only in the context of this assignment relationship. Supports NCQA care management standards and CMS chronic care management (CCM) billing requirements for documented team-based care.. Existence Justification: In care management operations, multi-disciplinary care teams are actively assigned to member care enrollments as a managed business process. One team can serve many enrolled members simultaneously (e.g., a behavioral health team managing 50 enrolled members), and one enrolled member can be served by multiple teams concurrently (e.g., a primary care team plus a behavioral health team plus a complex care team). This team-enrollment assignment is a recognized operational entity in care management platforms like Casenet TruCare, carrying its own lifecycle data including assignment dates, status, and role that cannot be stored on either parent entity alone.' .

ind:Affiliation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Provider ;
    rdfs:label 'Affiliation' ;
    rdfs:comment 'This association product represents the Medical Staff Appointment (contract/role) between a healthcare provider and a healthcare facility. It captures the operational credentialing relationship in which a provider is granted privileges at a specific facility, including the type of privileges, medical staff category, effective period, and credentialing verification status. Each record links one provider to one facility and carries attributes that exist only in the context of this specific provider-facility appointment. Supports NCQA credentialing standards, CMS provider directory accuracy mandates, and hospital privilege tracking.. Existence Justification: In healthcare, physicians and other providers hold medical staff privileges at multiple hospitals simultaneously, and each hospital credentials and grants privileges to many providers. This is a well-established operational business concept called \'medical staff appointment\' or \'hospital affiliation\' — actively managed by credentialing departments, with its own lifecycle (application, approval, expiration, renewal). The relationship carries substantial data (admitting privileges, medical staff category, effective dates, credentialing verification) that belongs to neither the provider nor the facility alone.' .

ind:ReviewerProgramAssignment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Utilization ;
    rdfs:label 'Reviewer Program Assignment' ;
    rdfs:comment 'This association product represents the formal Assignment between um_reviewer and um_program. It captures the authorization of a qualified UM reviewer to conduct reviews under a specific UM program, as required by NCQA and URAC accreditation standards. Each record links one um_reviewer to one um_program and carries the effective dates and role of the assignment — data that exists only in the context of this reviewer-program authorization and is essential for compliance auditing and accreditation documentation.. Existence Justification: In health insurance UM operations, reviewers are formally assigned to specific UM programs based on their credentials, specialty, and licensure — a single reviewer (e.g., an RN with oncology specialty) may be authorized under multiple UM programs (e.g., inpatient UM and specialty drug UM), and each UM program requires multiple qualified reviewers to meet NCQA/URAC staffing standards. This assignment is an actively managed, compliance-critical business concept: health plans must document which reviewers are authorized under which programs, with effective dates, to satisfy accreditation audits. The relationship carries its own data (assignment start/end dates, reviewer role within the program) that belongs to neither the reviewer nor the program alone.' .

# --- Attribute Properties ---
ind:drugMasterId rdf:type rdf:Property ;
    rdfs:label 'Drug Master Id' ;
    rdfs:comment 'Unique surrogate identifier for each drug master record in the lakehouse Silver layer. Serves as the primary key for all downstream joins across formulary, claims, DUR, rebate contracting, and PBM adjudication.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DrugMaster .

ind:atcCode rdf:type rdf:Property ;
    rdfs:label 'Atc Code' ;
    rdfs:comment 'The WHO Anatomical Therapeutic Chemical (ATC) classification code at the 5th level, identifying the drug\'s anatomical main group, therapeutic subgroup, pharmacological subgroup, chemical subgroup, and chemical substance. Used for therapeutic class reporting, HEDIS pharmacy measures, population health analytics, and international drug classification alignment.' ;
    rdfs:domain ind:DrugMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:awpEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Awp Effective Date' ;
    rdfs:comment 'The date on which the current AWP unit price became effective. Used to apply the correct AWP for historical claims repricing, audit reconciliation, and retroactive rebate calculations.' ;
    rdfs:domain ind:DrugMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:awpUnitPrice rdf:type rdf:Property ;
    rdfs:label 'Awp Unit Price' ;
    rdfs:comment 'The Average Wholesale Price (AWP) per unit of the drug as published by First Databank or Medi-Span. AWP is the benchmark pricing reference used in pharmacy reimbursement calculations, MAC pricing comparisons, and rebate contract negotiations. Expressed in USD per unit (tablet, mL, gram, etc.).' ;
    rdfs:domain ind:DrugMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:brandName rdf:type rdf:Property ;
    rdfs:label 'Brand Name' ;
    rdfs:comment 'The proprietary trade name under which the drug is marketed by the manufacturer (e.g., Lipitor, Humira). Used in formulary tier assignment, rebate contracting, member communications, and brand vs. generic substitution logic in PBM adjudication.' ;
    rdfs:domain ind:DrugMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlledSubstanceSchedule rdf:type rdf:Property ;
    rdfs:label 'Controlled Substance Schedule' ;
    rdfs:comment 'The DEA controlled substance schedule classification (I through V) indicating the drug\'s potential for abuse and accepted medical use. Schedule II-V drugs require enhanced DUR edits, quantity limits, early refill restrictions, and special handling in PBM adjudication. Not_scheduled indicates no DEA restriction.' ;
    rdfs:domain ind:DrugMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:createdTimestamp rdf:type rdf:Property ;
    rdfs:label 'Created Timestamp' ;
    rdfs:comment 'The timestamp when this drug master record was first created in the lakehouse Silver layer. Used for data lineage, audit compliance, and change data capture tracking per HIPAA Security Rule requirements.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:deaNumberRequired rdf:type rdf:Property ;
    rdfs:label 'Dea Number Required' ;
    rdfs:comment 'Indicates whether a valid DEA registration number is required on the prescription for this drug due to its controlled substance classification. Drives prescription validation edits in PBM adjudication and pharmacy dispensing workflows.' ;
    rdfs:domain ind:DrugMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dosageForm rdf:type rdf:Property ;
    rdfs:label 'Dosage Form' ;
    rdfs:comment 'The physical form in which the drug is dispensed (e.g., tablet, capsule, solution, injection, patch, inhaler). Critical for formulary configuration, quantity limit rules, step therapy protocols, and DUR screening in RxClaim/Argus. [ENUM-REF-CANDIDATE: tablet|capsule|solution|injection|patch|inhaler|cream|ointment|suspension|powder — promote to reference product]' ;
    rdfs:domain ind:DrugMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drugClassCode rdf:type rdf:Property ;
    rdfs:label 'Drug Class Code' ;
    rdfs:comment 'The classification code for the drug class within the GPI or ETC hierarchy, representing a more granular grouping below therapeutic subclass (e.g., specific statin subtype). Used in formulary step therapy rules, DUR clinical edits, and rebate tier segmentation in PBM systems.' ;
    rdfs:domain ind:DrugMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drugClassName rdf:type rdf:Property ;
    rdfs:label 'Drug Class Name' ;
    rdfs:comment 'The human-readable name of the drug class corresponding to the drug_class_code. Provides the most granular named classification level in the therapeutic hierarchy for formulary configuration and clinical reporting.' ;
    rdfs:domain ind:DrugMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drugName rdf:type rdf:Property ;
    rdfs:label 'Drug Name' ;
    rdfs:comment 'The full proprietary or established name of the drug as it appears on the FDA-approved label and in the First Databank or Medi-Span drug database feed. Used as the primary human-readable identity label across formulary displays, EOB communications, and member-facing materials.' ;
    rdfs:domain ind:Pharmacy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drugStatus rdf:type rdf:Property ;
    rdfs:label 'Drug Status' ;
    rdfs:comment 'Current lifecycle status of the drug record in the master file. Active drugs are eligible for formulary placement and PBM adjudication. Discontinued or recalled drugs trigger claim edits and member/provider notifications. Drives formulary maintenance workflows in RxClaim/Argus.' ;
    rdfs:domain ind:DrugMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drugType rdf:type rdf:Property ;
    rdfs:label 'Drug Type' ;
    rdfs:comment 'Classification of the drug as brand-name, generic, biosimilar, over-the-counter (OTC), compounded, or repackaged. Drives formulary tier assignment, cost-sharing rules, generic substitution logic, and rebate eligibility in PBM adjudication and formulary management.' ;
    rdfs:domain ind:DrugMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveDate rdf:type rdf:Property ;
    rdfs:label 'Effective Date' ;
    rdfs:comment 'The date on which this drug master record became effective and eligible for use in formulary configuration, PBM adjudication, and claims processing. Used for temporal validity enforcement in adjudication date-of-service lookups and formulary effective date management.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fdaApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Fda Approval Status' ;
    rdfs:comment 'The current FDA regulatory approval status of the drug product. Approved drugs are eligible for formulary coverage. Tentatively approved generics may be covered under specific plan designs. Withdrawn or not-approved drugs are excluded from formulary and trigger claim denials. Required for CMS Part D formulary compliance.' ;
    rdfs:domain ind:DrugMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:genericName rdf:type rdf:Property ;
    rdfs:label 'Generic Name' ;
    rdfs:comment 'The International Nonproprietary Name (INN) or United States Adopted Name (USAN) for the active ingredient(s) of the drug (e.g., atorvastatin, adalimumab). Used for generic substitution logic, DUR screening, therapeutic equivalence grouping, and HEDIS pharmacy measure reporting.' ;
    rdfs:domain ind:DrugMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gpiCode rdf:type rdf:Property ;
    rdfs:label 'Gpi Code' ;
    rdfs:comment 'The 14-digit Medi-Span Generic Product Identifier (GPI) code providing a hierarchical drug classification from drug group (2 digits) through drug class, subclass, name, name extension, dosage form, and strength. Used as the primary therapeutic classification key in RxClaim/Argus PBM systems for formulary management, DUR screening, and rebate contracting.' ;
    rdfs:domain ind:DrugMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hccRelevant rdf:type rdf:Property ;
    rdfs:label 'Hcc Relevant' ;
    rdfs:comment 'Indicates whether this drug is clinically associated with one or more CMS Hierarchical Condition Categories (HCCs) for risk adjustment purposes. HCC-relevant drugs are used in RAF score modeling, RAPS/EDPS encounter data submissions, and population health stratification for Medicare Advantage plans.' ;
    rdfs:domain ind:DrugMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isBiosimilar rdf:type rdf:Property ;
    rdfs:label 'Is Biosimilar' ;
    rdfs:comment 'Indicates whether this drug is an FDA-approved biosimilar to a reference biological product. Biosimilars have distinct formulary placement rules, interchangeability designations, and rebate contracting considerations under CMS Part D and commercial plan designs.' ;
    rdfs:domain ind:DrugMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isGenericAvailable rdf:type rdf:Property ;
    rdfs:label 'Is Generic Available' ;
    rdfs:comment 'Indicates whether an FDA-approved generic equivalent is available in the market for this brand-name drug. Used in formulary tier assignment, member cost-sharing communications, and generic substitution prompts during PBM adjudication and pharmacy dispensing.' ;
    rdfs:domain ind:DrugMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isMaintenanceDrug rdf:type rdf:Property ;
    rdfs:label 'Is Maintenance Drug' ;
    rdfs:comment 'Indicates whether this drug is classified as a maintenance medication intended for long-term chronic condition management (e.g., antihypertensives, statins, diabetes medications). Maintenance drugs are eligible for 90-day supply dispensing at mail-order pharmacies and are used in HEDIS medication adherence measures (PDC).' ;
    rdfs:domain ind:DrugMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPreventiveDrug rdf:type rdf:Property ;
    rdfs:label 'Is Preventive Drug' ;
    rdfs:comment 'Indicates whether this drug qualifies as a preventive medication under ACA Section 2713 or HDHP/HSA preventive care rules, making it eligible for $0 cost-sharing before the deductible is met. Used in benefit configuration and claims adjudication cost-sharing logic.' ;
    rdfs:domain ind:DrugMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSpecialtyDrug rdf:type rdf:Property ;
    rdfs:label 'Is Specialty Drug' ;
    rdfs:comment 'Indicates whether this drug is classified as a specialty pharmaceutical requiring special handling, storage, administration, or monitoring (e.g., biologics, oncology agents, hepatitis C treatments). Specialty drugs are subject to mandatory specialty pharmacy channel requirements, prior authorization, and enhanced DUR in PBM adjudication. Critical for CMS Part D specialty tier placement.' ;
    rdfs:domain ind:DrugMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:labelerCode rdf:type rdf:Property ;
    rdfs:label 'Labeler Code' ;
    rdfs:comment 'The 5-digit FDA-assigned labeler code (first segment of the NDC) identifying the firm that manufactures, repackages, relabels, or distributes the drug. Used for manufacturer-level rebate aggregation and PBM contract management.' ;
    rdfs:domain ind:DrugMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:multiSourceCode rdf:type rdf:Property ;
    rdfs:label 'Multi Source Code' ;
    rdfs:comment 'The FDA Orange Book multi-source code indicating the competitive market status of the drug: O=originator brand with no generic, M=multi-source (generic available), N=no current market (discontinued), Y=single-source generic. Used in generic substitution logic, formulary tier assignment, and MAC pricing eligibility determination.' ;
    rdfs:domain ind:Pharmacy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ndc rdf:type rdf:Property ;
    rdfs:label 'Ndc' ;
    rdfs:comment 'The 11-digit National Drug Code assigned by the FDA uniquely identifying the labeler, product, and package size of a drug. This is the primary external business identifier for the drug and is used in pharmacy claims (NCPDP/837P), formulary management, PBM adjudication (RxClaim/Argus), and CMS Part D reporting. Stored in 5-4-2 format without hyphens.' ;
    rdfs:domain ind:Pharmacy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ndc11 rdf:type rdf:Property ;
    rdfs:label 'Ndc 11' ;
    rdfs:comment 'The NDC formatted in the standard 5-4-2 hyphenated display format (e.g., 12345-6789-01) as required for human-readable labeling, SBC documentation, and regulatory submissions to CMS and state DOIs.' ;
    rdfs:domain ind:DrugMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packageSize rdf:type rdf:Property ;
    rdfs:label 'Package Size' ;
    rdfs:comment 'The quantity of drug units contained in the dispensed package as defined by the NDC (e.g., 30 tablets, 100 mL, 1 vial). Used in unit-of-use pricing calculations, days supply verification, quantity limit enforcement, and MAC pricing per-unit derivation.' ;
    rdfs:domain ind:Pharmacy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:packageSizeUnit rdf:type rdf:Property ;
    rdfs:label 'Package Size Unit' ;
    rdfs:comment 'The unit of measure for the package size quantity (e.g., EA for each/tablet/capsule, ML for milliliter, GM for gram). Used in conjunction with package_size for accurate dispensing quantity calculations, days supply verification, and unit-cost pricing in PBM adjudication. [ENUM-REF-CANDIDATE: EA|ML|GM|MG|TAB|CAP|VIAL|PATCH|KIT — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:DrugMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pharmacologicalCategory rdf:type rdf:Property ;
    rdfs:label 'Pharmacological Category' ;
    rdfs:comment 'The pharmacological mechanism-of-action category of the drug (e.g., ACE Inhibitor, Beta Blocker, SSRI, Statin, Monoclonal Antibody). Used for DUR drug-drug interaction screening, therapeutic duplication edits, clinical program targeting in care management, and HEDIS measure attribution.' ;
    rdfs:domain ind:DrugMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remsProgram rdf:type rdf:Property ;
    rdfs:label 'Rems Program' ;
    rdfs:comment 'The name of the FDA-mandated Risk Evaluation and Mitigation Strategy (REMS) program associated with this drug, if applicable (e.g., iPLEDGE for isotretinoin, TIRF REMS for fentanyl products). REMS drugs require special dispensing controls, patient enrollment, and prescriber certification that must be validated during PBM adjudication and prior authorization.' ;
    rdfs:domain ind:DrugMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routeOfAdministration rdf:type rdf:Property ;
    rdfs:label 'Route Of Administration' ;
    rdfs:comment 'The path by which the drug is administered to the patient (e.g., oral, intravenous, subcutaneous, topical, inhalation). Drives formulary benefit category assignment (medical vs. pharmacy benefit), prior authorization requirements, and specialty pharmacy routing in PBM adjudication. [ENUM-REF-CANDIDATE: oral|intravenous|subcutaneous|intramuscular|topical|inhalation|transdermal|ophthalmic|otic|rectal — promote to reference product]' ;
    rdfs:domain ind:DrugMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceRecordCode rdf:type rdf:Property ;
    rdfs:label 'Source Record Code' ;
    rdfs:comment 'The native record identifier from the originating source system (First Databank, Medi-Span, RxClaim, or Argus) for this drug master record. Used for data lineage, cross-system reconciliation, and upstream change tracking in the lakehouse ingestion pipeline.' ;
    rdfs:domain ind:DrugMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemCode rdf:type rdf:Property ;
    rdfs:label 'Source System Code' ;
    rdfs:comment 'Identifies the operational source system from which this drug master record was ingested (e.g., FDB=First Databank, MEDISPAN=Medi-Span, RXCLAIM=RxClaim PBM, ARGUS=Argus PBM, INTERNAL=internally maintained). Used for data lineage tracking, conflict resolution during ETL, and audit compliance in the Databricks Silver layer.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strength rdf:type rdf:Property ;
    rdfs:label 'Strength' ;
    rdfs:comment 'The concentration or potency of the active ingredient(s) expressed as a numeric value with unit of measure (e.g., 10 mg, 500 mg/5 mL, 0.25%). Used in DUR duplicate therapy screening, quantity limit enforcement, and clinical appropriateness review in UM/PA workflows.' ;
    rdfs:domain ind:DrugMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminationDate rdf:type rdf:Property ;
    rdfs:label 'Termination Date' ;
    rdfs:comment 'The date on which this drug master record was terminated or superseded, indicating the drug is no longer active for formulary placement or new claim adjudication. Null indicates the record is currently active. Used for historical claims repricing and formulary audit trails.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:therapeuticClassCode rdf:type rdf:Property ;
    rdfs:label 'Therapeutic Class Code' ;
    rdfs:comment 'The standardized code identifying the broad therapeutic class of the drug (e.g., cardiovascular agents, anti-infectives, antineoplastics). Used for formulary tier grouping, rebate contract aggregation, utilization reporting, and disease management program enrollment triggers.' ;
    rdfs:domain ind:DrugMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:therapeuticClassName rdf:type rdf:Property ;
    rdfs:label 'Therapeutic Class Name' ;
    rdfs:comment 'The human-readable name of the therapeutic class corresponding to the therapeutic_class_code. Used in formulary displays, member-facing SBC documents, provider communications, and regulatory reporting to CMS and state DOIs.' ;
    rdfs:domain ind:DrugMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:therapeuticEquivalenceCode rdf:type rdf:Property ;
    rdfs:label 'Therapeutic Equivalence Code' ;
    rdfs:comment 'The FDA Orange Book therapeutic equivalence evaluation code (e.g., AB, AA, BC) indicating whether a generic drug is therapeutically equivalent to the reference listed drug. AB-rated generics are substitutable at the pharmacy. Used in generic substitution logic, formulary step therapy, and DAW (Dispense As Written) override processing in PBM adjudication.' ;
    rdfs:domain ind:DrugMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:therapeuticSubclassCode rdf:type rdf:Property ;
    rdfs:label 'Therapeutic Subclass Code' ;
    rdfs:comment 'The standardized code identifying the therapeutic subclass within the broader therapeutic class (e.g., HMG-CoA Reductase Inhibitors within cardiovascular agents). Enables granular formulary tier differentiation, step therapy protocol design, and rebate contract segmentation.' ;
    rdfs:domain ind:DrugMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:therapeuticSubclassName rdf:type rdf:Property ;
    rdfs:label 'Therapeutic Subclass Name' ;
    rdfs:comment 'The human-readable name of the therapeutic subclass corresponding to the therapeutic_subclass_code. Used in formulary management workflows, clinical program configuration, and detailed utilization analytics.' ;
    rdfs:domain ind:DrugMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:updatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Updated Timestamp' ;
    rdfs:comment 'The timestamp when this drug master record was last modified in the lakehouse Silver layer. Used for incremental data refresh, change detection, and audit trail maintenance in the Databricks lakehouse pipeline.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:wacUnitPrice rdf:type rdf:Property ;
    rdfs:label 'Wac Unit Price' ;
    rdfs:comment 'The Wholesale Acquisition Cost (WAC) per unit as reported by the manufacturer, representing the list price to wholesalers before discounts and rebates. Used as a pricing benchmark for specialty drug reimbursement, rebate baseline calculations, and CMS Part D coverage gap discount program calculations.' ;
    rdfs:domain ind:DrugMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:formularyId rdf:type rdf:Property ;
    rdfs:label 'Formulary Id' ;
    rdfs:comment 'Unique surrogate identifier for the formulary record. Primary key for the formulary data product in the pharmacy domain.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Formulary .

ind:priorVersionFormularyId rdf:type rdf:Property ;
    rdfs:label 'Prior Version Formulary Id' ;
    rdfs:comment 'Reference to the immediately preceding version of this formulary. Enables formulary change tracking, member notification workflows, and historical adjudication lookups for appeals and grievances.' ;
    rdfs:domain ind:Formulary ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Formulary .

ind:providerNetworkId rdf:type rdf:Property ;
    rdfs:label 'Provider Network Id' ;
    rdfs:comment 'Foreign key linking to network.provider_network. Business justification: Formularies are scoped to specific provider networks in health insurance operations — CMS Part D and MA plans require network-specific formulary filings. Network-specific formulary management and regu' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProviderNetwork .

ind:regulatoryObligationId rdf:type rdf:Property ;
    rdfs:label 'Regulatory Obligation Id' ;
    rdfs:comment 'Foreign key linking to compliance.regulatory_obligation. Business justification: Formulary design must adhere to specific regulatory obligations (ACA, CMS); linking enables reporting of compliance status per formulary.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RegulatoryObligation .

ind:umProgramId rdf:type rdf:Property ;
    rdfs:label 'Um Program Id' ;
    rdfs:comment 'Foreign key linking to utilization.um_program. Business justification: Formularies are scoped to UM programs — a Part D formulary operates under the CMS Part D UM program; a commercial formulary under a commercial drug UM program. This FK supports UM program scope report' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:UmProgram .

ind:changeNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Change Notification Date' ;
    rdfs:comment 'Date on which member notification was sent for formulary changes. CMS Part D requires 60-day advance notice for non-preferred formulary changes and immediate notification for safety-related removals.' ;
    rdfs:domain ind:Formulary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cmsFormularyCode rdf:type rdf:Property ;
    rdfs:label 'Cms Formulary Code' ;
    rdfs:comment 'The CMS-assigned formulary identifier used in Part D formulary file submissions to CMS. Required for Medicare Part D plans to identify the formulary in RAPS and EDPS submissions.' ;
    rdfs:domain ind:Formulary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drugCount rdf:type rdf:Property ;
    rdfs:label 'Drug Count' ;
    rdfs:comment 'Total number of unique drug entries (NDC or drug-tier combinations) included in this formulary at the time of the last update. Used for formulary adequacy assessments and CMS Part D formulary file validation.' ;
    rdfs:domain ind:Formulary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:drugUtilizationReviewInd rdf:type rdf:Property ;
    rdfs:label 'Drug Utilization Review Ind' ;
    rdfs:comment 'Indicates whether Drug Utilization Review (DUR) edits are applied during adjudication under this formulary. DUR programs screen for drug interactions, duplicate therapy, and inappropriate dosing per OBRA \'90 requirements.' ;
    rdfs:domain ind:Formulary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:formularyCategory rdf:type rdf:Property ;
    rdfs:label 'Formulary Category' ;
    rdfs:comment 'Business classification of the formulary indicating its benefit richness level relative to other formularies offered by the plan. Used in benefit design analytics, member communications, and plan comparison tools.' ;
    rdfs:domain ind:Formulary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:formularyCode rdf:type rdf:Property ;
    rdfs:label 'Formulary Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying the formulary across systems, used in EDI transactions, PBM interfaces, and CMS Part D submissions. Corresponds to the formulary ID field in RxClaim/Argus PBM system.' ;
    rdfs:domain ind:Formulary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:formularyDescription rdf:type rdf:Property ;
    rdfs:label 'Formulary Description' ;
    rdfs:comment 'Free-text business description of the formulary, including its intended population, key design features, and any notable coverage inclusions or exclusions. Used in internal documentation and plan benefit configuration.' ;
    rdfs:domain ind:Formulary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:formularyName rdf:type rdf:Property ;
    rdfs:label 'Formulary Name' ;
    rdfs:comment 'Human-readable business name of the formulary (e.g., \'Standard Commercial Formulary 2025\', \'Medicare Part D Enhanced Formulary\'). Used in member-facing materials, SBC documents, and plan benefit configurations.' ;
    rdfs:domain ind:Formulary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:formularyStatus rdf:type rdf:Property ;
    rdfs:label 'Formulary Status' ;
    rdfs:comment 'Current lifecycle status of the formulary record. Active formularies are used in live adjudication; pending formularies are approved but not yet effective; retired formularies are historical records no longer in use.' ;
    rdfs:domain ind:Formulary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:formularyType rdf:type rdf:Property ;
    rdfs:label 'Formulary Type' ;
    rdfs:comment 'Classification of the formulary structure indicating coverage breadth and tier design. Open formularies cover most drugs; closed formularies restrict to listed drugs only; tiered formularies apply differential cost-sharing by tier.' ;
    rdfs:domain ind:Formulary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:genericSubstitutionPolicy rdf:type rdf:Property ;
    rdfs:label 'Generic Substitution Policy' ;
    rdfs:comment 'Policy governing generic drug substitution at point of dispensing. Mandatory substitution requires dispensing of generic equivalents; permissive allows brand if requested; DAW (Dispense As Written) honored respects prescriber instructions.' ;
    rdfs:domain ind:Formulary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isAcaCompliant rdf:type rdf:Property ;
    rdfs:label 'Is Aca Compliant' ;
    rdfs:comment 'Indicates whether this formulary meets ACA Qualified Health Plan (QHP) essential health benefit (EHB) drug coverage requirements, including the required drug categories and classes under 45 CFR Part 156.' ;
    rdfs:domain ind:Formulary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isCmsPartD rdf:type rdf:Property ;
    rdfs:label 'Is Cms Part D' ;
    rdfs:comment 'Indicates whether this formulary is subject to CMS Medicare Part D regulatory requirements, including annual bid submission, formulary file submission to CMS, and coverage determination obligations.' ;
    rdfs:domain ind:Formulary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastReviewDate rdf:type rdf:Property ;
    rdfs:label 'Last Review Date' ;
    rdfs:comment 'Date on which the Pharmacy and Therapeutics (P&T) Committee last reviewed and approved this formulary. P&T Committee review is required for CMS Part D compliance and NCQA accreditation.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lobCode rdf:type rdf:Property ;
    rdfs:label 'Lob Code' ;
    rdfs:comment 'Line of Business (LOB) associated with this formulary, indicating the regulatory and market segment under which the formulary operates. Drives CMS Part D, Medicaid, or commercial compliance requirements.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lowIncomeSubsidyInd rdf:type rdf:Property ;
    rdfs:label 'Low Income Subsidy Ind' ;
    rdfs:comment 'Indicates whether this formulary is designated for use by Low Income Subsidy (LIS) eligible members under Medicare Part D. LIS formularies must meet CMS benchmark plan requirements for cost-sharing and drug coverage.' ;
    rdfs:domain ind:Formulary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mailOrderInd rdf:type rdf:Property ;
    rdfs:label 'Mail Order Ind' ;
    rdfs:comment 'Indicates whether this formulary supports mail-order pharmacy dispensing. Mail-order programs typically offer 90-day supplies at reduced cost-sharing and are a key component of pharmacy benefit design.' ;
    rdfs:domain ind:Formulary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nextReviewDate rdf:type rdf:Property ;
    rdfs:label 'Next Review Date' ;
    rdfs:comment 'Scheduled date for the next Pharmacy and Therapeutics (P&T) Committee review of this formulary. Supports compliance tracking for CMS Part D requirements mandating regular formulary review cycles.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pbmFormularyCode rdf:type rdf:Property ;
    rdfs:label 'Pbm Formulary Code' ;
    rdfs:comment 'The formulary identifier as assigned by the PBM system (RxClaim or Argus). Used for cross-system reconciliation between the health plan\'s internal formulary record and the PBM\'s formulary configuration.' ;
    rdfs:domain ind:Pharmacy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planYear rdf:type rdf:Property ;
    rdfs:label 'Plan Year' ;
    rdfs:comment 'The benefit plan year (e.g., 2025) for which this formulary is effective. Used for annual formulary change management, CMS Part D annual bid submissions, and benefit year reporting.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:priorAuthInd rdf:type rdf:Property ;
    rdfs:label 'Prior Auth Ind' ;
    rdfs:comment 'Indicates whether this formulary requires prior authorization (PA) for any covered drugs. PA requirements are subject to CMS Part D coverage determination timelines and member appeal rights.' ;
    rdfs:domain ind:Formulary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ptCommitteeApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Pt Committee Approval Date' ;
    rdfs:comment 'Date on which the Pharmacy and Therapeutics (P&T) Committee formally approved this formulary or the most recent formulary update. Required documentation for CMS Part D compliance and NCQA accreditation audits.' ;
    rdfs:domain ind:Formulary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:quantityLimitInd rdf:type rdf:Property ;
    rdfs:label 'Quantity Limit Ind' ;
    rdfs:comment 'Indicates whether this formulary applies quantity limits (QL) on covered drugs, restricting the amount dispensed per fill or per defined time period. Quantity limits are a utilization management tool subject to CMS Part D exception requirements.' ;
    rdfs:domain ind:Formulary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Regulatory Approval Date' ;
    rdfs:comment 'The date on which CMS or the applicable State Department of Insurance approved this formulary for use. Required for Part D compliance documentation and audit trails.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryFilingDate rdf:type rdf:Property ;
    rdfs:label 'Regulatory Filing Date' ;
    rdfs:comment 'The date on which the formulary was submitted to CMS or the applicable State Department of Insurance for regulatory review and approval.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryFilingStatus rdf:type rdf:Property ;
    rdfs:label 'Regulatory Filing Status' ;
    rdfs:comment 'Status of the formulary\'s regulatory filing with CMS or applicable State Department of Insurance (DOI). Tracks whether the formulary has been submitted, approved, or rejected for compliance with Part D or state market requirements.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialtyPharmacyInd rdf:type rdf:Property ;
    rdfs:label 'Specialty Pharmacy Ind' ;
    rdfs:comment 'Indicates whether this formulary designates a specialty pharmacy network for dispensing high-cost specialty drugs. Specialty pharmacy programs may include limited distribution networks and enhanced clinical support services.' ;
    rdfs:domain ind:Formulary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:specialtyTierInd rdf:type rdf:Property ;
    rdfs:label 'Specialty Tier Ind' ;
    rdfs:comment 'Indicates whether this formulary includes a specialty drug tier for high-cost specialty medications. Specialty tiers typically apply to drugs with monthly costs exceeding CMS specialty tier threshold (currently $670/month for Part D).' ;
    rdfs:domain ind:Formulary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:stepTherapyInd rdf:type rdf:Property ;
    rdfs:label 'Step Therapy Ind' ;
    rdfs:comment 'Indicates whether this formulary employs step therapy (also known as fail-first) protocols requiring members to try lower-cost or preferred drugs before coverage of higher-cost alternatives is authorized.' ;
    rdfs:domain ind:Formulary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tierCount rdf:type rdf:Property ;
    rdfs:label 'Tier Count' ;
    rdfs:comment 'The total number of cost-sharing tiers defined in this formulary (e.g., 3-tier, 4-tier, 5-tier, 6-tier). Determines the tier structure used in drug tier assignments and member cost-sharing calculations.' ;
    rdfs:domain ind:Formulary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:url rdf:type rdf:Property ;
    rdfs:label 'Url' ;
    rdfs:comment 'Public-facing URL where members can access the formulary drug list. CMS Part D and ACA QHP regulations require health plans to publish formularies online and provide the URL in plan materials and SBC documents.' ;
    rdfs:domain ind:Formulary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:version rdf:type rdf:Property ;
    rdfs:label 'Version' ;
    rdfs:comment 'Version number of the formulary, incremented with each approved update or mid-year formulary change. Used to track formulary change history and ensure members receive required 60-day advance notice of non-preferred changes.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:formularyDrugTierId rdf:type rdf:Property ;
    rdfs:label 'Formulary Drug Tier Id' ;
    rdfs:comment 'Unique surrogate identifier for each formulary drug tier assignment record. Primary key for this association entity linking a drug (NDC) to a formulary with its tier, cost-sharing, and utilization management (UM) controls.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FormularyDrugTier .

ind:clinicalCriteriaId rdf:type rdf:Property ;
    rdfs:label 'Clinical Criteria Id' ;
    rdfs:comment 'Foreign key linking to utilization.clinical_criteria. Business justification: Formulary tier PA requirements, step therapy rules, and quantity limits are governed by specific clinical criteria versions. This FK supports CMS Part D formulary-clinical criteria alignment audits an' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ClinicalCriteria .

ind:healthPlanId rdf:type rdf:Property ;
    rdfs:label 'Health Plan Id' ;
    rdfs:comment 'Reference to the health plan or benefit plan under which this formulary drug tier assignment applies. Links the tier assignment to the specific plan for cost-sharing and benefit configuration.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:HealthPlan .

ind:benefitYear rdf:type rdf:Property ;
    rdfs:label 'Benefit Year' ;
    rdfs:comment 'The plan benefit year (e.g., 2024, 2025) to which this formulary drug tier assignment applies. CMS Part D formulary files are submitted annually by benefit year.' ;
    rdfs:domain ind:FormularyDrugTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:coinsuranceRate rdf:type rdf:Property ;
    rdfs:label 'Coinsurance Rate' ;
    rdfs:comment 'Member coinsurance percentage applied to the drug cost under this formulary tier assignment, expressed as a decimal (e.g., 0.20 = 20%). Used when cost-sharing is percentage-based rather than fixed copay. Applies to specialty and high-cost tiers.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:copayMailOrder rdf:type rdf:Property ;
    rdfs:label 'Copay Mail Order' ;
    rdfs:comment 'Fixed member copay amount for a 90-day supply dispensed through a mail-order pharmacy under this formulary tier assignment. Mail-order copays are typically lower than retail to incentivize mail-order utilization.' ;
    rdfs:domain ind:FormularyDrugTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:copayRetail30 rdf:type rdf:Property ;
    rdfs:label 'Copay Retail 30' ;
    rdfs:comment 'Fixed member copay amount for a 30-day supply dispensed at a retail pharmacy under this formulary tier assignment. Drives member cost-sharing at point of sale. Used in SBC and EOB generation.' ;
    rdfs:domain ind:FormularyDrugTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:copayRetail90 rdf:type rdf:Property ;
    rdfs:label 'Copay Retail 90' ;
    rdfs:comment 'Fixed member copay amount for a 90-day supply dispensed at a retail pharmacy under this formulary tier assignment. Applicable for maintenance medications at extended-supply retail pharmacies.' ;
    rdfs:domain ind:FormularyDrugTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coverageStatus rdf:type rdf:Property ;
    rdfs:label 'Coverage Status' ;
    rdfs:comment 'Indicates whether the drug is covered under this formulary assignment. \'covered\' = fully covered per tier rules; \'covered_with_restrictions\' = covered subject to UM controls (PA, ST, QL); \'not_covered\' = not on formulary; \'excluded\' = explicitly excluded per CMS or plan rules.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deductibleApplies rdf:type rdf:Property ;
    rdfs:label 'Deductible Applies' ;
    rdfs:comment 'Indicates whether the plan deductible must be met before cost-sharing for this drug tier applies. Relevant for High Deductible Health Plans (HDHP) and plans with drug-specific deductibles.' ;
    rdfs:domain ind:FormularyDrugTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dispensingChannel rdf:type rdf:Property ;
    rdfs:label 'Dispensing Channel' ;
    rdfs:comment 'Pharmacy dispensing channel(s) through which this drug may be dispensed under this formulary tier assignment. \'specialty\' indicates dispensing is restricted to a specialty pharmacy network. Drives pharmacy routing at point of sale.' ;
    rdfs:domain ind:Pharmacy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drugTierChangeReason rdf:type rdf:Property ;
    rdfs:label 'Drug Tier Change Reason' ;
    rdfs:comment 'Business reason for a change to the drug\'s tier assignment (e.g., \'generic available\', \'contract renegotiation\', \'clinical review\', \'CMS requirement\', \'formulary refresh\'). Supports audit trail and CMS formulary change notification requirements.' ;
    rdfs:domain ind:FormularyDrugTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:durAlertType rdf:type rdf:Property ;
    rdfs:label 'Dur Alert Type' ;
    rdfs:comment 'Type of Drug Utilization Review (DUR) alert associated with this formulary drug tier assignment (e.g., \'drug-drug interaction\', \'drug-disease contraindication\', \'duplicate therapy\', \'dose range check\'). Drives DUR edits at point of sale in the PBM adjudication system. [ENUM-REF-CANDIDATE: drug_drug_interaction|drug_disease|duplicate_therapy|dose_range|drug_allergy|drug_age — promote to reference product]' ;
    rdfs:domain ind:FormularyDrugTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:formularyStatusCode rdf:type rdf:Property ;
    rdfs:label 'Formulary Status Code' ;
    rdfs:comment 'CMS-defined formulary status code used in the Part D formulary file submission. Values: 1=Covered, 2=Covered with Restrictions, 3=Not Covered, 4=Covered (Grandfathered), 5=Covered (Transition), 6=Covered (LIS). Required field in CMS formulary extract file.' ;
    rdfs:domain ind:FormularyDrugTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:macPricingApplicable rdf:type rdf:Property ;
    rdfs:label 'Mac Pricing Applicable' ;
    rdfs:comment 'Indicates whether Maximum Allowable Cost (MAC) pricing applies to this drug under this formulary tier assignment. MAC pricing caps reimbursement for generic drugs and is a key PBM contract term.' ;
    rdfs:domain ind:FormularyDrugTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ndcCode rdf:type rdf:Property ;
    rdfs:label 'Ndc Code' ;
    rdfs:comment '11-digit National Drug Code uniquely identifying the specific drug product, dosage form, and package size assigned to this formulary tier. NDC is the primary drug identifier used in pharmacy claim adjudication and CMS formulary file submissions.' ;
    rdfs:domain ind:Pharmacy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paCriteriaDescription rdf:type rdf:Property ;
    rdfs:label 'Pa Criteria Description' ;
    rdfs:comment 'Narrative description of the clinical criteria that must be met for prior authorization approval of this drug. Supports PA adjudication, member appeals, and CMS/NCQA compliance documentation.' ;
    rdfs:domain ind:FormularyDrugTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paType rdf:type rdf:Property ;
    rdfs:label 'Pa Type' ;
    rdfs:comment 'Type of prior authorization process required for this drug (e.g., \'standard\' = standard review timeline; \'expedited\' = urgent/expedited review; \'retrospective\' = post-service review). Null or \'not_applicable\' if prior_auth_required is false.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorAuthRequired rdf:type rdf:Property ;
    rdfs:label 'Prior Auth Required' ;
    rdfs:comment 'Indicates whether prior authorization (PA) is required before this drug will be covered under this formulary tier assignment. When true, a PA request must be approved before the claim will adjudicate. Reported in the CMS PA extract file.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:qlClinicalBasis rdf:type rdf:Property ;
    rdfs:label 'Ql Clinical Basis' ;
    rdfs:comment 'Clinical rationale or basis for the quantity limit rule (e.g., \'FDA-approved maximum dose\', \'clinical guidelines\', \'safety limit\'). Documents the evidence basis for the QL control as required for CMS and NCQA compliance.' ;
    rdfs:domain ind:FormularyDrugTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qlDaysSupply rdf:type rdf:Property ;
    rdfs:label 'Ql Days Supply' ;
    rdfs:comment 'The number of days supply over which the maximum quantity limit applies (e.g., 30 days, 90 days). Defines the time window for the quantity limit rule. Null if quantity_limit_required is false.' ;
    rdfs:domain ind:FormularyDrugTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:qlDosageFormRestriction rdf:type rdf:Property ;
    rdfs:label 'Ql Dosage Form Restriction' ;
    rdfs:comment 'Specifies any dosage form restrictions associated with the quantity limit rule (e.g., \'tablet only\', \'extended-release excluded\', \'oral solution only\'). Captures clinical basis for dosage form-specific QL controls.' ;
    rdfs:domain ind:FormularyDrugTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qlMaxQuantity rdf:type rdf:Property ;
    rdfs:label 'Ql Max Quantity' ;
    rdfs:comment 'Maximum quantity of the drug allowed per fill or per defined time period under the quantity limit rule. Expressed in the drug\'s dispensing unit (e.g., tablets, mL, units). Null if quantity_limit_required is false.' ;
    rdfs:domain ind:FormularyDrugTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityLimitRequired rdf:type rdf:Property ;
    rdfs:label 'Quantity Limit Required' ;
    rdfs:comment 'Indicates whether a quantity limit (QL) applies to this drug under this formulary assignment. When true, the dispensed quantity per fill or per time period is restricted. Reported in the CMS QL extract file.' ;
    rdfs:domain ind:FormularyDrugTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recordStatus rdf:type rdf:Property ;
    rdfs:label 'Record Status' ;
    rdfs:comment 'Lifecycle status of this formulary drug tier assignment record. \'active\' = currently in effect; \'inactive\' = terminated or expired; \'pending\' = approved but not yet effective; \'superseded\' = replaced by a newer version of the same assignment.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialtyDrugFlag rdf:type rdf:Property ;
    rdfs:label 'Specialty Drug Flag' ;
    rdfs:comment 'Indicates whether this drug is designated as a specialty drug under this formulary. Specialty drugs typically require dispensing through a specialty pharmacy, have higher cost-sharing, and may require PA. Used in specialty pharmacy channel routing and PBM contract management.' ;
    rdfs:domain ind:Pharmacy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:stClinicalRationale rdf:type rdf:Property ;
    rdfs:label 'St Clinical Rationale' ;
    rdfs:comment 'Clinical rationale or evidence basis for the step therapy protocol (e.g., \'preferred generic available\', \'clinical guidelines recommend first-line therapy\', \'cost-effectiveness\'). Required for CMS and NCQA UM documentation.' ;
    rdfs:domain ind:FormularyDrugTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stOverrideCriteria rdf:type rdf:Property ;
    rdfs:label 'St Override Criteria' ;
    rdfs:comment 'Criteria under which the step therapy requirement may be overridden without completing the required step sequence (e.g., \'contraindication to step drug\', \'prior treatment failure documented\', \'clinical exception\'). Supports PA override adjudication.' ;
    rdfs:domain ind:FormularyDrugTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stRequiredStepNdc rdf:type rdf:Property ;
    rdfs:label 'St Required Step Ndc' ;
    rdfs:comment 'National Drug Code (NDC) of the required step drug that must be tried and failed before coverage of this drug is approved under the step therapy protocol. Null if step_therapy_required is false.' ;
    rdfs:domain ind:FormularyDrugTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stStepNumber rdf:type rdf:Property ;
    rdfs:label 'St Step Number' ;
    rdfs:comment 'The sequence number of this drug in the step therapy protocol (e.g., 1 = first-line, 2 = second-line). Defines the order in which step drugs must be tried and failed before coverage of the target drug is approved. Null if step_therapy_required is false.' ;
    rdfs:domain ind:FormularyDrugTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:stepTherapyRequired rdf:type rdf:Property ;
    rdfs:label 'Step Therapy Required' ;
    rdfs:comment 'Indicates whether step therapy (ST) applies to this drug under this formulary assignment. When true, the member must first try and fail one or more preferred (step) drugs before coverage of this drug is approved. Reported in the CMS ST extract file.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tierName rdf:type rdf:Property ;
    rdfs:label 'Tier Name' ;
    rdfs:comment 'Human-readable label for the drug tier (e.g., \'Generic\', \'Preferred Brand\', \'Non-Preferred Brand\', \'Specialty\', \'Specialty Preferred\'). Displayed on member-facing materials including the Summary of Benefits and Coverage (SBC) and Explanation of Benefits (EOB).' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tierNumber rdf:type rdf:Property ;
    rdfs:label 'Tier Number' ;
    rdfs:comment 'Numeric tier level assigned to the drug within the formulary (e.g., 1=Generic, 2=Preferred Brand, 3=Non-Preferred Brand, 4=Specialty, 5=Specialty Preferred, 6=Select Care). Drives member cost-sharing at point of sale. CMS requires tier number in formulary file submissions.' ;
    rdfs:domain ind:FormularyDrugTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:transitionFillAllowed rdf:type rdf:Property ;
    rdfs:label 'Transition Fill Allowed' ;
    rdfs:comment 'Indicates whether a transition fill is permitted for this drug when a member is new to the plan or the drug\'s formulary status has changed. CMS Part D requires transition fills for certain drugs during the transition period.' ;
    rdfs:domain ind:FormularyDrugTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:drugPricingId rdf:type rdf:Property ;
    rdfs:label 'Drug Pricing Id' ;
    rdfs:comment 'Unique surrogate identifier for each NDC-level drug pricing record in the Silver Layer lakehouse. Primary key for the drug_pricing data product.' ;
    rdfs:domain ind:DrugPricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:feeScheduleId rdf:type rdf:Property ;
    rdfs:label 'Fee Schedule Id' ;
    rdfs:comment 'Foreign key linking to contract.fee_schedule. Business justification: Drug pricing records (AWP%, MAC, dispensing fee) implement rates negotiated in fee schedules. Linking drug_pricing to fee_schedule enables contract compliance auditing — verifying that adjudicated dru' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FeeSchedule .

ind:providerContractId rdf:type rdf:Property ;
    rdfs:label 'Provider Contract Id' ;
    rdfs:comment 'Foreign key linking to contract.provider_contract. Business justification: Drug pricing tables are derived from PBM contract agreements; linking ensures price source traceability for regulatory filings and rebate calculations.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProviderContract .

ind:reimbursementPolicyId rdf:type rdf:Property ;
    rdfs:label 'Reimbursement Policy Id' ;
    rdfs:comment 'Foreign key linking to contract.reimbursement_policy. Business justification: Reimbursement policies define MAC pricing basis and AWP discount methodology that drug_pricing records operationalize. Contract auditors and pricing analysts require this link to trace each drug price' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ReimbursementPolicy .

ind:awpDiscountPct rdf:type rdf:Property ;
    rdfs:label 'Awp Discount Pct' ;
    rdfs:comment 'Percentage discount applied to AWP to derive the reimbursement rate under AWP-based contracts (e.g., AWP minus 15%). Expressed as a positive decimal percentage (e.g., 15.0000 = 15%). Used for PBM contract compliance validation and reimbursement audits.' ;
    rdfs:domain ind:DrugPricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:awpPrice rdf:type rdf:Property ;
    rdfs:label 'Awp Price' ;
    rdfs:comment 'Average Wholesale Price per unit as published by First Databank or Medi-Span. Commonly used as the benchmark for pharmacy reimbursement calculations and discount negotiations. Expressed in USD.' ;
    rdfs:domain ind:DrugPricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:currencyCode rdf:type rdf:Property ;
    rdfs:label 'Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for all monetary price fields in this record (e.g., USD). Supports multi-currency operations for Puerto Rico and other US territories. Defaults to USD for domestic plans.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:daysSupply rdf:type rdf:Property ;
    rdfs:label 'Days Supply' ;
    rdfs:comment 'Number of days of drug supply for which this pricing record applies (e.g., 30-day retail, 90-day mail order). Used to differentiate pricing tiers by supply duration per PBM contract terms.' ;
    rdfs:domain ind:Pharmacy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deaSchedule rdf:type rdf:Property ;
    rdfs:label 'Dea Schedule' ;
    rdfs:comment 'DEA controlled substance schedule classification (CI through CV) or NON-CONTROLLED. Used for DUR edits, quantity limit enforcement, prior authorization requirements, and regulatory compliance reporting.' ;
    rdfs:domain ind:DrugPricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispensingFee rdf:type rdf:Property ;
    rdfs:label 'Dispensing Fee' ;
    rdfs:comment 'Fixed dispensing fee in USD paid to the pharmacy per prescription fill, separate from the ingredient cost. Defined in PBM network contracts and applied during claim adjudication to calculate total pharmacy reimbursement.' ;
    rdfs:domain ind:Pharmacy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:expirationDate rdf:type rdf:Property ;
    rdfs:label 'Expiration Date' ;
    rdfs:comment 'Date on which this pricing record expires and is no longer applicable for new claim adjudication. Null indicates an open-ended pricing record with no defined end date. Used with effective_date to determine the active pricing window.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:macListVersion rdf:type rdf:Property ;
    rdfs:label 'Mac List Version' ;
    rdfs:comment 'Version identifier of the MAC list, used to track updates and revisions to the MAC pricing schedule. Supports audit trails for MAC list changes and pharmacy reimbursement disputes. Null when price_type is not MAC.' ;
    rdfs:domain ind:DrugPricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:macMethodology rdf:type rdf:Property ;
    rdfs:label 'Mac Methodology' ;
    rdfs:comment 'Describes the methodology used to derive the MAC price (e.g., MARKET_BASKET=based on market survey of acquisition costs, NADAC_BASED=derived from CMS NADAC data, AWP_DISCOUNT=percentage discount from AWP, WAC_DISCOUNT=percentage discount from WAC, CUSTOM=plan-specific methodology). Required for PBM contract compliance and regulatory transparency. Null when price_type is not MAC.' ;
    rdfs:domain ind:DrugPricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:macPrice rdf:type rdf:Property ;
    rdfs:label 'Mac Price' ;
    rdfs:comment 'Maximum Allowable Cost per unit set by the PBM or health plan for generic and multi-source drugs. Represents the upper reimbursement limit for a drug under the applicable MAC list. Expressed in USD. Null when price_type is not MAC.' ;
    rdfs:domain ind:DrugPricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:packageSizeUom rdf:type rdf:Property ;
    rdfs:label 'Package Size Uom' ;
    rdfs:comment 'Unit of measure for the package size quantity (e.g., TAB for tablets, ML for milliliters). Distinct from unit_of_measure which applies to the pricing unit; this field describes the package-level quantity unit. [ENUM-REF-CANDIDATE: EA|ML|GM|MG|UN|TAB|CAP|VIAL|PATCH — promote to reference product]' ;
    rdfs:domain ind:DrugPricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceChangePct rdf:type rdf:Property ;
    rdfs:label 'Price Change Pct' ;
    rdfs:comment 'Percentage change in unit price from the prior pricing record to the current record, calculated as ((unit_price - prior_unit_price) / prior_unit_price) * 100. Used for drug price inflation monitoring, CMS price increase reporting, and PBM contract compliance.' ;
    rdfs:domain ind:DrugPricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceType rdf:type rdf:Property ;
    rdfs:label 'Price Type' ;
    rdfs:comment 'Classifies the pricing methodology represented by this record: AWP (Average Wholesale Price), WAC (Wholesale Acquisition Cost), MAC (Maximum Allowable Cost), RBP (Reference Based Pricing), NADAC (National Average Drug Acquisition Cost), or Usual and Customary. Determines how the price is applied during claim adjudication and reimbursement calculation. [ENUM-REF-CANDIDATE: AWP|WAC|MAC|RBP|NADAC|USUAL_AND_CUSTOMARY — promote to reference product]' ;
    rdfs:domain ind:DrugPricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricingFileDate rdf:type rdf:Property ;
    rdfs:label 'Pricing File Date' ;
    rdfs:comment 'Publication or release date of the source pricing file from which this record was extracted. Used to track pricing file currency, identify stale pricing data, and support audit and reconciliation processes.' ;
    rdfs:domain ind:DrugPricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pricingFileName rdf:type rdf:Property ;
    rdfs:label 'Pricing File Name' ;
    rdfs:comment 'Name of the source pricing file from which this record was loaded (e.g., \'FDB_PRICE_20240101.txt\', \'RXCLAIM_MAC_Q1_2024.csv\'). Used for data lineage, audit trails, and troubleshooting pricing discrepancies.' ;
    rdfs:domain ind:DrugPricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricingSource rdf:type rdf:Property ;
    rdfs:label 'Pricing Source' ;
    rdfs:comment 'Identifies the originating source of the pricing data (e.g., First Databank, Medi-Span, RxClaim PBM feed, Argus PBM feed, CMS published rates, internal custom pricing). Critical for audit trails and PBM contract compliance. [ENUM-REF-CANDIDATE: FDB|MEDISPAN|RXCLAIM|ARGUS|CMS|INTERNAL|CUSTOM — promote to reference product]' ;
    rdfs:domain ind:DrugPricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricingStatus rdf:type rdf:Property ;
    rdfs:label 'Pricing Status' ;
    rdfs:comment 'Current lifecycle status of the pricing record: active (currently in use for adjudication), inactive (no longer applicable), pending (approved but not yet effective), superseded (replaced by a newer pricing record for the same NDC and price type).' ;
    rdfs:domain ind:DrugPricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorUnitPrice rdf:type rdf:Property ;
    rdfs:label 'Prior Unit Price' ;
    rdfs:comment 'Previous per-unit price for this NDC and price type before the most recent pricing update. Used for price change analysis, trend reporting, and PBM contract compliance audits.' ;
    rdfs:domain ind:DrugPricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rbpPrice rdf:type rdf:Property ;
    rdfs:label 'Rbp Price' ;
    rdfs:comment 'Reference Based Pricing per unit used as the benchmark reimbursement amount under RBP pharmacy contracts. Expressed in USD. Null when price_type is not RBP.' ;
    rdfs:domain ind:DrugPricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Unit Of Measure' ;
    rdfs:comment 'Dispensing unit of measure for which the price applies (e.g., EA=Each, ML=Milliliter, GM=Gram, MG=Milligram, UN=Unit, TAB=Tablet, CAP=Capsule, VIAL=Vial, PATCH=Patch). Required for accurate per-unit cost calculation during adjudication. [ENUM-REF-CANDIDATE: EA|ML|GM|MG|UN|TAB|CAP|VIAL|PATCH — promote to reference product]' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitPrice rdf:type rdf:Property ;
    rdfs:label 'Unit Price' ;
    rdfs:comment 'Per-unit drug price expressed in USD for the applicable price type (AWP, WAC, MAC, or RBP). Used as the basis for claim adjudication, cost-sharing calculation, and pharmacy reimbursement. Precision to 6 decimal places to accommodate high-precision specialty drug pricing.' ;
    rdfs:domain ind:DrugPricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wacPrice rdf:type rdf:Property ;
    rdfs:label 'Wac Price' ;
    rdfs:comment 'Wholesale Acquisition Cost per unit as reported by the manufacturer to the pricing compendia. Represents the list price from manufacturer to wholesaler before discounts. Expressed in USD. Used in WAC-based reimbursement contracts.' ;
    rdfs:domain ind:DrugPricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pharmacyClaimId rdf:type rdf:Property ;
    rdfs:label 'Pharmacy Claim Id' ;
    rdfs:comment 'Unique surrogate identifier for each pharmacy claim record in the Silver layer lakehouse. Primary key for the pharmacy_claim data product. Role: TRANSACTION_HEADER.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PharmacyClaim .

ind:dispensingPharmacyId rdf:type rdf:Property ;
    rdfs:label 'Dispensing Pharmacy Id' ;
    rdfs:comment 'Surrogate reference to the pharmacy that dispensed the drug. Links to the provider/pharmacy master record. Distinguishes retail, mail-order, and specialty pharmacy channels. Used for network adequacy reporting and pharmacy audit trail requirements.' ;
    rdfs:domain ind:Pharmacy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DispensingPharmacy .

ind:enrollmentEligibilitySpanId rdf:type rdf:Property ;
    rdfs:label 'Enrollment Eligibility Span Id' ;
    rdfs:comment 'Foreign key linking to enrollment.enrollment_eligibility_span. Business justification: Required for claim adjudication to determine member\'s eligibility span at service date, supporting CMS reporting and accurate cost-share calculations.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EnrollmentEligibilitySpan .

ind:gracePeriodId rdf:type rdf:Property ;
    rdfs:label 'Grace Period Id' ;
    rdfs:comment 'Foreign key linking to billing.grace_period. Business justification: ACA marketplace regulations require pharmacy claims adjudicated during a 90-day grace period to be tracked for potential reversal if premium goes unpaid. Health insurance operations must link each pha' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GracePeriod .

ind:headerId rdf:type rdf:Property ;
    rdfs:label 'Header Id' ;
    rdfs:comment 'Foreign key linking to claim.header. Business justification: Required for integrated care reporting: links pharmacy claims to the corresponding medical claim header for episode-of-care analysis and coordinated benefits calculations.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Header .

ind:memberIdentityId rdf:type rdf:Property ;
    rdfs:label 'Member Identity Id' ;
    rdfs:comment 'Surrogate reference to the health plan member who is the beneficiary of this pharmacy claim. Links to the member master record in the Core Administration Platform (Facets/QNXT). Required for eligibility verification, coordination of benefits (COB), and CMS Part D risk adjustment (RAF/HCC).' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Identity .

ind:memberRiskScoreId rdf:type rdf:Property ;
    rdfs:label 'Member Risk Score Id' ;
    rdfs:comment 'Foreign key linking to risk.member_risk_score. Business justification: Risk-adjusted claim adjudication report requires each claim to reference the member\'s risk score to apply CMS risk adjustment factors.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MemberRiskScore .

ind:pharmacyClaimPbmTransactionId rdf:type rdf:Property ;
    rdfs:label 'Pharmacy Claim Pbm Transaction Id' ;
    rdfs:comment 'Source system transaction identifier assigned by the PBM system (RxClaim or Argus) at the time of adjudication. Used for claim traceability, PBM reconciliation, EDI 835 remittance matching, and pharmacy audit trail. Enables lineage back to the operational system of record.' ;
    rdfs:domain ind:PharmacyClaim ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Transaction .

ind:pharmacyClaimTransactionId rdf:type rdf:Property ;
    rdfs:label 'Pharmacy Claim Transaction Id' ;
    rdfs:comment 'Foreign key linking to enrollment.enrollment_transaction. Business justification: Provides audit link between each pharmacy claim and the enrollment transaction that established coverage, needed for reconciliation and regulatory audit.' ;
    rdfs:domain ind:PharmacyClaim ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Transaction .

ind:priorAuthorizationId rdf:type rdf:Property ;
    rdfs:label 'Prior Authorization Id' ;
    rdfs:comment 'Surrogate reference to the prior authorization record that approved dispensing of this drug, if applicable. Null when no PA was required. Links to the utilization management PA product. Required for specialty drug claims and step therapy override tracking.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PriorAuthorization .

ind:providerId rdf:type rdf:Property ;
    rdfs:label 'Provider Id' ;
    rdfs:comment 'Surrogate reference to the prescribing provider who authored the prescription. Links to the provider master record in the Provider Management System (Cactus/ProviderSource). Used for prescriber profiling, fraud/waste/abuse (FWA) detection, and HEDIS measure attribution.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Provider .

ind:umCaseId rdf:type rdf:Property ;
    rdfs:label 'Um Case Id' ;
    rdfs:comment 'Foreign key linking to utilization.um_case. Business justification: Claims are associated with utilization-management cases for case-level cost analysis and outcome tracking, required by case management dashboards.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:UmCase .

ind:adjudicationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Adjudication Timestamp' ;
    rdfs:comment 'Date and time the pharmacy claim was adjudicated (approved or rejected) by the PBM system. Distinct from fill_date (dispensing event). Used for claims processing SLA measurement, 835 remittance matching, and audit trail compliance.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:basisOfCostDetermination rdf:type rdf:Property ;
    rdfs:label 'Basis Of Cost Determination' ;
    rdfs:comment 'Code indicating the pricing benchmark used to determine the ingredient cost for this claim. AWP = Average Wholesale Price; WAC = Wholesale Acquisition Cost; MAC = Maximum Allowable Cost; usual_and_customary = pharmacy\'s standard retail price; negotiated = contracted rate; 340B = 340B program pricing; other = alternative basis. [ENUM-REF-CANDIDATE: awp|wac|mac|usual_and_customary|negotiated|340b|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Pharmacy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimNumber rdf:type rdf:Property ;
    rdfs:label 'Claim Number' ;
    rdfs:comment 'Externally-known, human-readable claim reference number assigned by the Pharmacy Benefit Management (PBM) system (RxClaim or Argus) at adjudication. Used for member communications, Explanation of Benefits (EOB), and 835 remittance reconciliation. Maps to NCPDP D.0 transaction reference number.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimStatus rdf:type rdf:Property ;
    rdfs:label 'Claim Status' ;
    rdfs:comment 'Current adjudication lifecycle status of the pharmacy claim as determined by the PBM system. \'paid\' = claim adjudicated and payment issued; \'rejected\' = claim denied with reject code; \'reversed\' = previously paid claim reversed; \'adjusted\' = claim reprocessed with changed amounts; \'pending\' = awaiting adjudication; \'void\' = cancelled before processing.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cobIndicator rdf:type rdf:Property ;
    rdfs:label 'Cob Indicator' ;
    rdfs:comment 'Indicates whether coordination of benefits (COB) was applied on this claim (True = COB applied, another payer was involved). Triggers COB segment processing and other_payer_amount population. Used for COB reconciliation and CMS Part D TrOOP calculations.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dawCode rdf:type rdf:Property ;
    rdfs:label 'Daw Code' ;
    rdfs:comment 'NCPDP Dispense As Written (DAW) code indicating whether a brand drug was dispensed when a generic was available, and the reason. 0 = no product selection indicated; 1 = substitution not allowed by prescriber; 2 = substitution allowed, patient requested brand; 3 = substitution allowed, pharmacist selected brand; 4 = substitution allowed, generic not in stock; 5 = substitution allowed, brand dispensed as generic. Used for generic substitution rate analytics and formulary compliance.' ;
    rdfs:domain ind:PharmacyClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deductibleApplied rdf:type rdf:Property ;
    rdfs:label 'Deductible Applied' ;
    rdfs:comment 'Dollar amount of this pharmacy claim applied toward the member\'s pharmacy or combined medical/pharmacy deductible. Relevant for HDHP/HSA plans and CMS Part D deductible phase tracking. Contributes to OOP/MOOP accumulation.' ;
    rdfs:domain ind:PharmacyClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dispensingPharmacyNpi rdf:type rdf:Property ;
    rdfs:label 'Dispensing Pharmacy Npi' ;
    rdfs:comment '10-digit National Provider Identifier (NPI) of the dispensing pharmacy as submitted on the pharmacy claim. Denormalized for claim-level auditability and NCPDP D.0 compliance. Used for pharmacy network validation, audit trail, and CMS Part D encounter data.' ;
    rdfs:domain ind:PharmacyClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:durOutcomeCode rdf:type rdf:Property ;
    rdfs:label 'Dur Outcome Code' ;
    rdfs:comment 'NCPDP standard code indicating the outcome of the prospective drug utilization review (DUR) edit performed during adjudication (e.g., drug-drug interaction, duplicate therapy, dose check). Null if no DUR alert was triggered. Critical for pharmacy safety and regulatory compliance. [ENUM-REF-CANDIDATE: promote to reference product — NCPDP DUR outcome codes exceed 6 values]' ;
    rdfs:domain ind:Pharmacy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fillDate rdf:type rdf:Property ;
    rdfs:label 'Fill Date' ;
    rdfs:comment 'The date the prescription was dispensed by the pharmacy to the member. This is the principal real-world business event date (BUSINESS_EVENT_TIMESTAMP category). Used for days supply calculations, refill-too-soon edits, and CMS Part D encounter data date of service reporting.' ;
    rdfs:domain ind:PharmacyClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ingredientCost rdf:type rdf:Property ;
    rdfs:label 'Ingredient Cost' ;
    rdfs:comment 'The cost of the drug ingredient(s) as billed by the dispensing pharmacy, before dispensing fee and other adjustments. Basis may be AWP, WAC, MAC, or negotiated rate. Core component of the MONETARY_TRIPLET for pharmacy claim financials. Used for PBM contract reconciliation and MLR calculation.' ;
    rdfs:domain ind:PharmacyClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:is340bClaim rdf:type rdf:Property ;
    rdfs:label 'Is 340b Claim' ;
    rdfs:comment 'Indicates whether this pharmacy claim was dispensed under the 340B Drug Pricing Program (True = 340B claim). Used for 340B duplicate discount prevention, HRSA compliance reporting, and separation of 340B and non-340B claims in financial reconciliation.' ;
    rdfs:domain ind:PharmacyClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isCompoundClaim rdf:type rdf:Property ;
    rdfs:label 'Is Compound Claim' ;
    rdfs:comment 'Indicates whether this claim is for a compounded drug product containing multiple ingredients (True = compound claim). Compound claims require line-level detail in the pharmacy_claim_line product. Used for compound drug utilization review and cost management.' ;
    rdfs:domain ind:PharmacyClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lineOfBusiness rdf:type rdf:Property ;
    rdfs:label 'Line Of Business' ;
    rdfs:comment 'Line of business under which this pharmacy claim was adjudicated. Drives regulatory reporting requirements, formulary rules, and cost-sharing structures. \'commercial\' = employer-sponsored or individual; \'medicare_part_d\' = CMS Medicare Part D; \'medicaid\' = state Medicaid; \'exchange\' = ACA marketplace QHP; \'cobra\' = COBRA continuation coverage.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:memberCoinsurance rdf:type rdf:Property ;
    rdfs:label 'Member Coinsurance' ;
    rdfs:comment 'Percentage-based cost-sharing amount paid by the member for this pharmacy claim, calculated as a percentage of the allowed cost. Applies when the benefit design uses coinsurance rather than fixed copay. Contributes to OOP/MOOP accumulation.' ;
    rdfs:domain ind:PharmacyClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:memberCopay rdf:type rdf:Property ;
    rdfs:label 'Member Copay' ;
    rdfs:comment 'Fixed dollar amount paid by the member at point of sale as their cost-sharing obligation for this pharmacy claim. Determined by formulary tier and benefit design. Contributes to member out-of-pocket (OOP) and maximum out-of-pocket (MOOP) accumulation.' ;
    rdfs:domain ind:PharmacyClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:originalClaimNumber rdf:type rdf:Property ;
    rdfs:label 'Original Claim Number' ;
    rdfs:comment 'Claim number of the original pharmacy claim that this record adjusts or reverses. Populated only for adjusted or reversed claims; null for original claims. Enables claim adjustment chain tracing for financial reconciliation, audit, and CMS Part D encounter data correction submissions.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pharmacyChannel rdf:type rdf:Property ;
    rdfs:label 'Pharmacy Channel' ;
    rdfs:comment 'Channel through which the drug was dispensed. Drives cost-sharing differentials, formulary tier rules, and network adequacy reporting. \'retail\' = community pharmacy; \'mail_order\' = 90-day mail service; \'specialty\' = specialty pharmacy for high-cost/complex drugs; \'long_term_care\' = SNF/LTC pharmacy; \'home_infusion\' = infusion therapy at home.' ;
    rdfs:domain ind:Pharmacy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planPaidAmount rdf:type rdf:Property ;
    rdfs:label 'Plan Paid Amount' ;
    rdfs:comment 'Total amount paid by the health plan for this pharmacy claim after applying member cost-sharing (copay, coinsurance, deductible) and COB adjustments. Net total component of the MONETARY_TRIPLET. Used for 835 remittance, MLR reporting, and CMS Part D encounter data.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:prescriberNpi rdf:type rdf:Property ;
    rdfs:label 'Prescriber Npi' ;
    rdfs:comment '10-digit National Provider Identifier (NPI) of the prescribing provider as submitted on the pharmacy claim. Denormalized for claim-level auditability, NCPDP D.0 compliance, and CMS Part D encounter data submission. Used for prescriber fraud/waste/abuse (FWA) analytics.' ;
    rdfs:domain ind:PharmacyClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prescriptionWrittenDate rdf:type rdf:Property ;
    rdfs:label 'Prescription Written Date' ;
    rdfs:comment 'Date the prescription was written by the prescriber. Used to validate prescription age, enforce days-supply-from-written-date rules, and support medication adherence analytics. Distinct from fill_date (dispensing date).' ;
    rdfs:domain ind:Pharmacy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:quantityDispensed rdf:type rdf:Property ;
    rdfs:label 'Quantity Dispensed' ;
    rdfs:comment 'Actual quantity of the drug dispensed (e.g., number of tablets, milliliters, grams) as reported by the dispensing pharmacy. Used for quantity limit (QL) edits, drug utilization review (DUR), and CMS Part D encounter data submission.' ;
    rdfs:domain ind:Pharmacy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Quantity Unit Of Measure' ;
    rdfs:comment 'NCPDP standard unit of measure code for the quantity dispensed. EA = each (tablets/capsules); ML = milliliters; GM = grams; UN = units; F2 = international units; ME = milliequivalents. Required for accurate quantity limit (QL) edit enforcement and CMS Part D encounter data.' ;
    rdfs:domain ind:PharmacyClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refillNumber rdf:type rdf:Property ;
    rdfs:label 'Refill Number' ;
    rdfs:comment 'Refill sequence number for this dispensing event. Zero (0) indicates the original fill; subsequent values indicate refill number. Used for refill-too-soon edits, medication adherence tracking, and prescription lifecycle management.' ;
    rdfs:domain ind:Pharmacy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rejectCode rdf:type rdf:Property ;
    rdfs:label 'Reject Code' ;
    rdfs:comment 'NCPDP standard reject code returned by the PBM system when a claim is rejected or denied. Null for paid claims. Used for pharmacy operations, member appeals, and drug utilization review (DUR) outcome tracking. [ENUM-REF-CANDIDATE: promote to reference product — NCPDP reject codes exceed 6 values]' ;
    rdfs:domain ind:PharmacyClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesTax rdf:type rdf:Property ;
    rdfs:label 'Sales Tax' ;
    rdfs:comment 'Sales tax amount applied to the pharmacy claim where applicable by state law. Included in total claim cost and reported separately for financial reconciliation and statutory accounting (SAP) purposes.' ;
    rdfs:domain ind:PharmacyClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stepTherapyOverride rdf:type rdf:Property ;
    rdfs:label 'Step Therapy Override' ;
    rdfs:comment 'Indicates whether a step therapy protocol was overridden for this claim (True = override applied). Step therapy requires trying lower-cost drugs before approving higher-cost alternatives. Override requires prior authorization. Used for utilization management (UM) reporting and CMS step therapy compliance.' ;
    rdfs:domain ind:PharmacyClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:claimLineId rdf:type rdf:Property ;
    rdfs:label 'Claim Line Id' ;
    rdfs:comment 'Primary key for claim_line' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Line .

ind:catastrophicCoverageIndicator rdf:type rdf:Property ;
    rdfs:label 'Catastrophic Coverage Indicator' ;
    rdfs:comment 'Indicates whether this claim line was adjudicated under the catastrophic coverage phase of the Part D benefit, where the plan pays a higher percentage of drug costs after the member\'s True Out-of-Pocket (TrOOP) threshold is met.' ;
    rdfs:domain ind:ClaimLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cobSequence rdf:type rdf:Property ;
    rdfs:label 'Cob Sequence' ;
    rdfs:comment 'Indicates the payer sequence in a Coordination of Benefits (COB) scenario. 1=primary payer, 2=secondary payer, 3=tertiary payer. Used to correctly apply COB rules and calculate each payer\'s liability on this claim line.' ;
    rdfs:domain ind:ClaimLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:compoundIndicator rdf:type rdf:Property ;
    rdfs:label 'Compound Indicator' ;
    rdfs:comment 'Indicates whether this claim line is part of a compounded drug prescription. When true, multiple ingredient lines will exist under the same claim header, each with its own NDC and ingredient cost.' ;
    rdfs:domain ind:ClaimLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:coverageGapIndicator rdf:type rdf:Property ;
    rdfs:label 'Coverage Gap Indicator' ;
    rdfs:comment 'Indicates whether this claim line was adjudicated during the Part D coverage gap (donut hole) phase. Used for manufacturer discount program tracking and CMS Part D benefit phase reporting.' ;
    rdfs:domain ind:ClaimLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dispenseAsWrittenCode rdf:type rdf:Property ;
    rdfs:label 'Dispense As Written Code' ;
    rdfs:comment 'NCPDP Dispense As Written (DAW) code indicating whether the prescriber or member requested brand-name dispensing when a generic was available. DAW 0=no product selection indicated, DAW 1=substitution not allowed by prescriber, DAW 2=substitution allowed-patient requested brand. Impacts cost-sharing and GDR calculations.' ;
    rdfs:domain ind:ClaimLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispensedDate rdf:type rdf:Property ;
    rdfs:label 'Dispensed Date' ;
    rdfs:comment 'Date the drug was dispensed to the member at the pharmacy. Represents the real-world service event date used for benefit period calculations, days supply tracking, and CMS Part D reporting.' ;
    rdfs:domain ind:ClaimLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dispensingFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Dispensing Fee Amount' ;
    rdfs:comment 'The fee charged by the dispensing pharmacy for the professional service of dispensing the medication. Negotiated as part of PBM network contracts and reported separately from ingredient cost per CMS Part D requirements.' ;
    rdfs:domain ind:Pharmacy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:drugCoverageStatus rdf:type rdf:Property ;
    rdfs:label 'Drug Coverage Status' ;
    rdfs:comment 'Coverage determination status for this drug on the applicable formulary at time of adjudication. Indicates whether the drug is covered, non-covered, excluded, subject to step therapy, or requires prior authorization (PA).' ;
    rdfs:domain ind:ClaimLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:durConflictCode rdf:type rdf:Property ;
    rdfs:label 'Dur Conflict Code' ;
    rdfs:comment 'NCPDP DUR conflict code identifying the type of drug utilization issue detected during adjudication (e.g., drug-drug interaction, drug-disease contraindication, duplicate therapy, high dose). Supports clinical safety monitoring and regulatory DUR reporting. [ENUM-REF-CANDIDATE: promote to reference product for full NCPDP DUR conflict code set]' ;
    rdfs:domain ind:ClaimLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fillNumber rdf:type rdf:Property ;
    rdfs:label 'Fill Number' ;
    rdfs:comment 'Sequential fill number for this prescription across all fills, including original and all refills. Distinct from refill_number in that it counts total fills rather than refill sequence. Used for prescription lifecycle tracking.' ;
    rdfs:domain ind:ClaimLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:formularyTier rdf:type rdf:Property ;
    rdfs:label 'Formulary Tier' ;
    rdfs:comment 'Drug formulary tier assigned to this drug at the time of adjudication, determining the member\'s cost-sharing level (e.g., Tier 1 generic, Tier 2 preferred brand, Tier 3 non-preferred brand, Tier 4 specialty). Drives copay/coinsurance calculation.' ;
    rdfs:domain ind:ClaimLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:genericIndicator rdf:type rdf:Property ;
    rdfs:label 'Generic Indicator' ;
    rdfs:comment 'Indicates whether the dispensed drug is a generic equivalent. Used for generic dispensing rate (GDR) reporting, formulary compliance analytics, and PBM performance measurement.' ;
    rdfs:domain ind:ClaimLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:grossDrugCostAmount rdf:type rdf:Property ;
    rdfs:label 'Gross Drug Cost Amount' ;
    rdfs:comment 'Total gross cost of the drug on this claim line, calculated as ingredient cost plus dispensing fee plus sales tax plus incentive amount. Used as the basis for CMS Part D gross drug cost reporting and risk corridor calculations.' ;
    rdfs:domain ind:ClaimLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:incentiveAmount rdf:type rdf:Property ;
    rdfs:label 'Incentive Amount' ;
    rdfs:comment 'Incentive or bonus amount paid to the pharmacy for performance-based or preferred network participation on this claim line. Included in gross drug cost calculations for CMS Part D reporting.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ingredientCostAmount rdf:type rdf:Property ;
    rdfs:label 'Ingredient Cost Amount' ;
    rdfs:comment 'The drug ingredient cost component of the claim line, representing the cost of the drug itself exclusive of dispensing fee, sales tax, and other charges. Key input for MAC/AWP/WAC-based reimbursement calculations and compound drug cost analysis.' ;
    rdfs:domain ind:ClaimLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lineSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Line Sequence Number' ;
    rdfs:comment 'Sequential number identifying the position of this line within the parent pharmacy claim. Used to order compound ingredient lines and COB line splits. Starts at 1.' ;
    rdfs:domain ind:ClaimLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lineStatus rdf:type rdf:Property ;
    rdfs:label 'Line Status' ;
    rdfs:comment 'Current adjudication status of this pharmacy claim line. Drives payment processing, COB resolution, and audit reporting. [ENUM-REF-CANDIDATE: paid|denied|reversed|adjusted|pending|void — promote to reference product if additional statuses are needed]' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineType rdf:type rdf:Property ;
    rdfs:label 'Line Type' ;
    rdfs:comment 'Classifies the nature of this claim line: standard single-drug fill, compound ingredient line, COB line split, reversal, or adjustment. Drives compound cost analysis and COB workflows.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lowIncomeSubsidyIndicator rdf:type rdf:Property ;
    rdfs:label 'Low Income Subsidy Indicator' ;
    rdfs:comment 'Indicates whether the member received a Low Income Subsidy (LIS) benefit on this claim line, resulting in reduced cost-sharing. Required for CMS Part D PDE reporting and LIS reconciliation.' ;
    rdfs:domain ind:ClaimLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:manufacturerDiscountAmount rdf:type rdf:Property ;
    rdfs:label 'Manufacturer Discount Amount' ;
    rdfs:comment 'Amount of manufacturer discount applied to this claim line under the CMS Part D Coverage Gap Discount Program. Counts toward the member\'s TrOOP and is reported on the PDE record.' ;
    rdfs:domain ind:ClaimLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:patientPayAmount rdf:type rdf:Property ;
    rdfs:label 'Patient Pay Amount' ;
    rdfs:comment 'Total amount paid by the member/patient at point of sale, including copay, coinsurance, and deductible contributions. Used for Out-of-Pocket (OOP) accumulator tracking and Maximum Out-of-Pocket (MOOP) calculations.' ;
    rdfs:domain ind:ClaimLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pdeSubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Pde Submission Date' ;
    rdfs:comment 'Date this claim line was submitted to CMS as a Prescription Drug Event (PDE) record for Part D reconciliation and risk adjustment. Null for non-Part D claims. Critical for CMS compliance and audit.' ;
    rdfs:domain ind:ClaimLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:quantityLimitIndicator rdf:type rdf:Property ;
    rdfs:label 'Quantity Limit Indicator' ;
    rdfs:comment 'Indicates whether a quantity limit restriction was applied to this drug claim line during adjudication. When true, the dispensed quantity was subject to plan-defined quantity limit rules.' ;
    rdfs:domain ind:ClaimLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reversalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Reversal Timestamp' ;
    rdfs:comment 'Date and time when this pharmacy claim line was reversed, if applicable. Null for non-reversed lines. Used for financial reconciliation, audit trails, and identifying reversed claims in PMPM and MLR calculations.' ;
    rdfs:domain ind:ClaimLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:salesTaxAmount rdf:type rdf:Property ;
    rdfs:label 'Sales Tax Amount' ;
    rdfs:comment 'State or local sales tax applied to this pharmacy claim line where applicable. Reported separately per CMS Part D PDE requirements. Zero or null in states with no drug sales tax.' ;
    rdfs:domain ind:ClaimLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sourceSystemClaimLineKey rdf:type rdf:Property ;
    rdfs:label 'Source System Claim Line Key' ;
    rdfs:comment 'Natural key or transaction identifier for this claim line as assigned by the originating PBM system (RxClaim or Argus). Used for lineage tracing, reconciliation with source system, and EDI transaction matching.' ;
    rdfs:domain ind:ClaimLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialtyDrugIndicator rdf:type rdf:Property ;
    rdfs:label 'Specialty Drug Indicator' ;
    rdfs:comment 'Indicates whether the drug dispensed on this line is classified as a specialty drug, typically requiring special handling, storage, or administration and subject to specialty pharmacy channel requirements and PA rules.' ;
    rdfs:domain ind:ClaimLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:stepTherapyIndicator rdf:type rdf:Property ;
    rdfs:label 'Step Therapy Indicator' ;
    rdfs:comment 'Indicates whether this drug claim line was subject to a step therapy protocol requiring the member to try a preferred or lower-cost drug before coverage of this drug was approved.' ;
    rdfs:domain ind:ClaimLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:trueOopAmount rdf:type rdf:Property ;
    rdfs:label 'True Oop Amount' ;
    rdfs:comment 'Member\'s True Out-of-Pocket (TrOOP) cost contribution from this claim line, used to track progress toward the Part D catastrophic coverage threshold. Includes patient pay and applicable manufacturer discounts.' ;
    rdfs:domain ind:ClaimLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:caseId rdf:type rdf:Property ;
    rdfs:label 'Case Id' ;
    rdfs:comment 'Foreign key linking to appeal.appeal_case. Business justification: Needed for the \'Prior Authorization Appeal\' workflow; links a PA request to its appeal case for audit, compliance, and outcome reporting.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Case .

ind:medicareEntitlementId rdf:type rdf:Property ;
    rdfs:label 'Medicare Entitlement Id' ;
    rdfs:comment 'Foreign key linking to enrollment.medicare_entitlement. Business justification: Medicare Part D PA processing requires referencing the member\'s entitlement record for LIS/Extra Help status, Part D enrollment effective date, and dual-eligible indicators. prior_authorization.cms_pa' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MedicareEntitlement .

ind:memberSubscriberId rdf:type rdf:Property ;
    rdfs:label 'Member Subscriber Id' ;
    rdfs:comment 'Identifier of the health plan member for whom the prior authorization is requested. Links to the member master record in the Core Administration Platform (Facets/QNXT).' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Subscriber .

ind:originalPaPriorAuthorizationId rdf:type rdf:Property ;
    rdfs:label 'Original Pa Prior Authorization Id' ;
    rdfs:comment 'Reference to the original prior authorization record when this record represents a renewal, appeal, or modification. Enables tracking of the full PA lifecycle chain. Null for initial requests.' ;
    rdfs:domain ind:PriorAuthorization ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PriorAuthorization .

ind:paRequestId rdf:type rdf:Property ;
    rdfs:label 'Pa Request Id' ;
    rdfs:comment 'Foreign key linking to utilization.pa_request. Business justification: Required for PA audit report linking each prior authorization record to its originating request, enabling traceability of request-to-authorization lifecycle.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PaRequest .

ind:prescriberProviderId rdf:type rdf:Property ;
    rdfs:label 'Prescriber Provider Id' ;
    rdfs:comment 'Foreign key linking to provider.provider_provider. Business justification: PA requests are submitted by prescribing providers; health plans must validate prescriber credentials, network participation, and specialty when adjudicating PAs. This is a core UM/PA workflow. prescr' ;
    rdfs:domain ind:Pharmacy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Provider .

ind:appealIndicator rdf:type rdf:Property ;
    rdfs:label 'Appeal Indicator' ;
    rdfs:comment 'Indicates whether this prior authorization record is associated with a member or prescriber appeal of a prior denial. True = this PA is an appeal case.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:approvedDaysSupply rdf:type rdf:Property ;
    rdfs:label 'Approved Days Supply' ;
    rdfs:comment 'Number of days of drug therapy authorized under this prior authorization. Used by the PBM to enforce dispensing limits and by CMS Part D for compliance reporting.' ;
    rdfs:domain ind:PriorAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approvedQuantity rdf:type rdf:Property ;
    rdfs:label 'Approved Quantity' ;
    rdfs:comment 'Total quantity of the drug authorized for dispensing under this prior authorization (e.g., number of tablets, milliliters, units). Enforced at point-of-sale by the PBM adjudication system.' ;
    rdfs:domain ind:PriorAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvedRefills rdf:type rdf:Property ;
    rdfs:label 'Approved Refills' ;
    rdfs:comment 'Number of refills authorized under this prior authorization in addition to the initial fill. Enforced by the PBM adjudication system at point-of-sale.' ;
    rdfs:domain ind:PriorAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:clinicalCriteriaVersion rdf:type rdf:Property ;
    rdfs:label 'Clinical Criteria Version' ;
    rdfs:comment 'Version of the clinical criteria set (InterQual or MCG) applied at the time of the prior authorization decision. Required for audit trails and appeals to ensure the correct criteria version is referenced.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cmsPartDReportable rdf:type rdf:Property ;
    rdfs:label 'Cms Part D Reportable' ;
    rdfs:comment 'Indicates whether this prior authorization record is subject to CMS Part D PA reporting requirements. True = must be included in CMS Part D PA reporting submissions.' ;
    rdfs:domain ind:PriorAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:criteriaMet rdf:type rdf:Property ;
    rdfs:label 'Criteria Met' ;
    rdfs:comment 'Indicates whether the submitted clinical information met the applicable clinical criteria (InterQual/MCG) for the requested drug. True = criteria met (supports approval); False = criteria not met (supports denial).' ;
    rdfs:domain ind:PriorAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:decisionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Decision Timestamp' ;
    rdfs:comment 'Exact date and time the prior authorization decision (approval, denial, or pend) was rendered by the clinical reviewer or automated adjudication engine. Used to calculate turnaround time against CMS and URAC standards.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:denialReasonCode rdf:type rdf:Property ;
    rdfs:label 'Denial Reason Code' ;
    rdfs:comment 'Standardized code indicating the reason for denial of the prior authorization request (e.g., not medically necessary, step therapy not completed, quantity limit exceeded, non-covered drug). Populated only when pa_status = denied. Used for member appeals and CMS Part D reporting.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:denialReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Denial Reason Description' ;
    rdfs:comment 'Free-text description of the denial reason, providing clinical or administrative context beyond the denial reason code. Included in member and prescriber denial notices per CMS and state DOI requirements.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drugTier rdf:type rdf:Property ;
    rdfs:label 'Drug Tier' ;
    rdfs:comment 'Formulary tier of the requested drug at the time of the prior authorization request. Determines cost-sharing obligations and PA criteria applied.' ;
    rdfs:domain ind:PriorAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveEndDate rdf:type rdf:Property ;
    rdfs:label 'Effective End Date' ;
    rdfs:comment 'Date on which the prior authorization expires and is no longer valid for dispensing. After this date, a new PA request is required. Nullable for open-ended authorizations.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectiveStartDate rdf:type rdf:Property ;
    rdfs:label 'Effective Start Date' ;
    rdfs:comment 'Date from which the approved prior authorization is valid for dispensing. Pharmacies and PBM adjudication systems use this date to confirm dispensing eligibility.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:icdDiagnosisCode rdf:type rdf:Property ;
    rdfs:label 'Icd Diagnosis Code' ;
    rdfs:comment 'Primary ICD-10-CM diagnosis code submitted by the prescriber to support the clinical necessity of the requested drug. Required for clinical criteria evaluation and CMS Part D PA reporting. Contains Protected Health Information (PHI).' ;
    rdfs:domain ind:Pharmacy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lob rdf:type rdf:Property ;
    rdfs:label 'Lob' ;
    rdfs:comment 'Line of Business (LOB) under which the member\'s coverage falls, determining applicable regulatory requirements, formulary rules, and PA criteria (e.g., Commercial, Medicare Part D, Medicaid, ACA Marketplace).' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notes rdf:type rdf:Property ;
    rdfs:label 'Notes' ;
    rdfs:comment 'Free-text clinical notes entered by the reviewing clinician during the prior authorization evaluation, capturing clinical rationale, additional context, or instructions for the prescriber or pharmacy. Contains Protected Health Information (PHI).' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Pa Reference Number' ;
    rdfs:comment 'Externally-known, human-readable prior authorization reference number assigned by the Pharmacy Benefit Management (PBM) system (RxClaim or Argus) or Utilization Management (UM) system (InterQual/MCG). Used on Explanation of Benefits (EOB) and communicated to prescribers and pharmacies.' ;
    rdfs:domain ind:PriorAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paStatus rdf:type rdf:Property ;
    rdfs:label 'Pa Status' ;
    rdfs:comment 'Current lifecycle status of the prior authorization request. Drives dispensing eligibility at the pharmacy and CMS Part D PA reporting. [ENUM-REF-CANDIDATE: approved|denied|pending|cancelled|expired|appealed — promote to reference product if additional statuses are needed]' ;
    rdfs:domain ind:PriorAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityLimitApplied rdf:type rdf:Property ;
    rdfs:label 'Quantity Limit Applied' ;
    rdfs:comment 'Indicates whether a quantity limit restriction was a factor in the prior authorization evaluation. True = quantity limit rules were applied during adjudication.' ;
    rdfs:domain ind:PriorAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:receivedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Received Timestamp' ;
    rdfs:comment 'Exact date and time the prior authorization request was received by the Utilization Management (UM) system (InterQual/MCG) or PBM system (RxClaim/Argus). Used for precise turnaround time calculation and regulatory compliance.' ;
    rdfs:domain ind:PriorAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:requestDate rdf:type rdf:Property ;
    rdfs:label 'Request Date' ;
    rdfs:comment 'Calendar date on which the prior authorization request was submitted by the prescriber or pharmacy. Used for turnaround time measurement and CMS Part D compliance reporting.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requestType rdf:type rdf:Property ;
    rdfs:label 'Request Type' ;
    rdfs:comment 'Classification of the prior authorization request indicating whether it is a new request, renewal of an existing authorization, appeal of a denial, expedited urgent request, or retrospective review.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewLevel rdf:type rdf:Property ;
    rdfs:label 'Review Level' ;
    rdfs:comment 'Level of clinical review applied to the prior authorization request, indicating whether it was reviewed by a pharmacist, physician, peer-to-peer consultation, or medical director. Escalation level affects turnaround time standards.' ;
    rdfs:domain ind:PriorAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystem rdf:type rdf:Property ;
    rdfs:label 'Source System' ;
    rdfs:comment 'Operational system of record from which this prior authorization record originated (PBM system RxClaim/Argus or UM system InterQual/MCG or Core Admin Platform Facets/QNXT). Used for data lineage and reconciliation in the Silver Layer.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemPaCode rdf:type rdf:Property ;
    rdfs:label 'Source System Pa Code' ;
    rdfs:comment 'Native prior authorization identifier from the originating operational system (RxClaim, Argus, InterQual, or MCG). Preserved for reconciliation, audit, and cross-system traceability in the Silver Layer.' ;
    rdfs:domain ind:PriorAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stepTherapyCompleted rdf:type rdf:Property ;
    rdfs:label 'Step Therapy Completed' ;
    rdfs:comment 'Indicates whether the member has documented evidence of completing the required step therapy (tried and failed prerequisite drugs) as required by the formulary PA criteria. Populated when step_therapy_required = True.' ;
    rdfs:domain ind:PriorAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:durAlertId rdf:type rdf:Property ;
    rdfs:label 'Dur Alert Id' ;
    rdfs:comment 'Unique surrogate identifier for each Drug Utilization Review (DUR) alert record generated during pharmacy claim adjudication in the Pharmacy Benefit Management (PBM) system (RxClaim or Argus).' ;
    rdfs:domain ind:DurAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:careEnrollmentId rdf:type rdf:Property ;
    rdfs:label 'Care Enrollment Id' ;
    rdfs:comment 'Foreign key linking to care.care_enrollment. Business justification: DUR alerts for members enrolled in care management programs must be routed to their assigned care coordinator for clinical follow-up. Linking dur_alert to care_enrollment enables automated alert routi' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CareEnrollment .

ind:claimHeaderId rdf:type rdf:Property ;
    rdfs:label 'Claim Header Id' ;
    rdfs:comment 'Reference to the pharmacy claim record against which this DUR alert was generated during adjudication. Links the alert to the originating claim transaction.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Header .

ind:pbmTransactionId rdf:type rdf:Property ;
    rdfs:label 'Pbm Transaction Id' ;
    rdfs:comment 'Unique transaction identifier assigned by the PBM system (RxClaim or Argus) to the adjudication transaction that generated this DUR alert. Used for cross-system reconciliation and audit trail.' ;
    rdfs:domain ind:DurAlert ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Transaction .

ind:adjudicationOutcome rdf:type rdf:Property ;
    rdfs:label 'Adjudication Outcome' ;
    rdfs:comment 'Final adjudication outcome of the pharmacy claim after the DUR alert was processed. Indicates whether the claim was paid, rejected due to the alert, overridden by the pharmacist or plan, pending review, or reversed.' ;
    rdfs:domain ind:DurAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alertGeneratedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Alert Generated Timestamp' ;
    rdfs:comment 'Date and time when the DUR alert was generated by the PBM adjudication engine (RxClaim or Argus) during real-time claim processing. Represents the principal business event timestamp for this record.' ;
    rdfs:domain ind:DurAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:alertStatus rdf:type rdf:Property ;
    rdfs:label 'Alert Status' ;
    rdfs:comment 'Current lifecycle status of the DUR alert record. \'active\'=alert is open and requires action, \'resolved\'=alert addressed and closed, \'overridden\'=pharmacist or plan overrode the alert, \'suppressed\'=alert suppressed per plan rules, \'escalated\'=referred for clinical review.' ;
    rdfs:domain ind:DurAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alertTypeCode rdf:type rdf:Property ;
    rdfs:label 'Alert Type Code' ;
    rdfs:comment 'NCPDP standardized code identifying the category of Drug Utilization Review (DUR) alert. Common values: DD=Drug-Drug Interaction, DC=Drug-Disease Contraindication, TD=Therapeutic Duplication, PA=Drug-Allergy, LD=Low Dose, HD=High Dose, MN=Drug-Age, CS=Drug-Gender, AD=Additive Toxicity, RF=Early Refill. [ENUM-REF-CANDIDATE: DD|DC|TD|PA|LD|HD|MN|CS|AD|RF|LR|DS|PG|MC|ID — promote to reference product]' ;
    rdfs:domain ind:DurAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alertTypeDescription rdf:type rdf:Property ;
    rdfs:label 'Alert Type Description' ;
    rdfs:comment 'Human-readable description of the DUR alert type (e.g., \'Drug-Drug Interaction\', \'Therapeutic Duplication\', \'High Dose Alert\', \'Early Refill\'). Complements the alert_type_code for reporting and member communications.' ;
    rdfs:domain ind:DurAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clinicalSignificanceCode rdf:type rdf:Property ;
    rdfs:label 'Clinical Significance Code' ;
    rdfs:comment 'Numeric code from the clinical drug database (First DataBank or Medi-Span) indicating the clinical significance of the drug interaction or contraindication. Ranges from 1 (most severe) to 5 (least severe). Supplements the NCPDP severity_level_code with database-specific grading.' ;
    rdfs:domain ind:DurAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:daysSinceLastFill rdf:type rdf:Property ;
    rdfs:label 'Days Since Last Fill' ;
    rdfs:comment 'Number of days elapsed since the member\'s last fill of the same or therapeutically equivalent drug. Key metric for early refill DUR alert generation and medication adherence analysis.' ;
    rdfs:domain ind:DurAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dispensingDate rdf:type rdf:Property ;
    rdfs:label 'Dispensing Date' ;
    rdfs:comment 'Date on which the drug was dispensed at the pharmacy. Used to correlate the DUR alert with the dispensing event and for retrospective DUR analysis and CMS Part D reporting.' ;
    rdfs:domain ind:DurAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:drugDatabaseSource rdf:type rdf:Property ;
    rdfs:label 'Drug Database Source' ;
    rdfs:comment 'Identifies the clinical drug knowledge database used to generate the DUR alert (e.g., First DataBank (FDB), Medi-Span, Micromedex, Multum, or custom plan rules). Important for audit, reproducibility, and database version tracking.' ;
    rdfs:domain ind:DurAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drugDatabaseVersion rdf:type rdf:Property ;
    rdfs:label 'Drug Database Version' ;
    rdfs:comment 'Version or effective date of the clinical drug knowledge database (e.g., FDB or Medi-Span) used at the time the DUR alert was generated. Required for audit trail and regulatory reproducibility of DUR alert decisions.' ;
    rdfs:domain ind:DurAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drugNdc rdf:type rdf:Property ;
    rdfs:label 'Drug Ndc' ;
    rdfs:comment '11-digit National Drug Code (NDC) identifying the specific drug product (labeler, product, package) that triggered the DUR alert. Primary drug identifier used in pharmacy adjudication.' ;
    rdfs:domain ind:DurAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:durProgramType rdf:type rdf:Property ;
    rdfs:label 'Dur Program Type' ;
    rdfs:comment 'Indicates whether the DUR alert was generated as part of a prospective (point-of-sale, real-time), retrospective (post-dispensing, claims analysis), or concurrent (during hospitalization or ongoing therapy) DUR program.' ;
    rdfs:domain ind:DurAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:icdCodeVersion rdf:type rdf:Property ;
    rdfs:label 'Icd Code Version' ;
    rdfs:comment 'Version of the ICD coding system used for the icd_diagnosis_code on this DUR alert record (e.g., ICD-10-CM). Required for accurate clinical coding interpretation and regulatory reporting.' ;
    rdfs:domain ind:DurAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interactingDrugName rdf:type rdf:Property ;
    rdfs:label 'Interacting Drug Name' ;
    rdfs:comment 'Brand or generic name of the interacting drug involved in a drug-drug interaction or therapeutic duplication alert. Provides human-readable context for pharmacist review and DUR reporting without requiring a drug master lookup.' ;
    rdfs:domain ind:DurAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interactingDrugNdc rdf:type rdf:Property ;
    rdfs:label 'Interacting Drug Ndc' ;
    rdfs:comment '11-digit NDC of the second drug involved in a drug-drug interaction (DDI) or therapeutic duplication DUR alert. Populated when alert_type_code indicates a drug-drug conflict. Null for non-interaction alert types.' ;
    rdfs:domain ind:DurAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ncpdpDurCode rdf:type rdf:Property ;
    rdfs:label 'Ncpdp Dur Code' ;
    rdfs:comment 'Two-character NCPDP standardized DUR conflict code transmitted in the pharmacy claim transaction (Field 439-E4). Identifies the specific clinical conflict detected (e.g., \'DD\' for drug-drug interaction). Required for CMS Part D DUR reporting.' ;
    rdfs:domain ind:DurAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ncpdpRejectCode rdf:type rdf:Property ;
    rdfs:label 'Ncpdp Reject Code' ;
    rdfs:comment 'Two-digit NCPDP reject code returned when the DUR alert results in a claim rejection (e.g., \'88\'=DUR Reject Error). Populated when adjudication_outcome is \'rejected\'. Used for claim denial tracking and appeals.' ;
    rdfs:domain ind:DurAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overrideCode rdf:type rdf:Property ;
    rdfs:label 'Override Code' ;
    rdfs:comment 'Two-character NCPDP code submitted by the pharmacist to override a DUR alert and allow dispensing (e.g., \'OO\'=Other Override, \'OP\'=Prescriber Override, \'OR\'=Pharmacist Override). Populated when adjudication_outcome is \'overridden\'.' ;
    rdfs:domain ind:DurAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overrideComment rdf:type rdf:Property ;
    rdfs:label 'Override Comment' ;
    rdfs:comment 'Free-text clinical justification or pharmacist notes entered when overriding a DUR alert. Documents the clinical rationale for proceeding with dispensing despite the alert. Supports audit and retrospective DUR review.' ;
    rdfs:domain ind:DurAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Pa Required Flag' ;
    rdfs:comment 'Indicates whether the DUR alert outcome requires a Prior Authorization (PA) to be obtained before the drug can be dispensed. True when the alert triggers a PA requirement per plan formulary or step therapy rules.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:prescribedQuantity rdf:type rdf:Property ;
    rdfs:label 'Prescribed Quantity' ;
    rdfs:comment 'Quantity of the drug as written on the original prescription by the prescriber. Compared against quantity_dispensed and plan quantity limits in DUR alert evaluation.' ;
    rdfs:domain ind:DurAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:professionalServiceCode rdf:type rdf:Property ;
    rdfs:label 'Professional Service Code' ;
    rdfs:comment 'Two-character NCPDP code (Field 440-E5) indicating the professional service performed by the pharmacist in response to the DUR alert (e.g., \'AS\'=Patient Assessment, \'CC\'=Coordination of Care, \'DE\'=Dosing Evaluation, \'PM\'=Patient Medication Education). Required for CMS Part D DUR reporting.' ;
    rdfs:domain ind:DurAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityLimitFlag rdf:type rdf:Property ;
    rdfs:label 'Quantity Limit Flag' ;
    rdfs:comment 'Indicates whether the DUR alert was triggered by a quantity limit edit, where the dispensed or prescribed quantity exceeds the plan\'s maximum allowable quantity for the drug.' ;
    rdfs:domain ind:Pharmacy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reasonForServiceCode rdf:type rdf:Property ;
    rdfs:label 'Reason For Service Code' ;
    rdfs:comment 'Two-character NCPDP code (Field 439-E4 context) providing the clinical reason for the DUR service intervention. Captures the specific clinical basis for the alert and pharmacist action. Used in prospective DUR programs.' ;
    rdfs:domain ind:DurAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resultOfServiceCode rdf:type rdf:Property ;
    rdfs:label 'Result Of Service Code' ;
    rdfs:comment 'Two-character NCPDP code (Field 441-E6) indicating the outcome of the pharmacist\'s intervention in response to the DUR alert (e.g., \'FA\'=Filled As Is, \'FN\'=Filled with Prescriber Approval, \'FC\'=Filled, Calling Prescriber, \'FD\'=Filled, Directions Clarified). Required for CMS Part D DUR reporting.' ;
    rdfs:domain ind:DurAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:severityLevelCode rdf:type rdf:Property ;
    rdfs:label 'Severity Level Code' ;
    rdfs:comment 'Coded severity level of the DUR alert indicating clinical significance. Typically: 1=Contraindicated/Severe, 2=Major, 3=Moderate, 4=Minor, 5=Informational. Drives pharmacist override requirements and adjudication workflow.' ;
    rdfs:domain ind:DurAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:severityLevelDescription rdf:type rdf:Property ;
    rdfs:label 'Severity Level Description' ;
    rdfs:comment 'Plain-language description of the DUR alert severity level (e.g., \'Contraindicated\', \'Major\', \'Moderate\', \'Minor\', \'Informational\'). Used in pharmacist-facing displays and DUR reporting dashboards.' ;
    rdfs:domain ind:DurAlert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stepTherapyFlag rdf:type rdf:Property ;
    rdfs:label 'Step Therapy Flag' ;
    rdfs:comment 'Indicates whether the DUR alert is related to a step therapy protocol violation, where the member has not tried a required first-line drug before the prescribed drug. Supports step therapy enforcement and CMS Part D reporting.' ;
    rdfs:domain ind:Pharmacy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:accountId rdf:type rdf:Property ;
    rdfs:label 'Account Id' ;
    rdfs:comment 'Foreign key linking to billing.account. Business justification: Dispensing pharmacies receive payment settlements (ingredient costs, dispensing fees) through billing accounts. Health insurance/PBM operations require linking each dispensing pharmacy to its billing ' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Account .

ind:baaId rdf:type rdf:Property ;
    rdfs:label 'Baa Id' ;
    rdfs:comment 'Foreign key linking to compliance.baa. Business justification: BAA management: each dispensing pharmacy must have a Business Associate Agreement for PHI handling; compliance tracks BAAs per pharmacy.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Baa .

ind:ncpdpProviderId rdf:type rdf:Property ;
    rdfs:label 'Ncpdp Provider Id' ;
    rdfs:comment 'The 7-digit NCPDP pharmacy identifier (formerly NABP number) used as the primary pharmacy identifier in PBM claim transactions, formulary lookups, and pharmacy network directories. Sourced from RxClaim or Argus PBM system.' ;
    rdfs:domain ind:DispensingPharmacy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Provider .

ind:networkProviderId rdf:type rdf:Property ;
    rdfs:label 'Network Provider Id' ;
    rdfs:comment 'Foreign key linking to network.network_provider. Business justification: A dispensing pharmacy participating in a provider network has a corresponding network_provider record capturing credentialing status, participation type, and directory listing. Pharmacy credentialing ' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NetworkProvider .

ind:pbmContractId rdf:type rdf:Property ;
    rdfs:label 'Pbm Contract Id' ;
    rdfs:comment 'Foreign key linking to pharmacy.pbm_contract. Business justification: Dispensing pharmacies operate under PBM contracts that govern their reimbursement rates (AWP discount, dispensing fees, MAC list), network participation terms, and performance guarantees. Linking disp' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PbmContract .

ind:tierId rdf:type rdf:Property ;
    rdfs:label 'Tier Id' ;
    rdfs:comment 'Foreign key linking to network.tier. Business justification: Dispensing pharmacies are assigned to network tiers (preferred, standard, specialty) that determine member cost-sharing differentials. The plain attribute network_tier is a denormalized representation' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Tier .

ind:acceptsElectronicPrescriptions rdf:type rdf:Property ;
    rdfs:label 'Accepts Electronic Prescriptions' ;
    rdfs:comment 'Indicates whether the pharmacy is enabled to receive electronic prescriptions (e-prescribing) via NCPDP SCRIPT standard. Required for controlled substance e-prescribing (EPCS) compliance in many states.' ;
    rdfs:domain ind:DispensingPharmacy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:addressLine1 rdf:type rdf:Property ;
    rdfs:label 'Address Line1' ;
    rdfs:comment 'Primary street address of the pharmacy dispensing location. Used for member pharmacy locator, network directory, and regulatory reporting.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressLine2 rdf:type rdf:Property ;
    rdfs:label 'Address Line2' ;
    rdfs:comment 'Secondary address information (suite, unit, floor) for the pharmacy dispensing location.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:awpDiscountPercent rdf:type rdf:Property ;
    rdfs:label 'Awp Discount Percent' ;
    rdfs:comment 'The contracted discount percentage applied to the AWP for brand drug ingredient cost reimbursement. For example, AWP minus 15% means awp_discount_percent = 15.00. Applies when ingredient_cost_basis is \'awp_discount\'. Commercially sensitive contract term.' ;
    rdfs:domain ind:DispensingPharmacy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:chainIndependentFlag rdf:type rdf:Property ;
    rdfs:label 'Chain Independent Flag' ;
    rdfs:comment 'Indicates whether the pharmacy is part of a chain organization (e.g., CVS, Walgreens, Rite Aid) or operates as an independent pharmacy. Affects contract terms, reimbursement rates, and network tier assignment.' ;
    rdfs:domain ind:DispensingPharmacy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chainOrganizationName rdf:type rdf:Property ;
    rdfs:label 'Chain Organization Name' ;
    rdfs:comment 'Name of the parent chain organization if the pharmacy is a chain location (e.g., CVS Health, Walgreens Boots Alliance). Null for independent pharmacies. Used for chain-level contract management and performance reporting.' ;
    rdfs:domain ind:DispensingPharmacy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:city rdf:type rdf:Property ;
    rdfs:label 'City' ;
    rdfs:comment 'City of the pharmacy dispensing location. Used for geographic network analysis, member access reporting, and CMS Part D network adequacy compliance.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coldChainCertified rdf:type rdf:Property ;
    rdfs:label 'Cold Chain Certified' ;
    rdfs:comment 'Indicates whether the pharmacy holds cold chain certification for temperature-sensitive drug storage and shipping (e.g., biologics, insulin, vaccines). Required for specialty and mail-order pharmacies dispensing refrigerated or frozen medications.' ;
    rdfs:domain ind:DispensingPharmacy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contractEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Contract Effective Date' ;
    rdfs:comment 'Date on which the pharmacy\'s network participation contract becomes effective. Used to validate claim eligibility by service date and for contract lifecycle management.' ;
    rdfs:domain ind:DispensingPharmacy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contractTerminationDate rdf:type rdf:Property ;
    rdfs:label 'Contract Termination Date' ;
    rdfs:comment 'Date on which the pharmacy\'s network participation contract ends or was terminated. Null for active open-ended contracts. Used for claim eligibility validation and network adequacy gap analysis.' ;
    rdfs:domain ind:DispensingPharmacy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contractType rdf:type rdf:Property ;
    rdfs:label 'Contract Type' ;
    rdfs:comment 'Indicates whether the pharmacy reimbursement contract is negotiated directly with the health plan (direct) or administered through the PBM intermediary (PBM-administered). Affects financial settlement, audit rights, and MAC list applicability.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispensingStateCode rdf:type rdf:Property ;
    rdfs:label 'Dispensing State Code' ;
    rdfs:comment 'Two-letter USPS state code of the state in which the pharmacy is licensed to dispense. May differ from the physical address state for mail-order pharmacies licensed in multiple states. Used for state-level regulatory compliance and claim adjudication.' ;
    rdfs:domain ind:DispensingPharmacy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:doingBusinessAsName rdf:type rdf:Property ;
    rdfs:label 'Doing Business As Name' ;
    rdfs:comment 'Trade name or DBA name under which the pharmacy operates if different from the legal business name. Used in member-facing directories and communications.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:faxNumber rdf:type rdf:Property ;
    rdfs:label 'Fax Number' ;
    rdfs:comment 'Fax number for the pharmacy dispensing location. Used for prior authorization transmissions, prescription transfers, and clinical communications.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ingredientCostBasis rdf:type rdf:Property ;
    rdfs:label 'Ingredient Cost Basis' ;
    rdfs:comment 'The pricing benchmark used to calculate ingredient cost reimbursement for drug claims. AWP (Average Wholesale Price) discount is most common for brand drugs; MAC (Maximum Allowable Cost) applies to generics; WAC (Wholesale Acquisition Cost) and NADAC (National Average Drug Acquisition Cost) are alternative benchmarks. Sourced from PBM contract terms in RxClaim/Argus.' ;
    rdfs:domain ind:Pharmacy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mailOrderCapable rdf:type rdf:Property ;
    rdfs:label 'Mail Order Capable' ;
    rdfs:comment 'Indicates whether the pharmacy is certified and operationally capable of fulfilling mail-order prescriptions (90-day supply, home delivery). Drives claim routing and member benefit design enforcement.' ;
    rdfs:domain ind:DispensingPharmacy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ncpdpChainCode rdf:type rdf:Property ;
    rdfs:label 'Ncpdp Chain Code' ;
    rdfs:comment 'NCPDP-assigned 4-digit chain code identifying the pharmacy chain organization. Used for chain-level contract application and bulk reimbursement rate assignment in the PBM system.' ;
    rdfs:domain ind:DispensingPharmacy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:networkEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Network Effective Date' ;
    rdfs:comment 'Date on which the pharmacy\'s current network participation status became effective. Distinct from contract_effective_date; captures the most recent network status change date (e.g., reactivation after suspension).' ;
    rdfs:domain ind:DispensingPharmacy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:networkParticipationStatus rdf:type rdf:Property ;
    rdfs:label 'Network Participation Status' ;
    rdfs:comment 'Current status of the pharmacy\'s participation in the PBM network. Drives real-time claim adjudication eligibility checks in RxClaim/Argus. Active pharmacies are eligible to dispense covered drugs; inactive/terminated pharmacies are rejected at point-of-sale.' ;
    rdfs:domain ind:DispensingPharmacy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:networkTerminationDate rdf:type rdf:Property ;
    rdfs:label 'Network Termination Date' ;
    rdfs:comment 'Date on which the pharmacy\'s network participation was or is scheduled to be terminated. Null for currently active network participants. Used for claim eligibility validation and network adequacy gap analysis.' ;
    rdfs:domain ind:DispensingPharmacy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:performanceAuditProvision rdf:type rdf:Property ;
    rdfs:label 'Performance Audit Provision' ;
    rdfs:comment 'Indicates whether the pharmacy contract includes audit provisions allowing the PBM or health plan to conduct on-site or desk audits of dispensing records, pricing, and compliance. Required for CMS Part D sponsor oversight obligations.' ;
    rdfs:domain ind:DispensingPharmacy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pharmacyName rdf:type rdf:Property ;
    rdfs:label 'Pharmacy Name' ;
    rdfs:comment 'Legal business name of the dispensing pharmacy as registered with the state board of pharmacy and NCPDP. Used in member-facing communications, EOB documents, and provider directory.' ;
    rdfs:domain ind:DispensingPharmacy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pharmacyType rdf:type rdf:Property ;
    rdfs:label 'Pharmacy Type' ;
    rdfs:comment 'Classification of the pharmacy by dispensing channel and operational model. Drives claim routing, reimbursement logic, and formulary applicability within the PBM system (RxClaim/Argus). [ENUM-REF-CANDIDATE: retail|mail_order|specialty|long_term_care|compounding — promote to reference product if additional types emerge]' ;
    rdfs:domain ind:DispensingPharmacy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phoneNumber rdf:type rdf:Property ;
    rdfs:label 'Phone Number' ;
    rdfs:comment 'Primary telephone number for the pharmacy dispensing location. Used for member contact, prior authorization coordination, and provider directory.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signatureRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Signature Required Flag' ;
    rdfs:comment 'Indicates whether the pharmacy requires patient or authorized representative signature upon delivery for mail-order or specialty drug shipments. Relevant for controlled substances and high-value specialty medications.' ;
    rdfs:domain ind:DispensingPharmacy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:specialtyAccreditationCode rdf:type rdf:Property ;
    rdfs:label 'Specialty Accreditation Code' ;
    rdfs:comment 'Accreditation body certification held by the pharmacy for specialty drug dispensing. URAC, ACHC, and NABP PCAB are the primary specialty pharmacy accreditation bodies recognized by health plans and PBMs. Required for specialty network participation. [ENUM-REF-CANDIDATE: urac|achc|jcaho|nabp_pcab|none — promote to reference product if multi-accreditation tracking is needed]' ;
    rdfs:domain ind:DispensingPharmacy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stateCode rdf:type rdf:Property ;
    rdfs:label 'State Code' ;
    rdfs:comment 'Two-letter USPS state abbreviation for the pharmacy dispensing location. Used for state-level licensure validation, network adequacy reporting, and regulatory compliance.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:twentyFourHourFlag rdf:type rdf:Property ;
    rdfs:label 'Twenty Four Hour Flag' ;
    rdfs:comment 'Indicates whether the pharmacy operates 24 hours per day, 7 days per week. Used for network adequacy reporting and member access analysis, particularly for CMS Part D access requirements.' ;
    rdfs:domain ind:DispensingPharmacy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:zipCode rdf:type rdf:Property ;
    rdfs:label 'Zip Code' ;
    rdfs:comment 'US ZIP or ZIP+4 postal code for the pharmacy dispensing location. Used for geographic network adequacy analysis, member proximity calculations, and CMS Part D access reporting.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingCycleId rdf:type rdf:Property ;
    rdfs:label 'Billing Cycle Id' ;
    rdfs:comment 'Foreign key linking to billing.cycle. Business justification: PBM rebate reconciliation and settlement are governed by billing cycle schedules. Health insurance operations require linking PBM contracts to the billing cycle that controls rebate settlement frequen' ;
    rdfs:domain ind:PbmContract ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Cycle .

ind:delegationAgreementId rdf:type rdf:Property ;
    rdfs:label 'Delegation Agreement Id' ;
    rdfs:comment 'Foreign key linking to contract.delegation_agreement. Business justification: CMS and NCQA require health plans to maintain formal delegation agreements when PBM functions (formulary management, PA, UM) are delegated. Linking pbm_contract to delegation_agreement supports oversi' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DelegationAgreement .

ind:groupId rdf:type rdf:Property ;
    rdfs:label 'Group Id' ;
    rdfs:comment 'Foreign key linking to employer.group. Business justification: In self-funded and ASO employer arrangements, PBM contracts are negotiated at the employer group level. This link supports PBM contract administration reporting, renewal tracking, and pharmacy benefit' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Group .

ind:amendmentDate rdf:type rdf:Property ;
    rdfs:label 'Amendment Date' ;
    rdfs:comment 'Date of the most recent amendment or addendum executed against this PBM contract. Null if no amendments have been made since original execution. Used to track contract evolution and ensure current terms are applied in adjudication.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:auditFrequency rdf:type rdf:Property ;
    rdfs:label 'Audit Frequency' ;
    rdfs:comment 'Contractually specified frequency at which the health plan may exercise audit rights over the PBM. Relevant only when audit_rights_flag is True. Drives compliance calendar and vendor oversight scheduling.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditRightsFlag rdf:type rdf:Property ;
    rdfs:label 'Audit Rights Flag' ;
    rdfs:comment 'Indicates whether the health plan has contractual audit rights to inspect PBM financial records, rebate calculations, MAC list pricing, and claims adjudication data. True = audit rights granted; False = not included. Critical for compliance and financial oversight.' ;
    rdfs:domain ind:PbmContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:autoRenewalFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Renewal Flag' ;
    rdfs:comment 'Indicates whether the PBM contract automatically renews at the end of the contract term unless notice of termination is provided. True = auto-renews; False = requires affirmative renewal action.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cmsContractNumber rdf:type rdf:Property ;
    rdfs:label 'Cms Contract Number' ;
    rdfs:comment 'CMS (Centers for Medicare and Medicaid Services) contract number associated with the Medicare Part D plan under which this PBM contract operates (e.g., H1234 for MA-PD, S1234 for PDP). Required for CMS Part D reporting and RAPS/EDPS submissions. Null for non-Medicare LOBs.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractName rdf:type rdf:Property ;
    rdfs:label 'Contract Name' ;
    rdfs:comment 'Descriptive name of the PBM contract (e.g., \'Express Scripts ASO Agreement FY2024\'). Used for display in reporting dashboards and contract management workflows.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractNumber rdf:type rdf:Property ;
    rdfs:label 'Contract Number' ;
    rdfs:comment 'Externally-known, human-readable contract reference number assigned by the health plan or PBM vendor at execution. Used for correspondence, audits, and regulatory filings. Maps to the contract identifier in RxClaim or Argus PBM system.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractOwnerName rdf:type rdf:Property ;
    rdfs:label 'Contract Owner Name' ;
    rdfs:comment 'Name of the health plan employee or department responsible for managing this PBM contract relationship. Used for escalation routing, audit coordination, and vendor governance.' ;
    rdfs:domain ind:PbmContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractStatus rdf:type rdf:Property ;
    rdfs:label 'Contract Status' ;
    rdfs:comment 'Current lifecycle state of the PBM contract. Draft indicates the contract is under negotiation; active indicates it is in force; suspended indicates temporarily halted; terminated indicates early cancellation; expired indicates natural end-of-term; pending_renewal indicates renewal is in progress.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractVersion rdf:type rdf:Property ;
    rdfs:label 'Contract Version' ;
    rdfs:comment 'Version identifier for the PBM contract document, incremented with each amendment or renewal (e.g., \'1.0\', \'2.1\', \'Amendment_3\'). Supports contract lifecycle management and audit trail for regulatory examinations.' ;
    rdfs:domain ind:PbmContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:durProgramFlag rdf:type rdf:Property ;
    rdfs:label 'Dur Program Flag' ;
    rdfs:comment 'Indicates whether Drug Utilization Review (DUR) — including prospective, concurrent, and retrospective DUR — is included as a service under this PBM contract. True = DUR services included; False = not included.' ;
    rdfs:domain ind:PbmContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:genericDispensingRateGuarantee rdf:type rdf:Property ;
    rdfs:label 'Generic Dispensing Rate Guarantee' ;
    rdfs:comment 'Contractually guaranteed minimum generic dispensing rate (GDR) as a percentage of total prescription claims. If the PBM fails to achieve this rate, financial penalties or credits apply. Key cost-management metric in PBM contracts.' ;
    rdfs:domain ind:PbmContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:governingStateCode rdf:type rdf:Property ;
    rdfs:label 'Governing State Code' ;
    rdfs:comment 'Two-letter US state code of the state whose laws govern this PBM contract for dispute resolution and regulatory compliance purposes. Relevant for state DOI oversight, MAC transparency laws, and PBM regulation.' ;
    rdfs:domain ind:PbmContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lobScope rdf:type rdf:Property ;
    rdfs:label 'Lob Scope' ;
    rdfs:comment 'Line of Business (LOB) covered under this PBM contract. Determines which member populations and benefit programs are governed by this agreement. A single contract may cover one or multiple LOBs. [ENUM-REF-CANDIDATE: commercial|medicare_part_d|medicaid|exchange|all — promote to reference product for multi-LOB support]' ;
    rdfs:domain ind:PbmContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:macListReference rdf:type rdf:Property ;
    rdfs:label 'Mac List Reference' ;
    rdfs:comment 'Identifier or name of the MAC (Maximum Allowable Cost) list applied under this PBM contract for generic and multi-source drug reimbursement. MAC lists cap reimbursement for generics below AWP. References the specific MAC list version maintained by the PBM.' ;
    rdfs:domain ind:PbmContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mailOrderFlag rdf:type rdf:Property ;
    rdfs:label 'Mail Order Flag' ;
    rdfs:comment 'Indicates whether mail-order pharmacy dispensing services are included in the scope of this PBM contract. True = mail order included; False = retail-only or carved out.' ;
    rdfs:domain ind:PbmContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mailOrderPenetrationGuarantee rdf:type rdf:Property ;
    rdfs:label 'Mail Order Penetration Guarantee' ;
    rdfs:comment 'Contractually guaranteed minimum mail-order pharmacy utilization rate as a percentage of eligible maintenance drug claims. Drives cost savings through mail-order channel incentives.' ;
    rdfs:domain ind:PbmContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:performanceGuaranteeFlag rdf:type rdf:Property ;
    rdfs:label 'Performance Guarantee Flag' ;
    rdfs:comment 'Indicates whether the PBM contract includes financial performance guarantees (e.g., generic dispensing rate, mail-order penetration, member satisfaction scores). True = performance guarantees included; False = not included.' ;
    rdfs:domain ind:PbmContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priorAuthFlag rdf:type rdf:Property ;
    rdfs:label 'Prior Auth Flag' ;
    rdfs:comment 'Indicates whether prior authorization (PA) requirements for specialty and non-formulary drugs are administered by the PBM under this contract. True = PBM manages PA; False = health plan manages PA internally.' ;
    rdfs:domain ind:PbmContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rebateGuaranteePmpm rdf:type rdf:Property ;
    rdfs:label 'Rebate Guarantee Pmpm' ;
    rdfs:comment 'Contractually guaranteed minimum rebate amount expressed as Per Member Per Month (PMPM) in USD that the PBM must remit to the health plan. A key financial performance guarantee in PBM contracts. Used for actuarial reserving and financial reconciliation.' ;
    rdfs:domain ind:PbmContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rebatePassThroughPct rdf:type rdf:Property ;
    rdfs:label 'Rebate Pass Through Pct' ;
    rdfs:comment 'Percentage of manufacturer drug rebates that the PBM is contractually obligated to pass through to the health plan (e.g., 100% pass-through vs. spread-based retention). Critical for MLR (Medical Loss Ratio) calculations and CMS Part D compliance.' ;
    rdfs:domain ind:PbmContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rebateReconciliationLagDays rdf:type rdf:Property ;
    rdfs:label 'Rebate Reconciliation Lag Days' ;
    rdfs:comment 'Number of calendar days after the close of a settlement period within which the PBM must provide rebate invoices and supporting data to the health plan. Used for financial close scheduling and IBNR reserve calculations.' ;
    rdfs:domain ind:PbmContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rebateSettlementFrequency rdf:type rdf:Property ;
    rdfs:label 'Rebate Settlement Frequency' ;
    rdfs:comment 'Contractually specified frequency at which the PBM remits drug manufacturer rebates to the health plan. Drives cash flow forecasting, accounts receivable management, and actuarial IBNR (Incurred But Not Reported) rebate estimates.' ;
    rdfs:domain ind:PbmContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordCreatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Record Created Timestamp' ;
    rdfs:comment 'Timestamp when this PBM contract record was first created in the data platform. Used for audit trail, data lineage, and compliance with HIPAA record retention requirements. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:recordUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Record Updated Timestamp' ;
    rdfs:comment 'Timestamp when this PBM contract record was most recently modified in the data platform. Supports change detection, SCD (Slowly Changing Dimension) processing, and audit trail requirements. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:renewalNoticeDays rdf:type rdf:Property ;
    rdfs:label 'Renewal Notice Days' ;
    rdfs:comment 'Number of calendar days prior to contract termination_date by which either party must provide written notice of intent not to renew. Operationally critical for contract management and vendor transitions.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:specialtyPharmacyFlag rdf:type rdf:Property ;
    rdfs:label 'Specialty Pharmacy Flag' ;
    rdfs:comment 'Indicates whether specialty pharmacy benefit management (high-cost biologics, specialty injectables) is within the scope of this PBM contract. True = specialty pharmacy included; False = carved out or not applicable.' ;
    rdfs:domain ind:PbmContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:facilityId rdf:type rdf:Property ;
    rdfs:label 'Facility Id' ;
    rdfs:comment 'Foreign key linking to provider.facility. Business justification: Facility contracts (hospital, outpatient center) are a distinct contracting process from professional provider contracts. Claims adjudication, network adequacy reporting, and facility billing all requ' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Facility .

ind:groupPracticeId rdf:type rdf:Property ;
    rdfs:label 'Group Practice Id' ;
    rdfs:comment 'Foreign key linking to provider.group_practice. Business justification: Group practices negotiate contracts as legal entities covering all member providers. Provider contracting operations require linking a contract to the group practice to determine which providers are c' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GroupPractice .

ind:amendmentNumber rdf:type rdf:Property ;
    rdfs:label 'Amendment Number' ;
    rdfs:comment 'Identifier for the most recent amendment to this contract. Null for original, unamended contracts. Tracks the amendment sequence for audit and compliance purposes. Sourced from Cactus/ProviderSource.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:asoFlag rdf:type rdf:Property ;
    rdfs:label 'Aso Flag' ;
    rdfs:comment 'Indicates whether this contract operates under an Administrative Services Only (ASO) arrangement where the employer self-funds claims and the health plan provides administrative services only. True = ASO arrangement.' ;
    rdfs:domain ind:ProviderContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:capitationRatePmpm rdf:type rdf:Property ;
    rdfs:label 'Capitation Rate Pmpm' ;
    rdfs:comment 'Fixed monthly payment amount per enrolled member (Per Member Per Month - PMPM) paid to the provider under capitation contracts. Applicable only when payment_methodology = capitation. Expressed in USD.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:carveOutIndicator rdf:type rdf:Property ;
    rdfs:label 'Carve Out Indicator' ;
    rdfs:comment 'Indicates whether specific services or benefit categories are carved out of this contract and managed under a separate arrangement (e.g., behavioral health carve-out, pharmacy carve-out). True = carve-outs exist.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contractTier rdf:type rdf:Property ;
    rdfs:label 'Contract Tier' ;
    rdfs:comment 'Tiering classification assigned to this contract, reflecting the provider\'s preferred status and associated member cost-sharing levels. Tier 1/preferred providers typically have lower member cost-sharing. Used in benefit design and member-facing provider directory.' ;
    rdfs:domain ind:ProviderContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cptRangeEnd rdf:type rdf:Property ;
    rdfs:label 'Cpt Range End' ;
    rdfs:comment 'Ending CPT or HCPCS procedure code defining the upper bound of the service scope covered under this contract. Used with cpt_range_start to define the range of covered procedures.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cptRangeStart rdf:type rdf:Property ;
    rdfs:label 'Cpt Range Start' ;
    rdfs:comment 'Starting CPT or HCPCS procedure code defining the lower bound of the service scope covered under this contract. Used with cpt_range_end to define the range of covered procedures. Sourced from AMA CPT code set.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:credentialingRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Credentialing Required Flag' ;
    rdfs:comment 'Indicates whether the provider must maintain active credentialing status as a condition of this contract. True = credentialing is a contractual requirement. Linked to NCQA credentialing standards.' ;
    rdfs:domain ind:ProviderContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:delegationFlag rdf:type rdf:Property ;
    rdfs:label 'Delegation Flag' ;
    rdfs:comment 'Indicates whether credentialing, utilization management, or other health plan functions have been delegated to the provider organization under this contract. True = delegation arrangement exists. Requires NCQA delegation oversight.' ;
    rdfs:domain ind:ProviderContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:drgRangeEnd rdf:type rdf:Property ;
    rdfs:label 'Drg Range End' ;
    rdfs:comment 'Ending Diagnosis Related Group (DRG) code defining the upper bound of inpatient service scope covered under this contract. Used with drg_range_start to define the range of covered DRGs.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drgRangeStart rdf:type rdf:Property ;
    rdfs:label 'Drg Range Start' ;
    rdfs:comment 'Starting Diagnosis Related Group (DRG) code defining the lower bound of inpatient service scope covered under this contract. Applicable for hospital contracts with DRG-based payment methodology.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:executionDate rdf:type rdf:Property ;
    rdfs:label 'Execution Date' ;
    rdfs:comment 'Date on which all parties signed and the contract was fully executed. May differ from effective_date for retroactive or prospective contracts. Sourced from Cactus/ProviderSource contract module.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lobApplicability rdf:type rdf:Property ;
    rdfs:label 'Lob Applicability' ;
    rdfs:comment 'Line of Business (LOB) to which this contract applies. Determines which member populations and benefit plans are governed by this contract\'s reimbursement terms. Values: commercial, medicare_advantage, medicaid, marketplace, cobra, tricare, all. [ENUM-REF-CANDIDATE: commercial|medicare_advantage|medicaid|marketplace|cobra|tricare|all — promote to reference product]' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:npi rdf:type rdf:Property ;
    rdfs:label 'Npi' ;
    rdfs:comment 'National Provider Identifier (NPI) of the contracting provider as assigned by CMS NPPES. 10-digit unique identifier used in EDI transactions (837/835) and claims adjudication to identify the contracted provider.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentMethodology rdf:type rdf:Property ;
    rdfs:label 'Payment Methodology' ;
    rdfs:comment 'Specific reimbursement calculation methodology governing how the health plan pays the provider under this contract. Distinct from contract_type in that it specifies the payment calculation approach. Examples: fee_for_service (FFS), capitation (PMPM), per_diem, case_rate, DRG-based, bundled, Reference Based Pricing (RBP), global_budget, salary. [ENUM-REF-CANDIDATE: fee_for_service|capitation|per_diem|case_rate|drg_based|bundled|rbp|global_budget|salary — promote to reference product]' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:providerType rdf:type rdf:Property ;
    rdfs:label 'Provider Type' ;
    rdfs:comment 'Classification of the contracted provider entity type. Drives applicable reimbursement rules, credentialing requirements, and service scope definitions. [ENUM-REF-CANDIDATE: physician|hospital|clinic|ancillary|dme_supplier|behavioral_health|skilled_nursing|home_health|laboratory|radiology — promote to reference product]' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityIncentiveFlag rdf:type rdf:Property ;
    rdfs:label 'Quality Incentive Flag' ;
    rdfs:comment 'Indicates whether this contract includes quality-based incentive payments tied to HEDIS, STAR ratings, CAHPS, or other quality performance measures. True = quality incentive provisions exist in the contract.' ;
    rdfs:domain ind:ProviderContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rafApplicableFlag rdf:type rdf:Property ;
    rdfs:label 'Raf Applicable Flag' ;
    rdfs:comment 'Indicates whether Risk Adjustment Factor (RAF) / Hierarchical Condition Category (HCC) coding obligations apply to the provider under this contract. True = provider has contractual HCC coding and encounter data submission requirements.' ;
    rdfs:domain ind:ProviderContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:revenueCodeRangeEnd rdf:type rdf:Property ;
    rdfs:label 'Revenue Code Range End' ;
    rdfs:comment 'Ending UB-04 revenue code defining the upper bound of facility service categories covered under this contract. Used with revenue_code_range_start to define the range of covered revenue codes.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueCodeRangeStart rdf:type rdf:Property ;
    rdfs:label 'Revenue Code Range Start' ;
    rdfs:comment 'Starting UB-04 revenue code defining the lower bound of facility service categories covered under this contract. Used for hospital and facility contracts to define covered service lines.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskSharingModel rdf:type rdf:Property ;
    rdfs:label 'Risk Sharing Model' ;
    rdfs:comment 'Specifies the financial risk-sharing arrangement between the health plan and provider under VBC or ACO contracts. Determines how savings and losses are allocated. Values: none, shared_savings, shared_risk, full_risk, upside_only, downside_only.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceExclusionNotes rdf:type rdf:Property ;
    rdfs:label 'Service Exclusion Notes' ;
    rdfs:comment 'Free-text description of specific services, procedures, or conditions explicitly excluded from the scope of this contract. Supplements the CPT/DRG/revenue code ranges with narrative exclusion details.' ;
    rdfs:domain ind:ProviderContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemContractReference rdf:type rdf:Property ;
    rdfs:label 'Source System Contract Reference' ;
    rdfs:comment 'Native contract identifier from the originating operational system (Cactus, ProviderSource, Facets, or QNXT). Enables traceability and reconciliation back to the system of record.' ;
    rdfs:domain ind:ProviderContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxIdentificationNumber rdf:type rdf:Property ;
    rdfs:label 'Tax Identification Number' ;
    rdfs:comment 'Federal Tax Identification Number (TIN) or Employer Identification Number (EIN) of the contracting provider entity. Used for 1099 reporting, payment processing, and IRS compliance. 9-digit numeric value.' ;
    rdfs:domain ind:ProviderContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:templateCode rdf:type rdf:Property ;
    rdfs:label 'Template Code' ;
    rdfs:comment 'Reference to the standard contract template used as the basis for this agreement. Enables tracking of which template version governs the contract terms and supports template-level compliance audits.' ;
    rdfs:domain ind:ProviderContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:terminationNoticeDays rdf:type rdf:Property ;
    rdfs:label 'Termination Notice Days' ;
    rdfs:comment 'Number of days advance written notice required by either party to terminate the contract for convenience (without cause). Distinct from renewal_notice_days which applies at contract expiry.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tpaFlag rdf:type rdf:Property ;
    rdfs:label 'Tpa Flag' ;
    rdfs:comment 'Indicates whether this contract is administered by a Third Party Administrator (TPA) on behalf of the health plan. True = TPA-administered; False = directly administered by the health plan. Relevant for ASO arrangements.' ;
    rdfs:domain ind:ProviderContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:vbcFlag rdf:type rdf:Property ;
    rdfs:label 'Vbc Flag' ;
    rdfs:comment 'Indicates whether this contract includes Value-Based Care (VBC) components such as quality bonuses, shared savings, or risk-sharing arrangements beyond standard fee-for-service reimbursement.' ;
    rdfs:domain ind:ProviderContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:partyId rdf:type rdf:Property ;
    rdfs:label 'Party Id' ;
    rdfs:comment 'Unique surrogate identifier for each party record in the provider contract domain. Serves as the primary key for all contractual party references across the health plan enterprise.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:acoIndicator rdf:type rdf:Property ;
    rdfs:label 'Aco Indicator' ;
    rdfs:comment 'Indicates whether this party is an Accountable Care Organization (ACO) participating in a value-based care (VBC) arrangement. Triggers ACO-specific contract terms, shared savings calculations, and CMS reporting requirements.' ;
    rdfs:domain ind:Party ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:capitationEligibleIndicator rdf:type rdf:Property ;
    rdfs:label 'Capitation Eligible Indicator' ;
    rdfs:comment 'Indicates whether this party is eligible to receive capitation payments (Per Member Per Month - PMPM) under the contract. Drives capitation payment processing and actuarial PMPM rate application.' ;
    rdfs:domain ind:Party ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contractPartyNumber rdf:type rdf:Property ;
    rdfs:label 'Contract Party Number' ;
    rdfs:comment 'Externally-known alphanumeric identifier assigned to this party within the contract management system (e.g., Cactus or ProviderSource provider contract number). Used for cross-system reconciliation, EDI transactions, and provider directory publication.' ;
    rdfs:domain ind:Party ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:credentialingDate rdf:type rdf:Property ;
    rdfs:label 'Credentialing Date' ;
    rdfs:comment 'Date on which the party was most recently credentialed or re-credentialed by the health plan. NCQA requires re-credentialing every 36 months. Used to trigger re-credentialing workflows and network compliance reporting.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:credentialingStatus rdf:type rdf:Property ;
    rdfs:label 'Credentialing Status' ;
    rdfs:comment 'Current credentialing status of the party as maintained in the Provider Management System (Cactus/ProviderSource). Determines whether the party is eligible to provide services to plan members. Credentialing must be current for claims to be adjudicated as in-network.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:delegationIndicator rdf:type rdf:Property ;
    rdfs:label 'Delegation Indicator' ;
    rdfs:comment 'Indicates whether this party is a delegated entity authorized to perform functions on behalf of the health plan (e.g., credentialing, utilization management, claims processing). Triggers delegation oversight and audit requirements per NCQA and state DOI standards.' ;
    rdfs:domain ind:Party ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:delegationScope rdf:type rdf:Property ;
    rdfs:label 'Delegation Scope' ;
    rdfs:comment 'Specifies the functional scope of delegation authority granted to this party. Applicable only when delegation_indicator is true. Defines which health plan functions the delegated entity is authorized to perform on behalf of the payer.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalEntityName rdf:type rdf:Property ;
    rdfs:label 'Legal Entity Name' ;
    rdfs:comment 'Full legal name of the contracting party as registered with state or federal authorities. Used for contract execution, credentialing, and regulatory reporting. May be an individual provider name, group practice name, IPA, ACO, or hospital system name.' ;
    rdfs:domain ind:Party ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenseExpirationDate rdf:type rdf:Property ;
    rdfs:label 'License Expiration Date' ;
    rdfs:comment 'Date on which the party\'s primary state professional or business license expires. Triggers credentialing re-verification workflows and may result in contract suspension if not renewed. Critical for NCQA and URAC credentialing compliance.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:licenseState rdf:type rdf:Property ;
    rdfs:label 'License State' ;
    rdfs:comment 'Two-letter USPS state abbreviation where the party holds its primary professional or business license. Used for network adequacy reporting, credentialing, and state-specific regulatory compliance.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:malpracticeCoverageIndicator rdf:type rdf:Property ;
    rdfs:label 'Malpractice Coverage Indicator' ;
    rdfs:comment 'Indicates whether the party maintains active professional liability (malpractice) insurance coverage as required by the contract. Failure to maintain coverage may trigger contract suspension or termination per NCQA credentialing standards.' ;
    rdfs:domain ind:Party ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:malpracticeExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Malpractice Expiration Date' ;
    rdfs:comment 'Date on which the party\'s professional liability (malpractice) insurance policy expires. Triggers credentialing re-verification and contract compliance monitoring workflows.' ;
    rdfs:domain ind:Party ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:networkParticipationType rdf:type rdf:Property ;
    rdfs:label 'Network Participation Type' ;
    rdfs:comment 'Indicates whether the party is a participating (PAR) in-network provider, a non-participating (non-PAR) provider, or an out-of-network provider. Drives member cost-sharing calculations, claims adjudication rules, and EOB generation.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:npiType rdf:type rdf:Property ;
    rdfs:label 'Npi Type' ;
    rdfs:comment 'Indicates whether the NPI is Type 1 (individual/solo practitioner) or Type 2 (organizational entity such as group practice, hospital, or IPA). Determines credentialing requirements and contract structure.' ;
    rdfs:domain ind:Party ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oigExclusionIndicator rdf:type rdf:Property ;
    rdfs:label 'Oig Exclusion Indicator' ;
    rdfs:comment 'Indicates whether the party appears on the OIG List of Excluded Individuals/Entities (LEIE). Excluded parties are prohibited from participating in Medicare, Medicaid, and other federal healthcare programs. Checked monthly per CMS compliance requirements.' ;
    rdfs:domain ind:Party ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:partyRole rdf:type rdf:Property ;
    rdfs:label 'Party Role' ;
    rdfs:comment 'Functional role of this party within the contract relationship. Identifies whether the party is the health plan (payer), a contracting provider, a delegated entity, an Independent Practice Association (IPA), an Accountable Care Organization (ACO), a hospital system, or a group practice. [ENUM-REF-CANDIDATE: payer|provider|delegated_entity|ipa|aco|hospital_system|group_practice — promote to reference product]' ;
    rdfs:domain ind:Party ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partyStatus rdf:type rdf:Property ;
    rdfs:label 'Party Status' ;
    rdfs:comment 'Current lifecycle status of the party within the contract. Indicates whether the party is actively bound by the contract, pending execution, suspended, terminated, or inactive. Drives eligibility verification and claims adjudication routing.' ;
    rdfs:domain ind:Party ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partyType rdf:type rdf:Property ;
    rdfs:label 'Party Type' ;
    rdfs:comment 'Classifies the party as an individual (natural person, e.g., solo practitioner with individual NPI) or an organization (legal entity, e.g., group practice, hospital, IPA, ACO). Drives NPI type assignment and credentialing workflow.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primarySpecialtyCode rdf:type rdf:Property ;
    rdfs:label 'Primary Specialty Code' ;
    rdfs:comment 'NUCC Health Care Provider Taxonomy Code representing the party\'s primary clinical specialty. Used for network adequacy analysis, claims routing, prior authorization rules, and provider directory classification.' ;
    rdfs:domain ind:Party ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rafApplicableIndicator rdf:type rdf:Property ;
    rdfs:label 'Raf Applicable Indicator' ;
    rdfs:comment 'Indicates whether Risk Adjustment Factor (RAF) scoring applies to this party\'s contract arrangement. Relevant for Medicare Advantage and ACA marketplace contracts where Hierarchical Condition Category (HCC) risk scores drive capitation payments.' ;
    rdfs:domain ind:Party ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recredentialingDueDate rdf:type rdf:Property ;
    rdfs:label 'Recredentialing Due Date' ;
    rdfs:comment 'Date by which the party must complete re-credentialing to maintain active network participation. Calculated as 36 months from the credentialing_date per NCQA standards. Drives automated re-credentialing workflow initiation.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sanctionIndicator rdf:type rdf:Property ;
    rdfs:label 'Sanction Indicator' ;
    rdfs:comment 'Indicates whether the party has an active sanction, exclusion, or adverse action recorded by OIG, SAM, or state licensing boards. A true value triggers contract suspension review and claims payment hold per CMS and HIPAA compliance requirements.' ;
    rdfs:domain ind:Party ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:serviceAreaState rdf:type rdf:Property ;
    rdfs:label 'Service Area State' ;
    rdfs:comment 'Two-letter USPS state abbreviation representing the primary state in which this party provides services under the contract. Used for network adequacy reporting, state regulatory compliance, and geographic claims routing.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceAreaZipCode rdf:type rdf:Property ;
    rdfs:label 'Service Area Zip Code' ;
    rdfs:comment 'Primary ZIP code of the party\'s principal service location. Used for network adequacy geo-mapping, member-to-provider distance calculations, and CMS network adequacy submissions.' ;
    rdfs:domain ind:Party ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signatoryName rdf:type rdf:Property ;
    rdfs:label 'Signatory Name' ;
    rdfs:comment 'Full name of the authorized individual who signed or has authority to sign the contract on behalf of this party. Required for contract execution validation and legal enforceability. Typically the CEO, CMO, or designated contracting officer.' ;
    rdfs:domain ind:Party ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signatoryTitle rdf:type rdf:Property ;
    rdfs:label 'Signatory Title' ;
    rdfs:comment 'Official title or position of the authorized signatory (e.g., Chief Executive Officer, Medical Director, Contracting Officer). Validates the authority level of the individual executing the contract on behalf of the party.' ;
    rdfs:domain ind:Party ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemPartyReference rdf:type rdf:Property ;
    rdfs:label 'Source System Party Reference' ;
    rdfs:comment 'The native identifier of this party record in the originating operational system (e.g., Cactus provider ID, ProviderSource contract party key). Enables cross-system reconciliation and traceability from the Silver Layer back to the system of record.' ;
    rdfs:domain ind:Party ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stateLicenseNumber rdf:type rdf:Property ;
    rdfs:label 'State License Number' ;
    rdfs:comment 'State-issued professional or business license number for the contracting party. Required for credentialing verification and network participation. For individual providers, this is the state medical license; for organizations, the state business license or certificate of authority.' ;
    rdfs:domain ind:Party ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tin rdf:type rdf:Property ;
    rdfs:label 'Tin' ;
    rdfs:comment 'Federal Tax Identification Number (EIN or SSN) used for payment processing, 1099 reporting, and IRS compliance. Critical for remittance and premium payment routing. Stored as 9-digit numeric string without hyphens.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vbcArrangementType rdf:type rdf:Property ;
    rdfs:label 'Vbc Arrangement Type' ;
    rdfs:comment 'Specifies the payment methodology or value-based care arrangement type applicable to this party under the contract. Drives reimbursement calculation logic, risk-sharing model application, and financial reporting. [ENUM-REF-CANDIDATE: fee_for_service|capitation|bundled_payment|shared_savings|global_risk — promote to reference product]' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:termId rdf:type rdf:Property ;
    rdfs:label 'Term Id' ;
    rdfs:comment 'Unique surrogate identifier for a contract term record in the provider contract management system (Facets/QNXT or Provider Management System). Serves as the primary key for the term entity.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Term .

ind:amendmentId rdf:type rdf:Property ;
    rdfs:label 'Amendment Id' ;
    rdfs:comment 'Reference to the contract amendment that introduced or modified this term, if applicable. Null if the term originates from the base contract rather than an amendment.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Amendment .

ind:auditRightsPeriodYears rdf:type rdf:Property ;
    rdfs:label 'Audit Rights Period Years' ;
    rdfs:comment 'The number of years the health plan retains the right to audit provider records under this audit rights term. Typically 7 years per HIPAA and CMS requirements. Applicable when term_type is \'audit_rights\'.' ;
    rdfs:domain ind:Term ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:autoRenew rdf:type rdf:Property ;
    rdfs:label 'Auto Renew' ;
    rdfs:comment 'Indicates whether this term automatically renews upon expiration without requiring renegotiation (True). Supports contract lifecycle management and renewal notification workflows.' ;
    rdfs:domain ind:Term ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:capitationRate rdf:type rdf:Property ;
    rdfs:label 'Capitation Rate' ;
    rdfs:comment 'The Per Member Per Month (PMPM) capitation rate defined by this term when payment_methodology is capitation. Represents the fixed monthly payment per enrolled member to the provider regardless of services rendered. Classified confidential as proprietary pricing.' ;
    rdfs:domain ind:Term ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:complianceCheckpointDate rdf:type rdf:Property ;
    rdfs:label 'Compliance Checkpoint Date' ;
    rdfs:comment 'The scheduled date for the next compliance review or audit checkpoint associated with this term. Used by the compliance team to track regulatory obligations, CMS audit readiness, and DOI examination preparation.' ;
    rdfs:domain ind:Term ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:disputeResolutionMethod rdf:type rdf:Property ;
    rdfs:label 'Dispute Resolution Method' ;
    rdfs:comment 'The contractually agreed method for resolving disputes arising under this term: Arbitration, Mediation, Litigation, or Internal Review. Applicable for hold-harmless, indemnification, and audit rights terms.' ;
    rdfs:domain ind:Term ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drgGrouperVersion rdf:type rdf:Property ;
    rdfs:label 'Drg Grouper Version' ;
    rdfs:comment 'The DRG grouper version (e.g., \'MS-DRG v41.0\', \'APR-DRG v39\') applicable to this term when payment_methodology is \'drg_based\'. Ensures adjudication uses the correct DRG weight tables for inpatient reimbursement.' ;
    rdfs:domain ind:Term ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:governingState rdf:type rdf:Property ;
    rdfs:label 'Governing State' ;
    rdfs:comment 'The two-letter US state code whose laws govern this contract term. Determines applicable state DOI regulations, insurance code requirements, and state-specific provider contract mandates.' ;
    rdfs:domain ind:Term ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hipaaBaaRequired rdf:type rdf:Property ;
    rdfs:label 'Hipaa Baa Required' ;
    rdfs:comment 'Indicates whether this term constitutes or requires a HIPAA Business Associate Agreement (BAA) (True). Triggers compliance tracking and ensures Protected Health Information (PHI) handling obligations are documented per HIPAA 45 CFR Part 164.' ;
    rdfs:domain ind:Term ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:icdVersion rdf:type rdf:Property ;
    rdfs:label 'Icd Version' ;
    rdfs:comment 'Specifies the ICD diagnosis coding version applicable to this term when the term references diagnosis-based reimbursement rules or Hierarchical Condition Category (HCC) risk adjustment provisions.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isAdjudicationRule rdf:type rdf:Property ;
    rdfs:label 'Is Adjudication Rule' ;
    rdfs:comment 'Indicates whether this term directly drives claims adjudication logic in Facets/QNXT (True). When True, the term\'s reimbursement_policy_subtype, cpt_range_start/end, and reduction_percentage are loaded into the adjudication engine.' ;
    rdfs:domain ind:Term ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isNegotiable rdf:type rdf:Property ;
    rdfs:label 'Is Negotiable' ;
    rdfs:comment 'Indicates whether this contract term is open to negotiation (True) or is standard non-negotiable boilerplate language (False). Supports contract negotiation workflow and template management.' ;
    rdfs:domain ind:Term ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isStandardBoilerplate rdf:type rdf:Property ;
    rdfs:label 'Is Standard Boilerplate' ;
    rdfs:comment 'Indicates whether this term is sourced from the organization\'s standard contract template library (True) or is a custom-negotiated term specific to this contract (False). Supports template governance and deviation tracking.' ;
    rdfs:domain ind:Term ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:macPricingBasis rdf:type rdf:Property ;
    rdfs:label 'Mac Pricing Basis' ;
    rdfs:comment 'The drug pricing benchmark used for pharmacy reimbursement terms: Average Wholesale Price (AWP), Wholesale Acquisition Cost (WAC), Maximum Allowable Cost (MAC), National Average Drug Acquisition Cost (NADAC), or a custom contracted rate. Applicable for terms covering pharmacy benefits.' ;
    rdfs:domain ind:Term ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:posCode rdf:type rdf:Property ;
    rdfs:label 'Pos Code' ;
    rdfs:comment 'The CMS Place of Service (POS) code to which this term\'s reimbursement differential applies, when reimbursement_policy_subtype is \'pos_differential\'. Two-digit code per CMS POS code set (e.g., \'11\' for Office, \'21\' for Inpatient Hospital).' ;
    rdfs:domain ind:Term ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityMetricThreshold rdf:type rdf:Property ;
    rdfs:label 'Quality Metric Threshold' ;
    rdfs:comment 'The minimum quality performance threshold (expressed as a percentage or score) that the provider must achieve to qualify for incentive payments or avoid penalties under quality incentive terms. Linked to HEDIS or STAR measures.' ;
    rdfs:domain ind:Term ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reductionPercentage rdf:type rdf:Property ;
    rdfs:label 'Reduction Percentage' ;
    rdfs:comment 'The percentage reduction applied to the allowed amount under this reimbursement rule term (e.g., 50.00 for a 50% reduction on secondary procedures under multiple procedure reduction policy). Applicable when reimbursement_policy_subtype is set. Classified confidential as it represents proprietary pricing.' ;
    rdfs:domain ind:Term ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reimbursementPolicySubtype rdf:type rdf:Property ;
    rdfs:label 'Reimbursement Policy Subtype' ;
    rdfs:comment 'Granular sub-classification of the reimbursement rule when term_type is \'reimbursement_rule\'. Specifies the specific adjudication policy: Multiple Procedure Reduction, Bilateral Procedure, Assistant Surgeon, Global Surgery, Unbundling Rules, Place-of-Service (POS) Differential, or Modifier Impact. Directly maps to adjudication logic in Facets/QNXT. [ENUM-REF-CANDIDATE: multiple_procedure_reduction|bilateral_procedure|assistant_surgeon|global_surgery|unbundling|pos_differential|modifier_impact — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Term ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemTermRef rdf:type rdf:Property ;
    rdfs:label 'Source System Term Ref' ;
    rdfs:comment 'The native identifier of this term record in the originating operational system (e.g., Cactus contract clause ID, QNXT reimbursement rule ID, or ProviderSource term reference). Supports data lineage and reconciliation with source systems.' ;
    rdfs:domain ind:Term ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:summary rdf:type rdf:Property ;
    rdfs:label 'Summary' ;
    rdfs:comment 'Plain-language operational summary of the term\'s intent and impact, authored by the contracting team. Used for training, audits, and quick reference without reading full legal text.' ;
    rdfs:domain ind:Term ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:termNumber rdf:type rdf:Property ;
    rdfs:label 'Term Number' ;
    rdfs:comment 'Human-readable external identifier for the term, typically formatted as a section or clause reference (e.g., \'TERM-2024-0042\' or \'Section 4.2.1\'). Used in contract documents and correspondence.' ;
    rdfs:domain ind:Term ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:termStatus rdf:type rdf:Property ;
    rdfs:label 'Term Status' ;
    rdfs:comment 'Current lifecycle state of the contract term. \'active\' indicates the term is currently in force; \'superseded\' indicates it has been replaced by an amendment; \'expired\' indicates the effective period has lapsed.' ;
    rdfs:domain ind:Term ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:termText rdf:type rdf:Property ;
    rdfs:label 'Term Text' ;
    rdfs:comment 'Full verbatim legal text of the contract term as negotiated and executed. Contains the binding contractual language. Classified confidential as it represents proprietary reimbursement and legal obligations.' ;
    rdfs:domain ind:Term ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:termType rdf:type rdf:Property ;
    rdfs:label 'Term Type' ;
    rdfs:comment 'Categorical classification of the contract term defining its legal or operational purpose. Drives downstream adjudication logic and compliance tracking. [ENUM-REF-CANDIDATE: reimbursement_rule|payment_methodology|exclusivity|termination_clause|audit_rights|hold_harmless|indemnification|confidentiality|hipaa_baa|quality_incentive — promote to reference product]' ;
    rdfs:domain ind:Term ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminationCauseType rdf:type rdf:Property ;
    rdfs:label 'Termination Cause Type' ;
    rdfs:comment 'Specifies the basis under which termination is permitted by this term: For Cause (material breach, fraud, license revocation), Without Cause (convenience), Mutual Agreement, or Regulatory (required by law or CMS/DOI directive).' ;
    rdfs:domain ind:Term ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:title rdf:type rdf:Property ;
    rdfs:label 'Title' ;
    rdfs:comment 'Short descriptive title of the contract term as it appears in the contract document (e.g., \'Multiple Procedure Reduction Policy\', \'Termination for Cause Clause\'). Supports search and display in contract management UIs.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:withholdPercentage rdf:type rdf:Property ;
    rdfs:label 'Withhold Percentage' ;
    rdfs:comment 'The percentage of reimbursement withheld from provider payments pending quality performance or risk settlement under VBC or capitation arrangements. Classified confidential as proprietary financial terms.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:supersededAmendmentId rdf:type rdf:Property ;
    rdfs:label 'Superseded Amendment Id' ;
    rdfs:comment 'Reference to a prior amendment record that this amendment replaces or supersedes. Enables traversal of the full amendment history chain for a given contract. Null if this is the first amendment or does not supersede a prior amendment.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Amendment .

ind:vbcArrangementId rdf:type rdf:Property ;
    rdfs:label 'Vbc Arrangement Id' ;
    rdfs:comment 'Reference to the associated Accountable Care Organization (ACO) agreement when this amendment relates to an ACO or Value-Based Care (VBC) arrangement. Nullable for non-ACO amendments.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VbcArrangement .

ind:vbcContractId rdf:type rdf:Property ;
    rdfs:label 'Vbc Contract Id' ;
    rdfs:comment 'Foreign key linking to contract.vbc_contract. Business justification: amendment has vbc_target_metric (STRING) and amendment_effective_date-style attributes that indicate amendments can specifically modify VBC contract terms. The existing amendment.vbc_arrangement_id po' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VbcContract .

ind:amendmentType rdf:type rdf:Property ;
    rdfs:label 'Amendment Type' ;
    rdfs:comment 'Categorical classification of the amendment indicating the nature of the modification. Drives downstream processing workflows and audit categorization. [ENUM-REF-CANDIDATE: rate_change|term_modification|lob_addition|network_tier_change|scope_change|termination|capitation_change|bundled_payment_change|vbc_modification|addendum — promote to reference product]' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalStatus rdf:type rdf:Property ;
    rdfs:label 'Approval Status' ;
    rdfs:comment 'Current lifecycle state of the amendment through the negotiation and approval workflow. Tracks progression from draft through execution or withdrawal.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedDate rdf:type rdf:Property ;
    rdfs:label 'Approved Date' ;
    rdfs:comment 'The date on which the amendment received final internal approval from all required approvers. Distinct from execution date which reflects provider countersignature.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:claimsReprocessRequired rdf:type rdf:Property ;
    rdfs:label 'Claims Reprocess Required' ;
    rdfs:comment 'Indicates whether claims adjudicated under prior contract terms must be reprocessed following execution of this amendment. Triggers downstream claims reprocessing workflows in Facets/QNXT.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:documentReference rdf:type rdf:Property ;
    rdfs:label 'Document Reference' ;
    rdfs:comment 'Reference identifier or URL to the executed amendment document stored in the contract management document repository (e.g., SharePoint, Cactus/ProviderSource document store). Enables direct access to the legal document.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:formularyImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Formulary Impact Flag' ;
    rdfs:comment 'Indicates whether this amendment affects pharmacy formulary terms, drug reimbursement rates, or Pharmacy Benefit Management (PBM) arrangements. Triggers updates to the PBM system (RxClaim/Argus).' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:initiatingParty rdf:type rdf:Property ;
    rdfs:label 'Initiating Party' ;
    rdfs:comment 'Identifies which party initiated the amendment request — the health plan, the provider, a regulatory mandate, or a mutual agreement. Used for negotiation analytics and contract management reporting.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:internalNotes rdf:type rdf:Property ;
    rdfs:label 'Internal Notes' ;
    rdfs:comment 'Free-text field for internal health plan staff notes regarding the amendment, including strategic context, escalation history, or implementation considerations. Confidential internal business information not shared with providers.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:negotiationNotes rdf:type rdf:Property ;
    rdfs:label 'Negotiation Notes' ;
    rdfs:comment 'Free-text narrative capturing key negotiation points, concessions, and outcomes during the amendment negotiation process. Confidential commercial information used for internal reference and future renegotiation strategy.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:negotiationOutcome rdf:type rdf:Property ;
    rdfs:label 'Negotiation Outcome' ;
    rdfs:comment 'The result of the contract negotiation process leading to this amendment. Indicates whether terms were mutually agreed, required counter-proposals, or were resolved through arbitration or mediation. Confidential commercial negotiation data.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planSignatoryName rdf:type rdf:Property ;
    rdfs:label 'Plan Signatory Name' ;
    rdfs:comment 'Name of the authorized representative of the health plan who executed the amendment on behalf of the health plan. Required for legal enforceability of the amendment.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorAuthImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Prior Auth Impact Flag' ;
    rdfs:comment 'Indicates whether this amendment modifies Prior Authorization (PA) requirements for services rendered by the provider. Triggers updates to Utilization Management (UM) system configurations in InterQual/MCG.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:providerSignatoryName rdf:type rdf:Property ;
    rdfs:label 'Provider Signatory Name' ;
    rdfs:comment 'Name of the authorized representative of the provider organization who executed the amendment on behalf of the provider. Required for legal enforceability of the amendment.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateChangePct rdf:type rdf:Property ;
    rdfs:label 'Rate Change Pct' ;
    rdfs:comment 'The percentage increase or decrease in reimbursement rates resulting from this amendment. Expressed as a signed decimal (positive for increases, negative for decreases). Applicable when amendment_type is rate_change. Confidential commercial negotiation data.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rateEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Rate Effective Date' ;
    rdfs:comment 'The specific date on which revised reimbursement rates established by this amendment take effect in the claims adjudication system. May differ from the overall amendment effective date for phased implementations.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reason rdf:type rdf:Property ;
    rdfs:label 'Reason' ;
    rdfs:comment 'Narrative explanation of the business rationale or triggering event for the amendment (e.g., annual rate renegotiation, regulatory mandate, network expansion, provider request). Supports audit and compliance documentation.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryMandateFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Mandate Flag' ;
    rdfs:comment 'Indicates whether this amendment was required by a regulatory mandate (e.g., CMS rate update, state DOI directive, ACA compliance requirement). Drives prioritization and compliance reporting workflows.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryReference rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reference' ;
    rdfs:comment 'Citation of the specific regulation, CMS bulletin, state DOI directive, or legislative act that mandated or triggered this amendment (e.g., \'CMS-2024-MA-Rate-Update\', \'ACA Section 1302\'). Populated when regulatory_mandate_flag is true.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retroactiveFlag rdf:type rdf:Property ;
    rdfs:label 'Retroactive Flag' ;
    rdfs:comment 'Indicates whether the amendment has a retroactive effective date that precedes the execution date. Retroactive amendments require claims reprocessing and financial reconciliation activities.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:retroactiveStartDate rdf:type rdf:Property ;
    rdfs:label 'Retroactive Start Date' ;
    rdfs:comment 'The earliest date from which retroactive amendment terms apply, when retroactive_flag is true. Defines the claims reprocessing window for financial reconciliation.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:riskSharePct rdf:type rdf:Property ;
    rdfs:label 'Risk Share Pct' ;
    rdfs:comment 'The percentage of financial risk shared between the health plan and the provider under risk-sharing or Value-Based Care (VBC) arrangements established by this amendment. Confidential commercial negotiation data.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sectionsModified rdf:type rdf:Property ;
    rdfs:label 'Sections Modified' ;
    rdfs:comment 'Comma-delimited list or narrative description of the specific contract sections, exhibits, or schedules modified by this amendment (e.g., \'Exhibit A - Fee Schedule, Section 4.2 - Term\'). Supports targeted audit and compliance review.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submittedDate rdf:type rdf:Property ;
    rdfs:label 'Submitted Date' ;
    rdfs:comment 'The date on which the amendment was formally submitted for internal review and approval. Marks the start of the amendment approval workflow.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:vbcTargetMetric rdf:type rdf:Property ;
    rdfs:label 'Vbc Target Metric' ;
    rdfs:comment 'The primary quality or cost performance metric targeted under a Value-Based Care (VBC) or Accountable Care Organization (ACO) arrangement established by this amendment (e.g., HEDIS measure, readmission rate, cost per episode). Applicable when payment_methodology is vbc.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:versionNumber rdf:type rdf:Property ;
    rdfs:label 'Version Number' ;
    rdfs:comment 'Sequential version counter tracking revisions to the amendment record during the drafting and negotiation process. Supports amendment history and audit trail requirements.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:benefitPackageId rdf:type rdf:Property ;
    rdfs:label 'Benefit Package Id' ;
    rdfs:comment 'Foreign key linking to plan.benefit_package. Business justification: Fee schedules in health insurance are scoped to specific benefit packages — a Gold PPO benefit package carries different allowed amounts than a Bronze HMO. Claims adjudication requires selecting the c' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BenefitPackage .

ind:supersededByFeeScheduleId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Fee Schedule Id' ;
    rdfs:comment 'Reference to the fee_schedule_id of the newer fee schedule that replaced this one when schedule_status is \'superseded\'. Enables fee schedule version chain navigation and historical rate lookups.' ;
    rdfs:domain ind:FeeSchedule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FeeSchedule .

ind:yearId rdf:type rdf:Property ;
    rdfs:label 'Year Id' ;
    rdfs:comment 'Foreign key linking to plan.year. Business justification: Fee schedules are versioned annually in health insurance — annual rate negotiations, CMS fee schedule submissions, and regulatory rate filings all require explicit plan year association. Actuarial and' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Year .

ind:anesthesiaApplicable rdf:type rdf:Property ;
    rdfs:label 'Anesthesia Applicable' ;
    rdfs:comment 'Indicates whether this fee schedule includes anesthesia service reimbursement, which uses base units plus time units multiplied by a conversion factor rather than standard CPT-based rates.' ;
    rdfs:domain ind:FeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:anesthesiaConversionFactor rdf:type rdf:Property ;
    rdfs:label 'Anesthesia Conversion Factor' ;
    rdfs:comment 'Dollar amount per anesthesia unit (base units + time units) used to calculate anesthesia reimbursement when anesthesia_applicable is True. Negotiated rate specific to this fee schedule.' ;
    rdfs:domain ind:FeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvalDate rdf:type rdf:Property ;
    rdfs:label 'Approval Date' ;
    rdfs:comment 'Date on which the fee schedule was formally approved by the authorized contracting officer or governance body. Required for audit and regulatory compliance.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cmsFeeScheduleYear rdf:type rdf:Property ;
    rdfs:label 'Cms Fee Schedule Year' ;
    rdfs:comment 'The CMS Medicare fee schedule calendar year used as the basis or benchmark for this fee schedule when fee_schedule_source is \'cms_medicare\'. Enables tracking of which CMS annual update cycle the rates are derived from.' ;
    rdfs:domain ind:FeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contractCode rdf:type rdf:Property ;
    rdfs:label 'Contract Code' ;
    rdfs:comment 'Reference to the provider contract under which this fee schedule is established. Links the fee schedule to its governing contractual agreement.' ;
    rdfs:domain ind:FeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:conversionFactor rdf:type rdf:Property ;
    rdfs:label 'Conversion Factor' ;
    rdfs:comment 'Dollar amount multiplied by the total Relative Value Units (RVUs) to calculate the reimbursement amount for RVU-based fee schedules. Applicable when payment_basis is \'rvu_based\'. Sourced from CMS RBRVS conversion factor or negotiated contract rate.' ;
    rdfs:domain ind:FeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coordinationOfBenefitsApplicable rdf:type rdf:Property ;
    rdfs:label 'Coordination Of Benefits Applicable' ;
    rdfs:comment 'Indicates whether Coordination of Benefits (COB) rules apply to claims adjudicated under this fee schedule. When True, COB logic determines primary vs. secondary payer responsibilities.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cptCodeRangeEnd rdf:type rdf:Property ;
    rdfs:label 'Cpt Code Range End' ;
    rdfs:comment 'Ending CPT procedure code in the range of services covered by this fee schedule. Used in conjunction with cpt_code_range_start to define the scope of applicable procedure codes.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cptCodeRangeStart rdf:type rdf:Property ;
    rdfs:label 'Cpt Code Range Start' ;
    rdfs:comment 'Starting CPT procedure code in the range of services covered by this fee schedule. Used in conjunction with cpt_code_range_end to define the scope of applicable procedure codes. Null if the fee schedule applies to all CPT codes or uses ICD/DRG-based scoping.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drgApplicable rdf:type rdf:Property ;
    rdfs:label 'Drg Applicable' ;
    rdfs:comment 'Indicates whether this fee schedule uses Diagnosis Related Group (DRG)-based reimbursement for inpatient facility claims. When True, DRG weights and base rates govern payment rather than individual procedure codes.' ;
    rdfs:domain ind:FeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:drgBaseRate rdf:type rdf:Property ;
    rdfs:label 'Drg Base Rate' ;
    rdfs:comment 'The negotiated base dollar rate per DRG weight unit used for inpatient facility reimbursement when drg_applicable is True. Multiplied by the DRG relative weight to calculate the total inpatient payment.' ;
    rdfs:domain ind:FeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:feeScheduleDescription rdf:type rdf:Property ;
    rdfs:label 'Fee Schedule Description' ;
    rdfs:comment 'Free-text narrative description of the fee schedule, including its purpose, scope, special provisions, or notes relevant to adjudication staff and contract analysts.' ;
    rdfs:domain ind:FeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feeScheduleSource rdf:type rdf:Property ;
    rdfs:label 'Fee Schedule Source' ;
    rdfs:comment 'Identifies the origin or benchmark source of the fee schedule rates: cms_medicare (based on CMS Medicare fee schedule), cms_medicaid (based on state Medicaid fee schedule), negotiated (directly negotiated with provider), custom (health plan proprietary rates), rbp_benchmark (Reference Based Pricing benchmark).' ;
    rdfs:domain ind:FeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicModifierApplicable rdf:type rdf:Property ;
    rdfs:label 'Geographic Modifier Applicable' ;
    rdfs:comment 'Indicates whether geographic adjustment factors (e.g., CMS Geographic Practice Cost Indices - GPCI) are applied to rates under this fee schedule. True when locality-based adjustments are in effect; False for flat national rates.' ;
    rdfs:domain ind:FeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:globalSurgeryApplicable rdf:type rdf:Property ;
    rdfs:label 'Global Surgery Applicable' ;
    rdfs:comment 'Indicates whether global surgery payment rules apply under this fee schedule, bundling pre-operative, intra-operative, and post-operative services into a single reimbursement amount.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:localityCode rdf:type rdf:Property ;
    rdfs:label 'Locality Code' ;
    rdfs:comment 'CMS Medicare locality code identifying the geographic pricing area applicable to this fee schedule when geographic_modifier_applicable is True. Used to apply GPCI adjustments to RVU-based rates.' ;
    rdfs:domain ind:FeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:medicareCrossoverApplicable rdf:type rdf:Property ;
    rdfs:label 'Medicare Crossover Applicable' ;
    rdfs:comment 'Indicates whether this fee schedule applies to Medicare crossover claims where Medicare is the primary payer and the health plan is the secondary payer. Relevant for Medicare Advantage and Medigap plans.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:modifierApplicable rdf:type rdf:Property ;
    rdfs:label 'Modifier Applicable' ;
    rdfs:comment 'Indicates whether CPT or HCPCS modifiers affect reimbursement rates under this fee schedule (e.g., modifier 26 for professional component, modifier TC for technical component, modifier 50 for bilateral procedures).' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:outlierThresholdAmt rdf:type rdf:Property ;
    rdfs:label 'Outlier Threshold Amt' ;
    rdfs:comment 'Dollar threshold above which a claim qualifies as a cost outlier, triggering additional reimbursement beyond the standard DRG or bundled payment. Applicable for institutional fee schedules with outlier payment provisions.' ;
    rdfs:domain ind:FeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentBasis rdf:type rdf:Property ;
    rdfs:label 'Payment Basis' ;
    rdfs:comment 'The methodology used to calculate reimbursement amounts under this fee schedule. Options include: pct_medicare (percentage of Medicare allowable), pct_billed_charges (percentage of provider billed charges), flat_rate (fixed dollar amount per service), rvu_based (Relative Value Unit-based), bundled (bundled payment for episode of care), capitation (per-member per-month), rbp (Reference Based Pricing). [ENUM-REF-CANDIDATE: pct_medicare|pct_billed_charges|flat_rate|rvu_based|bundled|capitation|rbp — promote to reference product]' ;
    rdfs:domain ind:FeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentBasisPct rdf:type rdf:Property ;
    rdfs:label 'Payment Basis Pct' ;
    rdfs:comment 'The percentage rate applied when payment_basis is \'pct_medicare\' or \'pct_billed_charges\' (e.g., 110.0000 for 110% of Medicare). Null when payment_basis is flat_rate, rvu_based, bundled, or capitation. Stored as a decimal percentage value.' ;
    rdfs:domain ind:FeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priorAuthorizationRequired rdf:type rdf:Property ;
    rdfs:label 'Prior Authorization Required' ;
    rdfs:comment 'Indicates whether Prior Authorization (PA) is required for services reimbursed under this fee schedule. When True, claims must have an approved PA on file before adjudication at the scheduled rates.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:referralRequired rdf:type rdf:Property ;
    rdfs:label 'Referral Required' ;
    rdfs:comment 'Indicates whether a primary care physician (PCP) referral is required for services covered under this fee schedule. Applicable primarily for HMO and POS plan types.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scheduleCode rdf:type rdf:Property ;
    rdfs:label 'Schedule Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying the fee schedule within the Core Administration Platform (Facets/QNXT). Used in EDI transactions and cross-system references.' ;
    rdfs:domain ind:FeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleName rdf:type rdf:Property ;
    rdfs:label 'Schedule Name' ;
    rdfs:comment 'Human-readable name identifying the fee schedule (e.g., \'Commercial PPO Professional 2024\', \'Medicare Advantage Institutional Q1 2024\'). Used for display and reporting in Facets/QNXT Benefits Configuration.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleStatus rdf:type rdf:Property ;
    rdfs:label 'Schedule Status' ;
    rdfs:comment 'Current lifecycle state of the fee schedule. \'draft\' indicates under review; \'active\' indicates currently in use for adjudication; \'suspended\' indicates temporarily inactive; \'terminated\' indicates permanently closed; \'superseded\' indicates replaced by a newer version.' ;
    rdfs:domain ind:FeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleType rdf:type rdf:Property ;
    rdfs:label 'Schedule Type' ;
    rdfs:comment 'Categorizes the fee schedule by the type of services covered: professional (physician/practitioner), institutional (hospital/facility), ancillary (therapy/home health), DME (Durable Medical Equipment), lab (laboratory), or pharmacy. Drives claim adjudication logic in Facets/QNXT.' ;
    rdfs:domain ind:FeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceCategory rdf:type rdf:Property ;
    rdfs:label 'Service Category' ;
    rdfs:comment 'Broad clinical or administrative category of services covered by this fee schedule (e.g., \'Evaluation and Management\', \'Surgery\', \'Radiology\', \'Pathology\', \'Inpatient Facility\', \'Outpatient Facility\', \'Home Health\', \'Behavioral Health\'). Supports fee schedule segmentation and reporting. [ENUM-REF-CANDIDATE: evaluation_management|surgery|radiology|pathology|inpatient_facility|outpatient_facility|home_health|behavioral_health|physical_therapy|dme — promote to reference product]' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stopLossApplicable rdf:type rdf:Property ;
    rdfs:label 'Stop Loss Applicable' ;
    rdfs:comment 'Indicates whether a stop-loss provision applies to this fee schedule, capping the health plan\'s reimbursement liability per claim or per member. Relevant for risk-sharing and capitation arrangements.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:stopLossThresholdAmt rdf:type rdf:Property ;
    rdfs:label 'Stop Loss Threshold Amt' ;
    rdfs:comment 'Dollar amount per claim or per member above which the stop-loss provision activates, limiting the health plan\'s reimbursement exposure. Applicable when stop_loss_applicable is True.' ;
    rdfs:domain ind:FeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:feeScheduleRateId rdf:type rdf:Property ;
    rdfs:label 'Fee Schedule Rate Id' ;
    rdfs:comment 'Unique surrogate identifier for each fee schedule rate line record in the contract domain. Primary key for this entity.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FeeScheduleRate .

ind:priorRateFeeScheduleRateId rdf:type rdf:Property ;
    rdfs:label 'Prior Rate Fee Schedule Rate Id' ;
    rdfs:comment 'Self-referencing identifier pointing to the previous version of this rate record that was superseded by the current record. Enables full rate history chain traversal for audit and compliance purposes.' ;
    rdfs:domain ind:FeeScheduleRate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FeeScheduleRate .

ind:allowedAmount rdf:type rdf:Property ;
    rdfs:label 'Allowed Amount' ;
    rdfs:comment 'The contracted allowed amount or maximum reimbursable dollar amount for the specified procedure code, modifier, and place of service combination. This is the principal monetary value used by adjudication systems to price claims against contracted rates. Expressed in USD.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:awpPercent rdf:type rdf:Property ;
    rdfs:label 'Awp Percent' ;
    rdfs:comment 'When rate_derivation_method is AWP_PCT, this field stores the percentage of the Average Wholesale Price (AWP) used to derive the drug or supply reimbursement rate. For example, 0.8500 represents AWP minus 15%. Commonly used in pharmacy and DME fee schedules.' ;
    rdfs:domain ind:FeeScheduleRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bilateralIndicator rdf:type rdf:Property ;
    rdfs:label 'Bilateral Indicator' ;
    rdfs:comment 'Indicates whether this rate applies to a bilateral procedure (performed on both sides of the body). When true, the allowed amount may be adjusted per CMS bilateral surgery payment rules (150% of the unilateral rate).' ;
    rdfs:domain ind:FeeScheduleRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:bundledPaymentAmount rdf:type rdf:Property ;
    rdfs:label 'Bundled Payment Amount' ;
    rdfs:comment 'Single episode-of-care payment amount covering all services within a defined clinical episode (e.g., joint replacement, maternity). Applicable when payment_methodology is BUNDLED. Supports Value-Based Care (VBC) and ACO payment models.' ;
    rdfs:domain ind:FeeScheduleRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:drgCode rdf:type rdf:Property ;
    rdfs:label 'Drg Code' ;
    rdfs:comment 'CMS Diagnosis Related Group code used for inpatient hospital reimbursement. When the payment methodology is DRG-based, this code identifies the patient classification group that determines the base payment rate.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicRegion rdf:type rdf:Property ;
    rdfs:label 'Geographic Region' ;
    rdfs:comment 'Geographic region or market area to which this rate applies. Rates may vary by state, CMS locality, metropolitan statistical area (MSA), or health plan-defined region. Expressed as a state code, CMS locality code, or internal region identifier.' ;
    rdfs:domain ind:FeeScheduleRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:globalSurgeryDays rdf:type rdf:Property ;
    rdfs:label 'Global Surgery Days' ;
    rdfs:comment 'Number of days in the global surgery period for surgical procedure codes. Defines the pre-operative and post-operative period during which related services are bundled into the surgical payment (0=endoscopic/minor, 10=minor, 90=major surgery).' ;
    rdfs:domain ind:FeeScheduleRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:macAmount rdf:type rdf:Property ;
    rdfs:label 'Mac Amount' ;
    rdfs:comment 'The Maximum Allowable Cost (MAC) dollar amount set as the ceiling for reimbursement of a specific drug or service. When rate_derivation_method is MAC, this value represents the maximum the plan will pay regardless of billed charges.' ;
    rdfs:domain ind:FeeScheduleRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxUnitsPerDay rdf:type rdf:Property ;
    rdfs:label 'Max Units Per Day' ;
    rdfs:comment 'Maximum number of units of this procedure code that will be reimbursed per day per member. Used to enforce utilization limits during claims adjudication and prevent overbilling.' ;
    rdfs:domain ind:FeeScheduleRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maxUnitsPerYear rdf:type rdf:Property ;
    rdfs:label 'Max Units Per Year' ;
    rdfs:comment 'Maximum number of units of this procedure code that will be reimbursed per benefit year per member. Enforces annual utilization limits during adjudication for services with frequency restrictions.' ;
    rdfs:domain ind:FeeScheduleRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:medicareFeeSchedulePct rdf:type rdf:Property ;
    rdfs:label 'Medicare Fee Schedule Pct' ;
    rdfs:comment 'When rate_derivation_method is MEDICARE_PCT, this field stores the percentage of the applicable Medicare fee schedule rate used to derive the allowed amount. For example, 1.1500 represents 115% of Medicare. Used for rate benchmarking and contract analytics.' ;
    rdfs:domain ind:FeeScheduleRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ncciEditIndicator rdf:type rdf:Property ;
    rdfs:label 'Ncci Edit Indicator' ;
    rdfs:comment 'Indicates whether this procedure code is subject to National Correct Coding Initiative (NCCI) bundling edits during claims adjudication. When true, the adjudication system will apply NCCI column 1/column 2 and mutually exclusive code edits.' ;
    rdfs:domain ind:FeeScheduleRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:perDiemRate rdf:type rdf:Property ;
    rdfs:label 'Per Diem Rate' ;
    rdfs:comment 'Daily reimbursement rate paid to a facility provider for each day of an inpatient or residential stay. Applicable when payment_methodology is PER_DIEM. May vary by level of care (e.g., ICU vs. medical/surgical).' ;
    rdfs:domain ind:FeeScheduleRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:placeOfServiceCode rdf:type rdf:Property ;
    rdfs:label 'Place Of Service Code' ;
    rdfs:comment 'CMS two-digit place of service code indicating the setting where the service was rendered (e.g., 11=Office, 21=Inpatient Hospital, 22=Outpatient Hospital, 23=Emergency Room). Rates may vary by place of service.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:procedureCode rdf:type rdf:Property ;
    rdfs:label 'Procedure Code' ;
    rdfs:comment 'The CPT or HCPCS procedure code identifying the specific medical service, procedure, or supply for which this rate applies. Core identifier used in claims adjudication to match services to contracted rates.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:procedureCodeType rdf:type rdf:Property ;
    rdfs:label 'Procedure Code Type' ;
    rdfs:comment 'Classifies the coding system used for the procedure_code field. Distinguishes between CPT (physician services), HCPCS Level II (supplies/DME), CDT (dental), ICD-10-PCS (inpatient procedures), Revenue Code (facility billing), DRG (diagnosis-related group), APC (ambulatory payment classification), or NDC (drug). [ENUM-REF-CANDIDATE: CPT|HCPCS_II|CDT|ICD_PCS|REVENUE|DRG|APC|NDC — promote to reference product]' ;
    rdfs:domain ind:FeeScheduleRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:procedureModifier1 rdf:type rdf:Property ;
    rdfs:label 'Procedure Modifier 1' ;
    rdfs:comment 'First CPT or HCPCS modifier code appended to the procedure code to indicate special circumstances affecting the service (e.g., bilateral procedure, assistant surgeon, professional component). Modifiers can alter the allowed reimbursement amount.' ;
    rdfs:domain ind:FeeScheduleRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:procedureModifier2 rdf:type rdf:Property ;
    rdfs:label 'Procedure Modifier 2' ;
    rdfs:comment 'Second CPT or HCPCS modifier code when multiple modifiers apply to the same procedure code. Used in conjunction with procedure_modifier_1 for complex billing scenarios.' ;
    rdfs:domain ind:FeeScheduleRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productType rdf:type rdf:Property ;
    rdfs:label 'Product Type' ;
    rdfs:comment 'The health plan product type to which this rate applies. HMO=Health Maintenance Organization, PPO=Preferred Provider Organization, EPO=Exclusive Provider Organization, POS=Point of Service, HDHP=High Deductible Health Plan, INDEMNITY=traditional indemnity plan. Rates may vary by product type.' ;
    rdfs:domain ind:FeeScheduleRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateDerivationMethod rdf:type rdf:Property ;
    rdfs:label 'Rate Derivation Method' ;
    rdfs:comment 'Describes how the allowed amount was derived or calculated. MEDICARE_PCT=percentage of Medicare fee schedule, AWP_PCT=percentage of Average Wholesale Price, WAC_PCT=percentage of Wholesale Acquisition Cost, MAC=Maximum Allowable Cost, RBP=Reference Based Pricing benchmark, NEGOTIATED=directly negotiated flat rate, COST_PLUS=cost plus margin, BILLED_PCT=percent of billed charges. Critical for audit and rate validation. [ENUM-REF-CANDIDATE: MEDICARE_PCT|AWP_PCT|WAC_PCT|MAC|RBP|NEGOTIATED|COST_PLUS|BILLED_PCT — promote to reference product]' ;
    rdfs:domain ind:FeeScheduleRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateLineNumber rdf:type rdf:Property ;
    rdfs:label 'Rate Line Number' ;
    rdfs:comment 'Sequential line number identifying the position of this rate record within the parent fee schedule. Used for ordering and referencing individual rate lines.' ;
    rdfs:domain ind:FeeScheduleRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rateNote rdf:type rdf:Property ;
    rdfs:label 'Rate Note' ;
    rdfs:comment 'Free-text notes or comments providing additional context about this fee schedule rate, such as special billing instructions, exceptions, or conditions under which the rate applies. Used by contracting and claims operations staff.' ;
    rdfs:domain ind:FeeScheduleRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ratePercentOfBilled rdf:type rdf:Property ;
    rdfs:label 'Rate Percent Of Billed' ;
    rdfs:comment 'Reimbursement rate expressed as a percentage of the provider\'s billed charges, used when the payment methodology is percent-of-billed rather than a fixed allowed amount. For example, 0.8500 represents 85% of billed charges.' ;
    rdfs:domain ind:FeeScheduleRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rateSource rdf:type rdf:Property ;
    rdfs:label 'Rate Source' ;
    rdfs:comment 'Identifies the origin or source of this fee schedule rate. CONTRACT=directly negotiated in provider contract, CMS_PUBLISHED=derived from published CMS fee schedule, CROSSWALK=mapped from another code or schedule, MANUAL=manually entered by contracting staff, SYSTEM_GENERATED=automatically generated by the fee schedule management system.' ;
    rdfs:domain ind:FeeScheduleRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateStatus rdf:type rdf:Property ;
    rdfs:label 'Rate Status' ;
    rdfs:comment 'Current lifecycle status of this fee schedule rate record. ACTIVE=currently in effect and used for adjudication, INACTIVE=not currently in use, PENDING=approved but not yet effective, SUPERSEDED=replaced by a newer rate version, TERMINATED=permanently ended.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateVersion rdf:type rdf:Property ;
    rdfs:label 'Rate Version' ;
    rdfs:comment 'Incrementing version number tracking amendments and updates to this fee schedule rate line. Version 1 is the original rate; subsequent amendments increment this counter. Supports rate history and audit trail requirements.' ;
    rdfs:domain ind:FeeScheduleRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rbpReferenceAmount rdf:type rdf:Property ;
    rdfs:label 'Rbp Reference Amount' ;
    rdfs:comment 'The benchmark dollar amount used as the basis for Reference Based Pricing (RBP) reimbursement. Typically anchored to Medicare rates or a cost-based benchmark. The actual allowed amount is derived as a percentage of this reference amount.' ;
    rdfs:domain ind:FeeScheduleRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revenueCode rdf:type rdf:Property ;
    rdfs:label 'Revenue Code' ;
    rdfs:comment 'Four-digit UB-04 revenue code identifying the type of accommodation, ancillary service, or billing classification for facility claims. Used in conjunction with or as an alternative to procedure codes for hospital and facility fee schedule rates.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialtyCode rdf:type rdf:Property ;
    rdfs:label 'Specialty Code' ;
    rdfs:comment 'CMS three-digit provider specialty code indicating the clinical specialty for which this rate applies. Rates may be differentiated by provider specialty (e.g., 01=General Practice, 06=Cardiology, 93=Emergency Medicine). Null if rate applies to all specialties.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitsOfService rdf:type rdf:Property ;
    rdfs:label 'Units Of Service' ;
    rdfs:comment 'The number of units of service to which the allowed_amount applies. For most procedure codes, this is 1 unit. For time-based codes or quantity-based services, this may represent the standard unit quantity (e.g., 15-minute increments for therapy codes).' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capitationArrangementId rdf:type rdf:Property ;
    rdfs:label 'Capitation Arrangement Id' ;
    rdfs:comment 'Unique surrogate identifier for the capitation arrangement record in the Silver Layer lakehouse. Primary key for this entity.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CapitationArrangement .

ind:reinsuranceArrangementId rdf:type rdf:Property ;
    rdfs:label 'Reinsurance Arrangement Id' ;
    rdfs:comment 'Foreign key linking to risk.reinsurance_arrangement. Business justification: Capitation arrangements carry stop-loss exposure; health plans purchase reinsurance to cap individual/aggregate losses. Actuarial and finance teams must trace which reinsurance treaty backstops each c' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ReinsuranceArrangement .

ind:riskUnderwritingCaseId rdf:type rdf:Property ;
    rdfs:label 'Risk Underwriting Case Id' ;
    rdfs:comment 'Foreign key linking to risk.risk_underwriting_case. Business justification: Capitation PMPM rates are set through actuarial underwriting of the attributed population\'s morbidity and risk profile. Linking capitation_arrangement to risk_underwriting_case enables actuarial revie' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RiskUnderwritingCase .

ind:acoArrangementFlag rdf:type rdf:Property ;
    rdfs:label 'Aco Arrangement Flag' ;
    rdfs:comment 'Indicates whether this capitation arrangement is part of an Accountable Care Organization (ACO) or integrated delivery network model, which may have additional shared savings or risk-sharing components.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:aggregateStopLossThreshold rdf:type rdf:Property ;
    rdfs:label 'Aggregate Stop Loss Threshold' ;
    rdfs:comment 'Total dollar amount for the attributed member population above which the health plan assumes financial responsibility for claims costs. Protects the provider from population-level adverse risk. Expressed in USD.' ;
    rdfs:domain ind:CapitationArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:annualRateEscalator rdf:type rdf:Property ;
    rdfs:label 'Annual Rate Escalator' ;
    rdfs:comment 'Contractually agreed annual percentage increase applied to the PMPM rate at each rate renewal period (e.g., 3.50 for 3.5% annual escalation). Used for multi-year capitation arrangements.' ;
    rdfs:domain ind:CapitationArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvedBy rdf:type rdf:Property ;
    rdfs:label 'Approved By' ;
    rdfs:comment 'Name or employee identifier of the contracting authority who approved this capitation arrangement. Supports audit trail and delegation-of-authority compliance.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:arrangementName rdf:type rdf:Property ;
    rdfs:label 'Arrangement Name' ;
    rdfs:comment 'Human-readable descriptive name for the capitation arrangement (e.g., \'Primary Care Capitation - HMO Commercial 2024\'), used in reporting and provider communications.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:arrangementNumber rdf:type rdf:Property ;
    rdfs:label 'Arrangement Number' ;
    rdfs:comment 'Externally-known business identifier for the capitation arrangement, used in provider communications, payment remittances, and reconciliation processes. Assigned by the Core Administration Platform (Facets/QNXT).' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:arrangementStatus rdf:type rdf:Property ;
    rdfs:label 'Arrangement Status' ;
    rdfs:comment 'Current lifecycle status of the capitation arrangement. Controls whether PMPM payments are generated and whether members can be attributed to this arrangement.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:arrangementType rdf:type rdf:Property ;
    rdfs:label 'Arrangement Type' ;
    rdfs:comment 'Classification of the capitation arrangement by scope of covered services. Global capitation covers all services; primary care capitation covers PCP services only; specialty capitation covers specialist services; institutional covers facility-based care. [ENUM-REF-CANDIDATE: global_capitation|primary_care_capitation|specialty_capitation|institutional_capitation|behavioral_health_capitation|pharmacy_capitation — promote to reference product]' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attributedMemberCount rdf:type rdf:Property ;
    rdfs:label 'Attributed Member Count' ;
    rdfs:comment 'Current number of members attributed to this capitation arrangement for the active payment period. Used to calculate total monthly capitation payment disbursement.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:attributionMethod rdf:type rdf:Property ;
    rdfs:label 'Attribution Method' ;
    rdfs:comment 'Methodology used to attribute members to this capitation arrangement. PCP assignment uses enrollment data; claims-based uses plurality of visits; voluntary selection allows member choice; geographic assigns by service area.' ;
    rdfs:domain ind:CapitationArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carveOutServices rdf:type rdf:Property ;
    rdfs:label 'Carve Out Services' ;
    rdfs:comment 'Description of services explicitly excluded from the capitation scope and reimbursed separately (e.g., \'Mental Health, Substance Abuse, Transplants, Neonatal ICU\'). Carve-outs are paid fee-for-service or under separate capitation arrangements.' ;
    rdfs:domain ind:CapitationArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicServiceArea rdf:type rdf:Property ;
    rdfs:label 'Geographic Service Area' ;
    rdfs:comment 'Description or code of the geographic service area (county, state, or region) within which this capitation arrangement applies. Members outside this area may not be attributed to this arrangement.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:individualStopLossThreshold rdf:type rdf:Property ;
    rdfs:label 'Individual Stop Loss Threshold' ;
    rdfs:comment 'Dollar amount per member per year above which the health plan assumes financial responsibility for claims costs, protecting the provider from catastrophic individual member costs. Expressed in USD.' ;
    rdfs:domain ind:CapitationArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentFrequency rdf:type rdf:Property ;
    rdfs:label 'Payment Frequency' ;
    rdfs:comment 'Frequency at which capitation payments are disbursed to the provider. Monthly is standard for most capitation arrangements; quarterly or annual may apply for certain specialty or institutional arrangements.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pmpmRate rdf:type rdf:Property ;
    rdfs:label 'Pmpm Rate' ;
    rdfs:comment 'Fixed dollar amount paid to the provider per attributed member per calendar month, regardless of services rendered. The core financial parameter of the capitation arrangement. Expressed in USD.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pmpmRateCurrency rdf:type rdf:Property ;
    rdfs:label 'Pmpm Rate Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the PMPM rate (typically USD for domestic health plans). Required for multi-currency reporting and regulatory submissions.' ;
    rdfs:domain ind:CapitationArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityWithholdReleaseCriteria rdf:type rdf:Property ;
    rdfs:label 'Quality Withhold Release Criteria' ;
    rdfs:comment 'Description of the quality performance benchmarks or HEDIS/STAR measure thresholds that must be met for the provider to receive release of withheld capitation amounts. Defines the performance contract terms.' ;
    rdfs:domain ind:CapitationArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rafAdjustmentFactor rdf:type rdf:Property ;
    rdfs:label 'Raf Adjustment Factor' ;
    rdfs:comment 'Multiplier applied to the base PMPM rate to account for the relative health risk of the attributed member population. A RAF above 1.0 indicates a sicker-than-average population; below 1.0 indicates healthier-than-average.' ;
    rdfs:domain ind:CapitationArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rateExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Rate Expiration Date' ;
    rdfs:comment 'Date on which the current PMPM rate expires and is subject to renegotiation or automatic escalation. Null if the rate is open-ended for the arrangement term.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:riskAdjustmentApplicable rdf:type rdf:Property ;
    rdfs:label 'Risk Adjustment Applicable' ;
    rdfs:comment 'Indicates whether the PMPM rate is subject to risk adjustment based on the attributed member population\'s Hierarchical Condition Category (HCC) Risk Adjustment Factor (RAF) scores. Applicable primarily for Medicare Advantage and ACA Exchange arrangements.' ;
    rdfs:domain ind:CapitationArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:riskPoolParticipant rdf:type rdf:Property ;
    rdfs:label 'Risk Pool Participant' ;
    rdfs:comment 'Indicates whether the provider participates in a shared risk pool under this capitation arrangement. Risk pool participants share in surpluses or deficits relative to the capitation budget.' ;
    rdfs:domain ind:CapitationArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:riskSharePercentage rdf:type rdf:Property ;
    rdfs:label 'Risk Share Percentage' ;
    rdfs:comment 'Percentage of risk pool surplus or deficit allocated to the provider under this capitation arrangement. Expressed as a percentage (0.00–100.00). Applicable only when risk_pool_participant is True.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:serviceCategoryScope rdf:type rdf:Property ;
    rdfs:label 'Service Category Scope' ;
    rdfs:comment 'Comma-delimited list or narrative description of the covered service categories included under this capitation arrangement (e.g., \'Primary Care, Preventive Services, Lab, Radiology\'). Defines the scope of services the provider is financially responsible for under capitation.' ;
    rdfs:domain ind:CapitationArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemRecordReference rdf:type rdf:Property ;
    rdfs:label 'Source System Record Reference' ;
    rdfs:comment 'Native record identifier from the operational source system (Facets, QNXT, or Provider Management System) for this capitation arrangement. Supports data lineage, reconciliation, and back-referencing to the system of record.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stopLossType rdf:type rdf:Property ;
    rdfs:label 'Stop Loss Type' ;
    rdfs:comment 'Type of stop-loss protection included in the capitation arrangement. Individual stop-loss limits exposure per member; aggregate stop-loss limits total population exposure; both applies both thresholds.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vbcArrangementFlag rdf:type rdf:Property ;
    rdfs:label 'Vbc Arrangement Flag' ;
    rdfs:comment 'Indicates whether this capitation arrangement includes Value-Based Care (VBC) performance incentive components such as quality bonuses, shared savings, or outcome-based adjustments beyond the base PMPM.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:capitationPaymentId rdf:type rdf:Property ;
    rdfs:label 'Capitation Payment Id' ;
    rdfs:comment 'Unique surrogate identifier for each capitation payment disbursement record in the Silver Layer lakehouse. Primary key for this entity.' ;
    rdfs:domain ind:CapitationPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:originalPaymentCapitationPaymentId rdf:type rdf:Property ;
    rdfs:label 'Original Payment Capitation Payment Id' ;
    rdfs:comment 'Reference to the original capitation payment record that this record adjusts, reverses, or supplements. Populated only when prior_period_adjustment_flag is True. Enables audit trail linking of adjustment chains.' ;
    rdfs:domain ind:CapitationPayment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CapitationPayment .

ind:apVoucherNumber rdf:type rdf:Property ;
    rdfs:label 'Ap Voucher Number' ;
    rdfs:comment 'Accounts Payable (AP) voucher or invoice number assigned in Oracle Financials when the capitation payment is posted as a payable. Links the capitation disbursement to the AP subledger for financial reporting and audit trail.' ;
    rdfs:domain ind:CapitationPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capitationRateTier rdf:type rdf:Property ;
    rdfs:label 'Capitation Rate Tier' ;
    rdfs:comment 'Rate tier or member category applied to determine the PMPM rate for this payment (e.g., adult, pediatric, senior, ESRD, dual-eligible). Different member demographics may attract different PMPM rates under the same contract.' ;
    rdfs:domain ind:CapitationPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checkEftTraceNumber rdf:type rdf:Property ;
    rdfs:label 'Check Eft Trace Number' ;
    rdfs:comment 'Check number or EFT/ACH trace number assigned by the financial institution for the actual disbursement of this capitation payment. Used for bank reconciliation in Oracle Financials (AP module) and provider payment dispute resolution.' ;
    rdfs:domain ind:CapitationPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentAdjustmentAmount rdf:type rdf:Property ;
    rdfs:label 'Enrollment Adjustment Amount' ;
    rdfs:comment 'Dollar adjustment to the gross payment resulting from retroactive enrollment changes (late enrollments, disenrollments, or eligibility corrections) identified after the initial payment calculation. Can be positive (additional payment) or negative (recoupment).' ;
    rdfs:domain ind:CapitationPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:glCostCenter rdf:type rdf:Property ;
    rdfs:label 'Gl Cost Center' ;
    rdfs:comment 'General Ledger (GL) cost center code in Oracle Financials to which this capitation payment expense is allocated. Supports financial reporting by LOB, product, and organizational unit per GAAP and SAP statutory reporting requirements.' ;
    rdfs:domain ind:CapitationPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grossPaymentAmount rdf:type rdf:Property ;
    rdfs:label 'Gross Payment Amount' ;
    rdfs:comment 'Total gross capitation payment amount before any adjustments, calculated as attributed_member_count multiplied by the pmpm_rate. Represents the base payment obligation for the period prior to retroactive enrollment changes, risk pool withholds, or stop-loss recoveries.' ;
    rdfs:domain ind:CapitationPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netPaymentAmount rdf:type rdf:Property ;
    rdfs:label 'Net Payment Amount' ;
    rdfs:comment 'Final net amount disbursed to the provider after all adjustments: gross_payment_amount + enrollment_adjustment_amount - risk_pool_withhold_amount + stop_loss_recovery_amount + other_adjustment_amount. This is the actual amount reflected in the 835 ERA remittance advice.' ;
    rdfs:domain ind:CapitationPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Payment Approval Date' ;
    rdfs:comment 'Date on which the capitation payment was formally approved for disbursement by the authorized approver in the billing or finance system. Supports segregation of duties controls and audit trail requirements.' ;
    rdfs:domain ind:CapitationPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentDate rdf:type rdf:Property ;
    rdfs:label 'Payment Date' ;
    rdfs:comment 'Actual date the capitation payment was disbursed to the provider via EFT, check, or ACH. Used for accounts payable reconciliation and provider remittance reporting.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentMethod rdf:type rdf:Property ;
    rdfs:label 'Payment Method' ;
    rdfs:comment 'Mechanism by which the capitation payment was or will be disbursed to the provider. EFT (Electronic Funds Transfer) and ACH (Automated Clearing House) are most common for capitation arrangements.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentNumber rdf:type rdf:Property ;
    rdfs:label 'Payment Number' ;
    rdfs:comment 'Externally-visible business identifier for this capitation payment disbursement, used in provider remittance advice (835 ERA), accounts payable records, and provider portal references. Format: CAP-YYYYMM-NNNNNN.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Payment Period End Date' ;
    rdfs:comment 'Last day of the coverage month or period for which this capitation payment is being made. Typically the last day of the calendar month in monthly capitation cycles.' ;
    rdfs:domain ind:CapitationPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Payment Period Start Date' ;
    rdfs:comment 'First day of the coverage month or period for which this capitation payment is being made. Typically the first day of the calendar month in monthly capitation cycles.' ;
    rdfs:domain ind:CapitationPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentRunNumber rdf:type rdf:Property ;
    rdfs:label 'Payment Run Number' ;
    rdfs:comment 'Identifier of the capitation payment run or batch cycle that generated this payment record. Used to group all payments processed in the same cycle for reconciliation, audit, and reprocessing purposes in the Core Administration Platform (Facets/QNXT).' ;
    rdfs:domain ind:CapitationPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentStatus rdf:type rdf:Property ;
    rdfs:label 'Payment Status' ;
    rdfs:comment 'Current lifecycle state of the capitation payment disbursement. \'pending\' = calculated but not yet approved; \'approved\' = authorized for payment; \'paid\' = disbursed to provider; \'voided\' = cancelled before disbursement; \'reversed\' = clawed back after disbursement; \'on_hold\' = suspended pending investigation or contract dispute.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentType rdf:type rdf:Property ;
    rdfs:label 'Payment Type' ;
    rdfs:comment 'Classification of the capitation payment by its business purpose. \'standard\' = routine monthly capitation; \'retroactive\' = payment for prior periods due to enrollment changes; \'adjustment\' = correction to a previously issued payment; \'stop_loss_recovery\' = reimbursement under stop-loss provisions; \'risk_pool_settlement\' = periodic risk pool distribution or withhold settlement.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorPeriodAdjustmentFlag rdf:type rdf:Property ;
    rdfs:label 'Prior Period Adjustment Flag' ;
    rdfs:comment 'Indicates whether this capitation payment includes or represents an adjustment to a prior payment period. True when the payment corrects or supplements a previously issued capitation payment due to retroactive enrollment changes or rate corrections.' ;
    rdfs:domain ind:CapitationPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:qualityWithholdAmount rdf:type rdf:Property ;
    rdfs:label 'Quality Withhold Amount' ;
    rdfs:comment 'Amount withheld from the capitation payment pending achievement of quality performance targets (e.g., HEDIS measures, STAR ratings thresholds). Released or forfeited at the end of the performance measurement period based on provider quality scores.' ;
    rdfs:domain ind:CapitationPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:remittanceAdviceNumber rdf:type rdf:Property ;
    rdfs:label 'Remittance Advice Number' ;
    rdfs:comment 'Reference number of the 835 Electronic Remittance Advice (ERA) transaction sent to the provider for this capitation payment. Used to reconcile capitation disbursements with provider accounts receivable and the EDI clearinghouse (Availity/Change Healthcare) transaction log.' ;
    rdfs:domain ind:CapitationPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskAdjustedPmpmRate rdf:type rdf:Property ;
    rdfs:label 'Risk Adjusted Pmpm Rate' ;
    rdfs:comment 'PMPM rate after application of the risk adjustment factor (RAF score) to the base contractual PMPM rate. Reflects the risk-adjusted capitation amount per member per month for Medicare Advantage or risk-adjusted commercial arrangements.' ;
    rdfs:domain ind:CapitationPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:riskPoolWithholdAmount rdf:type rdf:Property ;
    rdfs:label 'Risk Pool Withhold Amount' ;
    rdfs:comment 'Amount withheld from the gross capitation payment and placed into a shared risk pool per the contract terms. Risk pool withholds are held and distributed (or forfeited) at the end of the risk settlement period based on actual utilization versus targets.' ;
    rdfs:domain ind:CapitationPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:riskScore rdf:type rdf:Property ;
    rdfs:label 'Risk Score' ;
    rdfs:comment 'Aggregate Risk Adjustment Factor (RAF) score for the attributed member population used to adjust the capitation rate for this payment period. Derived from Hierarchical Condition Category (HCC) coding and CMS Risk Adjustment Processing System (RAPS/EDPS) submissions.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemPaymentReference rdf:type rdf:Property ;
    rdfs:label 'Source System Payment Reference' ;
    rdfs:comment 'Native identifier of this capitation payment record in the originating operational system (Facets, QNXT, or HealthEdge). Used for cross-system reconciliation and data lineage tracing between the Silver Layer and the system of record.' ;
    rdfs:domain ind:CapitationPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stopLossRecoveryAmount rdf:type rdf:Property ;
    rdfs:label 'Stop Loss Recovery Amount' ;
    rdfs:comment 'Amount recovered from or credited to the provider under stop-loss provisions of the capitation contract. Positive values indicate plan reimbursement to provider for catastrophic cases exceeding the stop-loss threshold; negative values indicate provider liability adjustments.' ;
    rdfs:domain ind:CapitationPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vbcContractFlag rdf:type rdf:Property ;
    rdfs:label 'Vbc Contract Flag' ;
    rdfs:comment 'Indicates whether this capitation payment is made under a Value-Based Care (VBC) or Accountable Care Organization (ACO) contract arrangement, as opposed to a standard fee-for-service capitation. Drives VBC performance reporting and quality incentive calculations.' ;
    rdfs:domain ind:CapitationPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:voidReason rdf:type rdf:Property ;
    rdfs:label 'Void Reason' ;
    rdfs:comment 'Business reason code or description explaining why this capitation payment was voided or reversed. Populated only when payment_status is \'voided\' or \'reversed\'. Examples: contract_termination, duplicate_payment, enrollment_error, rate_correction.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vbcProgramId rdf:type rdf:Property ;
    rdfs:label 'Vbc Program Id' ;
    rdfs:comment 'Foreign key linking to network.vbc_program. Business justification: Every VBC contract (MSSP, BPCI, direct contracting) is instantiated under a specific VBC program that defines benchmark methodology, quality measure sets, and risk model. vbc_contract has no FK to vbc' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VbcProgram .

ind:acoCmsIdentifier rdf:type rdf:Property ;
    rdfs:label 'Aco Cms Identifier' ;
    rdfs:comment 'CMS-assigned unique identifier for the ACO participating in the Medicare Shared Savings Program (MSSP) or other CMS Innovation Center models. Required for RAPS/EDPS submissions and CMS regulatory reporting.' ;
    rdfs:domain ind:VbcContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualExpenditure rdf:type rdf:Property ;
    rdfs:label 'Actual Expenditure' ;
    rdfs:comment 'Total actual claims expenditure (in USD) incurred by attributed members or episode participants during the performance period. Compared against the benchmark expenditure target to determine shared savings or shared loss amounts.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:amendmentEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Amendment Effective Date' ;
    rdfs:comment 'Date on which the most recent contract amendment became effective. Used to determine which contract terms apply to claims and reconciliation calculations for a given service date.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:attributionMethodology rdf:type rdf:Property ;
    rdfs:label 'Attribution Methodology' ;
    rdfs:comment 'Method used to assign health plan members to this VBC contract/ACO entity for performance measurement. Prospective: members assigned at start of period based on prior utilization; Retrospective: members assigned at end of period based on actual utilization; Voluntary: member elects assignment.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:benchmarkExpenditureTarget rdf:type rdf:Property ;
    rdfs:label 'Benchmark Expenditure Target' ;
    rdfs:comment 'The risk-adjusted, trend-adjusted target expenditure amount (in USD) against which actual expenditures are compared during reconciliation. Calculated using historical claims data, risk scores (HCC/RAF), and applicable trend factors per the contract methodology.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cmsProgramTrack rdf:type rdf:Property ;
    rdfs:label 'Cms Program Track' ;
    rdfs:comment 'Specific CMS Innovation Center program track or model under which this contract operates (e.g., \'MSSP_BASIC_A\', \'MSSP_BASIC_E\', \'MSSP_ENHANCED\', \'BPCI_A\', \'CJR\', \'PCF\'). Null for commercial VBC contracts not affiliated with a CMS program. [ENUM-REF-CANDIDATE: MSSP_BASIC_A|MSSP_BASIC_B|MSSP_BASIC_C|MSSP_BASIC_D|MSSP_BASIC_E|MSSP_ENHANCED|BPCI_A|CJR|PCF|DCE — promote to reference product]' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractAmendmentNumber rdf:type rdf:Property ;
    rdfs:label 'Contract Amendment Number' ;
    rdfs:comment 'Sequential identifier for the most recent amendment to this VBC contract (e.g., \'AMD-003\'). Tracks contract modifications including rate changes, term extensions, quality measure updates, and risk arrangement adjustments. Null for original, unamended contracts.' ;
    rdfs:domain ind:VbcContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:episodeTargetPrice rdf:type rdf:Property ;
    rdfs:label 'Episode Target Price' ;
    rdfs:comment 'The risk-adjusted target price (in USD) for a single bundled payment episode. Calculated from historical claims data with applicable discounts and trend adjustments. Actual episode expenditures are compared to this target for reconciliation. Null for non-bundled VBC models.' ;
    rdfs:domain ind:VbcContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:episodeTriggerCode rdf:type rdf:Property ;
    rdfs:label 'Episode Trigger Code' ;
    rdfs:comment 'The CPT procedure code or DRG (Diagnosis Related Group) code that initiates a bundled payment episode. For example, DRG 470 triggers a major joint replacement episode under BPCI-A. Null for non-bundled VBC models.' ;
    rdfs:domain ind:VbcContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:episodeType rdf:type rdf:Property ;
    rdfs:label 'Episode Type' ;
    rdfs:comment 'For bundled payment contracts, the clinical episode category being bundled (e.g., \'joint_replacement\', \'cardiac_surgery\', \'maternity\', \'hip_fracture\', \'spinal_fusion\'). Null for non-bundled VBC models. Determines the trigger event, episode window, and target price methodology. [ENUM-REF-CANDIDATE: joint_replacement|cardiac_surgery|maternity|hip_fracture|spinal_fusion|pneumonia|copd|stroke — promote to reference product]' ;
    rdfs:domain ind:VbcContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:episodeWindowDays rdf:type rdf:Property ;
    rdfs:label 'Episode Window Days' ;
    rdfs:comment 'Total number of days in the bundled payment episode window, measured from the trigger event (e.g., 90 days post-discharge for BPCI-A). Defines the period during which all included services are attributed to the bundle for reconciliation.' ;
    rdfs:domain ind:VbcContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hedisMeasureTargets rdf:type rdf:Property ;
    rdfs:label 'Hedis Measure Targets' ;
    rdfs:comment 'Pipe-delimited list of HEDIS or CMS STAR measure identifiers and their contractual target thresholds included as quality gate requirements for this VBC contract (e.g., \'CBP:75.0|CDC-HbA1c:80.0|W34:85.0\'). Supports quality performance monitoring and NCQA reporting.' ;
    rdfs:domain ind:VbcContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxSharedLossRate rdf:type rdf:Property ;
    rdfs:label 'Max Shared Loss Rate' ;
    rdfs:comment 'The maximum percentage of benchmark expenditure (expressed as a decimal) that can be assessed as shared loss against the ACO/provider entity. Caps the provider\'s downside financial exposure in two-sided risk arrangements.' ;
    rdfs:domain ind:VbcContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxSharedSavingsRate rdf:type rdf:Property ;
    rdfs:label 'Max Shared Savings Rate' ;
    rdfs:comment 'The maximum percentage of benchmark expenditure (expressed as a decimal) that can be distributed as shared savings to the ACO/provider entity, regardless of actual savings achieved. Caps the health plan\'s financial exposure on the upside.' ;
    rdfs:domain ind:VbcContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumLossRate rdf:type rdf:Property ;
    rdfs:label 'Minimum Loss Rate' ;
    rdfs:comment 'The minimum percentage threshold (expressed as a decimal) by which actual expenditures must exceed the benchmark before any shared loss is assessed. Applicable to two-sided risk arrangements. Symmetric counterpart to the Minimum Savings Rate (MSR).' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumSavingsRate rdf:type rdf:Property ;
    rdfs:label 'Minimum Savings Rate' ;
    rdfs:comment 'The minimum percentage threshold (expressed as a decimal, e.g., 0.02 = 2%) by which actual expenditures must fall below the benchmark before any shared savings are distributed. Protects against random variation triggering unearned payments. Required field for MSSP Track 1 and Track 1+ contracts.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:performancePeriodEnd rdf:type rdf:Property ;
    rdfs:label 'Performance Period End' ;
    rdfs:comment 'End date of the current performance measurement period. Marks the close of the measurement window after which actual expenditures are compared to the benchmark target for reconciliation and settlement.' ;
    rdfs:domain ind:VbcContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:performancePeriodStart rdf:type rdf:Property ;
    rdfs:label 'Performance Period Start' ;
    rdfs:comment 'Start date of the current performance measurement period for this VBC contract. Defines the window during which attributed member expenditures, quality scores, and utilization are measured against the benchmark.' ;
    rdfs:domain ind:VbcContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:performanceYear rdf:type rdf:Property ;
    rdfs:label 'Performance Year' ;
    rdfs:comment 'Calendar or contract year for which performance is being measured and reconciled under this VBC contract. Used to track year-over-year performance trends, benchmark updates, and quality score progression. Typically a 4-digit year (e.g., 2024).' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:qualityGateMet rdf:type rdf:Property ;
    rdfs:label 'Quality Gate Met' ;
    rdfs:comment 'Indicates whether the ACO/provider entity met the minimum quality performance threshold (quality gate) required to be eligible for shared savings distribution. True = quality gate satisfied; False = quality gate not met, shared savings withheld or reduced.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:qualityScore rdf:type rdf:Property ;
    rdfs:label 'Quality Score' ;
    rdfs:comment 'Composite quality performance score (expressed as a decimal percentage, e.g., 0.85 = 85%) achieved by the ACO/provider entity during the performance period. Derived from HEDIS measures, STAR ratings, or contract-specific quality metrics. May gate or adjust shared savings distribution.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reconciliationMethodology rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Methodology' ;
    rdfs:comment 'Approach used to calculate and settle financial performance under this VBC contract. Prospective: target price set in advance; Retrospective: actual costs compared to historical benchmark after the period; Hybrid: combination of prospective target with retrospective quality adjustment.' ;
    rdfs:domain ind:VbcContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reconciliationStatus rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Status' ;
    rdfs:comment 'Current status of the financial reconciliation process for the performance period. Tracks the lifecycle from initial calculation through dispute resolution to final settlement: pending (not yet started), in_progress (under calculation), completed (finalized), disputed (under appeal), settled (payment processed).' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskArrangementType rdf:type rdf:Property ;
    rdfs:label 'Risk Arrangement Type' ;
    rdfs:comment 'Specifies the financial risk-sharing structure between the health plan and the provider/ACO entity. Upside_only: provider shares in savings only; two_sided: provider shares in both savings and losses; full_risk: provider assumes full financial risk (global capitation); partial_risk: provider assumes a defined portion of risk.' ;
    rdfs:domain ind:VbcContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskCorridorLower rdf:type rdf:Property ;
    rdfs:label 'Risk Corridor Lower' ;
    rdfs:comment 'Lower bound of the risk corridor (expressed as a decimal percentage below benchmark) within which no financial settlement occurs. Protects both parties from small random expenditure variations. Equivalent to the Minimum Savings Rate in MSSP terminology.' ;
    rdfs:domain ind:VbcContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:riskCorridorUpper rdf:type rdf:Property ;
    rdfs:label 'Risk Corridor Upper' ;
    rdfs:comment 'Upper bound of the risk corridor (expressed as a decimal percentage above benchmark) beyond which the health plan absorbs excess losses (stop-loss protection). Limits the provider\'s maximum financial exposure in two-sided risk arrangements.' ;
    rdfs:domain ind:VbcContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:savingsSharingRate rdf:type rdf:Property ;
    rdfs:label 'Savings Sharing Rate' ;
    rdfs:comment 'The percentage (expressed as a decimal, e.g., 0.50 = 50%) of qualifying shared savings that is distributed to the ACO/provider entity. Negotiated contractually and may vary by quality score tier or performance band.' ;
    rdfs:domain ind:VbcContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:settlementDate rdf:type rdf:Property ;
    rdfs:label 'Settlement Date' ;
    rdfs:comment 'Date on which the shared savings distribution or shared loss recoupment payment was or is scheduled to be processed. Used for financial accrual, IBNR reserve release, and cash flow reporting.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sharedSavingsAmount rdf:type rdf:Property ;
    rdfs:label 'Shared Savings Amount' ;
    rdfs:comment 'Net shared savings (positive) or shared loss (negative) amount in USD calculated after reconciliation. Represents the financial settlement due to or owed by the ACO/provider entity based on performance against the benchmark. Positive = savings distribution; negative = loss recoupment.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stopLossThreshold rdf:type rdf:Property ;
    rdfs:label 'Stop Loss Threshold' ;
    rdfs:comment 'Maximum dollar amount of shared loss that the ACO/provider entity is obligated to repay in a given performance period. Provides downside protection and is a key negotiated term in two-sided risk VBC contracts.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vbcModelType rdf:type rdf:Property ;
    rdfs:label 'Vbc Model Type' ;
    rdfs:comment 'Classification of the VBC payment model governing this contract. Determines the financial risk structure and reconciliation methodology: shared_savings (upside only), shared_risk (two-sided), full_capitation (global budget), bundled_payment (episode-based), pay_for_performance (quality incentive). [ENUM-REF-CANDIDATE: shared_savings|shared_risk|full_capitation|bundled_payment|pay_for_performance|global_budget — promote to reference product if additional models are needed]' ;
    rdfs:domain ind:VbcContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vbcPerformancePeriodId rdf:type rdf:Property ;
    rdfs:label 'Vbc Performance Period Id' ;
    rdfs:comment 'Unique surrogate identifier for a VBC performance period record within the contract domain. Primary key for this entity.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VbcPerformancePeriod .

ind:cmsSubmissionId rdf:type rdf:Property ;
    rdfs:label 'Cms Submission Id' ;
    rdfs:comment 'Foreign key linking to risk.risk_cms_submission. Business justification: VBC performance period settlement requires CMS data submissions for reconciliation. Linking vbc_performance_period to risk_cms_submission enables tracking of which CMS submission (EDPS/RAPS) correspon' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CmsSubmission .

ind:rapsSubmissionId rdf:type rdf:Property ;
    rdfs:label 'Raps Submission Id' ;
    rdfs:comment 'Foreign key linking to risk.raps_submission. Business justification: VBC performance period reconciliation under CMS programs (MSSP, CMMI) depends on RAPS/EDPS risk adjustment submissions that establish the risk-adjusted benchmark. Linking vbc_performance_period to rap' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RapsSubmission .

ind:acoIdentifier rdf:type rdf:Property ;
    rdfs:label 'Aco Identifier' ;
    rdfs:comment 'Reference to the Accountable Care Organization (ACO) participating in this performance period. Supports CMS MSSP and commercial ACO reporting.' ;
    rdfs:domain ind:VbcPerformancePeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualPmpm rdf:type rdf:Property ;
    rdfs:label 'Actual Pmpm' ;
    rdfs:comment 'Actual expenditure expressed on a Per Member Per Month (PMPM) basis in USD. Compared against benchmark PMPM to assess cost efficiency of the ACO or provider entity.' ;
    rdfs:domain ind:VbcPerformancePeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:appealDeadlineDate rdf:type rdf:Property ;
    rdfs:label 'Appeal Deadline Date' ;
    rdfs:comment 'Contractual or regulatory deadline by which the ACO or provider entity must file a formal appeal of the reconciliation results for this performance period.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:benchmarkPmpm rdf:type rdf:Property ;
    rdfs:label 'Benchmark Pmpm' ;
    rdfs:comment 'Benchmark expenditure expressed on a Per Member Per Month (PMPM) basis in USD. Normalizes the benchmark for population size and enables cross-period and cross-ACO comparisons.' ;
    rdfs:domain ind:VbcPerformancePeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:benchmarkUpdateMethod rdf:type rdf:Property ;
    rdfs:label 'Benchmark Update Method' ;
    rdfs:comment 'Methodology used to update or set the expenditure benchmark for this performance period (e.g., historical trend, regional average, blended, prospective). Affects benchmark accuracy and ACO incentive alignment.' ;
    rdfs:domain ind:VbcPerformancePeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cahpsCompositeScore rdf:type rdf:Property ;
    rdfs:label 'Cahps Composite Score' ;
    rdfs:comment 'Composite CAHPS survey score reflecting member experience with care during this performance period. Contributes to quality gate assessment and CMS Star Ratings.' ;
    rdfs:domain ind:VbcPerformancePeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cmsSubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Cms Submission Date' ;
    rdfs:comment 'Date on which performance period data was submitted to CMS for MSSP or other federal VBC program reporting. Required for regulatory compliance tracking.' ;
    rdfs:domain ind:VbcPerformancePeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:endDate rdf:type rdf:Property ;
    rdfs:label 'End Date' ;
    rdfs:comment 'Last date of the measurement period. Expenditures and quality events occurring on or before this date are included in the performance calculation.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:expenditureVariance rdf:type rdf:Property ;
    rdfs:label 'Expenditure Variance' ;
    rdfs:comment 'Difference between benchmark expenditure target and actual expenditure (in USD). Positive value indicates savings; negative value indicates losses. Drives shared savings or shared loss determination.' ;
    rdfs:domain ind:VbcPerformancePeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hccCaptureRate rdf:type rdf:Property ;
    rdfs:label 'Hcc Capture Rate' ;
    rdfs:comment 'Percentage of expected Hierarchical Condition Category (HCC) diagnoses that were documented and coded during the performance period. Impacts RAF score accuracy and benchmark integrity.' ;
    rdfs:domain ind:VbcPerformancePeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hedisCompositeScore rdf:type rdf:Property ;
    rdfs:label 'Hedis Composite Score' ;
    rdfs:comment 'Composite HEDIS measure score for the attributed population during this performance period. Contributes to the overall quality score and CMS quality reporting requirements.' ;
    rdfs:domain ind:VbcPerformancePeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ibnrReserveAmount rdf:type rdf:Property ;
    rdfs:label 'Ibnr Reserve Amount' ;
    rdfs:comment 'Actuarial reserve (in USD) for claims Incurred But Not Reported (IBNR) as of the performance period end date. Included in actual expenditure calculations to ensure completeness of cost measurement.' ;
    rdfs:domain ind:VbcPerformancePeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netSettlementAmount rdf:type rdf:Property ;
    rdfs:label 'Net Settlement Amount' ;
    rdfs:comment 'Final net dollar amount payable to or recoverable from the ACO or provider entity after applying shared savings, shared losses, quality adjustments, and any withholds. Positive = payment to provider; negative = recovery from provider.' ;
    rdfs:domain ind:VbcPerformancePeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentModel rdf:type rdf:Property ;
    rdfs:label 'Payment Model' ;
    rdfs:comment 'Reimbursement methodology governing this performance period. Determines how savings, losses, and risk are allocated between the health plan and the ACO or provider entity. [ENUM-REF-CANDIDATE: shared_savings|shared_risk|capitation|bundled|global_budget|fee_for_service — promote to reference product if additional models are needed]' ;
    rdfs:domain ind:VbcPerformancePeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:performancePeriodNumber rdf:type rdf:Property ;
    rdfs:label 'Performance Period Number' ;
    rdfs:comment 'Externally-known business identifier for this performance period, formatted as PP-YYYY-NNN. Used in CMS submissions, ACO reporting, and contract correspondence.' ;
    rdfs:domain ind:VbcPerformancePeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:periodStatus rdf:type rdf:Property ;
    rdfs:label 'Period Status' ;
    rdfs:comment 'Current lifecycle state of the performance period. Tracks progression from open measurement through reconciliation, settlement, and potential dispute resolution.' ;
    rdfs:domain ind:VbcPerformancePeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:periodType rdf:type rdf:Property ;
    rdfs:label 'Period Type' ;
    rdfs:comment 'Classification of the measurement period (e.g., annual, semi-annual, quarterly, interim, final). Determines the reconciliation cadence and reporting obligations.' ;
    rdfs:domain ind:VbcPerformancePeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorPeriodAdjustment rdf:type rdf:Property ;
    rdfs:label 'Prior Period Adjustment' ;
    rdfs:comment 'Dollar amount of adjustments applied to this performance period resulting from corrections or true-ups from a prior performance period. Positive = additional payment; negative = recovery.' ;
    rdfs:domain ind:VbcPerformancePeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rafScore rdf:type rdf:Property ;
    rdfs:label 'Raf Score' ;
    rdfs:comment 'Average Risk Adjustment Factor (RAF) score for the attributed population during this performance period. Reflects the relative health risk of the population and is used to normalize the benchmark expenditure target.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reconciliationDate rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Date' ;
    rdfs:comment 'Date on which the financial reconciliation calculation was completed and results were finalized for this performance period.' ;
    rdfs:domain ind:VbcPerformancePeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:riskModel rdf:type rdf:Property ;
    rdfs:label 'Risk Model' ;
    rdfs:comment 'Defines the risk-sharing arrangement for this period. One-sided models allow only shared savings; two-sided models expose the ACO to both savings and losses.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sharedLossAmount rdf:type rdf:Property ;
    rdfs:label 'Shared Loss Amount' ;
    rdfs:comment 'Calculated dollar amount of shared losses owed by the ACO or provider entity for this performance period (in USD). Positive value only; zero if loss threshold not met or one-sided model.' ;
    rdfs:domain ind:VbcPerformancePeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sharedLossRate rdf:type rdf:Property ;
    rdfs:label 'Shared Loss Rate' ;
    rdfs:comment 'The contractually agreed percentage of qualifying losses that the ACO or provider entity is liable to repay under two-sided risk arrangements. Expressed as a decimal (e.g., 0.30 = 30%).' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sharedSavingsRate rdf:type rdf:Property ;
    rdfs:label 'Shared Savings Rate' ;
    rdfs:comment 'The contractually agreed percentage of qualifying savings that is distributed to the ACO or provider entity. Expressed as a decimal (e.g., 0.50 = 50%). Varies by risk track and quality performance.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:starRating rdf:type rdf:Property ;
    rdfs:label 'Star Rating' ;
    rdfs:comment 'CMS Star Rating assigned to the health plan or ACO for this performance period. Influences quality bonus payments, shared savings eligibility, and member-facing plan comparisons.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:startDate rdf:type rdf:Property ;
    rdfs:label 'Start Date' ;
    rdfs:comment 'First date of the measurement period during which provider performance and expenditures are tracked against the benchmark target.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:withholdAmount rdf:type rdf:Property ;
    rdfs:label 'Withhold Amount' ;
    rdfs:comment 'Dollar amount withheld from shared savings distribution pending quality performance validation or regulatory review. Released upon satisfaction of quality gate or other contractual conditions.' ;
    rdfs:domain ind:VbcPerformancePeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:supersededPolicyReimbursementPolicyId rdf:type rdf:Property ;
    rdfs:label 'Superseded Policy Reimbursement Policy Id' ;
    rdfs:comment 'Reference to the prior reimbursement policy record that this policy replaces or supersedes. Enables policy lineage tracking and ensures historical adjudication records can be traced to the correct policy version.' ;
    rdfs:domain ind:ReimbursementPolicy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ReimbursementPolicy .

ind:appliesToFacility rdf:type rdf:Property ;
    rdfs:label 'Applies To Facility' ;
    rdfs:comment 'Indicates whether this reimbursement policy applies to facility (institutional) claims (CMS-1450/UB-04). When True, the policy is enforced on facility claims submitted via 837I transactions.' ;
    rdfs:domain ind:ReimbursementPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:appliesToProfessional rdf:type rdf:Property ;
    rdfs:label 'Applies To Professional' ;
    rdfs:comment 'Indicates whether this reimbursement policy applies to professional (physician) claims (CMS-1500). When True, the policy is enforced on professional claims submitted via 837P transactions.' ;
    rdfs:domain ind:ReimbursementPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:diagnosisCodeRequired rdf:type rdf:Property ;
    rdfs:label 'Diagnosis Code Required' ;
    rdfs:comment 'Indicates whether a specific ICD diagnosis code must be present on the claim for this reimbursement policy to apply. When True, the adjudication engine validates the presence of qualifying diagnosis codes before applying the policy.' ;
    rdfs:domain ind:ReimbursementPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:eobMessageCode rdf:type rdf:Property ;
    rdfs:label 'Eob Message Code' ;
    rdfs:comment 'Code referencing the EOB message displayed to members when a claim is adjusted or denied under this reimbursement policy. Ensures member-facing communications are clear and compliant with ACA transparency requirements.' ;
    rdfs:domain ind:ReimbursementPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facetsPolicyCode rdf:type rdf:Property ;
    rdfs:label 'Facets Policy Code' ;
    rdfs:comment 'System-specific policy code as configured in the Facets or QNXT core administration platform. Used to map this Silver Layer record back to the source adjudication system configuration for reconciliation and troubleshooting.' ;
    rdfs:domain ind:ReimbursementPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:globalSurgeryPeriodDays rdf:type rdf:Property ;
    rdfs:label 'Global Surgery Period Days' ;
    rdfs:comment 'Number of days in the global surgery package period during which related pre-operative and post-operative services are bundled into the surgical reimbursement. Standard CMS values are 0, 10, or 90 days. Applies only to global surgery policy types.' ;
    rdfs:domain ind:ReimbursementPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maxProceduresAllowed rdf:type rdf:Property ;
    rdfs:label 'Max Procedures Allowed' ;
    rdfs:comment 'Maximum number of procedures that can be reimbursed under this policy in a single claim or service encounter. Procedures exceeding this limit are denied or reduced per adjudication rules. Null indicates no limit.' ;
    rdfs:domain ind:ReimbursementPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:modifierCode rdf:type rdf:Property ;
    rdfs:label 'Modifier Code' ;
    rdfs:comment 'CPT or HCPCS modifier code associated with this reimbursement policy (e.g., 50=Bilateral, 51=Multiple Procedures, 80=Assistant Surgeon, 62=Two Surgeons). Triggers or qualifies the policy application during claims adjudication.' ;
    rdfs:domain ind:ReimbursementPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ncciEditType rdf:type rdf:Property ;
    rdfs:label 'Ncci Edit Type' ;
    rdfs:comment 'Indicates the NCCI edit category applicable to this reimbursement policy. Column 1/Column 2 edits identify procedure code pairs where one code is a component of another. Mutually exclusive edits identify code pairs that cannot be billed together. Used for unbundling policy enforcement.' ;
    rdfs:domain ind:ReimbursementPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overrideAllowed rdf:type rdf:Property ;
    rdfs:label 'Override Allowed' ;
    rdfs:comment 'Indicates whether a manual override of this reimbursement policy is permitted during claims adjudication (e.g., by a claims examiner or medical reviewer). When True, authorized users may bypass the policy with documented justification.' ;
    rdfs:domain ind:ReimbursementPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:overrideRequiresAuth rdf:type rdf:Property ;
    rdfs:label 'Override Requires Auth' ;
    rdfs:comment 'Indicates whether overriding this reimbursement policy requires a prior authorization (PA) or supervisory approval. When True, an authorization reference must be documented before the override is accepted in Facets/QNXT.' ;
    rdfs:domain ind:ReimbursementPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:policyDescription rdf:type rdf:Property ;
    rdfs:label 'Policy Description' ;
    rdfs:comment 'Detailed narrative description of the reimbursement policy, including the business rationale, adjudication logic, and any exceptions or special conditions. Used for provider communications, EOB narratives, and internal training documentation.' ;
    rdfs:domain ind:ReimbursementPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyName rdf:type rdf:Property ;
    rdfs:label 'Policy Name' ;
    rdfs:comment 'Human-readable name or title of the reimbursement policy (e.g., \'Multiple Procedure Reduction Policy\', \'Bilateral Procedure Policy\'). Used in provider communications, EOB narratives, and adjudication configuration.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyNumber rdf:type rdf:Property ;
    rdfs:label 'Policy Number' ;
    rdfs:comment 'Externally-known alphanumeric identifier for the reimbursement policy as referenced in Facets/QNXT and communicated to providers. Used for cross-system reconciliation and provider inquiries.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policySource rdf:type rdf:Property ;
    rdfs:label 'Policy Source' ;
    rdfs:comment 'Originating authority or source that defines this reimbursement policy. Distinguishes between federally mandated policies (CMS NCCI, MPPR), AMA CPT guidelines, state-mandated rules, and internally plan-defined or contract-specific policies.' ;
    rdfs:domain ind:ReimbursementPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyStatus rdf:type rdf:Property ;
    rdfs:label 'Policy Status' ;
    rdfs:comment 'Current lifecycle state of the reimbursement policy. Controls whether the policy is applied during claims adjudication in Facets/QNXT. Active policies are enforced; retired policies are retained for historical adjudication reference.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyType rdf:type rdf:Property ;
    rdfs:label 'Policy Type' ;
    rdfs:comment 'Categorical classification of the reimbursement policy governing how claims are adjudicated. Drives the adjudication logic applied in Facets/QNXT. [ENUM-REF-CANDIDATE: multiple_procedure_reduction|bilateral_procedure|assistant_surgeon|global_surgery|unbundling|place_of_service_differential|anesthesia|assistant_at_surgery|co_surgery|team_surgery|modifier_impact|site_of_service — promote to reference product]' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyVersion rdf:type rdf:Property ;
    rdfs:label 'Policy Version' ;
    rdfs:comment 'Version identifier for this reimbursement policy, incremented when the policy terms are amended (e.g., \'1.0\', \'2.3\'). Supports policy lifecycle management and historical adjudication audits by identifying which version was active at a given service date.' ;
    rdfs:domain ind:ReimbursementPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryProcedureRank rdf:type rdf:Property ;
    rdfs:label 'Primary Procedure Rank' ;
    rdfs:comment 'Ranking order used to determine which procedure is designated as the primary (highest-paid) procedure when multiple procedures are performed. The procedure with rank 1 is reimbursed at 100%; subsequent ranks receive the reduction percentage. Applies to multiple procedure reduction policies.' ;
    rdfs:domain ind:ReimbursementPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:providerSpecialtyCode rdf:type rdf:Property ;
    rdfs:label 'Provider Specialty Code' ;
    rdfs:comment 'CMS or NUCC provider specialty code restricting this reimbursement policy to a specific provider specialty (e.g., 02=General Surgery, 93=Radiation Oncology). Null indicates the policy applies to all specialties. Used for specialty-specific reimbursement rules.' ;
    rdfs:domain ind:ReimbursementPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reductionPct rdf:type rdf:Property ;
    rdfs:label 'Reduction Pct' ;
    rdfs:comment 'Percentage by which the allowed amount is reduced when this policy is triggered during claims adjudication. For example, a value of 50.00 indicates the secondary procedure is reimbursed at 50% of the contracted rate. Applies to policies such as multiple procedure reduction and assistant surgeon.' ;
    rdfs:domain ind:ReimbursementPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:retroactiveAdjustmentAllowed rdf:type rdf:Property ;
    rdfs:label 'Retroactive Adjustment Allowed' ;
    rdfs:comment 'Indicates whether this reimbursement policy can be applied retroactively to previously adjudicated claims when the policy is newly activated or amended. When True, claims reprocessing may be triggered for the applicable service date range.' ;
    rdfs:domain ind:ReimbursementPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:serviceScopeId rdf:type rdf:Property ;
    rdfs:label 'Service Scope Id' ;
    rdfs:comment 'Unique identifier for the service scope record. Primary key.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ServiceScope .

ind:practiceLocationId rdf:type rdf:Property ;
    rdfs:label 'Practice Location Id' ;
    rdfs:comment 'Foreign key linking to provider.practice_location. Business justification: Service scope can be site-specific — a provider may be authorized for certain services only at specific locations (e.g., telehealth at one site, surgery at another). Prior authorization and claims adj' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PracticeLocation .

ind:supersededByServiceScopeId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Service Scope Id' ;
    rdfs:comment 'Reference to the service scope record that supersedes this one, used to maintain historical lineage when scope definitions are updated or replaced.' ;
    rdfs:domain ind:ServiceScope ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ServiceScope .

ind:exclusionReason rdf:type rdf:Property ;
    rdfs:label 'Exclusion Reason' ;
    rdfs:comment 'Business rationale or regulatory reason for excluding specific services from the contract scope (e.g., experimental treatment, non-covered benefit, carved out to specialty vendor).' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:icdCodeRangeEnd rdf:type rdf:Property ;
    rdfs:label 'Icd Code Range End' ;
    rdfs:comment 'Ending ICD-10 diagnosis code in the range of diagnoses for which services are covered or excluded under this scope.' ;
    rdfs:domain ind:ServiceScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:icdCodeRangeStart rdf:type rdf:Property ;
    rdfs:label 'Icd Code Range Start' ;
    rdfs:comment 'Starting ICD-10 diagnosis code in the range of diagnoses for which services are covered or excluded under this scope.' ;
    rdfs:domain ind:ServiceScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inclusionExclusionFlag rdf:type rdf:Property ;
    rdfs:label 'Inclusion Exclusion Flag' ;
    rdfs:comment 'Indicates whether this scope definition specifies services that are included (covered) or excluded (not covered) under the contract.' ;
    rdfs:domain ind:ServiceScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reimbursementRatePct rdf:type rdf:Property ;
    rdfs:label 'Reimbursement Rate Pct' ;
    rdfs:comment 'Percentage of a reference fee schedule (e.g., Medicare, billed charges) used to calculate reimbursement for services within this scope. Applicable when payment methodology is percentage-based.' ;
    rdfs:domain ind:ServiceScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scopeCode rdf:type rdf:Property ;
    rdfs:label 'Scope Code' ;
    rdfs:comment 'Unique alphanumeric code identifying this service scope within the contract management system.' ;
    rdfs:domain ind:ServiceScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scopeDescription rdf:type rdf:Property ;
    rdfs:label 'Scope Description' ;
    rdfs:comment 'Detailed narrative description of the services included or excluded under this scope, including any special conditions, limitations, or clarifications.' ;
    rdfs:domain ind:ServiceScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scopeName rdf:type rdf:Property ;
    rdfs:label 'Scope Name' ;
    rdfs:comment 'Business-friendly name or title for this service scope definition.' ;
    rdfs:domain ind:ServiceScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scopeStatus rdf:type rdf:Property ;
    rdfs:label 'Scope Status' ;
    rdfs:comment 'Current lifecycle status of the service scope definition.' ;
    rdfs:domain ind:ServiceScope ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryDelegationPartyId rdf:type rdf:Property ;
    rdfs:label 'Primary Delegation Party Id' ;
    rdfs:comment 'Identifier of the health plan or entity delegating specific functions to another organization.' ;
    rdfs:domain ind:DelegationAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:supersededByDelegationAgreementId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Delegation Agreement Id' ;
    rdfs:comment 'Reference to the new delegation agreement that replaces this one when a new version is executed.' ;
    rdfs:domain ind:DelegationAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DelegationAgreement .

ind:agreementName rdf:type rdf:Property ;
    rdfs:label 'Agreement Name' ;
    rdfs:comment 'Descriptive name of the delegation agreement for business reference and reporting.' ;
    rdfs:domain ind:DelegationAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agreementNumber rdf:type rdf:Property ;
    rdfs:label 'Agreement Number' ;
    rdfs:comment 'Externally-known business identifier for the delegation agreement used in contracts and communications.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agreementStatus rdf:type rdf:Property ;
    rdfs:label 'Agreement Status' ;
    rdfs:comment 'Current lifecycle status of the delegation agreement indicating its operational state.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agreementType rdf:type rdf:Property ;
    rdfs:label 'Agreement Type' ;
    rdfs:comment 'Classification of the delegation arrangement based on scope and functions delegated.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cmsOversightRequired rdf:type rdf:Property ;
    rdfs:label 'Cms Oversight Required' ;
    rdfs:comment 'Indicates whether this delegation agreement requires Centers for Medicare and Medicaid Services (CMS) oversight and reporting for Medicare or Medicaid programs.' ;
    rdfs:domain ind:DelegationAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:delegateSignatoryName rdf:type rdf:Property ;
    rdfs:label 'Delegate Signatory Name' ;
    rdfs:comment 'Name of the authorized representative who signed the delegation agreement on behalf of the delegate entity.' ;
    rdfs:domain ind:DelegationAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:delegateSignatoryTitle rdf:type rdf:Property ;
    rdfs:label 'Delegate Signatory Title' ;
    rdfs:comment 'Title or position of the authorized representative who signed on behalf of the delegate entity.' ;
    rdfs:domain ind:DelegationAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:delegatedFunctionType rdf:type rdf:Property ;
    rdfs:label 'Delegated Function Type' ;
    rdfs:comment 'Specific function or set of functions delegated under this agreement. [ENUM-REF-CANDIDATE: credentialing|recredentialing|utilization_management|prior_authorization|claims_adjudication|claims_payment|member_services|care_management|disease_management|case_management|pharmacy_benefits|provider_network_management|quality_improvement|appeals_grievances — promote to reference product]' ;
    rdfs:domain ind:DelegationAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:delegatingSignatoryTitle rdf:type rdf:Property ;
    rdfs:label 'Delegating Signatory Title' ;
    rdfs:comment 'Title or position of the authorized representative who signed on behalf of the delegating entity.' ;
    rdfs:domain ind:DelegationAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialArrangementType rdf:type rdf:Property ;
    rdfs:label 'Financial Arrangement Type' ;
    rdfs:comment 'Type of financial arrangement governing payment to the delegate entity for delegated functions.' ;
    rdfs:domain ind:DelegationAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastAuditDate rdf:type rdf:Property ;
    rdfs:label 'Last Audit Date' ;
    rdfs:comment 'Date of the most recent delegation audit conducted by the delegating entity.' ;
    rdfs:domain ind:DelegationAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ncqaComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Ncqa Compliance Flag' ;
    rdfs:comment 'Indicates whether this delegation agreement meets National Committee for Quality Assurance (NCQA) delegation standards required for health plan accreditation.' ;
    rdfs:domain ind:DelegationAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nextAuditDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Audit Due Date' ;
    rdfs:comment 'Scheduled date for the next delegation audit to ensure ongoing compliance and performance monitoring.' ;
    rdfs:domain ind:DelegationAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:oversightRequirement rdf:type rdf:Property ;
    rdfs:label 'Oversight Requirement' ;
    rdfs:comment 'Detailed description of the delegating entity\'s oversight responsibilities, monitoring activities, and reporting requirements for the delegate.' ;
    rdfs:domain ind:DelegationAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:performanceStandard rdf:type rdf:Property ;
    rdfs:label 'Performance Standard' ;
    rdfs:comment 'Documented performance standards and quality metrics that the delegate entity must meet, including Healthcare Effectiveness Data and Information Set (HEDIS) measures, turnaround times, and accuracy thresholds.' ;
    rdfs:domain ind:DelegationAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryFilingRequired rdf:type rdf:Property ;
    rdfs:label 'Regulatory Filing Required' ;
    rdfs:comment 'Indicates whether this delegation agreement must be filed with state Department of Insurance (DOI) or other regulatory bodies.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:riskShareApplicable rdf:type rdf:Property ;
    rdfs:label 'Risk Share Applicable' ;
    rdfs:comment 'Indicates whether the delegation agreement includes risk-sharing arrangements between the delegating entity and delegate.' ;
    rdfs:domain ind:DelegationAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:terminationReason rdf:type rdf:Property ;
    rdfs:label 'Termination Reason' ;
    rdfs:comment 'Documented reason for termination of the delegation agreement, including performance issues, regulatory non-compliance, or mutual agreement.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:uracComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Urac Compliance Flag' ;
    rdfs:comment 'Indicates whether this delegation agreement meets URAC delegation standards for health care accreditation.' ;
    rdfs:domain ind:DelegationAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:incentiveArrangementId rdf:type rdf:Property ;
    rdfs:label 'Incentive Arrangement Id' ;
    rdfs:comment 'Unique identifier for the performance-linked financial arrangement within a provider contract. Primary key.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IncentiveArrangement .

ind:amountForfeited rdf:type rdf:Property ;
    rdfs:label 'Amount Forfeited' ;
    rdfs:comment 'Dollar amount of withheld funds forfeited by the provider due to failure to meet performance criteria. Expressed in USD.' ;
    rdfs:domain ind:IncentiveArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:amountReleased rdf:type rdf:Property ;
    rdfs:label 'Amount Released' ;
    rdfs:comment 'Dollar amount of withheld funds released back to the provider upon meeting performance criteria. Expressed in USD.' ;
    rdfs:domain ind:IncentiveArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:earnedStatus rdf:type rdf:Property ;
    rdfs:label 'Earned Status' ;
    rdfs:comment 'Indicates whether the provider has earned the incentive or withhold release based on performance evaluation results.' ;
    rdfs:domain ind:IncentiveArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumIncentiveAmount rdf:type rdf:Property ;
    rdfs:label 'Maximum Incentive Amount' ;
    rdfs:comment 'Maximum financial incentive or bonus amount that can be earned by the provider under this arrangement. Expressed in USD.' ;
    rdfs:domain ind:IncentiveArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maximumPenaltyAmount rdf:type rdf:Property ;
    rdfs:label 'Maximum Penalty Amount' ;
    rdfs:comment 'Maximum financial penalty that can be assessed against the provider for non-performance under this arrangement. Expressed in USD.' ;
    rdfs:domain ind:IncentiveArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:measurementMethodology rdf:type rdf:Property ;
    rdfs:label 'Measurement Methodology' ;
    rdfs:comment 'Detailed description of how the target metric is calculated, including data sources, calculation formulas, exclusions, and measurement period definitions.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementPeriodEnd rdf:type rdf:Property ;
    rdfs:label 'Measurement Period End' ;
    rdfs:comment 'End date of the performance measurement period during which provider performance is evaluated against target metrics.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:measurementPeriodStart rdf:type rdf:Property ;
    rdfs:label 'Measurement Period Start' ;
    rdfs:comment 'Start date of the performance measurement period during which provider performance is evaluated against target metrics.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:payoutSchedule rdf:type rdf:Property ;
    rdfs:label 'Payout Schedule' ;
    rdfs:comment 'Frequency at which incentive payments or withhold releases are distributed to the provider.' ;
    rdfs:domain ind:IncentiveArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:performanceThresholdTier rdf:type rdf:Property ;
    rdfs:label 'Performance Threshold Tier' ;
    rdfs:comment 'Tiered performance level definition (e.g., bronze, silver, gold, platinum) that determines incentive payout or withhold release amounts.' ;
    rdfs:domain ind:IncentiveArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityMeasureSet rdf:type rdf:Property ;
    rdfs:label 'Quality Measure Set' ;
    rdfs:comment 'Identifies the quality measure framework used for performance evaluation (HEDIS, STAR, CAHPS, custom measures).' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingFrequency rdf:type rdf:Property ;
    rdfs:label 'Reporting Frequency' ;
    rdfs:comment 'Frequency at which performance reports are generated and shared with the provider for transparency and tracking purposes.' ;
    rdfs:domain ind:IncentiveArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaCommitment rdf:type rdf:Property ;
    rdfs:label 'Sla Commitment' ;
    rdfs:comment 'Specific service level agreement commitments that the provider must meet as part of this incentive arrangement (e.g., appointment availability, response time, member satisfaction).' ;
    rdfs:domain ind:IncentiveArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetMetric rdf:type rdf:Property ;
    rdfs:label 'Target Metric' ;
    rdfs:comment 'Specific performance metric or key performance indicator (KPI) that the provider must achieve (e.g., readmission rate, preventive care completion, cost per member per month).' ;
    rdfs:domain ind:IncentiveArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalWithheldAmount rdf:type rdf:Property ;
    rdfs:label 'Total Withheld Amount' ;
    rdfs:comment 'Total dollar amount withheld from provider reimbursement during the measurement period. Expressed in USD.' ;
    rdfs:domain ind:IncentiveArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:withholdPoolType rdf:type rdf:Property ;
    rdfs:label 'Withhold Pool Type' ;
    rdfs:comment 'Classification of the withhold pool indicating whether it is for quality performance, utilization management, risk-sharing, or a combined pool.' ;
    rdfs:domain ind:IncentiveArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:withholdReleaseCriteria rdf:type rdf:Property ;
    rdfs:label 'Withhold Release Criteria' ;
    rdfs:comment 'Business rules and conditions that must be met for withheld amounts to be released to the provider (quality gates, utilization targets, shared risk thresholds).' ;
    rdfs:domain ind:IncentiveArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractNetworkParticipationId rdf:type rdf:Property ;
    rdfs:label 'Contract Network Participation Id' ;
    rdfs:comment 'Unique identifier for the network participation record. Primary key for this entity.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ContractNetworkParticipation .

ind:acceptingNewPatientsFlag rdf:type rdf:Property ;
    rdfs:label 'Accepting New Patients Flag' ;
    rdfs:comment 'Indicator whether the provider is currently accepting new patient enrollments under this network participation arrangement.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:acoParticipantFlag rdf:type rdf:Property ;
    rdfs:label 'Aco Participant Flag' ;
    rdfs:comment 'Boolean indicator whether this provider participates in an ACO arrangement under this network participation for value-based care programs.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:claimsAdjudicationPriority rdf:type rdf:Property ;
    rdfs:label 'Claims Adjudication Priority' ;
    rdfs:comment 'Numeric priority ranking used by claims processing systems when multiple network participations exist for the same provider, with lower numbers indicating higher priority.' ;
    rdfs:domain ind:ContractNetworkParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:directoryPublicationFlag rdf:type rdf:Property ;
    rdfs:label 'Directory Publication Flag' ;
    rdfs:comment 'Boolean indicator whether this network participation should be published in member-facing provider directories and online search tools.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inNetworkFlag rdf:type rdf:Property ;
    rdfs:label 'In Network Flag' ;
    rdfs:comment 'Boolean indicator whether this provider is considered in-network for claims adjudication and member cost-sharing calculations.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:outOfNetworkFlag rdf:type rdf:Property ;
    rdfs:label 'Out Of Network Flag' ;
    rdfs:comment 'Boolean indicator whether this provider arrangement allows out-of-network benefits and reimbursement under specific circumstances.' ;
    rdfs:domain ind:ContractNetworkParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:participationNumber rdf:type rdf:Property ;
    rdfs:label 'Participation Number' ;
    rdfs:comment 'Business identifier for this network participation arrangement, used for operational reference and tracking.' ;
    rdfs:domain ind:ContractNetworkParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:participationStatus rdf:type rdf:Property ;
    rdfs:label 'Participation Status' ;
    rdfs:comment 'Current lifecycle status of the network participation arrangement indicating whether the provider is actively participating in the network.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pcpAssignmentEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Pcp Assignment Eligible Flag' ;
    rdfs:comment 'Boolean indicator whether this provider can be assigned as a Primary Care Physician for members in HMO or POS plans requiring PCP selection.' ;
    rdfs:domain ind:ContractNetworkParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priorAuthorizationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Prior Authorization Required Flag' ;
    rdfs:comment 'Indicator whether services from this provider under this network arrangement require prior authorization for coverage and payment.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:productLine rdf:type rdf:Property ;
    rdfs:label 'Product Line' ;
    rdfs:comment 'Health plan product type that this network participation covers, defining network access rules and referral requirements.' ;
    rdfs:domain ind:ContractNetworkParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityTierDesignation rdf:type rdf:Property ;
    rdfs:label 'Quality Tier Designation' ;
    rdfs:comment 'Quality performance tier assigned to this provider based on HEDIS, STAR, or other quality metrics, influencing network tier placement and incentives.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referralRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Referral Required Flag' ;
    rdfs:comment 'Indicator whether members must obtain a referral from their PCP to access this provider under the network participation terms.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:serviceAreaCounty rdf:type rdf:Property ;
    rdfs:label 'Service Area County' ;
    rdfs:comment 'County name or FIPS code defining the local geographic area covered by this network participation arrangement.' ;
    rdfs:domain ind:ContractNetworkParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceAreaZipCodes rdf:type rdf:Property ;
    rdfs:label 'Service Area Zip Codes' ;
    rdfs:comment 'Comma-separated list or range of ZIP codes where this network participation is valid for member access and claims processing.' ;
    rdfs:domain ind:ContractNetworkParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:telehealthEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Telehealth Eligible Flag' ;
    rdfs:comment 'Indicator whether this provider is eligible to deliver covered telehealth or virtual care services under this network participation.' ;
    rdfs:domain ind:ContractNetworkParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:acoParticipationFlag rdf:type rdf:Property ;
    rdfs:label 'Aco Participation Flag' ;
    rdfs:comment 'Indicates whether this network includes participation in ACO arrangements. True if ACO providers are part of the network, False otherwise.' ;
    rdfs:domain ind:Network ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cmsNetworkCode rdf:type rdf:Property ;
    rdfs:label 'Cms Network Code' ;
    rdfs:comment 'The unique identifier assigned by CMS for Medicare Advantage and Part D networks. Required for all Medicare networks. Format: one letter followed by five digits.' ;
    rdfs:domain ind:ProviderNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilityCount rdf:type rdf:Property ;
    rdfs:label 'Facility Count' ;
    rdfs:comment 'The number of hospitals, skilled nursing facilities, and other institutional providers in this network. Used for facility access adequacy assessments.' ;
    rdfs:domain ind:ProviderNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:geographicFootprint rdf:type rdf:Property ;
    rdfs:label 'Geographic Footprint' ;
    rdfs:comment 'Comma-separated list of states, counties, or service areas where this network operates. Defines the geographic scope of provider availability and member eligibility.' ;
    rdfs:domain ind:ProviderNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastAdequacyReviewDate rdf:type rdf:Property ;
    rdfs:label 'Last Adequacy Review Date' ;
    rdfs:comment 'The date of the most recent internal or regulatory network adequacy review. Used to track compliance with annual review requirements.' ;
    rdfs:domain ind:ProviderNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:memberEnrollmentCount rdf:type rdf:Property ;
    rdfs:label 'Member Enrollment Count' ;
    rdfs:comment 'The current number of members enrolled in plans associated with this network. Used for provider-to-member ratio calculations and capacity planning.' ;
    rdfs:domain ind:ProviderNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:networkAdequacyFilingDate rdf:type rdf:Property ;
    rdfs:label 'Network Adequacy Filing Date' ;
    rdfs:comment 'The date when the most recent network adequacy filing was submitted to CMS or state regulators. Required annually for Medicare Advantage and Exchange plans.' ;
    rdfs:domain ind:Network ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:networkAdequacyStatus rdf:type rdf:Property ;
    rdfs:label 'Network Adequacy Status' ;
    rdfs:comment 'Regulatory assessment of whether the network meets time-and-distance and provider-to-member ratio standards. Adequate (meets all standards), Deficient (fails standards), Conditional (approved with corrective action plan), Pending Review (under regulatory evaluation).' ;
    rdfs:domain ind:Network ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:networkCode rdf:type rdf:Property ;
    rdfs:label 'Network Code' ;
    rdfs:comment 'Short alphanumeric code used to identify the network in operational systems, claims processing, and provider directories. Externally-known business identifier.' ;
    rdfs:domain ind:ProviderNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:networkDescription rdf:type rdf:Property ;
    rdfs:label 'Network Description' ;
    rdfs:comment 'Detailed narrative description of the network\'s design, provider composition, geographic coverage, and unique features. Used in member materials and regulatory filings.' ;
    rdfs:domain ind:ProviderNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:networkDirectoryUrl rdf:type rdf:Property ;
    rdfs:label 'Network Directory Url' ;
    rdfs:comment 'The web URL where members and providers can access the online provider directory for this network. Required for ACA and Medicare Advantage compliance.' ;
    rdfs:domain ind:ProviderNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:networkName rdf:type rdf:Property ;
    rdfs:label 'Network Name' ;
    rdfs:comment 'The official business name of the provider network (e.g., \'HMO Narrow Network\', \'PPO Broad Network\', \'Medicare Advantage Network\'). Human-readable identifier used in member communications and plan documents.' ;
    rdfs:domain ind:ProviderNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:networkStatus rdf:type rdf:Property ;
    rdfs:label 'Network Status' ;
    rdfs:comment 'Current operational status of the provider network. Active (accepting enrollments and claims), Inactive (closed to new enrollments), Suspended (temporary hold), Pending (awaiting regulatory approval), Terminated (permanently closed).' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:networkType rdf:type rdf:Property ;
    rdfs:label 'Network Type' ;
    rdfs:comment 'The structural classification of the provider network. HMO (Health Maintenance Organization) requires PCP and referrals; PPO (Preferred Provider Organization) allows out-of-network access; EPO (Exclusive Provider Organization) no out-of-network except emergency; POS (Point of Service) hybrid model; HDHP (High Deductible Health Plan) network; ACO (Accountable Care Organization) value-based network.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextAdequacyReviewDate rdf:type rdf:Property ;
    rdfs:label 'Next Adequacy Review Date' ;
    rdfs:comment 'The scheduled date for the next network adequacy review. Typically annual for Medicare Advantage and Exchange networks.' ;
    rdfs:domain ind:ProviderNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:outOfNetworkCoverageFlag rdf:type rdf:Property ;
    rdfs:label 'Out Of Network Coverage Flag' ;
    rdfs:comment 'Indicates whether the network allows members to access out-of-network providers with cost-sharing. True for PPO and some POS networks, False for HMO and EPO.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pcpCount rdf:type rdf:Property ;
    rdfs:label 'Pcp Count' ;
    rdfs:comment 'The number of primary care physicians in this network. Key metric for network adequacy and member-to-PCP ratio calculations.' ;
    rdfs:domain ind:ProviderNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pcpRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Pcp Required Flag' ;
    rdfs:comment 'Indicates whether members enrolled in this network are required to select a primary care physician. True for HMO and POS networks, False for PPO and EPO.' ;
    rdfs:domain ind:ProviderNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:providerCount rdf:type rdf:Property ;
    rdfs:label 'Provider Count' ;
    rdfs:comment 'The total number of unique providers (physicians, facilities, ancillary) participating in this network. Used for network adequacy calculations and member communications.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:serviceAreaType rdf:type rdf:Property ;
    rdfs:label 'Service Area Type' ;
    rdfs:comment 'The geographic granularity at which this network is defined. Statewide (entire state), Regional (multi-county region), County (county-level), ZIP (ZIP code level), National (multi-state or nationwide).' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialistCount rdf:type rdf:Property ;
    rdfs:label 'Specialist Count' ;
    rdfs:comment 'The number of specialist physicians in this network. Used for specialty access adequacy assessments.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tierClassification rdf:type rdf:Property ;
    rdfs:label 'Tier Classification' ;
    rdfs:comment 'The tiering structure of the network for cost-sharing purposes. Tier 1 (lowest cost-sharing, narrow network), Tier 2 (moderate cost-sharing), Tier 3 (highest cost-sharing, broadest access), Single Tier (no tiering), Tiered (multi-tier structure).' ;
    rdfs:domain ind:ProviderNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:updatedBy rdf:type rdf:Property ;
    rdfs:label 'Updated By' ;
    rdfs:comment 'The user ID or system identifier of the person or process that last modified this network record. Used for audit and accountability.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:createdBy rdf:type rdf:Property ;
    rdfs:label 'Created By' ;
    rdfs:comment 'The user ID or system identifier of the person or process that created this network record. Used for audit and accountability.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coinsuranceDifferentialPercentage rdf:type rdf:Property ;
    rdfs:label 'Coinsurance Differential Percentage' ;
    rdfs:comment 'Percentage coinsurance differential for this tier. Used when cost_share_differential_type is coinsurance or hybrid. Null if not applicable.' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:copayDifferentialAmount rdf:type rdf:Property ;
    rdfs:label 'Copay Differential Amount' ;
    rdfs:comment 'Fixed dollar copay differential for this tier compared to baseline tier. Used when cost_share_differential_type is copay or hybrid. Null if not applicable.' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costShareDifferentialType rdf:type rdf:Property ;
    rdfs:label 'Cost Share Differential Type' ;
    rdfs:comment 'Type of cost-sharing differential applied to this tier (copay, coinsurance, deductible, hybrid, or none). Determines how member out-of-pocket (OOP) costs are calculated.' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deductibleAppliesFlag rdf:type rdf:Property ;
    rdfs:label 'Deductible Applies Flag' ;
    rdfs:comment 'Indicates whether the plan deductible applies to services rendered by providers in this tier before cost-sharing begins.' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:displayLabel rdf:type rdf:Property ;
    rdfs:label 'Display Label' ;
    rdfs:comment 'Member-facing display label for the tier shown in EOB, member portal, and Summary of Benefits and Coverage (SBC). May differ from internal tier name for clarity.' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilityTypeApplicability rdf:type rdf:Property ;
    rdfs:label 'Facility Type Applicability' ;
    rdfs:comment 'Defines which facility types this tier applies to (all, hospital, Skilled Nursing Facility (SNF), Durable Medical Equipment (DME), lab, imaging, pharmacy, home health, or custom list). Used to segment tier assignment rules by facility type. [ENUM-REF-CANDIDATE: all|hospital|snf|dme|lab|imaging|pharmacy|home_health|custom — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastUpdatedBy rdf:type rdf:Property ;
    rdfs:label 'Last Updated By' ;
    rdfs:comment 'User identifier or system account that last modified this network tier record.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Updated Timestamp' ;
    rdfs:comment 'Timestamp when this network tier record was last modified.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:memberSteerageIncentiveDescription rdf:type rdf:Property ;
    rdfs:label 'Member Steerage Incentive Description' ;
    rdfs:comment 'Description of any member steerage incentives or rewards offered for using providers in this tier (e.g., reduced cost-sharing, waived deductible, wellness credits).' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:networkAdequacyCreditFlag rdf:type rdf:Property ;
    rdfs:label 'Network Adequacy Credit Flag' ;
    rdfs:comment 'Indicates whether providers in this tier count toward CMS network adequacy standards and state Department of Insurance (DOI) access requirements.' ;
    rdfs:domain ind:Network ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:oopMaxAppliesFlag rdf:type rdf:Property ;
    rdfs:label 'Oop Max Applies Flag' ;
    rdfs:comment 'Indicates whether member cost-sharing for this tier counts toward the plan Maximum Out-of-Pocket (MOOP) limit.' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:qualityTierFlag rdf:type rdf:Property ;
    rdfs:label 'Quality Tier Flag' ;
    rdfs:comment 'Indicates whether this tier is designated as a quality tier based on HEDIS, STAR ratings, or other quality performance metrics.' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryFilingReference rdf:type rdf:Property ;
    rdfs:label 'Regulatory Filing Reference' ;
    rdfs:comment 'Reference number or identifier for the state Department of Insurance (DOI) or CMS filing that approved this tier structure. Used for compliance audit trails.' ;
    rdfs:domain ind:Network ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sbcDisclosureText rdf:type rdf:Property ;
    rdfs:label 'Sbc Disclosure Text' ;
    rdfs:comment 'Standardized disclosure text for this tier that appears in the Summary of Benefits and Coverage (SBC) document provided to members under ACA requirements.' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialtyApplicability rdf:type rdf:Property ;
    rdfs:label 'Specialty Applicability' ;
    rdfs:comment 'Defines which provider specialties this tier applies to (all, primary care only, specialist only, facility, ancillary, behavioral health, or custom list). Used to segment tier assignment rules by provider type. [ENUM-REF-CANDIDATE: all|primary_care|specialist|facility|ancillary|behavioral_health|custom — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tierCode rdf:type rdf:Property ;
    rdfs:label 'Tier Code' ;
    rdfs:comment 'Business identifier code for the network tier (e.g., TIER1, TIER2, TIER3, OON). Used in system integrations and member communications.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tierRank rdf:type rdf:Property ;
    rdfs:label 'Tier Rank' ;
    rdfs:comment 'Numeric ranking of the tier indicating preference and cost-share level. Lower rank indicates preferred tier with lower member cost-sharing (e.g., 1=Tier 1 Preferred, 2=Tier 2 Standard, 3=Tier 3 Specialty, 99=Out-of-Network).' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tierStatus rdf:type rdf:Property ;
    rdfs:label 'Tier Status' ;
    rdfs:comment 'Current lifecycle status of the network tier configuration (active, inactive, pending approval, suspended, or retired).' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tierType rdf:type rdf:Property ;
    rdfs:label 'Tier Type' ;
    rdfs:comment 'Classification of the tier indicating its strategic purpose within the network design (preferred, standard, specialty, out-of-network, value-based, narrow network).' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vbcArrangementEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Vbc Arrangement Eligible Flag' ;
    rdfs:comment 'Indicates whether this tier is eligible for Value-Based Care (VBC) or Accountable Care Organization (ACO) performance incentives and shared savings arrangements.' ;
    rdfs:domain ind:Tier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:accessibilityAdaCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Accessibility Ada Compliant Flag' ;
    rdfs:comment 'Boolean indicator of whether this provider\'s facilities meet ADA accessibility requirements for members with disabilities. True indicates ADA compliance.' ;
    rdfs:domain ind:NetworkProvider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:afterHoursAvailabilityFlag rdf:type rdf:Property ;
    rdfs:label 'After Hours Availability Flag' ;
    rdfs:comment 'Boolean indicator of whether this provider offers after-hours or extended-hours services to members of this network. True indicates after-hours availability.' ;
    rdfs:domain ind:NetworkProvider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:continuityOfCareEndDate rdf:type rdf:Property ;
    rdfs:label 'Continuity Of Care End Date' ;
    rdfs:comment 'The date through which existing members may continue to see this provider under in-network benefits after network termination, per continuity of care requirements.' ;
    rdfs:domain ind:NetworkProvider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:currentPanelSize rdf:type rdf:Property ;
    rdfs:label 'Current Panel Size' ;
    rdfs:comment 'The current number of members assigned to or served by this provider within this network.' ;
    rdfs:domain ind:NetworkProvider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:directoryLastVerifiedDate rdf:type rdf:Property ;
    rdfs:label 'Directory Last Verified Date' ;
    rdfs:comment 'The date on which the provider\'s directory information was last verified for accuracy. CMS requires quarterly verification.' ;
    rdfs:domain ind:NetworkProvider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:directoryListingFlag rdf:type rdf:Property ;
    rdfs:label 'Directory Listing Flag' ;
    rdfs:comment 'Boolean indicator of whether this provider should be included in the published provider directory for this network. True indicates directory inclusion.' ;
    rdfs:domain ind:NetworkProvider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:languageServicesAvailable rdf:type rdf:Property ;
    rdfs:label 'Language Services Available' ;
    rdfs:comment 'Comma-separated list of languages in which this provider offers services to members of this network, supporting cultural and linguistic access requirements.' ;
    rdfs:domain ind:NetworkProvider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:networkAdequacyCategory rdf:type rdf:Property ;
    rdfs:label 'Network Adequacy Category' ;
    rdfs:comment 'Classification of this provider\'s role in meeting network adequacy requirements. Essential indicates critical for minimum adequacy standards.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:panelCapacity rdf:type rdf:Property ;
    rdfs:label 'Panel Capacity' ;
    rdfs:comment 'The maximum number of members this provider can serve within this network. Used for network adequacy calculations.' ;
    rdfs:domain ind:NetworkProvider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:panelStatus rdf:type rdf:Property ;
    rdfs:label 'Panel Status' ;
    rdfs:comment 'Current status of the provider\'s patient panel for this network. Open indicates capacity for new members; closed indicates no capacity.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pcpFlag rdf:type rdf:Property ;
    rdfs:label 'Pcp Flag' ;
    rdfs:comment 'Boolean indicator of whether this provider serves as a Primary Care Provider within this network. True indicates PCP designation.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recordActiveFlag rdf:type rdf:Property ;
    rdfs:label 'Record Active Flag' ;
    rdfs:comment 'Boolean indicator of whether this network-provider association record is currently active in the system. False indicates a logically deleted or superseded record.' ;
    rdfs:domain ind:NetworkProvider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:riskSharingArrangementFlag rdf:type rdf:Property ;
    rdfs:label 'Risk Sharing Arrangement Flag' ;
    rdfs:comment 'Boolean indicator of whether this provider participates in risk-sharing financial arrangements within this network. True indicates risk-sharing participation.' ;
    rdfs:domain ind:NetworkProvider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:specialistFlag rdf:type rdf:Property ;
    rdfs:label 'Specialist Flag' ;
    rdfs:comment 'Boolean indicator of whether this provider is designated as a specialist within this network. True indicates specialist designation.' ;
    rdfs:domain ind:NetworkProvider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:telehealthAvailableFlag rdf:type rdf:Property ;
    rdfs:label 'Telehealth Available Flag' ;
    rdfs:comment 'Boolean indicator of whether this provider offers telehealth services to members of this network. True indicates telehealth availability.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:terminationInitiatedBy rdf:type rdf:Property ;
    rdfs:label 'Termination Initiated By' ;
    rdfs:comment 'Indicates which party initiated the termination of the provider\'s network participation. Null for active participation.' ;
    rdfs:domain ind:NetworkProvider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminationReasonCode rdf:type rdf:Property ;
    rdfs:label 'Termination Reason Code' ;
    rdfs:comment 'Code indicating the reason for termination of the provider\'s participation in this network. Null for active participation. [ENUM-REF-CANDIDATE: voluntary|contract_expiration|quality_issues|credentialing_failure|network_restructure|provider_request|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vbcParticipantFlag rdf:type rdf:Property ;
    rdfs:label 'Vbc Participant Flag' ;
    rdfs:comment 'Boolean indicator of whether this provider participates in value-based care arrangements within this network. True indicates VBC participation.' ;
    rdfs:domain ind:NetworkProvider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:weekendAvailabilityFlag rdf:type rdf:Property ;
    rdfs:label 'Weekend Availability Flag' ;
    rdfs:comment 'Boolean indicator of whether this provider offers weekend services to members of this network. True indicates weekend availability.' ;
    rdfs:domain ind:NetworkProvider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:planAssociationId rdf:type rdf:Property ;
    rdfs:label 'Plan Association Id' ;
    rdfs:comment 'Unique identifier for the plan association record. Primary key for this entity.' ;
    rdfs:domain ind:PlanAssociation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:networkServiceAreaId rdf:type rdf:Property ;
    rdfs:label 'Network Service Area Id' ;
    rdfs:comment 'Reference to the geographic service area where this plan-network association is valid. Defines the counties, ZIP codes, or regions where members can access this network under this plan.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NetworkServiceArea .

ind:adequacyCertificationDate rdf:type rdf:Property ;
    rdfs:label 'Adequacy Certification Date' ;
    rdfs:comment 'The date when this plan-network association was certified as meeting network adequacy requirements by the regulatory authority or internal compliance review.' ;
    rdfs:domain ind:PlanAssociation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:adequacyReviewDate rdf:type rdf:Property ;
    rdfs:label 'Adequacy Review Date' ;
    rdfs:comment 'The date of the most recent network adequacy review or assessment for this plan-network association. Used to track compliance monitoring cycles.' ;
    rdfs:domain ind:PlanAssociation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:associationCode rdf:type rdf:Property ;
    rdfs:label 'Association Code' ;
    rdfs:comment 'Business identifier code for this plan-to-network association, used in eligibility verification (270/271 EDI transactions) and claims adjudication routing.' ;
    rdfs:domain ind:PlanAssociation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:associationName rdf:type rdf:Property ;
    rdfs:label 'Association Name' ;
    rdfs:comment 'Human-readable name for this plan-to-network association, typically combining plan name and network name for operational reference.' ;
    rdfs:domain ind:PlanAssociation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:associationType rdf:type rdf:Property ;
    rdfs:label 'Association Type' ;
    rdfs:comment 'Classification of the network\'s role for this plan. Primary indicates the main network for member access; supplemental provides additional coverage; specialty covers specific service categories; out-of-area supports members outside primary service area; reciprocal represents shared network arrangements; tertiary provides fallback coverage.' ;
    rdfs:domain ind:PlanAssociation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:autoAssignmentEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Assignment Eligible Flag' ;
    rdfs:comment 'Indicates whether members can be automatically assigned to providers in this network under this plan. Relevant for Medicaid and some Medicare programs that use auto-assignment for members who do not actively select a provider. True means eligible for auto-assignment; false means member must actively select.' ;
    rdfs:domain ind:PlanAssociation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contractReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Contract Reference Number' ;
    rdfs:comment 'Reference to the master contract or agreement document that governs this plan-network association. Links to contract management systems for terms, rates, and legal provisions.' ;
    rdfs:domain ind:Network ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketSegment rdf:type rdf:Property ;
    rdfs:label 'Market Segment' ;
    rdfs:comment 'The market segment this plan-network association targets. Individual covers direct-to-consumer; small group typically 2-50 employees; large group 51-999 employees; jumbo group 1000+ employees; government includes federal and state employee plans; student covers university and college plans.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:memberCount rdf:type rdf:Property ;
    rdfs:label 'Member Count' ;
    rdfs:comment 'The number of members currently enrolled in this plan who have access to this network. Used for network adequacy calculations and capacity planning.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pcpSelectionRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Pcp Selection Required Flag' ;
    rdfs:comment 'Indicates whether members enrolled in this plan with this network must select a primary care provider. Typically true for HMO and POS plans; false for PPO and EPO plans.' ;
    rdfs:domain ind:PlanAssociation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:planAssociationStatus rdf:type rdf:Property ;
    rdfs:label 'Plan Association Status' ;
    rdfs:comment 'Current lifecycle status of the plan-network association. Active indicates operational; inactive means temporarily disabled; pending awaits regulatory approval or contract execution; suspended indicates temporary hold; terminated means permanently ended.' ;
    rdfs:domain ind:PlanAssociation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorityRank rdf:type rdf:Property ;
    rdfs:label 'Priority Rank' ;
    rdfs:comment 'Numeric ranking indicating the priority order of this network when multiple networks are associated with the same plan. Lower numbers indicate higher priority. Used in claims adjudication routing when a member has access to multiple networks.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:starRatingImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Star Rating Impact Flag' ;
    rdfs:comment 'Indicates whether provider performance in this network impacts the plan\'s CMS Star Ratings. Applicable primarily to Medicare Advantage plans. True means network performance affects Star metrics; false means no Star impact.' ;
    rdfs:domain ind:PlanAssociation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cmsServiceAreaCode rdf:type rdf:Property ;
    rdfs:label 'Cms Service Area Code' ;
    rdfs:comment 'CMS-assigned identifier for the service area, used in Medicare Advantage and Marketplace (QHP) filings.' ;
    rdfs:domain ind:NetworkServiceArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commercialApprovedFlag rdf:type rdf:Property ;
    rdfs:label 'Commercial Approved Flag' ;
    rdfs:comment 'Indicates whether this service area is approved for commercial (employer-sponsored and individual) plan enrollment.' ;
    rdfs:domain ind:NetworkServiceArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:countyFipsCode rdf:type rdf:Property ;
    rdfs:label 'County Fips Code' ;
    rdfs:comment 'Five-digit Federal Information Processing Standards code uniquely identifying the county. Null for non-county-based service areas.' ;
    rdfs:domain ind:NetworkServiceArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countyName rdf:type rdf:Property ;
    rdfs:label 'County Name' ;
    rdfs:comment 'Name of the county included in this service area. Null for non-county-based service areas.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicBoundaryDescription rdf:type rdf:Property ;
    rdfs:label 'Geographic Boundary Description' ;
    rdfs:comment 'Textual description of the service area boundaries, used for custom or complex geographic definitions not captured by standard codes.' ;
    rdfs:domain ind:NetworkServiceArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:medicaidApprovedFlag rdf:type rdf:Property ;
    rdfs:label 'Medicaid Approved Flag' ;
    rdfs:comment 'Indicates whether this service area is approved for Medicaid managed care enrollment.' ;
    rdfs:domain ind:NetworkServiceArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:medicareAdvantageApprovedFlag rdf:type rdf:Property ;
    rdfs:label 'Medicare Advantage Approved Flag' ;
    rdfs:comment 'Indicates whether this service area is approved for Medicare Advantage plan enrollment.' ;
    rdfs:domain ind:NetworkServiceArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:memberResidencyRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Member Residency Required Flag' ;
    rdfs:comment 'Indicates whether members must reside within this service area to be eligible for enrollment in the associated network.' ;
    rdfs:domain ind:NetworkServiceArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:msaCode rdf:type rdf:Property ;
    rdfs:label 'Msa Code' ;
    rdfs:comment 'Five-digit code identifying the Metropolitan Statistical Area. Null for non-MSA-based service areas.' ;
    rdfs:domain ind:NetworkServiceArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:msaName rdf:type rdf:Property ;
    rdfs:label 'Msa Name' ;
    rdfs:comment 'Name of the Metropolitan Statistical Area (e.g., \'San Francisco-Oakland-Hayward, CA\'). Null for non-MSA-based service areas.' ;
    rdfs:domain ind:NetworkServiceArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:networkAdequacyApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Network Adequacy Approval Date' ;
    rdfs:comment 'Date when the network adequacy filing was approved by CMS or the state Department of Insurance for this service area.' ;
    rdfs:domain ind:NetworkServiceArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:networkServiceAreaStatus rdf:type rdf:Property ;
    rdfs:label 'Network Service Area Status' ;
    rdfs:comment 'Current lifecycle status of the service area: active (available for enrollment), inactive (not available), pending approval (awaiting regulatory approval), suspended (temporarily unavailable), or terminated (permanently closed).' ;
    rdfs:domain ind:NetworkServiceArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outOfAreaCoverageAllowedFlag rdf:type rdf:Property ;
    rdfs:label 'Out Of Area Coverage Allowed Flag' ;
    rdfs:comment 'Indicates whether the plan allows coverage for services received outside this service area (e.g., for travel or temporary relocation).' ;
    rdfs:domain ind:NetworkServiceArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:populationCount rdf:type rdf:Property ;
    rdfs:label 'Population Count' ;
    rdfs:comment 'Estimated total population residing in this service area, used for network adequacy calculations and market sizing.' ;
    rdfs:domain ind:NetworkServiceArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:qhpApprovedFlag rdf:type rdf:Property ;
    rdfs:label 'Qhp Approved Flag' ;
    rdfs:comment 'Indicates whether this service area is approved for Qualified Health Plan (Marketplace/Exchange) enrollment under the Affordable Care Act.' ;
    rdfs:domain ind:NetworkServiceArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:serviceAreaCode rdf:type rdf:Property ;
    rdfs:label 'Service Area Code' ;
    rdfs:comment 'Business identifier for the service area, used in contracts, filings, and member communications.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceAreaName rdf:type rdf:Property ;
    rdfs:label 'Service Area Name' ;
    rdfs:comment 'Human-readable name of the service area (e.g., \'Northern California Region\', \'Metro Atlanta Service Area\').' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:urbanRuralDesignation rdf:type rdf:Property ;
    rdfs:label 'Urban Rural Designation' ;
    rdfs:comment 'Classification of the service area as urban, suburban, rural, frontier (very low population density), or mixed.' ;
    rdfs:domain ind:NetworkServiceArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adequacyStandardId rdf:type rdf:Property ;
    rdfs:label 'Adequacy Standard Id' ;
    rdfs:comment 'Unique identifier for the network adequacy standard record. Primary key.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AdequacyStandard .

ind:adequacyStandardStatus rdf:type rdf:Property ;
    rdfs:label 'Adequacy Standard Status' ;
    rdfs:comment 'Current lifecycle status of this adequacy standard: active (currently enforced), inactive (not currently enforced), proposed (pending regulatory approval), superseded (replaced by newer standard), or under-review (being evaluated for changes).' ;
    rdfs:domain ind:AdequacyStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:afterHoursAvailabilityRequired rdf:type rdf:Property ;
    rdfs:label 'After Hours Availability Required' ;
    rdfs:comment 'Indicates whether after-hours availability (evenings, weekends, holidays) is required for this specialty and geography. True if after-hours access is mandated, false otherwise.' ;
    rdfs:domain ind:AdequacyStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:afterHoursDefinition rdf:type rdf:Property ;
    rdfs:label 'After Hours Definition' ;
    rdfs:comment 'Definition of what constitutes after-hours for this standard (e.g., weekdays after 5pm, weekends, 24/7 access). Null if after-hours availability is not required.' ;
    rdfs:domain ind:AdequacyStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appointmentType rdf:type rdf:Property ;
    rdfs:label 'Appointment Type' ;
    rdfs:comment 'Type of appointment this wait-time standard applies to: routine (non-urgent care), urgent (same-day/next-day need), preventive (wellness visits), behavioral-health (mental health/substance abuse), specialist (referral appointments), or emergency. Null if standard is not appointment-access based.' ;
    rdfs:domain ind:AdequacyStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceReportingFrequency rdf:type rdf:Property ;
    rdfs:label 'Compliance Reporting Frequency' ;
    rdfs:comment 'How often compliance with this standard must be assessed and reported to regulators: annual, semi-annual, quarterly, monthly, or on-demand (event-triggered).' ;
    rdfs:domain ind:AdequacyStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionCriteria rdf:type rdf:Property ;
    rdfs:label 'Exception Criteria' ;
    rdfs:comment 'Conditions under which an exception or waiver to this standard may be granted (e.g., provider shortage area designation, rural exception, temporary hardship). Null if no exceptions allowed.' ;
    rdfs:domain ind:Network ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicClassification rdf:type rdf:Property ;
    rdfs:label 'Geographic Classification' ;
    rdfs:comment 'Geographic area classification for which this standard applies: urban (metropolitan areas), suburban (surrounding metro areas), rural (non-metropolitan), or frontier (very low population density areas). Standards vary by geography.' ;
    rdfs:domain ind:AdequacyStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumDistanceMiles rdf:type rdf:Property ;
    rdfs:label 'Maximum Distance Miles' ;
    rdfs:comment 'Maximum allowable distance in miles from member residence to nearest in-network provider of this specialty in this geographic area. Null if standard is not distance-based.' ;
    rdfs:domain ind:AdequacyStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maximumTravelTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Maximum Travel Time Minutes' ;
    rdfs:comment 'Maximum allowable travel time in minutes from member residence to nearest in-network provider of this specialty in this geographic area. Null if standard is not time-based.' ;
    rdfs:domain ind:AdequacyStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maximumWaitTimeDays rdf:type rdf:Property ;
    rdfs:label 'Maximum Wait Time Days' ;
    rdfs:comment 'Maximum allowable wait time in days from appointment request to appointment date for this appointment type and specialty. Null if standard is not appointment-access based.' ;
    rdfs:domain ind:Network ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minimumProviderCount rdf:type rdf:Property ;
    rdfs:label 'Minimum Provider Count' ;
    rdfs:comment 'Absolute minimum number of providers of this specialty required in the network for this geography, regardless of member count. Null if not applicable.' ;
    rdfs:domain ind:AdequacyStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:penaltyForNonCompliance rdf:type rdf:Property ;
    rdfs:label 'Penalty For Non Compliance' ;
    rdfs:comment 'Description of regulatory penalties or consequences for failing to meet this standard (e.g., corrective action plan, fines, enrollment suspension, Star rating impact). Null if no specific penalty defined.' ;
    rdfs:domain ind:AdequacyStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planType rdf:type rdf:Property ;
    rdfs:label 'Plan Type' ;
    rdfs:comment 'Type of health plan this standard applies to: HMO (Health Maintenance Organization), PPO (Preferred Provider Organization), EPO (Exclusive Provider Organization), POS (Point of Service), HDHP (High Deductible Health Plan), or all (applies to all plan types). Standards may vary by plan structure.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:providerToMemberRatio rdf:type rdf:Property ;
    rdfs:label 'Provider To Member Ratio' ;
    rdfs:comment 'Required ratio of providers to members for this specialty and geography, expressed as ratio string (e.g., 1:2000 for PCPs, 1:5000 for specialists). Null if standard is not ratio-based.' ;
    rdfs:domain ind:AdequacyStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatorySource rdf:type rdf:Property ;
    rdfs:label 'Regulatory Source' ;
    rdfs:comment 'Governing body or regulatory authority that mandates this standard: CMS (Centers for Medicare and Medicaid Services), state-DOI (State Department of Insurance), NCQA (National Committee for Quality Assurance), URAC, ACA (Affordable Care Act), or internal (company-defined standard exceeding regulatory minimums).' ;
    rdfs:domain ind:Network ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialtyCategory rdf:type rdf:Property ;
    rdfs:label 'Specialty Category' ;
    rdfs:comment 'Provider specialty or facility type this standard applies to (e.g., PCP, cardiology, behavioral-health, hospital, SNF, DME). May be broad category or specific specialty code.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardCategory rdf:type rdf:Property ;
    rdfs:label 'Standard Category' ;
    rdfs:comment 'Classification of the adequacy standard type: time-distance (geographic access), provider-ratio (provider-to-member ratios), appointment-access (wait time standards), after-hours (availability requirements), telehealth-equivalency (virtual care standards), or network-composition (network mix requirements).' ;
    rdfs:domain ind:AdequacyStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardCode rdf:type rdf:Property ;
    rdfs:label 'Standard Code' ;
    rdfs:comment 'Business identifier code for the adequacy standard (e.g., PCP_URBAN_TIME, BH_RURAL_RATIO). Used for external reference and reporting.' ;
    rdfs:domain ind:Network ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardName rdf:type rdf:Property ;
    rdfs:label 'Standard Name' ;
    rdfs:comment 'Human-readable name of the adequacy standard (e.g., Primary Care Physician Urban Time-Distance Standard).' ;
    rdfs:domain ind:Network ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardVersion rdf:type rdf:Property ;
    rdfs:label 'Standard Version' ;
    rdfs:comment 'Version identifier for this standard, used to track changes over time (e.g., 2024.1, v3.0). Supports historical analysis and regulatory audit trails.' ;
    rdfs:domain ind:AdequacyStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:telehealthEquivalencyAllowed rdf:type rdf:Property ;
    rdfs:label 'Telehealth Equivalency Allowed' ;
    rdfs:comment 'Indicates whether telehealth/virtual care providers can be counted toward meeting this adequacy standard. True if telehealth equivalency is permitted, false if only in-person providers count.' ;
    rdfs:domain ind:AdequacyStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:telehealthPercentageCap rdf:type rdf:Property ;
    rdfs:label 'Telehealth Percentage Cap' ;
    rdfs:comment 'Maximum percentage of the adequacy requirement that can be met through telehealth providers (e.g., 25.00 means up to 25% of required providers can be telehealth-only). Null if no cap or telehealth not allowed.' ;
    rdfs:domain ind:AdequacyStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:thresholdPercentage rdf:type rdf:Property ;
    rdfs:label 'Threshold Percentage' ;
    rdfs:comment 'Percentage of members or geographic area that must meet this standard (e.g., 90.00 means 90% of members must have access within the specified time/distance). Used for compliance measurement.' ;
    rdfs:domain ind:AdequacyStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:adequacyAssessmentId rdf:type rdf:Property ;
    rdfs:label 'Adequacy Assessment Id' ;
    rdfs:comment 'Unique identifier for the network adequacy assessment record. Primary key.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AdequacyAssessment .

ind:accessStandardId rdf:type rdf:Property ;
    rdfs:label 'Access Standard Id' ;
    rdfs:comment 'Foreign key linking to network.access_standard. Business justification: adequacy_assessment evaluates both network adequacy (via adequacy_standard_id) and appointment access/availability compliance. The access_standard table defines appointment wait-time and availability ' ;
    rdfs:domain ind:Network ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AccessStandard .

ind:appointmentTypeRequested rdf:type rdf:Property ;
    rdfs:label 'Appointment Type Requested' ;
    rdfs:comment 'Type of appointment requested during mystery shopper or survey assessment: routine care, urgent care, preventive visit, follow-up visit, new patient intake, or specialist referral.' ;
    rdfs:domain ind:AdequacyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentDate rdf:type rdf:Property ;
    rdfs:label 'Assessment Date' ;
    rdfs:comment 'Date on which the network adequacy assessment was conducted or completed.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assessmentNumber rdf:type rdf:Property ;
    rdfs:label 'Assessment Number' ;
    rdfs:comment 'Business identifier for the adequacy assessment, used for external reference and regulatory submissions.' ;
    rdfs:domain ind:AdequacyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Assessment Period End Date' ;
    rdfs:comment 'End date of the evaluation period covered by this assessment.' ;
    rdfs:domain ind:AdequacyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assessmentPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Assessment Period Start Date' ;
    rdfs:comment 'Start date of the evaluation period covered by this assessment.' ;
    rdfs:domain ind:AdequacyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assessmentType rdf:type rdf:Property ;
    rdfs:label 'Assessment Type' ;
    rdfs:comment 'Type of network compliance evaluation performed: adequacy (provider count and ratio), access-survey (member experience survey), mystery-shopper (secret shopper call study), gap-analysis (deficiency identification), time-distance (geographic access compliance), or appointment-availability (wait time measurement).' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessorName rdf:type rdf:Property ;
    rdfs:label 'Assessor Name' ;
    rdfs:comment 'Name of the individual or team responsible for conducting the network adequacy assessment.' ;
    rdfs:domain ind:AdequacyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessorOrganization rdf:type rdf:Property ;
    rdfs:label 'Assessor Organization' ;
    rdfs:comment 'Organization or department that conducted the assessment (e.g., internal network management team, third-party consultant, regulatory auditor).' ;
    rdfs:domain ind:AdequacyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:comments rdf:type rdf:Property ;
    rdfs:label 'Comments' ;
    rdfs:comment 'Additional notes, observations, or context related to the network adequacy assessment, including qualitative findings or special circumstances.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceOutcome rdf:type rdf:Property ;
    rdfs:label 'Compliance Outcome' ;
    rdfs:comment 'Overall compliance result of the network adequacy assessment: compliant (meets all standards), non-compliant (fails standards), partially-compliant (meets some but not all standards), under-review (pending final determination), or remediation-required (corrective action needed).' ;
    rdfs:domain ind:AdequacyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilityType rdf:type rdf:Property ;
    rdfs:label 'Facility Type' ;
    rdfs:comment 'Type of healthcare facility evaluated in this assessment (e.g., hospital, urgent care, skilled nursing facility (SNF), ambulatory surgery center, imaging center).' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gapIdentifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Gap Identified Flag' ;
    rdfs:comment 'Indicates whether network gaps or deficiencies were identified during the assessment. True if gaps exist, False otherwise.' ;
    rdfs:domain ind:AdequacyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gapSeverity rdf:type rdf:Property ;
    rdfs:label 'Gap Severity' ;
    rdfs:comment 'Severity level of identified network gaps: critical (immediate member access risk), high (significant access limitation), moderate (minor access concern), or low (minimal impact).' ;
    rdfs:domain ind:Network ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:memberToProviderRatio rdf:type rdf:Property ;
    rdfs:label 'Member To Provider Ratio' ;
    rdfs:comment 'Calculated ratio of enrolled members to available providers in the assessed specialty or facility type, expressed as members per provider.' ;
    rdfs:domain ind:AdequacyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:providerCountAvailable rdf:type rdf:Property ;
    rdfs:label 'Provider Count Available' ;
    rdfs:comment 'Number of in-network providers or facilities available in the assessed specialty or facility type within the service area.' ;
    rdfs:domain ind:AdequacyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:providerCountRequired rdf:type rdf:Property ;
    rdfs:label 'Provider Count Required' ;
    rdfs:comment 'Minimum number of providers or facilities required by regulatory standards to meet network adequacy thresholds for the assessed specialty or facility type.' ;
    rdfs:domain ind:AdequacyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:regulatorySubmissionType rdf:type rdf:Property ;
    rdfs:label 'Regulatory Submission Type' ;
    rdfs:comment 'Type of regulatory body or framework for which this assessment is being conducted: CMS Medicare, CMS Marketplace, State Department of Insurance (DOI), NCQA accreditation, internal monitoring, or ACA Qualified Health Plan (QHP) certification.' ;
    rdfs:domain ind:AdequacyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remediationActionTaken rdf:type rdf:Property ;
    rdfs:label 'Remediation Action Taken' ;
    rdfs:comment 'Description of corrective actions taken to address identified network gaps, such as provider recruitment, contract expansion, telehealth deployment, or member outreach.' ;
    rdfs:domain ind:AdequacyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remediationDueDate rdf:type rdf:Property ;
    rdfs:label 'Remediation Due Date' ;
    rdfs:comment 'Target date by which remediation actions must be completed to resolve identified network gaps and achieve compliance.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:remediationStatus rdf:type rdf:Property ;
    rdfs:label 'Remediation Status' ;
    rdfs:comment 'Current status of remediation efforts: not-started (action plan pending), in-progress (corrective actions underway), completed (actions finished), verified (compliance confirmed), or overdue (past due date).' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialtyType rdf:type rdf:Property ;
    rdfs:label 'Specialty Type' ;
    rdfs:comment 'Medical specialty or provider type being evaluated in this assessment (e.g., primary care, cardiology, orthopedics, behavioral health, pediatrics).' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionDate rdf:type rdf:Property ;
    rdfs:label 'Submission Date' ;
    rdfs:comment 'Date on which the network adequacy assessment was submitted to the regulatory body (CMS, State DOI, NCQA).' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:submissionStatus rdf:type rdf:Property ;
    rdfs:label 'Submission Status' ;
    rdfs:comment 'Status of the regulatory submission: draft (not yet submitted), submitted (under review), accepted (approved by regulator), rejected (not approved), or resubmission-required (corrections needed).' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surveyMethod rdf:type rdf:Property ;
    rdfs:label 'Survey Method' ;
    rdfs:comment 'Methodology used to conduct the assessment: member survey (CAHPS or custom), secret shopper call (mystery shopper study), provider survey (direct provider inquiry), administrative data (claims and enrollment analysis), or geospatial analysis (GIS mapping).' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:telehealthOfferedFlag rdf:type rdf:Property ;
    rdfs:label 'Telehealth Offered Flag' ;
    rdfs:comment 'Indicates whether telehealth or virtual care options were offered as an alternative during the assessment. True if telehealth was available, False otherwise.' ;
    rdfs:domain ind:AdequacyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:timeDistanceCompliancePercentage rdf:type rdf:Property ;
    rdfs:label 'Time Distance Compliance Percentage' ;
    rdfs:comment 'Percentage of members in the service area who have access to the assessed provider specialty or facility type within the required time and distance standards.' ;
    rdfs:domain ind:AdequacyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:timeDistanceStandardMiles rdf:type rdf:Property ;
    rdfs:label 'Time Distance Standard Miles' ;
    rdfs:comment 'Maximum distance in miles that members should travel to access the assessed provider specialty or facility type, as defined by regulatory standards.' ;
    rdfs:domain ind:AdequacyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:timeDistanceStandardMinutes rdf:type rdf:Property ;
    rdfs:label 'Time Distance Standard Minutes' ;
    rdfs:comment 'Maximum travel time in minutes that members should travel to access the assessed provider specialty or facility type, as defined by regulatory standards.' ;
    rdfs:domain ind:AdequacyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:waitTimeDaysRoutine rdf:type rdf:Property ;
    rdfs:label 'Wait Time Days Routine' ;
    rdfs:comment 'Average number of days members wait for a routine appointment with the assessed provider specialty, measured through survey or mystery shopper methodology.' ;
    rdfs:domain ind:AdequacyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:waitTimeDaysUrgent rdf:type rdf:Property ;
    rdfs:label 'Wait Time Days Urgent' ;
    rdfs:comment 'Average number of days members wait for an urgent appointment with the assessed provider specialty, measured through survey or mystery shopper methodology.' ;
    rdfs:domain ind:AdequacyAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:adequacyGapId rdf:type rdf:Property ;
    rdfs:label 'Adequacy Gap Id' ;
    rdfs:comment 'Unique identifier for the network adequacy gap record. Primary key.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AdequacyGap .

ind:actualResolutionDate rdf:type rdf:Property ;
    rdfs:label 'Actual Resolution Date' ;
    rdfs:comment 'Actual date on which this adequacy gap was resolved and the network met the applicable adequacy standard. Null if gap remains unresolved.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:affectedMemberCount rdf:type rdf:Property ;
    rdfs:label 'Affected Member Count' ;
    rdfs:comment 'Estimated number of plan members residing in the affected geographic area who are impacted by this adequacy gap.' ;
    rdfs:domain ind:Network ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:availableProviderCount rdf:type rdf:Property ;
    rdfs:label 'Available Provider Count' ;
    rdfs:comment 'Number of providers or facilities of the specified type currently available in the network in this geographic area. Null if standard is not count-based.' ;
    rdfs:domain ind:AdequacyGap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:exceptionApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Exception Approval Date' ;
    rdfs:comment 'Date on which the regulatory exception or access plan waiver was approved by CMS or the state DOI. Null if no exception has been granted.' ;
    rdfs:domain ind:AdequacyGap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:exceptionExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Exception Expiration Date' ;
    rdfs:comment 'Date on which the granted regulatory exception or access plan waiver expires and the network must meet the full adequacy standard. Null if no exception has been granted or if exception is permanent.' ;
    rdfs:domain ind:AdequacyGap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:exceptionGrantedFlag rdf:type rdf:Property ;
    rdfs:label 'Exception Granted Flag' ;
    rdfs:comment 'Indicates whether a regulatory exception or access plan waiver has been granted by CMS or the state DOI for this adequacy gap.' ;
    rdfs:domain ind:AdequacyGap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:exceptionJustification rdf:type rdf:Property ;
    rdfs:label 'Exception Justification' ;
    rdfs:comment 'Business rationale and supporting documentation for the regulatory exception or access plan waiver request (e.g., rural area with limited provider availability, specialty shortage area designation, alternative access arrangements).' ;
    rdfs:domain ind:AdequacyGap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionRequestDate rdf:type rdf:Property ;
    rdfs:label 'Exception Request Date' ;
    rdfs:comment 'Date on which a regulatory exception or access plan waiver was formally requested for this adequacy gap. Null if no exception has been requested.' ;
    rdfs:domain ind:AdequacyGap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:exceptionRequestedFlag rdf:type rdf:Property ;
    rdfs:label 'Exception Requested Flag' ;
    rdfs:comment 'Indicates whether a regulatory exception or access plan waiver has been requested from CMS or the state DOI for this adequacy gap.' ;
    rdfs:domain ind:AdequacyGap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gapMagnitude rdf:type rdf:Property ;
    rdfs:label 'Gap Magnitude' ;
    rdfs:comment 'Numeric difference between required and available provider count (required minus available). Positive values indicate shortfall. Null if standard is not count-based.' ;
    rdfs:domain ind:AdequacyGap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:gapNumber rdf:type rdf:Property ;
    rdfs:label 'Gap Number' ;
    rdfs:comment 'Business identifier for the adequacy gap, used for tracking and reporting purposes.' ;
    rdfs:domain ind:AdequacyGap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gapStatus rdf:type rdf:Property ;
    rdfs:label 'Gap Status' ;
    rdfs:comment 'Current lifecycle status of the adequacy gap indicating whether it has been identified, is being remediated, has been resolved, or has received a regulatory exception or waiver.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gapType rdf:type rdf:Property ;
    rdfs:label 'Gap Type' ;
    rdfs:comment 'Classification of the adequacy gap by the dimension of network adequacy that fails to meet standards (specialty provider shortage, facility type shortage, geographic coverage gap, time and distance standard violation, appointment wait time standard violation, or essential community provider requirement shortfall).' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicAreaCode rdf:type rdf:Property ;
    rdfs:label 'Geographic Area Code' ;
    rdfs:comment 'Code identifying the specific geographic area affected by this adequacy gap (e.g., FIPS county code, ZIP code, CBSA code).' ;
    rdfs:domain ind:AdequacyGap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicAreaName rdf:type rdf:Property ;
    rdfs:label 'Geographic Area Name' ;
    rdfs:comment 'Human-readable name of the geographic area affected by this adequacy gap (e.g., county name, city name, region name).' ;
    rdfs:domain ind:AdequacyGap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicAreaType rdf:type rdf:Property ;
    rdfs:label 'Geographic Area Type' ;
    rdfs:comment 'Type of geographic unit used to define the area affected by this adequacy gap (county, ZIP code, Core-Based Statistical Area, service area, or custom region).' ;
    rdfs:domain ind:AdequacyGap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:identifiedDate rdf:type rdf:Property ;
    rdfs:label 'Identified Date' ;
    rdfs:comment 'Date on which this network adequacy gap was first identified during an adequacy assessment.' ;
    rdfs:domain ind:AdequacyGap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryFilingRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Filing Required Flag' ;
    rdfs:comment 'Indicates whether this adequacy gap must be disclosed in regulatory filings to CMS, state DOI, or other governing bodies (e.g., QHP certification, network adequacy annual report).' ;
    rdfs:domain ind:AdequacyGap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:remediationAction rdf:type rdf:Property ;
    rdfs:label 'Remediation Action' ;
    rdfs:comment 'Description of the corrective action plan or strategy being implemented to close this adequacy gap (e.g., targeted provider recruitment, contract expansion, telehealth deployment, access plan exception request).' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remediationOwner rdf:type rdf:Property ;
    rdfs:label 'Remediation Owner' ;
    rdfs:comment 'Name or identifier of the individual, team, or department responsible for executing the remediation action and closing this adequacy gap.' ;
    rdfs:domain ind:AdequacyGap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiredProviderCount rdf:type rdf:Property ;
    rdfs:label 'Required Provider Count' ;
    rdfs:comment 'Number of providers or facilities of the specified type required to meet the adequacy standard in this geographic area. Null if standard is not count-based.' ;
    rdfs:domain ind:AdequacyGap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:specialtyName rdf:type rdf:Property ;
    rdfs:label 'Specialty Name' ;
    rdfs:comment 'Human-readable name of the provider specialty or facility type that is deficient (e.g., Cardiology, Skilled Nursing Facility, Primary Care Physician). Null if gap is not specialty-specific.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardThreshold rdf:type rdf:Property ;
    rdfs:label 'Standard Threshold' ;
    rdfs:comment 'The regulatory or contractual adequacy standard threshold that must be met (e.g., \'30 miles or 30 minutes\', \'1 PCP per 2000 members\', \'95% within 10 business days\'). Format varies by standard type.' ;
    rdfs:domain ind:AdequacyGap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardType rdf:type rdf:Property ;
    rdfs:label 'Standard Type' ;
    rdfs:comment 'Type of network adequacy standard that this gap violates (time and distance, provider-to-member ratio, appointment availability, or essential community provider percentage requirement).' ;
    rdfs:domain ind:Network ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetResolutionDate rdf:type rdf:Property ;
    rdfs:label 'Target Resolution Date' ;
    rdfs:comment 'Planned date by which this adequacy gap is expected to be resolved or mitigated to meet the applicable standard.' ;
    rdfs:domain ind:AdequacyGap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:providerDirectoryId rdf:type rdf:Property ;
    rdfs:label 'Provider Directory Id' ;
    rdfs:comment 'Unique identifier for the provider directory record. Primary key for the published provider directory entry representing the member-facing view of a provider\'s network participation.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProviderDirectory .

ind:accessibilityFeatures rdf:type rdf:Property ;
    rdfs:label 'Accessibility Features' ;
    rdfs:comment 'Description of specific accessibility features available at the practice location, such as wheelchair ramps, accessible parking, or assistive listening devices.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adaCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Ada Compliant Flag' ;
    rdfs:comment 'Indicates whether the practice location is ADA-compliant and accessible to individuals with disabilities. Supports member searches for accessible facilities.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:addressLine1 rdf:type rdf:Property ;
    rdfs:label 'Address Line 1' ;
    rdfs:comment 'Primary street address of the practice location. First line of the physical address where the provider sees patients.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressLine2 rdf:type rdf:Property ;
    rdfs:label 'Address Line 2' ;
    rdfs:comment 'Secondary address information such as suite, floor, or building number. Optional address component for practice location.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:boardCertificationStatus rdf:type rdf:Property ;
    rdfs:label 'Board Certification Status' ;
    rdfs:comment 'Indicates whether the provider is board-certified in their specialty. Used for quality assessment and member directory filtering.' ;
    rdfs:domain ind:ProviderDirectory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:county rdf:type rdf:Property ;
    rdfs:label 'County' ;
    rdfs:comment 'County name of the practice location. Used for CMS network adequacy reporting and geographic access standards.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataQualityScore rdf:type rdf:Property ;
    rdfs:label 'Data Quality Score' ;
    rdfs:comment 'Calculated data quality score for this directory entry based on completeness, accuracy, and recency of verification. Range 0.00 to 100.00. Supports directory quality monitoring.' ;
    rdfs:domain ind:ProviderDirectory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:directoryPublicationChannel rdf:type rdf:Property ;
    rdfs:label 'Directory Publication Channel' ;
    rdfs:comment 'The channel through which this directory entry is published and accessible to members. Supports multi-channel directory distribution tracking.' ;
    rdfs:domain ind:ProviderDirectory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:directoryStatus rdf:type rdf:Property ;
    rdfs:label 'Directory Status' ;
    rdfs:comment 'Current status of the provider directory entry. Indicates whether the entry is actively published, pending verification, or suspended from member-facing display.' ;
    rdfs:domain ind:ProviderDirectory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emailAddress rdf:type rdf:Property ;
    rdfs:label 'Email Address' ;
    rdfs:comment 'Email contact for the practice location. Used for electronic communication and directory verification outreach.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gender rdf:type rdf:Property ;
    rdfs:label 'Gender' ;
    rdfs:comment 'Gender of the provider. Used for member preference-based directory searches, particularly for gender-specific care.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hospitalAffiliation rdf:type rdf:Property ;
    rdfs:label 'Hospital Affiliation' ;
    rdfs:comment 'Name of the hospital or health system with which the provider has admitting privileges or affiliation. Supports continuity of care and member decision-making.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:languagesSpoken rdf:type rdf:Property ;
    rdfs:label 'Languages Spoken' ;
    rdfs:comment 'Comma-separated list of languages spoken by the provider or available at the practice location. Supports culturally competent care and member language preference searches.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastVerificationMethod rdf:type rdf:Property ;
    rdfs:label 'Last Verification Method' ;
    rdfs:comment 'Method used for the most recent directory verification. Tracks how the provider information was validated for audit and compliance purposes.' ;
    rdfs:domain ind:ProviderDirectory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastVerificationOutcome rdf:type rdf:Property ;
    rdfs:label 'Last Verification Outcome' ;
    rdfs:comment 'Outcome of the most recent verification attempt. Indicates whether information was confirmed, updated, or if verification was unsuccessful.' ;
    rdfs:domain ind:ProviderDirectory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastVerifiedDate rdf:type rdf:Property ;
    rdfs:label 'Last Verified Date' ;
    rdfs:comment 'Date when the provider directory information was last verified. Critical for CMS 90-day directory update mandate and No Surprises Act compliance.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextVerificationDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Verification Due Date' ;
    rdfs:comment 'Date by which the next directory verification must be completed. Supports compliance with CMS 90-day update mandate and quarterly verification tracking.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:practiceLocationName rdf:type rdf:Property ;
    rdfs:label 'Practice Location Name' ;
    rdfs:comment 'Name of the practice location or facility where the provider sees patients. Displayed in member directory for location identification.' ;
    rdfs:domain ind:ProviderDirectory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialtyPrimary rdf:type rdf:Property ;
    rdfs:label 'Specialty Primary' ;
    rdfs:comment 'The primary medical specialty or taxonomy classification of the provider. Used for member search and filtering in the directory.' ;
    rdfs:domain ind:ProviderDirectory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialtySecondary rdf:type rdf:Property ;
    rdfs:label 'Specialty Secondary' ;
    rdfs:comment 'Additional specialty or sub-specialty of the provider. Supports multi-specialty provider directory searches.' ;
    rdfs:domain ind:ProviderDirectory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:state rdf:type rdf:Property ;
    rdfs:label 'State' ;
    rdfs:comment 'Two-letter state abbreviation of the practice location. Used for geographic filtering and state-level network adequacy compliance.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verifiedFields rdf:type rdf:Property ;
    rdfs:label 'Verified Fields' ;
    rdfs:comment 'Comma-separated list of fields that were verified during the last verification event. Examples include address, phone, accepting_new_patients, specialty.' ;
    rdfs:domain ind:ProviderDirectory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verifyingAgent rdf:type rdf:Property ;
    rdfs:label 'Verifying Agent' ;
    rdfs:comment 'Name or identifier of the person or system that performed the last verification. Used for audit trail and quality assurance.' ;
    rdfs:domain ind:ProviderDirectory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:websiteUrl rdf:type rdf:Property ;
    rdfs:label 'Website Url' ;
    rdfs:comment 'Website address for the provider or practice location. Displayed in member directory for additional provider information.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:benchmarkAmount rdf:type rdf:Property ;
    rdfs:label 'Benchmark Amount' ;
    rdfs:comment 'Target cost or quality benchmark value established for the performance period. Expressed in dollars for cost benchmarks or as a quality score for quality benchmarks.' ;
    rdfs:domain ind:VbcArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:benchmarkMethodology rdf:type rdf:Property ;
    rdfs:label 'Benchmark Methodology' ;
    rdfs:comment 'Method used to establish the cost or quality benchmark against which performance is measured. Options include historical baseline (prior year costs), regional average, national trend, risk-adjusted PMPM, or episode target price.' ;
    rdfs:domain ind:Network ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:careCoordinationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Care Coordination Required Flag' ;
    rdfs:comment 'Indicates whether the VBC arrangement requires formal care coordination programs (care management, transitional care, chronic disease management). True if required; False if optional or not applicable.' ;
    rdfs:domain ind:Network ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cmsAcoCode rdf:type rdf:Property ;
    rdfs:label 'Cms Aco Code' ;
    rdfs:comment 'CMS-assigned identifier for Medicare Shared Savings Program (MSSP) or other federally-recognized ACO arrangements. Null for commercial VBC programs.' ;
    rdfs:domain ind:VbcArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cmsReportingRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Cms Reporting Required Flag' ;
    rdfs:comment 'Indicates whether this arrangement requires formal reporting to Centers for Medicare and Medicaid Services (CMS). True for all Medicare ACOs; False for commercial-only VBC programs.' ;
    rdfs:domain ind:VbcArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dataSharingAgreementFlag rdf:type rdf:Property ;
    rdfs:label 'Data Sharing Agreement Flag' ;
    rdfs:comment 'Indicates whether a formal data sharing agreement exists between the health plan and the ACO or provider group for claims, clinical, and quality data exchange. True if agreement is in place; False otherwise.' ;
    rdfs:domain ind:VbcArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:healthItCertificationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Health It Certification Required Flag' ;
    rdfs:comment 'Indicates whether participating providers must use certified Electronic Health Record (EHR) systems and meet health IT standards. True if required; False if not required.' ;
    rdfs:domain ind:VbcArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:participatingAcoName rdf:type rdf:Property ;
    rdfs:label 'Participating Aco Name' ;
    rdfs:comment 'Legal name of the Accountable Care Organization or provider group participating in this VBC arrangement. Null for program template records.' ;
    rdfs:domain ind:VbcArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:participatingProviderCount rdf:type rdf:Property ;
    rdfs:label 'Participating Provider Count' ;
    rdfs:comment 'Number of individual providers (physicians, specialists, facilities) participating in this ACO or VBC arrangement. Used for network adequacy and capacity planning.' ;
    rdfs:domain ind:VbcArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:performanceGuaranteeAmount rdf:type rdf:Property ;
    rdfs:label 'Performance Guarantee Amount' ;
    rdfs:comment 'Dollar amount of financial guarantee or bond required from the ACO or provider group to participate in two-sided risk arrangements. Ensures ability to repay shared losses.' ;
    rdfs:domain ind:VbcArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:primaryCarePhysicianCount rdf:type rdf:Property ;
    rdfs:label 'Primary Care Physician Count' ;
    rdfs:comment 'Number of primary care physicians participating in this ACO or VBC arrangement. Critical for attribution and care coordination requirements.' ;
    rdfs:domain ind:VbcArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:qualityPerformanceThreshold rdf:type rdf:Property ;
    rdfs:label 'Quality Performance Threshold' ;
    rdfs:comment 'Minimum quality performance score required to earn shared savings or avoid penalties. Expressed as a percentage (e.g., 70.00 for 70th percentile).' ;
    rdfs:domain ind:Network ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reconciliationFrequency rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Frequency' ;
    rdfs:comment 'Frequency at which financial performance is reconciled and shared savings or losses are calculated and settled. Most Medicare ACOs reconcile annually; commercial arrangements may reconcile more frequently.' ;
    rdfs:domain ind:VbcArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordType rdf:type rdf:Property ;
    rdfs:label 'Record Type' ;
    rdfs:comment 'Distinguishes whether this record represents a program definition template (reusable VBC program design) or a specific participation instance (actual arrangement with a provider group or ACO).' ;
    rdfs:domain ind:VbcArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceAreaDescription rdf:type rdf:Property ;
    rdfs:label 'Service Area Description' ;
    rdfs:comment 'Geographic description of the service area covered by this VBC arrangement (e.g., \'Statewide California\', \'Metro Atlanta Region\', \'National Medicare Population\').' ;
    rdfs:domain ind:VbcArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialistPhysicianCount rdf:type rdf:Property ;
    rdfs:label 'Specialist Physician Count' ;
    rdfs:comment 'Number of specialist physicians participating in this ACO or VBC arrangement. Used for network adequacy and specialty care access analysis.' ;
    rdfs:domain ind:VbcArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sponsoringEntityName rdf:type rdf:Property ;
    rdfs:label 'Sponsoring Entity Name' ;
    rdfs:comment 'Name of the organization sponsoring or administering the VBC program (e.g., health plan name, CMS for federal programs, employer group for commercial arrangements).' ;
    rdfs:domain ind:VbcArrangement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stopLossLimit rdf:type rdf:Property ;
    rdfs:label 'Stop Loss Limit' ;
    rdfs:comment 'Maximum financial loss amount the ACO or provider group is responsible for under two-sided risk arrangements. Provides downside risk protection. Null for one-sided risk or full capitation models.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exceptionId rdf:type rdf:Property ;
    rdfs:label 'Exception Id' ;
    rdfs:comment 'Unique identifier for the network adequacy exception record. Primary key.' ;
    rdfs:domain ind:Exception ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cmsPlanBenefitPackageId rdf:type rdf:Property ;
    rdfs:label 'Cms Plan Benefit Package Id' ;
    rdfs:comment 'CMS Plan Benefit Package identifier for the specific Medicare Advantage plan affected by this exception.' ;
    rdfs:domain ind:Exception ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BenefitPackage .

ind:regulatorySubmissionId rdf:type rdf:Property ;
    rdfs:label 'Regulatory Submission Id' ;
    rdfs:comment 'Foreign key linking to compliance.regulatory_submission. Business justification: Network adequacy exceptions (time-distance waivers, specialty shortages) require formal regulatory submissions to CMS or state agencies. exception.regulatory_body is denormalized from regulatory_submi' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RegulatorySubmission .

ind:alternativeAccessArrangement rdf:type rdf:Property ;
    rdfs:label 'Alternative Access Arrangement' ;
    rdfs:comment 'Description of alternative access arrangements provided to members in lieu of meeting standard adequacy (e.g., telehealth services, out-of-network reimbursement at in-network rates, transportation assistance).' ;
    rdfs:domain ind:Exception ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appealDecision rdf:type rdf:Property ;
    rdfs:label 'Appeal Decision' ;
    rdfs:comment 'Outcome of the appeal process if an appeal was filed: upheld (denial confirmed), overturned (exception granted on appeal), or pending (appeal under review). Null if no appeal filed.' ;
    rdfs:domain ind:Exception ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appealFiledFlag rdf:type rdf:Property ;
    rdfs:label 'Appeal Filed Flag' ;
    rdfs:comment 'Indicates whether an appeal was filed in response to a denial of this exception request. True if appeal filed, false otherwise.' ;
    rdfs:domain ind:Exception ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:approvedTerms rdf:type rdf:Property ;
    rdfs:label 'Approved Terms' ;
    rdfs:comment 'Specific terms and conditions under which the exception was granted by the regulatory body, including any requirements, limitations, or reporting obligations.' ;
    rdfs:domain ind:Exception ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:denialDate rdf:type rdf:Property ;
    rdfs:label 'Denial Date' ;
    rdfs:comment 'Date the exception was denied by the regulatory body. Null if approved or still under review.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:exceptionNumber rdf:type rdf:Property ;
    rdfs:label 'Exception Number' ;
    rdfs:comment 'External filing or tracking number assigned by the regulatory body or internal system for this exception request.' ;
    rdfs:domain ind:Exception ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionStatus rdf:type rdf:Property ;
    rdfs:label 'Exception Status' ;
    rdfs:comment 'Current lifecycle status of the exception filing: draft (being prepared), submitted (filed with regulator), under review (regulator reviewing), approved (exception granted), denied (exception rejected), withdrawn (voluntarily withdrawn), or expired (approval period ended). [ENUM-REF-CANDIDATE: draft|submitted|under_review|approved|denied|withdrawn|expired — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Exception ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionType rdf:type rdf:Property ;
    rdfs:label 'Exception Type' ;
    rdfs:comment 'Category of network adequacy exception being filed: time-distance waiver (cannot meet time/distance standards), rural exception (rural area with limited providers), access plan (formal plan to address gaps), specialty shortage (insufficient specialists in area), temporary disruption (short-term network change), or other.' ;
    rdfs:domain ind:Exception ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filingDate rdf:type rdf:Property ;
    rdfs:label 'Filing Date' ;
    rdfs:comment 'Date the exception request was officially submitted to the regulatory body.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:geographicDescription rdf:type rdf:Property ;
    rdfs:label 'Geographic Description' ;
    rdfs:comment 'Textual description of the geographic area affected by the exception, including counties, ZIP codes, or other location identifiers.' ;
    rdfs:domain ind:Exception ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:memberNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Member Notification Date' ;
    rdfs:comment 'Date on which affected members were notified of the network adequacy exception and alternative access options. Null if notification not yet completed or not required.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:memberNotificationFlag rdf:type rdf:Property ;
    rdfs:label 'Member Notification Flag' ;
    rdfs:comment 'Indicates whether members in the affected area must be notified of the network adequacy exception and alternative access arrangements. True if notification is required, false otherwise.' ;
    rdfs:domain ind:Exception ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mitigationPlan rdf:type rdf:Property ;
    rdfs:label 'Mitigation Plan' ;
    rdfs:comment 'Description of the health plan\'s strategy to mitigate member access issues during the exception period, such as out-of-network coverage, telehealth options, or provider recruitment efforts.' ;
    rdfs:domain ind:Exception ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:providerRecruitmentEffort rdf:type rdf:Property ;
    rdfs:label 'Provider Recruitment Effort' ;
    rdfs:comment 'Summary of the health plan\'s efforts to recruit additional providers in the affected specialty and geographic area to resolve the adequacy gap.' ;
    rdfs:domain ind:Exception ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Regulatory Jurisdiction' ;
    rdfs:comment 'Specific jurisdiction or state where the exception is filed (e.g., state abbreviation for state DOI filings, or \'Federal\' for CMS).' ;
    rdfs:domain ind:Exception ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewDueDate rdf:type rdf:Property ;
    rdfs:label 'Review Due Date' ;
    rdfs:comment 'Expected or required date by which the regulatory body must complete review of the exception request.' ;
    rdfs:domain ind:Exception ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:supportingDocumentationReference rdf:type rdf:Property ;
    rdfs:label 'Supporting Documentation Reference' ;
    rdfs:comment 'Reference identifier or location of supporting documentation submitted with the exception filing (e.g., provider availability analysis, geographic access study, member impact assessment).' ;
    rdfs:domain ind:Exception ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timeDistanceStandardWaived rdf:type rdf:Property ;
    rdfs:label 'Time Distance Standard Waived' ;
    rdfs:comment 'Specific time or distance standard that is waived under this exception (e.g., \'30 minutes/30 miles for primary care\'). Applicable for time-distance waiver exception types.' ;
    rdfs:domain ind:Exception ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supersededByStandardAccessStandardId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Standard Access Standard Id' ;
    rdfs:comment 'Reference to the access_standard_id of the newer standard that replaces this one, if status is superseded. Enables version tracking and historical compliance analysis.' ;
    rdfs:domain ind:AccessStandard ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AccessStandard .

ind:accessStandardStatus rdf:type rdf:Property ;
    rdfs:label 'Access Standard Status' ;
    rdfs:comment 'Current lifecycle status of the access standard: active (in force and monitored), inactive (no longer enforced), draft (under development), pending_approval (awaiting regulatory or executive approval), superseded (replaced by a newer version).' ;
    rdfs:domain ind:AccessStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:afterHoursAvailabilityRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'After Hours Availability Required Flag' ;
    rdfs:comment 'Indicates whether providers must offer after-hours (evening, weekend, or holiday) appointment availability to meet this access standard. True for urgent care, behavioral health crisis, and certain primary care standards; false for routine specialty care.' ;
    rdfs:domain ind:AccessStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:appointmentTypeScope rdf:type rdf:Property ;
    rdfs:label 'Appointment Type Scope' ;
    rdfs:comment 'Defines whether this access standard applies to new patient appointments, established patient follow-ups, specialist consultations, or all appointment types. New patient access is typically more stringent than follow-up access.' ;
    rdfs:domain ind:AccessStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceMeasurementMethod rdf:type rdf:Property ;
    rdfs:label 'Compliance Measurement Method' ;
    rdfs:comment 'The method used to measure and audit compliance with this access standard: appointment_log_audit (review of provider scheduling systems), member_survey (CAHPS or custom surveys), secret_shopper (test calls to provider offices), provider_attestation (self-reported compliance), claims_analysis (time between referral and service date in claims data).' ;
    rdfs:domain ind:AccessStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineOfBusinessApplicability rdf:type rdf:Property ;
    rdfs:label 'Line Of Business Applicability' ;
    rdfs:comment 'Comma-separated list of lines of business to which this access standard applies (e.g., Commercial, Medicare Advantage, Medicaid, Exchange/QHP). Some standards are federally mandated for Medicare/Medicaid; others are state-specific or voluntary for commercial plans.' ;
    rdfs:domain ind:AccessStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumWaitTimeHours rdf:type rdf:Property ;
    rdfs:label 'Maximum Wait Time Hours' ;
    rdfs:comment 'For emergent or crisis access standards, the maximum number of hours allowed for appointment availability (e.g., behavioral health crisis must be seen within 6 hours). Null for standards measured in days.' ;
    rdfs:domain ind:AccessStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:memberAgeGroup rdf:type rdf:Property ;
    rdfs:label 'Member Age Group' ;
    rdfs:comment 'The member age cohort to which this access standard applies: pediatric (under 18), adult (18-64), geriatric (65+), or all. Pediatric and geriatric populations often have stricter access requirements.' ;
    rdfs:domain ind:AccessStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monitoringFrequency rdf:type rdf:Property ;
    rdfs:label 'Monitoring Frequency' ;
    rdfs:comment 'How often compliance with this access standard is measured and reported: monthly (for high-risk or CMS-mandated standards), quarterly (typical for HEDIS and accreditation), semi_annual, annual (for internal benchmarks), or continuous (real-time monitoring via appointment systems).' ;
    rdfs:domain ind:AccessStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:penaltyForNoncompliance rdf:type rdf:Property ;
    rdfs:label 'Penalty For Noncompliance' ;
    rdfs:comment 'Description of the consequences for failing to meet this access standard: regulatory sanctions, accreditation downgrade, member grievance escalation, provider contract breach, financial penalties, or corrective action plan requirements.' ;
    rdfs:domain ind:AccessStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryCitation rdf:type rdf:Property ;
    rdfs:label 'Regulatory Citation' ;
    rdfs:comment 'Specific regulatory or accreditation standard citation (e.g., 42 CFR 438.206, NCQA HEDIS AAP measure, State Insurance Code Section 1367.03). Provides traceability to the authoritative source.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:telehealthEquivalencyFlag rdf:type rdf:Property ;
    rdfs:label 'Telehealth Equivalency Flag' ;
    rdfs:comment 'Indicates whether telehealth (virtual) appointments satisfy this access standard in lieu of in-person visits. True for most routine and behavioral health standards post-COVID; may be false for certain procedures requiring physical examination.' ;
    rdfs:domain ind:AccessStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:benchmarkYear rdf:type rdf:Property ;
    rdfs:label 'Benchmark Year' ;
    rdfs:comment 'The base year or period used to establish the performance benchmark for this program.' ;
    rdfs:domain ind:VbcProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cmsProgramIdentifier rdf:type rdf:Property ;
    rdfs:label 'Cms Program Identifier' ;
    rdfs:comment 'The official CMS-assigned identifier for this VBC program, used for regulatory reporting and tracking. CMS = Centers for Medicare and Medicaid Services.' ;
    rdfs:domain ind:VbcProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactEmail rdf:type rdf:Property ;
    rdfs:label 'Contact Email' ;
    rdfs:comment 'Primary email address for inquiries and communications regarding this VBC program.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eligibleProviderTypes rdf:type rdf:Property ;
    rdfs:label 'Eligible Provider Types' ;
    rdfs:comment 'Comma-separated list of provider types eligible to participate in this VBC program (e.g., PCP, Specialist, Hospital, SNF). PCP = Primary Care Provider, SNF = Skilled Nursing Facility.' ;
    rdfs:domain ind:VbcProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:healthItRequirement rdf:type rdf:Property ;
    rdfs:label 'Health It Requirement' ;
    rdfs:comment 'Description of health IT capabilities required for participation (e.g., EHR certification, HIE connectivity, data reporting). EHR = Electronic Health Record, HIE = Health Information Exchange.' ;
    rdfs:domain ind:VbcProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumMemberThreshold rdf:type rdf:Property ;
    rdfs:label 'Minimum Member Threshold' ;
    rdfs:comment 'The minimum number of attributed members required for a provider or ACO to participate in or qualify for this VBC program.' ;
    rdfs:domain ind:VbcProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:performancePeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Performance Period End Date' ;
    rdfs:comment 'The date when the performance measurement period for this VBC program ends.' ;
    rdfs:domain ind:VbcProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:performancePeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Performance Period Start Date' ;
    rdfs:comment 'The date when the performance measurement period for this VBC program begins.' ;
    rdfs:domain ind:VbcProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:programCategory rdf:type rdf:Property ;
    rdfs:label 'Program Category' ;
    rdfs:comment 'Broad category of value-based arrangement that this program represents. ACO = Accountable Care Organization.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programCode rdf:type rdf:Property ;
    rdfs:label 'Program Code' ;
    rdfs:comment 'Unique business identifier code for the VBC program used across systems and external reporting.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programDescription rdf:type rdf:Property ;
    rdfs:label 'Program Description' ;
    rdfs:comment 'Detailed narrative description of the VBC program objectives, structure, and key features.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programName rdf:type rdf:Property ;
    rdfs:label 'Program Name' ;
    rdfs:comment 'Full business name of the value-based care program.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programOwner rdf:type rdf:Property ;
    rdfs:label 'Program Owner' ;
    rdfs:comment 'The internal business unit or department responsible for managing and administering this VBC program.' ;
    rdfs:domain ind:VbcProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programStatus rdf:type rdf:Property ;
    rdfs:label 'Program Status' ;
    rdfs:comment 'Current operational status of the VBC program.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programType rdf:type rdf:Property ;
    rdfs:label 'Program Type' ;
    rdfs:comment 'Classification of the VBC program model. MSSP = Medicare Shared Savings Program, REACH = Realizing Equity Access and Community Health, NextGen = Next Generation ACO, P4P = Pay for Performance.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programUrl rdf:type rdf:Property ;
    rdfs:label 'Program Url' ;
    rdfs:comment 'Web address for the program information page, provider portal, or documentation site.' ;
    rdfs:domain ind:VbcProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programYear rdf:type rdf:Property ;
    rdfs:label 'Program Year' ;
    rdfs:comment 'The calendar or performance year for which this VBC program design is configured.' ;
    rdfs:domain ind:VbcProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:settlementFrequency rdf:type rdf:Property ;
    rdfs:label 'Settlement Frequency' ;
    rdfs:comment 'How often financial reconciliation and shared savings/loss settlements are calculated and paid.' ;
    rdfs:domain ind:VbcProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sponsoringEntity rdf:type rdf:Property ;
    rdfs:label 'Sponsoring Entity' ;
    rdfs:comment 'The organization or regulatory body that sponsors and governs this VBC program. CMS = Centers for Medicare and Medicaid Services.' ;
    rdfs:domain ind:VbcProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accreditationProgramId rdf:type rdf:Property ;
    rdfs:label 'Accreditation Program Id' ;
    rdfs:comment 'Foreign key linking to compliance.accreditation_program. Business justification: Accreditation Program tracking: each provider must be linked to the accreditation program that certifies it, required for network participation and compliance reporting.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AccreditationProgram .

ind:boardCertificationSummaryStatus rdf:type rdf:Property ;
    rdfs:label 'Board Certification Summary Status' ;
    rdfs:comment 'Overall completeness of board certification documentation.' ;
    rdfs:domain ind:Provider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:boardCertifications rdf:type rdf:Property ;
    rdfs:label 'Board Certifications' ;
    rdfs:comment 'List of board certifications held by the provider.' ;
    rdfs:domain ind:Provider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countryCode rdf:type rdf:Property ;
    rdfs:label 'Country Code' ;
    rdfs:comment 'Three-letter ISO country code of the provider\'s location.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:culturalCompetencyCertifications rdf:type rdf:Property ;
    rdfs:label 'Cultural Competency Certifications' ;
    rdfs:comment 'Certifications or training demonstrating cultural competency for language access.' ;
    rdfs:domain ind:Provider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dateOfBirth rdf:type rdf:Property ;
    rdfs:label 'Date Of Birth' ;
    rdfs:comment 'Birth date of an individual provider; used for credentialing and compliance.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:deaNumber rdf:type rdf:Property ;
    rdfs:label 'Dea Number' ;
    rdfs:comment 'Drug Enforcement Administration registration number for prescribing controlled substances.' ;
    rdfs:domain ind:Provider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:firstName rdf:type rdf:Property ;
    rdfs:label 'First Name' ;
    rdfs:comment 'Given name of an individual provider.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:languageProficiency rdf:type rdf:Property ;
    rdfs:label 'Language Proficiency' ;
    rdfs:comment 'Proficiency level for each language (e.g., fluent, conversational).' ;
    rdfs:domain ind:Provider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastName rdf:type rdf:Property ;
    rdfs:label 'Last Name' ;
    rdfs:comment 'Family name of an individual provider.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastVerifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Verified Timestamp' ;
    rdfs:comment 'Timestamp of the last verification of provider data against source registries.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:licenseNumber rdf:type rdf:Property ;
    rdfs:label 'License Number' ;
    rdfs:comment 'State-issued professional license identifier.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:malpracticeCoverageFlag rdf:type rdf:Property ;
    rdfs:label 'Malpractice Coverage Flag' ;
    rdfs:comment 'Indicates whether the provider has active malpractice insurance coverage.' ;
    rdfs:domain ind:Provider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:networkParticipationFlag rdf:type rdf:Property ;
    rdfs:label 'Network Participation Flag' ;
    rdfs:comment 'True if the provider is currently part of any contracted network.' ;
    rdfs:domain ind:Provider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:postalCode rdf:type rdf:Property ;
    rdfs:label 'Postal Code' ;
    rdfs:comment 'ZIP or postal code for the provider\'s address.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primarySpecialty rdf:type rdf:Property ;
    rdfs:label 'Primary Specialty' ;
    rdfs:comment 'Main clinical specialty of the provider, derived from taxonomy.' ;
    rdfs:domain ind:Provider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:providerCategory rdf:type rdf:Property ;
    rdfs:label 'Provider Category' ;
    rdfs:comment 'High-level classification of the provider (e.g., physician, hospital, clinic, DME supplier, behavioral health, ancillary).' ;
    rdfs:domain ind:Provider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:providerName rdf:type rdf:Property ;
    rdfs:label 'Provider Name' ;
    rdfs:comment 'Full legal name of the provider (individual name or organization name).' ;
    rdfs:domain ind:Provider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statusFlag rdf:type rdf:Property ;
    rdfs:label 'Status Flag' ;
    rdfs:comment 'Operational status of the provider within the health plan.' ;
    rdfs:domain ind:Provider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxonomyCode rdf:type rdf:Property ;
    rdfs:label 'Taxonomy Code' ;
    rdfs:comment 'Standard taxonomy code (e.g., from the AMA) that describes the provider\'s specialty or service area.' ;
    rdfs:domain ind:Provider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxonomyDescription rdf:type rdf:Property ;
    rdfs:label 'Taxonomy Description' ;
    rdfs:comment 'Human-readable description of the taxonomy code.' ;
    rdfs:domain ind:Provider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tinEin rdf:type rdf:Property ;
    rdfs:label 'Tin Ein' ;
    rdfs:comment 'Federal tax identifier for the provider organization or individual.' ;
    rdfs:domain ind:Provider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:upin rdf:type rdf:Property ;
    rdfs:label 'Upin' ;
    rdfs:comment 'Legacy identifier for physicians used in Medicare billing.' ;
    rdfs:domain ind:Provider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialtyId rdf:type rdf:Property ;
    rdfs:label 'Specialty Id' ;
    rdfs:comment 'Primary key for specialty' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Specialty .

ind:boardCertifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Board Certified Flag' ;
    rdfs:comment 'Indicates whether the provider is board certified in this specialty. True if certified by a recognized medical board; False otherwise.' ;
    rdfs:domain ind:Specialty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:certificationDate rdf:type rdf:Property ;
    rdfs:label 'Certification Date' ;
    rdfs:comment 'The date on which the provider was initially certified by the board in this specialty. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:Specialty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:certificationExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Certification Expiration Date' ;
    rdfs:comment 'The date on which the board certification expires and requires renewal. Null if certification does not expire or is lifetime. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:Specialty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:certificationNumber rdf:type rdf:Property ;
    rdfs:label 'Certification Number' ;
    rdfs:comment 'The unique certification number or identifier issued by the certifying board for this specialty. Used for verification purposes.' ;
    rdfs:domain ind:Specialty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certifyingBoardName rdf:type rdf:Property ;
    rdfs:label 'Certifying Board Name' ;
    rdfs:comment 'The name of the medical board or certifying organization that granted board certification for this specialty (e.g., American Board of Internal Medicine, American Board of Surgery). Null if not board certified.' ;
    rdfs:domain ind:Specialty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:credentialingEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Credentialing Effective Date' ;
    rdfs:comment 'The date on which the provider\'s credentialing for this specialty became effective within the health plan\'s network. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:Provider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:credentialingEndDate rdf:type rdf:Property ;
    rdfs:label 'Credentialing End Date' ;
    rdfs:comment 'The date on which the provider\'s credentialing for this specialty ended or will end. Null if currently active with no planned end date. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:Specialty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:credentialingReviewDate rdf:type rdf:Property ;
    rdfs:label 'Credentialing Review Date' ;
    rdfs:comment 'The date of the most recent credentialing review or recredentialing for this specialty. NCQA requires recredentialing at least every three years. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:Specialty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:currentRecordFlag rdf:type rdf:Property ;
    rdfs:label 'Current Record Flag' ;
    rdfs:comment 'Indicates whether this is the current active version of the specialty record. True for the current record; False for historical versions. Supports slowly changing dimension (SCD) Type 2 historization.' ;
    rdfs:domain ind:Provider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fellowshipCompletedFlag rdf:type rdf:Property ;
    rdfs:label 'Fellowship Completed Flag' ;
    rdfs:comment 'Indicates whether the provider completed a fellowship program in this specialty or subspecialty. True if fellowship training was completed; False otherwise.' ;
    rdfs:domain ind:Specialty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fellowshipCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Fellowship Completion Date' ;
    rdfs:comment 'The date on which the provider completed the fellowship program. Format: yyyy-MM-dd. Null if no fellowship was completed.' ;
    rdfs:domain ind:Specialty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fellowshipProgramName rdf:type rdf:Property ;
    rdfs:label 'Fellowship Program Name' ;
    rdfs:comment 'The name of the fellowship program and institution where the provider completed subspecialty training. Null if no fellowship was completed.' ;
    rdfs:domain ind:Specialty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hedisSpecialtyFlag rdf:type rdf:Property ;
    rdfs:label 'Hedis Specialty Flag' ;
    rdfs:comment 'Indicates whether this specialty is relevant for HEDIS measure attribution and quality reporting. True if the specialty is used in HEDIS measure calculations; False otherwise.' ;
    rdfs:domain ind:Specialty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nextCredentialingReviewDate rdf:type rdf:Property ;
    rdfs:label 'Next Credentialing Review Date' ;
    rdfs:comment 'The scheduled date for the next credentialing review or recredentialing for this specialty. Used for compliance tracking and proactive credentialing management. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:Specialty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pcpEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Pcp Eligible Flag' ;
    rdfs:comment 'Indicates whether this specialty qualifies the provider to serve as a Primary Care Provider (PCP) for member assignment. True for specialties such as Family Medicine, Internal Medicine, Pediatrics, and General Practice.' ;
    rdfs:domain ind:Specialty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recertificationCycleYears rdf:type rdf:Property ;
    rdfs:label 'Recertification Cycle Years' ;
    rdfs:comment 'The number of years in the recertification cycle (e.g., 10 years for most ABMS boards). Null if recertification is not required.' ;
    rdfs:domain ind:Specialty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:recertificationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Recertification Required Flag' ;
    rdfs:comment 'Indicates whether the board certification requires periodic recertification or maintenance of certification (MOC). True if recertification is required; False if lifetime certification.' ;
    rdfs:domain ind:Specialty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recordEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Record Effective Date' ;
    rdfs:comment 'The date from which this version of the specialty record is effective for business purposes. Supports slowly changing dimension (SCD) Type 2 historization. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:Specialty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:recordEndDate rdf:type rdf:Property ;
    rdfs:label 'Record End Date' ;
    rdfs:comment 'The date on which this version of the specialty record ceased to be effective. Null for the current active record. Supports slowly changing dimension (SCD) Type 2 historization. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:Provider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:specialistReferralRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Specialist Referral Required Flag' ;
    rdfs:comment 'Indicates whether members require a referral from their PCP to see this provider in this specialty, based on plan type (e.g., HMO requires referrals; PPO typically does not). True if referral is required; False otherwise.' ;
    rdfs:domain ind:Specialty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:subspecialtyCode rdf:type rdf:Property ;
    rdfs:label 'Subspecialty Code' ;
    rdfs:comment 'Additional NUCC taxonomy code representing a subspecialty within the primary specialty (e.g., Interventional Cardiology within Cardiology). Null if no subspecialty designation.' ;
    rdfs:domain ind:Specialty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subspecialtyName rdf:type rdf:Property ;
    rdfs:label 'Subspecialty Name' ;
    rdfs:comment 'The human-readable name of the subspecialty, if applicable. Provides additional granularity beyond the primary specialty for network adequacy and member search.' ;
    rdfs:domain ind:Specialty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:telehealthEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Telehealth Enabled Flag' ;
    rdfs:comment 'Indicates whether the provider offers telehealth or telemedicine services for this specialty. True if telehealth services are available; False otherwise. Important for provider directory accuracy.' ;
    rdfs:domain ind:Provider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:yearsInSpecialty rdf:type rdf:Property ;
    rdfs:label 'Years In Specialty' ;
    rdfs:comment 'The number of years the provider has been practicing in this specialty. Calculated from the date the provider first began practicing in this specialty area.' ;
    rdfs:domain ind:Specialty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryPracticeMedicaidProviderId rdf:type rdf:Property ;
    rdfs:label 'Primary Practice Medicaid Provider Id' ;
    rdfs:comment 'State-specific Medicaid provider identifier for this practice location. Required for Medicaid claims submission.' ;
    rdfs:domain ind:PracticeLocation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Provider .

ind:tertiaryPracticeProviderId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Practice Provider Id' ;
    rdfs:comment 'Reference to the primary provider associated with this practice location. A provider may have multiple practice locations.' ;
    rdfs:domain ind:PracticeLocation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Provider .

ind:directoryDisplayFlag rdf:type rdf:Property ;
    rdfs:label 'Directory Display Flag' ;
    rdfs:comment 'Indicates whether this practice location should be displayed in the member-facing provider directory. May be false even if active (e.g., administrative locations).' ;
    rdfs:domain ind:Provider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fipsCode rdf:type rdf:Property ;
    rdfs:label 'Fips Code' ;
    rdfs:comment '5-digit FIPS county code for geographic identification and network adequacy reporting.' ;
    rdfs:domain ind:PracticeLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:latitude rdf:type rdf:Property ;
    rdfs:label 'Latitude' ;
    rdfs:comment 'Geographic latitude coordinate of the practice location in decimal degrees. Used for time/distance network adequacy calculations.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:locationName rdf:type rdf:Property ;
    rdfs:label 'Location Name' ;
    rdfs:comment 'Business name or designation of the practice location (e.g., \'Main Street Family Medicine\', \'Downtown Urgent Care Center\').' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:locationType rdf:type rdf:Property ;
    rdfs:label 'Location Type' ;
    rdfs:comment 'Classification of the practice location type indicating the care delivery setting.' ;
    rdfs:domain ind:PracticeLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:longitude rdf:type rdf:Property ;
    rdfs:label 'Longitude' ;
    rdfs:comment 'Geographic longitude coordinate of the practice location in decimal degrees. Used for time/distance network adequacy calculations.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:officeHours rdf:type rdf:Property ;
    rdfs:label 'Office Hours' ;
    rdfs:comment 'Operating hours of the practice location (e.g., \'Mon-Fri 8:00 AM - 5:00 PM, Sat 9:00 AM - 1:00 PM\'). Free-text field for member-facing display.' ;
    rdfs:domain ind:PracticeLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parkingAvailableFlag rdf:type rdf:Property ;
    rdfs:label 'Parking Available Flag' ;
    rdfs:comment 'Indicates whether on-site or nearby parking is available for patients.' ;
    rdfs:domain ind:PracticeLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:patientAgeMaximum rdf:type rdf:Property ;
    rdfs:label 'Patient Age Maximum' ;
    rdfs:comment 'Maximum patient age accepted at this practice location (e.g., 18 for pediatrics only). Null if no maximum restriction.' ;
    rdfs:domain ind:PracticeLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:patientAgeMinimum rdf:type rdf:Property ;
    rdfs:label 'Patient Age Minimum' ;
    rdfs:comment 'Minimum patient age accepted at this practice location (e.g., 0 for all ages, 18 for adults only). Null if no minimum restriction.' ;
    rdfs:domain ind:PracticeLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:patientGenderRestriction rdf:type rdf:Property ;
    rdfs:label 'Patient Gender Restriction' ;
    rdfs:comment 'Gender restriction for patients served at this location (e.g., \'female_only\' for women\'s health clinics).' ;
    rdfs:domain ind:PracticeLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publicTransportationAccessFlag rdf:type rdf:Property ;
    rdfs:label 'Public Transportation Access Flag' ;
    rdfs:comment 'Indicates whether the practice location is accessible via public transportation.' ;
    rdfs:domain ind:PracticeLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:taxIdentifier rdf:type rdf:Property ;
    rdfs:label 'Tax Identifier' ;
    rdfs:comment 'Federal Tax Identification Number (EIN) for the practice location or medical group. Used for claims payment and 1099 reporting.' ;
    rdfs:domain ind:Provider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationMethod rdf:type rdf:Property ;
    rdfs:label 'Verification Method' ;
    rdfs:comment 'Method used for the most recent verification of practice location information.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wheelchairAccessibleFlag rdf:type rdf:Property ;
    rdfs:label 'Wheelchair Accessible Flag' ;
    rdfs:comment 'Indicates whether the practice location has wheelchair accessibility features (ramps, elevators, accessible restrooms).' ;
    rdfs:domain ind:PracticeLocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:licenseId rdf:type rdf:Property ;
    rdfs:label 'License Id' ;
    rdfs:comment 'Primary key for license' ;
    rdfs:domain ind:License ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:attestationDate rdf:type rdf:Property ;
    rdfs:label 'Attestation Date' ;
    rdfs:comment 'The date the provider attested to the accuracy and currency of this license information. Used for credentialing and recredentialing cycles.' ;
    rdfs:domain ind:License ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:authorizedSchedules rdf:type rdf:Property ;
    rdfs:label 'Authorized Schedules' ;
    rdfs:comment 'For DEA and CDS registrations, the controlled substance schedules the provider is authorized to prescribe (Schedule II, III, IV, V). Stored as comma-separated list. Critical for pharmacy benefit management and prior authorization workflows.' ;
    rdfs:domain ind:License ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compactParticipationFlag rdf:type rdf:Property ;
    rdfs:label 'Compact Participation Flag' ;
    rdfs:comment 'Indicates whether this license is part of an interstate licensure compact (e.g., Interstate Medical Licensure Compact, Nurse Licensure Compact). True if the license grants multi-state practice privileges; false otherwise.' ;
    rdfs:domain ind:License ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:compactPrivilegeStates rdf:type rdf:Property ;
    rdfs:label 'Compact Privilege States' ;
    rdfs:comment 'Comma-separated list of state abbreviations where the provider has practice privileges under the interstate compact. Used for multi-state network adequacy and provider directory management.' ;
    rdfs:domain ind:License ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compactType rdf:type rdf:Property ;
    rdfs:label 'Compact Type' ;
    rdfs:comment 'The specific interstate licensure compact this license participates in. IMLC is Interstate Medical Licensure Compact for physicians. Populated only when compact_participation_flag is true. [ENUM-REF-CANDIDATE: imlc|nurse_licensure_compact|psychology_compact|physical_therapy_compact|ems_compact|counseling_compact|none — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:License ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:continuingEducationHoursRequired rdf:type rdf:Property ;
    rdfs:label 'Continuing Education Hours Required' ;
    rdfs:comment 'The number of continuing education or CME hours required per renewal cycle to maintain this license. Varies by state and license type.' ;
    rdfs:domain ind:License ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:continuingEducationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Continuing Education Required Flag' ;
    rdfs:comment 'Indicates whether continuing education (CE) or continuing medical education (CME) is required to maintain this license. True if CE/CME is mandatory for renewal; false otherwise.' ;
    rdfs:domain ind:License ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:disciplinaryActionDate rdf:type rdf:Property ;
    rdfs:label 'Disciplinary Action Date' ;
    rdfs:comment 'The date disciplinary action was taken against the license. Used for credentialing review timelines and risk assessment.' ;
    rdfs:domain ind:License ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:disciplinaryActionDetails rdf:type rdf:Property ;
    rdfs:label 'Disciplinary Action Details' ;
    rdfs:comment 'Detailed description of any disciplinary actions, sanctions, or restrictions imposed by the licensing authority. Includes nature of violation, dates, and resolution. Populated only when disciplinary_action_flag is true.' ;
    rdfs:domain ind:License ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disciplinaryActionFlag rdf:type rdf:Property ;
    rdfs:label 'Disciplinary Action Flag' ;
    rdfs:comment 'Indicates whether any disciplinary action has been taken against this license by the issuing authority. True if disciplinary action exists; false otherwise. Critical for credentialing risk assessment.' ;
    rdfs:domain ind:License ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:issueDate rdf:type rdf:Property ;
    rdfs:label 'Issue Date' ;
    rdfs:comment 'The date the license or registration was originally issued by the licensing authority. Used to calculate license tenure and verify historical credentialing timelines.' ;
    rdfs:domain ind:Provider ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:issuingAuthority rdf:type rdf:Property ;
    rdfs:label 'Issuing Authority' ;
    rdfs:comment 'The regulatory body or government agency that issued the license or registration. Examples include State Medical Board, State Board of Nursing, Drug Enforcement Administration (DEA), State Pharmacy Board, or Centers for Medicare and Medicaid Services (CMS).' ;
    rdfs:domain ind:License ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingState rdf:type rdf:Property ;
    rdfs:label 'Issuing State' ;
    rdfs:comment 'The U.S. state or territory that issued the license. Uses two-letter state abbreviation. Critical for multi-state licensure tracking and Interstate Medical Licensure Compact compliance. [ENUM-REF-CANDIDATE: AL|AK|AZ|AR|CA|CO|CT|DE|FL|GA|HI|ID|IL|IN|IA|KS|KY|LA|ME|MD|MA|MI|MN|MS|MO|MT|NE|NV|NH|NJ|NM|NY|NC|ND|OH|OK|OR|PA|RI|SC|SD|TN|TX|UT|VT|VA|WA|WV|WI|WY|DC — 51 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:License ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenseStatus rdf:type rdf:Property ;
    rdfs:label 'License Status' ;
    rdfs:comment 'Current status of the license or registration in its lifecycle. Active indicates the license is valid and in good standing; suspended, revoked, or expired indicate the provider cannot practice under this credential. [ENUM-REF-CANDIDATE: active|inactive|suspended|revoked|expired|surrendered|pending_renewal|probation|restricted — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:License ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenseType rdf:type rdf:Property ;
    rdfs:label 'License Type' ;
    rdfs:comment 'The category of professional license or registration. Includes state medical licenses (MD, DO), nursing licenses (RN, LPN, NP), DEA controlled substance registrations, state CDS permits, pharmacy licenses, and other professional certifications. [ENUM-REF-CANDIDATE: medical_license|nursing_license|dea_registration|cds_permit|pharmacy_license|dental_license|optometry_license|podiatry_license|chiropractic_license|physical_therapy_license|occupational_therapy_license|behavioral_health_license|advanced_practice_license|physician_assistant_license|other — 15 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:License ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:practiceRestrictions rdf:type rdf:Property ;
    rdfs:label 'Practice Restrictions' ;
    rdfs:comment 'Any limitations or restrictions placed on the license by the issuing authority. May include supervision requirements, practice setting restrictions, or specific clinical limitations.' ;
    rdfs:domain ind:License ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primarySourceVerificationDate rdf:type rdf:Property ;
    rdfs:label 'Primary Source Verification Date' ;
    rdfs:comment 'The date the license was last verified directly with the issuing authority (primary source). NCQA requires PSV within 180 days of credentialing decision and every 36 months thereafter.' ;
    rdfs:domain ind:License ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:primarySourceVerificationMethod rdf:type rdf:Property ;
    rdfs:label 'Primary Source Verification Method' ;
    rdfs:comment 'The method used to verify the license with the primary source. Includes online state board portals, written correspondence, phone verification, third-party credentialing services, or automated API integration.' ;
    rdfs:domain ind:License ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordCurrentFlag rdf:type rdf:Property ;
    rdfs:label 'Record Current Flag' ;
    rdfs:comment 'Indicates whether this is the current active version of the license record. True for the current record; false for historical versions. Supports Type 2 slowly changing dimension queries.' ;
    rdfs:domain ind:License ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recordEffectiveTimestamp rdf:type rdf:Property ;
    rdfs:label 'Record Effective Timestamp' ;
    rdfs:comment 'The date and time from which this version of the license record is effective for business reporting. Supports Type 2 slowly changing dimension tracking.' ;
    rdfs:domain ind:License ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:recordEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Record End Timestamp' ;
    rdfs:comment 'The date and time when this version of the license record was superseded by a new version. Null for the current active record. Supports Type 2 slowly changing dimension tracking.' ;
    rdfs:domain ind:License ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:renewalCycleMonths rdf:type rdf:Property ;
    rdfs:label 'Renewal Cycle Months' ;
    rdfs:comment 'The number of months between required renewals for this license type. Common values are 12, 24, or 36 months depending on state and license type.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:renewalDate rdf:type rdf:Property ;
    rdfs:label 'Renewal Date' ;
    rdfs:comment 'The date the license was last renewed. Used to track renewal cycles and ensure continuous licensure for credentialing purposes.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scopeOfPractice rdf:type rdf:Property ;
    rdfs:label 'Scope Of Practice' ;
    rdfs:comment 'Description of the clinical activities and services the provider is authorized to perform under this license. Varies by license type and state regulations. Used for state-specific scope-of-practice validation.' ;
    rdfs:domain ind:License ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:telemedicineAuthorizedFlag rdf:type rdf:Property ;
    rdfs:label 'Telemedicine Authorized Flag' ;
    rdfs:comment 'Indicates whether the provider is authorized to deliver telemedicine services under this license. True if telemedicine practice is permitted; false otherwise. Critical for virtual care network management.' ;
    rdfs:domain ind:License ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:verificationSource rdf:type rdf:Property ;
    rdfs:label 'Verification Source' ;
    rdfs:comment 'The specific entity or system used to perform primary source verification. Examples include state medical board website, NPDB, third-party credentialing verification organization (CVO), or automated verification service.' ;
    rdfs:domain ind:License ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationUrl rdf:type rdf:Property ;
    rdfs:label 'Verification Url' ;
    rdfs:comment 'The web address of the state licensing board or regulatory authority where the license can be verified online. Used for automated primary source verification workflows.' ;
    rdfs:domain ind:License ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:providerAffiliationId rdf:type rdf:Property ;
    rdfs:label 'Provider Affiliation Id' ;
    rdfs:comment 'Primary key for affiliation' ;
    rdfs:domain ind:ProviderAffiliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:admittingPrivilegesFlag rdf:type rdf:Property ;
    rdfs:label 'Admitting Privileges Flag' ;
    rdfs:comment 'Indicates whether the provider has been granted admitting privileges at this specific facility. A provider may have privileges at a facility without full admitting rights (e.g., consulting-only). Belongs to the relationship, not to the provider or facility alone.' ;
    rdfs:domain ind:ProviderAffiliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:affiliationStatus rdf:type rdf:Property ;
    rdfs:label 'Affiliation Status' ;
    rdfs:comment 'Current operational status of the provider\'s appointment or affiliation at this facility. Drives provider directory inclusion, claims routing eligibility, and network adequacy reporting. Belongs to the relationship.' ;
    rdfs:domain ind:ProviderAffiliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affiliationType rdf:type rdf:Property ;
    rdfs:label 'Affiliation Type' ;
    rdfs:comment 'Categorical classification of the affiliation relationship. Indicates whether the provider is affiliated with a medical group, Independent Practice Association (IPA), Accountable Care Organization (ACO), health system, hospital, or other facility type.' ;
    rdfs:domain ind:ProviderAffiliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingNpi rdf:type rdf:Property ;
    rdfs:label 'Billing Npi' ;
    rdfs:comment 'The National Provider Identifier (NPI) used for billing purposes in this affiliation context. May represent the organizational NPI (Type 2) of the affiliated entity.' ;
    rdfs:domain ind:ProviderAffiliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:credentialingVerificationDate rdf:type rdf:Property ;
    rdfs:label 'Credentialing Verification Date' ;
    rdfs:comment 'Date when the provider\'s credentials were last verified specifically for this facility appointment. Distinct from the provider-level last_verified_timestamp; this is facility-specific verification. Belongs to the relationship.' ;
    rdfs:domain ind:ProviderAffiliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:departmentName rdf:type rdf:Property ;
    rdfs:label 'Department Name' ;
    rdfs:comment 'The name of the department, division, or service line within the affiliated organization where the provider practices. Examples include Cardiology, Emergency Medicine, Orthopedic Surgery, Primary Care.' ;
    rdfs:domain ind:ProviderAffiliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:medicalStaffCategory rdf:type rdf:Property ;
    rdfs:label 'Medical Staff Category' ;
    rdfs:comment 'The category of medical staff membership the provider holds at the affiliated hospital or facility. Categories include Active Staff, Courtesy Staff, Consulting Staff, Honorary Staff, Affiliate Staff, and Provisional Staff.' ;
    rdfs:domain ind:ProviderAffiliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextCredentialingDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Credentialing Due Date' ;
    rdfs:comment 'The date by which the next credentialing verification for this affiliation is due. Supports proactive credentialing workflow management.' ;
    rdfs:domain ind:ProviderAffiliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:primaryAffiliationFlag rdf:type rdf:Property ;
    rdfs:label 'Primary Affiliation Flag' ;
    rdfs:comment 'Boolean indicator denoting whether this is the provider\'s primary organizational affiliation. True indicates this is the main affiliation; False indicates a secondary or additional affiliation.' ;
    rdfs:domain ind:ProviderAffiliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:roleTitle rdf:type rdf:Property ;
    rdfs:label 'Role Title' ;
    rdfs:comment 'The provider\'s role or title within the affiliated organization. Examples include Staff Physician, Medical Director, Department Chair, Attending Physician, Consulting Physician.' ;
    rdfs:domain ind:ProviderAffiliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceRecordReference rdf:type rdf:Property ;
    rdfs:label 'Source Record Reference' ;
    rdfs:comment 'The unique identifier of this affiliation record in the source system. Used for traceability and reconciliation with upstream systems.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryGroupMedicaidProviderId rdf:type rdf:Property ;
    rdfs:label 'Primary Group Medicaid Provider Id' ;
    rdfs:comment 'The state-assigned Medicaid provider identifier for the group practice, used for Medicaid claims submission.' ;
    rdfs:domain ind:GroupPractice ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Provider .

ind:acceptingNewPatients rdf:type rdf:Property ;
    rdfs:label 'Accepting New Patients' ;
    rdfs:comment 'Indicates whether the group practice is currently accepting new patients. Used for provider directory accuracy and member access.' ;
    rdfs:domain ind:GroupPractice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:accessibilityAccommodations rdf:type rdf:Property ;
    rdfs:label 'Accessibility Accommodations' ;
    rdfs:comment 'Description of accessibility accommodations available at the group practice (e.g., wheelchair access, hearing loop, accessible exam tables) to comply with ADA requirements.' ;
    rdfs:domain ind:GroupPractice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acoName rdf:type rdf:Property ;
    rdfs:label 'Aco Name' ;
    rdfs:comment 'The name of the ACO in which the group practice participates, if applicable.' ;
    rdfs:domain ind:GroupPractice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acoParticipant rdf:type rdf:Property ;
    rdfs:label 'Aco Participant' ;
    rdfs:comment 'Indicates whether the group practice participates in an Accountable Care Organization (ACO) for value-based care arrangements.' ;
    rdfs:domain ind:GroupPractice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cmsCertificationNumber rdf:type rdf:Property ;
    rdfs:label 'Cms Certification Number' ;
    rdfs:comment 'The CMS Certification Number (CCN) assigned to FQHC, RHC, or other certified facilities. Required for Medicare/Medicaid billing.' ;
    rdfs:domain ind:GroupPractice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Data Source System' ;
    rdfs:comment 'The name of the source system from which this group practice record originated (e.g., Cactus, ProviderSource, NPPES).' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:groupName rdf:type rdf:Property ;
    rdfs:label 'Group Name' ;
    rdfs:comment 'The legal business name of the medical group, physician organization, or practice entity as registered with state authorities and CMS.' ;
    rdfs:domain ind:GroupPractice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:groupNpi rdf:type rdf:Property ;
    rdfs:label 'Group Npi' ;
    rdfs:comment 'The 10-digit Type 2 NPI assigned to the group practice organization by CMS. This is the organizational NPI distinct from individual provider NPIs.' ;
    rdfs:domain ind:GroupPractice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:groupSize rdf:type rdf:Property ;
    rdfs:label 'Group Size' ;
    rdfs:comment 'The total number of individual providers (physicians, nurse practitioners, physician assistants) affiliated with and practicing under this group.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:groupType rdf:type rdf:Property ;
    rdfs:label 'Group Type' ;
    rdfs:comment 'Classification of the group practice organizational structure: solo practice (single physician), single specialty group, multi-specialty group, Independent Practice Association (IPA), Federally Qualified Health Center (FQHC), or Rural Health Clinic (RHC).' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:languageServicesOffered rdf:type rdf:Property ;
    rdfs:label 'Language Services Offered' ;
    rdfs:comment 'Comma-separated list of languages in which the group practice offers clinical services, used for provider directory cultural competency and member access.' ;
    rdfs:domain ind:GroupPractice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pcmhRecognized rdf:type rdf:Property ;
    rdfs:label 'Pcmh Recognized' ;
    rdfs:comment 'Indicates whether the group practice has achieved NCQA Patient-Centered Medical Home (PCMH) recognition, qualifying for enhanced reimbursement and quality incentives.' ;
    rdfs:domain ind:GroupPractice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:telehealthEnabled rdf:type rdf:Property ;
    rdfs:label 'Telehealth Enabled' ;
    rdfs:comment 'Indicates whether the group practice offers telehealth or telemedicine services to members.' ;
    rdfs:domain ind:GroupPractice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:bedCount rdf:type rdf:Property ;
    rdfs:label 'Bed Count' ;
    rdfs:comment 'Total number of licensed beds at the facility. Used for network adequacy calculations and capacity planning.' ;
    rdfs:domain ind:Facility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ccn rdf:type rdf:Property ;
    rdfs:label 'Ccn' ;
    rdfs:comment 'Six-character alphanumeric identifier assigned by CMS to Medicare/Medicaid certified facilities. Also known as Provider Number.' ;
    rdfs:domain ind:Facility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cliaNumber rdf:type rdf:Property ;
    rdfs:label 'Clia Number' ;
    rdfs:comment 'Ten-character identifier issued by CMS for facilities performing laboratory testing. Format: 2-digit state code + 1 letter + 7 digits.' ;
    rdfs:domain ind:Facility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:credentialingExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Credentialing Expiration Date' ;
    rdfs:comment 'Date when the current credentialing approval expires and recredentialing is required.' ;
    rdfs:domain ind:Facility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:criticalAccessHospitalFlag rdf:type rdf:Property ;
    rdfs:label 'Critical Access Hospital Flag' ;
    rdfs:comment 'Indicates whether the facility is designated as a Critical Access Hospital under the Medicare Rural Hospital Flexibility Program.' ;
    rdfs:domain ind:Facility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:emergencyServicesFlag rdf:type rdf:Property ;
    rdfs:label 'Emergency Services Flag' ;
    rdfs:comment 'Indicates whether the facility provides 24/7 emergency department services.' ;
    rdfs:domain ind:Facility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:facilityName rdf:type rdf:Property ;
    rdfs:label 'Facility Name' ;
    rdfs:comment 'Legal name of the healthcare facility as registered with state and federal authorities.' ;
    rdfs:domain ind:Facility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:medicaidCertifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Medicaid Certified Flag' ;
    rdfs:comment 'Indicates whether the facility is certified to participate in the Medicaid program.' ;
    rdfs:domain ind:Facility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:medicareCertifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Medicare Certified Flag' ;
    rdfs:comment 'Indicates whether the facility is certified to participate in the Medicare program.' ;
    rdfs:domain ind:Facility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:networkTier rdf:type rdf:Property ;
    rdfs:label 'Network Tier' ;
    rdfs:comment 'Tiering classification of the facility within the provider network. Tier 1 is preferred/lowest cost-sharing. Out_of_network indicates non-participating facility.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownershipType rdf:type rdf:Property ;
    rdfs:label 'Ownership Type' ;
    rdfs:comment 'Legal ownership structure of the facility. Values: for_profit (investor-owned), non_profit (tax-exempt), government (federal/state/local), tribal (Indian Health Service or tribal).' ;
    rdfs:domain ind:Facility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentOrganizationName rdf:type rdf:Property ;
    rdfs:label 'Parent Organization Name' ;
    rdfs:comment 'Name of the parent health system or organization that owns or operates the facility. Null if facility is independent.' ;
    rdfs:domain ind:Facility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityRating rdf:type rdf:Property ;
    rdfs:label 'Quality Rating' ;
    rdfs:comment 'Overall quality rating score for the facility on a scale of 1.00 to 5.00. Derived from CMS Star Ratings, HEDIS measures, or internal quality assessments.' ;
    rdfs:domain ind:Facility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:teachingHospitalFlag rdf:type rdf:Property ;
    rdfs:label 'Teaching Hospital Flag' ;
    rdfs:comment 'Indicates whether the facility is a teaching hospital affiliated with a medical school and residency programs.' ;
    rdfs:domain ind:Facility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:traumaLevel rdf:type rdf:Property ;
    rdfs:label 'Trauma Level' ;
    rdfs:comment 'Trauma center designation level assigned by state or American College of Surgeons. Level 1 is highest capability. Not_designated indicates facility is not a trauma center.' ;
    rdfs:domain ind:Facility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:directoryEntryId rdf:type rdf:Property ;
    rdfs:label 'Directory Entry Id' ;
    rdfs:comment 'Primary key for directory_entry' ;
    rdfs:domain ind:DirectoryEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:attestationMethod rdf:type rdf:Property ;
    rdfs:label 'Attestation Method' ;
    rdfs:comment 'Method used to verify the directory information with the provider. Documents the verification approach for audit and compliance purposes.' ;
    rdfs:domain ind:DirectoryEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attestationStatus rdf:type rdf:Property ;
    rdfs:label 'Attestation Status' ;
    rdfs:comment 'Status of the provider attestation or verification process for this directory entry. Tracks compliance with CMS directory accuracy requirements.' ;
    rdfs:domain ind:DirectoryEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:directoryDisplayName rdf:type rdf:Property ;
    rdfs:label 'Directory Display Name' ;
    rdfs:comment 'Consumer-facing display name of the provider as it appears in the published directory. May differ from legal name for readability and member experience.' ;
    rdfs:domain ind:DirectoryEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:directoryPublicationDate rdf:type rdf:Property ;
    rdfs:label 'Directory Publication Date' ;
    rdfs:comment 'Date when this directory entry was published or last updated in the member-facing provider directory. Required for CMS directory accuracy attestation.' ;
    rdfs:domain ind:DirectoryEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:graduationYear rdf:type rdf:Property ;
    rdfs:label 'Graduation Year' ;
    rdfs:comment 'Year the provider graduated from medical school or professional training program. Helps members assess provider experience.' ;
    rdfs:domain ind:DirectoryEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:medicalSchool rdf:type rdf:Property ;
    rdfs:label 'Medical School' ;
    rdfs:comment 'Name of the medical school or professional training institution where the provider received their degree. Provides credential transparency for members.' ;
    rdfs:domain ind:DirectoryEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:participationEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Participation Effective Date' ;
    rdfs:comment 'Date when the providers participation in this plan and network became effective. Determines when members can access the provider at in-network rates.' ;
    rdfs:domain ind:DirectoryEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:participationTerminationDate rdf:type rdf:Property ;
    rdfs:label 'Participation Termination Date' ;
    rdfs:comment 'Date when the providers participation in this plan and network ended or will end. Critical for member notification and continuity of care transitions.' ;
    rdfs:domain ind:DirectoryEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:practiceWebsiteUrl rdf:type rdf:Property ;
    rdfs:label 'Practice Website Url' ;
    rdfs:comment 'Website URL for the practice or provider. Published in directory to enable members to learn more about the provider and services offered.' ;
    rdfs:domain ind:DirectoryEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exclusionScreeningId rdf:type rdf:Property ;
    rdfs:label 'Exclusion Screening Id' ;
    rdfs:comment 'Unique identifier for the exclusion screening event record.' ;
    rdfs:domain ind:ExclusionScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fwaCaseId rdf:type rdf:Property ;
    rdfs:label 'Fwa Case Id' ;
    rdfs:comment 'Foreign key linking to compliance.fwa_case. Business justification: When exclusion screening identifies a sanctioned provider, an FWA case is opened per CMS program integrity protocols. Linking the screening result to the triggered FWA case supports fraud investigatio' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FwaCase .

ind:auditFlag rdf:type rdf:Property ;
    rdfs:label 'Audit Flag' ;
    rdfs:comment 'Boolean indicator (True/False) denoting whether this screening event has been flagged for audit review due to anomalies, policy violations, or regulatory examination requirements.' ;
    rdfs:domain ind:ExclusionScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:auditNotes rdf:type rdf:Property ;
    rdfs:label 'Audit Notes' ;
    rdfs:comment 'Free-text notes documenting audit findings, reviewer comments, or regulatory examination references related to this screening event.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cmsReportingFlag rdf:type rdf:Property ;
    rdfs:label 'Cms Reporting Flag' ;
    rdfs:comment 'Boolean indicator (True/False) denoting whether this screening event must be included in CMS regulatory reporting submissions or program integrity audits.' ;
    rdfs:domain ind:ExclusionScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:complianceStatus rdf:type rdf:Property ;
    rdfs:label 'Compliance Status' ;
    rdfs:comment 'The compliance status of this screening event relative to regulatory requirements: compliant (on schedule), overdue (past due date), pending review (awaiting resolution), non-compliant (violation), or waived (exception granted).' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSourceVersion rdf:type rdf:Property ;
    rdfs:label 'Data Source Version' ;
    rdfs:comment 'The version or publication date of the exclusion list data source used for this screening, ensuring traceability to the specific list snapshot consulted.' ;
    rdfs:domain ind:ExclusionScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exclusionEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Exclusion Effective Date' ;
    rdfs:comment 'The date on which the exclusion became effective, as reported by the exclusion list source. Null if no match found.' ;
    rdfs:domain ind:ExclusionScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:exclusionEndDate rdf:type rdf:Property ;
    rdfs:label 'Exclusion End Date' ;
    rdfs:comment 'The date on which the exclusion is scheduled to end or was lifted, if applicable. Null for indefinite exclusions or no match.' ;
    rdfs:domain ind:ExclusionScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:exclusionType rdf:type rdf:Property ;
    rdfs:label 'Exclusion Type' ;
    rdfs:comment 'The scope of the exclusion found: Federal (Medicare/Medicaid), State (state-specific Medicaid), Both (federal and state), or None (no exclusion).' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:matchDetails rdf:type rdf:Property ;
    rdfs:label 'Match Details' ;
    rdfs:comment 'Detailed narrative or structured information about the match, including matched data elements, exclusion list entry identifiers, and any discrepancies requiring review.' ;
    rdfs:domain ind:ExclusionScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:matchType rdf:type rdf:Property ;
    rdfs:label 'Match Type' ;
    rdfs:comment 'The type of match logic that triggered a positive or potential screening result, indicating which data elements matched the exclusion list entry.' ;
    rdfs:domain ind:ExclusionScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextScreeningDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Screening Due Date' ;
    rdfs:comment 'The date by which the next exclusion screening is required for this provider to maintain compliance with CMS monthly screening mandates.' ;
    rdfs:domain ind:ExclusionScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:priorScreeningDate rdf:type rdf:Property ;
    rdfs:label 'Prior Screening Date' ;
    rdfs:comment 'The date of the most recent prior exclusion screening for this provider, used to track screening cadence and compliance with monthly requirements.' ;
    rdfs:domain ind:ExclusionScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:resolutionAction rdf:type rdf:Property ;
    rdfs:label 'Resolution Action' ;
    rdfs:comment 'The action taken by the health plan in response to the screening result: no action (clear result), provider termination, contract suspension, pending manual review, false positive confirmation, or waiver granted per policy.' ;
    rdfs:domain ind:ExclusionScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionDate rdf:type rdf:Property ;
    rdfs:label 'Resolution Date' ;
    rdfs:comment 'The date on which the resolution action was completed or the screening result was finalized. Null if resolution is still pending.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:resolutionNotes rdf:type rdf:Property ;
    rdfs:label 'Resolution Notes' ;
    rdfs:comment 'Free-text notes documenting the resolution process, including rationale for the action taken, supporting evidence reviewed, and any exceptions or waivers applied.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screenedByName rdf:type rdf:Property ;
    rdfs:label 'Screened By Name' ;
    rdfs:comment 'The full name of the individual or system process that performed the screening, for audit trail purposes.' ;
    rdfs:domain ind:ExclusionScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screeningDate rdf:type rdf:Property ;
    rdfs:label 'Screening Date' ;
    rdfs:comment 'The date on which the exclusion screening was performed.' ;
    rdfs:domain ind:ExclusionScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:screeningFrequency rdf:type rdf:Property ;
    rdfs:label 'Screening Frequency' ;
    rdfs:comment 'The scheduled frequency or trigger for this screening event: monthly (CMS-required), quarterly, annual, ad hoc (event-driven), or initial credentialing.' ;
    rdfs:domain ind:ExclusionScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screeningMethod rdf:type rdf:Property ;
    rdfs:label 'Screening Method' ;
    rdfs:comment 'The method or channel used to perform the exclusion screening: automated batch process, manual lookup by staff, real-time API integration, or third-party vendor service.' ;
    rdfs:domain ind:ExclusionScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screeningResult rdf:type rdf:Property ;
    rdfs:label 'Screening Result' ;
    rdfs:comment 'The outcome of the exclusion screening: Clear (no match), Match Found (confirmed exclusion), Potential Match (requires manual review), Inconclusive (insufficient data), or Error (screening system failure).' ;
    rdfs:domain ind:ExclusionScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screeningSource rdf:type rdf:Property ;
    rdfs:label 'Screening Source' ;
    rdfs:comment 'The authoritative exclusion list source(s) checked during this screening event (OIG List of Excluded Individuals and Entities, System for Award Management, state Medicaid exclusion lists, or General Services Administration Excluded Parties List System).' ;
    rdfs:domain ind:ExclusionScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screeningVendor rdf:type rdf:Property ;
    rdfs:label 'Screening Vendor' ;
    rdfs:comment 'The name of the third-party vendor or service provider used to perform the exclusion screening, if applicable. Null for in-house screenings.' ;
    rdfs:domain ind:ExclusionScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stateReportingFlag rdf:type rdf:Property ;
    rdfs:label 'State Reporting Flag' ;
    rdfs:comment 'Boolean indicator (True/False) denoting whether this screening event must be reported to state Department of Insurance or Medicaid agencies per state-specific requirements.' ;
    rdfs:domain ind:ExclusionScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:vendorTransactionReference rdf:type rdf:Property ;
    rdfs:label 'Vendor Transaction Reference' ;
    rdfs:comment 'The unique transaction or reference identifier assigned by the third-party screening vendor for this screening event, used for vendor reconciliation and support.' ;
    rdfs:domain ind:ExclusionScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deaRegistrationId rdf:type rdf:Property ;
    rdfs:label 'Dea Registration Id' ;
    rdfs:comment 'Primary key for dea_registration' ;
    rdfs:domain ind:DeaRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:controlledSubstanceAuthorizedFlag rdf:type rdf:Property ;
    rdfs:label 'Controlled Substance Authorized Flag' ;
    rdfs:comment 'True if the provider is authorized to prescribe controlled substances.' ;
    rdfs:domain ind:DeaRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:issuingAgency rdf:type rdf:Property ;
    rdfs:label 'Issuing Agency' ;
    rdfs:comment 'Agency that issued the DEA registration (typically DEA).' ;
    rdfs:domain ind:DeaRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationState rdf:type rdf:Property ;
    rdfs:label 'Registration State' ;
    rdfs:comment 'Two-letter US state code where the DEA registration was issued. [ENUM-REF-CANDIDATE: AL|AK|AZ|AR|CA|CO|CT|DE|FL|GA|HI|ID|IL|IN|IA|KS|KY|LA|ME|MD|MA|MI|MN|MS|MO|MT|NE|NV|NH|NJ|NM|NY|NC|ND|OH|OK|OR|PA|RI|SC|SD|TN|TX|UT|VT|VA|WA|WV|WI|WY — promote to reference product]' ;
    rdfs:domain ind:DeaRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationStatus rdf:type rdf:Property ;
    rdfs:label 'Registration Status' ;
    rdfs:comment 'Current lifecycle status of the DEA registration.' ;
    rdfs:domain ind:DeaRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationType rdf:type rdf:Property ;
    rdfs:label 'Registration Type' ;
    rdfs:comment 'Indicates whether the registration is for an individual provider or an organization.' ;
    rdfs:domain ind:DeaRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleAuthorized rdf:type rdf:Property ;
    rdfs:label 'Schedule Authorized' ;
    rdfs:comment 'DEA schedule(s) the provider is authorized to prescribe (II, III, IV, V).' ;
    rdfs:domain ind:DeaRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationDate rdf:type rdf:Property ;
    rdfs:label 'Verification Date' ;
    rdfs:comment 'Date the DEA registration information was last verified against the primary source.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:benefitDesignVersion rdf:type rdf:Property ;
    rdfs:label 'Benefit Design Version' ;
    rdfs:comment 'Version identifier for the benefit design configuration.' ;
    rdfs:domain ind:HealthPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cmsPlanCode rdf:type rdf:Property ;
    rdfs:label 'Cms Plan Code' ;
    rdfs:comment 'CMS plan identifier used for regulatory reporting.' ;
    rdfs:domain ind:HealthPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coinsurancePercentage rdf:type rdf:Property ;
    rdfs:label 'Coinsurance Percentage' ;
    rdfs:comment 'Percentage of allowed amount the member pays after deductible is met.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:copayPrimaryCare rdf:type rdf:Property ;
    rdfs:label 'Copay Primary Care' ;
    rdfs:comment 'Fixed copayment amount for a primary care office visit.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:copaySpecialist rdf:type rdf:Property ;
    rdfs:label 'Copay Specialist' ;
    rdfs:comment 'Fixed copayment amount for a specialist office visit.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deductibleFamily rdf:type rdf:Property ;
    rdfs:label 'Deductible Family' ;
    rdfs:comment 'Annual amount a family must pay before cost-sharing begins.' ;
    rdfs:domain ind:HealthPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deductibleIndividual rdf:type rdf:Property ;
    rdfs:label 'Deductible Individual' ;
    rdfs:comment 'Annual amount an individual member must pay before cost-sharing begins.' ;
    rdfs:domain ind:HealthPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:enrollmentEndDate rdf:type rdf:Property ;
    rdfs:label 'Enrollment End Date' ;
    rdfs:comment 'Last date members may enroll in the plan for the plan year.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:enrollmentStartDate rdf:type rdf:Property ;
    rdfs:label 'Enrollment Start Date' ;
    rdfs:comment 'First date members may enroll in the plan for the plan year.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:hccScore rdf:type rdf:Property ;
    rdfs:label 'Hcc Score' ;
    rdfs:comment 'Aggregated HCC score for the plan population used in risk adjustment.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hiosPlanCode rdf:type rdf:Property ;
    rdfs:label 'Hios Plan Code' ;
    rdfs:comment 'CMS-assigned HIOS identifier for the plan.' ;
    rdfs:domain ind:HealthPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isExemptFromMlr rdf:type rdf:Property ;
    rdfs:label 'Is Exempt From Mlr' ;
    rdfs:comment 'Indicates whether the plan is exempt from Medical Loss Ratio reporting requirements.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:outOfPocketMaxFamily rdf:type rdf:Property ;
    rdfs:label 'Out Of Pocket Max Family' ;
    rdfs:comment 'Maximum amount a family pays in a year before the plan pays 100% of covered services.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:outOfPocketMaxIndividual rdf:type rdf:Property ;
    rdfs:label 'Out Of Pocket Max Individual' ;
    rdfs:comment 'Maximum amount an individual pays in a year before the plan pays 100% of covered services.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:planAcaCompliant rdf:type rdf:Property ;
    rdfs:label 'Plan Aca Compliant' ;
    rdfs:comment 'True if the plan meets all Affordable Care Act regulatory requirements.' ;
    rdfs:domain ind:HealthPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:planCategory rdf:type rdf:Property ;
    rdfs:label 'Plan Category' ;
    rdfs:comment 'High-level category indicating commercial, government, or special market plans.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planCode rdf:type rdf:Property ;
    rdfs:label 'Plan Code' ;
    rdfs:comment 'Business identifier code used in core administration platforms to reference the plan.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planDescription rdf:type rdf:Property ;
    rdfs:label 'Plan Description' ;
    rdfs:comment 'Narrative description of the plan\'s benefits and target audience.' ;
    rdfs:domain ind:HealthPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planMarketplaceEligible rdf:type rdf:Property ;
    rdfs:label 'Plan Marketplace Eligible' ;
    rdfs:comment 'Indicates if the plan can be sold on the ACA Health Insurance Marketplace.' ;
    rdfs:domain ind:HealthPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:planName rdf:type rdf:Property ;
    rdfs:label 'Plan Name' ;
    rdfs:comment 'Human-readable name of the health plan as marketed to members.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planRegion rdf:type rdf:Property ;
    rdfs:label 'Plan Region' ;
    rdfs:comment 'Geographic region (e.g., Northeast, Midwest) for reporting and network adequacy.' ;
    rdfs:domain ind:HealthPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planState rdf:type rdf:Property ;
    rdfs:label 'Plan State' ;
    rdfs:comment 'Two-letter US state abbreviation where the plan is offered.' ;
    rdfs:domain ind:HealthPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planStatus rdf:type rdf:Property ;
    rdfs:label 'Plan Status' ;
    rdfs:comment 'Current lifecycle status of the plan.' ;
    rdfs:domain ind:HealthPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:premiumAmount rdf:type rdf:Property ;
    rdfs:label 'Premium Amount' ;
    rdfs:comment 'Base premium amount charged to the member or group for the plan year.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:premiumCurrency rdf:type rdf:Property ;
    rdfs:label 'Premium Currency' ;
    rdfs:comment 'ISO 4217 currency code for the premium amount.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:premiumFrequency rdf:type rdf:Property ;
    rdfs:label 'Premium Frequency' ;
    rdfs:comment 'Billing frequency for the premium (monthly, quarterly, annually).' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryClassification rdf:type rdf:Property ;
    rdfs:label 'Regulatory Classification' ;
    rdfs:comment 'Regulatory category of the plan (e.g., ACA, Medicare, Medicaid).' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskAdjustmentFactor rdf:type rdf:Property ;
    rdfs:label 'Risk Adjustment Factor' ;
    rdfs:comment 'Factor used for risk-adjusted payments under CMS risk adjustment models.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sbcDocumentUrl rdf:type rdf:Property ;
    rdfs:label 'Sbc Document Url' ;
    rdfs:comment 'Link to the electronic Summary of Benefits and Coverage document for the plan.' ;
    rdfs:domain ind:HealthPlan ;
    rdf:type owl:DatatypeProperty ;
