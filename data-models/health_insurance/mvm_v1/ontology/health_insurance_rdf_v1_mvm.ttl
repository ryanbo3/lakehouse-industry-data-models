    rdfs:comment 'Category of the risk adjustment factor (e.g., "RAF", "HCC", "RxHCC").' ;
    rdfs:domain ind:MemberRiskScore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskScoreCode rdf:type rdf:Property ;
    rdfs:label 'Risk Score Code' ;
    rdfs:comment 'Business identifier code for the risk score record, often composed of member ID, year, and model version.' ;
    rdfs:domain ind:MemberRiskScore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskScoreConfidenceScore rdf:type rdf:Property ;
