    rdfs:range xsd:string .

ind:planContractNumber rdf:type rdf:Property ;
    rdfs:label 'Plan Contract Number' ;
    rdfs:comment 'Contract number of the plan submitted to CMS for risk adjustment.' ;
    rdfs:domain ind:RapsSubmission ;
