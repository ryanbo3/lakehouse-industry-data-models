ind:employerUnderwritingCaseId rdf:type rdf:Property ;
    rdfs:label 'Employer Underwriting Case Id' ;
    rdfs:comment 'Foreign key linking to employer.employer_underwriting_case. Business justification: In health insurance underwriting, the employer-facing underwriting case (quote, census, rating factors) and the risk-side underwriting case (morbidity, claims PMPM, risk classification) are two facets' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EmployerUnderwritingCase .

ind:ageGenderDistributionIndex rdf:type rdf:Property ;
    rdfs:label 'Age Gender Distribution Index' ;
    rdfs:comment 'Statistical index representing the age and gender mix of the applicant population.' ;
    rdfs:domain ind:RiskUnderwritingCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:applicantType rdf:type rdf:Property ;
    rdfs:label 'Applicant Type' ;
    rdfs:comment 'Classification of the applicant as individual, small group, large group, etc.' ;
    rdfs:domain ind:RiskUnderwritingCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chronicConditionPrevalenceRate rdf:type rdf:Property ;
    rdfs:label 'Chronic Condition Prevalence Rate' ;
    rdfs:comment 'Rate of chronic conditions among the applicant population.' ;
    rdfs:domain ind:RiskUnderwritingCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:decisionRationale rdf:type rdf:Property ;
    rdfs:label 'Decision Rationale' ;
