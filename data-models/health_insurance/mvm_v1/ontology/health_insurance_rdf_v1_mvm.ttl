ind:severity rdf:type rdf:Property ;
    rdfs:label 'Severity' ;
    rdfs:comment 'Clinical severity level of the condition.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataCollectionMethodology rdf:type rdf:Property ;
    rdfs:label 'Data Collection Methodology' ;
    rdfs:comment 'Method used to collect data for the measure (administrative, hybrid, or survey).' ;
    rdfs:domain ind:HedisMeasure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:denominatorDefinition rdf:type rdf:Property ;
    rdfs:label 'Denominator Definition' ;
    rdfs:comment 'Exact definition of the denominator component of the measure.' ;
    rdfs:domain ind:HedisMeasure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eligiblePopulationCriteria rdf:type rdf:Property ;
    rdfs:label 'Eligible Population Criteria' ;
    rdfs:comment 'Eligibility rules that define the member cohort for the measure.' ;
    rdfs:domain ind:HedisMeasure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exclusionCriteria rdf:type rdf:Property ;
    rdfs:label 'Exclusion Criteria' ;
    rdfs:comment 'Conditions or member attributes that exclude a member from the denominator.' ;
