    rdfs:comment 'Tier level used in underwriting risk segmentation.' ;
    rdfs:domain ind:RiskUnderwritingCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:aggregateAttachmentAmount rdf:type rdf:Property ;
    rdfs:label 'Aggregate Attachment Amount' ;
    rdfs:comment 'Monetary threshold for aggregate stop-loss coverage.' ;
    rdfs:domain ind:ReinsuranceArrangement ;
    rdf:type owl:DatatypeProperty ;
