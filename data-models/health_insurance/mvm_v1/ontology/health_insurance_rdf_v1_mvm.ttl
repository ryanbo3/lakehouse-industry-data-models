ind:icd10Code rdf:type rdf:Property ;
    rdfs:label 'Icd10 Code' ;
    rdfs:comment 'Standard ICD-10 diagnosis code associated with the mapping.' ;
    rdfs:domain ind:HccMapping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:icd10Description rdf:type rdf:Property ;
    rdfs:label 'Icd10 Description' ;
    rdfs:comment 'Full textual description of the ICD-10 diagnosis.' ;
