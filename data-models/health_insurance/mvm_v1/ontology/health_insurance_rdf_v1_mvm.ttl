    rdfs:range xsd:boolean .

ind:memberOutreachStatus rdf:type rdf:Property ;
    rdfs:label 'Member Outreach Status' ;
    rdfs:comment 'Lifecycle state of the outreach activity record.' ;
    rdfs:domain ind:MemberOutreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outcome rdf:type rdf:Property ;
