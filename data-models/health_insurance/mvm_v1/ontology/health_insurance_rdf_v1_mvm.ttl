    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:encounterType rdf:type rdf:Property ;
    rdfs:label 'Encounter Type' ;
    rdfs:comment 'Category of the clinical encounter data included in the batch.' ;
