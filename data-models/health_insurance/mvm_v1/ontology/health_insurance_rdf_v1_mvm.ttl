    rdfs:comment 'Status of the reconciliation of tax credits (APTC/CSR) with the IRS.' ;
    rdfs:domain ind:ExchangeEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditEngagementId rdf:type rdf:Property ;
    rdfs:label 'Audit Engagement Id' ;
    rdfs:comment 'Foreign key linking to compliance.audit_engagement. Business justification: CMS Risk Adjustment Data Validation (RADV) audits directly examine member risk scores. Linking member_risk_score to the audit_engagement driving the RADV review is essential for tracking which scores ' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AuditEngagement .

ind:auditUser rdf:type rdf:Property ;
    rdfs:label 'Audit User' ;
    rdfs:comment 'User ID of the person who performed the most recent audit action.' ;
    rdfs:domain ind:MemberRiskScore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cmsPublishedScore rdf:type rdf:Property ;
    rdfs:label 'Cms Published Score' ;
    rdfs:comment 'RAF score value as published by CMS after reconciliation.' ;
