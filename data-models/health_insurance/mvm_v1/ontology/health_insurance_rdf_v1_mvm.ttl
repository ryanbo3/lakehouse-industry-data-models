    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:idType rdf:type rdf:Property ;
    rdfs:label 'Id Type' ;
    rdfs:comment 'Type of identifier used for the contact (e.g., NPI, SSN).' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:idValue rdf:type rdf:Property ;
    rdfs:label 'Id Value' ;
    rdfs:comment 'The actual identifier value corresponding to contact_id_type.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:memberContactStatus rdf:type rdf:Property ;
    rdfs:label 'Member Contact Status' ;
    rdfs:comment 'Current lifecycle status of the contact record.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:optInEmail rdf:type rdf:Property ;
    rdfs:label 'Opt In Email' ;
    rdfs:comment 'Indicates whether the member has consented to receive email communications.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:optInRobocall rdf:type rdf:Property ;
    rdfs:label 'Opt In Robocall' ;
    rdfs:comment 'Indicates whether the member permits automated voice calls.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:optInSms rdf:type rdf:Property ;
    rdfs:label 'Opt In Sms' ;
    rdfs:comment 'Indicates whether the member has consented to receive SMS messages.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:phoneHome rdf:type rdf:Property ;
    rdfs:label 'Phone Home' ;
    rdfs:comment 'Primary residential telephone number.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phoneMobile rdf:type rdf:Property ;
    rdfs:label 'Phone Mobile' ;
    rdfs:comment 'Cellular telephone number for mobile contact.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phoneWork rdf:type rdf:Property ;
    rdfs:label 'Phone Work' ;
    rdfs:comment 'Telephone number associated with the contact\'s place of work.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredContactMethod rdf:type rdf:Property ;
    rdfs:label 'Preferred Contact Method' ;
    rdfs:comment 'Contact channel the member prefers for communications.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationship rdf:type rdf:Property ;
    rdfs:label 'Relationship' ;
    rdfs:comment 'Relationship of the contact to the member.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stateProvince rdf:type rdf:Property ;
    rdfs:label 'State Province' ;
    rdfs:comment 'State or province component of the address.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tcpAConsentFlag rdf:type rdf:Property ;
    rdfs:label 'Tcp A Consent Flag' ;
    rdfs:comment 'True if the contact has provided consent under the Telephone Consumer Protection Act.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:memberEligibilitySpanId rdf:type rdf:Property ;
    rdfs:label 'Member Eligibility Span Id' ;
    rdfs:comment 'System-generated unique identifier for the eligibility span record.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MemberEligibilitySpan .

ind:openEnrollmentWindowId rdf:type rdf:Property ;
    rdfs:label 'Open Enrollment Window Id' ;
    rdfs:comment 'Foreign key linking to employer.open_enrollment_window. Business justification: Eligibility spans are created or modified during employer open enrollment windows. Linking spans to the originating window supports compliance audit trails, retroactive eligibility validation, and reg' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OpenEnrollmentWindow .

ind:policyId rdf:type rdf:Property ;
    rdfs:label 'Policy Id' ;
    rdfs:comment 'Foreign key linking to member.policy. Business justification: An eligibility span represents a continuous period of health plan coverage for a member, which is governed by a specific policy. Linking member_eligibility_span to policy via policy_id enables traceab' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Policy .

ind:premiumRateId rdf:type rdf:Property ;
    rdfs:label 'Premium Rate Id' ;
    rdfs:comment 'Foreign key linking to billing.premium_rate. Business justification: The eligibility span is the operational record that drives premium calculation for a coverage period. Linking it directly to the applicable premium rate enables premium estimation at enrollment, rate ' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PremiumRate .

ind:tpaArrangementId rdf:type rdf:Property ;
    rdfs:label 'Tpa Arrangement Id' ;
    rdfs:comment 'Foreign key linking to employer.tpa_arrangement. Business justification: For self-funded employer groups, eligibility spans are administered under a specific TPA arrangement governing claims adjudication, fee schedules, and stop-loss thresholds. TPA administrators require ' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TpaArrangement .

ind:cobroEndDate rdf:type rdf:Property ;
    rdfs:label 'Cobro End Date' ;
    rdfs:comment 'End date of COBRA continuation coverage, if applicable.' ;
    rdfs:domain ind:MemberEligibilitySpan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cobroStartDate rdf:type rdf:Property ;
    rdfs:label 'Cobro Start Date' ;
    rdfs:comment 'Start date of COBRA continuation coverage, if applicable.' ;
    rdfs:domain ind:MemberEligibilitySpan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:eligibilitySource rdf:type rdf:Property ;
    rdfs:label 'Eligibility Source' ;
    rdfs:comment 'Origin of the eligibility information (e.g., EDI 834 file, manual entry).' ;
    rdfs:domain ind:MemberEligibilitySpan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentType rdf:type rdf:Property ;
    rdfs:label 'Enrollment Type' ;
    rdfs:comment 'Nature of the enrollment event that created this eligibility span.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gapInCoverageFlag rdf:type rdf:Property ;
    rdfs:label 'Gap In Coverage Flag' ;
    rdfs:comment 'True if there is a gap in coverage between this span and the previous span.' ;
    rdfs:domain ind:MemberEligibilitySpan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPrimaryCoverage rdf:type rdf:Property ;
    rdfs:label 'Is Primary Coverage' ;
    rdfs:comment 'Indicates whether this span represents the primary coverage for the member (vs. supplemental).' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:retroactiveEligibilityFlag rdf:type rdf:Property ;
    rdfs:label 'Retroactive Eligibility Flag' ;
    rdfs:comment 'Indicates if the eligibility was applied retroactively.' ;
    rdfs:domain ind:MemberEligibilitySpan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:subscriberRelationshipCode rdf:type rdf:Property ;
    rdfs:label 'Subscriber Relationship Code' ;
    rdfs:comment 'Code indicating the relationship of the member to the primary subscriber.' ;
    rdfs:domain ind:MemberEligibilitySpan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cobraContinuantId rdf:type rdf:Property ;
    rdfs:label 'Cobra Continuant Id' ;
    rdfs:comment 'System-generated unique identifier for the COBRA continuant record.' ;
    rdfs:domain ind:CobraContinuant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cobraElectionId rdf:type rdf:Property ;
    rdfs:label 'Cobra Election Id' ;
    rdfs:comment 'Foreign key linking to enrollment.cobra_election. Business justification: cobra_continuant (member domain) and cobra_election (enrollment domain) are complementary records of the same COBRA event. Linking them is essential for COBRA administration, DOL 60-day notice complia' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CobraElection .

ind:disenrollmentId rdf:type rdf:Property ;
    rdfs:label 'Disenrollment Id' ;
    rdfs:comment 'Foreign key linking to member.disenrollment. Business justification: COBRA continuation is triggered by a qualifying disenrollment event (loss of employer-sponsored coverage). Linking cobra_continuant to the triggering disenrollment record via disenrollment_id establis' ;
    rdfs:domain ind:Member ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Disenrollment .

ind:qualifyingLifeEventId rdf:type rdf:Property ;
    rdfs:label 'Qualifying Life Event Id' ;
    rdfs:comment 'Foreign key linking to enrollment.qualifying_life_event. Business justification: COBRA eligibility is triggered by qualifying life events. cobra_continuant has denormalized qualifying_event_type and qualifying_event_date but no FK to the QLE record. Linking to qualifying_life_even' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:QualifyingLifeEvent .

ind:transactionId rdf:type rdf:Property ;
    rdfs:label 'Transaction Id' ;
    rdfs:comment 'Identifier of the original enrollment that triggered COBRA eligibility.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Transaction .

ind:cobraContinuantStatus rdf:type rdf:Property ;
    rdfs:label 'Cobra Continuant Status' ;
    rdfs:comment 'Current lifecycle status of the COBRA coverage.' ;
    rdfs:domain ind:CobraContinuant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cobraEligibilityIndicator rdf:type rdf:Property ;
    rdfs:label 'Cobra Eligibility Indicator' ;
    rdfs:comment 'Flag indicating whether the member is eligible for COBRA coverage.' ;
    rdfs:domain ind:CobraContinuant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cobraEligibilityReason rdf:type rdf:Property ;
    rdfs:label 'Cobra Eligibility Reason' ;
    rdfs:comment 'Free-text explanation for eligibility determination.' ;
    rdfs:domain ind:CobraContinuant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cobraNoticeSentDate rdf:type rdf:Property ;
    rdfs:label 'Cobra Notice Sent Date' ;
    rdfs:comment 'Date the required COBRA notice was mailed or emailed to the member.' ;
    rdfs:domain ind:CobraContinuant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cobraNoticeType rdf:type rdf:Property ;
    rdfs:label 'Cobra Notice Type' ;
    rdfs:comment 'Classification of the notice (e.g., initial election notice, reminder, final notice).' ;
    rdfs:domain ind:CobraContinuant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:electionDate rdf:type rdf:Property ;
    rdfs:label 'Election Date' ;
    rdfs:comment 'Date the member elected to continue coverage under COBRA.' ;
    rdfs:domain ind:CobraContinuant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:electionDeadline rdf:type rdf:Property ;
    rdfs:label 'Election Deadline' ;
    rdfs:comment 'Last date by which the member must elect COBRA coverage.' ;
    rdfs:domain ind:CobraContinuant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:exhaustionDate rdf:type rdf:Property ;
    rdfs:label 'Exhaustion Date' ;
    rdfs:comment 'Date when coverage was exhausted due to reaching the maximum period.' ;
    rdfs:domain ind:CobraContinuant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isExhausted rdf:type rdf:Property ;
    rdfs:label 'Is Exhausted' ;
    rdfs:comment 'True when the maximum COBRA coverage period has been reached.' ;
    rdfs:domain ind:CobraContinuant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maxCoverageEndDate rdf:type rdf:Property ;
    rdfs:label 'Max Coverage End Date' ;
    rdfs:comment 'Calculated date when the maximum allowable COBRA period expires.' ;
    rdfs:domain ind:CobraContinuant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:maxCoverageMonths rdf:type rdf:Property ;
    rdfs:label 'Max Coverage Months' ;
    rdfs:comment 'Maximum number of months the member may receive COBRA coverage (e.g., 18, 29, 36).' ;
    rdfs:domain ind:CobraContinuant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:memberRelationship rdf:type rdf:Property ;
    rdfs:label 'Member Relationship' ;
    rdfs:comment 'Relationship of the continuant to the primary employee (e.g., employee, spouse, child).' ;
    rdfs:domain ind:CobraContinuant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:premiumDueDate rdf:type rdf:Property ;
    rdfs:label 'Premium Due Date' ;
    rdfs:comment 'Date by which the premium must be paid for the coverage month.' ;
    rdfs:domain ind:CobraContinuant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:premiumPaymentDate rdf:type rdf:Property ;
    rdfs:label 'Premium Payment Date' ;
    rdfs:comment 'Date the premium payment was actually received.' ;
    rdfs:domain ind:CobraContinuant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:premiumPaymentStatus rdf:type rdf:Property ;
    rdfs:label 'Premium Payment Status' ;
    rdfs:comment 'Current status of premium payment for the coverage period.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pcpAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Pcp Assignment Id' ;
    rdfs:comment 'Primary key for pcp_assignment' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PcpAssignment .

ind:pcpProviderId rdf:type rdf:Property ;
    rdfs:label 'Pcp Provider Id' ;
    rdfs:comment 'Foreign key linking to provider.provider_provider. Business justification: REQUIRED: PCP assignment records must reference the provider entity to support network participation audits and accurate provider-member linkage.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Provider .

ind:assignmentReason rdf:type rdf:Property ;
    rdfs:label 'Assignment Reason' ;
    rdfs:comment 'Free-text explanation for why the PCP was assigned (e.g., member request, network requirement).' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentStatus rdf:type rdf:Property ;
    rdfs:label 'Assignment Status' ;
    rdfs:comment 'Current lifecycle status of the PCP assignment.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentType rdf:type rdf:Property ;
    rdfs:label 'Assignment Type' ;
    rdfs:comment 'Method by which the PCP was assigned: member-selected, auto-assigned by system, or plan-assigned.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeTimestamp rdf:type rdf:Property ;
    rdfs:label 'Change Timestamp' ;
    rdfs:comment 'Exact time when the most recent change to the assignment was recorded.' ;
    rdfs:domain ind:PcpAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:isCurrent rdf:type rdf:Property ;
    rdfs:label 'Is Current' ;
    rdfs:comment 'True if the assignment is the active PCP for the member at query time.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pcpSpecialtyCode rdf:type rdf:Property ;
    rdfs:label 'Pcp Specialty Code' ;
    rdfs:comment 'Standardized code representing the PCP\'s clinical specialty.' ;
    rdfs:domain ind:PcpAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cobRecordId rdf:type rdf:Property ;
    rdfs:label 'Cob Record Id' ;
    rdfs:comment 'Primary key for cob_record' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CobRecord .

ind:birthdayRuleApplicable rdf:type rdf:Property ;
    rdfs:label 'Birthday Rule Applicable' ;
    rdfs:comment 'Indicates whether the birthday rule is used to determine primary payer.' ;
    rdfs:domain ind:CobRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cobOrder rdf:type rdf:Property ;
    rdfs:label 'Cob Order' ;
    rdfs:comment 'Sequencing of the carrier in the coordination of benefits hierarchy.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cobRecordNumber rdf:type rdf:Property ;
    rdfs:label 'Cob Record Number' ;
    rdfs:comment 'Business identifier assigned to the COB record for external reference.' ;
    rdfs:domain ind:CobRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cobStatus rdf:type rdf:Property ;
    rdfs:label 'Cob Status' ;
    rdfs:comment 'Current lifecycle status of the COB record.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cobVerificationDate rdf:type rdf:Property ;
    rdfs:label 'Cob Verification Date' ;
    rdfs:comment 'Date when the COB information was verified.' ;
    rdfs:domain ind:CobRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:coordinationOfBenefitsRule rdf:type rdf:Property ;
    rdfs:label 'Coordination Of Benefits Rule' ;
    rdfs:comment 'Rule applied to determine payer order (e.g., birthday rule).' ;
    rdfs:domain ind:CobRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isMspCompliant rdf:type rdf:Property ;
    rdfs:label 'Is Msp Compliant' ;
    rdfs:comment 'Indicates compliance with Medicare Secondary Payer rules.' ;
    rdfs:domain ind:CobRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSubrogationFlag rdf:type rdf:Property ;
    rdfs:label 'Is Subrogation Flag' ;
    rdfs:comment 'True if the claim may be subject to subrogation based on this COB arrangement.' ;
    rdfs:domain ind:CobRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:consentId rdf:type rdf:Property ;
    rdfs:label 'Consent Id' ;
    rdfs:comment 'Primary key for consent' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:authorizedRecipientProviderId rdf:type rdf:Property ;
    rdfs:label 'Authorized Recipient Provider Id' ;
    rdfs:comment 'Foreign key linking to provider.provider_provider. Business justification: HIPAA and 42 CFR Part 2 consent records frequently name a specific provider as the authorized recipient of PHI disclosures. Compliance audits and authorization tracking require a structured FK to the ' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Provider .

ind:carePlanId rdf:type rdf:Property ;
    rdfs:label 'Care Plan Id' ;
    rdfs:comment 'Foreign key linking to care.care_plan. Business justification: HIPAA and 42 CFR Part 2 require documented consent records linked to care coordination activities. Care plans require explicit consent for sharing PHI among care team members. This FK enables complian' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CarePlan .

ind:authorizedRecipient rdf:type rdf:Property ;
    rdfs:label 'Authorized Recipient' ;
    rdfs:comment 'Entity or individual authorized to receive the disclosed PHI.' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectionMethod rdf:type rdf:Property ;
    rdfs:label 'Collection Method' ;
    rdfs:comment 'Method used to collect the consent from the member.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentDate rdf:type rdf:Property ;
    rdfs:label 'Consent Date' ;
    rdfs:comment 'Date when the consent was originally obtained.' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:consentStatus rdf:type rdf:Property ;
    rdfs:label 'Consent Status' ;
    rdfs:comment 'Current lifecycle status of the consent.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentType rdf:type rdf:Property ;
    rdfs:label 'Consent Type' ;
    rdfs:comment 'Category of consent indicating purpose of authorized disclosure.' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disclosureScope rdf:type rdf:Property ;
    rdfs:label 'Disclosure Scope' ;
    rdfs:comment 'Description of the data elements or categories covered by the consent.' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:is42cfrPart2Applicable rdf:type rdf:Property ;
    rdfs:label 'Is 42cfr Part2 Applicable' ;
    rdfs:comment 'Flag indicating if the consent is subject to 42 CFR Part 2 substance abuse privacy rules.' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isElectronicSignature rdf:type rdf:Property ;
    rdfs:label 'Is Electronic Signature' ;
    rdfs:comment 'Indicates if the consent was captured with an electronic signature.' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isMinimumNecessary rdf:type rdf:Property ;
    rdfs:label 'Is Minimum Necessary' ;
    rdfs:comment 'Indicates whether the consent adheres to the HIPAA minimum necessary standard.' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:language rdf:type rdf:Property ;
    rdfs:label 'Language' ;
    rdfs:comment 'Language in which the consent was provided.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revocationDate rdf:type rdf:Property ;
    rdfs:label 'Revocation Date' ;
    rdfs:comment 'Date when the consent was revoked by the member.' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:signatureTimestamp rdf:type rdf:Property ;
    rdfs:label 'Signature Timestamp' ;
    rdfs:comment 'Timestamp of the electronic signature capture.' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:stateOfResidence rdf:type rdf:Property ;
    rdfs:label 'State Of Residence' ;
    rdfs:comment 'State code of the member\'s residence at time of consent.' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disenrollmentHealthPlanId rdf:type rdf:Property ;
    rdfs:label 'Disenrollment Health Plan Id' ;
    rdfs:comment 'Identifier of the health plan the member was enrolled in before disenrollment.' ;
    rdfs:domain ind:Disenrollment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:HealthPlan .

ind:disenrollmentNewPlanHealthPlanId rdf:type rdf:Property ;
    rdfs:label 'Disenrollment New Plan Health Plan Id' ;
    rdfs:comment 'Identifier of a new plan if the member re-enrolls immediately after disenrollment.' ;
    rdfs:domain ind:Disenrollment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:HealthPlan .

ind:appealRightsNotified rdf:type rdf:Property ;
    rdfs:label 'Appeal Rights Notified' ;
    rdfs:comment 'Indicates whether the member was notified of appeal rights.' ;
    rdfs:domain ind:Disenrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cobroEligibility rdf:type rdf:Property ;
    rdfs:label 'Cobro Eligibility' ;
    rdfs:comment 'Flag indicating if the member qualifies for COBRA continuation coverage.' ;
    rdfs:domain ind:Disenrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:disenrollmentNumber rdf:type rdf:Property ;
    rdfs:label 'Disenrollment Number' ;
    rdfs:comment 'Business identifier assigned to the disenrollment event, used for external reporting and audit.' ;
    rdfs:domain ind:Disenrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disenrollmentStatus rdf:type rdf:Property ;
    rdfs:label 'Disenrollment Status' ;
    rdfs:comment 'Current processing status of the disenrollment request.' ;
    rdfs:domain ind:Disenrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveTimestamp rdf:type rdf:Property ;
    rdfs:label 'Effective Timestamp' ;
    rdfs:comment 'Date and time when the disenrollment becomes effective for coverage purposes.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:eligibilityLossIndicator rdf:type rdf:Property ;
    rdfs:label 'Eligibility Loss Indicator' ;
    rdfs:comment 'True if disenrollment is due to loss of eligibility.' ;
    rdfs:domain ind:Disenrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:noticeSentDate rdf:type rdf:Property ;
    rdfs:label 'Notice Sent Date' ;
    rdfs:comment 'Date the required notice of disenrollment was sent to the member.' ;
    rdfs:domain ind:Disenrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:processedBy rdf:type rdf:Property ;
    rdfs:label 'Processed By' ;
    rdfs:comment 'User or system identifier that processed the disenrollment.' ;
    rdfs:domain ind:Disenrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Processed Timestamp' ;
    rdfs:comment 'Date and time when the disenrollment was processed.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:reasonCode rdf:type rdf:Property ;
    rdfs:label 'Reason Code' ;
    rdfs:comment 'Standardized code representing why the member is disenrolling.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reasonDescription rdf:type rdf:Property ;
    rdfs:label 'Reason Description' ;
    rdfs:comment 'Free-text description of the disenrollment reason.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refundAdjustmentAmount rdf:type rdf:Property ;
    rdfs:label 'Refund Adjustment Amount' ;
    rdfs:comment 'Adjustments (e.g., fees, penalties) applied to the gross refund.' ;
    rdfs:domain ind:Disenrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:refundGrossAmount rdf:type rdf:Property ;
    rdfs:label 'Refund Gross Amount' ;
    rdfs:comment 'Total gross amount refunded to the member as part of disenrollment.' ;
    rdfs:domain ind:Disenrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:refundNetAmount rdf:type rdf:Property ;
    rdfs:label 'Refund Net Amount' ;
    rdfs:comment 'Net amount actually paid to the member after adjustments.' ;
    rdfs:domain ind:Disenrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:source rdf:type rdf:Property ;
    rdfs:label 'Source' ;
    rdfs:comment 'Origin of the disenrollment request.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminationType rdf:type rdf:Property ;
    rdfs:label 'Termination Type' ;
    rdfs:comment 'Classification of the disenrollment termination.' ;
    rdfs:domain ind:Disenrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:groupLocationId rdf:type rdf:Property ;
    rdfs:label 'Group Location Id' ;
    rdfs:comment 'Foreign key linking to employer.group_location. Business justification: Eligibility calculations depend on employer\'s primary location to apply network rules and state-specific regulations.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GroupLocation .

ind:primaryCareProviderId rdf:type rdf:Property ;
    rdfs:label 'Primary Care Provider Id' ;
    rdfs:comment 'Foreign key linking to provider.provider_provider. Business justification: Needed to assign a primary care provider to each member’s coverage span for network compliance and care coordination reports.' ;
    rdfs:domain ind:EnrollmentEligibilitySpan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Provider .

ind:benefitDesignation rdf:type rdf:Property ;
    rdfs:label 'Benefit Designation' ;
    rdfs:comment 'Design of the benefit plan (e.g., HMO, PPO).' ;
    rdfs:domain ind:EnrollmentEligibilitySpan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:benefitPeriodEnd rdf:type rdf:Property ;
    rdfs:label 'Benefit Period End' ;
    rdfs:comment 'End date of the benefit period (often same as termination_date).' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:benefitPeriodStart rdf:type rdf:Property ;
    rdfs:label 'Benefit Period Start' ;
    rdfs:comment 'Start date of the benefit period (often same as effective_date).' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:coverageCategory rdf:type rdf:Property ;
    rdfs:label 'Coverage Category' ;
    rdfs:comment 'Classification of the covered individual (e.g., employee, spouse).' ;
    rdfs:domain ind:EnrollmentEligibilitySpan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coverageLimitAmount rdf:type rdf:Property ;
    rdfs:label 'Coverage Limit Amount' ;
    rdfs:comment 'Maximum allowable amount for a specific benefit within the span.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coverageLimitUnits rdf:type rdf:Property ;
    rdfs:label 'Coverage Limit Units' ;
    rdfs:comment 'Unit of measure for the coverage limit (e.g., visits, days).' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deductibleResetDate rdf:type rdf:Property ;
    rdfs:label 'Deductible Reset Date' ;
    rdfs:comment 'Date when the deductible accumulator resets (usually start of benefit year).' ;
    rdfs:domain ind:EnrollmentEligibilitySpan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:enrollmentEligibilitySpanStatus rdf:type rdf:Property ;
    rdfs:label 'Enrollment Eligibility Span Status' ;
    rdfs:comment 'Current lifecycle status of the eligibility span.' ;
    rdfs:domain ind:EnrollmentEligibilitySpan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentEventType rdf:type rdf:Property ;
    rdfs:label 'Enrollment Event Type' ;
    rdfs:comment 'Category of enrollment event that created or modified this span.' ;
    rdfs:domain ind:Enrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isWaiverApplied rdf:type rdf:Property ;
    rdfs:label 'Is Waiver Applied' ;
    rdfs:comment 'Indicates if a cost-sharing waiver (e.g., HSA) is applied to this span.' ;
    rdfs:domain ind:EnrollmentEligibilitySpan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastStatusChangeTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Status Change Timestamp' ;
    rdfs:comment 'Timestamp when the status field last changed.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:moopResetDate rdf:type rdf:Property ;
    rdfs:label 'Moop Reset Date' ;
    rdfs:comment 'Date when the MOOP threshold resets.' ;
    rdfs:domain ind:EnrollmentEligibilitySpan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:moopThreshold rdf:type rdf:Property ;
    rdfs:label 'Moop Threshold' ;
    rdfs:comment 'Combined deductible and OOP limit for this span.' ;
    rdfs:domain ind:EnrollmentEligibilitySpan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:oopMaximum rdf:type rdf:Property ;
    rdfs:label 'Oop Maximum' ;
    rdfs:comment 'Maximum out-of-pocket expense the member can incur.' ;
    rdfs:domain ind:EnrollmentEligibilitySpan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:oopResetDate rdf:type rdf:Property ;
    rdfs:label 'Oop Reset Date' ;
    rdfs:comment 'Date when the OOP accumulator resets.' ;
    rdfs:domain ind:EnrollmentEligibilitySpan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:priorCoverageEndDate rdf:type rdf:Property ;
    rdfs:label 'Prior Coverage End Date' ;
    rdfs:comment 'Termination date of the preceding coverage period, if any.' ;
    rdfs:domain ind:EnrollmentEligibilitySpan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:priorCoverageIndicator rdf:type rdf:Property ;
    rdfs:label 'Prior Coverage Indicator' ;
    rdfs:comment 'True if the member had coverage immediately before this span.' ;
    rdfs:domain ind:EnrollmentEligibilitySpan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:qualifyingLifeEventCode rdf:type rdf:Property ;
    rdfs:label 'Qualifying Life Event Code' ;
    rdfs:comment 'Code representing the life event that triggered a special enrollment.' ;
    rdfs:domain ind:EnrollmentEligibilitySpan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retroactiveAdjustmentFlag rdf:type rdf:Property ;
    rdfs:label 'Retroactive Adjustment Flag' ;
    rdfs:comment 'Indicates whether the span was created or modified retroactively.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:retroactiveAdjustmentReason rdf:type rdf:Property ;
    rdfs:label 'Retroactive Adjustment Reason' ;
    rdfs:comment 'Explanation for a retroactive change to the eligibility span.' ;
    rdfs:domain ind:EnrollmentEligibilitySpan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subscriberRelationship rdf:type rdf:Property ;
    rdfs:label 'Subscriber Relationship' ;
    rdfs:comment 'Relationship of the covered individual to the subscriber.' ;
    rdfs:domain ind:EnrollmentEligibilitySpan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:utilizationResetDate rdf:type rdf:Property ;
    rdfs:label 'Utilization Reset Date' ;
    rdfs:comment 'Date when utilization counters (e.g., visit counts) reset.' ;
    rdfs:domain ind:EnrollmentEligibilitySpan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:waiverType rdf:type rdf:Property ;
    rdfs:label 'Waiver Type' ;
    rdfs:comment 'Type of waiver applied, if any.' ;
    rdfs:domain ind:EnrollmentEligibilitySpan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentOpenEnrollmentPeriodId rdf:type rdf:Property ;
    rdfs:label 'Enrollment Open Enrollment Period Id' ;
    rdfs:comment 'Foreign key linking to enrollment.open_enrollment_period. Business justification: Each enrollment transaction occurs within a defined open enrollment period; linking transaction to period enables period-based reporting and ensures the period is not a silo.' ;
    rdfs:domain ind:Transaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OpenEnrollmentPeriod .

ind:groupContactId rdf:type rdf:Property ;
    rdfs:label 'Group Contact Id' ;
    rdfs:comment 'Foreign key linking to employer.group_contact. Business justification: Required for audit of enrollment approvals: employer\'s designated contact must be recorded per ACA compliance reporting.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GroupContact .

ind:groupRenewalId rdf:type rdf:Property ;
    rdfs:label 'Group Renewal Id' ;
    rdfs:comment 'Foreign key linking to employer.group_renewal. Business justification: Financial reconciliation requires associating each enrollment transaction with the employer\'s renewal cycle.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GroupRenewal .

ind:memberGroupId rdf:type rdf:Property ;
    rdfs:label 'Member Group Id' ;
    rdfs:comment 'Identifier of the employer group or line of business to which the member belongs.' ;
    rdfs:domain ind:Transaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Group .

ind:adjustmentAmount rdf:type rdf:Property ;
    rdfs:label 'Adjustment Amount' ;
    rdfs:comment 'Monetary adjustment (e.g., discount, surcharge) applied to the gross premium.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:adjustmentReasonCode rdf:type rdf:Property ;
    rdfs:label 'Adjustment Reason Code' ;
    rdfs:comment 'Standard code describing why a financial or coverage adjustment was made.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvingAuthority rdf:type rdf:Property ;
    rdfs:label 'Approving Authority' ;
    rdfs:comment 'Name or role of the individual or system that approved the enrollment change.' ;
    rdfs:domain ind:Transaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditUserRole rdf:type rdf:Property ;
    rdfs:label 'Audit User Role' ;
    rdfs:comment 'Role of the audit user (e.g., admin, operator, system).' ;
