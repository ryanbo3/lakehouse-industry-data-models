ind:denialId rdf:type rdf:Property ;
    rdfs:label 'Denial Id' ;
    rdfs:comment 'Foreign key linking to claim.denial. Business justification: When a claim is denied, the EOB document must reference the specific denial record to accurately communicate denial reason codes, appeal rights, and clinical criteria to the member. The eob product ha' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Denial .

ind:paymentId rdf:type rdf:Property ;
    rdfs:label 'Payment Id' ;
    rdfs:comment 'Foreign key linking to claim.payment. Business justification: EOB documents communicate payment information to members and providers, including plan_paid_amount and member_responsibility_amount. Linking eob.payment_id -> payment.payment_id establishes the author' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Payment .

ind:appealRightsText rdf:type rdf:Property ;
    rdfs:label 'Appeal Rights Text' ;
