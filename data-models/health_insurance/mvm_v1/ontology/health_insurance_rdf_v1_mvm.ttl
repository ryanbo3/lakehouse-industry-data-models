ind:billingGroupPracticeId rdf:type rdf:Property ;
    rdfs:label 'Billing Group Practice Id' ;
    rdfs:comment 'Foreign key linking to provider.group_practice. Business justification: Claims submitted under a group NPI must be traceable to the group_practice entity for group-level contract validation, network participation verification, and provider directory reconciliation. Role-p' ;
