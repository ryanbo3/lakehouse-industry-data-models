    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hccDescription rdf:type rdf:Property ;
    rdfs:label 'Hcc Description' ;
    rdfs:comment 'Human-readable description of the HCC.' ;
    rdfs:domain ind:HccMapping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hccMappingStatus rdf:type rdf:Property ;
    rdfs:label 'Hcc Mapping Status' ;
    rdfs:comment 'Current lifecycle status of the mapping record.' ;
    rdfs:domain ind:HccMapping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hierarchyLevel rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Level' ;
    rdfs:comment 'Depth of the HCC within the hierarchical structure (0 = top level).' ;
    rdfs:domain ind:HccMapping ;
