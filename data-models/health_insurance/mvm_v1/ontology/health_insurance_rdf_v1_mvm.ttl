    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:coverageTier rdf:type rdf:Property ;
    rdfs:label 'Coverage Tier' ;
    rdfs:comment 'Level of coverage elected (e.g., employee only, employee + spouse, employee + children, family).' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dentalRiderFlag rdf:type rdf:Property ;
    rdfs:label 'Dental Rider Flag' ;
    rdfs:comment 'Indicates if a dental coverage rider was elected.' ;
    rdfs:domain ind:PlanElection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:electionNumber rdf:type rdf:Property ;
    rdfs:label 'Election Number' ;
    rdfs:comment 'External reference number assigned to the election by the enrollment system.' ;
    rdfs:domain ind:PlanElection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:electionType rdf:type rdf:Property ;
    rdfs:label 'Election Type' ;
    rdfs:comment 'Nature of the election event (new enrollment, change, termination, reinstatement).' ;
    rdfs:domain ind:PlanElection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fsaElectionFlag rdf:type rdf:Property ;
    rdfs:label 'Fsa Election Flag' ;
    rdfs:comment 'Indicates if a Flexible Spending Account was elected.' ;
    rdfs:domain ind:PlanElection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hraElectionFlag rdf:type rdf:Property ;
    rdfs:label 'Hra Election Flag' ;
    rdfs:comment 'Indicates if a Health Reimbursement Arrangement was elected.' ;
    rdfs:domain ind:PlanElection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hsaElectionFlag rdf:type rdf:Property ;
    rdfs:label 'Hsa Election Flag' ;
    rdfs:comment 'Indicates if a Health Savings Account was elected.' ;
    rdfs:domain ind:PlanElection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isCobraEligible rdf:type rdf:Property ;
    rdfs:label 'Is Cobra Eligible' ;
    rdfs:comment 'Indicates if the election is eligible for COBRA continuation coverage.' ;
    rdfs:domain ind:PlanElection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:planElectionStatus rdf:type rdf:Property ;
    rdfs:label 'Plan Election Status' ;
    rdfs:comment 'Current processing status of the election record.' ;
    rdfs:domain ind:PlanElection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:premiumContributionEmployee rdf:type rdf:Property ;
    rdfs:label 'Premium Contribution Employee' ;
    rdfs:comment 'Portion of the premium paid by the employee.' ;
    rdfs:domain ind:PlanElection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:premiumContributionEmployer rdf:type rdf:Property ;
    rdfs:label 'Premium Contribution Employer' ;
    rdfs:comment 'Portion of the premium paid by the employer.' ;
    rdfs:domain ind:PlanElection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalPremium rdf:type rdf:Property ;
    rdfs:label 'Total Premium' ;
    rdfs:comment 'Total premium amount for the elected coverage (employer + employee).' ;
    rdfs:domain ind:PlanElection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:visionRiderFlag rdf:type rdf:Property ;
    rdfs:label 'Vision Rider Flag' ;
    rdfs:comment 'Indicates if a vision coverage rider was elected.' ;
    rdfs:domain ind:PlanElection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:medicaidEligibilityId rdf:type rdf:Property ;
    rdfs:label 'Medicaid Eligibility Id' ;
    rdfs:comment 'System-generated unique identifier for the Medicaid eligibility record.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MedicaidEligibility .

ind:assignedPcpProviderId rdf:type rdf:Property ;
    rdfs:label 'Assigned Pcp Provider Id' ;
    rdfs:comment 'Foreign key linking to provider.provider_provider. Business justification: Medicaid managed care programs require PCP assignment for every beneficiary for care coordination, state reporting, and capitation payment. This is a named regulatory and operational requirement. A Me' ;
    rdfs:domain ind:Enrollment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Provider .

ind:priorEligibilityMedicaidEligibilityId rdf:type rdf:Property ;
    rdfs:label 'Prior Eligibility Medicaid Eligibility Id' ;
    rdfs:comment 'Reference to the previous eligibility record for continuity tracking.' ;
    rdfs:domain ind:MedicaidEligibility ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MedicaidEligibility .

ind:assetsAmount rdf:type rdf:Property ;
    rdfs:label 'Assets Amount' ;
    rdfs:comment 'Total countable assets reported for eligibility assessment.' ;
    rdfs:domain ind:MedicaidEligibility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dualEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Dual Eligible Flag' ;
    rdfs:comment 'Indicates whether the member is also eligible for Medicare.' ;
    rdfs:domain ind:MedicaidEligibility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:eligibilityCategory rdf:type rdf:Property ;
    rdfs:label 'Eligibility Category' ;
    rdfs:comment 'Classification of Medicaid eligibility based on income and other criteria.' ;
    rdfs:domain ind:MedicaidEligibility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eligibilityDeterminationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Eligibility Determination Timestamp' ;
    rdfs:comment 'Exact date and time when the eligibility determination was made.' ;
    rdfs:domain ind:MedicaidEligibility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:eligibilityNotes rdf:type rdf:Property ;
    rdfs:label 'Eligibility Notes' ;
    rdfs:comment 'Free-text notes captured by eligibility staff during determination.' ;
    rdfs:domain ind:MedicaidEligibility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eligibilityNumber rdf:type rdf:Property ;
    rdfs:label 'Eligibility Number' ;
    rdfs:comment 'Business reference number for the eligibility determination, used in reporting and external communications.' ;
    rdfs:domain ind:MedicaidEligibility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eligibilityReasonCode rdf:type rdf:Property ;
    rdfs:label 'Eligibility Reason Code' ;
    rdfs:comment 'Standard code indicating the reason for eligibility determination (e.g., income, disability).' ;
    rdfs:domain ind:MedicaidEligibility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eligibilityVerificationDate rdf:type rdf:Property ;
    rdfs:label 'Eligibility Verification Date' ;
    rdfs:comment 'Date on which eligibility information was verified.' ;
    rdfs:domain ind:MedicaidEligibility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:eligibilityVerificationMethod rdf:type rdf:Property ;
    rdfs:label 'Eligibility Verification Method' ;
    rdfs:comment 'Method used to verify eligibility information.' ;
    rdfs:domain ind:MedicaidEligibility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:federalProgramIndicator rdf:type rdf:Property ;
    rdfs:label 'Federal Program Indicator' ;
    rdfs:comment 'True if the eligibility is linked to a federal program such as Medicare.' ;
    rdfs:domain ind:MedicaidEligibility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fplPercentage rdf:type rdf:Property ;
