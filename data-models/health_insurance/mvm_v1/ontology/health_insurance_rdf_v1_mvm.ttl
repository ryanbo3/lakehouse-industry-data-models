    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordCount rdf:type rdf:Property ;
    rdfs:label 'Record Count' ;
    rdfs:comment 'Total number of individual risk adjustment records submitted in the batch.' ;
    rdfs:domain ind:CmsSubmission ;
    rdf:type owl:DatatypeProperty ;
