ind:auditFindingId rdf:type rdf:Property ;
    rdfs:label 'Audit Finding Id' ;
    rdfs:comment 'Foreign key linking to compliance.audit_finding. Business justification: Compliance audits of grievance handling produce audit findings referencing specific grievances (e.g., pattern of wrongful denials). Compliance officers and regulators require direct linkage between a ' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AuditFinding .

ind:careCoordinatorId rdf:type rdf:Property ;
    rdfs:label 'Care Coordinator Id' ;
    rdfs:comment 'Foreign key linking to care.coordinator. Business justification: Care coordinator grievance tracking: members file grievances about specific care coordinators (quality of care coordination, communication failures). The grievance must reference the coordinator for p' ;
    rdfs:domain ind:Appeal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Coordinator .

ind:premiumInvoiceId rdf:type rdf:Property ;
    rdfs:label 'Premium Invoice Id' ;
    rdfs:comment 'Foreign key linking to billing.premium_invoice. Business justification: Grievance filings often concern billing errors; linking grievance to the premium invoice provides the basis for investigation and compliance tracking.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PremiumInvoice .

ind:acknowledgmentDate rdf:type rdf:Property ;
