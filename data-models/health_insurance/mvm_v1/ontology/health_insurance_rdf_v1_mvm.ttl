    rdfs:comment 'Indicates whether the diagnosis is excluded from the current model year.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isMapped rdf:type rdf:Property ;
    rdfs:label 'Is Mapped' ;
    rdfs:comment 'True if the ICD-10 code has a valid HCC mapping in this version.' ;
    rdfs:domain ind:HccMapping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mappingSource rdf:type rdf:Property ;
    rdfs:label 'Mapping Source' ;
    rdfs:comment 'Origin of the mapping data.' ;
    rdfs:domain ind:HccMapping ;
