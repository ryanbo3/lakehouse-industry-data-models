    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contributionWeight rdf:type rdf:Property ;
    rdfs:label 'Contribution Weight' ;
    rdfs:comment 'The weighted coefficient applied to this specific HCC for this member-score combination, reflecting any member-level demographic or plan-type adjustments applied on top of the base HCC coefficient.' ;
    rdfs:domain ind:ScoreHccContribution ;
    rdf:type owl:DatatypeProperty ;
