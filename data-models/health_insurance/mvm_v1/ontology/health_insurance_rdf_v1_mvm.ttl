    rdfs:range xsd:decimal .

ind:grossPremiumAmount rdf:type rdf:Property ;
    rdfs:label 'Gross Premium Amount' ;
    rdfs:comment 'Total premium before adjustments.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:industryRiskFactor rdf:type rdf:Property ;
    rdfs:label 'Industry Risk Factor' ;
    rdfs:comment 'Adjustment factor based on the applicant\'s industry risk profile.' ;
