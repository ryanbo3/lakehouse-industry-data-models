ind:outreachTimestamp rdf:type rdf:Property ;
    rdfs:label 'Outreach Timestamp' ;
    rdfs:comment 'Date and time when the outreach attempt occurred.' ;
    rdfs:domain ind:MemberOutreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:purpose rdf:type rdf:Property ;
    rdfs:label 'Purpose' ;
    rdfs:comment 'Reason for contacting the member, such as enrolling in a program or closing a care gap.' ;
    rdfs:domain ind:MemberOutreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hraId rdf:type rdf:Property ;
    rdfs:label 'Hra Id' ;
    rdfs:comment 'Unique surrogate key for each health risk assessment record.' ;
    rdfs:domain ind:HealthInsurance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Hra .

ind:answeredQuestions rdf:type rdf:Property ;
    rdfs:label 'Answered Questions' ;
    rdfs:comment 'Number of questions answered by the member.' ;
