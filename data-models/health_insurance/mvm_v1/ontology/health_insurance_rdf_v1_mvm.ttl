ind:submissionType rdf:type rdf:Property ;
    rdfs:label 'Submission Type' ;
    rdfs:comment 'Indicates whether the batch was submitted via the Risk Adjustment Processing System (RAPS) or Encounter Data Processing System (EDPS).' ;
