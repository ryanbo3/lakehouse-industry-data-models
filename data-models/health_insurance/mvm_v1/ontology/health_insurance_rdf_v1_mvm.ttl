ind:modelVersion rdf:type rdf:Property ;
    rdfs:label 'Model Version' ;
    rdfs:comment 'Version identifier of the actuarial model used to generate the score (e.g., "CMS-HCC v2023").' ;
    rdfs:domain ind:MemberRiskScore ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentYear rdf:type rdf:Property ;
