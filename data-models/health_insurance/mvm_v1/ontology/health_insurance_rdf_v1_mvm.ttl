ind:assignedReviewQueue rdf:type rdf:Property ;
    rdfs:label 'Assigned Review Queue' ;
    rdfs:comment 'Primary review queue to which the reviewer is assigned. [Moved from um_reviewer: The review queue a reviewer works in is program-specific — a reviewer may work different queues under different UM programs. This attribute is more accurately a property of the reviewer-program assignment than a single static attribute on the reviewer master record. However, if the business treats assigned_review_queue as the reviewer\'s primary/default queue independent of program context, it may remain on um_reviewer. Flag for business stakeholder confirmation.]' ;
    rdfs:domain ind:ReviewerProgramAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentEndDate rdf:type rdf:Property ;
    rdfs:label 'Assignment End Date' ;
    rdfs:comment 'The date on which the reviewer\'s authorization under this UM program expires or is revoked. Null if the assignment is currently active. Enables historical compliance queries.' ;
    rdfs:domain ind:ReviewerProgramAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assignmentStartDate rdf:type rdf:Property ;
    rdfs:label 'Assignment Start Date' ;
    rdfs:comment 'The date on which the reviewer\'s authorization to conduct reviews under this UM program becomes effective. Required for NCQA/URAC compliance auditing to confirm reviewer qualification was in place at time of review.' ;
    rdfs:domain ind:ReviewerProgramAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reviewerRoleInProgram rdf:type rdf:Property ;
    rdfs:label 'Reviewer Role In Program' ;
    rdfs:comment 'The specific functional role the reviewer performs within this UM program (e.g., primary clinical reviewer, peer-to-peer reviewer, medical director sign-off). A reviewer may hold different roles across different programs, so this attribute belongs to the assignment, not the reviewer.' ;
    rdfs:domain ind:ReviewerProgramAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affiliationId rdf:type rdf:Property ;
    rdfs:label 'Affiliation Id' ;
    rdfs:comment 'Primary key for affiliation' ;
    rdfs:domain ind:Affiliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .
