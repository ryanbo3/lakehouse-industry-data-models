    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:networkExclusionDescription rdf:type rdf:Property ;
    rdfs:label 'Network Exclusion Description' ;
    rdfs:comment 'Textual description of exclusions when the exclusion flag is true.' ;
