    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scoreContributionAmount rdf:type rdf:Property ;
    rdfs:label 'Score Contribution Amount' ;
    rdfs:comment 'The RAF unit amount this HCC contributes to the member\'s total risk score for the payment year. Equals contribution_weight multiplied by applicable adjustment factors.' ;
    rdfs:domain ind:ScoreHccContribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

