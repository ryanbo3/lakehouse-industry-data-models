ind:dataQualityStatus rdf:type rdf:Property ;
    rdfs:label 'Data Quality Status' ;
    rdfs:comment 'Current data quality assessment of the condition record.' ;
    rdfs:domain ind:Care ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:identificationDate rdf:type rdf:Property ;
    rdfs:label 'Identification Date' ;
    rdfs:comment 'Date the condition was first identified for the member.' ;
    rdfs:domain ind:ConditionRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:identificationMethod rdf:type rdf:Property ;
    rdfs:label 'Identification Method' ;
    rdfs:comment 'Method used to identify the condition for the member.' ;
    rdfs:domain ind:ConditionRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isChronic rdf:type rdf:Property ;
    rdfs:label 'Is Chronic' ;
    rdfs:comment 'Flag indicating whether the condition is considered chronic for HEDIS and risk adjustment.' ;
    rdfs:domain ind:ConditionRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:onsetDate rdf:type rdf:Property ;
    rdfs:label 'Onset Date' ;
    rdfs:comment 'Date when the condition first manifested.' ;
    rdfs:domain ind:ConditionRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:populationSegment rdf:type rdf:Property ;
    rdfs:label 'Population Segment' ;
    rdfs:comment 'Segment of the member population based on the condition\'s risk level.' ;
    rdfs:domain ind:ConditionRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskAdjustmentFlag rdf:type rdf:Property ;
