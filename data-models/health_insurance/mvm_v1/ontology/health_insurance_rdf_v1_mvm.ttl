    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalClaimAmount rdf:type rdf:Property ;
    rdfs:label 'Total Claim Amount' ;
    rdfs:comment 'Aggregate dollar amount of all claims included in the submission.' ;
    rdfs:domain ind:CmsSubmission ;
    rdf:type owl:DatatypeProperty ;
