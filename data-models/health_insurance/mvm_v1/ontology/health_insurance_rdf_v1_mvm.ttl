    rdfs:range xsd:string .

ind:networkExclusionFlag rdf:type rdf:Property ;
    rdfs:label 'Network Exclusion Flag' ;
    rdfs:comment 'Indicates whether the network has any excluded providers or services.' ;
    rdfs:domain ind:NetworkConfig ;
