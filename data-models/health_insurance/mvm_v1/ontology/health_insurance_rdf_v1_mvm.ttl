ind:aptcSubsidyId rdf:type rdf:Property ;
    rdfs:label 'Aptc Subsidy Id' ;
    rdfs:comment 'Foreign key linking to billing.aptc_subsidy. Business justification: invoice_line has aptc_subsidy_amount and csr_adjustment_amount fields representing APTC/CSR applied to the line. Linking to aptc_subsidy provides traceability to the member\'s APTC subsidy record for C' ;
