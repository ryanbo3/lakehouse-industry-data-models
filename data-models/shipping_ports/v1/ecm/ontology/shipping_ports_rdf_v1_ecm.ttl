    rdfs:comment 'Master reference table for facility. Referenced by facility_id.' .

ind:AllocationCycle rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Allocation Cycle' ;
    rdfs:comment 'Master reference table for allocation_cycle. Referenced by allocation_cycle_id.' .

ind:InvestmentProgram rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Investment Program' ;
    rdfs:comment 'Master reference table for investment_program. Referenced by investment_program_id.' .

